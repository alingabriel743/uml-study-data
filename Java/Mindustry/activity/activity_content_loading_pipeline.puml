@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
    StartColor #212529
    EndColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Content Loading Pipeline

|ContentLoader|
start
:ContentLoader() constructor called;
note right
  Allocate contentMap: Seq<Content>[]
  Allocate contentNameMap: ObjectMap[]
  — one slot per ContentType ordinal —
end note
:For each ContentType in ContentType.all:\n  contentMap[type.ordinal()] = new Seq<>()\n  contentNameMap[type.ordinal()] = new ObjectMap<>();

|ContentLoader|
:createBaseContent();
note right
  Each static load() call below
  instantiates Content objects;
  constructors auto-register them
end note

|Base Content|
:UnitCommand.loadAll();
:TeamEntries.load();
:Items.load();
:UnitStance.loadAll();
note right: Depends on Items being loaded first
:StatusEffects.load();
:Liquids.load();
:Bullets.load();
:UnitTypes.load();
:Blocks.load();
:Loadouts.load();
:Weathers.load();
:Planets.load();
:SectorPresets.load();
:SerpuloTechTree.load();
:ErekirTechTree.load();

|Registration|
note right
  Auto-triggered by every
  Content subclass constructor
end note
:Content() constructor:\n  id = contentMap[type].size\n  Vars.content.handleContent(this);
:handleContent():\n  lastAdded = content\n  contentMap[type.ordinal()].add(content);

if (Is MappableContent subclass?) then (yes)
  :MappableContent() constructor:\n  name = transformName(name)\n  handleMappableContent(this);
  if (Name already in contentNameMap?) then (yes)
    :Remove content from contentMap list;
    :throw IllegalArgumentException\n(name collision);
    stop
  else (no)
    if (Content is from a mod?) then (yes)
      :Set minfo.mod = currentMod\nSet sourceFile if null;
    else (no — vanilla)
    endif
    :contentNameMap[type.ordinal()].put(name, content)\nnameMap.put(name, content);
  endif
else (no — non-mappable)
endif

|ContentLoader|
:createModContent();
if (mods != null?) then (yes)
  |Mod System|
  :mods.loadContent();
  note right
    Mod content constructors run;
    same registration flow as above
    (phase 2a) applies for each mod item
  end note
  |ContentLoader|
else (no)
  :Skip mod content loading;
endif

:init();
note right: initialize() guard prevents double-init
|Lifecycle|
:For each ContentType, for each Content:\n  content.init();
:For each ContentType, for each Content:\n  content.postInit();
note right
  UnlockableContent.postInit:
    set databaseCategory fallback
    set databaseTag fallback
    populate databaseTabs from shownPlanets
end note
if (Error during init/postInit?) then (yes)
  if (Content from mod?) then (yes)
    :Log.err(e)\nmods.handleContentError(content, e);
    note right: Soft fail — continue loading
  else (no — vanilla)
    :throw RuntimeException(e);
    stop
  endif
else (no)
endif

|ContentLoader|
if (logicVars != null?) then (yes)
  :logicVars.init();
else (no)
endif
:Events.fire(new ContentInitEvent());

if (Client mode?) then (yes)
  |Asset System|
  :initialize(Content::loadIcon);
  note right
    UnlockableContent.loadIcon:
      resolve fullIcon from atlas
      (tries fullOverride → type-name-full
       → name-full → name → type-name
       → name+1 fallback chain)
      uiIcon = atlas.find(type-name-ui,
               fallback: fullIcon)
  end note
  :initialize(Content::load);
  note right: Load sounds, texture regions, etc.

  |ContentLoader|
  :loadColors();
  |Asset System|
  :Load Pixmap from 'sprites/block_colors.png';
  :For each pixel column i where blocks().size > i:;
  repeat
    :Read RGBA color at pixel (i, 0);
    if (color == 0 or 255?) then (yes)
      :Skip — no map color for block(i);
    else (no)
      :block(i).mapColor.rgba8888(color);
      if (mapColor.a > 0.5f?) then (yes)
        :block(i).squareSprite = true;
      else (no)
      endif
      :block(i).mapColor.a = 1f\nblock(i).hasColor = true;
    endif
  repeat while (more pixel columns?) is (yes)
  -> no;
  :pixmap.dispose();
  :ColorMapper.load();
else (no — headless server)
  note right: load(), loadIcon(), loadColors() skipped
endif

|ContentLoader|
:logContent();
|Validation|
:For each ContentType:\n  assert arr.get(i).id == i for all i;
note right: Throws if ID ordering is corrupted
:Log count per ContentType;
:Log total content count;

|ContentLoader|
stop

@enduml
