@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF9C4
    DiamondBorderColor #F9A825
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontStyle bold
}
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #F9A825

title Crash Handling & Error Reporting

|#E3F2FD|Launcher / Entry Point|
start
:Uncaught exception thrown at runtime;

if (Platform?) then (Android / iOS)

  |#E8F5E9|Android & iOS|
  :UncaughtExceptionHandler fires\n(Thread.setDefaultUncaughtExceptionHandler)\nor iOS catch(Throwable);
  |#FFF8E1|CrashHandler|
  :CrashHandler.log(exception);
  :writeException(exception)\n→ stack trace to string;
  :createReport(exception)\n→ build compact report content;
  |#F3E5F5|File System|
  :Write to crashes/crash_<ms>.txt\n(silent — no UI dialog);
  stop

elseif (Platform?) then (Server / Headless)

  |#FFEBEE|Server / Headless|
  :HeadlessApplication crash callback fires\n(registered via lambda in ServerLauncher.main());
  note right
    writeListener = f -> {}
    No-op — headless server
    shows no user dialog
  end note
  :CrashHandler.handle(throwable, no-op listener);
  |#FFF8E1|CrashHandler|

else (Desktop)

  |#FCE4EC|DesktopLauncher|
  :catch(Throwable e) →\nDesktopLauncher.handleCrash(e);
  :Analyse exception message string\nfor GPU / graphics failure keywords;

  if (Message contains\n'Couldn\'t create window',\n'OpenGL 2.0', 'pixel format',\nor 'GLEW'?) then (yes)
    :Show GPU graphics error message\nvia ErrorDialog / message();
    :Set badGPU = true;
  else (no)
  endif

  :CrashHandler.getModCause(exception);
  |#FFF8E1|CrashHandler|
  :Scan each stack frame class name;\nmatch against mods.list() by\npackage-prefix or JS filename pattern;
  |#FCE4EC|DesktopLauncher|

  if (Responsible mod identified\n(LoadedMod returned)?) then (yes)
    :causeString =\n'<ModName> has caused\nMindustry to crash...';
  elseif (Stack trace contains 'rhino.gen.'?) then (yes)
    :causeString =\n'A mod or script has caused\nMindustry to crash...';
  else (no mod detected)
    :causeString = 'Mindustry has crashed.';
  endif

  :CrashHandler.handle(exception, writeListener);
  |#FFF8E1|CrashHandler|

endif

' ── Shared CrashHandler.handle pipeline ───────────────────────────────
|#FFF8E1|CrashHandler|
:Log.err(exception) → console and log file;
:settings.manualSave()\n→ attempt to preserve game state;

if (Dev build?\n(OS.username = 'anuke'\n&& modifier ≠ 'steam')) then (yes)
  :System.exit(1)\n[skip crash report — developer machine];
  stop
else (no)
endif

if (Version.number == 0\n(not yet loaded)?) then (yes)
  :Read version from\n/version.properties resource;
else (no)
endif

:Build crash file path:\ncrashes/crash-report-<MM_dd_yyyy_HH_mm_ss>.txt;

|#F3E5F5|File System|
:new Fi(...).child('crashes').mkdirs()\n→ ensure directory exists;

|#FFF8E1|CrashHandler|
:CrashHandler.createReport(exception);

note right
  Report content includes:
  • Header: mod-caused or vanilla crash
  • Issue report URL (no mods + official build only)
  • Version, date, OS, GL version
  • Java version, memory, CPU cores
  • Likely mod cause (if any)
  • Enabled mods list + patches
  • Full stack trace
end note

|#F3E5F5|File System|
:Write full report to crash file;

|#FFF8E1|CrashHandler|
:writeListener.get(file)\n[invoke platform callback with File ref];
:net.dispose()\n→ close all network connections;

' ── Post-write user notification ─────────────────────────────────────
if (Desktop path\n&& badGPU == false?) then (yes)
  |#FCE4EC|DesktopLauncher|
  :writeListener callback executes;
  |#E8EAF6|User Notification|
  :Show error dialog:\ncauseString +\n"The logs have been saved in:\\n<filePath>"\n(SDL_ShowSimpleMessageBox;\nfallback: JOptionPane.showMessageDialog);
else (no — Server or GPU crash)
  note right
    Server: no-op callback, no dialog
    GPU crash: message shown earlier;
    dialog skipped here
  end note
endif

|#FFF8E1|CrashHandler|
:System.exit(1);
stop

' ── Pre-launch ErrorDialog fast-path (not part of main crash pipeline) ─
note as N1
  **Pre-launch ErrorDialog fast-path**
  (invoked before crash handler is needed)
  • 32-bit Windows detected
  • Java version too old
  → ErrorDialog.show(text):
    1. Log.err(text)
    2. SDL_ShowSimpleMessageBox (or JOptionPane)
    3. System.exit(1)
end note

@enduml
