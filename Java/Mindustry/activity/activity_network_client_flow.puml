@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
    StartColor #212529
    EndColor #212529
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 12
}
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F0C040

title Network Client Connection & Sync

|#DDEEFF|UI / Application|
|#D5F5E3|ArcNetProvider / NetListener|
|#FDEBD0|NetClient|
|#F9EBEA|NetworkIO|
|#EAD7F5|PacketSerializer|

|UI / Application|
start
:UI calls ArcNetProvider.connectClient(ip, port, success);
:Daemon thread: client.stop() [cleanup previous connection];
:Spawn 'Net Client' daemon thread: client.run();

|ArcNetProvider / NetListener|
:client.connect(5000, ip, port, port)
[TCP + UDP, 5s timeout];

if (Connection successful?) then (yes)
    :success.run() callback;

    note right
      NetListener.connected() fires
      on successful TCP handshake
    end note

    :Build Connect packet with
    addressTCP from getRemoteAddressTCP();
    :Post to main thread:
    net.handleClientReceived(Connect);

    |NetClient|
    :**[Handle: Connect.class]**
    reset(): clears removed set, Groups, chat
    connecting=true, quiet=false, clientLoaded=false;

    if (net.client() still active?) then (no)
        :disconnectQuietly();
        stop
    else (yes)
    endif

    :Show loadfrag '@connecting.data'
    with cancel button;
    :Build ConnectPacket:
    name, locale, mods, mobile,
    versionType, color, usid, uuid;

    if (UUID != null?) then (no)
        :showErrorMessage('@invalidid');
        :disconnectQuietly();
        stop
    else (yes)
    endif

    |PacketSerializer|
    note right
      WRITE path:
      write id byte → serialize to temp buffer
      write length (short)
      if length >= 36: LZ4 compress (flag=1)
      else: write uncompressed (flag=0)
    end note

    |NetClient|
    :net.send(ConnectPacket, reliable=true) [TCP];

else (no — timeout/error)
    |ArcNetProvider / NetListener|
    if (isConnecting()?) then (yes)
        :net.handleException(e);
    endif
    stop
endif

' ─── Phase 3: World Data Receipt ───────────────────────────────

|NetClient|
:Server triggers @Remote worldDataBegin;
:Groups.clear(), removed.clear(), logic.reset()
connecting=true, net.setClientLoaded(false)
Show loadfrag '@connecting.data';

note right
  Server streams WorldStream via TCP:
  StreamBegin(total, type) + StreamChunk[]
  via ArcConnection.sendStream (InputStreamSender)
end note

:**[Handle: WorldStream.class]**
Decompress: InflaterInputStream(data.stream);

|NetworkIO|
:**NetworkIO.loadWorld()**;
:DataInputStream wraps InflaterInputStream;
:Time.clear();
:state.rules = JsonIO.read(Rules.class, readUTF())
state.mapLocales = JsonIO.read(MapLocales.class, readUTF())
state.map = new Map(SaveWriter.readStringMap(stream));
:Read: wave (int), wavetime (float), tick (double)
Read: GlobalVars rand.seed0 / seed1 (longs);
:Groups.clear(); player.reset()
player.read(read); player.id=id; player.add();

fork
    :SaveWriter.readContentHeader(stream)
    SaveWriter.readContentPatches(stream);
fork again
    :SaveWriter.readMap(stream, world.context)
    SaveWriter.readTeamBlocks(stream);
fork again
    :SaveWriter.readMarkers(stream)
    SaveWriter.readCustomChunks(stream);
end fork

:content.setTemporaryMapper(null)
[finally block — always executed];

' ─── Phase 3b: finishConnecting ────────────────────────────────

|NetClient|
:**finishConnecting()**;
:state.set(State.playing)
connecting = false;
:ui.join.hide()
net.setClientLoaded(true);
:Core.app.post(Call::connectConfirm)
[deferred to next frame — notifies server];
:Time.runTask(40f, platform::updateRPC)
Core.app.post(ui.loadfrag::hide);
:lastSnapshotTimestamp = Time.millis();

' ─── Phase 4: Ongoing Update Loop ──────────────────────────────

note right
  === IN-GAME STATE ===
  NetClient.update() called each frame
end note

:NetClient.update() — frame loop;

if (net.client() && state.isGame() && !connecting?) then (yes)
    :sync();
    fork
        :Every 66 ms:
        Call.clientSnapshot(lastSent++,
        unitId, dead, x, y, aimX, aimY,
        rotation, baseRotation, velX, velY,
        mineTile, boosting, shooting,
        chatShown, isBuilding, selectedBlock,
        selectedRotation, plans, camX/Y/W/H)
        [outbound UDP — unreliable];
    fork again
        :Every 1 s:
        Call.ping(Time.millis())
        [TCP round-trip latency];
    fork again
        :Every 0.5 s:
        getSyncedPlans(plansOut)
        chunk into max 75-plan batches
        Call.clientPlanSnapshot(id, plans)
        [TCP — build plans];
    end fork

else (no)
    if (!net.client() && !connecting?) then (yes)
        :net.disconnect();
        stop
    else (connecting timeout?)
        :timeoutTime += delta;
        if (timeoutTime > dataTimeout 30s?) then (yes)
            :disconnect with '@disconnect.data';
            stop
        else (no)
        endif
    endif
endif

' ─── Phase 6: Server Snapshots ─────────────────────────────────

|ArcNetProvider / NetListener|
note right
  Server sends snapshots via UDP (unreliable, low priority)
end note

fork
    :**@Remote entitySnapshot(amount, data)**
    [UDP, low priority];
    :lastSnapshotTimestamp = Time.millis();
    :Loop amount times: readSyncEntity(input, reads)
    — read id(int) + typeID(byte);
    if (entity == null && id == player.id?) then (yes)
        :entity = player; add = true;
    else (no)
        if (entity == null?) then (yes)
            :EntityMapping.map(typeID).get()
            creates new entity;
        endif
    endif
    :entity.readSync(read);
    if (Newly created?) then (yes)
        :entity.snapSync() [snap initial position];
    endif
    if (Should add to world?) then (yes)
        :entity.add(); addRemovedEntity(id);
    endif
fork again
    :**@Remote hiddenSnapshot(IntSeq ids)**;
    :entity.handleSyncHidden() for each id;
fork again
    :**@Remote blockSnapshot(amount, data)**
    [UDP];
    :Read pos + blockId
    tile.build.readSync(reads, version);
fork again
    :**@Remote stateSnapshot(...)**;
    :Update state.wave / wavetime / gameOver
    enemies / serverTps / rand seeds;
    if (!state.isMenu()?) then (yes)
        :Set paused/playing state;
    endif
    :Read team core item data per team;
end fork

' ─── Phase 7: Snapshot Timeout ─────────────────────────────────

|NetClient|
if (lastSnapshotTimestamp > 0 AND
timeSinceMillis > 20 000 ms?) then (yes)
    :Log.err("Timed out — no UDP snapshots");
    :quiet = true
    ui.showErrorMessage('@disconnect.snapshottimeout');
    :net.disconnect()
    lastSnapshotTimestamp = 0;
    stop
else (no)
endif

' ─── Phase 8: Disconnect / Kick Handling ────────────────────────

|ArcNetProvider / NetListener|
:**NetListener.disconnected() fires**;
if (lastProtocolError != null?) then (yes)
    :netClient.setQuiet();
endif
:Build Disconnect(reason)
post net.handleClientReceived(Disconnect);

|NetClient|
:**[Handle: Disconnect.class]**;
if (quietReset?) then (yes)
    :return [silent — no dialog, no state change];
    stop
else (no)
endif
:connecting = false
logic.reset()
platform.updateRPC();
if (quiet?) then (yes)
    :return [suppress dialog];
    stop
else (no)
    :Show disconnect reason dialog
    (closed / timeout / error);
    stop
endif

' ─── Kick path ──────────────────────────────────────────────────

|NetClient|
detach

:**@Remote kick(KickReason)**;
:disconnectQuietly()
logic.reset();
if (reason == serverRestarting?) then (yes)
    :ui.join.reconnect() [auto-reconnect];
    stop
else (no)
    if (reason.quiet?) then (yes)
        :return [no dialog];
        stop
    else (no)
        :Show kick reason dialog;
        stop
    endif
endif

@enduml
