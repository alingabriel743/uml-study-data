@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
}

title AI & Unit Controllers

' ─────────────────────────────────────────────
' External base class (referenced, not detailed)
' ─────────────────────────────────────────────
abstract class MappableContent {
    +int id
    +ContentType getContentType()
}

' ─────────────────────────────────────────────
' Package: mindustry.entities.units
' ─────────────────────────────────────────────
package "mindustry.entities.units" {

    interface UnitController {
        +void unit(Unit unit)
        +Unit unit()
        +default void hit(Bullet bullet)
        +default boolean isValidController()
        +default boolean isLogicControllable()
        +default void updateUnit()
        +default void removed(Unit unit)
        +default void afterRead(Unit unit)
    }

    class AIController {
        #Unit unit
        #Interval timer
        #AIController fallback
        #float noTargetTime
        #Teamc target
        #Teamc bomberTarget
        #boolean turningAway
        --
        +void updateUnit()
        +void updateVisuals()
        +void updateTargeting()
        +void updateMovement()
        +void updateWeapons()
        +Teamc findTarget(float x, float y, float range, boolean air, boolean ground)
        +Teamc findMainTarget(float x, float y, float range, boolean air, boolean ground)
        +boolean retarget()
        +boolean checkTarget(Teamc target, float x, float y, float range)
        +boolean shouldFire()
        +boolean shouldShoot()
        +boolean useFallback()
        +AIController fallback()
        +boolean hasStance(UnitStance stance)
        +boolean keepState()
        +void pathfind(int pathTarget, boolean stopAtTarget, boolean avoidance)
        +void moveTo(Position target, float circleLength, ...)
        +void circleAttack(float circleLength)
        +void faceTarget()
        +void commandTarget(Teamc moveTo)
        +void commandPosition(Vec2 pos)
        +void stopShooting()
        +float prefSpeed()
        +void init()
    }

}

' ─────────────────────────────────────────────
' Package: mindustry.ai.types
' ─────────────────────────────────────────────
package "mindustry.ai.types" {

    class GroundAI {
        -float stuckTime
        -float stuckX
        -float stuckY
        --
        +void updateMovement()
    }
    note right of GroundAI
        Pathfinds to enemy core.
        Stuck detection notifies
        nearby GroundAI units.
    end note

    class SuicideAI {
    }

    class FlyingAI {
        --
        +void updateMovement()
        +Teamc findTarget(float x, float y, float range, boolean air, boolean ground)
        +Teamc findMainTarget(float x, float y, float range, boolean air, boolean ground)
    }
    note right of FlyingAI
        Target priority:
        enemy core → random flags
        → unit.type.targetFlags
    end note

    class FlyingFollowAI {
        -Teamc following
        --
        +void updateMovement()
        +void updateVisuals()
        +boolean shouldFaceTarget()
        +AIController fallback()
        +boolean useFallback()
    }
    note bottom of FlyingFollowAI
        Wave-team escort AI.
        useFallback()=true in PvP
        → fallback()=new FlyingAI()
    end note

    class CommandAI {
        -Seq<Position> commandQueue
        -Vec2 targetPos
        -Teamc attackTarget
        -UnitGroup group
        -UnitCommand command
        -Bits stances
        #AIController commandController
        --
        +void updateUnit()
        +void defaultBehavior()
        +boolean hasStance(UnitStance stance)
        +void setStance(UnitStance stance)
        +void disableStance(UnitStance stance)
        +void command(UnitCommand command)
        +void commandTarget(Teamc moveTo)
        +void commandPosition(Vec2 pos)
        +void commandQueue(Position location)
        +void clearCommands()
        +void finishPath()
        +boolean shouldFire()
        +Teamc findTarget(...)
        +Teamc findMainTarget(...)
        +boolean retarget()
        +boolean keepState()
        +boolean isLogicControllable()
        +void hit(Bullet bullet)
        +void afterRead(Unit unit)
    }
    note right of CommandAI
        Player-command bridge.
        Holds commandController
        (from UnitCommand factory).
        Stance bits control behavior.
    end note

    class BoostAI {
    }

    class RepairAI {
    }

    class BuilderAI {
        -boolean onlyAssist
    }

    class MinerAI {
    }

}

' ─────────────────────────────────────────────
' Package: mindustry.ai
' ─────────────────────────────────────────────
package "mindustry.ai" {

    class UnitStance {
        +String icon
        +KeyBind keybind
        +Seq<UnitCommand> incompatibleCommands
        +Seq<UnitStance> incompatibleStances
        +boolean toggle
        +Bits incompatibleStanceBits
        +Bits incompatibleCommandBits
        --
        +void init()
        +boolean isCompatible(UnitCommand other)
        +String localized()
        +ContentType getContentType()
        +{static} void loadAll()
    }
    note bottom of UnitStance
        Static instances: stop, holdFire,
        pursueTarget, patrol, ram, boost,
        holdPosition, mineAuto
    end note

    class UnitCommand {
        +String icon
        +Func<Unit,AIController> controller
        +boolean switchToMove
        +boolean drawTarget
        +boolean resetTarget
        +boolean exactArrival
        +KeyBind keybind
        +Seq<UnitStance> extraStances
        --
        +String localized()
        +ContentType getContentType()
        +{static} void loadAll()
    }
    note bottom of UnitCommand
        Static instances: moveCommand,
        repairCommand→RepairAI,
        rebuildCommand→BuilderAI,
        mineCommand→MinerAI,
        loopPayloadCommand, ...
    end note

}

' ─────────────────────────────────────────────
' Inheritance relationships
' ─────────────────────────────────────────────
AIController          ..|> UnitController

GroundAI              --|> AIController
FlyingAI              --|> AIController
CommandAI             --|> AIController
BoostAI               --|> AIController
RepairAI              --|> AIController
BuilderAI             --|> AIController
MinerAI               --|> AIController

SuicideAI             --|> GroundAI
FlyingFollowAI        --|> FlyingAI

UnitStance            --|> MappableContent
UnitCommand           --|> MappableContent

' ─────────────────────────────────────────────
' Composition / association relationships
' ─────────────────────────────────────────────
AIController "1" o-- "0..1" AIController : fallback\n(nullable)
AIController "1" o-- "0..1" Teamc          : target\n(nullable)

CommandAI "1" *-- "1"   UnitCommand    : command
CommandAI "1" o-- "0..1" AIController  : commandController\n(from UnitCommand.controller)

UnitCommand ..> AIController : <<creates via\ncontroller factory>>

UnitStance  "1" ..> UnitCommand : incompatibleCommandBits\n(by ID ref)
UnitStance  "1" ..> UnitStance  : incompatibleStanceBits\n(by ID ref)

@enduml
