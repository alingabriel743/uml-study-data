@startuml block_defense_and_turrets

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}
skinparam abstractClass {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
}

title Block Defense & Turret System

' ─────────────────────────────────────────
'  Interfaces
' ─────────────────────────────────────────
interface Ranged {
    +range() : float
}
interface RotBlock {
    +buildRotation() : float
}
interface ControlBlock {
    +unit() : BlockUnitc
    +isActive() : boolean
}

' ─────────────────────────────────────────
'  Block Definition Hierarchy
' ─────────────────────────────────────────
package "Block Definitions" {

    abstract class Block {
    }

    class BaseTurret {
        +float range
        +float rotateSpeed
        +float activationTime
        +float coolantMultiplier
        +Effect coolEffect
        +ConsumeLiquidBase coolant
        --
        +init()
        +setStats()
        +setBars()
        +drawPlace(x, y, rotation, valid)
    }

    class ReloadTurret {
        +float reload
    }

    class Turret {
        +int maxAmmo
        +int ammoPerShot
        +boolean consumeAmmoOnce
        +float inaccuracy
        +float shootCone
        +float minRange
        +float minWarmup
        +float heatRequirement
        +float maxHeatEfficiency
        +boolean targetAir
        +boolean targetGround
        +boolean targetBlocks
        +boolean targetHealing
        +boolean alwaysShooting
        +boolean predictTarget
        +ShootPattern shoot
        +DrawBlock drawer
        +Sound shootSound
        +Sound chargeSound
        +float recoil
        +float cooldownTime
        --
        +init()
        +setStats()
        +setBars()
        +limitRange(BulletType, float)
        +outputsItems() : boolean
    }

    class ItemTurret {
        +ObjectMap<Item, BulletType> ammoTypes
        --
        +ammo(Object... objects)
        +limitRange()
        +init()
        +setStats()
        +setBars()
    }

    class LiquidTurret {
        +ObjectMap<Liquid, BulletType> ammoTypes
        +boolean extinguish
        --
        +ammo(Object... objects)
        +init()
    }

    class PowerTurret {
        +BulletType shootType
        --
        +limitRange(float margin)
        +setStats()
    }
}

' ─────────────────────────────────────────
'  Build Runtime Hierarchy
' ─────────────────────────────────────────
package "Build Runtime" {

    abstract class Building {
    }

    class BaseTurretBuild {
        +float rotation
        +float activationTimer
        --
        +range() : float
        +buildRotation() : float
        +estimateDps() : float
        +drawSelect()
        +status() : BlockStatus
    }

    class ReloadTurretBuild {
        +float reloadCounter
        --
        +updateCooling()
        +ammoReloadMultiplier() : float
        +baseReloadSpeed() : float
        +canReload() : boolean
    }

    class TurretBuild {
        +Seq<AmmoEntry> ammo
        +int totalAmmo
        +Posc target
        +Vec2 targetPos
        +float shootWarmup
        +float curRecoil
        +float heat
        +float charge
        +float logicControlTime
        +int totalShots
        +int barrelCounter
        +int queuedBullets
        +boolean logicShooting
        +boolean wasShooting
        +BlockUnitc unit
        --
        +updateTile()
        +updateShooting()
        +shoot(BulletType)
        +bullet(BulletType, float, float, float, Mover)
        +handleBullet(Bullet, float, float, float)
        +findTarget()
        +findEnemy(float range) : Posc
        +targetPosition(Posc)
        +useAmmo() : BulletType
        +peekAmmo() : BulletType
        +hasAmmo() : boolean
        +isShooting() : boolean
        +validateTarget() : boolean
        +charging() : boolean
        +turnToTarget(float)
        +updateReload()
        +control(LAccess, ...)
        +sense(LAccess) : double
        +range() : float
        +write(Writes) / read(Reads)
    }

    class ItemTurretBuild {
        --
        +handleItem(Building, Item)
        +acceptItem(Building, Item) : boolean
        +updateTile()
        +senseObject(LAccess)
        +write(Writes) / read(Reads)
    }

    class LiquidTurretBuild {
        --
        +useAmmo() : BulletType
        +peekAmmo() : BulletType
        +hasAmmo() : boolean
        +acceptLiquid(Building, Liquid) : boolean
        +findTarget()
        +updateTile()
        +senseObject(LAccess)
    }

    class PowerTurretBuild {
        --
        +useAmmo() : BulletType
        +hasAmmo() : boolean
        +peekAmmo() : BulletType
        +sense(LAccess) : double
    }
}

' ─────────────────────────────────────────
'  Ammo Entry Types
' ─────────────────────────────────────────
package "Ammo Model" {

    abstract class AmmoEntry {
        +int amount
        --
        +{abstract} type() : BulletType
    }

    class ItemEntry {
        +Item item
        --
        +type() : BulletType
    }

    class BulletEntry {
        +float x
        +float y
        +float rotation
        +float life
    }
}

' ─────────────────────────────────────────
'  External Collaborators
' ─────────────────────────────────────────
class ShootPattern {
    +int shots
    +float firstShotDelay
    --
    +shoot(barrelCounter, callback)
}

class DrawBlock {
    --
    +draw(Building)
    +drawPlan(...)
    +icons()
    +getRegionsToOutline()
}

class BulletType {
    +float rangeChange
    +float ammoMultiplier
    --
    +create(owner, team, x, y, angle, ...) : Bullet
}

' ─────────────────────────────────────────
'  Block Definition Inheritance
' ─────────────────────────────────────────
BaseTurret    --|> Block
ReloadTurret  --|> BaseTurret
Turret        --|> ReloadTurret
ItemTurret    --|> Turret
LiquidTurret  --|> Turret
PowerTurret   --|> Turret

' ─────────────────────────────────────────
'  Build Runtime Inheritance
' ─────────────────────────────────────────
BaseTurretBuild   --|> Building
ReloadTurretBuild --|> BaseTurretBuild
TurretBuild       --|> ReloadTurretBuild
ItemTurretBuild   --|> TurretBuild
LiquidTurretBuild --|> TurretBuild
PowerTurretBuild  --|> TurretBuild

' ─────────────────────────────────────────
'  Interface Implementations
' ─────────────────────────────────────────
BaseTurretBuild ..|> Ranged
BaseTurretBuild ..|> RotBlock
TurretBuild     ..|> ControlBlock

' ─────────────────────────────────────────
'  Ammo Entry Inheritance
' ─────────────────────────────────────────
ItemEntry --|> AmmoEntry

' ─────────────────────────────────────────
'  Key Associations
' ─────────────────────────────────────────
TurretBuild  *-- "0..*" AmmoEntry   : ammo stack
TurretBuild  o--  ShootPattern      : shoot (pattern)
TurretBuild  o--  DrawBlock         : drawer (rendering)
TurretBuild ..>   BulletType        : creates bullets

ItemTurretBuild ..> ItemEntry       : manages
LiquidTurretBuild ..> BulletType    : resolves via\nliquid ammoTypes
PowerTurretBuild  o-- BulletType    : shootType (fixed)

Turret       o--  ShootPattern      : shoot
Turret       o--  DrawBlock         : drawer

@enduml
