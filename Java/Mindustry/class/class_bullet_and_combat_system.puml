@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Bullet & Combat System

' ─────────────────────────────────────────────
' External / shared types
' ─────────────────────────────────────────────
package "mindustry.content" #EDE7F6 {
    abstract class Content {
    }
}

package "mindustry.type" #E3F2FD {
    class StatusEffect {
    }
    class UnitType {
    }
}

package "mindustry.world.blocks.defense" #E8F5E9 {
    class Damage <<utility>> {
        +{static} collideLaser(b, length, largeHit, laserAbsorb, pierceCap): void
        +{static} collideLine(b, team, x, y, rot, length, largeHit, laserAbsorb, pierceCap): void
        +{static} damage(team, x, y, radius, damage): void
        +{static} createIncend(x, y, radius, amount): void
        +{static} applySuppression(...): void
    }
}

package "mindustry.entities" #FFF3E0 {
    class Lightning <<utility>> {
        +{static} create(team, type, damage, x, y, rotation, length): void
    }
}

' ─────────────────────────────────────────────
' BulletType hierarchy
' ─────────────────────────────────────────────
package "mindustry.entities.bullet" {

    class BulletType {
        ' --- core stats ---
        +damage: float
        +speed: float
        +lifetime: float
        +hitSize: float
        +range: float
        ' --- pierce ---
        +pierce: boolean
        +pierceBuilding: boolean
        +pierceCap: int
        +pierceDamageFactor: float
        ' --- splash ---
        +splashDamage: float
        +splashDamageRadius: float
        +splashDamagePierce: boolean
        ' --- status / heal ---
        +status: StatusEffect
        +statusDuration: float
        +healPercent: float
        +healAmount: float
        +lifesteal: float
        ' --- secondary effects ---
        +fragBullet: BulletType
        +fragBullets: int
        +intervalBullet: BulletType
        +lightningType: BulletType
        +spawnBullets: Seq<BulletType>
        +spawnUnit: UnitType
        +despawnUnit: UnitType
        +lightning: int
        +incendAmount: int
        ' --- movement / collision ---
        +homingPower: float
        +keepVelocity: boolean
        +scaleLife: boolean
        +sticky: boolean
        +collides: boolean
        +collidesAir: boolean
        +collidesGround: boolean
        +despawnHit: boolean
        ' --- damage multipliers ---
        +buildingDamageMultiplier: float
        +shieldDamageMultiplier: float
        +armorMultiplier: float
        +pierceArmor: boolean
        ' --- lifecycle ---
        +create(...): Bullet
        +init(b: Bullet): void
        +update(b: Bullet): void
        +hit(b: Bullet, x: float, y: float, createFrags: boolean): void
        +hitEntity(b: Bullet, entity: Hitboxc, health: float): void
        +hitTile(b: Bullet, build: Building, x: float, y: float, initialHealth: float, direct: boolean): void
        +handlePierce(b: Bullet, initialHealth: float, x: float, y: float): void
        +despawned(b: Bullet): void
        +removed(b: Bullet): void
        +createFrags(b: Bullet, x: float, y: float): void
        +createSplashDamage(b: Bullet, x: float, y: float): void
        +createIncend(b: Bullet, x: float, y: float): void
        +draw(b: Bullet): void
        +drawLight(b: Bullet): void
        +estimateDPS(): float
        +continuousDamage(): float
        +heals(): boolean
        +damageMultiplier(b: Bullet): float
        #calculateRange(): float
    }

    class BasicBulletType {
        +backColor: Color
        +frontColor: Color
        +width: float
        +height: float
        +shrinkX: float
        +shrinkY: float
        +shrinkInterp: Interp
        +spin: float
        +sprite: String
        +backSprite: String
        +draw(b: Bullet): void
        +load(): void
    }

    class ArtilleryBulletType {
        +trailMult: float
        +trailSize: float
        ' constructor defaults:
        ' collidesTiles=false, collidesAir=false
        ' scaleLife=true, shrinkY=0.5f
        +update(b: Bullet): void
    }

    class MissileBulletType {
        ' homingPower=0.08f (default)
        ' trailChance=0.2f, lifetime=52f
        ' hitSound=Sounds.explosion
    }

    class FlakBulletType {
        +explodeRange: float
        +explodeDelay: float
        +flakDelay: float
        +flakInterval: float
        ' splashDamage=15f, collidesGround=false
        +update(b: Bullet): void
    }

    class ContinuousBulletType {
        +length: float
        +shake: float
        +damageInterval: float
        +largeHit: boolean
        +continuous: boolean
        +timescaleDamage: boolean
        ' speed=0, pierce=true, collides=false
        +update(b: Bullet): void
        +applyDamage(b: Bullet): void
        +continuousDamage(): float
        +currentLength(b: Bullet): float
        #calculateRange(): float
    }

    class ContinuousLaserBulletType {
        +fadeTime: float
        +lightStroke: float
        +divisions: int
        +colors: Color[]
        +strokeFrom: float
        +strokeTo: float
        +width: float
        +oscScl: float
        +oscMag: float
        +backLength: float
        +frontLength: float
        +draw(b: Bullet): void
        +drawLight(b: Bullet): void
        +currentLength(b: Bullet): float
    }

    class LaserBulletType {
        +length: float
        +width: float
        +colors: Color[]
        +lengthFalloff: float
        +lightningSpacing: float
        +lightningDelay: float
        +largeHit: boolean
        ' speed=0, pierce=true, collides=false
        ' delayFrags=true
        +init(b: Bullet): void
        +draw(b: Bullet): void
        +drawLight(b: Bullet): void
        +estimateDPS(): float
        #calculateRange(): float
    }

    class ShrapnelBulletType {
        +length: float
        +width: float
        +fromColor: Color
        +toColor: Color
        +hitLarge: boolean
        +serrations: int
        +serrationLenScl: float
        +serrationWidth: float
        +serrationSpacing: float
        ' speed=0, pierce=true, collides=false
        +init(b: Bullet): void
        +draw(b: Bullet): void
        #calculateRange(): float
    }
}

' ─────────────────────────────────────────────
' Bullet entity (generated)
' ─────────────────────────────────────────────
package "mindustry.gen" {

    interface Timedc
    interface Damagec
    interface Hitboxc
    interface Teamc
    interface Posc
    interface Drawc
    interface Bulletc
    interface Senseable

    class Bullet <<generated entity>> {
        +type: BulletType
        +vel: Vec2
        +team: Team
        +owner: Entityc
        +shooter: Entityc
        +damage: float
        +lifetime: float
        +time: float
        +collided: IntSeq
        +data: Object
        +fdata: float
        +absorbed: boolean
        +hit: boolean
        +trail: Trail
        +frags: int
        +aimX: float
        +aimY: float
        +mover: Mover
        +buildingDamageMultiplier: float
        +stickyTarget: Posc
        +add(): void
        +remove(): void
        +update(): void
        +collision(other: Hitboxc, x: float, y: float): void
        +collides(other: Hitboxc): boolean
        +draw(): void
        +tileRaycast(x1: float, y1: float, x2: float, y2: float): void
        +absorb(): void
        +stickTo(other: Posc): void
        +initVel(angle: float, amount: float): void
        +damageMultiplier(): float
        +hasCollided(id: int): boolean
        +rotation(): float
        +sense(sensor: LAccess): double
    }
}

' ─────────────────────────────────────────────
' Inheritance relationships
' ─────────────────────────────────────────────
Content              <|-- BulletType
BulletType           <|-- BasicBulletType
BasicBulletType      <|-- ArtilleryBulletType
BasicBulletType      <|-- MissileBulletType
BasicBulletType      <|-- FlakBulletType
BulletType           <|-- ContinuousBulletType
ContinuousBulletType <|-- ContinuousLaserBulletType
BulletType           <|-- LaserBulletType
BulletType           <|-- ShrapnelBulletType

' ─────────────────────────────────────────────
' Bullet entity interface implementations
' ─────────────────────────────────────────────
Bullet ..|> Timedc
Bullet ..|> Damagec
Bullet ..|> Hitboxc
Bullet ..|> Teamc
Bullet ..|> Posc
Bullet ..|> Drawc
Bullet ..|> Bulletc
Bullet ..|> Senseable

' ─────────────────────────────────────────────
' Key associations
' ─────────────────────────────────────────────

' Strategy / flyweight: Bullet holds a reference to its BulletType
Bullet *-- BulletType : type (strategy)

' BulletType creates Bullet instances
BulletType ..> Bullet : <<creates>>

' BulletType self-references (frag / interval / lightning sub-bullets)
BulletType o-- BulletType : fragBullet / intervalBullet\nlightningType / spawnBullets

' BulletType status & unit spawning
BulletType --> StatusEffect : status
BulletType --> UnitType     : spawnUnit / despawnUnit

' BulletType delegates heavy math to Damage & Lightning utilities
BulletType ..> Damage   : <<uses>> collideLaser\ncollideLine / splashDamage
BulletType ..> Lightning : <<uses>> create arcs

' Flak also queries nearby units
FlakBulletType ..> Damage : <<uses>> nearbyEnemies scan

' Notes on damage types
note right of BulletType
  **Damage types:**
  • Direct  — b.damage → h.damage()
  • Splash  — Damage.damage() on hit/despawn
  • Laser   — Damage.collideLaser on init
  • Continuous — Damage.collideLine every damageInterval
  • Lightning — Lightning.create() arcs
  • Fire   — Fires.create on tile (makeFire)
  • Status — unit.apply(status, statusDuration)
  • Heal   — build.heal() if heals() && same team
end note

note bottom of Bullet
  **Lifecycle:**
  create() → add() → init()
  → update() [every tick: move, homing, trail]
  → collision() → hit() / hitEntity() / hitTile()
  → remove(): despawned() → removed() [frags, trail fade]
  → draw() → type.draw() + type.drawLight()
end note

@enduml
