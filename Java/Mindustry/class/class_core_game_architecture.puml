@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #856404
}
skinparam interface {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
}

title Core Game Architecture

' ─────────────────────────────────────────────
' Arc framework interfaces / base classes
' ─────────────────────────────────────────────
package "arc (framework)" {

    interface Loadable {
        +loadAsync(): void
        +loadSync(): void
    }

    interface ApplicationListener {
        +update(): void
        +dispose(): void
    }

    interface Platform {
    }

    abstract class ApplicationCore {
        +init(): void
        +update(): void
    }
}

' ─────────────────────────────────────────────
' Entry point
' ─────────────────────────────────────────────
package "mindustry" {

    abstract class ClientLauncher {
        #loader: LoadRenderer
        #finished: boolean
        #nextFrame: long
        +setup(): void
        +update(): void
        +dispose(): void
        +init(): void
    }

    class Vars {
        ' ── static subsystem handles ──
        +{static} content: ContentLoader
        +{static} state: GameState
        +{static} logic: Logic
        +{static} control: Control
        +{static} renderer: Renderer
        +{static} ui: UI
        +{static} net: Net
        +{static} world: World
        +{static} mods: Mods
        +{static} maps: Maps
        +{static} waves: Waves
        +{static} spawner: WaveSpawner
        +{static} pathfinder: Pathfinder
        +{static} asyncCore: AsyncCore
        +{static} universe: Universe
        +{static} player: Player
        ' ── constants ──
        +{static} appName: String = "Mindustry"
        +{static} port: int = 6567
        +{static} tilesize: int = 8
        +{static} defaultEnv: int
        ' ── flags ──
        +{static} headless: boolean
        +{static} mobile: boolean
        +{static} steam: boolean
        +{static} clientLoaded: boolean
        +{static} failedToLaunch: boolean
        ' ── lifecycle ──
        +loadAsync(): void
        +{static} init(): void
        +{static} loadSettings(): void
        +{static} loadLogger(): void
        +{static} checkLaunch(): void
        +{static} finishLaunch(): void
    }
}

' ─────────────────────────────────────────────
' Core subsystems
' ─────────────────────────────────────────────
package "mindustry.core" {

    class GameState {
        +wave: int
        +wavetime: float
        +tick: double
        +updateId: long
        +gameOver: boolean
        +won: boolean
        +enemies: int
        +map: Map
        +rules: Rules
        +stats: GameStats
        +teams: Teams
        +patcher: DataPatcher
        +markers: MapMarkers
        -state: State
        +set(s: State): void
        +getState(): State
        +is(s: State): boolean
        +isPlaying(): boolean
        +isPaused(): boolean
        +isMenu(): boolean
        +isGame(): boolean
        +isCampaign(): boolean
        +hasSector(): boolean
        +getSector(): Sector
        +getPlanet(): Planet
        +isEditor(): boolean
        +boss(): Unit
    }

    enum State {
        paused
        playing
        menu
    }

    class ContentLoader {
        -contentNameMap: ObjectMap[]
        -contentMap: Seq[]
        -nameMap: ObjectMap
        -temporaryMapper: MappableContent[][]
        -currentMod: LoadedMod
        -lastAdded: Content
        -initialization: ObjectSet
        +createBaseContent(): void
        +createModContent(): void
        +init(): void
        +load(): void
        +loadColors(): void
        +copy(): ContentLoader
        +handleContent(c: Content): void
        +handleMappableContent(c: MappableContent): void
        +getByID(type: ContentType, id: int): Content
        +getByName(type: ContentType, name: String): MappableContent
        +getBy(type: ContentType): Seq
        +byName(name: String): MappableContent
        +setCurrentMod(mod: LoadedMod): void
        +setTemporaryMapper(m: MappableContent[][]): void
        +blocks(): Seq
        +items(): Seq
        +units(): Seq
        +planets(): Seq
    }

    class Logic {
        +Logic()
        +update(): void
        +dispose(): void
        +play(): void
        +reset(): void
        +runWave(): void
        +skipWave(): void
        +isWaitingWave(): boolean
        +{static} sectorCapture(): void
        +{static} gameOver(winner: Team): void
        +{static} updateGameOver(winner: Team): void
        +{static} researched(c: Content): void
        -checkGameState(): void
        -updateWeather(): void
        -checkCampaignStats(): boolean
    }
}

' ─────────────────────────────────────────────
' GameState value types
' ─────────────────────────────────────────────
package "mindustry.game" {

    class Rules {
        +waves: boolean
        +pvp: boolean
        +infiniteResources: boolean
        +waveTimer: boolean
        +teams: TeamRules
        +copy(): Rules
        +mode(): GameMode
        +hasEnv(env: int): boolean
        +isBanned(b: Block): boolean
        +isBanned(u: UnitType): boolean
    }

    class Teams {
    }

    class GameStats {
    }
}

' ─────────────────────────────────────────────
' Inheritance / implementation
' ─────────────────────────────────────────────

ClientLauncher --|> ApplicationCore
ClientLauncher ..|> Platform
Vars ..|> Loadable
Logic ..|> ApplicationListener

' ─────────────────────────────────────────────
' Vars → subsystems (static composition)
' ─────────────────────────────────────────────

Vars *-- ContentLoader : content
Vars *-- GameState    : state
Vars *-- Logic        : logic

' ─────────────────────────────────────────────
' GameState inner structure
' ─────────────────────────────────────────────

GameState +-- State
GameState *-- Rules   : rules
GameState *-- Teams   : teams
GameState *-- GameStats : stats

' ─────────────────────────────────────────────
' Logic reads/writes GameState; calls ContentLoader
' ─────────────────────────────────────────────

Logic ..> GameState    : reads/writes via\nVars.state
Logic ..> ContentLoader : queries via\nVars.content

' ─────────────────────────────────────────────
' ClientLauncher triggers Vars bootstrap
' ─────────────────────────────────────────────

ClientLauncher ..> Vars : calls setup()\n→ Vars.init()

' ─────────────────────────────────────────────
' ContentLoader calls Mods for mod content
' ─────────────────────────────────────────────

note as N1
  **Initialization Order**
  1. Vars.loadSettings()
  2. Vars.init() — instantiates all subsystems
  3. mods.load()
  4. content.createBaseContent()
  5. content.createModContent()
  6. content.init() → fires ContentInitEvent
  7. content.load() (client only)
  8. ClientLauncher.setup() — GL + ApplicationListeners
end note

@enduml
