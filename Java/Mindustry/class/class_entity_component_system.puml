@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam interface {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontColor #0D47A1
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Entity Component System\n<size:11><i>Annotation-driven ECS: source components, generated interfaces, and concrete entity classes</i></size>

legend top right
  |= Annotation |= Meaning |
  | @Component | Marks abstract class as ECS component |
  | @BaseComponent | Universal base merged into every entity |
  | @EntityDef(Xc) | Triggers generation of concrete entity class |
  | @Import field | Field owned by another merged component |
  | @Replace | Overrides another component's default impl |
  | <<codegen>> | Artifact generated at annotation-processing time |
endlegend

'─────────────────────────────────────────
' SOURCE COMPONENTS
'─────────────────────────────────────────
package "mindustry.entities.comp  (Source Components)" {

    abstract class EntityComp << @Component @BaseComponent >> {
        -transient boolean added
        +transient int id
        ..
        +boolean isAdded()
        +void update()
        +void add()
        +void remove()
        +<T extends Entityc> T self()
        +void read(Reads read)
        +void write(Writes write)
        +void beforeWrite()
        +void afterRead()
        +{abstract} int classId()
        +{abstract} boolean serialize()
    }

    abstract class BuildingComp << @Component(base=true) @EntityDef(Buildingc) >> {
        +@Import float x, y, health, maxHealth
        +@Import Team team
        +@Import boolean dead
        +transient Tile tile
        +transient Block block
        +transient Seq<Building> proximity
        +@Nullable PowerModule power
        +@Nullable ItemModule items
        +@Nullable LiquidModule liquids
        +transient float efficiency, optionalEfficiency
        -transient float timeScale
        -transient boolean sleeping, initialized
        ..
        +Building init(Tile tile, Team team, boolean shouldAdd, int rotation)
        +Building create(Block block, Team team)
        +void add()
        +void update()
        +int tileX()
        +int tileY()
        +void writeBase(Writes write)
    }

    abstract class UnitComp << @Component(base=true) >> {
        +@Import float x, y, rotation, health, maxHealth
        +@Import float drag, armor, hitSize, shield, ammo
        +@Import Team team
        +@Import int id
        +@Import Vec2 vel
        +@Import WeaponMount[] mounts
        +@Import ItemStack stack
        -UnitController controller
        +Ability[] abilities
        +UnitType type
        +boolean spawnedByCore
        +double flag
        +@SyncLocal float elevation
        +transient float healTime, drownTime
        ..
        +void update()
        +void add()
        +void remove()
        +void kill()
        +void killed()
        +void destroy()
        +void setType(UnitType type)
        +void controller(UnitController next)
        +UnitController controller()
        +boolean isFlying()
        +boolean isGrounded()
        +boolean isPlayer()
        +boolean isAI()
        +boolean killable()
        +void moveAt(Vec2 vector, float acceleration)
        +void draw()
        +void afterSync()
    }

    abstract class PlayerComp << @Component(base=true) @EntityDef(Playerc) >> {
        +@Import float x, y
        +@ReadOnly @Nullable Unit unit
        +transient @Nullable NetConnection con
        +@ReadOnly Team team
        +@SyncLocal boolean typing, shooting, boosting
        +@SyncLocal @Nullable Block selectedBlock
        +@SyncLocal float mouseX, mouseY
        +boolean admin
        +String name
        +Color color
        +transient float deathTimer
        ..
        +void update()
        +void remove()
        +void draw()
        +void reset()
        +void unit(Unit unit)
        +boolean dead()
        +boolean isBuilder()
        +boolean isValidController()
        +boolean isLogicControllable()
        +void checkSpawn()
        +void afterSync()
        +String uuid()
        +void kick(KickReason reason)
    }
}

'─────────────────────────────────────────
' GENERATED ARTIFACTS (mindustry.gen)
'─────────────────────────────────────────
package "mindustry.gen  (Generated at compile-time)" {

    interface Entityc << generated from EntityComp >> {
        +boolean isAdded()
        +void update()
        +void add()
        +void remove()
        +int id()
        +void read(Reads read)
        +void write(Writes write)
    }

    interface Buildingc << manually defined >> {
        +Building init(Tile, Team, boolean, int)
        +Building create(Block, Team)
        +void add()
        +int tileX()
        +int tileY()
    }

    interface Unitc << generated from UnitComp >> {
        +void update()
        +void kill()
        +void setType(UnitType)
        +boolean isFlying()
        +UnitController controller()
        +UnitType type()
    }

    interface Playerc << generated from PlayerComp >> {
        +void update()
        +void reset()
        +Unit unit()
        +boolean dead()
        +String uuid()
        +void kick(KickReason reason)
    }

    class Building << codegen, non-final >> {
        ' Merged from BuildingComp + EntityComp
        ' Implements full Building API
    }

    class Unit << codegen >> {
        ' Merged from UnitComp + EntityComp
        ' Implements full Unit API
    }

    class Player << codegen >> {
        ' Merged from PlayerComp + EntityComp
        ' Is also a UnitController
    }
}

'─────────────────────────────────────────
' SUPPORTING TYPES
'─────────────────────────────────────────
interface UnitController {
    +void updateUnit(Unit unit)
    +boolean isLogicControllable()
    +boolean isValidController()
}

class AIController {
    #Unit unit
    #Teamc target
    #Interval timer
    ..
    +void updateUnit()
    +void updateMovement()
    +void updateTargeting()
    +void faceTarget()
}

class UnitType {
    +float speed
    +float health
    +float hitSize
    +Seq<Ability> abilities
    ..
    +UnitController createController(Unit unit)
    +Unit create(Team team)
    +Unit spawn(Team team, float x, float y)
}

abstract class Ability {
    +void update(Unit unit)
    +void draw(Unit unit)
}

class ItemModule {
    +int get(Item item)
    +void add(Item item, int amount)
}

class PowerModule {
    +float status
    +Seq<Building> links
}

class LiquidModule {
    +float get(Liquid liquid)
    +void add(Liquid liquid, float amount)
}

class Block {
    +boolean hasItems
    +boolean hasLiquids
    +boolean hasPower
    +boolean outputsLiquid
    +boolean consumesPower
}

'─────────────────────────────────────────
' RELATIONSHIPS
'─────────────────────────────────────────

' --- Comp classes implement their core interfaces ---
BuildingComp ..|> Buildingc : implements
UnitComp ..|> Unitc : implements
PlayerComp ..|> UnitController : implements
PlayerComp ..|> Entityc : implements

' --- Code generation: @EntityDef + codegen merges ---
EntityComp ..> Building  : <<@BaseComponent\nmerges into>>
EntityComp ..> Unit      : <<@BaseComponent\nmerges into>>
EntityComp ..> Player    : <<@BaseComponent\nmerges into>>
BuildingComp ..> Building : <<@EntityDef\ngenerates>>
UnitComp ..> Unit         : <<codegen\ngenerates>>
PlayerComp ..> Player     : <<@EntityDef\ngenerates>>

' --- Generated concrete classes implement interfaces ---
Building ..|> Buildingc : implements
Building ..|> Entityc   : implements
Unit ..|> Unitc         : implements
Unit ..|> Entityc       : implements
Player ..|> Playerc     : implements
Player ..|> UnitController : implements
Player ..|> Entityc     : implements

' --- Compositions within UnitComp / Unit ---
UnitComp o-- UnitController : -controller\n(Player or AI)
UnitComp *-- UnitType       : type
UnitComp *-- Ability        : abilities[0..*]

' --- Compositions within BuildingComp / Building ---
BuildingComp o-- ItemModule  : items [0..1]
BuildingComp o-- PowerModule : power [0..1]
BuildingComp o-- LiquidModule : liquids [0..1]
BuildingComp --> Block       : block (type def)

' --- PlayerComp controls a Unit ---
PlayerComp o-- Unit : unit [0..1]\n@ReadOnly

' --- AIController implements UnitController ---
AIController ..|> UnitController : implements

@enduml
