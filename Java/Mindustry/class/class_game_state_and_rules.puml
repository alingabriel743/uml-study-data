@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #EEF2FF
    BorderColor #5C6BC0
}
skinparam interface {
    BackgroundColor #E8F5E9
    BorderColor #388E3C
}

title Game State & Rules

' ─────────────────────────────────────────
' External / referenced types (no details)
' ─────────────────────────────────────────
package "External References" <<Rectangle>> {
    class Teams <<(S,#AADDAA) singleton>>
    class GameStats
    class Attributes
    class SpawnGroup
    class WeatherEntry
    class MapObjectives
    class Sector
    class Planet
    class Team
    interface JsonSerializable
}

' ─────────────────────────────────────────
' mindustry.game
' ─────────────────────────────────────────
package "mindustry.game" {

    class Rules {
        ' ── game mode flags ──
        +boolean pvp
        +boolean attackMode
        +boolean editor
        +boolean waves
        +boolean waveTimer
        +boolean waveSending
        +boolean fog
        +boolean staticFog
        +boolean canGameOver
        +boolean coreCapture
        +boolean infiniteResources
        ' ── wave / spawn config ──
        +float waveSpacing
        +float initialWaveSpacing
        +float dropZoneRadius
        +int winWave
        +int unitCap
        +int env
        +Team defaultTeam
        +Team waveTeam
        +Seq<SpawnGroup> spawns
        +Seq<ItemStack> loadout
        +Seq<WeatherEntry> weather
        +MapObjectives objectives
        +Sector sector
        +Planet planet
        +TeamRules teams
        ' ── multipliers ──
        +float unitBuildSpeedMultiplier
        +float unitDamageMultiplier
        +float unitHealthMultiplier
        +float blockHealthMultiplier
        +float buildSpeedMultiplier
        +float solarMultiplier
        ..
        +Rules copy()
        +Gamemode mode()
        +boolean hasEnv(int env)
        +float buildRadius(Team team)
        +float unitBuildSpeed(Team team)
        +float unitDamage(Team team)
        +float unitHealth(Team team)
        +float blockHealth(Team team)
        +float blockDamage(Team team)
        +float buildSpeed(Team team)
        +boolean isBanned(Block block)
        +boolean isBanned(UnitType unit)
    }

    class "Rules.TeamRule" as TeamRule <<static nested>> {
        +boolean aiCoreSpawn
        +boolean protectCores
        +boolean checkPlacement
        +boolean cheat
        +boolean fillItems
        +boolean infiniteResources
        +boolean infiniteAmmo
        +boolean prebuildAi
        +boolean buildAi
        +boolean rtsAi
        +float buildAiTier
        +int rtsMinSquad
        +int rtsMaxSquad
        +float unitFactoryActivationDelay
        +float unitBuildSpeedMultiplier
        +float unitDamageMultiplier
        +float unitHealthMultiplier
        +float blockHealthMultiplier
        +float blockDamageMultiplier
        +float buildSpeedMultiplier
        +float extraCoreBuildRadius
        ..
        +TeamRule()
        +TeamRule(Team team)
    }

    class "Rules.TeamRules" as TeamRules <<static nested>> {
        +TeamRule[] values
        ..
        +TeamRule get(Team team)
        +void write(Json json)
        +void read(Json json, JsonValue jsonData)
    }

    class SectorInfo {
        +ObjectMap<Item, ExportStat> production
        +ObjectMap<Item, ExportStat> rawProduction
        +ObjectMap<Item, ExportStat> export
        +ObjectMap<Item, ExportStat> imports
        +ItemSeq items
        +Block bestCoreType
        +int storageCapacity
        +boolean hasCore
        +boolean wasCaptured
        +boolean waves
        +boolean attack
        +boolean hasSpawns
        +int wave
        +int winWave
        +float waveSpacing
        +float minutesCaptured
        +Sector origin
        +Sector destination
        ..
        +boolean sectorDataMatches(Sector sector)
        +void handleCoreItem(Item, int amount)
        +void handleProduction(Item, int amount)
        +void handleItemExport(Item, int amount)
        +void handleItemImport(Item, int amount)
        +float getExport(Item item)
        +void refreshImportRates(Planet planet)
        +float getImportRate(Planet planet, Item item)
        +void write()
        +void prepare(Sector sector)
        +void update()
        +ObjectFloatMap<Item> exportRates()
    }

    class "SectorInfo.ExportStat" as ExportStat <<static nested>> {
        ~float counter
        ~WindowedMean means
        ~boolean loaded
        +float mean
    }

    ' Nesting relationship — dashed containment
    Rules +-- TeamRule
    Rules +-- TeamRules
    SectorInfo +-- ExportStat
}

' ─────────────────────────────────────────
' mindustry.core
' ─────────────────────────────────────────
package "mindustry.core" {

    class GameState {
        +int wave
        +float wavetime
        +double tick
        +long updateId
        +boolean gameOver
        +boolean afterGameOver
        +boolean won
        +int serverTps
        +int enemies
        +Map map
        -State state
        ..
        +Unit boss()
        +void set(State state)
        +boolean hasSpawns()
        +boolean isCampaign()
        +boolean hasSector()
        +Sector getSector()
        +Planet getPlanet()
        +boolean isPlaying()
        +boolean isMenu()
        +boolean isPaused()
        +boolean isGame()
        +boolean is(State s)
        +State getState()
    }

    enum "GameState.State" as GameState_State {
        paused
        playing
        menu
    }

    GameState +-- GameState_State
}

' ─────────────────────────────────────────
' mindustry.ai
' ─────────────────────────────────────────
package "mindustry.ai" {

    class WaveSpawner {
        +Seq<Tile> spawns
        +boolean spawning
        +boolean any
        +Tile firstSpawn
        ..
        +Tile getFirstSpawn()
        +int countSpawns()
        +Seq<Tile> getSpawns()
        +boolean playerNear()
        +void spawnEnemies()
        +void spawnUnit(SpawnGroup, float x, float y)
        +void doShockwave(float x, float y)
        +int countGroundSpawns()
        +int countFlyerSpawns()
        +boolean isSpawning()
        +void reset()
        +void spawnEffect(Unit unit)
        {static} +void spawnEffect(float x, float y, float rotation, UnitType)
    }

    interface SpawnConsumer <<inner interface>> {
        +void accept(float x, float y, boolean shockwave)
    }

    WaveSpawner +-- SpawnConsumer
}

' ─────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────

' GameState composition
GameState *-- Rules           : rules
GameState *-- Teams           : teams
GameState *-- GameStats       : stats
GameState *-- Attributes      : envAttrs

' Rules composition / aggregation
Rules *-- TeamRules            : teams
Rules o-- SpawnGroup           : spawns (Seq)
Rules o-- WeatherEntry         : weather (Seq)
Rules o-- MapObjectives        : objectives
Rules ..> Sector               : sector (nullable)
Rules ..> Planet               : planet
Rules ..> Team                 : defaultTeam / waveTeam

' TeamRules owns TeamRule array
TeamRules *-- TeamRule         : values[ ]

' TeamRules serialization
TeamRules ..|> JsonSerializable

' SectorInfo aggregation
SectorInfo o-- ExportStat      : production / export / imports (ObjectMap)
SectorInfo ..> Sector          : origin / destination

' Cross-package dependencies (via Vars.state)
SectorInfo ..> GameState       : reads/writes\n(Vars.state)
WaveSpawner ..> GameState      : reads rules & wave\n(Vars.state)
WaveSpawner ..> SpawnGroup     : iterates spawns

@enduml
