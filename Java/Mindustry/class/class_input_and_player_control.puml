package "mindustry.ui.fragments" {
    class BlockInventoryFragment {
    }
    class BlockConfigFragment {
    }
    class PlanConfigFragment {
    }
}

' ─────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────

' Inheritance
MobileInput  --|> InputHandler
DesktopInput --|> InputHandler

' Interface implementation
InputHandler ..|> InputProcessor    : implements
InputHandler ..|> GestureListener   : implements
MobileInput  ..|> GestureListener   : re-implements
BuildPlan    ..|> Position           : implements
BuildPlan    ..|> QuadTreeObject     : implements
Schematic    ..|> Publishable        : implements

' Composition / aggregation – InputHandler
InputHandler "1" *-- "many" BuildPlan      : linePlans / selectPlans / lastPlans
InputHandler "1" o-- "0..1" Schematic      : lastSchematic
InputHandler "1" *-- "1" BlockInventoryFragment : inv
InputHandler "1" *-- "1" BlockConfigFragment    : config
InputHandler "1" *-- "1" PlanConfigFragment     : planConfig

' MobileInput extras
MobileInput "1" *-- "many" BuildPlan       : removals (fade-out)

' PlaceMode usage
MobileInput  ..> PlaceMode  : uses (mode)
DesktopInput ..> PlaceMode  : uses (mode)

' Schematic composition
Schematic "1" *-- "many" SchematicStile : tiles

' BuildPlan → Schematic (via useSchematic flow)
InputHandler ..> Schematic  : converts to BuildPlans

@enduml
