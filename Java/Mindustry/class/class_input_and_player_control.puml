@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}
skinparam interface {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
    FontColor #212529
}

title Input & Player Control

' ─────────────────────────────────────────
' External interfaces
' ─────────────────────────────────────────
interface InputProcessor {
    +keyDown(keyCode: KeyCode): boolean
    +keyUp(keyCode: KeyCode): boolean
    +touchDown(x: int, y: int, pointer: int, button: KeyCode): boolean
    +touchUp(x: int, y: int, pointer: int, button: KeyCode): boolean
    +scrolled(amountX: float, amountY: float): boolean
}

interface GestureListener {
    +tap(x: float, y: float, count: int, button: KeyCode): boolean
    +longPress(x: float, y: float): boolean
    +pan(x: float, y: float, deltaX: float, deltaY: float): boolean
    +zoom(initialDistance: float, distance: float): boolean
    +pinch(...): boolean
}

interface Position {
    +getX(): float
    +getY(): float
}

interface QuadTreeObject {
    +hitbox(out: Rect): void
}

interface Publishable {
    +steamid(): long
}

' ─────────────────────────────────────────
' mindustry.input package
' ─────────────────────────────────────────
package "mindustry.input" {

    enum PlaceMode {
        none
        placing
        breaking
        schematicSelect
        rebuildSelect
    }

    abstract class InputHandler {
        ' -- State --
        +block: Block
        +rotation: int
        +isBuilding: boolean
        +commandMode: boolean
        +commandRect: boolean
        +droppingItem: boolean
        +overrideLineRotation: boolean
        +controlledType: UnitType
        +lastUnit: Unit
        +spectating: Unit
        ' -- Build plan queues --
        +linePlans: Seq<BuildPlan>
        +selectPlans: Seq<BuildPlan>
        +lastPlans: Queue<BuildPlan>
        +lastSchematic: Schematic
        +bplan: BuildPlan
        +playerPlanTree: QuadTree<BuildPlan>
        +selectPlanTree: QuadTree<BuildPlan>
        ' -- Command / selection --
        +selectedUnits: Seq<Unit>
        +commandBuildings: Seq<Building>
        +controlGroups: IntSeq[10]
        +inputLocks: Seq<Boolp>
        ' -- UI fragments --
        +inv: BlockInventoryFragment
        +config: BlockConfigFragment
        +planConfig: PlanConfigFragment
        ' -- Core methods --
        +update(): void
        +updateState(): void
        +reset(): void
        +{abstract} useSchematic(schem: Schematic, checkHidden: boolean): void
        +useSchematic(schem: Schematic): void
        +buildPlacementUI(table: Table): void
        +buildUI(group: Group): void
        +drawBottom(): void
        +drawTop(): void
        +drawBuildPlans(): void
        +drawOtherBuildPlans(): void
        ' -- Plan management --
        +validPlace(x: int, y: int, type: Block, rotation: int): boolean
        +validBreak(x: int, y: int): boolean
        +flushPlans(plans: Seq<BuildPlan>): void
        +flushSelectPlans(plans: Seq<BuildPlan>): void
        +rotatePlans(plans: Seq<BuildPlan>, direction: int): void
        +flipPlans(plans: Seq<BuildPlan>, x: boolean): void
        +getPlan(x: int, y: int): BuildPlan
        +updateSelectQuadtree(): void
        +rebuildArea(x1: int, y1: int, x2: int, y2: int): void
        +removeSelection(x1: int, y1: int, x2: int, y2: int, ...): void
        ' -- Command / unit selection --
        +commandTap(x: float, y: float): void
        +selectTypedUnits(): void
        +selectUnitsRect(): void
        +selectedUnit(): Unit
        +selectedCommandUnit(x: float, y: float): Unit
        ' -- Query helpers --
        +isPlacing(): boolean
        +isBreaking(): boolean
        +locked(): boolean
        +canShoot(): boolean
        ' -- Interaction --
        +tryBreakBlock(x: int, y: int): void
        +tryBeginMine(tile: Tile): boolean
        +tryTapPlayer(x: float, y: float): boolean
        +tileTapped(build: Building): boolean
        +tryPickupPayload(): void
        +tryDropPayload(): void
        +spectate(unit: Unit): void
        +panCamera(position: Vec2): void
        +addLock(lock: Boolp): void
        +getMouseX(): float
        +getMouseY(): float
        ' -- @Remote (network) --
        +{static} commandUnits(player: Player, ...): void
        +{static} buildingControlSelect(player: Player, building: Building): void
        +{static} unitControl(player: Player, unit: Unit): void
        +{static} unitClear(player: Player): void
        +{static} deletePlans(player: Player, positions: int[]): void
        +{static} requestItem(player: Player, build: Building, item: Item, amount: int): void
        +{static} rotateBlock(player: Player, build: Building, forward: boolean): void
        +{static} tileConfig(player: Player, build: Building, value: Object): void
    }

    class MobileInput {
        ' -- Movement / aim --
        +vector: Vec2
        +movement: Vec2
        +targetPos: Vec2
        +lastZoom: float
        +edgePan: float
        +shiftDeltaX: float
        +shiftDeltaY: float
        ' -- Line / area placement --
        +lineStartX: int
        +lineStartY: int
        +lastLineX: int
        +lastLineY: int
        +lineScale: float
        +crosshairScale: float
        ' -- Mode flags --
        +mode: PlaceMode
        +lineMode: boolean
        +schematicMode: boolean
        +rebuildMode: boolean
        +queueCommandMode: boolean
        +selecting: boolean
        +down: boolean
        +manualShooting: boolean
        ' -- Targets --
        +target: Teamc
        +lastTarget: Teamc
        +payloadTarget: Position
        +unitTapped: Unit
        +buildingTapped: Building
        +lastBlock: Block
        +lastPlaced: BuildPlan
        +removals: Seq<BuildPlan>
        ' -- Touch handling --
        +touchDown(screenX: int, screenY: int, pointer: int, key: KeyCode): boolean
        +touchUp(screenX: int, screenY: int, pointer: int, key: KeyCode): boolean
        +longPress(x: float, y: float): boolean
        +tap(x: float, y: float, count: int, key: KeyCode): boolean
        +pan(x: float, y: float, deltaX: float, deltaY: float): boolean
        +panStop(x: float, y: float, pointer: int, key: KeyCode): boolean
        +zoom(initialDistance: float, distance: float): boolean
        ' -- Update / render --
        +update(): void
        +updateState(): void
        +reset(): void
        +updateMovement(unit: Unit): void
        +autoPan(): void
        +useSchematic(schem: Schematic, checkHidden: boolean): void
        +getSyncedPlans(out: Seq<BuildPlan>): void
        +buildPlacementUI(table: Table): void
        +buildUI(group: Group): void
        +drawBottom(): void
        +drawTop(): void
        +drawOverSelect(): void
        +drawPlan(plan: BuildPlan): void
        ' -- Plan helpers --
        +checkTargets(x: float, y: float): void
        +hasPlan(tile: Tile): boolean
        +getPlan(tile: Tile): BuildPlan
        +checkOverlapPlacement(x: int, y: int, block: Block): boolean
        +removePlan(plan: BuildPlan): void
        +isLinePlacing(): boolean
        +isAreaBreaking(): boolean
        +isPlacing(): boolean
        +isBreaking(): boolean
        +showCancel(): boolean
        +hasSchematic(): boolean
        +schemOriginX(): int
        +schemOriginY(): int
    }

    class DesktopInput {
        ' -- Movement / aim --
        +movement: Vec2
        +cursorType: Cursor
        +panScale: float
        +panSpeed: float
        +panBoostSpeed: float
        +panning: boolean
        ' -- Select / schematic --
        +selectX: int
        +selectY: int
        +schemX: int
        +schemY: int
        +lastLineX: int
        +lastLineY: int
        +schematicX: int
        +schematicY: int
        +selectScale: float
        +selectMillis: long
        ' -- Mode & flags --
        +mode: PlaceMode
        +deleting: boolean
        +shouldShoot: boolean
        +movedPlan: boolean
        +pressedCommandRect: boolean
        +changedCursor: boolean
        +lastCtrlGroup: int
        +lastCtrlGroupSelectMillis: long
        +lastPayloadKeyTapMillis: long
        +lastPayloadKeyHoldMillis: long
        ' -- Plan helpers --
        +splan: BuildPlan
        +prevSelected: Tile
        +buildPlanMouseOffsetX: float
        +buildPlanMouseOffsetY: float
        ' -- Core overrides --
        +update(): void
        +updateState(): void
        +reset(): void
        +pollInputPlayer(): void
        +pollInputNoPlayer(): void
        +updateMovement(unit: Unit): void
        +touchDown(x: float, y: float, pointer: int, key: KeyCode): boolean
        +tap(x: float, y: float, count: int, key: KeyCode): boolean
        +useSchematic(schem: Schematic, checkHidden: boolean): void
        +buildUI(group: Group): void
        +buildPlacementUI(table: Table): void
        +drawTop(): void
        +drawBottom(): void
        +isBreaking(): boolean
        +selectedBlock(): boolean
        +panCamera(position: Vec2): void
        +getMouseX(): float
        +getMouseY(): float
        +showHint(): boolean
    }
}

' ─────────────────────────────────────────
' mindustry.entities.units package
' ─────────────────────────────────────────
package "mindustry.entities.units" {

    class BuildPlan {
        +x: int
        +y: int
        +rotation: int
        +block: Block
        +breaking: boolean
        +config: Object
        +progress: float
        +animScale: float
        +initialized: boolean
        +stuck: boolean
        +cachedValid: boolean
        +worldContext: boolean
        ' -- Constructors --
        +BuildPlan(x, y, rotation, block) <<place>>
        +BuildPlan(x, y, rotation, block, config) <<place+config>>
        +BuildPlan(x, y) <<break>>
        ' -- Methods --
        +placeable(team: Team): boolean
        +isRotation(team: Team): boolean
        +isDone(): boolean
        +isDerelictRepair(): boolean
        +samePos(other: BuildPlan): boolean
        +copy(): BuildPlan
        +tile(): Tile
        +build(): Building
        +drawx(): float
        +drawy(): float
        +bounds(rect: Rect): Rect
        +hitbox(rect: Rect): void
        +set(x, y, rotation, block): BuildPlan
        +pointConfig(cons: Cons<Point2>): void
        +{static} pointConfig(block, config, cons): Object
    }
}

' ─────────────────────────────────────────
' mindustry.game package
' ─────────────────────────────────────────
package "mindustry.game" {

    class Schematic {
        +tiles: Seq<Stile>
        +labels: Seq<String>
        +tags: StringMap
        +width: int
        +height: int
        +file: Fi
        +mod: LoadedMod
        ' -- Methods --
        +powerProduction(): float
        +powerConsumption(): float
        +requirements(): ItemSeq
        +hasCore(): boolean
        +findCore(): CoreBlock
        +name(): String
        +description(): String
        +save(): void
        +compareTo(other: Schematic): int
    }

    class "Schematic.Stile" as SchematicStile {
        +block: Block
        +x: short
        +y: short
        +config: Object
        +rotation: byte
        +set(other: Stile): Stile
        +copy(): Stile
    }
}

