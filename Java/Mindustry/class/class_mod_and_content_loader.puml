@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #856404
}
skinparam interface {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
}

title Mod & Content Loader System

' ─── External interfaces / base types ───────────────────────────────────────

interface Loadable {
    +load()
    +loadAsync()
    +loadSync()
}

interface Disposable {
    +dispose()
}

interface Publishable {
    +getSteamID(): String
    +addSteamID(id: String)
    +getRepo(): String
    +setRepo(repo: String)
}

class RuntimeException <<external>>

' ─── mindustry.mod package ─────────────────────────────────────────────────

package "mindustry.mod" {

    abstract class Mod {
        +init()
        +loadContent()
        +registerUnlockables()
    }

    class ModClassLoader <<ClassLoader>> {
    }

    class Mods {
        -json: Json
        -scripts: Scripts
        -parser: ContentParser
        -bundles: ObjectMap<String, Seq<Fi>>
        -lastOrderedMods: Seq<LoadedMod>
        -mainLoader: ModClassLoader
        +mods: Seq<LoadedMod>
        -newImports: Seq<LoadedMod>
        -metas: ObjectMap<Class<?>, ModMeta>
        -requiresReload: boolean
        --
        +load()
        +loadAsync()
        +loadSync()
        +loadScripts()
        +loadContent()
        +importMod(file: Fi): LoadedMod
        +removeMod(mod: LoadedMod)
        +orderedMods(): Seq<LoadedMod>
        +sortMods()
        +updateDependencies(mod: LoadedMod)
        +handleContentError(content: Content, error: Throwable)
        +addParseListener(hook: ParseListener)
        +contextRun(mod: LoadedMod, run: Runnable)
        +eachEnabled(cons: Cons<LoadedMod>)
        +getMod(name: String): LoadedMod
        +resolveDependencies(mods: Seq<ModMeta>): OrderedMap
        +checkDependencies(mods: Seq<LoadedMod>, b: boolean)
        +skipModLoading(): boolean
        +list(): Seq<LoadedMod>
        -loadMod(fi: Fi, update: boolean, req: boolean): LoadedMod
        -packSprites(packer: MultiPacker, sprites: Seq<Fi>, mod: LoadedMod, ...)
        -loadIcons()
        -loadIcon(mod: LoadedMod)
        +hasScripts(): boolean
        +hasContentErrors(): boolean
    }

    class LoadedMod {
        +file: Fi
        +root: Fi
        +main: Mod
        +name: String
        +meta: ModMeta
        +dependencies: Seq<LoadedMod>
        +softDependencies: Seq<LoadedMod>
        +missingDependencies: Seq<String>
        +erroredContent: ObjectSet<Content>
        +state: ModState
        +iconTexture: Texture
        +loader: ClassLoader
        --
        +isJava(): boolean
        +enabled(): boolean
        +shouldBeEnabled(): boolean
        +hasUnmetDependencies(): boolean
        +hasContentErrors(): boolean
        +isSupported(): boolean
        +isBlacklisted(): boolean
        +isOutdated(): boolean
        +getMinMajor(): int
        +dispose()
    }

    class ModMeta {
        +name: String
        +internalName: String
        +minGameVersion: String
        +displayName: String
        +author: String
        +version: String
        +main: String
        +repo: String
        +dependencies: Seq<String>
        +softDependencies: Seq<String>
        +hidden: boolean
        +java: boolean
        +iosCompatible: boolean
        +texturescale: float
        +contentOrder: String[]
        +pregenerated: boolean
        --
        +isBlacklisted(): boolean
        +shortDescription(): String
        +cleanup()
        +getMinMajor(): int
    }

    enum ModState {
        enabled
        contentErrors
        missingDependencies
        incompleteDependencies
        circularDependencies
        unsupported
        disabled
    }

    class ModLoadException {
    }

    class ModResolutionContext {
        +dependencies: ObjectMap<String, Seq<ModDependency>>
        +visited: ObjectSet<String>
        +ordered: OrderedSet<String>
        +invalid: ObjectMap<String, ModState>
    }

    class ModDependency {
        +name: String
        +required: boolean
    }

    class ContentParser {
        +contentTypes: ObjectMap<Class<?>, ContentType>
        +listeners: Seq<ParseListener>
        +allowClassResolution: boolean
        +allowAssetLoading: boolean
        +classParsers: ObjectMap<Class<?>, FieldParser>
        -parsers: ObjectMap<ContentType, TypeParser<?>>
        -reads: Seq<Runnable>
        -postreads: Seq<Runnable>
        -toBeParsed: ObjectSet<Object>
        +currentMod: LoadedMod
        +currentContent: Content
        --
        +parse(mod: LoadedMod, name: String, json: String,\n    file: Fi, type: ContentType): Content
        +finishParsing()
        +checkInit()
        +markError(content: Content, mod: LoadedMod,\n    file: Fi, error: Throwable)
        +readFields(obj: Object, jsonMap: JsonValue,\n    stripType: boolean)
        +readBlockConsumers(block: Block, value: JsonValue)
        +getJson(): Json
    }

    interface FieldParser {
        +parse(type: Class<?>, data: JsonValue): Object
    }

    interface TypeParser<T> {
        +parse(mod: String, name: String,\n    value: JsonValue): T
    }

    class Scripts {
        +context: Context
        +scope: Scriptable
        -errored: boolean
        +currentMod: LoadedMod
        --
        +Scripts()
        +run(mod: LoadedMod, file: Fi): boolean
        +runConsole(text: String): String
        +hasErrored(): boolean
        +dispose()
    }
}

' ─── mindustry.core package ────────────────────────────────────────────────

package "mindustry.core" {

    class ContentLoader {
        -contentNameMap: ObjectMap<String, MappableContent>[]
        -contentMap: Seq<Content>[]
        -nameMap: ObjectMap<String, MappableContent>
        -temporaryMapper: MappableContent[][]
        -currentMod: LoadedMod
        -lastAdded: Content
        -initialization: ObjectSet<Cons<Content>>
        --
        +copy(): ContentLoader
        +createBaseContent()
        +createModContent()
        +init()
        +load()
        +loadColors()
        +handleContent(content: Content)
        +handleMappableContent(content: MappableContent)
        +setCurrentMod(mod: LoadedMod)
        +transformName(name: String): String
        +removeLast()
        +getLastAdded(): Content
        +byName(name: String): MappableContent
        +getByName(type: ContentType, name: String): T
        +getByID(type: ContentType, id: int): T
        +getBy(type: ContentType): Seq<T>
        +blocks() / block(int) / block(String)
        +items() / item(int) / item(String)
        +units() / unit(int) / unit(String)
        +planets() / planet(String)
        +weathers() / weather(String)
    }
}

' ─── Inheritance / Implementation ──────────────────────────────────────────

Mods             ..|>  Loadable
LoadedMod        ..|>  Publishable
LoadedMod        ..|>  Disposable
Scripts          ..|>  Disposable
ModLoadException --|>  RuntimeException

' ─── Composition / Aggregation ─────────────────────────────────────────────

Mods  *--  ContentParser         : -parser\n(1:1)
Mods  *--  "0..1" Scripts        : -scripts\n(lazy)
Mods  *--  ModClassLoader        : -mainLoader
Mods  o--  "0..*" LoadedMod      : +mods

LoadedMod  *--  ModMeta          : +meta (1:1)
LoadedMod  -->  ModState         : +state
LoadedMod  o--  "0..*" LoadedMod : +dependencies\n(self-referential)
LoadedMod  -->  "0..1" Mod       : +main

ContentParser  o--  "0..*" TypeParser   : -parsers\n(per ContentType)
ContentParser  o--  "0..*" FieldParser  : +classParsers
ContentParser  -->  LoadedMod           : +currentMod

ContentLoader  -->  "0..1" LoadedMod    : -currentMod

ModResolutionContext  o--  "0..*" ModDependency  : +dependencies

' ─── Cross-package dependencies ─────────────────────────────────────────────

ContentLoader  ..>  Mods          : createModContent()\n→ loadContent()
Mods           ..>  ContentLoader : via Vars singleton\n(content)
Mods           ..>  ModResolutionContext : uses in\nresolveDependencies()

' ─── Notes ───────────────────────────────────────────────────────────────────

note as LoadingPipelineNote
  <b>Loading Pipeline</b>
  1. Mods.load()       — discover mod files, parse ModMeta,
                         resolve dependency order via ModResolutionContext
  2. Mods.loadAsync()  — pack sprites with MultiPacker (background)
  3. Mods.loadSync()   — finalize atlas, load mod icons
  4. Mods.loadScripts()— run *.js files via Scripts (Rhino JS engine)
  5. ContentLoader.createBaseContent() — load all built-in content
  6. ContentLoader.createModContent() → Mods.loadContent():
       Java mods: mod.main.loadContent()
       JSON mods: ContentParser.parse() per content/*.json|hjson file
  7. ContentParser.finishParsing() — resolve deferred cross-references
  8. ContentLoader.init()  — call Content.init() / postInit()
  9. ContentLoader.load()  — call Content.loadIcon() / load()
end note

note bottom of ContentParser
  <b>Two-phase JSON parsing</b>
  Phase 1 (parse): TypeParser.parse() →
    register Content object immediately
  Phase 2 (finishParsing): runs deferred
    reads[] then postreads[] to fully
    populate cross-referenced fields.
  Registered parsers: block, unit, weather,
    liquid, status, sector, planet, team
end note

note right of ModClassLoader
  Extends ClassLoader.
  Used for JAR-based mods
  to isolate class loading.
end note

@enduml
