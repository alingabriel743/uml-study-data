@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
}

title Networking & Administration

' ─────────────── External interfaces ───────────────
interface ApplicationListener {
    +init(): void
    +update(): void
}

interface Serializable
interface Poolable {
    +reset(): void
}

' ─────────────── mindustry.core ─────────────────────
package "mindustry.core" {

    class NetServer {
        -maxSnapshotSize: int = 800
        -blockSyncTime: Timekeeper
        -healthSyncTime: Timekeeper
        -planPreviewSyncTime: Timekeeper
        --
        +admins: Administration
        +clientCommands: CommandHandler
        +assigner: TeamAssigner
        +chatFormatter: ChatFormatter
        +invalidHandler: InvalidCommandHandler
        ==
        +init(): void
        +update(): void
        +openServer(): void
        +kickAll(reason: KickReason): void
        +sendWorldData(player: Player): void
        +assignTeam(current: Player): Team
        +isWaitingForPlayers(): boolean
        +votesRequired(): int
        +addPacketHandler(type: String, handler: Cons2): void
        +addBinaryPacketHandler(type: String, handler: Cons2): void
        ..@Remote (RPC)..
        +onDisconnect(player: Player, reason: String): void
        +clientSnapshot(...): void
        +adminRequest(player: Player, other: Player, action: AdminAction): void
        +connectConfirm(player: Player): void
        +serverPacketReliable(player: Player, type: String, contents: String): void
        +requestBlockSnapshot(player: Player, pos: int): void
        +clientPlanSnapshot(player: Player, groupId: int, plans: ClientBuildPlans): void
    }

    class NetClient {
        -ping: long
        -connecting: boolean
        -quiet: boolean
        -timeoutTime: float
        -lastSnapshotTimestamp: long
        -lastSent: int
        -removed: IntSet
        -customPacketHandlers: ObjectMap<String, Seq<Cons<String>>>
        -customBinaryPacketHandlers: ObjectMap<String, Seq<Cons<byte[]>>>
        ==
        +update(): void
        +sync(): void
        +reset(): void
        +finishConnecting(): void
        +beginConnecting(): void
        +disconnectQuietly(): void
        +isConnecting(): boolean
        +getPing(): int
        +addPacketHandler(type: String, handler: Cons<String>): void
        +addBinaryPacketHandler(type: String, handler: Cons<byte[]>): void
        +getPacketHandlers(type: String): Seq
        +getUsid(ip: String): String
        ..@Remote (RPC)..
        +entitySnapshot(amount: short, data: byte[]): void
        +blockSnapshot(amount: short, data: byte[]): void
        +stateSnapshot(...): void
        +sendMessage(message: String, unformatted: String, sender: Player): void
        +sendChatMessage(player: Player, message: String): void
        +kick(reason: KickReason): void
        +connect(ip: String, port: int): void
        +ping(player: Player, time: long): void
        +traceInfo(player: Player, info: TraceInfo): void
    }

    interface TeamAssigner {
        +assign(player: Player, players: Iterable<Player>): Team
    }

    interface ChatFormatter {
        +format(player: Player, message: String): String
    }
}

' ─────────────── mindustry.net ──────────────────────
package "mindustry.net" {

    abstract class NetConnection {
        +address: String
        +uuid: String
        +usid: String
        +mobile: boolean
        +modclient: boolean
        +player: Player
        +kicked: boolean
        +syncTime: long
        +connectTime: long
        +lastReceivedClientSnapshot: int
        +snapshotsSent: int
        +chatRate: Ratekeeper
        +packetRate: Ratekeeper
        +hasConnected: boolean
        +hasBegunConnecting: boolean
        +hasDisconnected: boolean
        +viewWidth: float
        +viewHeight: float
        ==
        +kick(): void
        +kick(reason: KickReason): void
        +kick(reason: KickReason, kickDuration: long): void
        +kick(reason: String): void
        #kickDisconnect(): void
        +isConnected(): boolean
        +sendStream(stream: Streamable): void
        +{abstract} send(object: Object, reliable: boolean): void
        +{abstract} close(): void
    }

    class Administration {
        +bannedIPs: Seq<String>
        +whitelist: Seq<String>
        +subnetBans: Seq<String>
        +dosBlacklist: ObjectSet<String>
        +kickedIPs: ObjectMap<String, Long>
        +bannedNames: Seq<Pattern>
        +playerInfo: ObjectMap<String, PlayerInfo>
        +chatFilters: Seq<ChatFilter>
        +actionFilters: Seq<ActionFilter>
        ==
        +blacklistDos(address: String): void
        +unBlacklistDos(address: String): void
        +isDosBlacklisted(address: String): boolean
        +getKickTime(uuid: String, ip: String): long
        +handleKicked(uuid: String, ip: String, duration: long): void
        +banPlayer(uuid: String): boolean
        +banPlayerIP(ip: String): boolean
        +unbanPlayerIP(ip: String): boolean
        +unbanPlayerID(id: String): boolean
        +adminPlayer(id: String, usid: String): boolean
        +unAdminPlayer(id: String): boolean
        +filterMessage(player: Player, message: String): String
        +allowAction(player: Player, type: ActionType, tile: Tile, setter: Cons<PlayerAction>): boolean
        +addChatFilter(filter: ChatFilter): void
        +addActionFilter(filter: ActionFilter): void
        +isIPBanned(ip: String): boolean
        +isIDBanned(uuid: String): boolean
        +isNameBanned(name: String): boolean
        +isAdmin(id: String, usid: String): boolean
        +isWhitelisted(id: String, usid: String): boolean
        +getInfo(id: String): PlayerInfo
        +findByIP(ip: String): PlayerInfo
        +findByName(name: String): ObjectSet<PlayerInfo>
        +getAdmins(): Seq<PlayerInfo>
        +getBanned(): Seq<PlayerInfo>
        +getPlayerLimit(): int
        +setPlayerLimit(limit: int): void
        +save(): void
        +forceSave(): void
    }

    class "Administration.PlayerInfo" as PlayerInfo {
        +id: String
        +lastName: String
        +lastIP: String
        +ips: Seq<String>
        +names: Seq<String>
        +adminUsid: String
        +timesKicked: int
        +timesJoined: int
        +banned: boolean
        +admin: boolean
        +lastKicked: long
        ~lastMessageTime: long
        ~lastSyncTime: long
        ~lastSentMessage: String
        ~messageInfractions: int
        ==
        +plainLastName(): String
    }

    class "Administration.TraceInfo" as TraceInfo {
        +ip: String
        +uuid: String
        +locale: String
        +modded: boolean
        +mobile: boolean
        +timesJoined: int
        +timesKicked: int
        +ips: String[]
        +names: String[]
    }

    class "Administration.PlayerAction" as PlayerAction {
        +player: Player
        +type: ActionType
        +tile: Tile
        +block: Block
        +rotation: int
        +config: Object
        +item: Item
        +unit: Unit
        +payload: Payload
        +plans: int[]
        +pingText: String
        +pingX: float
        +pingY: float
        ==
        +set(player, type, tile): PlayerAction
        +set(player, type, unit): PlayerAction
        +reset(): void
    }

    class "Administration.Config" as Config {
        +{static} all: Seq<Config>
        +name: String
        +key: String
        +description: String
        +defaultValue: Object
        +changed: Runnable
        ==
        +bool(): boolean
        +num(): int
        +string(): String
        +get(): Object
        +set(value: Object): void
        +isDefault(): boolean
        +isNum(): boolean
        +isBool(): boolean
        +isString(): boolean
    }

    interface ChatFilter {
        +filter(player: Player, message: String): String
    }

    interface ActionFilter {
        +allow(action: PlayerAction): boolean
    }

    enum ActionType {
        breakBlock
        placeBlock
        rotate
        configure
        withdrawItem
        depositItem
        control
        buildSelect
        command
        removePlanned
        commandUnits
        commandBuilding
        respawn
        pickupBlock
        dropPayload
        pingLocation
    }
}

' ─────────────── Inheritance ────────────────────────
NetServer   ..|> ApplicationListener
NetClient   ..|> ApplicationListener
PlayerInfo  ..|> Serializable
PlayerAction ..|> Poolable

' ─────────────── Composition / Aggregation ──────────
NetServer *-down- Administration       : admins
NetServer o--    TeamAssigner          : assigner
NetServer o--    ChatFormatter         : chatFormatter

Administration *-- PlayerInfo          : playerInfo (0..*)
Administration *-- Config              : Config.all (0..*)
Administration *-- TraceInfo           : <<nested>>
Administration *-- PlayerAction        : <<nested>>
Administration o-- ChatFilter          : chatFilters (0..*)
Administration o-- ActionFilter        : actionFilters (0..*)

' ─────────────── Dependencies ───────────────────────
NetServer   ..>  NetConnection         : accesses player.con
NetClient   ..>  Administration        : uses admins (filterMessage, blacklistDos)
NetConnection ..> Administration       : kick() → handleKicked / save

PlayerAction ..> ActionType            : type

@enduml
