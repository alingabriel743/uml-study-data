@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Planet & Campaign System

' ─────────────────────────────────────────────
' Base / shared types
' ─────────────────────────────────────────────
package "mindustry.ctype" {
    abstract class UnlockableContent {
        +String name
        +unlock()
        +unlocked(): boolean
        +getContentType(): ContentType
    }
}

' ─────────────────────────────────────────────
' Core planet & sector model
' ─────────────────────────────────────────────
package "mindustry.type" {

    class Planet {
        +Vec3 position
        +PlanetGrid grid
        +PlanetGenerator generator
        +Seq<Sector> sectors
        +float radius
        +float orbitRadius
        +float totalRadius
        +float orbitTime
        +float rotateTime
        +int startSector
        +int sectorSeed
        +boolean tidalLock
        +boolean accessible
        +boolean visible
        +boolean hasAtmosphere
        +boolean allowLaunchSchematics
        +boolean allowLaunchLoadout
        +boolean allowSectorInvasion
        +boolean clearSectorOnLose
        +boolean prebuildBase
        +float launchCapacityMultiplier
        +float enemyBuildSpeedMultiplier
        +Planet parent
        +Planet solarSystem
        +Planet statParent
        +Seq<Planet> children
        +Seq<Planet> launchCandidates
        +TechNode techTree
        +Seq<UnlockableContent> unlockedOnLand
        +CampaignRules campaignRules
        +CampaignRules campaignRuleDefaults
        -CampaignStats campaignStats
        +Block defaultCore
        --
        +Planet(name: String, parent: Planet, radius: float)
        +init()
        +load()
        +getStartSector(): Sector
        +getLastSector(): Sector
        +setLastSector(sector: Sector)
        +preset(index: int, preset: SectorPreset)
        +hasGrid(): boolean
        +isLandable(): boolean
        +applyRules(rules: Rules)
        +applyRules(rules: Rules, customGame: boolean)
        +stats(): CampaignStats
        +loadStats() / saveStats() / clearStats()
        +loadRules() / saveRules()
        +getData(): PlanetData
        +getSector(tile: Ptile): Sector
        +getSector(ray: Ray): Sector
        +getContentType(): ContentType
    }

    class "Planet.PlanetData" as PlanetData {
        +ObjectIntMap<String> presets
        +int[] attackSectors
    }

    class Sector {
        +final Planet planet
        +final Ptile tile
        +final int id
        +final SectorRect rect
        +final Plane plane
        +SaveSlot save
        +SectorPreset preset
        +Sector shieldTarget
        +SectorInfo info
        +float threat
        +boolean generateEnemyBase
        --
        +Sector(planet: Planet, tile: Ptile)
        +near(): Seq<Sector>
        +isNear(other: Sector): boolean
        +unlocked(): boolean
        +locked(): boolean
        +hasBase(): boolean
        +hasEnemyBase(): boolean
        +isCaptured(): boolean
        +isAttacked(): boolean
        +isFrozen(): boolean
        +isShielded(): boolean
        +allowLaunchSchematics(): boolean
        +allowLaunchLoadout(): boolean
        +name(): String
        +displayThreat(): String
        +addItems(items: ItemSeq)
        +removeItems(items: ItemSeq)
        +items(): ItemSeq
        #makeRect(): SectorRect
    }

    class "Sector.SectorRect" as SectorRect {
        +float radius
        +float rotation
        +Vec3 center
        +Vec3 top
        +Vec3 right
        +project(x: float, y: float): Vec3
    }

    class SectorPreset {
        +FileMapGenerator generator
        +Planet planet
        +Sector sector
        +int captureWave
        +float difficulty
        +float startWaveTimeMultiplier
        +boolean requireUnlock
        +boolean showHidden
        +boolean isLastSector
        +boolean overrideLaunchDefaults
        +boolean allowLaunchSchematics
        +boolean allowLaunchLoadout
        +boolean attackAfterWaves
        +int originalPosition
        +Seq<Sector> shieldSectors
        +Cons<Rules> rules
        --
        +SectorPreset(name: String, planet: Planet, sector: int)
        +initialize(planet: Planet, sector: int)
        +init()
        +loadIcon()
        +isHidden(): boolean
        +getContentType(): ContentType
    }
}

' ─────────────────────────────────────────────
' Tech Tree
' ─────────────────────────────────────────────
package "mindustry.content" {

    class TechTree <<utility>> {
        +{static} Seq<TechNode> all
        +{static} Seq<TechNode> roots
        -{static} TechNode context
        --
        +{static} nodeRoot(name: String, content: UnlockableContent, children: Runnable): TechNode
        +{static} node(content: UnlockableContent, children: Runnable): TechNode
        +{static} node(content: UnlockableContent, requirements: ItemStack[], objectives: Seq<Objective>, children: Runnable): TechNode
        +{static} nodeProduce(content: UnlockableContent, objectives: Seq<Objective>, children: Runnable): TechNode
        +{static} context(): TechNode
    }

    class TechNode {
        +int depth
        +Drawable icon
        +String name
        +boolean requiresUnlock
        +TechNode parent
        +UnlockableContent content
        +ItemStack[] requirements
        +ItemStack[] finishedRequirements
        +Seq<Objective> objectives
        +Seq<TechNode> children
        +Planet planet
        +ObjectFloatMap<Item> researchCostMultipliers
        --
        +TechNode(parent: TechNode, content: UnlockableContent, requirements: ItemStack[])
        +each(consumer: Cons<TechNode>)
        +addDatabaseTab(tab: UnlockableContent)
        +addPlanet(planet: Planet)
        +icon(): Drawable
    }
}

' ─────────────────────────────────────────────
' Game state
' ─────────────────────────────────────────────
package "mindustry.game" {

    class SectorInfo {
        +ObjectMap<Item, ExportStat> production
        +ObjectMap<Item, ExportStat> export
        +ObjectMap<Item, ExportStat> imports
        +ItemSeq items
        +Block bestCoreType
        +int storageCapacity
        +boolean hasCore
        +String lastPresetName
        --
        +prepare(sector: Sector)
        +update()
        +handleCoreItem(item: Item, amount: int)
        +handleProduction(item: Item, amount: int)
        +getExport(item: Item): float
        +write()
    }

    class CampaignRules {
        ' Serialised per-planet to Core.settings
        ' Key: "<planetName>-campaign-rules"
    }

    class CampaignStats {
        ' Serialised per-planet to Core.settings
        ' Key: "<planetName>-campaign-stats"
        ' Shared via Planet.statParent
    }
}

' ─────────────────────────────────────────────
' UI — Planet Dialog
' ─────────────────────────────────────────────
package "mindustry.ui.dialogs" {

    enum Mode {
        look
        select
        planetLaunch
    }

    class PlanetDialog {
        +FrameBuffer buffer
        +LaunchLoadoutDialog loadouts
        +PlanetRenderer planets
        +PlanetParams state
        +float zoom
        +Sector selected
        +Sector hovered
        +Sector launchSector
        +Seq<Planet> launchCandidates
        +Mode mode
        +boolean launching
        +Cons<Sector> listener
        --
        +PlanetDialog()
        +show(): Dialog
        +showOverview()
        +showPlanetLaunch(sector: Sector, candidates: Seq<Planet>, listener: Cons<Sector>)
        +showSelect(sector: Sector, listener: Cons<Sector>)
        +lookAt(sector: Sector)
        +selectSector(sector: Sector)
        +abandonSectorConfirm(sector: Sector, listener: Runnable)
        +viewPlanet(planet: Planet, pan: boolean)
        +canSelect(sector: Sector): boolean
        +findLauncher(to: Sector): Sector
        +renderSectors(planet: Planet)
        +renderProjections(planet: Planet)
        +draw()
        +act(delta: float)
    }
}

' ─────────────────────────────────────────────
' External / support stubs
' ─────────────────────────────────────────────
package "arc / mindustry (external)" {
    abstract class BaseDialog
    interface PlanetInterfaceRenderer {
        +renderSectors(planet: Planet)
    }
    class PlanetGrid <<geodesic>> {
        +Ptile[] tiles
    }
    class PlanetGenerator {
        +generateSector(sector: Sector)
    }
    class SaveSlot {
        +String name
    }
}

' ─────────────────────────────────────────────
' Inheritance
' ─────────────────────────────────────────────
Planet         --|> UnlockableContent
SectorPreset   --|> UnlockableContent
PlanetDialog   --|> BaseDialog
PlanetDialog   ..|> PlanetInterfaceRenderer

' ─────────────────────────────────────────────
' Composition / Aggregation
' ─────────────────────────────────────────────
Planet         *-- "many" Sector            : sectors (composition)
Planet         *-- PlanetData               : data (inner, JSON-loaded)
Planet         o-- "0..*" Planet            : children / launchCandidates
Planet         o-- Planet                   : parent / solarSystem / statParent
Planet         *-- TechNode                 : techTree (root node)
Planet         *-- CampaignRules            : campaignRules / defaults
Planet         *-- CampaignStats            : campaignStats (private)
Planet         o-- PlanetGrid               : grid
Planet         o-- PlanetGenerator          : generator

Sector         *-- SectorRect               : rect (inner)
Sector         *-- SectorInfo               : info
Sector         o-- SectorPreset             : preset (nullable)
Sector         o-- SaveSlot                 : save (nullable)

SectorPreset   o-- Planet                   : planet
SectorPreset   o-- Sector                   : sector
SectorPreset   o-- "0..*" Sector            : shieldSectors

TechTree       *-- "many" TechNode          : all / roots (static)
TechNode       o-- TechNode                 : parent
TechNode       *-- "many" TechNode          : children
TechNode       o-- UnlockableContent        : content
TechNode       o-- Planet                   : planet (nullable)

PlanetDialog   *-- Mode                     : mode
PlanetDialog   o-- Sector                   : selected / hovered / launchSector
PlanetDialog   ..> Planet                   : navigates / renders
PlanetDialog   ..> TechNode                 : addTech()

@enduml
