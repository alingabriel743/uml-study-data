@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F9A825

title Power & Liquid Systems

' ─────────────────────────────────────────────────────────────────────────────
' External / shared references (summarised)
' ─────────────────────────────────────────────────────────────────────────────
class Building {
    +PowerModule power
    +LiquidModule liquids
}

interface Entityc
interface Autotiler
interface ChainedBuilding

' ─────────────────────────────────────────────────────────────────────────────
' Block-module layer
' ─────────────────────────────────────────────────────────────────────────────
package "mindustry.world.modules" {

    abstract class BlockModule {
        +{abstract} write(write: Writes): void
        +read(read: Reads, legacy: boolean): void
        +read(read: Reads): void
    }

    class PowerModule {
        +float status
        +boolean init
        +PowerGraph graph
        +IntSeq links
        +write(write: Writes): void
        +read(read: Reads): void
    }

    class LiquidModule {
        +float[] liquids
        +Liquid current
        +WindowedMean[] flow
        +get(liquid: Liquid): float
        +add(liquid: Liquid, amount: float): void
        +remove(liquid: Liquid, amount: float): void
        +reset(liquid: Liquid, amount: float): void
        +handleFlow(liquid: Liquid, amount: float): void
        +each(cons: LiquidConsumer): void
        +sum(calc: LiquidCalculator): float
        +updateFlow(): void
        +stopFlow(): void
        +getFlowRate(liquid: Liquid): float
        +hasFlowLiquid(liquid: Liquid): boolean
        +currentAmount(): float
        +clear(): void
    }

    interface LiquidConsumer {
        +accept(liquid: Liquid, amount: float): void
    }

    interface LiquidCalculator {
        +get(liquid: Liquid, amount: float): float
    }
}

' ─────────────────────────────────────────────────────────────────────────────
' Consumer layer
' ─────────────────────────────────────────────────────────────────────────────
package "mindustry.world.consumers" {

    abstract class Consume {
        +boolean optional
        +boolean booster
        +boolean update
        +Floatf<Building> multiplier
        +{abstract} efficiency(build: Building): float
        +apply(block: Block): void
        +optional(optional: boolean, boost: boolean): Consume
        +boost(): Consume
        +ignore(): boolean
        +trigger(build: Building): void
        +update(build: Building): void
        +efficiencyMultiplier(build: Building): float
        +display(stats: Stats): void
    }

    class ConsumePower {
        +float usage
        +float capacity
        +boolean buffered
        +apply(block: Block): void
        +ignore(): boolean
        +efficiency(build: Building): float
        +requestedPower(build: Building): float
        +display(stats: Stats): void
    }
}

' ─────────────────────────────────────────────────────────────────────────────
' Power-graph infrastructure
' ─────────────────────────────────────────────────────────────────────────────
package "mindustry.world.blocks.power" {

    class PowerGraph {
        +Seq<Building> producers
        +Seq<Building> consumers
        +Seq<Building> batteries
        +Seq<Building> all
        +PowerGraphUpdater entity
        +WindowedMean powerBalance
        +float lastPowerProduced
        +float lastPowerNeeded
        +float lastPowerStored
        +float energyDelta
        +int graphID
        +update(): void
        +getPowerNeeded(): float
        +getPowerProduced(): float
        +getBatteryStored(): float
        +getBatteryCapacity(): float
        +useBatteries(needed: float): float
        +chargeBatteries(excess: float): float
        +transferPower(amount: float): void
        +distributePower(needed: float, produced: float, charged: boolean): void
        +getSatisfaction(): float
        +add(build: Building): void
        +addGraph(graph: PowerGraph): void
        +remove(build: Building): void
        +reflow(build: Building): void
        +getPowerBalance(): float
    }

    class PowerBlock {
        ' hasPower=true, solid=true
        ' group=BlockGroup.power
    }

    class PowerDistributor {
        ' consumesPower=false, outputsPower=true
    }

    class Battery {
        +DrawBlock drawer
        +Color emptyLightColor
        +Color fullLightColor
        ' outputsPower=true, consumesPower=true
        ' buffered ConsumePower → classified as battery
    }

    class BatteryBuild {
        +draw(): void
        +drawLight(): void
        +warmup(): float
        +overwrote(replaced: Seq<Building>): void
        +status(): BlockStatus
    }
}

' ─────────────────────────────────────────────────────────────────────────────
' PowerGraph entity driver (annotation-processed component)
' ─────────────────────────────────────────────────────────────────────────────
package "mindustry.entities.comp" {

    abstract class PowerGraphUpdaterComp {
        +PowerGraph graph
        +update(): void
        ' Annotation-processed → generates PowerGraphUpdater entity
    }
}

' ─────────────────────────────────────────────────────────────────────────────
' Block definition (power- and liquid-relevant fields only)
' ─────────────────────────────────────────────────────────────────────────────
package "mindustry.world" {

    class Block {
        +boolean hasPower
        +boolean consumesPower
        +boolean outputsPower
        +boolean connectedPower
        +ConsumePower consPower
        +boolean hasLiquids
        +boolean outputsLiquid
        +float liquidCapacity
    }
}

' ─────────────────────────────────────────────────────────────────────────────
' Liquid-block hierarchy
' ─────────────────────────────────────────────────────────────────────────────
package "mindustry.world.blocks.liquid" {

    class LiquidBlock {
        +TextureRegion liquidRegion
        +TextureRegion topRegion
        +TextureRegion bottomRegion
        +{static} drawTiledFrames(size: int, x: float, y: float, rotation: float, liquid: Liquid, alpha: float): void
    }

    class LiquidBuild {
        +draw(): void
    }

    class Conduit {
        +boolean padCorners
        +boolean leaks
        +Block junctionReplacement
        +Block bridgeReplacement
        +Block rotBridgeReplacement
        +blends(tile: Tile, rotation: int, ...): boolean
        +getReplacement(plan: BuildPlan, plans: Seq<BuildPlan>): Block
        +handlePlacementLine(plans: Seq<BuildPlan>): void
    }

    class ConduitBuild {
        +float smoothLiquid
        +int blendbits
        +int xscl
        +int yscl
        +boolean capped
        +boolean backCapped
        +updateTile(): void
        +acceptLiquid(source: Building, liquid: Liquid): boolean
        +next(): Building
        +onProximityUpdate(): void
        +draw(): void
        +drawAt(x: float, y: float, rotation: int, bits: int, slice: SliceMode): void
    }
}

' ─────────────────────────────────────────────────────────────────────────────
' Inheritance hierarchy
' ─────────────────────────────────────────────────────────────────────────────
BlockModule <|-- PowerModule
BlockModule <|-- LiquidModule

Consume <|-- ConsumePower

Block <|-- PowerBlock
PowerBlock <|-- PowerDistributor
PowerDistributor <|-- Battery

Block <|-- LiquidBlock
LiquidBlock <|-- Conduit

Building <|-- BatteryBuild
Building <|-- LiquidBuild
LiquidBuild <|-- ConduitBuild

' ─────────────────────────────────────────────────────────────────────────────
' Interface implementations
' ─────────────────────────────────────────────────────────────────────────────
PowerGraphUpdaterComp ..|> Entityc
Conduit ..|> Autotiler
ConduitBuild ..|> ChainedBuilding

' ─────────────────────────────────────────────────────────────────────────────
' Inner-class nesting
' ─────────────────────────────────────────────────────────────────────────────
Battery +-- BatteryBuild
LiquidBlock +-- LiquidBuild
Conduit +-- ConduitBuild
LiquidModule +-- LiquidConsumer
LiquidModule +-- LiquidCalculator

' ─────────────────────────────────────────────────────────────────────────────
' Composition & association
' ─────────────────────────────────────────────────────────────────────────────

' PowerModule owns a PowerGraph (1:1 per building)
PowerModule *-- PowerGraph : graph

' PowerGraph owns one updater entity that drives its update() each tick
PowerGraph *-- PowerGraphUpdaterComp : entity

' PowerGraph categorises buildings into role buckets
PowerGraph o-- Building : producers / consumers / batteries

' Block carries a ConsumePower reference; ConsumePower.apply() sets it
Block o-- ConsumePower : consPower
ConsumePower ..> Block : apply() → hasPower=true, consPower=this

' ConsumePower reads power.status from the building's PowerModule
ConsumePower ..> PowerModule : reads status

' Building aggregates its modules
Building o-- PowerModule : .power
Building o-- LiquidModule : .liquids

' ConduitBuild delegates liquid transfer to LiquidModule via moveLiquidForward()
ConduitBuild ..> LiquidModule : moveLiquidForward() / acceptLiquid guard

@enduml
