@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Production & Crafting Blocks

' ─── Interfaces ───────────────────────────────────────────────────────────────

interface Autotiler {
    +blends(...): boolean
}

interface ChainedBuilding

' ─── Base Classes (stubs) ─────────────────────────────────────────────────────

package "mindustry.world (base)" {
    abstract class Block {
        +name: String
        +update: boolean
        +solid: boolean
        +hasItems: boolean
        +size: int
    }

    abstract class Building {
        +tile: Tile
        +team: Team
        +health: float
        --
        +updateTile()
        +draw()
        +write(write: Writes)
        +read(read: Reads, revision: byte)
    }
}

' ─── External referenced types ────────────────────────────────────────────────

class DrawBlock <<external>> {
    +draw(build: Building)
    +load(block: Block)
}

class UnitType <<external>> {
    +name: String
    +create(team: Team): Unit
}

' ─── Production ───────────────────────────────────────────────────────────────

package "mindustry.world.blocks.production" {

    class GenericCrafter {
        +outputItem: ItemStack
        +outputItems: ItemStack[]
        +outputLiquid: LiquidStack
        +outputLiquids: LiquidStack[]
        +liquidOutputDirections: int[]
        +craftTime: float = 80
        +craftEffect: Effect
        +warmupSpeed: float = 0.019
        +drawer: DrawBlock
        --
        +setStats()
        +setBars()
        +rotatedOutput(x: int, y: int, dest: Tile): boolean
        +outputsItems(): boolean
        +icons(): TextureRegion[]
    }

    class "GenericCrafterBuild" as GenericCrafterBuild {
        +progress: float
        +totalProgress: float
        +warmup: float
        --
        +updateTile()
        +craft()
        +dumpOutputs()
        +shouldConsume(): boolean
        +getProgressIncrease(baseTime: float): float
        +warmup(): float
        +progress(): float
        +sense(sensor: LAccess): double
        +write(write: Writes)
        +read(read: Reads, revision: byte)
    }

    class Drill {
        +tier: int
        +drillTime: float = 300
        +hardnessDrillMultiplier: float = 50
        +liquidBoostIntensity: float = 1.6
        +warmupSpeed: float = 0.015
        +blockedItem: Item
        #returnItem: Item
        #returnCount: int
        +drillMultipliers: ObjectFloatMap<Item>
        --
        +getDrop(tile: Tile): Item
        +canPlaceOn(tile: Tile, team: Team, rot: int): boolean
        +getDrillTime(item: Item): float
        +setStats()
        #countOre(tile: Tile)
        +canMine(tile: Tile): boolean
    }

    class "DrillBuild" as DrillBuild {
        +progress: float
        +warmup: float
        +timeDrilled: float
        +lastDrillSpeed: float
        +dominantItem: Item
        +dominantItems: int
        --
        +updateTile()
        +onProximityUpdate()
        +shouldConsume(): boolean
        +ambientVolume(): float
        +draw()
        +write(write: Writes)
        +read(read: Reads, revision: byte)
    }
}

' ─── Distribution ─────────────────────────────────────────────────────────────

package "mindustry.world.blocks.distribution" {

    class Conveyor {
        -itemSpace: float = 0.4
        -capacity: int = 3
        +speed: float
        +displayedSpeed: float
        +pushUnits: boolean
        +junctionReplacement: Block
        +bridgeReplacement: Block
        --
        +setStats()
        +blends(...): boolean
        +canReplace(other: Block): boolean
        +isAccessible(): boolean
        +handlePlacementLine(plans: Seq<BuildPlan>)
        +icons(): TextureRegion[]
    }

    class "ConveyorBuild" as ConveyorBuild {
        +ids: Item[3]
        +xs: float[3]
        +ys: float[3]
        +len: int
        +next: Building
        +nextc: ConveyorBuild
        +aligned: boolean
        +clogHeat: float
        --
        +updateTile()
        +onProximityUpdate()
        +pass(item: Item): boolean
        +unitOn(unit: Unit)
        +draw()
        +removeStack(item: Item, amount: int): int
    }
}

' ─── Payloads ─────────────────────────────────────────────────────────────────

package "mindustry.world.blocks.payloads" {

    class PayloadBlock {
        +payloadSpeed: float = 0.7
        +payloadRotateSpeed: float = 5
        +regionSuffix: String
        +topRegion: TextureRegion
        +outRegion: TextureRegion
        +inRegion: TextureRegion
    }

    class "PayloadBlockBuild<T>" as PayloadBlockBuild {
        ' Generic base for payload-producing buildings
    }

    class PayloadConveyor {
        +moveTime: float = 45
        +moveForce: float = 201
        +interp: Interp
        +payloadLimit: float = 3
        +pushUnits: boolean
        --
        +icons(): TextureRegion[]
        +drawPlace(x: int, y: int, rot: int, valid: boolean)
        +setStats()
        +init()
    }

    class "PayloadConveyorBuild" as PayloadConveyorBuild {
        +item: Payload
        +progress: float
        +animation: float
        +next: Building
        +blocked: boolean
        +step: int
        --
        +updateTile()
        +onProximityUpdate()
        +checkBlocked()
        +acceptPayload(source: Building, payload: Payload): boolean
        +handlePayload(source: Building, payload: Payload)
        +unitOn(unit: Unit)
        +takePayload(): Payload
        +draw()
    }
}

' ─── Units ────────────────────────────────────────────────────────────────────

package "mindustry.world.blocks.units" {

    class UnitBlock {
        --
        +UnitBlock(name: String)
        +unitBlockSpawn(tile: Tile) «Remote»
    }

    class "UnitBuild" as UnitBuild {
        +progress: float
        +time: float
        +speedScl: float
        --
        +spawned()
        +dumpPayload()
    }

    class UnitFactory {
        +capacities: int[]
        +plans: Seq<UnitPlan>
        +createSound: Sound
        +createSoundVolume: float = 1
        --
        +init()
        +initCapacities()
        +setBars()
        +setStats()
        +outputsItems(): boolean
        +icons(): TextureRegion[]
    }

    class UnitPlan <<static>> {
        +unit: UnitType
        +requirements: ItemStack[]
        +time: float
        --
        +UnitPlan(unit: UnitType, time: float, requirements: ItemStack[])
    }

    class "UnitFactoryBuild" as UnitFactoryBuild {
        +commandPos: Vec2
        +command: UnitCommand
        +currentPlan: int = -1
        --
        +updateTile()
        +shouldConsume(): boolean
        +acceptItem(source: Building, item: Item): boolean
        +buildConfiguration(table: Table)
        +draw()
        +config(): Object
        +unit(): UnitType
        +write(write: Writes)
        +read(read: Reads, revision: byte)
    }
}

' ─── Block Inheritance ────────────────────────────────────────────────────────

GenericCrafter    --|> Block
Drill             --|> Block
Conveyor          --|> Block
PayloadBlock      --|> Block
PayloadConveyor   --|> Block
UnitBlock         --|> PayloadBlock
UnitFactory       --|> UnitBlock

' ─── Building Inheritance ─────────────────────────────────────────────────────

GenericCrafterBuild  --|> Building
DrillBuild           --|> Building
ConveyorBuild        --|> Building
PayloadBlockBuild    --|> Building
UnitBuild            --|> PayloadBlockBuild
UnitFactoryBuild     --|> UnitBuild
PayloadConveyorBuild --|> Building

' ─── Interface Implementations ────────────────────────────────────────────────

Conveyor      ..|> Autotiler
ConveyorBuild ..|> ChainedBuilding

' ─── Inner Class Nesting ──────────────────────────────────────────────────────

GenericCrafter  +-- GenericCrafterBuild
Drill           +-- DrillBuild
Conveyor        +-- ConveyorBuild
PayloadBlock    +-- PayloadBlockBuild
PayloadConveyor +-- PayloadConveyorBuild
UnitBlock       +-- UnitBuild
UnitFactory     +-- UnitPlan
UnitFactory     +-- UnitFactoryBuild

' ─── Compositions & Key Associations ─────────────────────────────────────────

GenericCrafter       *--  "drawer"  DrawBlock      : contains
UnitFactory          *--  "plans"   UnitPlan       : contains
UnitPlan             -->            UnitType        : references
ConveyorBuild        -->  "next"    ConveyorBuild   : peer reference
PayloadConveyorBuild -->  "next"    Building        : forward building

@enduml
