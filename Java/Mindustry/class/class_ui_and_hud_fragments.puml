@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D6EAF8
    BorderColor #2980B9
    FontColor #1A5276
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title UI & HUD Fragments

' ── External types (arc / libgdx framework) ───────────────────────────────────
package "arc (framework)" <<Frame>> {
    interface ApplicationListener {
        +void update()
        +void resize(int width, int height)
    }

    interface Loadable {
        +void loadAsync()
        +void loadSync()
    }

    class Table <<scene.ui>> {
    }
}

' ── mindustry.core ─────────────────────────────────────────────────────────────
package "mindustry.core" {
    class UI {
        +{static} String billions
        +{static} String millions
        +{static} String thousands
        +{static} PixmapPacker packer
        __fragments__
        +MenuFragment menufrag
        +HudFragment hudfrag
        +ChatFragment chatfrag
        +ConsoleFragment consolefrag
        +MinimapFragment minimapfrag
        +PlayerListFragment listfrag
        +LoadingFragment loadfrag
        +HintsFragment hints
        __layout groups__
        +WidgetGroup menuGroup
        +WidgetGroup hudGroup
        __private state__
        -Element lastAnnouncement
        -ObjectMap<String, Table> popups
        -IntMap<Table> labels
        __lifecycle__
        +void init()
        +void update()
        +void resize(int width, int height)
        +void loadAsync()
        +void loadSync()
        +void updateMargins()
        __ui helpers__
        +void loadAnd(Runnable call)
        +void loadAnd(String text, Runnable call)
        +void showInfo(String info)
        +void showInfoFade(String info, float duration)
        +void showInfoToast(String info, float duration)
        +void showConfirm(String title, String text, Boolp hide, Runnable confirmed)
        +void showCustomConfirm(String title, String text, String yes, String no, ...)
        +void showErrorMessage(String text)
        +void showException(String text, Throwable exc)
        +void announce(String text, float duration)
        +boolean hasAnnouncement()
        +void showMenu(String title, String message, String[][] options, Intc cb)
        +void showFollowUpMenu(int menuId, String title, ...)
        +void hideFollowUpMenu(int menuId)
        __static utilities__
        +{static} String formatAmount(long number)
        +{static} String formatTime(float ticks)
        +{static} String formatIcons(String s)
        +{static} int roundAmount(int number)
        +{static} void loadColors()
    }
}

' ── mindustry.ui.fragments ─────────────────────────────────────────────────────
package "mindustry.ui.fragments" {

    class HudFragment {
        +{static} float dsize
        +{static} float pauseHeight
        +PlacementFragment blockfrag
        +CoreItemsDisplay coreItems
        +boolean shown
        -ImageButton flip
        -String hudText
        -boolean showHudText
        -Table lastUnlockTable
        -Table lastUnlockLayout
        -long lastToast
        -float pauseDisableDur
        -Seq<Block> blocksOut
        -Table hudLabel
        __
        +void build(Group parent)
        +void setHudText(String text)
        +void toggleHudText(boolean shown)
        +boolean hasToast()
        +void showToast(String text)
        +void showToast(Drawable icon, String text)
        +void showToast(Drawable icon, float size, String text)
        +void showPauseDisabled()
        +void showUnlock(UnlockableContent content)
        +{static} void setPlayerTeamEditor(Player player, Team team)
        -void scheduleToast(Runnable run)
        -void toggleMenus()
        -Table makeStatusTable()
        -void addInfoTable(Table table)
        -boolean canSkipWave()
    }

    class MenuFragment {
        -Table container
        -Table submenu
        -Button currentMenu
        -MenuRenderer renderer
        -Seq<MenuButton> customButtons
        +Seq<MenuButton> desktopButtons
        __
        +void build(Group parent)
        +void addButton(String text, Drawable icon, Runnable callback)
        +void addButton(String text, Runnable callback)
        +void addButton(MenuButton button)
        -void buildMobile()
        -void buildDesktop()
        -void checkPlay(Runnable run)
        -void fadeInMenu()
        -void fadeOutMenu()
        -void buttons(Table t, MenuButton... buttons)
    }

    class MenuButton <<inner>> {
        ' inner static class of MenuFragment
    }

    class MinimapFragment {
        -boolean shown
        -float baseSize
        +Element elem
        __
        +void build(Group parent)
        +void panTo(float relativeX, float relativeY)
        +Vec2 convert(float relativeX, float relativeY)
        +boolean shown()
        +void hide()
        +void toggle()
    }

    class ChatFragment {
        __
        +void build(Group parent)
        +void toggle()
        +void hide()
    }

    class ConsoleFragment {
        __
        +void build(Group parent)
        +void toggleMobile()
        +void toggle()
        +void hide()
    }

    class PlayerListFragment {
        __
        +void build(Group parent)
        +void toggle()
    }

    class LoadingFragment {
        __
        +void build(Group parent)
        +void show()
        +void show(String text)
        +void hide()
    }

    class HintsFragment {
        __
        +void build(Group parent)
    }

    class PlacementFragment {
        __
        +void build(Group parent)
        -void addBlockSelection(Table cont)
        -{static} void loadFavorites()
        -{static} void saveFavorites()
        -{static} boolean isFavorite(Block block)
        -{static} void toggleFavorite(Block block)
        -void rebuildBlockSelection(Table blockSelection, String searchText)
    }

    class CoreItemsDisplay <<display>> {
        ' Displays core resource counts in HUD
    }
}

' ── mindustry.world.meta ───────────────────────────────────────────────────────
package "mindustry.world.meta" {

    interface StatValue {
        +void display(Table table)
    }

    class StatValues <<utility>> {
        +{static} StatValue string(String value, Object... args)
        +{static} StatValue bool(boolean value)
        +{static} StatValue number(float value, StatUnit unit, boolean merge)
        +{static} StatValue multiplierModifier(float value, StatUnit unit, boolean merge)
        +{static} StatValue percentModifier(float value, StatUnit unit, boolean merge)
        +{static} StatValue liquid(Liquid liquid, float amount, boolean perSecond)
        +{static} StatValue liquids(Boolf<Liquid> filter, float amount, boolean perSecond)
        +{static} StatValue items(ItemStack... stacks)
        +{static} StatValue items(float timePeriod, ItemStack... stacks)
        +{static} StatValue content(UnlockableContent content)
        +{static} StatValue blocks(Boolf<Block> pred)
        +{static} StatValue weapons(UnitType unit, Seq<Weapon> weapons)
        +{static} StatValue abilities(Seq<Ability> abilities)
        +{static} StatValue ammo(ObjectMap<T, BulletType> map, boolean nested, boolean showUnit)
        +{static} StatValue boosters(float reload, float maxUsed, float multiplier, ...)
        +{static} StatValue drillables(float drillTime, float drillMultiplier, ...)
        +{static} Table displayLiquid(Liquid liquid, float amount, boolean perSecond)
        +{static} Table displayItem(Item item, int amount, boolean showName)
        +{static} String fixValue(float value)
        +{static} StatValue squared(float value, StatUnit unit)
    }
}

' ── Dialogs note ───────────────────────────────────────────────────────────────
note bottom of UI
  UI also owns dialog instances:
  AboutDialog, GameOverDialog, PausedDialog,
  SettingsMenuDialog, MapEditorDialog, PlanetDialog,
  ResearchDialog, SchematicsDialog, LogicDialog,
  CampaignCompleteDialog, CampaignRulesDialog,
  IntMap<Dialog> followUpMenus
end note

' ── Relationships ──────────────────────────────────────────────────────────────

' UI implements arc interfaces
UI ..|> ApplicationListener
UI ..|> Loadable

' UI composes fragments (strong ownership)
UI *-- HudFragment        : hudfrag
UI *-- MenuFragment       : menufrag
UI *-- ChatFragment       : chatfrag
UI *-- ConsoleFragment    : consolefrag
UI *-- MinimapFragment    : minimapfrag
UI *-- PlayerListFragment : listfrag
UI *-- LoadingFragment    : loadfrag
UI *-- HintsFragment      : hints

' HudFragment composes sub-fragments
HudFragment *-- PlacementFragment  : blockfrag
HudFragment *-- CoreItemsDisplay   : coreItems

' ChatFragment and ConsoleFragment extend arc Table
ChatFragment    --|> Table
ConsoleFragment --|> Table

' MenuButton is an inner class of MenuFragment
MenuFragment +-- MenuButton

' StatValues factory produces StatValue lambdas
StatValues ..> StatValue : <<creates>>

' StatValues uses UI formatting utilities
StatValues ..> UI : UI.formatAmount()

@enduml
