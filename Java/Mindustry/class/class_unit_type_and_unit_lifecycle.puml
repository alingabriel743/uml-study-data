@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EEF4FF
    BorderColor #5B7EC2
}
skinparam abstract {
    BackgroundColor #FFF8EE
    BorderColor #C27A1A
}

title Unit Type & Unit Lifecycle

' ─── External / base types ───────────────────────────────────────────────────

class UnlockableContent <<content>> {
}

interface Senseable <<interface>> {
}

interface Cloneable <<interface>> {
}

class Unit <<entity>> {
    +UnitType type
    +Team team
    +WeaponMount[] mounts
    +Ability[] abilities
    +float x, y, health, shield
    +float elevation, rotation
    +void setType(UnitType type)
    +void heal()
    +void add()
    +void killed()
    +void remove()
}

class BulletType <<type>> {
    +float damage
    +float speed
    +float lifetime
    +Bullet create(...)
}

class ShootPattern <<pattern>> {
    +int shots
    +float shotDelay
    +void shoot(...)
}

class DrawPart <<visual>> {
}

class UnitEngine <<component>> {
}

' ─── mindustry.type ──────────────────────────────────────────────────────────

package "mindustry.type" {

    class UnitType {
        ' Movement & combat stats
        +float speed, health, armor, hitSize
        +float rotateSpeed, drag, accel
        +float boostMultiplier, fallSpeed
        +float range, maxRange, mineRange
        ' Behaviour flags
        +boolean flying, canBoost, hovering
        +boolean omniMovement, naval
        +boolean targetAir, targetGround
        +boolean faceTarget, circleTarget
        +boolean hittable, killable, targetable
        +boolean logicControllable, playerControllable
        +boolean useUnitCap, pickupUnits, canDrown
        ' Capacity & environment
        +int itemCapacity, ammoCapacity, mineTier
        +int legCount, segments
        +int envRequired, envEnabled, envDisabled
        ' Type-level composition
        +float dpsEstimate, targetPriority
        +Prov<Unit> constructor
        +Prov<UnitController> aiController
        +Func<Unit, UnitController> controller
        +Seq<Weapon> weapons
        +Seq<Ability> abilities
        +Seq<DrawPart> parts
        +Seq<UnitEngine> engines
        +UnitType segmentUnit
        +UnitType segmentEndUnit
        +AmmoType ammoType
        +PathCost pathCost
        ' Lifecycle methods
        +Unit create(Team team)
        +Unit spawn(Team team, float x, float y)
        +Unit spawn(Team team, float x, float y, float rotation)
        +Unit spawn(Team team, Position pos)
        +UnitController createController(Unit unit)
        +void update(Unit unit)
        +void updatePayload(Unit unit, Unit unitHolder, Building buildingHolder)
        +void killed(Unit unit)
        +void landed(Unit unit)
        ' Query methods
        +boolean targetable(Unit unit, Team targeter)
        +boolean killable(Unit unit)
        +boolean hittable(Unit unit)
        +boolean hasWeapons()
        +boolean allowStance(Unit unit, UnitStance stance)
        +boolean allowCommand(Unit unit, UnitCommand command)
        +void postInit()
        +void init()
    }

    class Weapon {
        +String name
        +BulletType bullet
        ' Position & timing
        +float reload
        +float x, y, shootX, shootY
        +float recoil, recoilTime, recoilPow
        +float rotateSpeed, rotationLimit, baseRotation
        +float inaccuracy, shootCone, minWarmup
        +float targetInterval, targetSwitchInterval
        ' Behaviour flags
        +boolean mirror, rotate, alternate
        +boolean continuous, alwaysContinuous
        +boolean controllable, aiControllable
        +boolean autoTarget, predictTarget
        +boolean alwaysShooting, noAttack
        +boolean top, useAmmo
        +int otherSide
        ' Sub-components
        +ShootPattern shoot
        +Func<Weapon, WeaponMount> mountType
        +StatusEffect shootStatus
        +Seq<DrawPart> parts
        ' Methods
        +void update(Unit unit, WeaponMount mount)
        +void shoot(Unit unit, WeaponMount mount, float shootX, float shootY, float rotation)
        +void bullet(Unit unit, WeaponMount mount, float xOffset, float yOffset, float angleOffset, Mover mover)
        +void handleBullet(Unit unit, WeaponMount mount, Bullet bullet)
        +Teamc findTarget(Unit unit, float x, float y, float range, boolean air, boolean ground)
        +boolean checkTarget(Unit unit, Teamc target, float x, float y, float range)
        +float dps()
        +float range()
        +float shotsPerSec()
        +Weapon copy()
        +void flip()
        +void init()
    }

}

' ─── mindustry.entities.units ────────────────────────────────────────────────

package "mindustry.entities.units" {

    class WeaponMount {
        +final Weapon weapon
        ' Runtime state
        +float reload
        +float rotation, targetRotation
        +float recoil
        +float[] recoils
        +float heat, warmup, charge, smoothReload
        +float aimX, aimY
        +float lastLength, retarget
        +boolean shoot, rotate, side
        +boolean charging, allowShootEffects
        +int totalShots, barrelCounter
        +Bullet bullet
        +Teamc target
        +WeaponMount(Weapon weapon)
    }

    interface UnitController <<interface>> {
        +void updateUnit()
        +boolean isLogicControllable()
    }

}

' ─── mindustry.entities.abilities ────────────────────────────────────────────

package "mindustry.entities.abilities" {

    abstract class Ability {
        ' Synced field
        +boolean display
        +float data
        ' Lifecycle hooks
        +void update(Unit unit)
        +void draw(Unit unit)
        +void death(Unit unit)
        +void created(Unit unit)
        +void init(UnitType type)
        +void displayBars(Unit unit, Table bars)
        +Ability copy()
        +String localized()
    }

}

' ─── mindustry.entities ──────────────────────────────────────────────────────

package "mindustry.entities" {

    class Units <<utility>> {
        ' Lifecycle (network @Remote)
        +{static} boolean canCreate(Team team, UnitType type)
        +{static} int getCap(Team team)
        +{static} String getStringCap(Team team)
        +{static} void notifyUnitSpawn(Unit unit)
        +{static} void unitSpawn(UnitSyncContainer container)
        +{static} void unitDeath(int uid)
        +{static} void unitDestroy(int uid)
        +{static} void unitDespawn(Unit unit)
        +{static} void unitSafeDeath(Unit unit)
        +{static} void unitCapDeath(Unit unit)
        +{static} void unitEnvDeath(Unit unit)
        ' Targeting queries
        +{static} boolean invalidateTarget(Posc target, Team team, float x, float y, float range)
        +{static} boolean isHittable(Posc target, boolean air, boolean ground)
        +{static} Unit closestEnemy(Team team, float x, float y, float range, Boolf<Unit> predicate)
        +{static} Teamc closestTarget(Team team, float x, float y, float range)
        +{static} Teamc bestTarget(Team team, float x, float y, float range, Boolf<Unit> unitPred, Boolf<Building> tilePred, Sortf sort)
        +{static} void nearby(Team team, float x, float y, float radius, Cons<Unit> cons)
    }

    class UnitSyncContainer {
        +Unit unit
    }

}

' ─── Relationships ───────────────────────────────────────────────────────────

' Inheritance & interface implementation
UnitType     --|>  UnlockableContent
UnitType     ..|>  Senseable
Weapon       ..|>  Cloneable
Ability      ..|>  Cloneable

' UnitType composition
UnitType    "1" *-- "0..*" Weapon          : weapons
UnitType    "1" *-- "0..*" Ability         : abilities
UnitType    "1" *-- "0..*" DrawPart        : parts
UnitType    "1" *-- "0..*" UnitEngine      : engines

' UnitType creates / uses
UnitType    ..>  Unit                       : <<creates>> constructor.get()
UnitType    ..>  UnitController             : <<creates>> createController()
UnitType    o--  UnitType                   : segmentUnit / segmentEndUnit

' Weapon sub-components
Weapon      *--  ShootPattern               : shoot
Weapon      ..>  BulletType                 : bullet
Weapon      ..>  Units                      : findTarget / checkTarget

' WeaponMount ↔ Weapon
WeaponMount "1" --> "1" Weapon              : weapon

' Unit runtime state
Unit        "1" *-- "0..*" WeaponMount      : mounts[]
Unit        "1" *-- "0..*" Ability          : abilities[]
Unit        ..>  UnitController             : controller

' Units utility
Units       ..>  Unit                       : manages lifecycle
Units       ..>  UnitType                   : reads caps / targetPriority
Units       *--  UnitSyncContainer
UnitSyncContainer --> Unit                  : unit

@enduml
