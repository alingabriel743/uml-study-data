    "PayloadBlock extends Block",
    "UnitBlock extends PayloadBlock",
    "UnitFactory extends UnitBlock",
    "UnitFactory *-- UnitPlan (plans: Seq<UnitPlan>)",
    "UnitPlan --> UnitType",
    "UnitFactory.UnitFactoryBuild extends UnitBlock.UnitBuild",
