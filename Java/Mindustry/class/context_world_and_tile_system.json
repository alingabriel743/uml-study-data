  "key_relationships": [
    "World composition Tiles (world.tiles: Tiles)",
    "Tiles composition Tile[] (flat array, row-major: y*width+x)",
    "Tile composition Block (block field — the wall/structure)",
    "Tile composition Floor (floor field — base floor layer)",
    "Tile composition Floor (overlay field — overlay/ore layer)",
    "Tile association Building (build field, nullable — living entity on tile)",
    "Floor association Block (blendGroup — self or another Floor)",
    "Floor association Block (wall — wall variant of this floor)",
    "Floor association Block (decoration — boulder/rock variant)",
    "Floor association Liquid (liquidDrop — nullable, pumped liquid)",
    "Block dependency Tile (blockChanged, isDarkened, newBuilding accept/use Tile)",
    "Floor dependency Tile (drawBase, drawMain, drawEdges, drawOverlay all take Tile)"
  ],

  "layering_model": {
    "description": "Each Tile holds THREE independent layers",
    "layers": [
      "floor  (Floor) — base terrain drawn first; drives walkability, speed, liquids",
      "overlay (Floor, actually OverlayFloor) — drawn on top of floor; used for ores, scorch, etc.",
      "block  (Block) — wall/structure placed on the tile; can be multiblock spanning multiple tiles"
    ],
    "draw_order": "floor.drawBase(tile) → [drawEdges → blending] → floor.drawOverlay(tile) [calls overlay.drawBase]",
    "data_bytes": "data (block), floorData (floor), overlayData (overlay), extraData (int, shared)"
  },

  "multiblock_logic": {
    "description": "Blocks with size > 1 are 'multiblocks'. Center tile owns the Building; satellite tiles store same block/build references.",
    "placement": "setBlock() iterates dx/dy offset grid; pass 0 clears, pass 1 assigns proxy refs to non-center tiles",
    "removal": "preChanged() on center tile removes all satellite tiles manually, firing per-tile preChanged/fireChanged"
  },

  "adjacency_and_proximity": {
    "relativeTo": "Returns direction (0-3) from tile to neighbor; -1 if not adjacent",
    "nearby(int rotation)": "Returns Tile at rotation offset (0=east,1=north,2=west,3=south)",
    "getLinkedTiles": "Iterates all tiles belonging to a multiblock (size×size grid)",
    "changed()": "After block change: calls build.updateProximity() or notifies d4 neighbors' onProximityUpdate()"
  },

  "events_fired": [
    "TileChangeEvent — after any block change",
    "TilePreChangeEvent — before any block change",
    "TileFloorChangeEvent — after floor layer change",
    "TileOverlayChangeEvent — after overlay layer change",
    "WorldLoadBeginEvent / WorldLoadEndEvent / WorldLoadEvent — map lifecycle"
  ],

  "important_notes": [
    "No 'Chunk' class exists — Tiles is a single flat array (width*height), not chunk-based",
    "World.tiles is the canonical grid; World.tile(x,y) delegates to tiles.get(x,y)",
    "Floor extends Block; overlay slot stores a Floor (usually OverlayFloor/OreBlock)",
    "Tile.drop() returns overlay.itemDrop if set, otherwise floor.itemDrop (ore priority)",
    "Block.isStatic() = cacheLayer==CacheLayer.walls; affects rendering and darkness",
    "Building is a separate entity tracked per Tile (not modeled here — belongs to entity system)"
  ]
}
