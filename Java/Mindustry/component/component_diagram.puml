@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Mindustry — High-Level Component Architecture

' ─────────────────────────────────────────────
' PLATFORM LAYER
' ─────────────────────────────────────────────
package "Platform Layer" #DDEEFF {
    [Android\nLauncher] as android
    [iOS\nLauncher] as ios
    [Desktop Launcher\n(+ Steam Integration)] as desktop
    [Server\n(Headless)] as server
}

' ─────────────────────────────────────────────
' CORE FRAMEWORK
' ─────────────────────────────────────────────
package "Core Framework" #D5F5E3 {
    [Core Systems\n(Control · World · Logic\nUI · Renderer · NetClient)] as core
    [Content System\n(ContentLoader · MappableContent\nUnlockableContent)] as content
    [Game State\n(Teams · Rules · Events\nFog · Research · Objectives)] as gamestate
    [IO & Serialization\n(SaveIO · MapIO · TypeIO\nJsonIO · SaveVersions)] as iomod
}

' ─────────────────────────────────────────────
' GAME SYSTEMS
' ─────────────────────────────────────────────
package "Game Systems" #FDE8D8 {
    [Entity System\n(ECS Components · Effects\nBullets · Abilities · Parts)] as entities
    [AI System\n(Pathfinder · ControlPathfinder\nUnit AI Types · BaseAI)] as ai
    [Input Handling\n(DesktopInput · MobileInput\nBindings · Placement)] as input
    [Audio System\n(SoundControl · SoundLoop\nSoundPriority)] as audio
    [Rendering\n(Shaders · FogRenderer\nPlanetRenderer · G3D)] as graphics
    [Logic Programming\n(LStatements · VM\nBuiltins · GlobalVars)] as logic
}

' ─────────────────────────────────────────────
' WORLD & MAP
' ─────────────────────────────────────────────
package "World & Map" #F9EBF8 {
    [Map System\n(Maps · Generators\nFilters · SectorDamage)] as maps
    [Async Physics\n(PhysicsWorld · PhysicsBody\nAvoidanceProcess)] as asyncphys
    [Map Editor\n(MapEditor · Objectives\nSprite Cache · Locales)] as editor
}

' ─────────────────────────────────────────────
' EXTENSION LAYER
' ─────────────────────────────────────────────
package "Extension Layer" #FAFAD2 {
    [Mod System\n(Scripts · Plugins\nModClassLoader · DataPatcher)] as mods
    [Annotation Processors\n(EntityProcess · RemoteProcess\nAssetsProcess · StructProcess)] as annotations
}

' ─────────────────────────────────────────────
' DEPENDENCIES
' ─────────────────────────────────────────────

' Platforms → Core
android --> core : launches
ios     --> core : launches
desktop --> core : launches
server  --> core : launches

' Core ↔ major sub-systems
core --> content    : loads & indexes
core --> gamestate  : manages state
core --> iomod      : save / load
core --> entities   : spawns & ticks
core --> graphics   : drives rendering
core --> input      : routes events
core --> audio      : plays sounds
core --> maps       : loads world

' Entity ↔ AI / Physics / Game State
entities --> ai        : assigns controllers
entities --> asyncphys : physics tick
entities --> gamestate : reads teams & rules

' Map subsystem
maps --> content   : references blocks
maps --> iomod     : serialises maps
editor --> maps    : edits map data
editor --> content : picks blocks

' Logic programming
logic --> entities  : reads/writes entity state
logic --> gamestate : reads game variables

' Mod system
mods --> core     : registers content & hooks
mods --> content  : adds custom content

' Annotation processors (build-time)
annotations ..> entities  : generates entity code
annotations ..> iomod     : generates TypeIO stubs
annotations ..> core      : generates remote calls

@enduml
