@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam node {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam artifact {
    BackgroundColor #D9EAF7
    BorderColor #2980B9
    FontColor #1A252F
}
skinparam database {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}
skinparam cloud {
    BackgroundColor #E8F5E9
    BorderColor #388E3C
    FontColor #1B5E20
}
skinparam arrow {
    Color #495057
    FontColor #495057
    FontSize 10
}

title Mindustry — Deployment Diagram

' ─────────────────────────────────────────────
'  SOURCE & BUILD
' ─────────────────────────────────────────────
node "GitHub Actions CI/CD\n(ubuntu-latest, JDK 17)" <<Build Server>> as ci {
    artifact "Mindustry.jar\n(Desktop Client)" as desktopJar
    artifact "server-release.jar\n(Dedicated Server)" as serverJar
    artifact "core-release-deps.jar\n(Dependencies)" as depsJar
    artifact "android-release.apk\n(Android App)" as androidApk
}

' ─────────────────────────────────────────────
'  EXTERNAL DEPENDENCY REGISTRIES
' ─────────────────────────────────────────────
cloud "JitPack.io\n(Maven Proxy)" as jitpack
cloud "Maven Central" as mavenCentral
cloud "GitHub: Anuken/Arc\n(Core Framework)" as arcRepo

ci --> jitpack      : "resolves Arc\ndependencies"
ci --> mavenCentral : "resolves Java\ndependencies"
ci --> arcRepo      : "clones & tags\nArc on release"

' ─────────────────────────────────────────────
'  DISTRIBUTION CHANNELS
' ─────────────────────────────────────────────
cloud "GitHub Releases\n(Anuken/Mindustry)" as githubReleases
cloud "MindustryJitpack\n(JitPack Mirror)" as jitpackMirror
cloud "MindustryGame/docs\n(Javadoc Site)" as docsSite
cloud "MindustryBuilds\n(F-Droid Build Strings)" as fdroidBuilds

desktopJar --> githubReleases  : "upload on tag"
serverJar  --> githubReleases  : "upload on tag"
depsJar    --> githubReleases  : "upload on tag"
androidApk --> fdroidBuilds    : "version string update"

ci --> jitpackMirror : "push sources\n(on push / tag)"
ci --> docsSite      : "publish merged\nJavadoc"

' ─────────────────────────────────────────────
'  DESKTOP RUNTIME ENVIRONMENTS
' ─────────────────────────────────────────────
node "Windows 64-bit\n(Packr Bundle + JRE)" <<Desktop>> as winNode {
    artifact "Mindustry.exe\n+ bundled JRE" as winApp
}

node "Linux 64-bit\n(Packr Bundle + JRE)" <<Desktop>> as linuxNode {
    artifact "Mindustry\n+ bundled JRE" as linuxApp
}

node "macOS\n(Packr Bundle + JRE)" <<Desktop>> as macNode {
    artifact "Mindustry.app\n+ bundled JRE" as macApp
}

githubReleases --> winNode   : "download\n[Windows64].zip"
githubReleases --> linuxNode : "download\n[Linux64].zip"
githubReleases --> macNode   : "download\n[MacOS].zip"

' ─────────────────────────────────────────────
'  SERVER RUNTIME
' ─────────────────────────────────────────────
node "Dedicated Game Server\n(JVM / Linux host)" <<Server>> as serverNode {
    artifact "server.jar\n(mindustry.server.ServerLauncher)" as serverRuntime
    artifact "core/assets\n(game data)" as serverAssets
}

githubReleases --> serverNode  : "download\nserver-release.jar"
serverRuntime ..> serverAssets : "reads"

' ─────────────────────────────────────────────
'  MOBILE RUNTIME ENVIRONMENTS
' ─────────────────────────────────────────────
node "Android Device\n(API 14+, minSdk 14 / targetSdk 36)" <<Mobile>> as androidNode {
    artifact "io.anuke.mindustry\n(AndroidLauncher)" as androidRuntime
}

node "iOS Device\n(RoboVM / libGDX)" <<Mobile>> as iosNode {
    artifact "Mindustry iOS App\n(IOSLauncher)" as iosRuntime
}

fdroidBuilds  --> androidNode : "F-Droid\ndistribution"
githubReleases --> androidNode : "direct APK\ndownload"
githubReleases --> iosNode     : "TestFlight /\nApp Store release"

' ─────────────────────────────────────────────
'  MULTI-PLAYER NETWORKING
' ─────────────────────────────────────────────
winNode   --> serverNode : "TCP/UDP\n(game protocol)"
linuxNode --> serverNode : "TCP/UDP\n(game protocol)"
macNode   --> serverNode : "TCP/UDP\n(game protocol)"
androidNode --> serverNode : "TCP/UDP\n(game protocol)"

@enduml
