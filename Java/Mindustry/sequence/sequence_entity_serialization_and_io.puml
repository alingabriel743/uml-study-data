@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #495057
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #868E96
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam noteBorderColor #6C757D
skinparam noteBackgroundColor #FFF9C4

title Entity Serialization and IO Flow

' ─── Participants ───────────────────────────────────────────────────
actor "Annotation\nProcessor" as AP #D0E8FF
participant "EntityIO\n(code generator)" as EntityIO #BBDDF5
participant "TypeIOResolver\n(ClassSerializer)" as Resolver #BBDDF5
participant "SaveVersion\n(save/load orchestrator)" as SaveVersion
participant "BuildingComp\n(building entity)" as BuildingComp
participant "ItemModule /\nPowerModule /\nLiquidModule" as Modules
participant "UnitComp\n(unit entity)" as UnitComp
participant "TypeIO\n(static IO utilities)" as TypeIO
participant "NetServer" as NetServer
participant "NetClient" as NetClient
participant "Groups.sync\n(entity registry)" as Groups
participant "Writes / Reads\n(arc IO streams)" as IO

' ════════════════════════════════════════════════════════════════════
' 1. ANNOTATION PROCESSING  (compile time)
' ════════════════════════════════════════════════════════════════════
group "Compile-time: EntityIO Annotation Processing"
    AP -> Resolver : resolve(BaseProcessor)
    note right : Scans @TypeIOHandler classes\nbuilds writers / readers /\nmutatorReaders / netWriters maps
    activate Resolver
    Resolver --> AP : ClassSerializer
    deactivate Resolver

    AP -> EntityIO : generate write/read/writeSync/readSync\nmethod bodies for each entity class
    activate EntityIO

    note over EntityIO
        Revision system:
        • Loads stored <EntityName>/<version>.json
        • Compares non-transient fields (sorted by name)
        • If changed → creates new Revision, writes JSON, logs warning
        • write() emits: write.s(latestRevision.version) + per-field io()
        • read() emits: REV=read.s(); if/else per stored revision (back-compat)
    end note

    EntityIO --> AP : generated source files injected into entity classes
    deactivate EntityIO
end

' ════════════════════════════════════════════════════════════════════
' 2. SAVE TO DISK
' ════════════════════════════════════════════════════════════════════
group "Save to Disk"
    SaveVersion -> BuildingComp : writeAll(Writes out)\n[wraps in chunk with build.version() byte]
    activate BuildingComp

    BuildingComp -> BuildingComp : writeBase(write)
    note right : health:f, rotation:b, team:b,\nversion:b, enabled:b, moduleBitmask:b
    activate BuildingComp

    BuildingComp -> Modules : write(write)\n[conditional on moduleBitmask bits]
    activate Modules
    Modules --> BuildingComp : —
    deactivate Modules

    deactivate BuildingComp

    BuildingComp -> BuildingComp : write(write)\n[@CallSuper — generated by EntityIO]
    activate BuildingComp

    BuildingComp -> IO : write.s(latestRevision.version)
    activate IO
    IO --> BuildingComp : —
    deactivate IO

    loop for each non-transient, non-static, non-final field
        BuildingComp -> TypeIO : writeObject / writeMounts / writeController\n/ writeStatus / writePayload (as needed)
        activate TypeIO
        TypeIO -> IO : primitive write.b/s/i/f/bool\nor type-code + value bytes
        activate IO
        IO --> TypeIO : —
        deactivate IO
        TypeIO --> BuildingComp : —
        deactivate TypeIO
    end

    deactivate BuildingComp
    BuildingComp --> SaveVersion : —
    deactivate BuildingComp
end

' ════════════════════════════════════════════════════════════════════
' 3. LOAD FROM DISK
' ════════════════════════════════════════════════════════════════════
group "Load from Disk"
    SaveVersion -> BuildingComp : readAll(Reads in, byte revision)
    activate BuildingComp

    BuildingComp -> BuildingComp : readBase(read)\n[version-aware: dispatches v0–v4]
    activate BuildingComp
    note right
        v1: adds enabled flag
        v2: adds moduleBitmask
        v3: bool efficiency → bytes
        v4: adds visibleFlags long
    end note

    BuildingComp -> Modules : read(read, legacy)\n[conditional on moduleBitmask bits]
    activate Modules
    Modules --> BuildingComp : —
    deactivate Modules
    deactivate BuildingComp

    BuildingComp -> BuildingComp : read(read, revision)\n[generated by EntityIO]
    activate BuildingComp

    BuildingComp -> IO : REV = read.s()
    activate IO
    IO --> BuildingComp : revision short
    deactivate IO

    alt REV matches known revision
        loop for each field in that revision
            BuildingComp -> TypeIO : readObject / readMounts / readController\n/ readStatus / readPayload (as needed)
            activate TypeIO
            TypeIO -> IO : read typed bytes
            activate IO
            IO --> TypeIO : value
            deactivate IO
            TypeIO --> BuildingComp : deserialized value
            deactivate TypeIO
        end
    else unknown REV
        BuildingComp -> BuildingComp : throw IOException("Unknown revision: " + REV)
    end

    deactivate BuildingComp
    BuildingComp --> SaveVersion : —
    deactivate BuildingComp
end

' ════════════════════════════════════════════════════════════════════
' 4. NETWORK SYNC — SERVER WRITE
' ════════════════════════════════════════════════════════════════════
group "Network Sync — Server Write"
    NetServer -> BuildingComp : beforeWrite()\n[components update transient → serializable fields]
    activate BuildingComp
    BuildingComp --> NetServer : —
    deactivate BuildingComp

    NetServer -> BuildingComp : writeSync(Writes dataStreamWrites)\n[classId byte + sync data]
    activate BuildingComp
    note right : Buildings: writeSync\ndelegates fully to writeAll\n(no lightweight sync path)
    BuildingComp -> BuildingComp : writeAll(write)
    BuildingComp --> NetServer : —
    deactivate BuildingComp

    NetServer -> UnitComp : beforeWrite()
    activate UnitComp
    UnitComp --> NetServer : —
    deactivate UnitComp

    NetServer -> UnitComp : writeSync(Writes dataStreamWrites)\n[generated by EntityIO — @SyncField / non-@NoSync fields only,\nno revision header]
    activate UnitComp

    loop for each @SyncField / non-@NoSync field
        UnitComp -> TypeIO : writeMounts / writeController /\nwriteAbilities / writeStatus /\nwritePayload (as needed)
        activate TypeIO
        TypeIO -> IO : serialized bytes
        activate IO
        IO --> TypeIO : —
        deactivate IO
        TypeIO --> UnitComp : —
        deactivate TypeIO
    end

    UnitComp --> NetServer : —
    deactivate UnitComp

    note over NetServer, TypeIO
        TypeIO.writeUnitContainer: full bootstrap packet
        packs id + classId + full writeSync blob
        → calls unit.beforeWrite() then unit.writeSync(write)
    end note
end

' ════════════════════════════════════════════════════════════════════
' 5. NETWORK SYNC — CLIENT READ
' ════════════════════════════════════════════════════════════════════
group "Network Sync — Client Read"
    NetClient -> Groups : getByID(id)
    activate Groups
    Groups --> NetClient : existing entity (or null)
    deactivate Groups

    alt entity not found
        NetClient -> Groups : EntityMapping.map(typeID).get()\n[create new entity instance]
        activate Groups
        Groups --> NetClient : new entity
        deactivate Groups
    end

    NetClient -> UnitComp : readSync(Reads read)\n[generated by EntityIO]
    activate UnitComp

    loop for each @SyncField / non-@NoSync field
        UnitComp -> TypeIO : readMounts / readController /\nreadAbilities / readStatus /\nreadPayload (as needed)
        activate TypeIO
        TypeIO -> IO : read typed bytes
        activate IO
        IO --> TypeIO : value
        deactivate IO
        TypeIO --> UnitComp : deserialized value
        deactivate TypeIO

        note right of UnitComp
            @SyncField → written into
            _TARGET_ shadow field
            @SyncLocal → skipped
            if isLocal() == true
        end note
    end

    UnitComp -> UnitComp : afterSync()\n[setType(type) + controller.unit(self())]
    UnitComp --> NetClient : —
    deactivate UnitComp

    opt first creation (snapSync)
        NetClient -> UnitComp : snapSync()\n[set _LAST_ = _TARGET_ = current\nto avoid position jump]
        activate UnitComp
        UnitComp --> NetClient : —
        deactivate UnitComp
    end

    NetClient -> BuildingComp : blockSnapshot → readSync(read, revision)\n[delegates to readAll]
    activate BuildingComp
    BuildingComp --> NetClient : —
    deactivate BuildingComp
end

' ════════════════════════════════════════════════════════════════════
' 6. INTERPOLATION  (every render frame)
' ════════════════════════════════════════════════════════════════════
group "@SyncField Interpolation (render frame)"
    note over UnitComp
        SyncComp.interpolate() — generated by EntityIO.writeInterpolate:
        alpha = timeSinceUpdate / updateSpacing
        For each @SyncField:
          field = Mathf.lerp(field_LAST_, field_TARGET_, alpha)   [linear]
          — or —
          field = Mathf.slerp(field_LAST_, field_TARGET_, alpha)  [angle]
        High-freq manual sync (player units):
          writeSyncManual / readSyncManual → FloatBuffer.put / get
    end note
end

@enduml
