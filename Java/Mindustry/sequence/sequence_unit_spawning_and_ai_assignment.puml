@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    BoxBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    GroupBackgroundColor #DEE2E6
    GroupBorderColor #6C757D
    DividerBackgroundColor #DEE2E6
    DividerBorderColor #6C757D
    NoteBackgroundColor #FFF3CD
    NoteBorderColor #FFC107
}

title Unit Spawning and AI Controller Assignment

actor       "Caller\n(WaveSpawner / UnitPayload)" as Caller
participant "Units"                                as Units
participant "TeamData"                             as TeamData
participant "UnitType"                             as UnitType
participant "UnitComp\n(Unit entity)"              as UnitComp
participant "AIController\n(GroundAI / FlyingAI)"  as AI
participant "CommandAI"                            as CmdAI
participant "Call (RPC)"                           as RPC

== Cap Check ==

Caller -> Units : canCreate(team, type)
activate Units

Units -> TeamData : countType(type)
activate TeamData
TeamData --> Units : currentCount
deactivate TeamData

Units -> Units : getCap(team)\n// MAX_VALUE if waveTeam;\n// else rules.unitCap + team.data().unitCap

alt over cap OR type banned
    Units --> Caller : return false
    deactivate Units
else allowed to spawn
    Units --> Caller : return true
    deactivate Units

    == Entity Construction ==

    Caller -> UnitType : create(team)
    activate UnitType

    UnitType -> UnitType : constructor.get()\n// Prov<Unit>: UnitEntity::create,\n// MechUnit::create, etc.

    UnitType -> UnitComp : unit.team = team
    activate UnitComp

    UnitType -> UnitComp : setType(this)
    note right of UnitComp
        maxHealth = type.health
        drag      = type.drag
        armor     = type.armor
        hitSize   = type.hitSize
    end note

    UnitComp -> UnitComp : setupWeapons(type)\n// if mounts.length != type.weapons.size

    UnitComp -> UnitComp : abilities[] = copy of type.abilities

    == AI Controller Creation ==

    UnitComp -> UnitType : createController(self())\n// only if controller == null
    activate UnitType

    alt AI team OR non-playerControllable
        UnitType -> AI : new GroundAI() / new FlyingAI()
        activate AI
        note right of AI
            Instance initializer:
            resetTimers()
            ├ timer.reset(timerTarget,  Mathf.random(40f))
            └ timer.reset(timerTarget2, Mathf.random(60f))
        end note
        AI --> UnitType : aiController instance
        deactivate AI
        UnitType --> UnitComp : AIController
    else player-controllable team (rtsAi off)
        UnitType -> CmdAI : new CommandAI()
        activate CmdAI
        note right of CmdAI
            Instance initializer:
            resetTimers() (inherited)
        end note
        CmdAI --> UnitType : commandAI instance
        deactivate CmdAI
        UnitType --> UnitComp : CommandAI
    end

    deactivate UnitType

    == Controller Binding ==

    UnitComp -> UnitComp : controller(newController)
    UnitComp -> AI : unit(self())\n// binds unit reference
    activate AI
    AI -> AI : this.unit = unit
    AI -> AI : init()\n// base: no-op for GroundAI/FlyingAI
    AI --> UnitComp : (bound)
    deactivate AI

    note over CmdAI
        CommandAI.init():
        command = type.defaultCommand
                  ?? type.commands.first()
                  ?? UnitCommand.moveCommand
    end note

    == Final Setup ==

    UnitType -> UnitComp : ability.created(unit)  [for each ability]
    UnitType -> UnitComp : unit.ammo = type.ammoCapacity
    UnitType -> UnitComp : unit.elevation = flying ? 1f : 0
    UnitType -> UnitComp : unit.heal()  // full HP
    deactivate UnitComp

    UnitType --> Caller : unit  (NOT yet in world)
    deactivate UnitType

    == World Registration ==

    Caller -> UnitComp : unit.set(x, y)\nunit.rotation = rotation
    activate UnitComp

    Caller -> UnitComp : unit.add()\n// registers into Groups / EntityGroup
    activate UnitComp

    UnitComp -> TeamData : updateCount(type, +1)

    alt count() > cap() AND useUnitCap AND !spawnedByCore
        UnitComp -> RPC : unitCapDeath(self())
        activate RPC
        RPC -> UnitComp : unit.dead = true\nFx.unitCapKill.at(unit)\nunitDestroy(id)
        deactivate RPC
    else within cap
        note right of UnitComp : Unit remains alive
    end

    deactivate UnitComp
    deactivate UnitComp

    == Multiplayer Sync ==

    Caller -> Units : notifyUnitSpawn(unit)  // server-only
    activate Units
    Units -> RPC : unitSpawn(new UnitSyncContainer(unit))\n// syncs to clients without waiting for snapshot
    activate RPC
    RPC --> Units : (dispatched)
    deactivate RPC
    deactivate Units

    == First Update Tick (server-side) ==

    [-> UnitComp : update()
    activate UnitComp

    UnitComp -> UnitComp : shouldUpdateController()\n// returns true normally

    UnitComp -> AI : controller.updateUnit()
    activate AI
    AI -> AI : updateVisuals()\n// wobble if flying; lookAt(prefRotation())
    AI -> AI : updateTargeting()\n// retarget() timer; findMainTarget();\n// updateWeapons(); mount.shoot/rotate
    AI -> AI : updateMovement()\n// GroundAI or FlyingAI implementation
    AI --> UnitComp : (done)
    deactivate AI

    opt controller.isValidController() == false
        UnitComp -> UnitComp : resetController()\n// type.createController(self())
    end

    deactivate UnitComp

end

@enduml
