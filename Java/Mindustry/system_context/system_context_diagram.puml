@startuml
title Mindustry — System Context Diagram

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actor {
    BackgroundColor<<Person>> #08427B
    FontColor<<Person>> #FFFFFF
    BorderColor<<Person>> #052E56
}

skinparam package {
    BackgroundColor #F5F5F5
    BorderColor #BDBDBD
    FontColor #424242
    FontStyle bold
}

skinparam arrow {
    Color #424242
    FontSize 10
    FontColor #616161
}

' ── Actors ──────────────────────────────────────────────────────────────
actor "Desktop Player\n[Windows / macOS / Linux]" as desktopUser <<Person>>
actor "Android Player\n[Android Device]" as androidUser <<Person>>
actor "iOS Player\n[iPhone / iPad]" as iosUser <<Person>>
actor "Server Operator\n[Headless CLI / Remote Socket]" as serverOp <<Person>>
actor "Multiplayer Client\n[Remote Game Player]" as mpClient <<Person>>

' ── Core System ─────────────────────────────────────────────────────────
rectangle "**Mindustry**\n[Cross-Platform Java / LibGDX Game]\n\nTower-defense / sandbox game with\nmultiplayer networking, mod scripting,\ncampaign & custom map support.\nRuns on Desktop, Android, iOS & Server." as system <<System>>

' ── Steam Integration ────────────────────────────────────────────────────
package "Steam Platform (Desktop Only)" {
    rectangle "**Steam Networking**\n[SteamNetworking API]\n\nP2P game connections,\nlobby discovery,\nSteam relay transport" as steamNet <<External>>
    rectangle "**Steam Matchmaking**\n[SteamMatchmaking API]\n\nLobby creation & search,\nfriend game invites,\ncurrent server listing" as steamMM <<External>>
    rectangle "**Steam Workshop**\n[SWorkshop]\n\nMod & map publishing,\ncommunity content download,\nupdates & subscriptions" as steamWS <<External>>
    rectangle "**Steam Friends\n& Achievements**\n[SteamFriends / SStats]\n\nFriend presence, rich presence,\nstats & achievement tracking" as steamFriends <<External>>
}

' ── Multiplayer Networking ───────────────────────────────────────────────
package "Multiplayer Infrastructure" {
    rectangle "**Remote Game Server**\n[Headless Mindustry Server]\n\nAuthoritative game state,\nplayer session management,\nmap & unit sync" as gameServer <<External>>
    rectangle "**Server List API**\n[GitHub Raw / jsDelivr CDN]\n\nPublic server registry JSON\n(servers_v8.json / servers_be.json)\nfor in-game server browser" as serverList <<Infrastructure>>
}

' ── Mod & Content System ─────────────────────────────────────────────────
package "Mod & Content Services" {
    rectangle "**GitHub API**\n[api.github.com]\n\nMod listing & metadata\n(MindustryMods/mods.json),\nbug report submission" as githubApi <<External>>
    rectangle "**jsDelivr CDN**\n[cdn.jsdelivr.net]\n\nFallback CDN for\nmod index & server list,\nlow-latency global delivery" as jsdelivr <<Infrastructure>>
    rectangle "**Rhino JavaScript Engine**\n[Mozilla Rhino — Embedded]\n\nIn-process JS scripting for\nmods (Android & Desktop),\ndynamic mod content loading" as rhino <<External>>
}

' ── Community & Reporting ────────────────────────────────────────────────
package "Community & Reporting" {
    rectangle "**Discord**\n[discord.gg/mindustry]\n\nCommunity hub link,\nDesktop Rich Presence\n(discordID integration)" as discord <<External>>
    rectangle "**GitHub Issues**\n[github.com/Anuken/Mindustry]\n\nCrash & bug report\nsubmission via\npre-filled issue template URL" as githubIssues <<External>>
}

' ── Local Storage ────────────────────────────────────────────────────────
package "Local Data Stores" {
    rectangle "**Local Filesystem**\n[Platform File API]\n\nSave files, map data (.msav),\nmod packages (.zip / .jar),\nconfig & settings" as localStorage <<Database>>
    rectangle "**Server Admin Socket**\n[TCP ServerSocket]\n\nLocal/remote CLI control\nof headless server via\nplain-text command stream" as adminSocket <<Queue>>
}

' ── Relationships ────────────────────────────────────────────────────────

' Players → System
desktopUser  --> system      : "Native input events\n(keyboard, mouse)"
androidUser  --> system      : "Touch / sensor input\n(Android Activity)"
iosUser      --> system      : "Touch input\n(iOS RoboVM bridge)"
serverOp     --> system      : "CLI stdin / TCP socket\n(server commands)"
mpClient     --> system      : "UDP + TCP\n(custom game protocol)"

' System → Multiplayer
system       --> gameServer  : "UDP + TCP\n(connect, sync game state)"
gameServer   --> system      : "UDP + TCP\n(world snapshots, events)"
system       --> serverList  : "HTTPS GET\n(fetch server list JSON)"

' System → Steam
system       --> steamNet    : "Steam SDK (JNI)\n(P2P packet send/recv)"
system       --> steamMM     : "Steam SDK (JNI)\n(lobby create/join/list)"
system       --> steamWS     : "Steam SDK (JNI)\n(publish & download mods/maps)"
system       --> steamFriends: "Steam SDK (JNI)\n(friend list, rich presence,\nstats & achievements)"

' System → Mod & Content
system       --> githubApi   : "HTTPS REST\n(fetch mods.json, open issue URL)"
system       --> jsdelivr    : "HTTPS GET\n(CDN fallback for mod & server lists)"
system       --> rhino       : "In-process call\n(execute mod JS scripts)"

' System → Community
system       --> discord     : "Discord RPC (IPC)\n(rich presence status)"
system       --> githubIssues: "HTTPS (browser launch)\n(pre-filled bug report URL)"

' System → Local
system       --> localStorage: "File I/O\n(read/write saves, maps, mods, config)"
system       --> adminSocket : "TCP ServerSocket\n(expose server control interface)"
serverOp     --> adminSocket : "TCP plaintext\n(remote admin commands)"

@enduml
