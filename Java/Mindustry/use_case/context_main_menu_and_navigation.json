{
  "scope": "main_menu_and_navigation",
  "title": "Main Menu & Navigation",
  "diagram_type": "use_case",
  "actors": [
    "Player",
    "System (MenuFragment/UI)"
  ],
  "primary_entry_point": "MenuFragment (mindustry.ui.fragments.MenuFragment)",
  "use_cases": [
    {
      "id": "UC01",
      "name": "Start Campaign",
      "trigger": "Player clicks Campaign button",
      "actor": "Player",
      "flow": "MenuFragment.checkPlay(ui.planet::show) → PlanetDialog.show()",
      "guard": "checkPlay() validates no mod content errors before opening",
      "dialog": "PlanetDialog"
    },
    {
      "id": "UC02",
      "name": "Play Custom Game",
      "trigger": "Player clicks Custom Game button",
      "actor": "Player",
      "flow": "MenuFragment.checkPlay(ui.custom::show) → CustomGameDialog (MapListDialog.show()) → showMap(map) → MapPlayDialog.show(map)",
      "guard": "checkPlay() mod error check",
      "dialog": "CustomGameDialog"
    },
    {
      "id": "UC03",
      "name": "Join Multiplayer Game",
      "trigger": "Player clicks Join Game button",
      "actor": "Player",
      "flow": "MenuFragment.checkPlay(ui.join::show) → JoinDialog.show()",
      "guard": "checkPlay() mod error check",
      "dialog": "JoinDialog"
    },
    {
      "id": "UC04",
      "name": "Load Saved Game",
      "trigger": "Player clicks Load Game button",
      "actor": "Player",
      "flow": "MenuFragment.checkPlay(ui.load::show) → LoadDialog.show()",
      "guard": "checkPlay() mod error check",
      "dialog": "LoadDialog"
    },
    {
      "id": "UC05",
      "name": "Open Map Editor",
      "trigger": "Player clicks Editor button",
      "actor": "Player",
      "flow": "MenuFragment.checkPlay(ui.maps::show) → EditorMapsDialog.show()",
      "guard": "checkPlay() mod error check",
      "dialog": "EditorMapsDialog"
    },
    {
      "id": "UC06",
      "name": "View Database",
      "trigger": "Player clicks Database button",
      "actor": "Player",
      "flow": "ui.database::show → DatabaseDialog.show() → checkTabList() → sortContents() → rebuild() → [click item] → ui.content.show(unlock)",
      "guard": "None",
      "dialog": "DatabaseDialog"
    },
    {
      "id": "UC07",
      "name": "View Schematics",
      "trigger": "Player clicks Schematics button (desktop submenu)",
      "actor": "Player",
      "flow": "ui.schematics::show → SchematicsDialog.show()",
      "guard": "Desktop only (in 'Database' submenu on desktop)",
      "dialog": "SchematicsDialog"
    },
    {
      "id": "UC08",
      "name": "Open Settings",
      "trigger": "Player clicks Settings button",
      "actor": "Player",
      "flow": "ui.settings::show → SettingsMenuDialog.show() → rebuildMenu() → [category select] visible(index) shows game/graphics/sound SettingsTable OR dataDialog.show()",
      "guard": "None",
      "dialog": "SettingsMenuDialog"
    },
    {
      "id": "UC09",
      "name": "View About / Credits",
      "trigger": "Player clicks About button",
      "actor": "Player",
      "flow": "ui.about::show → AboutDialog.show() → setup() → [Credits button] showCredits() → BaseDialog with contributors list",
      "guard": "Mobile: info button in bottom-left; Desktop: in Database submenu",
      "dialog": "AboutDialog"
    },
    {
      "id": "UC10",
      "name": "Open Mods",
      "trigger": "Player clicks Mods button",
      "actor": "Player",
      "flow": "ui.mods::show → ModsDialog.show()",
      "guard": "None",
      "dialog": "ModsDialog"
    },
    {
      "id": "UC11",
      "name": "Quit Game",
      "trigger": "Player clicks Quit button",
      "actor": "Player",
      "flow": "Core.app.exit()",
      "guard": "Desktop only (iOS shows About instead)",
      "dialog": "N/A"
    },
    {
      "id": "UC12",
      "name": "Manage Data (Settings sub-use-case)",
      "trigger": "Player clicks Data in Settings menu",
      "actor": "Player",
      "flow": "SettingsMenuDialog → dataDialog.show() → [clear data|clear saves|clear research|clear campaign saves|export data|import data]",
      "guard": "Confirmation dialogs for destructive actions",
      "dialog": "dataDialog (BaseDialog)"
    }
  ],
  "dialog_class_summary": [
    {
      "class": "MenuFragment",
      "package": "mindustry.ui.fragments",
      "key_methods": ["build(Group)", "buildDesktop()", "buildMobile()", "checkPlay(Runnable)", "buttons(Table, MenuButton...)", "addButton(MenuButton)"],
      "notes": "Root menu. Desktop: left-side nav with submenus. Mobile: grid of MobileButton. Holds Seq<MenuButton> desktopButtons, Seq<MenuButton> customButtons."
    },
    {
      "class": "PlanetDialog",
      "extends": "BaseDialog",
      "implements": "PlanetInterfaceRenderer",
      "package": "mindustry.ui.dialogs",
      "key_methods": ["show()", "showOverview()", "showPlanetLaunch(Sector, Seq<Planet>, Cons<Sector>)", "showSelect(Sector, Cons<Sector>)", "selectSector(Sector)", "showStats(Sector)"],
      "inner_types": ["enum Mode"],
      "notes": "3D planet/sector campaign navigation. Uses FrameBuffer for rendering. Entry point for all campaign sector selection."
    },
    {
      "class": "CustomGameDialog",
      "extends": "MapListDialog",
      "package": "mindustry.ui.dialogs",
      "key_methods": ["showMap(Map)"],
      "fields": ["MapPlayDialog dialog"],
      "notes": "Extends MapListDialog(@customgame, showSaves=false). showMap(map) → dialog.show(map)."
    },
    {
      "class": "DatabaseDialog",
      "extends": "BaseDialog",
      "package": "mindustry.ui.dialogs",
      "key_methods": ["checkTabList()", "sortContents()", "rebuild()", "unlocked(UnlockableContent)"],
      "fields": ["OrderedMap sortedContents", "TextField search", "Table all", "UnlockableContent tab"],
      "notes": "shouldPause=true. Content browsing by planet/category/tag tabs. Click unlocked item → ui.content.show(). Search filter on localizedName."
    },
    {
      "class": "SettingsMenuDialog",
      "extends": "BaseDialog",
      "package": "mindustry.ui.dialogs",
      "key_methods": ["rebuildMenu()", "addSettings()", "visible(int)", "back()", "addCategory(String, Drawable, Cons<SettingsTable>)", "exportData(Fi)", "importData(Fi)"],
      "fields": ["SettingsTable graphics, game, sound, main", "Table prefs, menu", "BaseDialog dataDialog", "Seq<SettingsCategory> categories"],
      "inner_types": ["SettingsCategory", "SettingsTable", "SettingsTable.Setting", "SettingsTable.CheckSetting", "SettingsTable.SliderSetting", "SettingsTable.TextSetting", "SettingsTable.AreaTextSetting"],
      "notes": "Menu items: game/graphics/sound settings, language (ui.language), controls (ui.controls), data management. Back button navigates menu→sub or closes."
    },
    {
      "class": "AboutDialog",
      "extends": "BaseDialog",
      "package": "mindustry.ui.dialogs",
      "key_methods": ["setup()", "showCredits()"],
      "fields": ["Seq<String> contributors", "static ObjectSet<String> bannedItems"],
      "notes": "Displays Links.getLinks() as clickable link cards. Opens URIs. Credits button shows contributors list in sub-dialog. bannedItems filters platform-specific links (google-play, itch.io, etc)."
    }
  ],
  "desktop_menu_structure": {
    "Play (submenu)": ["Campaign → ui.planet::show", "Join Game → ui.join::show", "Custom Game → ui.custom::show", "Load Game → ui.load::show"],
    "Database (submenu)": ["Schematics → ui.schematics::show", "Database → ui.database::show", "About → ui.about::show"],
    "Editor": "ui.maps::show",
    "Workshop (Steam only)": "platform::openWorkshop",
    "Mods": "ui.mods::show",
    "Settings": "ui.settings::show",
    "Quit": "Core.app::exit"
  },
  "mobile_menu_structure": {
    "Campaign": "checkPlay(ui.planet::show)",
    "Custom Game": "checkPlay(ui.custom::show)",
    "Load Game": "checkPlay(ui.load::show)",
    "Join Game": "checkPlay(ui.join::show)",
    "Editor": "checkPlay(ui.maps::show)",
    "Settings": "ui.settings::show",
    "Mods": "ui.mods::show",
    "About (bottom-left info banner)": "ui.about::show",
    "Exit (iOS shows About)": "Core.app.exit()"
  },
  "key_relationships": [
    "MenuFragment navigates_to PlanetDialog via ui.planet.show()",
    "MenuFragment navigates_to CustomGameDialog via ui.custom.show()",
    "MenuFragment navigates_to DatabaseDialog via ui.database.show()",
    "MenuFragment navigates_to SettingsMenuDialog via ui.settings.show()",
    "MenuFragment navigates_to AboutDialog via ui.about.show()",
    "CustomGameDialog extends MapListDialog",
    "CustomGameDialog uses MapPlayDialog",
    "SettingsMenuDialog uses SettingsTable (inner class) for game/graphics/sound",
    "SettingsMenuDialog uses BaseDialog dataDialog for data management",
    "DatabaseDialog depends_on ContentInfoDialog (ui.content.show)",
    "SettingsMenuDialog depends_on LanguageDialog (ui.language), ControlsDialog (ui.controls)",
    "UI class (mindustry.core.UI) owns all dialog instances as public fields"
  ],
  "important_notes": "checkPlay() guards all gameplay-entry dialogs from launching if mod content errors exist. Desktop uses hierarchical submenu (MenuButton with submenu Seq); mobile uses flat MobileButton grid. Custom mod buttons supported via addButton()/addCategory(). All dialogs are singletons held by UI class.",
  "source_files_analyzed": [
    "core/src/mindustry/ui/fragments/MenuFragment.java",
    "core/src/mindustry/ui/dialogs/PlanetDialog.java",
    "core/src/mindustry/ui/dialogs/CustomGameDialog.java",
    "core/src/mindustry/ui/dialogs/DatabaseDialog.java",
    "core/src/mindustry/ui/dialogs/SettingsMenuDialog.java",
    "core/src/mindustry/ui/dialogs/AboutDialog.java",
    "core/src/mindustry/core/UI.java"
  ]
}
