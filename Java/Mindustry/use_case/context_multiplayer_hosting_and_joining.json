{
  "scope": "multiplayer_hosting_and_joining",
  "title": "Multiplayer Hosting & Joining",
  "diagram_type": "use_case",
  "actors": [
    "Player (Client)",
    "Server Admin (Host / ServerControl CLI)",
    "Net / Network Layer",
    "Administration (netServer.admins)"
  ],
  "use_cases": [
    {
      "id": "UC01",
      "name": "Host a Server",
      "actor": "Player (Client)",
      "component": "HostDialog",
      "steps": [
        "Open HostDialog (@hostserver)",
        "Set player name & color (PaletteDialog)",
        "Configure server port (default 6567, valid 1-65535)",
        "Optionally toggle Steam friends-only visibility",
        "Click 'host' button → validates non-empty name & valid port",
        "runHost(): ui.loadfrag.show('@hosting'), delay 5f ticks",
        "net.host(port) → opens server",
        "player.admin = true",
        "Events.fire(new HostEvent())",
        "On Steam public host + beta/alpha build: force private lobby"
      ],
      "exceptions": [
        "Address already in use → show '@server.error.addressinuse'",
        "Other exception → show '@server.error'"
      ]
    },
    {
      "id": "UC02",
      "name": "Join a Server (Direct IP)",
      "actor": "Player (Client)",
      "component": "JoinDialog",
      "steps": [
        "Open JoinDialog (@joingame)",
        "Set player name & color",
        "Click 'Add Server' → enter IP:port in add dialog",
        "saveServers() → setupRemote() → refreshRemote()",
        "net.pingHost(ip, port) → setupServer(server, host)",
        "Click server entry → safeConnect(ip, port, version)",
        "safeConnect(): version check, mismatch shows outdated warning",
        "connect(ip, port): logic.reset(), net.reset(), netClient.beginConnecting()",
        "net.connect(ip, port, callback) → hide dialogs on success"
      ],
      "exceptions": [
        "Empty player name → show '@noname'",
        "Version mismatch → show clientOutdated/serverOutdated message",
        "Connection cancel button → netClient.disconnectQuietly()"
      ]
    },
    {
      "id": "UC03",
      "name": "Join a Local (LAN) Server",
      "actor": "Player (Client)",
      "component": "JoinDialog",
      "steps": [
        "JoinDialog shown → refreshLocal()",
        "net.discoverServers(addLocalHost, finishLocalHosts)",
        "addLocalHost(host): builds server entry in local table",
        "Click entry → safeConnect(host.address, host.port, host.version)"
      ]
    },
    {
      "id": "UC04",
      "name": "Browse & Join Community Servers",
      "actor": "Player (Client)",
      "component": "JoinDialog",
      "steps": [
        "JoinDialog shown → refreshCommunity()",
        "fetchServers(): HTTP GET serverJsonURLs",
        "Load cached server list if fetch fails",
        "Display server groups (prioritized/favorite/hidden filtering)",
        "Search by name/description/map/mode",
        "Click community server → show disclaimer if first time",
        "safeConnect(host.address, host.port, host.version)"
      ]
    },
    {
      "id": "UC05",
      "name": "Reconnect to Last Server",
      "actor": "Player (Client)",
      "component": "JoinDialog",
      "steps": [
        "reconnect(): requires lastIp to be set",
        "ui.loadfrag.show('@reconnecting')",
        "Timer.schedule: net.pingHost(lastIp, lastPort) every 1s",
        "On successful ping → connect(lastIp, lastPort)"
      ]
    },
    {
      "id": "UC06",
      "name": "Host Server via CLI",
      "actor": "Server Admin (Host / ServerControl CLI)",
      "component": "ServerControl",
      "steps": [
        "Command: host [mapname] [mode]",
        "Validate not already hosting",
        "Resolve map by name or shuffle next map",
        "logic.reset() → world.loadMap(map, rules) → logic.play()",
        "netServer.openServer()",
        "Auto-pause when no players (if Config.autoPause)",
        "Auto-save on interval (Config.autosave)"
      ]
    },
    {
      "id": "UC07",
      "name": "Stop Server",
      "actor": "Server Admin (Host / ServerControl CLI)",
      "component": "ServerControl",
      "steps": [
        "Command: stop",
        "net.closeServer()",
        "cancelPlayTask()",
        "state.set(State.menu)"
      ]
    },
    {
      "id": "UC08",
      "name": "Kick Player",
      "actor": "Server Admin (Host / ServerControl CLI)",
      "component": "ServerControl",
      "steps": [
        "Command: kick <username>",
        "Groups.player.find(name match)",
        "Call.sendMessage('[scarlet]<name> has been kicked')",
        "target.kick(KickReason.kick)"
      ]
    },
    {
      "id": "UC09",
      "name": "Ban Player",
      "actor": "Server Admin (Host / ServerControl CLI)",
      "component": "ServerControl",
      "steps": [
        "Command: ban <id|name|ip> <value>",
        "netServer.admins.banPlayerID/banPlayer/banPlayerIP()",
        "All currently connected banned players: player.con.kick(KickReason.banned)"
      ]
    },
    {
      "id": "UC10",
      "name": "Unban Player",
      "actor": "Server Admin (Host / ServerControl CLI)",
      "component": "BansDialog / ServerControl",
      "steps": [
        "BansDialog: lists netServer.admins.getBanned()",
        "Click unban (cancel icon) → showConfirm → netServer.admins.unbanPlayerID(info.id)",
        "CLI: command 'unban <ID>' → netServer.admins.unbanPlayerID()"
      ]
    },
    {
      "id": "UC11",
      "name": "Manage Admins",
      "actor": "Server Admin (Host / ServerControl CLI)",
      "component": "AdminsDialog / ServerControl",
      "steps": [
        "AdminsDialog: lists netServer.admins.getAdmins()",
        "Click remove (cancel icon) → showConfirm → netServer.admins.unAdminPlayer(info.id)",
        "Groups.player.each: set player.admin(false) for matching UUID",
        "CLI: admin <uuid> → netServer.admins.adminPlayer(uuid)",
        "CLI: unadmin <uuid> → netServer.admins.unAdminPlayer(uuid)"
      ]
    },
    {
      "id": "UC12",
      "name": "Set Player Limit",
      "actor": "Server Admin (Host / ServerControl CLI)",
      "component": "ServerControl",
      "steps": [
        "Command: playerlimit [off|number]",
        "netServer.admins.setPlayerLimit(n)"
      ]
    },
    {
      "id": "UC13",
      "name": "Manage Whitelist",
      "actor": "Server Admin (Host / ServerControl CLI)",
      "component": "ServerControl",
      "steps": [
        "Command: whitelist [add/remove] [ID]",
        "netServer.admins.whitelist(id) or unwhitelist(id)"
      ]
    },
    {
      "id": "UC14",
      "name": "Configure Server Settings",
      "actor": "Server Admin (Host / ServerControl CLI)",
      "component": "ServerControl",
      "steps": [
        "Command: config [name] [value]",
        "Config.all.find(name) → c.set(value)",
        "Settings: serverName, desc, port, maxPlayers, logging, autosave, autoPause, etc."
      ]
    },
    {
      "id": "UC15",
      "name": "Manage Subnet & Name Bans",
      "actor": "Server Admin (Host / ServerControl CLI)",
      "component": "ServerControl",
      "steps": [
        "subnet-ban [add/remove] <address>: netServer.admins.addSubnetBan/removeSubnetBan",
        "name-ban [add/remove/clear] <regex>: netServer.admins.addNameBan"
      ]
    }
  ],
  "key_relationships": [
    "HostDialog extends BaseDialog",
    "JoinDialog extends BaseDialog",
    "AdminsDialog extends BaseDialog",
    "BansDialog extends BaseDialog",
    "ServerControl implements ApplicationListener",
    "HostDialog uses net.host(port)",
    "JoinDialog uses net.connect(), net.pingHost(), net.discoverServers()",
    "AdminsDialog reads/writes netServer.admins (Administration)",
    "BansDialog reads/writes netServer.admins (Administration)",
    "ServerControl uses netServer.admins for all player management",
    "ServerControl uses netServer.openServer() / net.closeServer()",
    "HostDialog fires EventType.HostEvent on success",
    "JoinDialog fires EventType.ClientPreConnectEvent on connect attempt",
    "ServerControl listens to GameOverEvent, WorldLoadEvent, PlayEvent"
  ],
  "include_extend_relationships": [
    "UC02 includes UC safeConnect (version check)",
    "UC03 includes UC safeConnect (version check)",
    "UC04 includes UC safeConnect (version check)",
    "UC04 extends UC04 with disclaimer confirm (first-time community servers)",
    "UC05 extends UC02 (uses same connect() method)"
  ],
  "important_notes": [
    "Default server port: 6567 (Vars.port)",
    "HostDialog sets player.admin=true on successful host",
    "JoinDialog has three server tabs: local (LAN discovery), remote (saved IPs), global (community JSON from URLs)",
    "Steam mode changes UI: friends-only toggle in HostDialog, no info button in JoinDialog",
    "ServerControl reads commands from stdin (Scanner) in a daemon thread",
    "ServerControl also supports TCP socket input (Config.socketInput)",
    "netServer.admins (Administration class) is the central player management registry",
    "BansDialog uses info.lastIP + info.lastName for display",
    "AdminsDialog uses PlayerInfo.id for admin management"
  ],
  "source_files_analyzed": [
    "core/src/mindustry/ui/dialogs/HostDialog.java",
    "core/src/mindustry/ui/dialogs/JoinDialog.java",
    "server/src/mindustry/server/ServerControl.java",
    "core/src/mindustry/ui/dialogs/AdminsDialog.java",
    "core/src/mindustry/ui/dialogs/BansDialog.java"
  ]
}
