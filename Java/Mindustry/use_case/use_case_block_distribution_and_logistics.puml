@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #336699
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam usecaseBorderThickness 1.5

title Block Distribution & Logistics

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────
actor "Building\n(Adjacent Block / Source)" as Building
actor "Unit\n(Player-Controlled)" as Unit
actor "Logic Controller\n(LAccess)" as LogicCtrl
actor "Transport Network\n(Neighbouring Blocks)" as TransportNet

' ── System boundary ──────────────────────────────────────────────────────
rectangle "Block Distribution & Logistics" {

    ' ── Item routing ─────────────────────────────────────────────────────
    usecase "Route Item Round-Robin\n<size:10>(Router)</size>" as UC1
    usecase "Direct Output\nto Specific Side\n<size:10>(RouterBuild / ControlBlock)</size>" as UC1a
    usecase "Sort & Route Item\n<size:10>(DuctRouter)</size>" as UC2
    usecase "Configure Sort Filter\n<size:10>(sortItem / clearOnDoubleTap)</size>" as UC_SortFilter
    usecase "Batch-Stack &\nOffload Items\n<size:10>(StackRouter)</size>" as UC3

    ' ── Liquid routing ───────────────────────────────────────────────────
    usecase "Route Liquid\nOmni-directionally\n<size:10>(LiquidRouter)</size>" as UC4

    ' ── Payload routing ──────────────────────────────────────────────────
    usecase "Sort & Route\nPayload (Block/Unit)\n<size:10>(PayloadRouter)</size>" as UC5
    usecase "Check Payload Match\n<size:10>(checkMatch / invert flag)</size>" as UC5a
    usecase "Override Output\nDirection\n<size:10>(LAccess.config / controlTime)</size>" as UC5b
    usecase "Persist Router\nConfiguration\n<size:10>(write() / read())</size>" as UC_Persist

}

' ── Actor → Use case connections ─────────────────────────────────────────
Building  --> UC1
Building  --> UC2
Building  --> UC3
Building  --> UC4
Building  --> UC5

Unit      --> UC1a
Unit      --> UC5

LogicCtrl --> UC5b

UC1       --> TransportNet
UC2       --> TransportNet
UC3       --> TransportNet
UC4       --> TransportNet
UC5       --> TransportNet

' ── Use case relationships ───────────────────────────────────────────────
UC1  ..> UC1a       : <<extend>>\nunit aims output
UC2  ..> UC_SortFilter : <<include>>
UC5  ..> UC_SortFilter : <<include>>
UC5  ..> UC5a       : <<include>>
UC5  ..> UC5b       : <<extend>>\nlogic override
UC3  ..> UC2        : <<extend>>\nbatch-unload mode
UC2  ..> UC_Persist : <<include>>
UC5  ..> UC_Persist : <<include>>

@enduml
