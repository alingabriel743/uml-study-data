@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #1a1a2e
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #F0F4F8
    BorderColor #6C757D
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 11
skinparam ArrowFontColor #6C757D

title Campaign & Sector Management

left to right direction

actor "Player" as Player #D0E8FF
actor "GameSystem\n(Engine / Universe)" as GameSystem #D8F5E4

rectangle "Campaign & Sector Management" {

    package "Planet Map Navigation" {
        usecase "View Planet Map" as UC1
        usecase "Select Planet" as UC2
        usecase "Browse Sector List" as UC15
    }

    package "Sector Interaction" {
        usecase "Hover / Select Sector" as UC3
        usecase "View Sector Info & Stats" as UC4
        usecase "Rename Sector" as UC13
        usecase "Change Sector Icon" as UC14
        usecase "Abandon Sector" as UC12
    }

    package "Campaign Configuration" {
        usecase "Configure Campaign Rules" as UC5
    }

    package "Sector Launch" {
        usecase "Launch to New Sector" as UC6
        usecase "Configure Launch Loadout" as UC7
        usecase "Resume / Enter Existing Sector" as UC8
        usecase "Select Sector for Planet Launch" as UC9
        usecase "Select Destination Sector" as UC10
    }

    package "Campaign Completion" {
        usecase "View Campaign Completion" as UC11
    }

}

' ── Player associations ──────────────────────────────────────
Player --> UC1
Player --> UC2
Player --> UC3
Player --> UC4
Player --> UC5
Player --> UC6
Player --> UC7
Player --> UC8
Player --> UC9
Player --> UC10
Player --> UC11
Player --> UC13
Player --> UC14
Player --> UC15

' ── GameSystem associations ──────────────────────────────────
GameSystem --> UC6  : control.playSector()
GameSystem --> UC7  : universe.updateLoadout()
GameSystem --> UC8  : control.playSector()
GameSystem --> UC11 : campaign complete\nevent

' ── Include relationships ────────────────────────────────────
UC1 ..> UC2   : <<include>>
UC1 ..> UC15  : <<include>>
UC6 ..> UC7   : <<include>>
UC4 ..> UC12  : <<include>>

' ── Extend relationships ─────────────────────────────────────
UC1  <.. UC5  : <<extend>>
UC3  <.. UC13 : <<extend>>
UC3  <.. UC14 : <<extend>>

@enduml
