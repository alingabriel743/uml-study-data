@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Crash & Error Handling

left to right direction

actor "JVM / OS" as jvm
actor "Mod System" as mods
actor "Server Admin" as admin
actor "Player" as player

rectangle "Crash & Error Handling System" {

    package "Crash Reporting (CrashHandler)" {
        usecase "Handle Crash" as UC1
        usecase "Generate Crash Report" as UC2
        usecase "Identify Mod Cause" as UC3
        usecase "Log Crash to File" as UC4
        usecase "Save Settings Before Exit" as UC5
        usecase "Dispose Network Connection" as UC6
    }

    package "Error Presentation" {
        usecase "Show Desktop Error Dialog" as UC7
    }

    package "Admin & Player Dialogs" {
        usecase "View Player Trace Info" as UC8
        usecase "View Game Over Stats" as UC9
        usecase "Continue After Game Over" as UC10
        usecase "Display Full-Text Info" as UC11
    }
}

' --- Actor associations ---
jvm --> UC1
jvm --> UC4
jvm --> UC7
mods --> UC3
admin --> UC8
player --> UC9
player --> UC10
player --> UC11

' --- Include relationships ---
UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC1 ..> UC5 : <<include>>
UC1 ..> UC6 : <<include>>
UC4 ..> UC2 : <<include>>
UC9 ..> UC10 : <<include>>

' --- Extend relationships ---
UC7 <.. UC1 : <<extend>>\n[desktop platform]
UC11 <.. UC9 : <<extend>>\n[campaign mode]

note bottom of UC1
  Ends with System.exit(1)
  Skips file writing for dev builds
end note

note right of UC3
  Scans stack frames against
  loaded mod class & JS file names
end note

note right of UC7
  Tries SDL_ShowSimpleMessageBox,
  falls back to JOptionPane,
  then System.exit(1)
end note

@enduml
