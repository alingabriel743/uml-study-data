@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam ArrowFontColor #495057

title Game Launch & Platform Initialization

left to right direction

actor "Desktop Player\n(OS / JVM)" as DesktopPlayer
actor "Android User\n(Activity)" as AndroidUser
actor "iOS User\n(UIApplication)" as IOSUser
actor "Server Operator\n(Headless)" as ServerOperator

rectangle "Mindustry Launch & Platform Initialization" {

    ' ── Desktop ──────────────────────────────────────────
    package "Desktop Launch" {
        usecase "Launch Game\non Desktop" as UC1
        usecase "Check System\nRequirements" as UC11
        usecase "Configure\nGL Version" as UC12
        usecase "Initialize Steam\nIntegration" as UC8
        usecase "Initialize\nDiscord RPC" as UC9
    }

    ' ── Android ──────────────────────────────────────────
    package "Android Launch" {
        usecase "Launch Game\non Android" as UC2
        usecase "Request Storage\nPermissions" as UC14
    }

    ' ── iOS ──────────────────────────────────────────────
    package "iOS Launch" {
        usecase "Launch Game\non iOS" as UC3
        usecase "Handle Application\nLifecycle (Mobile)" as UC16
    }

    ' ── Server ───────────────────────────────────────────
    package "Headless Server Launch" {
        usecase "Launch Headless\nServer" as UC4
        usecase "Initialize\nHeadless Server" as UC13
    }

    ' ── Shared Client Bootstrap ───────────────────────────
    package "Client Bootstrap (Shared)" {
        usecase "Initialize Core\nClient Systems" as UC5
        usecase "Load Assets\nAsynchronously" as UC6
        usecase "Finalize\nClient Load" as UC7
        usecase "Handle File Drop\n/ URL Open" as UC10
        usecase "Show\nFile Chooser" as UC15
    }
}

' ── Actor → Use Case ─────────────────────────────────────
DesktopPlayer --> UC1
DesktopPlayer --> UC10
AndroidUser   --> UC2
AndroidUser   --> UC16
IOSUser       --> UC3
IOSUser       --> UC16
ServerOperator --> UC4

' ── Include relationships ────────────────────────────────
UC1  ..> UC11 : <<include>>
UC1  ..> UC12 : <<include>>
UC1  ..> UC5  : <<include>>
UC2  ..> UC5  : <<include>>
UC3  ..> UC5  : <<include>>
UC5  ..> UC6  : <<include>>
UC6  ..> UC7  : <<include>>
UC4  ..> UC13 : <<include>>

' ── Extend relationships ─────────────────────────────────
UC1  <.. UC8  : <<extend>>\n[Version.isSteam]
UC1  <.. UC9  : <<extend>>\n[!nodiscord]
UC2  <.. UC14 : <<extend>>\n[Android ≥M]
UC15 <.. UC10 : <<extend>>\n[file/URL received]

@enduml
