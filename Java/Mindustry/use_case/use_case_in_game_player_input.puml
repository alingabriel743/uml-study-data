@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2255AA
    FontColor #1a1a2e
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057

left to right direction

title In-Game Player Input & Control

actor "Desktop Player\n(Keyboard + Mouse)" as DesktopPlayer
actor "Mobile Player\n(Touchscreen)" as MobilePlayer
actor "Server\n(Trust Boundary)" as Server

rectangle "In-Game Player Input & Control" {

    package "Movement & Combat" {
        usecase "Move Unit" as UC01
        usecase "Shoot / Attack" as UC02
        usecase "Boost Unit" as UC21
    }

    package "Building & Tile" {
        usecase "Tap Tile\n(General Interaction)" as UC20
        usecase "Place Block" as UC03
        usecase "Break Block" as UC04
        usecase "Rotate Block" as UC05
        usecase "Configure Tile" as UC06
        usecase "Mine Tile" as UC09
        usecase "Repair Derelict Building" as UC22
    }

    package "Items & Payloads" {
        usecase "Transfer Item\nto Building" as UC07
        usecase "Drop Item" as UC08
        usecase "Pick Up Payload" as UC16
        usecase "Drop Payload" as UC17
    }

    package "Unit & Building Control" {
        usecase "Control Unit\n(Possess)" as UC10
        usecase "Control Building" as UC11
        usecase "Respawn" as UC12
        usecase "Command Units\n(RTS Mode)" as UC13
    }

    package "Selection (Desktop Only)" {
        usecase "Select Unit\nControl Group" as UC14
        usecase "Select All Units" as UC15
    }

    package "Navigation & Communication" {
        usecase "Pan / Zoom Camera" as UC19
        usecase "Ping Location" as UC18
    }
}

' ── Desktop Player associations ──────────────────────────────
DesktopPlayer --> UC01
DesktopPlayer --> UC02
DesktopPlayer --> UC21
DesktopPlayer --> UC20
DesktopPlayer --> UC03
DesktopPlayer --> UC04
DesktopPlayer --> UC05
DesktopPlayer --> UC06
DesktopPlayer --> UC09
DesktopPlayer --> UC22
DesktopPlayer --> UC07
DesktopPlayer --> UC08
DesktopPlayer --> UC16
DesktopPlayer --> UC17
DesktopPlayer --> UC10
DesktopPlayer --> UC11
DesktopPlayer --> UC12
DesktopPlayer --> UC13
DesktopPlayer --> UC14
DesktopPlayer --> UC15
DesktopPlayer --> UC19
DesktopPlayer --> UC18

' ── Mobile Player associations ───────────────────────────────
MobilePlayer --> UC01
MobilePlayer --> UC02
MobilePlayer --> UC21
MobilePlayer --> UC20
MobilePlayer --> UC03
MobilePlayer --> UC04
MobilePlayer --> UC06
MobilePlayer --> UC09
MobilePlayer --> UC22
MobilePlayer --> UC07
MobilePlayer --> UC08
MobilePlayer --> UC16
MobilePlayer --> UC17
MobilePlayer --> UC10
MobilePlayer --> UC11
MobilePlayer --> UC12
MobilePlayer --> UC13
MobilePlayer --> UC19
MobilePlayer --> UC18

' ── Server associations (validates @Remote actions) ──────────
UC03 --> Server
UC04 --> Server
UC05 --> Server
UC06 --> Server
UC07 --> Server
UC08 --> Server
UC10 --> Server
UC11 --> Server
UC12 --> Server
UC13 --> Server
UC18 --> Server

' ── Include relationships (base flow delegates to tap) ───────
UC03 ..> UC20 : <<include>>
UC04 ..> UC20 : <<include>>
UC06 ..> UC20 : <<include>>

' ── Extend relationships ─────────────────────────────────────
UC20 <.. UC09 : <<extend>>
UC13 <.. UC10 : <<extend>>
UC10 <.. UC16 : <<extend>>
UC10 <.. UC17 : <<extend>>

@enduml
