@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057

title Logic Scripting & Programming

left to right direction

' ─── Actors ───────────────────────────────────────────────
actor "Player" as Player
actor "Privileged Player\n(World Editor / Admin)" as PrivilegedPlayer
actor "Logic Processor\n(Building / World Block)" as LogicProcessor
actor "Android Rhino Runtime\n(Android-only JS Engine)" as AndroidRhinoRuntime

' Privileged Player is a specialisation of Player
PrivilegedPlayer -up-|> Player

' ─── System Boundary ──────────────────────────────────────
rectangle "Logic Scripting & Programming" {

    ' ── Core Editor ──────────────────────────────────────
    usecase "Open Logic Editor\n<size:10>(LogicDialog.show())</size>" as UC1
    usecase "Save / Apply Code\n<size:10>(canvas.save() → consumer)</size>" as UC10

    ' ── In-Editor Actions ────────────────────────────────
    usecase "Add Logic Statement\n<size:10>(showAddDialog())</size>" as UC2
    usecase "Clear All Statements\n<size:10>(canvas.clearStatements())</size>" as UC3
    usecase "Copy Code to Clipboard\n<size:10>(canvas.save() → clipboard)</size>" as UC4
    usecase "Import Code from Clipboard\n<size:10>(canvas.load())</size>" as UC5
    usecase "Restart Logic Processor\n<size:10>(forceRestart=true; hide())</size>" as UC6

    ' ── Variable Inspection ──────────────────────────────
    usecase "View Live Variables\n<size:10>(executor.vars[])</size>" as UC7
    usecase "View Global Variables\n<size:10>(GlobalVarsDialog.show())</size>" as UC8

    ' ── Privileged Actions ───────────────────────────────
    usecase "Rename Logic Processor\n<size:10>(executor.build.configure(tag))</size>" as UC9

    ' ── Runtime / System ─────────────────────────────────
    usecase "Assemble & Execute\nLogic Statements\n<size:10>(LExecutor.load())</size>" as UC11
    usecase "Run JavaScript Mods\n(Android)\n<size:10>(AndroidRhinoContext.enter())</size>" as UC12

    ' ── include / extend relationships ───────────────────
    UC1 .right.> UC10   : <<include>>
    UC2 .up.>   UC1     : <<extend>>
    UC3 .up.>   UC1     : <<extend>>
    UC4 .down.> UC1     : <<extend>>
    UC5 .down.> UC1     : <<extend>>
    UC6 .down.> UC1     : <<extend>>
    UC7 .right.> UC1    : <<extend>>
    UC8 .right.> UC7    : <<extend>>
    UC9 .up.>   UC1     : <<extend>>
}

' ─── Actor → Use-Case associations ───────────────────────
Player          --> UC1
Player          --> UC2
Player          --> UC3
Player          --> UC4
Player          --> UC5
Player          --> UC6
Player          --> UC7
Player          --> UC8
Player          --> UC10

PrivilegedPlayer --> UC9

LogicProcessor      --> UC11
AndroidRhinoRuntime --> UC12

@enduml
