@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}

left to right direction

title Main Menu & Navigation

actor "Player" as player

rectangle "Mindustry — Main Menu (MenuFragment)" {

    package "Play" {
        usecase "Start Campaign" as UC01
        usecase "Play Custom Game" as UC02
        usecase "Join Multiplayer Game" as UC03
        usecase "Load Saved Game" as UC04
        usecase "Open Map Editor" as UC05
    }

    package "Content & Info" {
        usecase "View Database" as UC06
        usecase "View Schematics\n<<desktop only>>" as UC07
        usecase "View About / Credits" as UC09
        usecase "Browse Content Item" as UC13
        usecase "View Credits" as UC14
    }

    package "Configuration" {
        usecase "Open Settings" as UC08
        usecase "Configure Game / Graphics / Sound" as UC15
        usecase "Manage Data" as UC12
    }

    package "Other" {
        usecase "Open Mods" as UC10
        usecase "Quit Game\n<<desktop only>>" as UC11
    }

    usecase "Validate Mod Errors\n(checkPlay)" as UC_CHECK

}

' --- Player associations ---
player --> UC01
player --> UC02
player --> UC03
player --> UC04
player --> UC05
player --> UC06
player --> UC07
player --> UC08
player --> UC09
player --> UC10
player --> UC11

' --- checkPlay guard (include) ---
UC01 ..> UC_CHECK : <<include>>
UC02 ..> UC_CHECK : <<include>>
UC03 ..> UC_CHECK : <<include>>
UC04 ..> UC_CHECK : <<include>>
UC05 ..> UC_CHECK : <<include>>

' --- Settings sub-use-cases (include) ---
UC08 ..> UC15 : <<include>>
UC08 ..> UC12 : <<include>>

' --- Database and About extensions ---
UC06 <.. UC13 : <<extend>>
UC09 <.. UC14 : <<extend>>

@enduml
