@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BBF
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #EEF2F7
    BorderColor #6C757D
    FontColor #212529
}

title Map Editor

left to right direction

actor "Designer" as designer
actor "Steam Platform" as steam

rectangle "Map Editor Toolset (MapEditorDialog)" {

    package "Editor Lifecycle" {
        usecase "Open Map Editor" as UC01
        usecase "Exit Editor" as UC32
    }

    package "Canvas Drawing" {
        usecase "Draw Tiles" as UC02
        usecase "Select Drawing Tool" as UC03
        usecase "Select Block" as UC04
        usecase "Select Team" as UC05
        usecase "Set Brush Size" as UC06
        usecase "Rotate Block" as UC07
    }

    package "View Controls" {
        usecase "Zoom / Pan Map" as UC10
        usecase "Toggle Grid" as UC08
        usecase "Center View" as UC09
        usecase "Toggle View Layers" as UC12
    }

    package "Edit History" {
        usecase "Undo / Redo Edit" as UC11
    }

    package "File Operations" {
        usecase "Save Map" as UC13
        usecase "Load Map" as UC14
        usecase "Import Map" as UC15
        usecase "Export Map" as UC16
        usecase "Resize Map" as UC17
    }

    package "Map Info & Metadata" {
        usecase "Edit Map Info" as UC19
        usecase "Configure Game Rules" as UC20
        usecase "Configure Waves" as UC21
        usecase "Configure Objectives" as UC22
        usecase "Configure Generation Filters (Saved)" as UC23
        usecase "Configure Locales" as UC24
        usecase "Configure World Processors" as UC25
        usecase "Configure Patches" as UC26
    }

    package "Terrain Generation" {
        usecase "Generate Terrain" as UC18
        usecase "Generate Sector" as UC29
        usecase "Copy / Paste Filters (Clipboard)" as UC31
    }

    package "Testing & Publishing" {
        usecase "Playtest Map" as UC27
        usecase "Edit In-Game" as UC28
        usecase "Publish to Workshop" as UC30
    }

}

' --- Designer associations ---
designer --> UC01
designer --> UC02
designer --> UC03
designer --> UC04
designer --> UC05
designer --> UC06
designer --> UC07
designer --> UC08
designer --> UC09
designer --> UC10
designer --> UC11
designer --> UC12
designer --> UC13
designer --> UC14
designer --> UC15
designer --> UC16
designer --> UC17
designer --> UC18
designer --> UC19
designer --> UC27
designer --> UC28
designer --> UC29
designer --> UC30
designer --> UC32

' --- Steam Platform association ---
steam --> UC30

' --- Include relationships ---
UC13 ..> UC19 : <<include>>\nif name empty
UC18 ..> UC31 : <<include>>\nclipboard copy/paste
UC19 ..> UC20 : <<include>>
UC19 ..> UC21 : <<include>>
UC19 ..> UC22 : <<include>>
UC19 ..> UC23 : <<include>>
UC19 ..> UC24 : <<include>>
UC19 ..> UC25 : <<include>>
UC19 ..> UC26 : <<include>>

' --- Extend relationships ---
UC15 ..> UC14 : <<extend>>\nmultiple import sources
UC27 ..> UC13 : <<extend>>\nsaves first
UC30 ..> UC13 : <<extend>>\nsaves first

@enduml
