@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057

left to right direction

title Map Management & Selection

' ── Actors ───────────────────────────────────────────────────────────────────
actor "Player" as player
actor "Editor User" as editor
actor "Platform\n(FileSystem)" as platform
actor "System\n(AssetManager)" as system

' ── System Boundary ──────────────────────────────────────────────────────────
rectangle "Map Management & Selection" {

    ' ── Map Browsing ─────────────────────────────────────────────────────────
    package "Map Browsing (MapListDialog)" {
        usecase "Browse Map List" as UC01
        usecase "Search Maps" as UC02
        usecase "Filter Maps by\nType / Gamemode" as UC03
    }

    ' ── Map Playing ──────────────────────────────────────────────────────────
    package "Map Playing (MapPlayDialog)" {
        usecase "Select Map to Play" as UC04
        usecase "Choose Gamemode" as UC05
        usecase "Customize Rules" as UC06
        usecase "View Gamemode Help" as UC07
        usecase "Play Map" as UC08
        usecase "View Map High Score" as UC09
    }

    ' ── Map Editing ──────────────────────────────────────────────────────────
    package "Map Editing (EditorMapsDialog)" {
        usecase "Create New Map" as UC10
        usecase "Import Map from File" as UC11
        usecase "View Map Info" as UC12
        usecase "Open Map in Editor" as UC13
        usecase "Delete Map" as UC14
        usecase "View Map on Workshop" as UC15
    }

    ' ── System / Background ──────────────────────────────────────────────────
    package "Preview & Validation (MapPreviewLoader / MapIO)" {
        usecase "Load Map Preview Texture" as UC16
        usecase "Generate Map Preview" as UC17
        usecase "Validate Map File" as UC18
    }
}

' ── Actor → Use Case associations ────────────────────────────────────────────
' Player
player --> UC01
player --> UC04
player --> UC05
player --> UC06
player --> UC07
player --> UC08
player --> UC09

' Editor User
editor --> UC01
editor --> UC10
editor --> UC11
editor --> UC12
editor --> UC13
editor --> UC14
editor --> UC15

' Platform (FileSystem)
UC11 --> platform : file chooser
UC15 --> platform : view listing

' System (AssetManager)
system --> UC16

' ── <<extend>> relationships ──────────────────────────────────────────────────
UC02 ..> UC01 : <<extend>>
UC03 ..> UC01 : <<extend>>
UC06 ..> UC05 : <<extend>>

' ── <<include>> relationships ─────────────────────────────────────────────────
UC11 ..> UC18 : <<include>>
UC16 ..> UC17 : <<include>>

@enduml
