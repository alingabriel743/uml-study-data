@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #4A90D9
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #EEF2F7
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Mod Management

left to right direction

' ─── Actors ───────────────────────────────────────────────────────────
actor "Player" as player
actor "Steam\nPlatform" as steam #D0F0D0
actor "GitHub\nAPI" as github #FFE0CC

' ─── System Boundary ──────────────────────────────────────────────────
rectangle "Mod Management System" {

    ' ── Discovery & Browsing ──────────────────────────────────────────
    package "Discovery & Browsing" {
        usecase "Browse Installed Mods" as UC01
        usecase "Search / Filter Mods" as UC02
        usecase "View Mod Details" as UC12
        usecase "View Mod Content" as UC13
    }

    ' ── Community Browser ─────────────────────────────────────────────
    package "Community Mod Browser" {
        usecase "Browse Community\nMod Browser" as UC05
        usecase "Sort Mod Browser" as UC06
        usecase "Install Mod\nfrom Browser" as UC07
        usecase "View Mod Releases" as UC08
    }

    ' ── Installation ──────────────────────────────────────────────────
    package "Mod Installation" {
        usecase "Import Mod\nfrom File" as UC03
        usecase "Import Mod\nfrom GitHub" as UC04
        usecase "Import Mod\nDependencies" as UC15
    }

    ' ── Lifecycle Management ──────────────────────────────────────────
    package "Mod Lifecycle" {
        usecase "Enable Mod" as UC09
        usecase "Disable Mod" as UC10
        usecase "Remove Mod" as UC11
        usecase "Reload Mods" as UC14
    }

    ' ── Steam Workshop ────────────────────────────────────────────────
    package "Steam Workshop Integration" {
        usecase "Publish Mod to\nSteam Workshop" as UC16
        usecase "Update Steam\nWorkshop Item" as UC17
        usecase "View Steam\nWorkshop Listing" as UC18
        usecase "Subscribe to\nWorkshop Mod" as UC19
        usecase "Load Workshop\nMods on Startup" as UC20
    }
}

' ─── Player Associations ──────────────────────────────────────────────
player --> UC01
player --> UC02
player --> UC12
player --> UC13
player --> UC03
player --> UC04
player --> UC05
player --> UC06
player --> UC07
player --> UC08
player --> UC09
player --> UC10
player --> UC11
player --> UC14
player --> UC15
player --> UC16
player --> UC17
player --> UC18

' ─── Steam Platform Associations ──────────────────────────────────────
steam --> UC19
steam --> UC20

' ─── GitHub API Associations ──────────────────────────────────────────
github --> UC04
github --> UC08

' ─── Include / Extend Relationships ──────────────────────────────────
UC07 ..> UC04 : <<include>>
UC15 ..> UC04 : <<include>>
UC13 ..> UC12 : <<extend>>
UC08 ..> UC07 : <<extend>>
UC14 ..> UC09 : <<extend>>
UC14 ..> UC10 : <<extend>>

' ─── Notes ────────────────────────────────────────────────────────────
note bottom of UC11
  Only available for
  non-Steam mods
end note

note bottom of UC14
  Auto-triggered when
  ModsDialog closes after
  enable/disable changes
end note

note right of UC19
  Steam callback on
  subscription event;
  triggers achievement
end note

@enduml
