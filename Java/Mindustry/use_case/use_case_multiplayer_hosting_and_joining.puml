@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #495057
    FontColor #212529
}

left to right direction

title Multiplayer Hosting & Joining

' ── Actors ──────────────────────────────────────────────
actor "Player\n(Client)" as Player
actor "Server Admin\n(Host / CLI)" as Admin
actor "Net / Network\nLayer" as Net <<external>>
actor "Administration\n(netServer.admins)" as AdminSys <<external>>

' ── System Boundary ──────────────────────────────────────
rectangle "Multiplayer Hosting & Joining" {

    ' ── Client Session Management ──────────────────────
    package "Client Session Management" #EEF4FF {
        usecase "Host a Server\n<size:10>(HostDialog)</size>" as UC01
        usecase "Join Server\n(Direct IP)\n<size:10>(JoinDialog – Remote Tab)</size>" as UC02
        usecase "Join Local\n(LAN) Server\n<size:10>(JoinDialog – Local Tab)</size>" as UC03
        usecase "Browse & Join\nCommunity Servers\n<size:10>(JoinDialog – Global Tab)</size>" as UC04
        usecase "Reconnect to\nLast Server" as UC05
    }

    ' ── Server Control ─────────────────────────────────
    package "Server Control" #FFF8E1 {
        usecase "Host Server via CLI\n<size:10>(ServerControl)</size>" as UC06
        usecase "Stop Server" as UC07
        usecase "Configure Server\nSettings\n<size:10>(serverName, port, maxPlayers…)</size>" as UC14
        usecase "Set Player Limit" as UC12
    }

    ' ── Player Management ──────────────────────────────
    package "Player Management" #FFF0F3 {
        usecase "Kick Player" as UC08
        usecase "Ban Player\n<size:10>(by ID / name / IP)</size>" as UC09
        usecase "Unban Player\n<size:10>(BansDialog / CLI)</size>" as UC10
        usecase "Manage Admins\n<size:10>(AdminsDialog / CLI)</size>" as UC11
        usecase "Manage Whitelist" as UC13
        usecase "Manage Subnet\n& Name Bans" as UC15
    }
}

' ── Player → Use Cases ────────────────────────────────────
Player --> UC01
Player --> UC02
Player --> UC03
Player --> UC04
Player --> UC05

' ── Admin → Use Cases ─────────────────────────────────────
Admin --> UC06
Admin --> UC07
Admin --> UC08
Admin --> UC09
Admin --> UC10
Admin --> UC11
Admin --> UC12
Admin --> UC13
Admin --> UC14
Admin --> UC15

' ── External: Net / Network Layer ────────────────────────
UC01 --> Net : net.host(port)
UC02 --> Net : net.connect()
UC03 --> Net : net.discoverServers()
UC05 --> Net : net.pingHost()
UC06 --> Net : netServer.openServer()
UC07 --> Net : net.closeServer()

' ── External: Administration (player registry) ───────────
UC09 --> AdminSys : banPlayerID/\nbanPlayerIP()
UC10 --> AdminSys : unbanPlayerID()
UC11 --> AdminSys : adminPlayer() /\nunAdminPlayer()
UC12 --> AdminSys : setPlayerLimit()
UC13 --> AdminSys : whitelist() /\nunwhitelist()
UC15 --> AdminSys : addSubnetBan() /\naddNameBan()

@enduml
