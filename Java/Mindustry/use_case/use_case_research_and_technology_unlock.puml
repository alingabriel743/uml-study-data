@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Research & Technology Unlock

left to right direction

actor "Player" as Player
actor "GameService" as GameService <<system>>
actor "NetworkClient" as NetworkClient <<system>>

rectangle "Research & Technology Unlock" {

    usecase "Open Research Dialog" as UC1
    note right of UC1
      Triggered via Binding.research
      keybind or planet UI callback;
      loads tech tree for current planet
    end note

    usecase "Browse Tech Tree" as UC2
    note bottom of UC2
      Pan / zoom the tree view
    end note

    usecase "Switch Tech Tree (Planet)" as UC4
    note bottom of UC4
      Only shown when >1 eligible
      tech tree root exists
    end note

    usecase "Inspect Node Details" as UC3
    note right of UC3
      Hover / tap a node to see
      name, requirements & progress;
      locked nodes show '???'
    end note

    usecase "View Available Resources" as UC7
    note bottom of UC7
      Aggregates items across all
      active planet sector storages
    end note

    usecase "Spend Resources to Research" as UC5
    note right of UC5
      Disabled for NetworkClient;
      requires selectable node and
      sufficient items in sectors
    end note

    usecase "Unlock Content" as UC6
    note right of UC6
      Persists unlock to settings;
      fires UnlockEvent + ResearchEvent;
      plays uiUnlock sound
    end note

    usecase "Open Content Database" as UC8
    note bottom of UC8
      Opens full database entry
      for the selected content
    end note

    ' Include relationships
    UC1 ..> UC7 : <<include>>
    UC5 ..> UC6 : <<include>>
    UC3 ..> UC7 : <<include>>

    ' Extend relationships
    UC1 <.. UC4 : <<extend>>\nmulti-planet game
    UC3 <.. UC8 : <<extend>>\nfrom info button
}

' Player interactions
Player --> UC1
Player --> UC2
Player --> UC3
Player --> UC4
Player --> UC5
Player --> UC6
Player --> UC7
Player --> UC8

' NetworkClient: read-only view, cannot research
NetworkClient --> UC1
NetworkClient --> UC2
NetworkClient --> UC3

' GameService reacts to events fired after unlock
UC6 --> GameService : fires ResearchEvent\n& UnlockEvent

@enduml
