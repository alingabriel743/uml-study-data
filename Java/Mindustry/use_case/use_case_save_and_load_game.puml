@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2A6090
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Save & Load Game

left to right direction

actor "Player" as player
actor "System\n(Autosave)" as autosave

rectangle "Save/Load Persistence System" {

    usecase "Save Game to\nNew Slot" as UC1
    usecase "Overwrite\nExisting Save" as UC2
    usecase "Load Game\nfrom Slot" as UC3
    usecase "Import Save File" as UC4
    usecase "Export Save File" as UC5
    usecase "Delete Save Slot" as UC6
    usecase "Rename Save Slot" as UC7
    usecase "Toggle Autosave" as UC8
    usecase "Preview Save\nThumbnail" as UC9
    usecase "Search / Filter\nSave Slots" as UC10

}

' --- Player associations ---
player --> UC1
player --> UC2
player --> UC3
player --> UC4
player --> UC5
player --> UC6
player --> UC7
player --> UC8
player --> UC10

' --- System (Autosave) associations ---
autosave --> UC1
autosave --> UC9

' --- Include relationships ---
UC3  ..> UC9   : <<include>>

' --- Extend relationships ---
UC2 <.. UC1   : <<extend>>\n(overwrite existing)

@enduml
