@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Schematic & Loadout Management

left to right direction

actor "Player" as player
actor "Platform\n(Steam / OS)" as platform
actor "Schematics\nSystem" as schemsys
actor "Universe /\nSector System" as universe

rectangle "Schematic & Loadout Management" {

    rectangle "Schematics (SchematicsDialog)" {
        usecase "Browse Schematics" as UC1
        usecase "Search Schematics" as UC2
        usecase "Filter by Tags" as UC3
        usecase "View Schematic Info" as UC4
        usecase "Deploy / Use Schematic" as UC5
        usecase "Import Schematic" as UC6
        usecase "Export Schematic" as UC7
        usecase "Edit Schematic Metadata" as UC8
        usecase "Delete Schematic" as UC9
    }

    rectangle "Tag Management" {
        usecase "Manage Tags (Global)" as UC10
        usecase "Add Tag to Schematic" as UC11
        usecase "Remove Tag from Schematic" as UC12
        usecase "Create Icon Tag" as UC13
    }

    rectangle "Loadout & Launch (LaunchLoadoutDialog)" {
        usecase "Select Launch Schematic" as UC15
        usecase "Configure Launch Resources" as UC16
        usecase "Auto-Max Launch Resources" as UC17
        usecase "Launch to Sector" as UC18
    }

    rectangle "Item Loadout (LoadoutDialog)" {
        usecase "Configure Item Loadout" as UC14
    }

    rectangle "UI Helpers" {
        usecase "Select Player Color" as UC19
        usecase "Select Icon" as UC20
    }
}

' ── Player → Schematics ──────────────────────────────────────────────────────
player --> UC1
player --> UC2
player --> UC3
player --> UC4
player --> UC5
player --> UC6
player --> UC7
player --> UC8
player --> UC9

' ── Player → Tag Management ──────────────────────────────────────────────────
player --> UC10
player --> UC11
player --> UC12

' ── Player → Loadout / Launch ─────────────────────────────────────────────────
player --> UC15
player --> UC17
player --> UC18

' ── Player → UI Helpers ───────────────────────────────────────────────────────
player --> UC19
player --> UC20

' ── External system interactions ─────────────────────────────────────────────
platform --> UC6  : file chooser /\nWorkshop
platform --> UC7  : file export /\nWorkshop publish
schemsys --> UC1  : provides schematic list
schemsys --> UC5  : useSchematic()
universe --> UC16 : getLaunchResources()
universe --> UC18 : updateLoadout()

' ── Include / Extend relationships ───────────────────────────────────────────
' View Schematic Info surfaces export and edit actions
UC4  ..> UC7  : <<include>>
UC4  ..> UC8  : <<include>>

' Adding a tag can trigger icon tag creation
UC11 ..> UC13 : <<include>>

' Launch loadout flow composes nested dialogs
UC15 ..> UC16 : <<include>>
UC15 ..> UC17 : <<include>>
UC16 ..> UC14 : <<include>>

' ── Conditional / notes ───────────────────────────────────────────────────────
note top of UC6
  Steam Workshop path active
  only when steam == true.
  Clipboard & file paths always available.
end note

note top of UC7
  Steam Workshop publish available
  only when steam == true
  and schematic has no Steam ID yet.
end note

note right of UC16
  Only shown when
  destination.allowLaunchLoadout()
  is true.
end note

' ── Composition / delegation notes ───────────────────────────────────────────
note bottom of UC13
  Inline icon picker in SchematicsDialog.
  Full delegation to IconSelectDialog (UC20)
  is planned but not yet implemented.
end note

note right of UC14
  Step logic: 100 -> 200 -> 500 -> 1000
  based on current item amount.
  Max button fills all items to capacity.
end note

@enduml
