@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7FC1
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
    FontStyle bold
}
skinparam ArrowColor #495057
skinparam ArrowThickness 1.2
skinparam NoteBackgroundColor #FFF9C4
skinparam NoteBorderColor #C8A800

title Settings, Keybinds & Accessibility

left to right direction

' ─── Actors ───────────────────────────────────────────────
actor "Player" as Player
actor "Mod / Plugin" as Mod
actor "Core Settings\n(platform)" as CoreSettings

' ─── System Boundary ──────────────────────────────────────
rectangle "Mindustry — Settings, Keybinds & Accessibility" {

    ' Entry point
    usecase "Open Settings Menu\n<size:10>(SettingsMenuDialog)</size>" as UC01

    ' Settings categories launched from the menu
    usecase "Adjust Game Settings\n<size:10>(save interval, hints, keyboard mode…)</size>" as UC02
    usecase "Adjust Graphics Settings\n<size:10>(bloom, FPS, fullscreen, effects…)</size>" as UC03
    usecase "Adjust Sound Settings\n<size:10>(music, SFX, ambient volumes)</size>" as UC04

    ' Sub-dialogs extended/navigated from Settings Menu
    usecase "Change Language\n<size:10>(LanguageDialog — 35+ locales)</size>" as UC05
    usecase "Remap Keybinds\n<size:10>(KeybindDialog — search, capture, axis)</size>" as UC06
    usecase "Manage Data\n<size:10>(export/import ZIP, clear saves/research)</size>" as UC09

    ' Shared embedded behaviour
    usecase "Reset Settings to Defaults\n<size:10>(SettingsTable — remove all keys)</size>" as UC11

    ' Standalone / auxiliary dialogs
    usecase "View / Select Visual Effects\n<size:10>(EffectsDialog — live previews)</size>" as UC07
    usecase "View Discord Integration\n<size:10>(DiscordDialog — copy/open link)</size>" as UC08

    ' Mod extension point
    usecase "Add Custom Settings Category\n<size:10>(Mod API — addCategory())</size>" as UC10
}

' ─── Player associations ──────────────────────────────────
Player --> UC01 : opens
Player --> UC07 : browses effects
Player --> UC08 : views Discord

' ─── Mod association ──────────────────────────────────────
Mod --> UC10 : injects category

' ─── Core Settings (platform) associations ────────────────
CoreSettings --> UC02 : persists via Core.settings
CoreSettings --> UC03 : applies renderer/platform calls
CoreSettings --> UC04 : persists volume keys

' ─── «include» — UC01 always launches these sub-dialogs ──
UC01 ..> UC02  : <<include>>
UC01 ..> UC03  : <<include>>
UC01 ..> UC04  : <<include>>
UC01 ..> UC09  : <<include>>

' ─── «extend» — optional navigation from UC01 ────────────
UC05 ..> UC01  : <<extend>>
UC06 ..> UC01  : <<extend>>
UC10 ..> UC01  : <<extend>>

' ─── «include» — Reset embedded in each settings table ───
UC02 ..> UC11  : <<include>>
UC03 ..> UC11  : <<include>>
UC04 ..> UC11  : <<include>>

' ─── Notes ───────────────────────────────────────────────
note right of UC06
  Two-pass axis rebinding:
  min key captured first,
  then max key.
end note

note right of UC09
  Clear data retains UUID/USID.
  Import/Export as ZIP;
  app restarts after import.
end note

note bottom of UC10
  Called at rebuildMenu()
  extension point.
end note

@enduml
