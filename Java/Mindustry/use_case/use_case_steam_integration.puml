@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7DC9
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Steam Integration

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────
actor "Player" as Player
actor "Server Host" as ServerHost
actor "Steam Platform" as Steam <<external system>>

' ── System Boundary ──────────────────────────────────────────────────────
rectangle "Steam Integration  (App ID: 1127400)" {

    ' ── Networking ───────────────────────────────────────────────────────
    package "Multiplayer Networking  (SNet)" {
        usecase "Authenticate Steam User"         as UC13
        usecase "Host Multiplayer Server"         as UC01
        usecase "Discover Steam Servers"          as UC03
        usecase "Join Server via Steam"           as UC02
        usecase "Send / Receive P2P Packets"      as UC04
        usecase "Invite Friends to Game"          as UC05
        usecase "Update Lobby Metadata"           as UC06
    }

    ' ── Workshop ─────────────────────────────────────────────────────────
    package "Workshop & Content Sharing  (SWorkshop)" {
        usecase "Browse & Download Workshop Content" as UC10
        usecase "View Workshop Listing"              as UC09
        usecase "Publish Content to Workshop"        as UC07
        usecase "Update Workshop Item"               as UC08
    }

    ' ── Stats & Achievements ─────────────────────────────────────────────
    package "Stats & Achievements  (SStats)" {
        usecase "Track & Store Steam Stats"   as UC11
        usecase "Complete Achievement"        as UC12
    }
}

' ── Actor → Use Case associations ────────────────────────────────────────
' Player
Player --> UC13
Player --> UC03
Player --> UC02
Player --> UC04
Player --> UC10
Player --> UC09
Player --> UC07
Player --> UC08
Player --> UC11
Player --> UC12

' Server Host (is also a Player, plus hosting actions)
ServerHost --> UC01
ServerHost --> UC05
ServerHost --> UC06
ServerHost --> UC04

' Steam Platform interactions
UC01  --> Steam : createLobby / setLobbyData
UC02  --> Steam : joinLobby / P2P connect
UC03  --> Steam : requestLobbyList
UC04  --> Steam : sendP2PPacket / readP2PPacket
UC05  --> Steam : activateGameOverlayInviteDialog
UC06  --> Steam : setLobbyData
UC07  --> Steam : createItem / submitItemUpdate
UC08  --> Steam : startItemUpdate / submitItemUpdate
UC09  --> Steam : sendQueryUGCRequest / overlay
UC10  --> Steam : getSubscribedItems / getItemInstallInfo
UC11  --> Steam : requestCurrentStats / storeStats
UC12  --> Steam : setAchievement / storeStats

' ── Include / Extend relationships ───────────────────────────────────────
UC01 ..> UC05 : <<extend>>\nopen invite dialog
UC01 ..> UC06 : <<extend>>\nupdate metadata

UC02 ..> UC13 : <<include>>\nverify identity / ban check
UC03 ..> UC13 : <<include>>\nban check

UC07 ..> UC12 : <<extend>>\ntrigger publishMap\nachievement
UC10 ..> UC12 : <<extend>>\ntrigger downloadMap\nWorkshop achievement

UC11 ..> UC12 : <<include>>\nstore stats after\nachievement unlock

@enduml
