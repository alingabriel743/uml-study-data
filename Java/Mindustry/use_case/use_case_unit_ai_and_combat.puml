@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Unit AI & Combat

left to right direction

actor "Game Engine" as engine
actor "AI Unit" as aiUnit
actor "Logic Controller" as logic
actor "Enemy / Target" as enemy

rectangle "Unit AI & Combat" {

    ' --- Core AI Update ---
    usecase "Update Unit State" as UC_Update
    usecase "Use Fallback AI" as UC_Fallback
    usecase "Update Visuals\n(wobble, look-at)" as UC_Visuals
    usecase "Update Movement" as UC_Movement
    usecase "Pathfind to Objective" as UC_Pathfind
    usecase "Circle Attack Maneuver" as UC_Circle

    ' --- Stance & Command ---
    usecase "Update Combat Stance" as UC_Stance
    usecase "Accept Logic Command" as UC_LogicCmd
    usecase "Stop Shooting" as UC_StopShoot

    ' --- Targeting ---
    usecase "Update Targeting" as UC_Targeting
    usecase "Find Main Target" as UC_FindMain
    usecase "Find Weapon Target" as UC_FindWeapon
    usecase "Target Air Units" as UC_Air
    usecase "Target Ground Units" as UC_Ground
    usecase "Prioritize Targets" as UC_Priority
    usecase "Index Entities\nfor Query" as UC_Index
    usecase "Invalidate Stale Target" as UC_Invalidate

    ' --- Shooting ---
    usecase "Shoot Bullet" as UC_Shoot
    usecase "Aim & Intercept Predict" as UC_Aim
    usecase "Auto-Drop Bombs" as UC_Bombs

    ' --- Bullet Types ---
    usecase "Fire Basic Projectile" as UC_Basic
    usecase "Fire Artillery Shell" as UC_Artillery
    usecase "Fire Laser Beam" as UC_Laser
    usecase "Fire Missile" as UC_Missile
    usecase "Fire EMP Burst" as UC_EMP
    usecase "Fire Flak Burst" as UC_Flak
    usecase "Fire Lightning Bolt" as UC_Lightning
    usecase "Fire Continuous Beam" as UC_Continuous

    ' --- Collision ---
    usecase "Detect Entity Collisions" as UC_Collision
    usecase "Handle Bullet Impact" as UC_Impact

}

' --- Game Engine drives the update cycle ---
engine --> UC_Update

' --- AI Unit is the primary actor in combat ---
aiUnit --> UC_Update
aiUnit --> UC_Stance
aiUnit --> UC_StopShoot
aiUnit --> UC_LogicCmd

' --- Logic Controller can override AI ---
logic --> UC_LogicCmd
logic --> UC_StopShoot

' --- Enemy is the target of combat actions ---
enemy --> UC_Priority

' --- Core update includes sub-behaviours ---
UC_Update ..> UC_Fallback    : <<include>>
UC_Update ..> UC_Visuals     : <<include>>
UC_Update ..> UC_Movement    : <<include>>
UC_Update ..> UC_Targeting   : <<include>>

' --- Movement sub-cases ---
UC_Movement <.. UC_Pathfind  : <<extend>>
UC_Movement <.. UC_Circle    : <<extend>>

' --- Targeting sub-cases ---
UC_Targeting ..> UC_FindMain    : <<include>>
UC_Targeting ..> UC_FindWeapon  : <<include>>
UC_Targeting ..> UC_Shoot       : <<include>>
UC_Targeting <.. UC_Invalidate  : <<extend>>

UC_FindMain <.. UC_Air         : <<extend>>
UC_FindMain <.. UC_Ground      : <<extend>>
UC_FindMain  ..> UC_Priority    : <<include>>
UC_FindMain  ..> UC_Index       : <<include>>

UC_FindWeapon <.. UC_Air        : <<extend>>
UC_FindWeapon <.. UC_Ground     : <<extend>>

' --- Shooting sub-cases ---
UC_Shoot ..> UC_Aim             : <<include>>
UC_Shoot <.. UC_Bombs           : <<extend>>
UC_Shoot <.. UC_Basic           : <<extend>>
UC_Shoot <.. UC_Artillery       : <<extend>>
UC_Shoot <.. UC_Laser           : <<extend>>
UC_Shoot <.. UC_Missile         : <<extend>>
UC_Shoot <.. UC_EMP             : <<extend>>
UC_Shoot <.. UC_Flak            : <<extend>>
UC_Shoot <.. UC_Lightning       : <<extend>>
UC_Shoot <.. UC_Continuous      : <<extend>>

' --- Collision detection ---
UC_Basic      ..> UC_Collision  : <<include>>
UC_Artillery  ..> UC_Collision  : <<include>>
UC_Missile    ..> UC_Collision  : <<include>>
UC_Collision  ..> UC_Impact     : <<include>>

@enduml
