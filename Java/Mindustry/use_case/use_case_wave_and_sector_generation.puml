@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7FD5
    FontColor #1A1A2E
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #F0F4F8
    BorderColor #495057
}
skinparam ArrowColor #495057

title Wave Design & Sector Generation

left to right direction

actor "Designer" as designer

actor "Waves\nSystem" as waveSys <<system>>
actor "World /\nSector System" as worldSys <<system>>
actor "Maps\nSystem" as mapsSys <<system>>
actor "Map Patcher\nSystem" as patcherSys <<system>>
actor "Clipboard" as clipboard <<system>>

rectangle "Wave Design & Sector Generation" {

    package "Wave Configuration  (WaveInfoDialog)" as WaveConfig {
        usecase "Add Spawn Group" as UC1
        usecase "Edit Spawn Group Parameters\n(waves, spacing, amount, scaling,\nshields, max)" as UC2
        usecase "Remove Spawn Group" as UC3
        usecase "Copy Spawn Group" as UC4
        usecase "Set Boss / Guardian Status" as UC5
        usecase "Set Team for Spawn Group" as UC6
        usecase "Set Spawn Point for Group" as UC7
        usecase "Filter Groups by Unit Type" as UC8
        usecase "Search Groups by Wave Number" as UC9
        usecase "Sort Spawn Groups" as UC10
        usecase "Copy Wave Config to Clipboard" as UC11
        usecase "Load Wave Config from Clipboard" as UC12
        usecase "Clear All Spawn Groups" as UC13
        usecase "Reset Spawns to Default" as UC14
        usecase "Generate Random Wave Set" as UC15
    }

    package "Wave Preview  (WaveGraph)" as WavePreview {
        usecase "Preview Unit Counts per Wave" as UC16
        usecase "Preview Total Unit Count per Wave" as UC17
        usecase "Preview Total Health per Wave" as UC18
        usecase "Navigate Graph (Pan / Zoom)" as UC19
        usecase "Toggle Unit Type Visibility" as UC20
        usecase "Inspect Wave Column Details" as UC21
    }

    package "Sector Generation  (SectorGenerateDialog)" as SectorGen {
        usecase "Select Planet" as UC22
        usecase "Configure Sector Index & Seed" as UC23
        usecase "Preview Sector Size" as UC24
        usecase "Apply Sector Generation" as UC25
    }

    package "Map Patches  (MapPatchesDialog)" as MapPatches {
        usecase "View Active Map Patches" as UC26
        usecase "Add Patch from Clipboard" as UC27
        usecase "Add Patch from File (.json/.hjson)" as UC28
        usecase "Replace / Update Existing Patch" as UC29
        usecase "Delete Patch" as UC30
        usecase "Copy Patch JSON to Clipboard" as UC31
        usecase "View Patch Warnings & Errors" as UC32
    }

    package "Map Loading  (MapLoadDialog)" as MapLoad {
        usecase "Browse Available Maps" as UC33
        usecase "Select & Load Map into Editor" as UC34
    }

}

' ── Designer initiates all use cases ──────────────────────────────────────────
designer --> UC1
designer --> UC2
designer --> UC3
designer --> UC4
designer --> UC5
designer --> UC6
designer --> UC7
designer --> UC8
designer --> UC9
designer --> UC10
designer --> UC11
designer --> UC12
designer --> UC13
designer --> UC14
designer --> UC15
designer --> UC16
designer --> UC17
designer --> UC18
designer --> UC19
designer --> UC20
designer --> UC21
designer --> UC22
designer --> UC23
designer --> UC24
designer --> UC25
designer --> UC26
designer --> UC27
designer --> UC28
designer --> UC29
designer --> UC30
designer --> UC31
designer --> UC32
designer --> UC33
designer --> UC34

' ── Include / Extend relationships ────────────────────────────────────────────
UC2  ..> UC1  : <<include>>
UC21 <.. UC16 : <<extend>>
UC21 <.. UC17 : <<extend>>
UC21 <.. UC18 : <<extend>>
UC25 ..> UC24 : <<include>>
UC26 <.. UC27 : <<extend>>
UC26 <.. UC28 : <<extend>>
UC26 <.. UC29 : <<extend>>
UC26 <.. UC30 : <<extend>>

' ── System interactions (right-side actors) ───────────────────────────────────
UC15 --> waveSys   : Waves.generate()
UC14 --> waveSys   : JsonIO.copy(waves.get())
UC11 --> clipboard : maps.writeWaves(groups)
UC12 --> clipboard : maps.readWaves(text)
UC31 --> clipboard : writes patch JSON
UC27 --> clipboard : reads patch JSON
UC22 --> worldSys  : content.planets()
UC25 --> worldSys  : world.loadSector(sector, params)
UC26 --> patcherSys : state.patcher.apply(patches)
UC33 --> mapsSys   : maps.all()
UC34 --> mapsSys   : via loader callback

@enduml
