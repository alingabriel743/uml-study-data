@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    DiamondFontColor #212529
}
skinparam swimlane {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    TitleFontColor #212529
    TitleFontSize 12
}
skinparam note {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
    FontColor #0C5460
}

title Connection Factory Management

' ══════════════════════════════════════════════════════
'  SECTION 1 — Factory Initialization
' ══════════════════════════════════════════════════════

|#D0E8FF|Caller|

start

:new DefaultMainConnectionProvidingConnectionFactory(delegate);

|#D4EDDA|DefaultMainConnectionProvidingConnectionFactory|

:Store ConnectionFactory<T> as delegate field;

|#FFF3CD|ConnectionFactory<T> Delegate|

:Invoke delegate.newConnection();
note right
  Eager call in constructor —
  main connection is never lazy
end note
:Return fresh JdbcConnection instance;

|DefaultMainConnectionProvidingConnectionFactory|

:Assign result to mainConnection field\n(pre-created singleton for parallel snapshotting);

' ══════════════════════════════════════════════════════
'  SECTION 2 — Connection Request Dispatch
' ══════════════════════════════════════════════════════

|Caller|

:Request a connection;

if (Which connection type is needed?) then (mainConnection())
  |DefaultMainConnectionProvidingConnectionFactory|
  :Return pre-cached mainConnection field\n(no new object allocation);
  note right
    Singleton — always the
    same object per factory
  end note
  |Caller|
  :Receive singleton main JdbcConnection;
else (newConnection())
  |DefaultMainConnectionProvidingConnectionFactory|
  :Delegate to delegate.newConnection();
  |ConnectionFactory<T> Delegate|
  :Create and return a fresh T instance;
  |DefaultMainConnectionProvidingConnectionFactory|
  :Return new connection to caller;
  |Caller|
  :Receive fresh (non-main) JdbcConnection;
endif

' ══════════════════════════════════════════════════════
'  SECTION 3 — Test Connection Provisioning (SPI Flow)
' ══════════════════════════════════════════════════════

:Call TestConnectionService.forTestDatabase();

|#F8D7DA|TestConnectionService|

if (Was a databaseName argument supplied?) then (no)
  :Default databaseName = "mysql";
endif

:Call forTestDatabase(databaseName);
:ServiceLoader.load(TestConnectionProvider.class)\n— scan META-INF/services on classpath;

if (TestConnectionProvider registered on classpath?) then (yes)
  :providers.findFirst() — select first available provider;

  if (Which provider is active at runtime?) then (MySqlTestConnectionProvider)
    :MySqlTestConnection.forTestDatabase(databaseName);
  else (MariaDbTestConnectionProvider)
    :MariaDbTestConnection.forTestDatabase(databaseName);
  endif

  |#E8D5F5|BinlogTestConnection|

  :Invoke super(config, factory)\n— call BinlogTestConnection constructor;
  :addDefaultSettings(config)\n— apply JDBC defaults;
  :Delegate to JdbcConnection(config, factory, "\`", "\`");
  note right
    BinlogTestConnection is abstract;
    concrete subclass provided
    by each connector module
  end note
  :BinlogTestConnection instance ready;

  |TestConnectionService|

  :Return BinlogTestConnection to caller;

  |Caller|

  :Receive BinlogTestConnection;

else (no — absent provider)
  :orElseThrow() → NoSuchElementException;
  note right
    No TestConnectionProvider found.
    Ensure META-INF/services entry
    exists in connector module.
  end note
  |Caller|
  :Exception propagated — provisioning failed;
  stop
endif

stop

@enduml
