@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleFontSize 13
    TitleFontStyle bold
}
skinparam NoteBackgroundColor #E8F4FD
skinparam NoteBorderColor #5B9BD5

title MariaDB Streaming Pipeline

|Kafka Connect Runtime|
start
:Invoke **MariaDbConnectorTask.preStart**(config);
note right
  Kafka Connect lifecycle entry point
end note

|MariaDbConnectorTask|
:Instantiate **MariaDbConnectorConfig**(config);
:Instantiate **MariaDbTaskContext**(config, connectorConfig);
:Return taskContext as CdcSourceTaskContext;

:start(configuration);
note right
  responseBuffering=adaptive
  fetchSize=10,000
end note
:Create **DefaultMainConnectionProvidingConnectionFactory**
→ new MariaDbConnection(config, MariaDbFieldReader);
:connection = connectionFactory.mainConnection();
:Load previousOffsets via
**MariaDbPartition.Provider** + **MariaDbOffsetContext.Loader**;

:registerServiceProviders(connectorConfig.getServiceRegistry())
→ registers **MariaDbCharsetRegistryServiceProvider**;

|MariaDbCharsetRegistry|
:MariaDbCharsetRegistryServiceProvider.getServiceClass()
→ BinlogCharsetRegistry.class;
:createService() → new **MariaDbCharsetRegistry**();
:loadCharacterSetMappingsFromFileResource();
:Load **charset_mappings.json** via ClassLoader.getResourceAsStream();
:ObjectMapper.readValue(stream, CharacterSetMappings.class);
:loadCharacterSetMappings(characterSets)
→ populate **characterSetNameToCharacterSet** map
  (canonical name + aliases);
:loadCollationMappings(collations)
→ populate **collationIndexToCollationName** (List)
  + **collationIndexToCharacterSet** (TreeMap);

repeat
  if (Charset.forName(encoding) known?) then (yes)
    :Add canonical name + all aliases to map;
  elseif (unknown && mblen == 1?) then (yes)
    :Add raw encoding string to map;
  else (empty / unknown)
    if (mblen > 1?) then (yes)
      :Fallback → UTF-8;
    else (no)
      :Fallback → Cp1252;
    endif
  endif
repeat while (More charset entries?) is (yes)
-> (no);

|MariaDbConnectorTask|
:Create **MariaDbValueConverters**
(decimal / temporal / binary modes + serviceRegistry);
:new **MariaDbDatabaseSchema**(connectorConfig, valueConverters,
  topicNamingStrategy, schemaNameAdjuster, ...);
:BeanRegistry: register config, schema, connection,
  valueConverters, offsets, taskContext;
:SnapshotterService.getSnapshotter() → determine snapshot mode;

:validateBinlogConfiguration(snapshotter, connection)
→ verify binlog enabled;

if (Binlog position available?) then (yes)
  ' continue
else (no)
  :previousOffsets.resetOffset();
endif

if (guardrailCollectionsMax > 0?) then (yes)
  :connection.getAllTableIds();
  :GuardrailValidator.validate(allTableIds);
else (no / skip)
endif

:connection.close() before schema recovery;
:validateSchemaHistory(connectorConfig, connection::validateLogPosition,
  previousOffsets, schema, snapshotter);
:Reconnect: connection.execute('SELECT 1');

if (Reconnect succeeded?) then (yes)
  :connection.setAutoCommit(false);
else (failed)
  :connection.close();
  :connection = connectionFactory.mainConnection();
  :connection.setAutoCommit(false);
endif

fork
  :Build **ChangeEventQueue**<DataChangeEvent>
  (pollInterval, maxBatchSize, maxQueueSize, buffering);
fork again
  :new **MariaDbErrorHandler**(connectorConfig, queue, errorHandler);
fork again
  :new **SignalProcessor**<>(MariaDbConnector.class, ...);
fork again
  :new **EventDispatcher**<>(connectorConfig, topicNamingStrategy,
    schema, queue, dataCollectionFilter, ...);
end fork

:new **BinaryLogClient**(hostname, port, username, password);

if (isSqlQueryIncluded?) then (yes)
  :binaryLogClient.setUseSendAnnotateRowsEvent(true);
  note right: Enables ANNOTATE_ROWS\n(MariaDB-specific SQL capture)
else (no)
endif

:new **MariaDbStreamingChangeEventSourceMetrics**
  (taskContext, queue, metadataProvider, binaryLogClient);
:new **NotificationService**<>(...);
:new **MariaDbChangeEventSourceFactory**
  (config, connectionFactory, errorHandler, dispatcher,
   clock, schema, taskContext, streamingMetrics, queue,
   snapshotterService, binaryLogClient);
:new **ChangeEventSourceCoordinator**<>
  (previousOffsets, errorHandler, MariaDbConnector.class,
   connectorConfig, changeEventSourceFactory, metricsFactory,
   dispatcher, schema, signalProcessor, notificationService,
   snapshotterService);
:coordinator.start(taskContext, queue, metadataProvider);

|MariaDbStreamingChangeEventSource|
:init(offsetContext)
→ set effectiveOffsetContext
  (or MariaDbOffsetContext.initial(config));
:configureReplicaCompatibility
→ binaryLogClient.setMariaDbSlaveCapability(4);

:sslModeFor(secureConnectionMode)
→ map MariaDbSecureConnectionMode → SSLMode;
note right
  DISABLE→DISABLED
  TRUST→REQUIRED
  VERIFY_CA→VERIFY_CA
  VERIFY_FULL→VERIFY_IDENTITY
end note

:Register core event handlers:
  STOP, HEARTBEAT, INCIDENT, ROTATE,
  TABLE_MAP, QUERY, TRANSACTION_PAYLOAD;

if (!skipCreate?) then (yes)
  :Register WRITE_ROWS / EXT_WRITE_ROWS → handleInsert;
endif
if (!skipUpdate?) then (yes)
  :Register UPDATE_ROWS / EXT_UPDATE_ROWS → handleUpdate;
endif
if (!skipDelete?) then (yes)
  :Register DELETE_ROWS / EXT_DELETE_ROWS → handleDelete;
endif

:Register XID → handleTransactionCompletion,
  XA_PREPARE, VIEW_CHANGE;

if (isSqlQueryIncluded?) then (yes)
  :Register ANNOTATE_ROWS → handleRecordingQuery;
else (no)
endif

if (bufferSize == 0?) then (yes — direct)
  :Attach direct event listener to BinaryLogClient;
else (no — buffered)
  :Attach **EventBuffer** listener to BinaryLogClient;
endif

:client.registerLifecycleListener(ReaderThreadLifecycleListener);

if (isGtidModeEnabled && shouldRecoverUsingGtid()?) then (yes)
  :Register MARIADB_GTID → handleGtidEvent;
  note right
    GTID format: {domainId}-{serverId}-{sequence}
    (constructed from GTID_EVENT header + payload)
  end note
  :connection.knownGtidSet() + connection.purgedGtidSet();
  :connection.filterGtidSet(gtidSourceFilter,
    offsetGtidSet, availableGtidSet, purgedGtidSet);
  if (filteredGtidSet not null?) then (yes)
    :client.setGtidSet(filteredGtidSet);
    :initializeGtidSet(filtered) → new MariadbGtidSet(value);
  elseif (purgedGtidSet empty?) then (yes — empty)
    :client.setGtidSet('');
    :initializeGtidSet('');
  else (purged non-empty)
    :client.setGtidSet(purgedGtidSet);
    :initializeGtidSet('');
  endif
else (no — binlog file/position mode)
  :client.setBinlogFilename(filename);
  :client.setBinlogPosition(position);
endif

:BinaryLogClient connects to MariaDB
→ starts reading binlog events;
note right
  Streaming event loop begins
end note

repeat
  :Receive binlog event from BinaryLogClient;
  :handleEvent(partition, offsetContext, context, event);

  if (Event type?) then (MARIADB_GTID)
    :Construct GTID string: {domainId}-{serverId}-{sequence};
    :gtidSet.add(gtid);
    :offsetContext.startGtid();
    if (ignoreDmlByGtidSource?) then (yes)
      :setIgnoreDmlEventByGtidSource;
    endif
    :handleTransactionBegin;
  elseif (ANNOTATE_ROWS) then
    if (Signal table query?) then (yes)
      :Skip signal query;
    else (no)
      :offsetContext.setQuery(query);
    endif
  elseif (QUERY) then
    :handleQueryEvent → DDL processing / schema change;
  elseif (WRITE_ROWS / EXT_WRITE_ROWS) then
    :handleInsert → EventDispatcher → ChangeEventQueue;
  elseif (UPDATE_ROWS / EXT_UPDATE_ROWS) then
    :handleUpdate → EventDispatcher → ChangeEventQueue;
  elseif (DELETE_ROWS / EXT_DELETE_ROWS) then
    :handleDelete → EventDispatcher → ChangeEventQueue;
  else (XID)
    :handleTransactionCompletion (commit);
  endif
repeat while (Connector running?) is (yes)
-> (stop signal received);

|MariaDbConnectorTask|
:doStop(): connection.close();
:beanRegistryJdbcConnection.close();
:schema.close();

stop

@enduml
