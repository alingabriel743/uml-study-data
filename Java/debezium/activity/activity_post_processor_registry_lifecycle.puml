@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Post-Processor Registry Lifecycle

|ServiceRegistry|
start
:Call PostProcessorRegistryServiceProvider\n.createService(Configuration, ServiceRegistry);

|PostProcessorRegistryServiceProvider|
:Read config key CUSTOM_POST_PROCESSORS\n→ comma-separated processor name list;
:Split name list\n→ List<String> processorNames;

note right
  Each name resolves to one
  configured PostProcessor instance
end note

:Begin iterating processorNames;

|PostProcessorRegistryServiceProvider|
fork
  :getPostProcessor(config, processorName₁);
fork again
  :getPostProcessor(config, processorName₂);
fork again
  :... (one branch per name);
end fork

:--- Resolve each PostProcessor ---;

|PostProcessorRegistryServiceProvider|
if (config.subset('post.processors.<name>')\nis non-empty?) then (yes — new convention)
    :Instantiate via\nconfig.getInstance(\n  'post.processors.<name>.type',\n  PostProcessor.class);
    :Call postProcessor.configure(\n  newConventionConfigs);
    :Return PostProcessor instance;
else (no)
    if (config.hasKey('<name>.type') AND\nconfig.subset('<name>') non-empty?) then (yes — old convention)
        :Log WARN: deprecated configuration convention\n("<name>.*" style is deprecated);
        :Instantiate via\nconfig.getInstance(\n  '<name>.type',\n  PostProcessor.class);
        :Call postProcessor.configure(\n  oldConventionConfigs);
        :Return PostProcessor instance;
    else (no — missing config)
        #FFB3B3:Throw DebeziumException:\n"Post processor <name> is missing\n<name>.type and/or <name>.<option>\nconfigurations";
        stop
    endif
endif

:Collect all config-based\nPostProcessor instances → List<PostProcessor>;

note right
  Ordering: config-defined processors
  are added first
end note

:SPI Discovery:\nServiceLoader<PostProcessorFactory>\n.load(PostProcessorFactory.class);

if (PostProcessorFactory found\nvia SPI ServiceLoader?) then (yes)
    :Invoke PostProcessorFactory.get()\n→ List<PostProcessor> externalProcessors;
else (no)
    :externalProcessors =\nCollections.emptyList();
endif

:Merge: postProcessors.addAll(externalProcessors)\n→ combined ordered list\n(config-defined first, SPI-discovered appended);
:Construct new PostProcessorRegistry(processors)\n→ stored as unmodifiable list (@Immutable);

|ServiceRegistry|
:Receive PostProcessorRegistry instance;

note right
  Registry is now registered
  in the ServiceRegistry
end note

:Inject dependencies via @InjectService:\ncall setBeanRegistry(BeanRegistry);
:Inject dependencies:\ncall injectServiceRegistry(ServiceRegistry);

|PostProcessorRegistry|
:start() invoked (Startable lifecycle);

fork
    :For each PostProcessor;
    if (instanceof BeanRegistryAware?) then (yes)
        :injectBeanRegistry(beanRegistry);
    else (no)
        :Skip BeanRegistry injection;
    endif
fork again
    :For each PostProcessor;
    if (instanceof ServiceRegistryAware?) then (yes)
        :injectServiceRegistry(serviceRegistry);
    else (no)
        :Skip ServiceRegistry injection;
    endif
end fork

:PostProcessorRegistry fully initialized\nand ready to serve processors;

note right
  Processor list is immutable after
  construction. Thread-safe @ThreadSafe
end note

|Connector Pipeline|
:CDC event received;

repeat
    :Retrieve processor list via\nPostProcessorRegistry.getProcessors();
    :Iterate over each PostProcessor;
    :Call postProcessor.apply(Object key, Struct value)\nfor each processor in order;
    :Event record enriched / transformed;
repeat while (More CDC events?) is (yes)
-> no;

|PostProcessorRegistry|
:close() invoked (Closeable lifecycle);
:For each PostProcessor:\npostProcessor.close();
:All PostProcessor resources released;

|ServiceRegistry|
:PostProcessorRegistry lifecycle complete;
stop

@enduml
