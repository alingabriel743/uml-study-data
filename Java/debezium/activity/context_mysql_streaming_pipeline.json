    "debezium-connector-binlog/src/test/java/io/debezium/connector/binlog/BinlogReselectColumnsProcessorIT.java",
    "debezium-connector-binlog/src/test/java/io/debezium/connector/binlog/BinlogTableMaintenanceStatementsIT.java"
  ]
}
