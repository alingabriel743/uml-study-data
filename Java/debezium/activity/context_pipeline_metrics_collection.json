{
  "scope": "pipeline_metrics_collection",
  "title": "Pipeline Metrics Collection",
  "diagram_type": "activity",
  "description": "Event counting (create/update/delete/filtered/erroneous), timestamp tracking, connector event handling, and metrics reset",

  "key_actors": [
    "EventDispatcher (caller)",
    "PipelineMetrics<P extends Partition>",
    "CommonEventMeter",
    "ChangeEventQueueMetrics",
    "EventMetadataProvider"
  ],

  "class_hierarchy": [
    "PipelineMetrics extends Metrics",
    "PipelineMetrics implements DataChangeEventListener<P>",
    "PipelineMetrics implements ChangeEventSourceMetricsMXBean",
    "ChangeEventSourceMetricsMXBean extends CommonEventMetricsMXBean, QueueMetricsMXBean, SchemaMetricsMXBean",
    "CommonEventMeter implements CommonEventMetricsMXBean"
  ],

  "state_fields": [
    "CommonEventMeter.totalNumberOfEventsSeen: AtomicLong",
    "CommonEventMeter.totalNumberOfCreateEventsSeen: AtomicLong",
    "CommonEventMeter.totalNumberOfUpdateEventsSeen: AtomicLong",
    "CommonEventMeter.totalNumberOfDeleteEventsSeen: AtomicLong",
    "CommonEventMeter.numberOfEventsFiltered: AtomicLong",
    "CommonEventMeter.numberOfErroneousEvents: AtomicLong",
    "CommonEventMeter.lastEventTimestamp: AtomicLong (init -1)",
    "CommonEventMeter.lastEvent: volatile String"
  ],

  "activity_flows": [
    {
      "trigger": "onEvent(partition, source, offset, key, value, operation)",
      "steps": [
        "PipelineMetrics.onEvent() → commonEventMeter.onEvent(source, offset, key, value, operation)",
        "CommonEventMeter.onEvent() → updateCommonEventMetrics(operation)",
        "updateCommonEventMetrics: totalNumberOfEventsSeen++, lastEventTimestamp = clock.currentTimeInMillis()",
        "if operation == CREATE → totalNumberOfCreateEventsSeen++",
        "if operation == UPDATE → totalNumberOfUpdateEventsSeen++",
        "if operation == DELETE → totalNumberOfDeleteEventsSeen++",
        "if operation == other/null → no per-type counter incremented",
        "CommonEventMeter.onEvent() → lastEvent = metadataProvider.toSummaryString(source, offset, key, value)"
      ]
    },
    {
      "trigger": "onFilteredEvent(partition, event) [no operation]",
      "steps": [
        "PipelineMetrics.onFilteredEvent() → commonEventMeter.onFilteredEvent()",
        "numberOfEventsFiltered++",
        "updateCommonEventMetrics(null): totalNumberOfEventsSeen++, lastEventTimestamp updated, no per-type counter"
      ]
    },
    {
      "trigger": "onFilteredEvent(partition, event, operation) [with operation]",
      "steps": [
        "PipelineMetrics.onFilteredEvent() → commonEventMeter.onFilteredEvent(operation)",
        "numberOfEventsFiltered++",
        "updateCommonEventMetrics(operation): totalNumberOfEventsSeen++, lastEventTimestamp updated, per-type counter incremented"
      ]
    },
    {
      "trigger": "onErroneousEvent(partition, event) [no operation]",
      "steps": [
        "PipelineMetrics.onErroneousEvent() → commonEventMeter.onErroneousEvent()",
        "numberOfErroneousEvents++",
        "updateCommonEventMetrics(null): totalNumberOfEventsSeen++, lastEventTimestamp updated"
      ]
    },
    {
      "trigger": "onErroneousEvent(partition, event, operation) [with operation]",
      "steps": [
        "PipelineMetrics.onErroneousEvent() → commonEventMeter.onErroneousEvent(operation)",
        "numberOfErroneousEvents++",
        "updateCommonEventMetrics(operation): totalNumberOfEventsSeen++, lastEventTimestamp updated, per-type counter incremented"
      ]
    },
    {
      "trigger": "onConnectorEvent(partition, event)",
      "steps": [
        "PipelineMetrics.onConnectorEvent() → no-op in base class (subclasses may override)"
      ]
    },
    {
      "trigger": "reset()",
      "steps": [
        "PipelineMetrics.reset() → commonEventMeter.reset()",
        "totalNumberOfEventsSeen = 0",
        "totalNumberOfCreateEventsSeen = 0",
        "totalNumberOfUpdateEventsSeen = 0",
        "totalNumberOfDeleteEventsSeen = 0",
        "numberOfEventsFiltered = 0",
        "numberOfErroneousEvents = 0",
        "lastEventTimestamp = -1",
        "lastEvent = null"
      ]
    }
  ],

  "read_operations": [
    "getLastEvent() → commonEventMeter.lastEvent",
    "getMilliSecondsSinceLastEvent() → if lastEventTimestamp==-1 return -1, else clock.now() - lastEventTimestamp",
    "getTotalNumberOfEventsSeen() → totalNumberOfEventsSeen.get()",
    "getTotalNumberOfCreateEventsSeen() → totalNumberOfCreateEventsSeen.get()",
    "getTotalNumberOfUpdateEventsSeen() → totalNumberOfUpdateEventsSeen.get()",
    "getTotalNumberOfDeleteEventsSeen() → totalNumberOfDeleteEventsSeen.get()",
    "getNumberOfEventsFiltered() → numberOfEventsFiltered.get()",
    "getNumberOfErroneousEvents() → numberOfErroneousEvents.get()",
    "getQueueTotalCapacity() → changeEventQueueMetrics.totalCapacity()",
    "getQueueRemainingCapacity() → changeEventQueueMetrics.remainingCapacity()",
    "getMaxQueueSizeInBytes() → changeEventQueueMetrics.maxQueueSizeInBytes()",
    "getCurrentQueueSizeInBytes() → changeEventQueueMetrics.currentQueueSizeInBytes()"
  ],

  "key_decisions": [
    "operation switch (CREATE/UPDATE/DELETE/other) in updateCommonEventMetrics determines which per-type counter is incremented",
    "lastEventTimestamp initialized to -1; getMilliSecondsSinceLastEvent() returns -1 if no event seen yet",
    "onConnectorEvent is a no-op at base level — extensible by subclasses",
    "All counters are AtomicLong ensuring thread safety (@ThreadSafe)"
  ],

  "important_notes": "PipelineMetrics is abstract; concrete subclasses provide snapshot/streaming specialization. CommonEventMeter is the internal delegate for all event counting and timestamp tracking. Queue metrics are fully delegated to ChangeEventQueueMetrics without any local caching.",

  "source_files_analyzed": [
    "debezium-connector-common/src/main/java/io/debezium/pipeline/metrics/PipelineMetrics.java",
    "debezium-connector-common/src/main/java/io/debezium/pipeline/meters/CommonEventMeter.java",
    "debezium-connector-common/src/main/java/io/debezium/pipeline/metrics/ChangeEventSourceMetricsMXBean.java",
    "debezium-connector-common/src/main/java/io/debezium/pipeline/source/spi/DataChangeEventListener.java"
  ]
}
