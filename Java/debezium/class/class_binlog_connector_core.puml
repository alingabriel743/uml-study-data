@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Binlog Connector Core (MySQL/MariaDB)

' ─── External base types (simplified) ──────────────────────────────────────
class RelationalBaseSourceConnector <<external>> {
}

class HistorizedRelationalDatabaseConnectorConfig <<external>> {
}

class JdbcConnection <<external>> {
}

abstract class CommonOffsetContext<T> <<external>> {
}

class AbstractPartition <<external>> {
}

interface Partition <<external>> {
}

' ─── io.debezium.connector.binlog ───────────────────────────────────────────
package "io.debezium.connector.binlog" {

    abstract class "BinlogConnector<T>" as BinlogConnector {
        -@Immutable Map<String,String> properties
        --
        +void start(Map<String,String> props)
        +void stop()
        +List<Map<String,String>> taskConfigs(int maxTasks)
        +ExactlyOnceSupport exactlyOnceSupport(Map<String,String> connectorConfig)
        +void validateConnection(Map<String,ConfigValue> configValues, Configuration config)
        +{abstract} BinlogConnectorConnection createConnection(Configuration config, T connectorConfig)
        +{abstract} T createConnectorConfig(Configuration config)
    }
    note right of BinlogConnector
        T extends BinlogConnectorConfig
        Supports exactly-once delivery.
        Only 1 task allowed.
    end note

    abstract class BinlogConnectorConfig {
        #Configuration config
        #SnapshotMode snapshotMode
        #TemporalPrecisionMode temporalPrecisionMode
        #Duration connectionTimeout
        #BigIntUnsignedHandlingMode bigIntUnsignedHandlingMode
        #boolean readOnlyConnection
        #boolean ignoreGtidOnRecovery
        --
        +EnumeratedValue getSnapshotMode()
        +Duration getConnectionTimeout()
        +String getHostName()
        +int getPort()
        +String getUserName()
        +long getServerId()
        +boolean isReadOnlyConnection()
        +boolean shouldIgnoreGtidOnRecovery()
        +boolean useCursorFetch()
        +{static} boolean isBuiltInDatabase(String databaseName)
        ..abstract..
        +{abstract} GtidSetFactory getGtidSetFactory()
        +{abstract} SecureConnectionMode getSslMode()
        +{abstract} Predicate<String> getGtidSourceFilter()
        +{abstract} SnapshotLockingStrategy getSnapshotLockingStrategy()
    }

    enum "BigIntUnsignedHandlingMode" as BigIntUnsignedHandlingMode {
        LONG
        PRECISE
    }

    enum "SnapshotLockingMode" as SnapshotLockingMode {
        MINIMAL
        MINIMAL_PERMISSIVE
        EXTENDED
        NONE
        CUSTOM
        MINIMAL_AT_LEAST_ONCE
    }

    enum "SnapshotMode" as SnapshotMode {
        INITIAL
        INITIAL_ONLY
        SCHEMA_ONLY
        SCHEMA_ONLY_RECOVERY
        NEVER
        WHEN_NEEDED
        CUSTOM
    }

    interface SecureConnectionMode {
        +String getValue()
    }

    interface SnapshotLockingStrategy {
    }

    class "BinlogOffsetContext<T>" as BinlogOffsetContext {
        +{static} String EVENTS_TO_SKIP_OFFSET_KEY = "event"
        +{static} String TIMESTAMP_KEY = "ts_sec"
        +{static} String GTID_SET_KEY = "gtids"
        --
        -Schema sourceInfoSchema
        -TransactionContext transactionContext
        -IncrementalSnapshotContext<TableId> incrementalSnapshotContext
        -String restartGtidSet
        -String currentGtidSet
        -String restartBinlogFilename
        -long restartBinlogPosition
        -long restartEventsToSkip
        -int restartRowsToSkip
        -boolean inTransaction
        -String transactionId
        --
        +Map<String,?> getOffset()
        +void setBinlogStartPoint(String binlogFilename, long positionOfFirstEvent)
        +void setCompletedGtidSet(String gtidSet)
        +void startGtid(String gtid, String gtidSet)
        +void startNextTransaction()
        +void commitTransaction()
        +void setEventPosition(long positionOfCurrentEvent, long eventSizeInBytes)
        +void setInitialSkips(long restartEventsToSkip, int restartRowsToSkip)
        +long eventsToSkipUponRestart()
        +int rowsToSkipUponRestart()
    }
    note right of BinlogOffsetContext
        T extends BinlogSourceInfo
        Tracks both GTID-based and
        file/position-based offsets.
        restartXxx fields hold recovery position.
    end note

    abstract class "BinlogOffsetContext.Loader<O>" as BinlogOffsetContextLoader {
        +{abstract} O load(Map<String,?> offset)
    }

    class BinlogPartition {
        -{static} String SERVER_PARTITION_KEY = "server"
        -String serverName
        --
        +Map<String,String> getSourcePartition()
        +boolean equals(Object o)
        +int hashCode()
    }
    note bottom of BinlogPartition
        Equality based solely on serverName
        (ignores databaseName from AbstractPartition)
    end note
}

' ─── io.debezium.connector.binlog.jdbc ──────────────────────────────────────
package "io.debezium.connector.binlog.jdbc" {

    abstract class BinlogConnectorConnection {
        #ConnectionConfiguration connectionConfig
        #BinlogFieldReader fieldReader
        --
        +String connectionString()
        +boolean userHasPrivileges(String grantName)
        +String earliestBinlogFilename()
        +List<String> availableBinlogFiles()
        +List<String> availableDatabases()
        +boolean isBinlogRowImageFull()
        +boolean isBinlogFormatRow()
        +boolean isBinlogPositionAvailable(BinlogConnectorConfig config, String gtid, String binlogFileName)
        +boolean validateLogPosition(Partition partition, OffsetContext offset, CommonConnectorConfig config)
        ..abstract..
        +{abstract} boolean isGtidModeEnabled()
        +{abstract} GtidSet knownGtidSet()
        +{abstract} GtidSet purgedGtidSet()
        +{abstract} GtidSet subtractGtidSet(GtidSet set1, GtidSet set2)
        +{abstract} GtidSet filterGtidSet(Predicate<String> gtidSourceFilter, String offsetGtids, GtidSet availableServerGtidSet, GtidSet purgedServerGtidSet)
    }
    note right of BinlogConnectorConnection
        Uses SHOW BINARY LOGS,
        SHOW MASTER STATUS, SHOW VARIABLES.
        Validates log position via GTID
        or binlog file/position.
    end note

    class "TablesWithReadableDatabases" as TablesWithReadableDatabases {
        +Set<TableId> tableIds
        +Set<String> readableDatabaseNames
    }

    class "DatabaseLocales" as DatabaseLocales {
        +String charset
        +String collation
        +void appendToDdlStatement(String, StringBuilder)
    }
}

' ─── Inheritance ─────────────────────────────────────────────────────────────
BinlogConnector          --|> RelationalBaseSourceConnector
BinlogConnectorConfig    --|> HistorizedRelationalDatabaseConnectorConfig
BinlogConnectorConnection --|> JdbcConnection
BinlogOffsetContext      --|> CommonOffsetContext
BinlogPartition          --|> AbstractPartition
BinlogPartition          ..|> Partition

' ─── Nesting / containment ───────────────────────────────────────────────────
BinlogConnectorConfig    +-- BigIntUnsignedHandlingMode
BinlogConnectorConfig    +-- SnapshotLockingMode
BinlogConnectorConfig    +-- SnapshotMode
BinlogConnectorConfig    +-- SecureConnectionMode
BinlogConnectorConfig    +-- SnapshotLockingStrategy
BinlogOffsetContext      +-- BinlogOffsetContextLoader
BinlogConnectorConnection +-- TablesWithReadableDatabases
BinlogConnectorConnection +-- DatabaseLocales

' ─── Key associations ────────────────────────────────────────────────────────
BinlogConnector          ..> BinlogConnectorConnection   : creates via\ncreateConnection()
BinlogConnector          ..> BinlogConnectorConfig       : creates via\ncreateConnectorConfig()

BinlogConnectorConnection *-- "1" ConnectionConfiguration : connectionConfig
BinlogConnectorConnection *-- "1" BinlogFieldReader       : fieldReader

BinlogOffsetContext      *-- "1" TransactionContext               : transactionContext
BinlogOffsetContext      *-- "1" "IncrementalSnapshotContext<TableId>" : incrementalSnapshotContext

BinlogConnectorConnection ..> BinlogConnectorConfig  : depends on\n(validateLogPosition,\nisBinlogPositionAvailable)
BinlogConnectorConnection ..> BinlogOffsetContext     : reads offset\n(gtidSet, binlogFilename)

@enduml
