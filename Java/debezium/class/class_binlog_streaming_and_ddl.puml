@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Binlog Streaming & DDL Parsing

' ─────────────────────────────────────────────
' External / framework stubs
' ─────────────────────────────────────────────
package "io.debezium.pipeline (framework)" {
    interface StreamingChangeEventSource<P, O> {
        +execute(ChangeEventSourceContext, P, O): void
    }
    class EventDispatcher<P, TableId> {
    }
}

package "io.debezium.relational (framework)" {
    abstract class HistorizedRelationalDatabaseSchema {
    }
    abstract class AbstractDdlParser {
        +parse(String ddlContent, Tables databaseTables): DdlChanges
    }
    interface DdlParser {
    }
}

package "io.debezium.connector.base (framework)" {
    abstract class CdcSourceTaskContext<C> {
    }
    abstract class CommonOffsetContext<T> {
    }
    abstract class DefaultStreamingChangeEventSourceMetrics<P> {
    }
    interface StreamingChangeEventSourceMetricsMXBean {
    }
}

package "com.github.shyiko.mysql.binlog (external)" {
    class BinaryLogClient <<external>> {
        +registerEventListener(EventListener): void
        +setGtidSet(String): void
        +getBinlogFilename(): String
        +getBinlogPosition(): long
        +getGtidSet(): String
        +connect(long timeout): void
        +disconnect(): void
        +isConnected(): boolean
    }
    interface "BinaryLogClient.EventListener" as BinaryLogClientEventListener <<external>> {
        +onEvent(Event): void
    }
    interface "BinaryLogClient.LifecycleListener" as BinaryLogClientLifecycleListener <<external>> {
        +onConnect(BinaryLogClient): void
        +onCommunicationFailure(BinaryLogClient, Exception): void
        +onEventDeserializationFailure(BinaryLogClient, Exception): void
        +onDisconnect(BinaryLogClient): void
    }
}

' ─────────────────────────────────────────────
' Core binlog connector package
' ─────────────────────────────────────────────
package "io.debezium.connector.binlog" {

    abstract class BinlogStreamingChangeEventSource<P extends BinlogPartition, O extends BinlogOffsetContext> {
        -BinaryLogClient client
        -BinlogStreamingChangeEventSourceMetrics<?, P> metrics
        -BinlogTaskContext<?> taskContext
        -BinlogDatabaseSchema schema
        -BinlogConnectorConfig connectorConfig
        -BinlogConnectorConnection connection
        -EventDispatcher<P, TableId> eventDispatcher
        -EnumMap<EventType, BlockingConsumer<Event>> eventHandlers
        -boolean isGtidModeEnabled
        -AtomicLong totalRecordCounter
        -O effectiveOffsetContext
        +execute(ChangeEventSourceContext, P, O): void
        +onEvent(O, Event): void
        #handleEvent(P, O, ChangeEventSourceContext, Event): void
        #handleQueryEvent(P, O, Event): void
        #handleInsert(P, O, Event): void
        #handleUpdate(P, O, Event): void
        #handleDelete(P, O, Event): void
        #handleRotateLogsEvent(O, Event): void
        #handleTransactionBegin(P, O, Event, Long): void
        #handleTransactionPayload(P, O, ChangeEventSourceContext, Event): void
        #handleServerStop(O, Event): void
        #handleServerHeartbeat(P, O, Event): void
        #handleServerIncident(P, O, Event): void
        #setGtidChanged(String): void
        #isGtidModeEnabled(): boolean
        #shouldRecoverUsingGtid(): boolean
        +configureBinaryLogClient(BinaryLogClient, BinlogConnectorConfig, Map, BinlogConnectorConnection): void
        +getBinaryLogClient(): BinaryLogClient
        +{abstract} handleGtidEvent(P, O, Event, Predicate<String>): void
        +{abstract} getGtidEventType(): EventType
        +{abstract} initializeGtidSet(String): void
        +{abstract} handleRecordingQuery(O, Event): void
        +{abstract} getConnectorClass(): Class
    }

    class "BinlogStreamingChangeEventSource$ReaderThreadLifecycleListener" as ReaderThreadLifecycleListener {
        +onConnect(BinaryLogClient): void
        +onCommunicationFailure(BinaryLogClient, Exception): void
        +onDisconnect(BinaryLogClient): void
    }

    abstract class BinlogDatabaseSchema<P, O, V, D> {
        -DdlParser ddlParser
        -RelationalTableFilters filters
        -Map<Long, TableId> tableIdsByTableNumber
        -Map<Long, TableId> excludeTableIdsByTableNumber
        -BinlogConnectorConfig connectorConfig
        +getDdlParser(): DdlParser
        +applySchemaChange(SchemaChangeEvent): void
        +skipSchemaChangeEvent(SchemaChangeEvent): boolean
        +assignTableNumber(long, TableId): boolean
        +getTableId(long): TableId
        +clearTableMappings(): void
        +{abstract} createDdlParser(BinlogConnectorConfig, V): DdlParser
    }

    class BinlogTaskContext<T extends RelationalDatabaseSchema> {
        +BinlogTaskContext(Configuration, BinlogConnectorConfig)
    }

    class BinlogOffsetContext<T extends BinlogSourceInfo> {
        +setCompletedGtidSet(String): void
        +resetGtidSet(): void
    }
}

' ─────────────────────────────────────────────
' Metrics package
' ─────────────────────────────────────────────
package "io.debezium.connector.binlog.metrics" {

    interface BinlogStreamingChangeEventSourceMetricsMXBean {
        +isConnected(): boolean
        +getBinlogFilename(): String
        +getBinlogPosition(): long
        +getGtidSet(): String
        +getIsGtidModeEnabled(): boolean
    }

    class BinlogStreamingChangeEventSourceMetrics<T extends BinlogDatabaseSchema, P extends Partition> {
        -BinaryLogClient client
        -AtomicLong numberOfCommittedTransactions
        -AtomicLong numberOfRolledBackTransactions
        -AtomicLong numberOfNotWellFormedTransactions
        -AtomicLong numberOfLargeTransactions
        -AtomicBoolean isGtidModeEnabled
        -AtomicLong milliSecondsBehindSource
        -AtomicReference<String> lastTransactionId
        +isConnected(): boolean
        +getBinlogFilename(): String
        +getBinlogPosition(): long
        +getGtidSet(): String
        +getIsGtidModeEnabled(): boolean
    }
}

' ─────────────────────────────────────────────
' DDL Parser package
' ─────────────────────────────────────────────
package "io.debezium.antlr" {
    abstract class AntlrDdlParser<L extends Lexer, P extends Parser> {
        -boolean throwErrorsFromTreeWalk
        -AntlrDdlParserListener antlrDdlParserListener
        -Tables databaseTables
        +parse(String ddlContent, Tables databaseTables): DdlChanges
        +{abstract} parseTree(P parser): ParseTree
        +{abstract} createParseTreeWalkerListener(): AntlrDdlParserListener
        +{abstract} createNewLexerInstance(CharStream): L
        +{abstract} createNewParserInstance(CommonTokenStream): P
    }
}

package "io.debezium.connector.mysql.antlr" {
    class MySqlAntlrDdlParser {
        -ConcurrentMap<String, String> charsetNameForDatabase
        -TableFilter tableFilter
        -BinlogCharsetRegistry charsetRegistry
        -DataTypeResolver dataTypeResolver
        +parseTree(MySqlParser): ParseTree
        +createParseTreeWalkerListener(): AntlrDdlParserListener
        +isGrammarInUpperCase(): boolean
    }
}

package "io.debezium.connector.mariadb.antlr" {
    class MariaDbAntlrDdlParser {
        -ConcurrentHashMap<String, String> charsetNameForDatabase
        -TableFilter tableFilter
        -BinlogCharsetRegistry charsetRegistry
        -DataTypeResolver dataTypeResolver
        +parseTree(MariaDBParser): ParseTree
        +createParseTreeWalkerListener(): AntlrDdlParserListener
    }
}

' ─────────────────────────────────────────────
' Inheritance & Implementation Relationships
' ─────────────────────────────────────────────

' BinlogStreamingChangeEventSource
BinlogStreamingChangeEventSource ..|> StreamingChangeEventSource : implements
BinlogStreamingChangeEventSource --|> BinaryLogClientEventListener : \n<<inner registers>>

' ReaderThreadLifecycleListener (inner class)
ReaderThreadLifecycleListener ..|> BinaryLogClientLifecycleListener : implements
BinlogStreamingChangeEventSource +.. ReaderThreadLifecycleListener : <<inner class>>

' BinlogDatabaseSchema hierarchy
BinlogDatabaseSchema --|> HistorizedRelationalDatabaseSchema : extends
BinlogDatabaseSchema ..|> DdlParser : <<via hierarchy>>

' BinlogTaskContext
BinlogTaskContext --|> CdcSourceTaskContext : extends

' BinlogOffsetContext
BinlogOffsetContext --|> CommonOffsetContext : extends

' Metrics hierarchy
BinlogStreamingChangeEventSourceMetrics --|> DefaultStreamingChangeEventSourceMetrics : extends
BinlogStreamingChangeEventSourceMetrics ..|> BinlogStreamingChangeEventSourceMetricsMXBean : implements
BinlogStreamingChangeEventSourceMetricsMXBean --|> StreamingChangeEventSourceMetricsMXBean : extends

' DDL parser hierarchy
AntlrDdlParser --|> AbstractDdlParser : extends
MySqlAntlrDdlParser --|> AntlrDdlParser : extends
MariaDbAntlrDdlParser --|> AntlrDdlParser : extends

' ─────────────────────────────────────────────
' Composition & Dependency Relationships
' ─────────────────────────────────────────────

' BinlogStreamingChangeEventSource compositions
BinlogStreamingChangeEventSource *-- BinaryLogClient : client
BinlogStreamingChangeEventSource *-- BinlogDatabaseSchema : schema
BinlogStreamingChangeEventSource *-- BinlogTaskContext : taskContext
BinlogStreamingChangeEventSource *-- BinlogStreamingChangeEventSourceMetrics : metrics
BinlogStreamingChangeEventSource o-- EventDispatcher : eventDispatcher
BinlogStreamingChangeEventSource ..> BinlogOffsetContext : manages GTID state

' BinlogDatabaseSchema composes DDL parser
BinlogDatabaseSchema *-- AntlrDdlParser : ddlParser\n<<createDdlParser()>>

' BinlogStreamingChangeEventSourceMetrics uses BinaryLogClient
BinlogStreamingChangeEventSourceMetrics o-- BinaryLogClient : stats source

' BinaryLogClient relationships
BinaryLogClient o-- BinaryLogClientEventListener : registered listeners
BinaryLogClient o-- BinaryLogClientLifecycleListener : lifecycle callbacks

@enduml
