title Change Event Source Framework

package "io.debezium.pipeline.source.spi" {

    interface ChangeEventSource {
        {abstract} ''(marker interface)''
    }

    interface ChangeEventSourceContext {
        +isPaused(): boolean
        +isRunning(): boolean
        +resumeStreaming(): void
        +waitSnapshotCompletion(): void
        +streamingPaused(): void
        +waitStreamingPaused(): void
    }

    interface "SnapshotChangeEventSource<P, O>" as SnapshotChangeEventSource {
        +execute(context: ChangeEventSourceContext,\n  partition: P, previousOffset: O,\n  task: SnapshottingTask): SnapshotResult<O>
        +getSnapshottingTask(partition: P, previousOffset: O): SnapshottingTask
        +getBlockingSnapshottingTask(partition: P,\n  previousOffset: O,\n  config: SnapshotConfiguration): SnapshottingTask
    }

    interface "StreamingChangeEventSource<P, O>" as StreamingChangeEventSource {
        +init(offsetContext: O): void
        +execute(context: ChangeEventSourceContext,\n  partition: P, offsetContext: O): void
        +executeIteration(context: ChangeEventSourceContext,\n  partition: P, offsetContext: O): boolean
        +commitOffset(partition: Map<String,?>,\n  offset: Map<String,?>): void
        +getOffsetContext(): O
        +close(): void
    }

    interface "ChangeEventSourceFactory<P, O>" as ChangeEventSourceFactory {
        +getSnapshotChangeEventSource(\n  listener: SnapshotProgressListener<P>,\n  notificationService: NotificationService<P,O>)\n  : SnapshotChangeEventSource<P,O>
        +getStreamingChangeEventSource()\n  : StreamingChangeEventSource<P,O>
        +getIncrementalSnapshotChangeEventSource(\n  offsetContext: O, ...)\n  : Optional<IncrementalSnapshotChangeEventSource<P,?>>
    }

}

package "io.debezium.pipeline" {

    class "ChangeEventSourceCoordinator<P, O>" as ChangeEventSourceCoordinator <<@ThreadSafe>> {
        #previousOffsets: Offsets<P, O>
        #errorHandler: ErrorHandler
        #changeEventSourceFactory: ChangeEventSourceFactory<P, O>
        #changeEventSourceMetricsFactory: ChangeEventSourceMetricsFactory<P>
        #snapshotterService: SnapshotterService
        #executor: ExecutorService
        -blockingSnapshotExecutor: ExecutorService
        #eventDispatcher: EventDispatcher<P, ?>
        #schema: DatabaseSchema<?>
        #signalProcessor: SignalProcessor<P, O>
        #notificationService: NotificationService<P, O>
        #connectorConfig: CommonConnectorConfig
        -running: volatile boolean
        -paused: volatile boolean
        -streaming: volatile boolean
        #streamingSource: volatile StreamingChangeEventSource<P, O>
        #commitOffsetLock: ReentrantLock
        #snapshotMetrics: SnapshotChangeEventSourceMetrics<P>
        #streamingMetrics: StreamingChangeEventSourceMetrics<P>
        -context: ChangeEventSourceContext
        -snapshotSource: SnapshotChangeEventSource<P, O>
        --
        +start(taskContext: CdcSourceTaskContext,\n  queueMetrics: ChangeEventQueueMetrics,\n  metadataProvider: EventMetadataProvider): void
        #executeChangeEventSources(...): void
        #doSnapshot(snapshotSource: SnapshotChangeEventSource<P,O>,\n  context, partition, offset): SnapshotResult<O>
        #streamEvents(context, partition, offset): void
        #initStreamEvents(partition, offset): void
        +doBlockingSnapshot(partition, offsetContext,\n  config: SnapshotConfiguration): void
        #delayStreamingIfNeeded(context): void
        #executeCatchUpStreaming(...): CatchUpStreamingResult
        +commitOffset(partition: Map<String,?>,\n  offset: Map<String,?>): void
        +stop(): void
        +getSignalProcessor(previousOffset): Optional<SignalProcessor<P,O>>
        +getStreamingSource(): Optional<StreamingChangeEventSource<P,O>>
        +getErrorHandler(): ErrorHandler
        #streamingConnected(status: boolean): void
    }

    class ChangeEventSourceContextImpl {
        -lock: Lock
        -snapshotFinished: Condition
        -streamingPaused: Condition
        -streamingRunning: Condition
        --
        +isPaused(): boolean
        +isRunning(): boolean
        +resumeStreaming(): void
        +waitSnapshotCompletion(): void
        +streamingPaused(): void
        +waitStreamingPaused(): void
    }

    class CatchUpStreamingResult {
        +performedCatchUpStreaming: boolean
        --
        +CatchUpStreamingResult(performed: boolean)
    }

}

' External dependencies (abbreviated)
class EventDispatcher<P> <<external>> {
}
class ErrorHandler <<external>> {
}
class SignalProcessor<P, O> <<external>> {
}
class NotificationService<P, O> <<external>> {
}
class SnapshotterService <<external>> {
}
class DatabaseSchema <<external>> {
}

' Inheritance / implementation
SnapshotChangeEventSource --|> ChangeEventSource : extends
StreamingChangeEventSource --|> ChangeEventSource : extends
StreamingChangeEventSource ..|> Closeable : implements

ChangeEventSourceContextImpl ..|> ChangeEventSourceContext : implements

' Composition inside Coordinator
ChangeEventSourceCoordinator *-- ChangeEventSourceContextImpl : creates at start()
ChangeEventSourceCoordinator *-- CatchUpStreamingResult : inner result
ChangeEventSourceCoordinator *-- ChangeEventSourceFactory : factory
ChangeEventSourceCoordinator *-- SnapshotChangeEventSource : snapshotSource
ChangeEventSourceCoordinator *-- StreamingChangeEventSource : streamingSource

' Dependencies
ChangeEventSourceCoordinator ..> EventDispatcher : uses
ChangeEventSourceCoordinator ..> ErrorHandler : uses
ChangeEventSourceCoordinator ..> SignalProcessor : uses
ChangeEventSourceCoordinator ..> NotificationService : uses
ChangeEventSourceCoordinator ..> SnapshotterService : uses
ChangeEventSourceCoordinator ..> DatabaseSchema : uses

' Factory produces
ChangeEventSourceFactory ..> SnapshotChangeEventSource : creates
ChangeEventSourceFactory ..> StreamingChangeEventSource : creates

' Nesting note
note bottom of ChangeEventSourceContext
  Nested interface inside
  ChangeEventSource — controls
  snapshot/streaming lifecycle
end note

note right of ChangeEventSourceContextImpl
  Uses ReentrantLock + 3 Conditions
  to coordinate snapshot↔streaming
  phase transitions and blocking snapshots
end note

note top of ChangeEventSourceCoordinator
  @ThreadSafe
  Two ExecutorService threads:
  "change-event-source-coordinator"
  and "blocking-snapshot"
end note

@enduml
