@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
}
skinparam enum {
    BackgroundColor #FEF9E7
    BorderColor #D4AC0D
}

title Core Configuration Framework

' ─────────────────────────────────────────────
'  SHARED INTERFACE
' ─────────────────────────────────────────────
interface EnumeratedValue {
    +String getValue()
    +{static} <T> T parse(String value, T[] options)
}

' ─────────────────────────────────────────────
'  io.debezium.config
' ─────────────────────────────────────────────
package "io.debezium.config" {

    interface Configuration <<@Immutable>> {
        +{static} Pattern PASSWORD_PATTERN
        +{static} String CUSTOM_SANITIZE_PATTERN_KEY
        .. Static Factories ..
        +{static} Configuration from(Properties): Configuration
        +{static} Configuration from(Map<String,?>): Configuration
        +{static} Configuration empty(): Configuration
        +{static} Builder create(): Builder
        +{static} Configuration load(File): Configuration
        .. Abstract Contract ..
        +Set<String> keys()
        +String getString(String key)
        .. Default Methods ..
        +String getString(Field field)
        +Integer getInteger(Field field)
        +Boolean getBoolean(Field field)
        +Long getLong(Field field)
        +List<String> getList(Field field)
        +boolean hasKey(String key)
        +boolean validate(Iterable<Field>, ValidationOutput): boolean
        +Configuration subset(String prefix, boolean removePrefix)
        +Configuration merge(Configuration other)
        +Configuration withMaskedPasswords()
        +Map<String, String> asMap()
        +Properties asProperties()
    }

    interface "Configuration.ConfigBuilder<C,B>" as ConfigBuilder {
        +B with(String key, String value)
        +B withDefault(Field field, Object value)
        +C build()
    }

    class "Configuration.Builder" as CfgBuilder {
        -Map<String, String> values
        --
        +Builder with(String key, String value)
        +Configuration build()
    }

    class Field <<@Immutable>> {
        +{static} String INTERNAL_PREFIX
        -String name
        -String displayName
        -String desc
        -Supplier<Object> defaultValueGenerator
        -Validator validator
        -Width width
        -Type type
        -Importance importance
        -List<String> dependents
        -Recommender recommender
        -Set<?> allowedValues
        -GroupEntry group
        -boolean isRequired
        -Set<String> deprecatedAliases
        .. Static Factories ..
        +{static} Field create(String name): Field
        +{static} Field createInternal(String name): Field
        +{static} Field.Set setOf(Field...): Field.Set
        +{static} GroupEntry createGroupEntry(Group): GroupEntry
        .. Accessors ..
        +String name()
        +Type type()
        +Importance importance()
        +Object defaultValue()
        +Validator validator()
        +Recommender recommender()
        +boolean isRequired()
        +GroupEntry group()
        .. Fluent Builder (clone pattern) ..
        +Field withDescription(String): Field
        +Field withType(Type): Field
        +Field withWidth(Width): Field
        +Field withImportance(Importance): Field
        +Field withDefault(String/int/boolean): Field
        +Field withValidation(Validator...): Field
        +Field withRecommender(Recommender): Field
        +Field withEnum(Class<T extends Enum>): Field
        +Field required(): Field
        +Field optional(): Field
        .. Validation ..
        +boolean validate(Configuration, ValidationOutput): boolean
    }

    class "Field.Set" as FieldSet <<@Immutable>> {
        -Map<String, Field> fieldsByName
        --
        +Field fieldWithName(String name)
        +Field[] asArray()
        +Set<String> allFieldNames()
        +Field.Set with(Field... fields)
        +Field.Set filtered(Predicate<Field>)
        +void forEachTopLevelField(Consumer<Field>)
        +void forEachMissingDependent(Consumer<String>)
    }

    interface "Field.ValidationOutput" as ValidationOutput <<@FunctionalInterface>> {
        +void accept(Field field, Object value, String problem)
    }

    interface "Field.Validator" as Validator <<@FunctionalInterface>> {
        +int validate(Configuration config, Field field, ValidationOutput problems)
        +Validator and(Validator other)
    }

    interface "Field.Recommender" as Recommender {
        +List<Object> validValues(Field field, Configuration config)
        +boolean visible(Field field, Configuration config)
    }

    enum "Field.Group" as FieldGroup {
        CONNECTION
        CONNECTION_ADVANCED_SSL
        CONNECTION_ADVANCED
        CONNECTION_ADVANCED_REPLICATION
        CONNECTION_ADVANCED_PUBLICATION
        FILTERS
        CONNECTOR_SNAPSHOT
        CONNECTOR
        CONNECTOR_ADVANCED
        ADVANCED_HEARTBEAT
        ADVANCED
    }

    class "Field.GroupEntry" as GroupEntry {
        -Group group
        -int positionInGroup
        --
        +Group getGroup()
        +int getPositionInGroup()
    }

    abstract class CommonConnectorConfig {
        #final Configuration config
        #final DefaultBeanRegistry beanRegistry
        #final DefaultServiceRegistry serviceRegistry
        -final boolean emitTombstoneOnDelete
        -final int maxQueueSize
        -final int maxBatchSize
        -final long maxQueueSizeInBytes
        -final Duration pollInterval
        -final String logicalName
        #SnapshotQueryMode snapshotQueryMode
        .. Static Field Definitions ..
        +{static} Field TOPIC_PREFIX
        +{static} Field TOMBSTONES_ON_DELETE
        +{static} Field MAX_QUEUE_SIZE
        +{static} Field MAX_BATCH_SIZE
        +{static} Field POLL_INTERVAL_MS
        +{static} Field MAX_QUEUE_SIZE_IN_BYTES
        +{static} Field EVENT_PROCESSING_FAILURE_HANDLING_MODE
        +{static} Field BINARY_HANDLING_MODE
        +{static} Field SCHEMA_NAME_ADJUSTMENT_MODE
        +{static} Field SIGNAL_DATA_COLLECTION
        +{static} String DATABASE_CONFIG_PREFIX
        +{static} String DRIVER_CONFIG_PREFIX
        .. Abstract Methods ..
        +{abstract} String getContextName()
        +{abstract} String getConnectorName()
        +{abstract} EnumeratedValue getSnapshotMode()
        +{abstract} Optional<EnumeratedValue> getSnapshotLockingMode()
        .. Accessors ..
        +BeanRegistry getBeanRegistry()
        +ServiceRegistry getServiceRegistry()
        +boolean isEmitTombstoneOnDelete()
        +int getMaxQueueSize()
        +int getMaxBatchSize()
        +long getMaxQueueSizeInBytes()
        +Duration getPollInterval()
        +String getLogicalName()
        +int getSnapshotFetchSize()
        +int getSnapshotMaxThreads()
        +Duration getHeartbeatInterval()
    }

    enum "CommonConnectorConfig.BinaryHandlingMode" as BinaryHandlingMode {
        BYTES
        BASE64
        BASE64_URL_SAFE
        HEX
    }

    enum "CommonConnectorConfig.EventProcessingFailureHandlingMode" as EventProcessingFailureHandlingMode {
        SKIP
        WARN
        FAIL
        IGNORE
    }

    enum "CommonConnectorConfig.SchemaNameAdjustmentMode" as SchemaNameAdjustmentMode {
        NONE
        AVRO
        AVRO_UNICODE
    }

    enum "CommonConnectorConfig.SnapshotQueryMode" as SnapshotQueryMode {
        SELECT_ALL
        CUSTOM
    }

    enum "CommonConnectorConfig.GuardrailCollectionsLimitAction" as GuardrailCollectionsLimitAction {
        WARN
        FAIL
    }
}

' ─────────────────────────────────────────────
'  io.debezium.jdbc
' ─────────────────────────────────────────────
package "io.debezium.jdbc" {

    interface JdbcConfiguration <<@Immutable>> {
        +{static} Field DATABASE
        +{static} Field USER
        +{static} Field PASSWORD
        +{static} Field HOSTNAME
        +{static} Field PORT
        +{static} Field ON_CONNECT_STATEMENTS
        +{static} Field CONNECTION_TIMEOUT_MS
        +{static} Field QUERY_TIMEOUT_MS
        +{static} Set<String> ALL_KNOWN_FIELDS
        .. Adapter Factory ..
        +{static} JdbcConfiguration adapt(Configuration config)
        +{static} JdbcConfiguration empty()
    }
}

' ─────────────────────────────────────────────
'  io.debezium.relational
' ─────────────────────────────────────────────
package "io.debezium.relational" {

    abstract class RelationalDatabaseConnectorConfig {
        -final RelationalTableFilters tableFilters
        -final ColumnNameFilter columnFilter
        -final TemporalPrecisionMode temporalPrecisionMode
        -final KeyMapper keyMapper
        -final JdbcConfiguration jdbcConfig
        -final String heartbeatActionQuery
        .. Static Field Definitions ..
        +{static} Field HOSTNAME
        +{static} Field PORT
        +{static} Field USER
        +{static} Field PASSWORD
        +{static} Field DATABASE_NAME
        +{static} Field TABLE_INCLUDE_LIST
        +{static} Field TABLE_EXCLUDE_LIST
        +{static} Field COLUMN_INCLUDE_LIST
        +{static} Field COLUMN_EXCLUDE_LIST
        +{static} Field DECIMAL_HANDLING_MODE
        +{static} Field SCHEMA_INCLUDE_LIST
        +{static} Field SCHEMA_EXCLUDE_LIST
        +{static} Field MSG_KEY_COLUMNS
        +{static} Field SNAPSHOT_LOCK_TIMEOUT_MS
        .. Accessors ..
        +RelationalTableFilters getTableFilters()
        +DecimalMode getDecimalMode()
        +TemporalPrecisionMode getTemporalPrecisionMode()
        +KeyMapper getKeyMapper()
    }

    enum "RelationalDatabaseConnectorConfig.DecimalHandlingMode" as DecimalHandlingMode {
        PRECISE
        STRING
        DOUBLE
        --
        +DecimalMode asDecimalMode()
    }
}

' ─────────────────────────────────────────────
'  RELATIONSHIPS
' ─────────────────────────────────────────────

' Configuration inner types (nesting)
Configuration +-- ConfigBuilder
Configuration +-- CfgBuilder
CfgBuilder ..|> ConfigBuilder : implements

' Field inner types (nesting)
Field +-- FieldSet
Field +-- ValidationOutput
Field +-- Validator
Field +-- Recommender
Field +-- FieldGroup
Field +-- GroupEntry

' Field references its inner types as fields
Field --> Validator : -validator
Field --> Recommender : -recommender
Field --> GroupEntry : -group
GroupEntry --> FieldGroup : -group

' Field.Set composes Fields
FieldSet *-- Field : fieldsByName >

' JdbcConfiguration extends Configuration (adapter pattern)
JdbcConfiguration --|> Configuration

' CommonConnectorConfig composes Configuration
CommonConnectorConfig *-- Configuration : #config

' CommonConnectorConfig inner enums
CommonConnectorConfig +-- BinaryHandlingMode
CommonConnectorConfig +-- EventProcessingFailureHandlingMode
CommonConnectorConfig +-- SchemaNameAdjustmentMode
CommonConnectorConfig +-- SnapshotQueryMode
CommonConnectorConfig +-- GuardrailCollectionsLimitAction

' All config enums implement EnumeratedValue
BinaryHandlingMode ..|> EnumeratedValue
EventProcessingFailureHandlingMode ..|> EnumeratedValue
SchemaNameAdjustmentMode ..|> EnumeratedValue
SnapshotQueryMode ..|> EnumeratedValue
GuardrailCollectionsLimitAction ..|> EnumeratedValue
DecimalHandlingMode ..|> EnumeratedValue

' RelationalDatabaseConnectorConfig hierarchy
RelationalDatabaseConnectorConfig --|> CommonConnectorConfig
RelationalDatabaseConnectorConfig +-- DecimalHandlingMode

' RelationalDatabaseConnectorConfig composes JdbcConfiguration
RelationalDatabaseConnectorConfig *-- JdbcConfiguration : -jdbcConfig\n(via adapt + subset)

' Field validator uses ValidationOutput (functional param)
Validator ..> ValidationOutput : uses >
Recommender ..> Configuration : uses >

' Configuration uses Field for default methods
Configuration ..> Field : uses >

note top of Field
  <b>Immutable value object</b>
  All with*() methods return a
  new Field copy (fluent clone pattern).
  Fields are registered to Kafka ConfigDef
  via Field.group() static helper.
end note

note bottom of JdbcConfiguration
  <b>Adapter Pattern</b>
  adapt() wraps any Configuration as
  JdbcConfiguration without copying data.
  RelationalDatabaseConnectorConfig
  extracts JDBC config via:
  config.subset("database.", true)
end note

note right of CommonConnectorConfig
  Constructor reads all config values
  into typed <b>final</b> fields upfront.
  getConfig() is @Deprecated — use
  typed accessor methods instead.
end note

@enduml
