@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #856404
}
skinparam interface {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
}

title DDL Parser Framework

' ─────────────────────────────────────────────────────────────────
' Package: io.debezium.relational.ddl
' ─────────────────────────────────────────────────────────────────
package "io.debezium.relational.ddl" {

    interface DdlParser {
        +parse(ddlContent: String, databaseTables: Tables): DdlChanges
        +setCurrentDatabase(databaseName: String): void
        +setCurrentSchema(schemaName: String): void
        +systemVariables(): SystemVariables
    }

    abstract class AbstractDdlParser {
        #skipViews: boolean
        #skipComments: boolean
        #ddlChanges: DdlChanges
        #systemVariables: SystemVariables
        -currentSchema: String
        +setCurrentSchema(schema: String): void
        +setCurrentDatabase(db: String): void
        +systemVariables(): SystemVariables
        +currentSchema(): String
        +getAndResetDdlChanges(): DdlChanges
        +signalChangeEvent(event: Event): void
        +signalCreateTable(id: TableId, stmt: String): void
        +signalAlterTable(id: TableId, prev: TableId, stmt: String): void
        +signalDropTable(id: TableId, stmt: String): void
        +signalTruncateTable(id: TableId, stmt: String): void
        +signalCreateDatabase(name: String, stmt: String): void
        +signalAlterDatabase(name: String, prev: String, stmt: String): void
        +signalDropDatabase(name: String, stmt: String): void
        +signalSetVariable(name: String, value: String, order: int, stmt: String): void
        #{abstract} createNewSystemVariablesInstance(): SystemVariables
        +{static} withoutQuotes(s: String): String
        +{static} isQuoted(s: String): boolean
    }

    interface DdlParserListener <<FunctionalInterface>> {
        +handle(event: Event): void
    }

    class DdlChanges <<@NotThreadSafe>> {
        #events: List<Event>
        -databaseNames: Set<String>
        +handle(event: Event): void
        +reset(): DdlChanges
        +getEventsByDatabase(consumer: DatabaseEventConsumer): void
        +getDatabase(event: Event): String
        +isEmpty(): boolean
        +anyMatch(filters: RelationalTableFilters): boolean
    }

    interface "DdlChanges.DatabaseEventConsumer" as DatabaseEventConsumer {
        +consume(databaseName: String, events: List<Event>): void
    }

    ' ── DdlParserListener nested event hierarchy ──
    enum "EventType" as EventType {
        CREATE_TABLE
        ALTER_TABLE
        DROP_TABLE
        TRUNCATE_TABLE
        CREATE_INDEX
        DROP_INDEX
        CREATE_DATABASE
        ALTER_DATABASE
        DROP_DATABASE
        USE_DATABASE
        SET_VARIABLE
    }

    abstract class "Event" as ListenerEvent {
        -statement: String
        -type: EventType
        +type(): EventType
        +statement(): String
    }

    abstract class TableEvent {
        -tableId: TableId
        -isView: boolean
        +tableId(): TableId
        +isView(): boolean
    }

    class TableCreatedEvent
    class TableAlteredEvent {
        -previousTableId: TableId
    }
    class TableDroppedEvent
    class TableTruncatedEvent

    abstract class TableIndexEvent {
        -tableId: TableId
        -indexName: String
        +tableId(): TableId
        +indexName(): String
    }

    class TableIndexCreatedEvent
    class TableIndexDroppedEvent

    abstract class DatabaseEvent {
        -databaseName: String
        +databaseName(): String
    }

    class DatabaseCreatedEvent
    class DatabaseAlteredEvent {
        -previousDatabaseName: String
    }
    class DatabaseDroppedEvent
    class DatabaseSwitchedEvent

    class SetVariableEvent {
        -variableName: String
        -value: String
        -databaseName: String
        -order: int
        +variableName(): String
        +variableValue(): String
        +order(): int
        +databaseName(): Optional<String>
    }
}

' ─────────────────────────────────────────────────────────────────
' Package: io.debezium.relational.history
' ─────────────────────────────────────────────────────────────────
package "io.debezium.relational.history" {

    interface SchemaHistory {
        +configure(config: Configuration, comparator: HistoryRecordComparator,\n  listener: SchemaHistoryListener, preferDdl: boolean): void
        +start(): void
        +stop(): void
        +record(source: Map, position: Map, db: String, ddl: String): void
        +record(source: Map, position: Map, db: String, schema: String,\n  ddl: String, changes: TableChanges, timestamp: Instant): void
        +recover(offsets: Offsets, tables: Tables, parser: DdlParser): void
        +exists(): boolean
        +storageExists(): boolean
        +initializeStorage(): void
    }

    abstract class AbstractSchemaHistory {
        #config: Configuration
        -comparator: HistoryRecordComparator
        -skipUnparseableDDL: boolean
        -ddlFilter: Predicate<String>
        -listener: SchemaHistoryListener
        -preferDdl: boolean
        -tableChangesSerializer: TableChangesSerializer<Array>
        +configure(...): void
        +start(): void
        +stop(): void
        +record(...): void
        +recover(...): void
        #{abstract} storeRecord(record: HistoryRecord): void
        #{abstract} recoverRecords(consumer: Consumer<HistoryRecord>): void
        +initializeStorage(): void
    }

    class MemorySchemaHistory {
        #storeRecord(record: HistoryRecord): void
        #recoverRecords(consumer: Consumer<HistoryRecord>): void
    }

    interface SchemaHistoryListener {
        +started(): void
        +stopped(): void
        +recoveryStarted(): void
        +recoveryStopped(): void
        +onChangeFromHistory(record: HistoryRecord): void
        +onChangeApplied(record: HistoryRecord): void
    }

    class TableChanges {
        -changes: List<TableChange>
        +create(table: Table): TableChanges
        +alter(table: Table): TableChanges
        +alter(change: TableChange): TableChanges
        +rename(table: Table, previousId: TableId): TableChanges
        +drop(tableId: TableId): TableChanges
        +iterator(): Iterator<TableChange>
    }

    class "TableChanges.TableChange" as TableChange {
        -type: TableChangeType
        -table: Table
        -id: TableId
        -previousId: TableId
        +getType(): TableChangeType
        +getTable(): Table
        +getId(): TableId
        +getPreviousId(): TableId
    }

    enum "TableChanges.TableChangeType" as TableChangeType {
        CREATE
        ALTER
        DROP
    }

    interface "TableChanges.TableChangesSerializer<T>" as TableChangesSerializer {
        +serialize(changes: TableChanges): T
        +deserialize(data: T, useCatalogBeforeSchema: boolean): TableChanges
    }
}

' ─────────────────────────────────────────────────────────────────
' Package: io.debezium.relational
' ─────────────────────────────────────────────────────────────────
package "io.debezium.relational" {

    abstract class HistorizedRelationalDatabaseSchema {
        #schemaHistory: SchemaHistory
        -recoveredTables: boolean
        +recover(offsets: Offsets): void
        +close(): void
        +initializeStorage(): void
        #{abstract} getDdlParser(): DdlParser
        +record(event: SchemaChangeEvent, changes: TableChanges): void
        +getSchemaHistory(): SchemaHistory
        +isHistorized(): boolean
        +storeOnlyCapturedTables(): boolean
        +storeOnlyCapturedDatabases(): boolean
        +skipUnparseableDdlStatements(): boolean
    }
}

' ─────────────────────────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────────────────────────

' DDL Parser hierarchy
AbstractDdlParser ..|> DdlParser : implements
AbstractDdlParser *-- DdlChanges : ddlChanges (composed)

' DdlChanges implements DdlParserListener
DdlChanges ..|> DdlParserListener : implements
DdlChanges +-- DatabaseEventConsumer : nested interface

' Schema History hierarchy
AbstractSchemaHistory ..|> SchemaHistory : implements
MemorySchemaHistory --|> AbstractSchemaHistory : extends

' HistorizedRelationalDatabaseSchema
HistorizedRelationalDatabaseSchema *-- SchemaHistory : schemaHistory
HistorizedRelationalDatabaseSchema ..> DdlParser : <<uses>>\ngetDdlParser()
HistorizedRelationalDatabaseSchema ..> TableChanges : <<uses>>\nrecord()

' AbstractSchemaHistory uses
AbstractSchemaHistory o-- SchemaHistoryListener : listener
AbstractSchemaHistory ..> DdlParser : <<uses>>\nduring recovery
AbstractSchemaHistory ..> TableChanges : <<uses>>\nrecover / record

' TableChanges inner types
TableChanges *-- TableChange : contains
TableChange -- TableChangeType : type
TableChanges +-- TableChangesSerializer : nested interface

' DdlParserListener Event hierarchy (nested in DdlParserListener)
ListenerEvent -- EventType : type
TableEvent --|> ListenerEvent : extends
TableCreatedEvent --|> TableEvent : extends
TableAlteredEvent --|> TableEvent : extends
TableDroppedEvent --|> TableEvent : extends
TableTruncatedEvent --|> TableEvent : extends

TableIndexEvent --|> ListenerEvent : extends
TableIndexCreatedEvent --|> TableIndexEvent : extends
TableIndexDroppedEvent --|> TableIndexEvent : extends

DatabaseEvent --|> ListenerEvent : extends
DatabaseCreatedEvent --|> DatabaseEvent : extends
DatabaseAlteredEvent --|> DatabaseEvent : extends
DatabaseDroppedEvent --|> DatabaseEvent : extends
DatabaseSwitchedEvent --|> DatabaseEvent : extends

SetVariableEvent --|> ListenerEvent : extends

note top of AbstractDdlParser
  signalXxx() methods delegate to
  signalChangeEvent(event) which calls
  ddlChanges.handle(event)
end note

note right of AbstractSchemaHistory
  Recovery strategy (per record):
  • preferDdl=false AND tableChanges present
    → apply via schema.overwriteTable/removeTable
  • otherwise → ddlParser.setCurrentDatabase/Schema
    + ddlParser.parse(ddl, schema)
  skipUnparseableDDL controls error tolerance
end note

note bottom of DdlChanges
  Accumulates DdlParserListener.Event objects
  grouped by database name.
  Also returned as result of DdlParser.parse().
end note

@enduml
