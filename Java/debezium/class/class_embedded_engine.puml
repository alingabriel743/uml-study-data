@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EBF5FB
    BorderColor #2E86C1
}
skinparam enum {
    BackgroundColor #FEF9E7
    BorderColor #D4AC0D
}

title Embedded Engine

' ─────────────────────────────────────────────
' Package: io.debezium.engine  (API module)
' ─────────────────────────────────────────────
package "io.debezium.engine" {

    interface "DebeziumEngine<R>" as DebeziumEngine {
        +{static} create(format): Builder<ChangeEvent<T,T>>
        +{static} create(keyFormat, valueFormat): Builder<ChangeEvent<K,V>>
        +{static} create(KeyValueHeaderChangeEventFormat): Builder<ChangeEvent<K,V>>
        +getSignaler(): Signaler
    }

    interface "DebeziumEngine.Builder<R>" as DEBuilder {
        +notifying(Consumer<R>): Builder<R>
        +notifying(ChangeConsumer<R>): Builder<R>
        +using(Properties): Builder<R>
        +using(ClassLoader): Builder<R>
        +using(Clock): Builder<R>
        +using(CompletionCallback): Builder<R>
        +using(ConnectorCallback): Builder<R>
        +using(OffsetCommitPolicy): Builder<R>
        +build(): DebeziumEngine<R>
    }

    interface "DebeziumEngine.BuilderFactory" as DEBuilderFactory {
        +builder(ChangeEventFormat): Builder
        +builder(KeyValueChangeEventFormat): Builder
        +builder(KeyValueHeaderChangeEventFormat): Builder
    }

    interface "DebeziumEngine.ChangeConsumer<R>" as DEChangeConsumer {
        +handleBatch(List<R>, RecordCommitter<R>): void
        +supportsTombstoneEvents(): boolean
    }

    interface "DebeziumEngine.RecordCommitter<R>" as DERecordCommitter {
        +markProcessed(R record): void
        +markBatchFinished(): void
        +buildOffsets(): Offsets
    }

    interface "DebeziumEngine.CompletionCallback" as DECompletionCallback {
        +handle(boolean success, String message, Throwable error): void
    }

    interface "DebeziumEngine.ConnectorCallback" as DEConnectorCallback {
        +connectorStarted(): void
        +connectorStopped(): void
        +taskStarted(): void
        +taskStopped(): void
        +pollingStarted(): void
        +pollingStopped(): void
    }

    interface "DebeziumEngine.Offsets" as DEOffsets {
        +set(String key, Object value): void
    }

    interface "DebeziumEngine.Signaler" as DESignaler {
        +signal(Signal signal): void
    }
}

' ─────────────────────────────────────────────
' Package: io.debezium.embedded
' ─────────────────────────────────────────────
package "io.debezium.embedded" {

    interface EmbeddedEngineConfig {
        +{static} ENGINE_NAME: Field
        +{static} CONNECTOR_CLASS: Field
        +{static} OFFSET_STORAGE: Field
        +{static} OFFSET_FLUSH_INTERVAL_MS: Field
        +{static} OFFSET_COMMIT_TIMEOUT_MS: Field
        +{static} OFFSET_COMMIT_POLICY: Field
        +{static} TRANSFORMS: Field
        +{static} PREDICATES: Field
        +{static} ERRORS_RETRY_DELAY_INITIAL_MS: Field
        +{static} ERRORS_MAX_RETRIES: Field
        +{static} WAIT_FOR_COMPLETION_BEFORE_INTERRUPT_MS: Field
    }

    class DebeziumEngineCommon {
    }

    class "DebeziumEngineCommon.SourceRecordOffsets" as SourceRecordOffsets {
        -offsets: HashMap<String, Object>
        +set(String key, Object value): void
        +getOffsets(): HashMap<String, Object>
    }

    class "EmbeddedEngineChangeEvent<K,V,H>" as EmbeddedEngineChangeEvent {
        -key: K
        -value: V
        -headers: List<Header<H>>
        -sourceRecord: SourceRecord
        +key(): K
        +value(): V
        +headers(): List<Header<H>>
        +record(): V
        +destination(): String
        +partition(): Integer
        +sourceRecord(): SourceRecord
    }

    class "EmbeddedEngineHeader<T>" as EmbeddedEngineHeader {
        -key: String
        -value: T
        +getKey(): String
        +getValue(): T
    }

    class EmbeddedEngineSignaler {
        -channels: List<SignalChannelWriter>
        +signal(DebeziumEngine.Signal signal): void
    }
}

' ─────────────────────────────────────────────
' Package: io.debezium.embedded.async
' ─────────────────────────────────────────────
package "io.debezium.embedded.async" {

    interface AsyncEngineConfig {
        +{static} RECORD_PROCESSING_THREADS: Field
        +{static} RECORD_PROCESSING_ORDER: Field
        +{static} RECORD_PROCESSING_SHUTDOWN_TIMEOUT_MS: Field
        +{static} RECORD_PROCESSING_WITH_SERIAL_CONSUMER: Field
        +{static} TASK_MANAGEMENT_TIMEOUT_MS: Field
        +{static} AVAILABLE_CORES: int
    }

    class "AsyncEmbeddedEngine<R>" as AsyncEmbeddedEngine {
        -config: Configuration
        -consumer: Consumer<R>
        -handler: DebeziumEngine.ChangeConsumer<R>
        -completionCallback: CompletionCallback
        -connectorCallback: Optional<ConnectorCallback>
        -connector: EngineSourceConnector
        -tasks: List<EngineSourceTask>
        -taskService: ExecutorService
        -recordService: ExecutorService
        -state: AtomicReference<State>
        -transformations: Transformations
        -offsetCommitPolicy: OffsetCommitPolicy
        -signaler: Signaler
        +run(): void
        +close(): void
        +getSignaler(): Signaler
        +tasks(): List<EngineSourceTask>
        -initializeConnector(): Map<String,String>
        -createSourceTasks(): void
        -startSourceTasks(): void
        -runTasksPolling(): void
        -createRecordProcessor(String, EngineSourceTask): RecordProcessor
        -stopConnector(): void
        -finishShutDown(Throwable): void
    }

    enum "AsyncEmbeddedEngine.State" as EngineState {
        CREATING
        INITIALIZING
        CREATING_TASKS
        STARTING_TASKS
        POLLING_TASKS
        STOPPING
        STOPPED
    }

    class "AsyncEmbeddedEngine.AsyncEngineBuilder<R>" as AsyncEngineBuilder {
        -config: Properties
        -consumer: Consumer<R>
        -handler: DebeziumEngine.ChangeConsumer<?>
        -classLoader: ClassLoader
        -clock: Clock
        -completionCallback: CompletionCallback
        -connectorCallback: ConnectorCallback
        -offsetCommitPolicy: OffsetCommitPolicy
        -recordConverter: Function<SourceRecord,R>
        +notifying(Consumer<R>): Builder<R>
        +notifying(ChangeConsumer<R>): Builder<R>
        +using(Properties): Builder<R>
        +using(ClassLoader): Builder<R>
        +using(Clock): Builder<R>
        +using(CompletionCallback): Builder<R>
        +using(ConnectorCallback): Builder<R>
        +using(OffsetCommitPolicy): Builder<R>
        +build(): DebeziumEngine<R>
    }

    class ConvertingAsyncEngineBuilderFactory {
        +builder(ChangeEventFormat): Builder<RecordChangeEvent<T>>
        +builder(KeyValueChangeEventFormat): Builder<ChangeEvent<S,T>>
        +builder(KeyValueHeaderChangeEventFormat): Builder<ChangeEvent<S,T>>
    }

    interface "RecordProcessor<R>" as RecordProcessor {
        +initialize(ExecutorService, Transformations): void
        +processRecords(List<SourceRecord>): void
    }

    note bottom of RecordProcessor
      Implementations:
      • ParallelSmtBatchProcessor
      • ParallelSmtAndConvertBatchProcessor
      • ParallelSmtConsumerProcessor
      • ParallelSmtAndConvertConsumerProcessor
      • ParallelSmtAsyncConsumerProcessor
      • ParallelSmtAndConvertAsyncConsumerProcessor
    end note
}

' ─────────────────────────────────────────────
' Package: io.debezium.engine.source
' ─────────────────────────────────────────────
package "io.debezium.engine.source" {

    class EngineSourceConnector {
        ' Wraps SourceConnector (Kafka Connect)
    }

    class EngineSourceTask {
        ' Wraps SourceTask and EngineSourceTaskContext
    }

    class EngineSourceConnectorContext {
        ' Holds AsyncEmbeddedEngine ref, OffsetBackingStore,
        ' OffsetStorageReader, OffsetStorageWriter
    }

    class EngineSourceTaskContext {
        ' Holds taskConfig, OffsetStorageReader,
        ' OffsetStorageWriter, OffsetCommitPolicy, Clock, Transformations
    }
}

' ─────────────────────────────────────────────
' Inner-type containment
' ─────────────────────────────────────────────
DebeziumEngine +-- DEBuilder
DebeziumEngine +-- DEBuilderFactory
DebeziumEngine +-- DEChangeConsumer
DebeziumEngine +-- DERecordCommitter
DebeziumEngine +-- DECompletionCallback
DebeziumEngine +-- DEConnectorCallback
DebeziumEngine +-- DEOffsets
DebeziumEngine +-- DESignaler

DebeziumEngineCommon +-- SourceRecordOffsets
AsyncEmbeddedEngine +-- AsyncEngineBuilder
AsyncEmbeddedEngine +-- EngineState

' ─────────────────────────────────────────────
' Inheritance & Implementation
' ─────────────────────────────────────────────
AsyncEngineConfig --|> EmbeddedEngineConfig
AsyncEmbeddedEngine ..|> DebeziumEngine
AsyncEmbeddedEngine ..|> AsyncEngineConfig

AsyncEngineBuilder ..|> DEBuilder
ConvertingAsyncEngineBuilderFactory ..|> DEBuilderFactory

EmbeddedEngineSignaler ..|> DESignaler
SourceRecordOffsets ..|> DEOffsets

' ─────────────────────────────────────────────
' Composition & Dependencies
' ─────────────────────────────────────────────
AsyncEmbeddedEngine *-- EngineSourceConnector : connector
AsyncEmbeddedEngine *-- EngineSourceTask : tasks 0..*
AsyncEmbeddedEngine ..> RecordProcessor : <<creates>>

ConvertingAsyncEngineBuilderFactory ..> AsyncEngineBuilder : <<creates>>
AsyncEngineBuilder ..> AsyncEmbeddedEngine : <<builds>>

EngineSourceConnector *-- EngineSourceConnectorContext : context
EngineSourceTask *-- EngineSourceTaskContext : context

note top of ConvertingAsyncEngineBuilderFactory
  Default BuilderFactory loaded via
  ServiceLoader by DebeziumEngine.create()
end note

note right of EngineState
  Lifecycle order:
  CREATING → INITIALIZING
  → CREATING_TASKS → STARTING_TASKS
  → POLLING_TASKS → STOPPING → STOPPED
end note

@enduml
