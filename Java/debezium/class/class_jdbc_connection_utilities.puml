title JDBC Connection & Utilities\n<size:11><i>io.debezium.jdbc</i></size>

' ─────────────────────────────────────────────
' External / framework types (lightweight stubs)
' ─────────────────────────────────────────────
interface AutoCloseable <<java.lang>> #ECECEC
interface "java.sql.ResultSet" as JavaResultSet <<java.sql>> #ECECEC
interface Configuration <<io.debezium.config>> #ECECEC
interface ValueConverterProvider <<io.debezium.relational>> #ECECEC
class RuntimeException <<java.lang>> #ECECEC

' ─────────────────────────────────────────────
' Inner Functional Interfaces of JdbcConnection
' ─────────────────────────────────────────────
package "JdbcConnection — Inner Interfaces" as JdbcInner {

    interface "ConnectionFactory" as InnerConnFactory <<inner, @FunctionalInterface>> {
        +connect(config: JdbcConfiguration): java.sql.Connection
    }

    interface "Operations" as Operations <<inner, @FunctionalInterface>> {
        +apply(stmt: Statement): void
    }

    interface "ResultSetConsumer" as ResultSetConsumer <<inner>> {
        +accept(rs: ResultSet): void
    }

    interface "ResultSetMapper<T>" as ResultSetMapper <<inner>> {
        +apply(rs: ResultSet): T
    }

    interface "BlockingResultSetConsumer" as BlockingResultSetConsumer <<inner>> {
        +accept(rs: ResultSet): void throws InterruptedException
    }

    interface "StatementPreparer" as StatementPreparer <<inner>> {
        +accept(stmt: PreparedStatement): void
    }

    interface "StatementFactory" as StatementFactory <<inner, @FunctionalInterface>> {
        +createStatement(conn: Connection): Statement
    }

    interface "CallPreparer" as CallPreparer <<inner, @FunctionalInterface>> {
        +accept(stmt: CallableStatement): void
    }

    class "ConnectionFactoryDecorator" as ConnFactoryDecorator <<private inner>> {
        -defaultConnectionFactory: ConnectionFactory
        -customConnectionFactory: ConnectionFactory
        +connect(config: JdbcConfiguration): java.sql.Connection
    }
}

' ─────────────────────────────────────────────
' Core JDBC classes
' ─────────────────────────────────────────────
package "io.debezium.jdbc" {

    class JdbcConnection <<@NotThreadSafe>> {
        -config: JdbcConfiguration
        -factory: ConnectionFactory
        -initialOps: Operations
        -conn: volatile Connection
        -queryTimeout: int
        -openingQuoteCharacter: String
        -closingQuoteCharacter: String
        -statementCache: Map<String, PreparedStatement>
        ==
        +{static} patternBasedFactory(urlPattern: String, variables: Field...): ConnectionFactory
        ..Connection Management..
        +connect(): JdbcConnection
        +reconnect(): void
        +setAutoCommit(autoCommit: boolean): JdbcConnection
        +commit(): JdbcConnection
        +close(): void
        ..Query Execution..
        +execute(sqlStatements: String...): JdbcConnection
        +query(query: String, consumer: ResultSetConsumer): JdbcConnection
        +query(query: String, factory: StatementFactory, consumer: ResultSetConsumer): JdbcConnection
        +queryAndMap(query: String, mapper: ResultSetMapper<T>): T
        +prepareQuery(sql: String, preparer: StatementPreparer, consumer: ResultSetConsumer): JdbcConnection
        +prepareQueryAndMap(sql: String, preparer: StatementPreparer, mapper: ResultSetMapper<T>): T
        +prepareUpdate(stmt: String, preparer: StatementPreparer): JdbcConnection
        +call(sql: String, preparer: CallPreparer, consumer: ResultSetConsumer): JdbcConnection
        ..Schema Introspection..
        +readSchema(tables: Tables, catalog: String, schema: String, ...): void
        +readAllTableNames(tableTypes: String[]): Set<TableId>
        +readPrimaryKeyNames(metadata: DatabaseMetaData, id: TableId): List<String>
        +readAllCatalogNames(): Set<String>
        ..Utilities..
        +getColumnValue(rs: ResultSet, columnIndex: int, col: Column, table: Table): Object
        +buildSelectWithRowLimits(tableId: TableId, limit: int, ...): String
        +quoteIdentifier(name: String): String
        +quotedTableIdString(tableId: TableId): String
        +getCurrentTimestamp(): Optional<Instant>
    }

    interface JdbcConfiguration <<@Immutable>> {
        +{static} DATABASE: Field
        +{static} USER: Field
        +{static} PASSWORD: Field
        +{static} HOSTNAME: Field
        +{static} PORT: Field
        +{static} ON_CONNECT_STATEMENTS: Field
        +{static} CONNECTION_TIMEOUT_MS: Field
        +{static} QUERY_TIMEOUT_MS: Field
        ..Accessors..
        +getHostname(): String
        +getPort(): int
        +getDatabase(): String
        +getUser(): String
        +getPassword(): String
        +getConnectionTimeout(): Duration
        +getQueryTimeout(): Duration
        ..Factory..
        +{static} adapt(config: Configuration): JdbcConfiguration
        +{static} create(): Builder
        +{static} copy(config: Configuration): Builder
    }

    interface "JdbcConfiguration.Builder" as JdbcConfigBuilder {
        +withUser(user: String): Builder
        +withPassword(password: String): Builder
        +withHostname(hostname: String): Builder
        +withDatabase(database: String): Builder
        +withPort(port: int): Builder
        +withConnectionTimeoutMs(ms: long): Builder
        +withQueryTimeoutMs(ms: long): Builder
        +withConnectionFactoryClass(cls: Class<?>): Builder
    }

    class CancellableResultSet <<Decorator>> {
        -resultSet: ResultSet
        ==
        +{static} from(resultSet: ResultSet): CancellableResultSet
        +close(): void
        +next(): boolean
        +wasNull(): boolean
        .. all other ResultSet methods: pure delegation ..
    }

    interface "ConnectionFactory<T extends JdbcConnection>" as OuterConnFactory <<@FunctionalInterface>> {
        +newConnection(): T
    }

    interface "MainConnectionProvidingConnectionFactory<T>" as MainConnFactory {
        +mainConnection(): T
        +newConnection(): T
    }

    class "DefaultMainConnectionProvidingConnectionFactory<T>" as DefaultMainConnFactory {
        -delegate: ConnectionFactory<T>
        -mainConnection: T
        ==
        +DefaultMainConnectionProvidingConnectionFactory(delegate: ConnectionFactory<T>)
        +mainConnection(): T
        +newConnection(): T
    }

    interface ResultReceiver {
        +deliver(o: Object): void
        +hasReceived(): boolean
        +get(): Object
        +{static} create(): ResultReceiver
    }

    interface ValueConversionCallback <<@FunctionalInterface>> {
        +convert(receiver: ResultReceiver): void
    }

    class JdbcValueConverters <<@Immutable>> {
        #defaultOffset: ZoneOffset
        #temporalPrecisionMode: TemporalPrecisionMode
        #decimalMode: DecimalMode
        #bigIntUnsignedMode: BigIntUnsignedMode
        #binaryMode: BinaryHandlingMode
        #adjuster: TemporalAdjuster
        ==
        +JdbcValueConverters()
        +JdbcValueConverters(decimalMode: DecimalMode, precisionMode: TemporalPrecisionMode, ...)
        +schemaBuilder(column: Column): SchemaBuilder
        +converter(column: Column, fieldDefn: Field): ValueConverter
    }

    enum TemporalPrecisionMode {
        ADAPTIVE
        ADAPTIVE_TIME_MICROSECONDS
        ISOSTRING
        CONNECT
        MICROSECONDS
        NANOSECONDS
        ==
        -value: String
        +getValue(): String
        +getDateBuilder(): SchemaBuilder
        +getTimeBuilder(precision: int): SchemaBuilder
        +getTimestampBuilder(precision: int): SchemaBuilder
        +{static} parse(value: String): TemporalPrecisionMode
    }

    class JdbcConnectionException <<final>> {
        -sqlState: String
        -errorCode: int
        ==
        +JdbcConnectionException(e: SQLException)
        +JdbcConnectionException(message: String, e: SQLException)
        +getSqlState(): String
        +getErrorCode(): int
    }
}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' JdbcConnection core
JdbcConnection ..|> AutoCloseable
JdbcConnection *-- JdbcConfiguration        : config
JdbcConnection *-- InnerConnFactory         : factory

' JdbcConnection inner types
JdbcConnection +-- InnerConnFactory
JdbcConnection +-- Operations
JdbcConnection +-- ResultSetConsumer
JdbcConnection +-- ResultSetMapper
JdbcConnection +-- BlockingResultSetConsumer
JdbcConnection +-- StatementPreparer
JdbcConnection +-- StatementFactory
JdbcConnection +-- CallPreparer
JdbcConnection +-- ConnFactoryDecorator
ConnFactoryDecorator ..|> InnerConnFactory  : implements

' JdbcConnection uses inner interfaces (key query methods)
JdbcConnection ..> ResultSetConsumer        : query()
JdbcConnection ..> ResultSetMapper          : queryAndMap()
JdbcConnection ..> StatementPreparer        : prepareQuery()
JdbcConnection ..> StatementFactory         : query() overloads
JdbcConnection ..> CancellableResultSet     : snapshot reads

' CancellableResultSet decorator
CancellableResultSet ..|> JavaResultSet
CancellableResultSet *-- JavaResultSet      : delegate

' JdbcConfiguration
JdbcConfiguration --|> Configuration
JdbcConfiguration +-- JdbcConfigBuilder

' Outer ConnectionFactory hierarchy (builds JdbcConnection subclasses)
MainConnFactory     --|> OuterConnFactory
DefaultMainConnFactory ..|> MainConnFactory
DefaultMainConnFactory *-- OuterConnFactory : delegate

' JdbcValueConverters
JdbcValueConverters ..|> ValueConverterProvider
JdbcValueConverters *-- TemporalPrecisionMode : temporalPrecisionMode

' ValueConversionCallback <-> ResultReceiver
ValueConversionCallback ..> ResultReceiver  : uses

' JdbcConnectionException
JdbcConnectionException --|> RuntimeException

@enduml
