@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EBF5FB
    BorderColor #2E86C1
}
skinparam enum {
    BackgroundColor #FEF9E7
    BorderColor #F39C12
}

title JDBC Sink Connector

'=== EXTERNAL BASE TYPES ===
abstract class SinkConnector <<external>> #D5DBDB
abstract class SinkTask <<external>> #D5DBDB
interface ChangeEventSink <<external>> #D5DBDB
interface SinkConnectorConfig <<external>> #D5DBDB
interface ConfigDescriptor <<external>> #D5DBDB
interface CollectionNamingStrategy <<external>> #D5DBDB

'=== PACKAGE: io.debezium.connector.jdbc ===
package "io.debezium.connector.jdbc" {

    class JdbcSinkConnector {
        -properties: Map<String, String>
        +version(): String
        +start(props: Map<String,String>): void
        +taskClass(): Class<? extends Task>
        +taskConfigs(maxTasks: int): List<Map<String,String>>
        +stop(): void
        +config(): ConfigDef
        +getConfigFields(): Field.Set
    }

    class JdbcSinkConnectorConfig {
        -config: Configuration
        -insertMode: InsertMode
        -deleteEnabled: boolean
        -truncateEnabled: boolean
        -schemaEvolutionMode: SchemaEvolutionMode
        -quoteIdentifiers: boolean
        -primaryKeyMode: PrimaryKeyMode
        -primaryKeyFields: Set<String>
        -batchSize: int
        -useReductionBuffer: boolean
        -flushMaxRetries: int
        -flushRetryDelayMs: long
        -collectionNamingStrategy: CollectionNamingStrategy
        -columnNamingStrategy: ColumnNamingStrategy
        --
        +JdbcSinkConnectorConfig(props: Map<String,String>)
        +validate(): void
        +getHibernateConfiguration(): Configuration
        +getInsertMode(): InsertMode
        +isDeleteEnabled(): boolean
        +getSchemaEvolutionMode(): SchemaEvolutionMode
        +isQuoteIdentifiers(): boolean
        +getPrimaryKeyMode(): PrimaryKeyMode
        +getPrimaryKeyFields(): Set<String>
        +getBatchSize(): int
        +isUseReductionBuffer(): boolean
        +getCollectionNamingStrategy(): CollectionNamingStrategy
        +getColumnNamingStrategy(): ColumnNamingStrategy
        +fieldFilter(): FieldNameFilter
    }

    enum InsertMode {
        INSERT
        UPSERT
        UPDATE
    }

    enum SchemaEvolutionMode {
        NONE
        BASIC
    }

    class JdbcSinkConnectorTask {
        -sessionFactory: SessionFactory
        -changeEventSink: JdbcChangeEventSink
        -state: AtomicReference<State>
        -stateLock: ReentrantLock
        -assignedPartitions: Set<TopicPartition>
        --
        +version(): String
        +start(props: Map<String,String>): void
        +put(records: Collection<SinkRecord>): void
        +open(partitions: Collection<TopicPartition>): void
        +close(partitions: Collection<TopicPartition>): void
        +preCommit(...): Map<TopicPartition, OffsetAndMetadata>
        +stop(): void
        #createRecordWriter(...): RecordWriter
    }

    enum State {
        RUNNING
        STOPPED
    }

    class JdbcChangeEventSink {
        -config: JdbcSinkConnectorConfig
        -dialect: DatabaseDialect
        -session: StatelessSession
        -recordWriter: RecordWriter
        -connectorContext: ConnectorContext
        --
        +JdbcChangeEventSink(config, session, dialect, recordWriter, connectorContext)
        +execute(records: Collection<SinkRecord>): void
        +close(): void
    }

    interface RecordWriter {
        +write(tableDescriptor: TableDescriptor, records: List<JdbcSinkRecord>): void
        +checkAndApplyTableChangesIfNeeded(collectionId: CollectionId, record: JdbcSinkRecord): TableDescriptor
        +writeTruncate(collectionId: CollectionId): void
        +executeWithRetries(description: String, callable: Callable<T>): T
    }

    class DefaultRecordWriter {
        -session: SharedSessionContract
        -queryBinderResolver: QueryBinderResolver
        -config: JdbcSinkConnectorConfig
        -dialect: DatabaseDialect
        -flushMaxRetries: int
        -flushRetryDelay: Duration
        --
        +write(tableDescriptor, records): void
        +writeTruncate(collectionId): void
        +checkAndApplyTableChangesIfNeeded(collectionId, record): TableDescriptor
        +executeWithRetries(description, callable): T
        #getSqlStatementInfo(table, records): SqlStatementInfo
        #bindValues(record, queryBinder): void
    }

    class UnnestRecordWriter {
        +write(tableDescriptor, records): void
        #writeUnnestBatch(statement, records): void
    }

    interface Buffer {
        +add(record: JdbcSinkRecord): List<JdbcSinkRecord>
        +flush(): List<JdbcSinkRecord>
        +isEmpty(): boolean
        +getTableDescriptor(): TableDescriptor
        +remove(record: JdbcSinkRecord): void
    }

    class RecordBuffer {
        -connectorConfig: JdbcSinkConnectorConfig
        -keySchema: Schema
        -valueSchema: Schema
        -records: ArrayList<JdbcSinkRecord>
    }

    class ReducedRecordBuffer {
        -connectorConfig: JdbcSinkConnectorConfig
        -keySchema: Schema
        -valueSchema: Schema
        .. note ..
        Deduplicates by PK before flush
    }

    class QueryBinderResolver {
        +resolve(prepareStatement: PreparedStatement): QueryBinder
    }

}

'=== PACKAGE: io.debezium.connector.jdbc.dialect ===
package "io.debezium.connector.jdbc.dialect" {

    interface DatabaseDialect {
        +getVersion(): DatabaseVersion
        +tableExists(connection, tableId): boolean
        +readTable(connection, collectionId): TableDescriptor
        +resolveMissingFields(record, table): Set<String>
        +getCreateTableStatement(record, collectionId): String
        +getAlterTableStatement(table, record, missingFields): String
        +getInsertStatement(table, record): String
        +getBatchInsertStatement(table, records): Optional<String>
        +getUpsertStatement(table, record): String
        +getBatchUpsertStatement(table, records): Optional<String>
        +getUpdateStatement(table, record): String
        +getDeleteStatement(table, record): String
        +getTruncateStatement(collectionId): String
        +bindValue(field, startIndex, value): List<ValueBindDescriptor>
        +getCommunicationExceptions(): Set<Class<? extends Exception>>
    }

    interface DatabaseDialectProvider {
        +supports(dialect: Dialect): boolean
        +name(): Class<?>
        +instantiate(config: JdbcSinkConnectorConfig, sessionFactory: SessionFactory): DatabaseDialect
    }

    class DatabaseDialectResolver {
        +{static} resolve(config: JdbcSinkConnectorConfig, sessionFactory: SessionFactory): DatabaseDialect
        .. Uses ServiceLoader<DatabaseDialectProvider> ..
    }

    class GeneralDatabaseDialect {
        .. Base implementation for all dialects ..
        .. Uses Hibernate SessionFactory internals ..
    }

    class PostgresDatabaseDialect {
        +getBatchInsertStatement(table, records): Optional<String>
        +getBatchUpsertStatement(table, records): Optional<String>
        .. UNNEST batch optimization ..
    }

    class MySqlDatabaseDialect {
        .. MySQL-specific SQL generation ..
    }

    class MariaDbDatabaseDialect {
        .. MariaDB-specific overrides ..
    }

    class OracleDatabaseDialect {
        .. Oracle-specific SQL generation ..
    }

    class Db2DatabaseDialect {
        .. IBM DB2 SQL generation ..
    }

    class Db2iDatabaseDialect {
        .. IBM DB2i SQL generation ..
    }

}

'=== PACKAGE: io.debezium.connector.jdbc.naming ===
package "io.debezium.connector.jdbc.naming" {

    interface ColumnNamingStrategy {
        +resolveColumnName(fieldName: String): String
        +configure(properties: Map<String,String>): void
    }

    class DefaultColumnNamingStrategy {
        .. Returns field name as-is ..
    }

    class TemporaryBackwardCompatibleCollectionNamingStrategyProxy {
        .. Wraps CollectionNamingStrategy ..
        .. Backward compatibility for table-format config ..
    }

}

'=== INHERITANCE & IMPLEMENTATION RELATIONSHIPS ===

' JdbcSinkConnector hierarchy
JdbcSinkConnector --|> SinkConnector
JdbcSinkConnector ..|> ConfigDescriptor

' JdbcSinkConnectorConfig
JdbcSinkConnectorConfig ..|> SinkConnectorConfig
JdbcSinkConnectorConfig +-- InsertMode
JdbcSinkConnectorConfig +-- SchemaEvolutionMode

' JdbcSinkConnectorTask hierarchy
JdbcSinkConnectorTask --|> SinkTask
JdbcSinkConnectorTask +-- State

' JdbcChangeEventSink
JdbcChangeEventSink ..|> ChangeEventSink

' RecordWriter hierarchy
DefaultRecordWriter ..|> RecordWriter
UnnestRecordWriter --|> DefaultRecordWriter

' Dialect hierarchy
GeneralDatabaseDialect ..|> DatabaseDialect
PostgresDatabaseDialect --|> GeneralDatabaseDialect
MySqlDatabaseDialect --|> GeneralDatabaseDialect
MariaDbDatabaseDialect --|> MySqlDatabaseDialect
OracleDatabaseDialect --|> GeneralDatabaseDialect
Db2DatabaseDialect --|> GeneralDatabaseDialect
Db2iDatabaseDialect --|> GeneralDatabaseDialect

' Buffer hierarchy
RecordBuffer ..|> Buffer
ReducedRecordBuffer ..|> Buffer

' Naming strategy hierarchy
DefaultColumnNamingStrategy ..|> ColumnNamingStrategy
TemporaryBackwardCompatibleCollectionNamingStrategyProxy ..|> CollectionNamingStrategy

'=== COMPOSITION & DEPENDENCY RELATIONSHIPS ===

' Connector → Task
JdbcSinkConnector ..> JdbcSinkConnectorTask : <<creates via taskClass()>>

' Task composition
JdbcSinkConnectorTask *-- JdbcChangeEventSink : composes
JdbcSinkConnectorTask ..> JdbcSinkConnectorConfig : uses
JdbcSinkConnectorTask ..> DatabaseDialectResolver : resolves dialect
JdbcSinkConnectorTask ..> RecordWriter : creates (Default or Unnest)

' Sink config composition
JdbcSinkConnectorConfig *-- CollectionNamingStrategy : collectionNamingStrategy
JdbcSinkConnectorConfig *-- ColumnNamingStrategy : columnNamingStrategy

' Change event sink dependencies
JdbcChangeEventSink *-- "1" JdbcSinkConnectorConfig : config
JdbcChangeEventSink *-- "1" DatabaseDialect : dialect
JdbcChangeEventSink *-- "1" RecordWriter : recordWriter
JdbcChangeEventSink o-- Buffer : upsert/deleteBufferByTable

' DefaultRecordWriter dependencies
DefaultRecordWriter *-- "1" JdbcSinkConnectorConfig : config
DefaultRecordWriter *-- "1" DatabaseDialect : dialect
DefaultRecordWriter *-- "1" QueryBinderResolver : queryBinderResolver

' Buffer dependencies
RecordBuffer *-- JdbcSinkConnectorConfig : connectorConfig
ReducedRecordBuffer *-- JdbcSinkConnectorConfig : connectorConfig

' Dialect resolver
DatabaseDialectResolver ..> DatabaseDialectProvider : <<ServiceLoader>>
DatabaseDialectResolver ..> DatabaseDialect : <<resolves>>

' Naming strategy proxy
TemporaryBackwardCompatibleCollectionNamingStrategyProxy ..> CollectionNamingStrategy : wraps

@enduml
