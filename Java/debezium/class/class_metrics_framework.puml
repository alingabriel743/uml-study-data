@startuml class_metrics_framework

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
    FontColor #1A5276
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Metrics Framework

' ─────────────────────────────────────────
'  External / SPI stubs (minimal, no body)
' ─────────────────────────────────────────
package "io.debezium.pipeline.source.spi" <<external>> {
    interface DataChangeEventListener<P> {
        + onEvent(partition, source, offset, key, value, operation): void
        + onFilteredEvent(partition, event): void
        + onErroneousEvent(partition, event): void
        + onConnectorEvent(partition, event): void
    }
    interface SnapshotProgressListener<P> {
        + snapshotStarted(partition): void
        + snapshotCompleted(partition): void
        + snapshotAborted(partition): void
    }
    interface StreamingProgressListener {
        + pause(): void
        + resume(): void
    }
}

package "io.debezium.pipeline.meters" <<external>> {
    class CommonEventMeter {
        + onEvent(...): void
        + onFilteredEvent(...): void
        + onErroneousEvent(...): void
        + reset(): void
    }
    class SnapshotMeter {
        + snapshotStarted(partition): void
        + snapshotCompleted(partition): void
        + reset(): void
    }
    class StreamingMeter {
        + getCapturedTables(): String[]
        + onEvent(...): void
        + reset(): void
    }
    class ConnectionMeter {
        + isConnected(): boolean
        + connected(connected: boolean): void
        + reset(): void
    }
    class ActivityMonitoringMeter {
        + onEvent(...): void
        + reset(): void
    }
}

package "io.debezium.connector.base" <<external>> {
    class ChangeEventQueueMetrics {
        + totalCapacity(): int
        + remainingCapacity(): int
        + maxQueueSizeInBytes(): long
        + currentQueueSizeInBytes(): long
    }
}

' ─────────────────────────────────────────
'  MXBean Traits
' ─────────────────────────────────────────
package "io.debezium.pipeline.metrics.traits" {
    interface CommonEventMetricsMXBean {
        + getLastEvent(): String
        + getMilliSecondsSinceLastEvent(): long
        + getTotalNumberOfEventsSeen(): long
        + getTotalNumberOfCreateEventsSeen(): long
        + getTotalNumberOfUpdateEventsSeen(): long
        + getTotalNumberOfDeleteEventsSeen(): long
        + getNumberOfEventsFiltered(): long
        + getNumberOfErroneousEvents(): long
    }
    interface QueueMetricsMXBean {
        + getQueueTotalCapacity(): int
        + getQueueRemainingCapacity(): int
        + getMaxQueueSizeInBytes(): long
        + getCurrentQueueSizeInBytes(): long
    }
    interface SchemaMetricsMXBean {
        + getCapturedTables(): String[]
    }
    interface SnapshotMetricsMXBean {
        + getTotalTableCount(): int
        + getRemainingTableCount(): int
        + getSnapshotRunning(): boolean
        + getSnapshotCompleted(): boolean
        + getSnapshotAborted(): boolean
        + getSnapshotDurationInSeconds(): long
        + getRowsScanned(): Map<String,Long>
        + getChunkId(): String
        + getTableChunkCounts(): Map<String,Long>
    }
    interface StreamingMetricsMXBean {
        + getSourceEventPosition(): Map<String,String>
        + getMilliSecondsBehindSource(): long
        + getNumberOfCommittedTransactions(): long
        + getLastTransactionId(): String
        + resetLagBehindSource(): void
        + getNumberOfUnchangedEventsSkipped(): long
    }
    interface ConnectionMetricsMXBean {
        + isConnected(): boolean
    }
}

' Trait inheritance
SnapshotMetricsMXBean --|> SchemaMetricsMXBean
StreamingMetricsMXBean --|> SchemaMetricsMXBean

' ─────────────────────────────────────────
'  Core Metrics interfaces
' ─────────────────────────────────────────
package "io.debezium.pipeline.metrics" {

    interface ChangeEventSourceMetricsMXBean {
        + reset(): void
    }
    interface SnapshotChangeEventSourceMetricsMXBean
    interface StreamingChangeEventSourceMetricsMXBean

    ' MXBean hierarchy
    ChangeEventSourceMetricsMXBean --|> CommonEventMetricsMXBean
    ChangeEventSourceMetricsMXBean --|> QueueMetricsMXBean
    ChangeEventSourceMetricsMXBean --|> SchemaMetricsMXBean
    SnapshotChangeEventSourceMetricsMXBean --|> ChangeEventSourceMetricsMXBean
    SnapshotChangeEventSourceMetricsMXBean --|> SnapshotMetricsMXBean
    StreamingChangeEventSourceMetricsMXBean --|> ChangeEventSourceMetricsMXBean
    StreamingChangeEventSourceMetricsMXBean --|> ConnectionMetricsMXBean
    StreamingChangeEventSourceMetricsMXBean --|> StreamingMetricsMXBean

    interface ChangeEventSourceMetrics<P extends Partition> {
        + register(): void
        + unregister(): void
    }
    interface SnapshotChangeEventSourceMetrics<P extends Partition>
    interface StreamingChangeEventSourceMetrics<P extends Partition>

    ' Interface hierarchy
    ChangeEventSourceMetrics --|> DataChangeEventListener
    SnapshotChangeEventSourceMetrics --|> ChangeEventSourceMetrics
    SnapshotChangeEventSourceMetrics --|> SnapshotProgressListener
    StreamingChangeEventSourceMetrics --|> ChangeEventSourceMetrics
    StreamingChangeEventSourceMetrics --|> StreamingProgressListener

    interface CapturedTablesSupplier <<FunctionalInterface>> {
        + getCapturedTables(): Collection<? extends DataCollectionId>
    }
}

' ─────────────────────────────────────────
'  SPI
' ─────────────────────────────────────────
package "io.debezium.pipeline.metrics.spi" {
    interface ChangeEventSourceMetricsFactory<P extends Partition> {
        + getSnapshotMetrics(taskContext, changeEventQueueMetrics, eventMetadataProvider): SnapshotChangeEventSourceMetrics<P>
        + getStreamingMetrics(taskContext, changeEventQueueMetrics, eventMetadataProvider, capturedTablesSupplier): StreamingChangeEventSourceMetrics<P>
        + connectionMetricHandledByCoordinator(): boolean
    }
}

ChangeEventSourceMetricsFactory ..> SnapshotChangeEventSourceMetrics : <<creates>>
ChangeEventSourceMetricsFactory ..> StreamingChangeEventSourceMetrics : <<creates>>
ChangeEventSourceMetricsFactory ..> CapturedTablesSupplier : <<uses>>

' ─────────────────────────────────────────
'  Base class
' ─────────────────────────────────────────
package "io.debezium.metrics" {
    abstract class Metrics <<@ThreadSafe>> {
        - name: ObjectName
        - registered: boolean <<volatile>>
        --
        + register(): void <<synchronized>>
        + unregister(): void <<synchronized>>
        # metricName(connectorType, connectorName, contextName, customTags): ObjectName
        # metricName(connectorType, tags): ObjectName
    }
}

note bottom of Metrics
  JMX name pattern:
  debezium.<type>:type=connector-metrics,
  context=<snapshot|streaming>,server=<name>
end note

' ─────────────────────────────────────────
'  Pipeline abstract class
' ─────────────────────────────────────────
package "io.debezium.pipeline.metrics" {
    abstract class PipelineMetrics<P extends Partition> <<@ThreadSafe>> {
        # metadataProvider: EventMetadataProvider
        # taskContext: CdcSourceTaskContext
        - changeEventQueueMetrics: ChangeEventQueueMetrics
        - commonEventMeter: CommonEventMeter
        --
        + onEvent(partition, source, offset, key, value, operation): void
        + onFilteredEvent(partition, event): void
        + onErroneousEvent(partition, event): void
        + onConnectorEvent(partition, event): void
        + getLastEvent(): String
        + getTotalNumberOfEventsSeen(): long
        + getNumberOfEventsFiltered(): long
        + getQueueTotalCapacity(): int
        + getQueueRemainingCapacity(): int
        + reset(): void
    }
}

' PipelineMetrics inheritance & impl
PipelineMetrics --|> Metrics
PipelineMetrics ..|> DataChangeEventListener
PipelineMetrics ..|> ChangeEventSourceMetricsMXBean
PipelineMetrics *-- CommonEventMeter : commonEventMeter
PipelineMetrics *-- ChangeEventQueueMetrics : changeEventQueueMetrics

' ─────────────────────────────────────────
'  Concrete metrics classes
' ─────────────────────────────────────────
package "io.debezium.pipeline.metrics" {
    class DefaultSnapshotChangeEventSourceMetrics<P extends Partition> <<@ThreadSafe>> {
        - snapshotMeter: SnapshotMeter
        --
        + DefaultSnapshotChangeEventSourceMetrics(taskContext, changeEventQueueMetrics, metadataProvider)
        + DefaultSnapshotChangeEventSourceMetrics(taskContext, changeEventQueueMetrics, metadataProvider, tags)
        --
        + getTotalTableCount(): int
        + getRemainingTableCount(): int
        + getSnapshotRunning(): boolean
        + getSnapshotCompleted(): boolean
        + getSnapshotAborted(): boolean
        + getSnapshotDurationInSeconds(): long
        + getCapturedTables(): String[]
        + getRowsScanned(): ConcurrentMap<String,Long>
        + monitoredDataCollectionsDetermined(partition, dataCollectionIds): void
        + snapshotStarted(partition): void
        + snapshotCompleted(partition): void
        + snapshotAborted(partition): void
        + rowsScanned(partition, tableId, numRows): void
        + currentChunk(partition, chunkId, chunkFrom, chunkTo): void
        + reset(): void
    }

    class DefaultStreamingChangeEventSourceMetrics<P extends Partition> <<@ThreadSafe>> {
        - connectionMeter: ConnectionMeter
        - streamingMeter: StreamingMeter
        - activityMonitoringMeter: ActivityMonitoringMeter
        --
        + DefaultStreamingChangeEventSourceMetrics(taskContext, changeEventQueueMetrics, metadataProvider, capturedTablesSupplier)
        + DefaultStreamingChangeEventSourceMetrics(taskContext, changeEventQueueMetrics, metadataProvider, tags, capturedTablesSupplier)
        --
        + isConnected(): boolean
        + connected(connected: boolean): void
        + getCapturedTables(): String[]
        + getSourceEventPosition(): Map<String,String>
        + getMilliSecondsBehindSource(): long
        + getNumberOfCommittedTransactions(): long
        + onEvent(...): void
        + pause(): void
        + resume(): void
        + getNumberOfCreateEventsSeen(): Map<String,Long>
        + getNumberOfUpdateEventsSeen(): Map<String,Long>
        + getNumberOfDeleteEventsSeen(): Map<String,Long>
        + reset(): void
    }

    class DefaultChangeEventSourceMetricsFactory<P extends Partition> {
        + getSnapshotMetrics(taskContext, changeEventQueueMetrics, eventMetadataProvider): SnapshotChangeEventSourceMetrics<P>
        + getStreamingMetrics(taskContext, changeEventQueueMetrics, eventMetadataProvider, capturedTablesSupplier): StreamingChangeEventSourceMetrics<P>
    }
}

' Inheritance
DefaultSnapshotChangeEventSourceMetrics --|> PipelineMetrics
DefaultStreamingChangeEventSourceMetrics --|> PipelineMetrics

' Interface implementations
DefaultSnapshotChangeEventSourceMetrics ..|> SnapshotChangeEventSourceMetrics
DefaultSnapshotChangeEventSourceMetrics ..|> SnapshotChangeEventSourceMetricsMXBean
DefaultStreamingChangeEventSourceMetrics ..|> StreamingChangeEventSourceMetrics
DefaultStreamingChangeEventSourceMetrics ..|> StreamingChangeEventSourceMetricsMXBean
DefaultChangeEventSourceMetricsFactory ..|> ChangeEventSourceMetricsFactory

' Composition: meter delegates
DefaultSnapshotChangeEventSourceMetrics *-- SnapshotMeter : snapshotMeter
DefaultStreamingChangeEventSourceMetrics *-- ConnectionMeter : connectionMeter
DefaultStreamingChangeEventSourceMetrics *-- StreamingMeter : streamingMeter
DefaultStreamingChangeEventSourceMetrics *-- ActivityMonitoringMeter : activityMonitoringMeter

note right of DefaultStreamingChangeEventSourceMetrics
  activityMonitoringMeter.onEvent()
  only called when
  isAdvancedMetricsEnabled() == true
end note

@enduml
