@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #EDF2FF
    BorderColor #4C6EF5
}

title MongoDB Connector

' ─── External base types ───────────────────────────────────────────────────────
abstract class BaseSourceConnector <<Kafka Connect>> {
}

abstract class CommonConnectorConfig {
}

abstract class CommonOffsetContext<S> {
}

abstract class BaseSourceInfo {
}

interface ConfigDescriptor {
}

interface SharedMongoDbConnectorConfig {
}

interface DataCollectionId {
}

interface AutoCloseable {
}

' ─── Package: io.debezium.connector.mongodb ────────────────────────────────────
package "io.debezium.connector.mongodb" {

    class MongoDbConnector {
        + {static} DEPRECATED_SHARD_CS_PARAMS_FILED : String
        + {static} DEPRECATED_CONNECTION_MODE_FILED : String
        - config : Configuration
        --
        + version() : String
        + taskClass() : Class<? extends Task>
        + start(props : Map<String,String>) : void
        + stop() : void
        + config() : ConfigDef
        + getConfigFields() : Field.Set
        + taskConfigs(maxTasks : int) : List<Map<String,String>>
        + validate(connectorConfigs : Map<String,String>) : Config
        + validateConnection(config : Configuration, connectionStringValidation : ConfigValue) : void
        # validateAllFields(config : Configuration) : Map<String,ConfigValue>
        + exactlyOnceSupport(connectorConfig : Map<String,String>) : ExactlyOnceSupport
    }

    class MongoDbConnectorConfig {
        - snapshotMode : SnapshotMode
        - captureMode : CaptureMode
        - captureModeFullUpdateType : FullUpdateType
        - captureScope : CaptureScope
        - cursorPipelineOrder : CursorPipelineOrder
        - oversizeHandlingMode : OversizeHandlingMode
        - filtersMatchMode : FiltersMatchMode
        --
        + MongoDbConnectorConfig(config : Configuration)
        + configDef() : ConfigDef
        + getSnapshotMode() : SnapshotMode
        + getCaptureMode() : CaptureMode
        + getCaptureScope() : CaptureScope
        + getConnectionString() : ConnectionString
        + getCursorPipelineOrder() : CursorPipelineOrder
        + getOversizeHandlingMode() : OversizeHandlingMode
        + getFiltersMatchMode() : FiltersMatchMode
        + getContextName() : String
        + getConnectorName() : String
    }

    enum SnapshotMode {
        INITIAL
        NEVER
        NO_DATA
        ALWAYS
        INITIAL_ONLY
        WHEN_NEEDED
        CONFIGURATION_BASED
        CUSTOM
    }

    enum CaptureMode {
        CHANGE_STREAMS
        CHANGE_STREAMS_UPDATE_FULL
        CHANGE_STREAMS_WITH_PRE_IMAGE
        CHANGE_STREAMS_UPDATE_FULL_WITH_PRE_IMAGE
        --
        - value : String
        - changeStreams : boolean
        - fullUpdate : boolean
        - includePreImage : boolean
    }

    enum FullUpdateType {
        LOOKUP
        POST_IMAGE
        --
        - postImage : boolean
    }

    enum CaptureScope {
        DEPLOYMENT
        DATABASE
        COLLECTION
    }

    enum CursorPipelineOrder {
        INTERNAL_FIRST
        USER_FIRST
        USER_ONLY
    }

    enum OversizeHandlingMode {
        FAIL
        SKIP
        SPLIT
    }

    enum FiltersMatchMode {
        REGEX
        LITERAL
    }

    class MongoDbOffsetContext {
        - transactionContext : TransactionContext
        - incrementalSnapshotContext : IncrementalSnapshotContext<CollectionId>
        --
        + MongoDbOffsetContext(sourceInfo : SourceInfo, transactionContext : TransactionContext, incrementalSnapshotContext : IncrementalSnapshotContext<CollectionId>)
        + getOffset() : Map<String,?>
        + isInitialSnapshotRunning() : boolean
        + readEvent(collectionId : CollectionId, timestamp : Instant) : void
        + changeStreamEvent(changeStreamEvent : ChangeStreamDocument<BsonDocument>) : void
        + lastResumeToken() : String
        + lastTimestamp() : BsonTimestamp
        + startInitialSnapshot() : void
        + stopInitialSnapshot() : void
        + {static} empty(connectorConfig : MongoDbConnectorConfig) : MongoDbOffsetContext
    }

    class "MongoDbOffsetContext.Loader" as OffsetLoader {
        + load(offset : Map<String,?>) : MongoDbOffsetContext
    }

    class ChangeStreamPipeline {
        - stages : List<? extends Bson>
        --
        + ChangeStreamPipeline(json : String)
        + ChangeStreamPipeline(stages : List<? extends Bson>)
        + ChangeStreamPipeline(stages : Bson...)
        + getStages() : List<? extends Bson>
        + then(pipeline : ChangeStreamPipeline) : ChangeStreamPipeline
    }

    class ChangeStreamPipelineFactory {
        - connectorConfig : MongoDbConnectorConfig
        - filterConfig : Filters.FilterConfig
        --
        ~ ChangeStreamPipelineFactory(connectorConfig : MongoDbConnectorConfig, filterConfig : FilterConfig)
        ~ create() : ChangeStreamPipeline
        - createUserAndInternalPipeline() : ChangeStreamPipeline
        - createInternalPipeline() : ChangeStreamPipeline
        - createUserPipeline() : ChangeStreamPipeline
        - createSizePipeline() : ChangeStreamPipeline
        - createSplitPipeline() : ChangeStreamPipeline
    }

    class CollectionId <<@Immutable>> {
        - dbName : String
        - name : String
        --
        + CollectionId(dbName : String, collectionName : String)
        + {static} parse(str : String) : CollectionId
        + name() : String
        + dbName() : String
        + identifier() : String
        + namespace() : String
    }

    class SourceInfo {
        - collectionId : CollectionId
        - position : Position
        - wallTime : long
        --
        + SourceInfo(connectorConfig : MongoDbConnectorConfig)
        + lastResumeToken() : String
        + lastTimestamp() : BsonTimestamp
        + hasPosition() : boolean
        + readEvent(collectionId : CollectionId, wallTime : long) : void
        + changeStreamEvent(changeStreamEvent : ChangeStreamDocument<BsonDocument>) : void
    }

    class "SourceInfo.Position" as Position {
        + ts : BsonTimestamp
        + changeStreamSessionTxnId : SessionTransactionId
        + resumeToken : String
    }

    class "SourceInfo.SessionTransactionId" as SessionTransactionId {
        + lsid : String
        + txnNumber : long
    }
}

' ─── Package: io.debezium.connector.mongodb.connection ────────────────────────
package "io.debezium.connector.mongodb.connection" {

    class MongoDbConnection {
        - filters : Filters
        - errorHandler : ErrorHandler
        - running : AtomicBoolean
        - connectorConfig : MongoDbConnectorConfig
        - connectionContext : MongoDbConnectionContext
        --
        ~ MongoDbConnection(config : Configuration, errorHandler : ErrorHandler)
        + getMongoClient() : MongoClient
        + execute(desc : String, operation : BlockingConsumer<MongoClient>) : void
        + databaseNames() : Set<String>
        + collections() : List<CollectionId>
        + hello() : BsonTimestamp
        + validateLogPosition(offset : MongoDbOffsetContext, taskContext : MongoDbTaskContext) : boolean
        + close() : void
    }

    interface "MongoDbConnection.ErrorHandler" as ErrorHandler {
        + onError(desc : String, error : Throwable) : void
    }

    class MongoDbConnectionContext {
        - connectorConfig : MongoDbConnectorConfig
        - clientFactory : MongoDbClientFactory
        --
        + MongoDbConnectionContext(config : Configuration)
        + getConnectorConfig() : MongoDbConnectorConfig
        + getConnectionString() : ConnectionString
        + getMongoClient() : MongoClient
        + getClusterType() : ClusterType
        + isShardedCluster() : boolean
        + getShardNames() : Set<String>
    }
}

' ─── Inheritance ───────────────────────────────────────────────────────────────
MongoDbConnector          --|> BaseSourceConnector
MongoDbConnector          ..|> ConfigDescriptor
MongoDbConnectorConfig    --|> CommonConnectorConfig
MongoDbConnectorConfig    ..|> SharedMongoDbConnectorConfig
MongoDbOffsetContext      --|> CommonOffsetContext
MongoDbConnection         ..|> AutoCloseable
CollectionId              ..|> DataCollectionId
SourceInfo                --|> BaseSourceInfo

' ─── Composition / containment ─────────────────────────────────────────────────
MongoDbConnectorConfig    +-- SnapshotMode
MongoDbConnectorConfig    +-- CaptureMode
MongoDbConnectorConfig    +-- FullUpdateType
MongoDbConnectorConfig    +-- CaptureScope
MongoDbConnectorConfig    +-- CursorPipelineOrder
MongoDbConnectorConfig    +-- OversizeHandlingMode
MongoDbConnectorConfig    +-- FiltersMatchMode
MongoDbOffsetContext      +-- OffsetLoader
MongoDbConnection         +-- ErrorHandler
SourceInfo                *-- Position       : position
SourceInfo                +-- SessionTransactionId

' ─── Associations ──────────────────────────────────────────────────────────────
MongoDbConnector               ..> MongoDbConnectorConfig       : validates & uses
MongoDbConnector               ..> MongoDbConnectionContext     : validates connection
MongoDbConnection              *-- MongoDbConnectionContext     : connectionContext
MongoDbConnection              ..> MongoDbConnectorConfig       : uses
MongoDbConnection              ..> MongoDbOffsetContext         : validateLogPosition
MongoDbConnectionContext       *-- MongoDbConnectorConfig       : connectorConfig
MongoDbOffsetContext           *-- SourceInfo                   : sourceInfo
MongoDbOffsetContext           ..> CollectionId                 : uses
ChangeStreamPipelineFactory    *-- MongoDbConnectorConfig       : connectorConfig
ChangeStreamPipelineFactory    ..> ChangeStreamPipeline         : creates
SourceInfo                     ..> CollectionId                 : collectionId

@enduml
