@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Offset & Partition Model

package "io.debezium.pipeline.spi" {

    interface OffsetContext {
        +getOffset(): Map<String, ?>
        +getSourceInfoSchema(): Schema
        +getSourceInfo(): Struct
        +isInitialSnapshotRunning(): boolean
        +markSnapshotRecord(record: SnapshotRecord): void
        +preSnapshotStart(onDemand: boolean): void
        +preSnapshotCompletion(): void
        +postSnapshotCompletion(): void
        +event(collectionId: DataCollectionId, timestamp: Instant): void
        +getTransactionContext(): TransactionContext
        +incrementalSnapshotEvents(): void
        +getIncrementalSnapshotContext(): IncrementalSnapshotContext<?>
    }

    interface "OffsetContext.Loader<O>" as OffsetContextLoader {
        +load(offset: Map<String, ?>): O
        +loadSnapshot(offset: Map<String, ?>): Optional<SnapshotType>
        +loadSnapshotCompleted(offset: Map<String, ?>): boolean
    }

    interface Partition {
        +getSourcePartition(): Map<String, String>
        +getSupportedFormats(): List<Map<String, String>>
        +getLoggingContext(): Map<String, String>
    }

    interface "Partition.Provider<P>" as PartitionProvider {
        +getPartitions(): Set<P>
    }
}

package "io.debezium.pipeline" {

    abstract class "CommonOffsetContext<T extends BaseSourceInfo>" as CommonOffsetContext {
        #sourceInfo: T
        #snapshot: SnapshotType
        #snapshotCompleted: boolean
        +{static} SNAPSHOT_COMPLETED_KEY: String
        --
        +getSourceInfo(): Struct
        +isInitialSnapshotRunning(): boolean
        +markSnapshotRecord(record: SnapshotRecord): void
        +preSnapshotStart(onDemand: boolean): void
        +preSnapshotCompletion(): void
        +postSnapshotCompletion(): void
        +incrementalSnapshotEvents(): void
        +getSnapshot(): Optional<SnapshotType>
        +setSnapshot(snapshotType: SnapshotType): void
    }
}

package "io.debezium.pipeline.txmetadata" {

    class TransactionContext {
        +{static} OFFSET_TRANSACTION_ID: String
        -{static} OFFSET_TABLE_COUNT_PREFIX: String
        -transactionId: String
        -perTableEventCount: Map<String, Long>
        -totalEventCount: long
        --
        +store(offset: Map<String, Object>): Map<String, Object>
        +{static} load(offsets: Map<String, ?>): TransactionContext
        +isTransactionInProgress(): boolean
        +getTransactionId(): String
        +getTotalEventCount(): long
        +getPerTableEventCount(): Map<String, Long>
        +beginTransaction(transactionInfo: TransactionInfo): void
        +endTransaction(): void
        +event(source: DataCollectionId): long
        +setTransactionId(transactionId: String): void
        +setTotalEventCount(totalEventCount: long): void
    }
}

package "io.debezium.connector" {

    abstract class AbstractSourceInfo {
        -{static} DEBEZIUM_VERSION_KEY: String
        -{static} DEBEZIUM_CONNECTOR_KEY: String
        -{static} SERVER_NAME_KEY: String
        -{static} TIMESTAMP_KEY: String
        -{static} SNAPSHOT_KEY: String
        -{static} DATABASE_NAME_KEY: String
        -{static} TABLE_NAME_KEY: String
        -config: CommonConnectorConfig
        --
        +schema(): Schema
        +struct(): Struct
        #timestamp(): Instant
        #snapshot(): SnapshotRecord
        #database(): String
        #serverName(): String
        #sequence(): String
    }
}

package "io.debezium.connector.common" {

    abstract class BaseSourceInfo {
        #snapshotRecord: SnapshotRecord
        --
        +isSnapshot(): boolean
        +setSnapshot(snapshot: SnapshotRecord): void
        +snapshot(): SnapshotRecord
    }
}

package "io.debezium.relational" {

    abstract class AbstractPartition {
        #databaseName: String
        --
        +getLoggingContext(): Map<String, String>
    }
}

package "io.debezium.connector.binlog" {

    class BinlogPartition {
        +getSourcePartition(): Map<String, String>
    }
}

package "io.debezium.connector.sqlserver" {

    class SqlServerPartition {
        +getSourcePartition(): Map<String, String>
    }

    class "SqlServerPartition.Provider" as SqlServerPartitionProvider {
        +getPartitions(): Set<SqlServerPartition>
    }
}

package "Connector-Specific OffsetContexts" <<Frame>> {

    class MongoDbOffsetContext
    class "BinlogOffsetContext<T>" as BinlogOffsetContext
    class PostgresOffsetContext
    class OracleOffsetContext
    class SqlServerOffsetContext
}

' ---- OffsetContext SPI hierarchy ----
CommonOffsetContext ..|> OffsetContext : implements
OffsetContextLoader ..+ OffsetContext : inner interface
OffsetContextLoader ..> OffsetContext : <<creates>>

' ---- OffsetContext subclasses ----
MongoDbOffsetContext --|> CommonOffsetContext
BinlogOffsetContext --|> CommonOffsetContext
PostgresOffsetContext --|> CommonOffsetContext
OracleOffsetContext --|> CommonOffsetContext
SqlServerOffsetContext --|> CommonOffsetContext

' ---- Composition inside CommonOffsetContext ----
CommonOffsetContext *-- BaseSourceInfo : sourceInfo (T)
OffsetContext ..> TransactionContext : getTransactionContext()

' ---- SourceInfo hierarchy ----
BaseSourceInfo --|> AbstractSourceInfo

' ---- Partition SPI hierarchy ----
AbstractPartition ..|> Partition : implements
PartitionProvider ..+ Partition : inner interface

BinlogPartition --|> AbstractPartition
SqlServerPartition --|> AbstractPartition

SqlServerPartitionProvider ..|> PartitionProvider : implements
SqlServerPartitionProvider ..+ SqlServerPartition : inner class

' ---- TransactionContext offset persistence note ----
note bottom of TransactionContext
  Persisted as flat Map keys inside Kafka
  Connect source offset. Tracks active
  transactionId + per-table event counts.
  store(offset) injects fields; load() restores.
end note

note right of OffsetContext
  Core SPI: CDC stream position persisted
  as Kafka Connect source offset via
  getOffset() → Map<String, ?>
end note

note right of Partition
  Identifies the source DB partition.
  getSupportedFormats() supports legacy
  offset key formats during upgrades.
end note

@enduml
