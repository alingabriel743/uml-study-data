@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}

title Oracle Connector Core\nio.debezium.connector.oracle

' ─────────────────────────────────────────────
' External parent types (abbreviated)
' ─────────────────────────────────────────────
package "io.debezium (external)" <<Frame>> {

    abstract class RelationalBaseSourceConnector <<external>> {
    }

    abstract class HistorizedRelationalDatabaseConnectorConfig <<external>> {
    }

    abstract class JdbcConnection <<external>> {
    }

    abstract class "CommonOffsetContext<S>" as CommonOffsetContext <<external>> {
    }

    abstract class AbstractPartition <<external>> {
    }

    interface Partition <<external>> {
    }

    interface ConfigDescriptor <<external>> {
    }
}

' ─────────────────────────────────────────────
' Core Oracle connector classes
' ─────────────────────────────────────────────
package "io.debezium.connector.oracle" {

    class OracleConnector {
        - properties: Map<String,String>
        --
        + version(): String
        + start(props: Map<String,String>): void
        + taskClass(): Class<? extends Task>
        + taskConfigs(maxTasks: int): List<Map<String,String>>
        + stop(): void
        + config(): ConfigDef
        + getConfigFields(): Field.Set
        + validateConnection(configValues: Map, config: Configuration): void
        + validateAllFields(config: Configuration): Map<String,ConfigValue>
        + exactlyOnceSupport(connectorConfig: Map): ExactlyOnceSupport
    }
    note right of OracleConnector
        taskClass() returns OracleConnectorTask.
        Only maxTasks=1 is supported.
        validateConnection() instantiates
        OracleConnectorConfig + OracleConnection.
    end note

    class OracleConnectorConfig {
        ' Static configuration fields
        + {static} PORT: Field
        + {static} HOSTNAME: Field
        + {static} PDB_NAME: Field
        + {static} XSTREAM_SERVER_NAME: Field
        + {static} CONNECTOR_ADAPTER: Field
        + {static} LOG_MINING_STRATEGY: Field
        + {static} SNAPSHOT_MODE: Field
        + {static} LOB_ENABLED: Field
        + {static} LOG_MINING_BUFFER_TYPE: Field
        + {static} RAC_NODES: Field
        + {static} URL: Field
        ' Instance fields
        - databaseName: String
        - pdbName: String
        - connectorAdapter: ConnectorAdapter
        - streamingAdapter: StreamingAdapter
        - snapshotMode: SnapshotMode
        - snapshotLockingMode: SnapshotLockingMode
        - logMiningStrategy: LogMiningStrategy
        - logMiningBufferType: LogMiningBufferType
        - lobEnabled: boolean
        - queryFetchSize: int
        - racNodes: Set<String>
        - archiveLogRetention: Duration
        - logMiningReadOnly: boolean
        --
        + {static} configDef(): ConfigDef
        + getDatabaseName(): String
        + getPdbName(): String
        + getCatalogName(): String
        + getConnectorAdapter(): ConnectorAdapter
        + getSnapshotMode(): SnapshotMode
        + getSnapshotLockingMode(): Optional<SnapshotLockingMode>
        + getLogMiningStrategy(): LogMiningStrategy
        + getLogMiningBufferType(): LogMiningBufferType
        + isLobEnabled(): boolean
        + isLogMiningReadOnly(): boolean
        + getQueryFetchSize(): int
        + getArchiveLogRetention(): Duration
        + getIntervalHandlingMode(): IntervalHandlingMode
    }

    ' ── Inner enums of OracleConnectorConfig ──
    enum ConnectorAdapter {
        XSTREAM
        LOG_MINER
        LOG_MINER_UNBUFFERED
        OLR
        --
        + getConnectionUrl(): String
        + getInstance(config: OracleConnectorConfig): StreamingAdapter
    }
    note bottom of ConnectorAdapter
        Controls streaming strategy:
        XSTREAM=OCI JDBC,
        LOG_MINER=buffered thin JDBC,
        OLR=OpenLogReplicator
    end note

    enum SnapshotMode {
        INITIAL
        ALWAYS
        INITIAL_ONLY
        SCHEMA_ONLY
        SCHEMA_ONLY_RECOVERY
    }

    enum SnapshotLockingMode {
        SHARED
        NONE
    }

    enum LogMiningStrategy {
        ONLINE_CATALOG
        CATALOG_IN_REDO
    }

    enum LogMiningBufferType {
        MEMORY
        INFINISPAN_EMBEDDED
        INFINISPAN_REMOTE
        EHCACHE
    }

    enum IntervalHandlingMode {
        NUMERIC
        STRING
    }

    ' ─────────────────────────────────────────
    class OracleConnection {
        - queryFetchSize: int
        - databaseVersion: OracleDatabaseVersion
        - databaseCharacterSet: CharacterSet
        - {static} ORACLE_UNSET_SCALE: int = -127
        - {static} SYS_NC_PATTERN: Pattern
        - {static} ADT_INDEX_NAMES_PATTERN: Pattern
        --
        + setSessionToPdb(pdbName: String): void
        + resetSessionToCdb(): void
        + getOracleVersion(): OracleDatabaseVersion
        + readTableNames(catalog, schemaPattern, tablePattern, types): Set<TableId>
        + getAllTableIds(catalogName: String): Set<TableId>
        + getCurrentTimestamp(): Optional<Instant>
        + resolveCatalogName(catalogName: String): String
        + initializeStatement(statement: Statement): void
        + {static} connectionString(config: JdbcConfiguration): String
    }
    note right of OracleConnection
        Overrides JdbcConnection to handle
        CDB/PDB session switching via
        ALTER SESSION SET CONTAINER.
    end note

    ' ─────────────────────────────────────────
    class OracleOffsetContext {
        + {static} SNAPSHOT_SCN_KEY: String
        + {static} SNAPSHOT_PENDING_TRANSACTIONS_KEY: String
        + {static} WINDOW_ADVANCE_ENABLED_KEY: String
        - sourceInfoSchema: Schema
        - windowAdvanceEnabled: boolean
        - snapshotScn: Scn
        - snapshotPendingTransactions: Map<String,Scn>
        - transactionContext: TransactionContext
        - incrementalSnapshotContext: IncrementalSnapshotContext<TableId>
        --
        + {static} create(): Builder
        + getOffset(): Map<String,?>
        + getScn(): Scn
        + setScn(scn: Scn): void
        + getCommitScn(): CommitScn
        + getEventScn(): Scn
        + setEventScn(eventScn: Scn): void
        + getLcrPosition(): String
        + setLcrPosition(lcrPosition: String): void
        + getSnapshotScn(): Scn
        + getTransactionContext(): TransactionContext
        + getIncrementalSnapshotContext(): IncrementalSnapshotContext<?>
        + event(tableId: DataCollectionId, timestamp: Instant): void
        + tableEvent(tableId: TableId, timestamp: Instant): void
        + {static} loadSnapshotScn(offset: Map): Scn
        + {static} loadSnapshotPendingTransactions(offset: Map): Map<String,Scn>
    }
    note right of OracleOffsetContext
        Uses Builder pattern (private constructor).
        Tracks Oracle SCN (System Change Number)
        for both snapshot and streaming offsets.
    end note

    class "OracleOffsetContext.Builder" as OracleOffsetContextBuilder {
        - connectorConfig: OracleConnectorConfig
        - scn: Scn
        - scnIndex: Long
        - lcrPosition: String
        - snapshot: boolean
        - snapshotCompleted: boolean
        - transactionContext: TransactionContext
        - incrementalSnapshotContext: IncrementalSnapshotContext
        - snapshotPendingTransactions: Map<String,Scn>
        - snapshotScn: Scn
        - commitScn: CommitScn
        - windowAdvanceEnabled: boolean
        --
        + scn(scn: Scn): Builder
        + snapshotScn(scn: Scn): Builder
        + build(): OracleOffsetContext
    }

    ' ─────────────────────────────────────────
    class OraclePartition {
        - serverName: String
        - {static} SERVER_PARTITION_KEY: String = "server"
        --
        + getSourcePartition(): Map<String,String>
        + equals(obj: Object): boolean
        + hashCode(): int
        + toString(): String
    }

    class "OraclePartition.Provider" as OraclePartitionProvider {
        - connectorConfig: OracleConnectorConfig
        --
        + getPartitions(): Set<OraclePartition>
    }
    note bottom of OraclePartitionProvider
        Uses pdbName when set,
        otherwise CDB databaseName.
    end note

    ' ─────────────────────────────────────────
    ' Value / support types
    ' ─────────────────────────────────────────
    class Scn <<value>> {
        + {static} NULL: Scn
        + asBigInteger(): BigInteger
        + add(scn: Scn): Scn
        + compareTo(other: Scn): int
    }

    class CommitScn <<value>> {
        + getCommitScnForRedoThread(thread: Integer): Scn
        + setCommitScnOnAllThreads(scn: Scn): void
    }

    class OracleDatabaseVersion <<value>> {
        + getMajor(): int
        + getMinor(): int
        + toString(): String
    }

    class SourceInfo <<value>> {
        + toStruct(): Struct
    }
}

' ─────────────────────────────────────────────
' Inheritance / Implementation
' ─────────────────────────────────────────────
OracleConnector        --|> RelationalBaseSourceConnector
OracleConnector        ..|> ConfigDescriptor
OracleConnectorConfig  --|> HistorizedRelationalDatabaseConnectorConfig
OracleConnection       --|> JdbcConnection
OracleOffsetContext    --|> CommonOffsetContext
OraclePartition        --|> AbstractPartition
OraclePartition        ..|> Partition
OraclePartitionProvider ..|> Partition

' ─────────────────────────────────────────────
' Composition / Containment
' ─────────────────────────────────────────────
OracleConnectorConfig  *-- ConnectorAdapter       : adapter strategy
OracleConnectorConfig  *-- SnapshotMode           : snapshot mode
OracleConnectorConfig  *-- SnapshotLockingMode    : locking mode
OracleConnectorConfig  *-- LogMiningStrategy      : mining strategy
OracleConnectorConfig  *-- LogMiningBufferType    : buffer type
OracleConnectorConfig  *-- IntervalHandlingMode   : interval handling
OracleOffsetContext    *-- OracleOffsetContextBuilder : created via
OracleOffsetContext    *-- TransactionContext      : transactionContext
OraclePartition        +-- OraclePartitionProvider : inner Provider

' ─────────────────────────────────────────────
' Associations / Dependencies
' ─────────────────────────────────────────────
OracleConnector        ..> OracleConnectorConfig  : creates (validateConnection)
OracleConnector        ..> OracleConnection       : creates (validateConnection)
OracleConnection       ..> OracleConnectorConfig  : uses (constructor)
OracleConnection       o-- OracleDatabaseVersion  : databaseVersion
OracleOffsetContext    o-- Scn                    : scn / snapshotScn
OracleOffsetContext    o-- CommitScn              : commitScn
OracleOffsetContext    o-- SourceInfo             : sourceInfo (via parent)
OracleOffsetContextBuilder ..> OracleConnectorConfig : configured by
OraclePartitionProvider    ..> OracleConnectorConfig : reads pdbName / dbName

@enduml
