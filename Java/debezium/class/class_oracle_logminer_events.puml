@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #856404
}
skinparam note {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
}

title Oracle LogMiner Events

package "io.debezium.connector.oracle.logminer.events" {

    enum EventType {
        INSERT(1)
        DELETE(2)
        UPDATE(3)
        DDL(5)
        START(6)
        COMMIT(7)
        SELECT_LOB_LOCATOR(9)
        LOB_WRITE(10)
        LOB_TRIM(11)
        REPLICATION_MARKER(27)
        LOB_ERASE(29)
        MISSING_SCN(34)
        ROLLBACK(36)
        XML_BEGIN(68)
        XML_WRITE(70)
        XML_END(71)
        EXTENDED_STRING_BEGIN(91)
        EXTENDED_STRING_WRITE(92)
        EXTENDED_STRING_END(93)
        UNSUPPORTED(255)
        --
        +getValue(): int
        +{static} from(value: int): EventType
    }

    class RowIdCodec <<utility>> {
        -{static} BASE64_CHARS: String
        -{static} BASE64_VALUES: int[]
        -{static} EMPTY_ROW_ID: long
        --
        +{static} encode(rowId: String): long
        +{static} decode(packed: long): String
    }

    class LogMinerEventRow <<flyweight>> {
        -scn: Scn
        -tableId: TableId
        -tableName: String
        -tablespaceName: String
        -eventType: EventType
        -changeTime: Instant
        -transactionId: String
        -transactionSequence: Long
        -operation: String
        -userName: String
        -rowId: String
        -rollbackFlag: boolean
        -rsId: String
        -redoSql: String
        -status: int
        -info: String
        -ssn: long
        -thread: int
        -objectId: long
        -objectVersion: long
        -dataObjectId: long
        -clientId: String
        -startScn: Scn
        -commitScn: Scn
        -startTime: Instant
        -commitTime: Instant
        --
        +{static} fromResultSet(rs: ResultSet, schema: OracleDatabaseSchema, config: OracleConnectorConfig): LogMinerEventRow
        -initializeFromResultSet(rs: ResultSet, catalog: String, schema: OracleDatabaseSchema, trackRsId: boolean): void
        -getSqlRedo(rs: ResultSet): String
        -getTransactionId(rs: ResultSet): String
        -getTime(rs: ResultSet, col: int): Instant
        -getScn(rs: ResultSet, col: int): Scn
        +hasErrorStatus(): boolean
        +getScn(): Scn
        +getTableId(): TableId
        +setTableId(tableId: TableId): void
        +getEventType(): EventType
        +getRedoSql(): String
        +getRowId(): String
        +getRsId(): String
        +getTransactionId(): String
    }

    class LogMinerEvent {
        #{static} eventType: EventType
        #{static} scn: Scn
        #{static} tableId: TableId
        -rowId: long
        -rsId: String
        -changeTime: long
        --
        +LogMinerEvent(row: LogMinerEventRow)
        +getEventType(): EventType
        +getScn(): Scn
        +getTableId(): TableId
        +getRowId(): Long
        +getRowIdAsString(): String
        +getRsId(): String
        +getChangeTime(): Instant
        +equals(): boolean
        +hashCode(): int
        +toString(): String
    }

    class DmlEvent {
        -oldValues: Object[]
        -newValues: Object[]
        --
        +DmlEvent(row: LogMinerEventRow, dmlEntry: LogMinerDmlEntry)
        +getOldValues(): Object[]
        +getNewValues(): Object[]
        +toString(): String
    }

    class RedoSqlDmlEvent {
        -redoSql: String
        --
        +RedoSqlDmlEvent(row: LogMinerEventRow, dmlEntry: LogMinerDmlEntry, redoSql: String)
        +getRedoSql(): String
    }

    class TruncateEvent {
        --
        +TruncateEvent(row: LogMinerEventRow, dmlEntry: LogMinerDmlEntry)
    }

    class SelectLobLocatorEvent {
        -columnName: String
        -binary: boolean
        --
        +SelectLobLocatorEvent(row: LogMinerEventRow, dmlEntry: LogMinerDmlEntry, columnName: String, binary: boolean)
        +getColumnName(): String
        +isBinary(): boolean
        +toString(): String
    }

    class XmlBeginEvent {
        -columnName: String
        --
        +XmlBeginEvent(row: LogMinerEventRow, dmlEntry: LogMinerDmlEntry, columnName: String)
        +getColumnName(): String
        +toString(): String
    }

    class ExtendedStringBeginEvent {
        -columnName: String
        --
        +ExtendedStringBeginEvent(row: LogMinerEventRow, dmlEntry: LogMinerDmlEntry, columnName: String)
        +getColumnName(): String
        +toString(): String
    }

    class LobWriteEvent {
        -data: String
        -offset: int
        -length: int
        --
        +LobWriteEvent(row: LogMinerEventRow, parsedEvent: LobWrite)
        +LobWriteEvent(row: LogMinerEventRow, data: String, offset: int, length: int)
        +getData(): String
        +getOffset(): int
        +getLength(): int
        +toString(): String
    }

    class LobEraseEvent {
        --
        +LobEraseEvent(row: LogMinerEventRow)
    }

    class XmlWriteEvent {
        -xml: String
        -length: int
        --
        +XmlWriteEvent(row: LogMinerEventRow, xml: String, length: Integer)
        +getXml(): String
        +getLength(): Integer
        +toString(): String
    }

    class XmlEndEvent {
        --
        +XmlEndEvent(row: LogMinerEventRow)
    }

    class ExtendedStringWriteEvent {
        -data: String
        --
        +ExtendedStringWriteEvent(row: LogMinerEventRow, data: String)
        +getData(): String
        +toString(): String
    }

    class LogMinerEventRowTooLargeException {
        --
        +LogMinerEventRowTooLargeException(tableName: String, limitInKiloBytes: Long, scn: Scn)
    }
}

package "External Dependencies" <<Frame>> {
    class DebeziumException <<external>> {
    }
    class Scn <<external>> {
    }
    class TableId <<external>> {
    }
    class LogMinerDmlEntry <<external>> {
    }
    class OracleDatabaseSchema <<external>> {
    }
    class OracleConnectorConfig <<external>> {
    }
}

' ── Inheritance ──────────────────────────────────────────────────────────────
DmlEvent                --|> LogMinerEvent
RedoSqlDmlEvent         --|> DmlEvent
TruncateEvent           --|> DmlEvent
SelectLobLocatorEvent   --|> DmlEvent
XmlBeginEvent           --|> DmlEvent
ExtendedStringBeginEvent --|> DmlEvent

LobWriteEvent           --|> LogMinerEvent
LobEraseEvent           --|> LogMinerEvent
XmlWriteEvent           --|> LogMinerEvent
XmlEndEvent             --|> LogMinerEvent
ExtendedStringWriteEvent --|> LogMinerEvent

LogMinerEventRowTooLargeException --|> DebeziumException

' ── Key Associations ─────────────────────────────────────────────────────────
LogMinerEvent           ..> RowIdCodec          : uses (encode/decode rowId)
LogMinerEvent           *-- EventType           : eventType
LogMinerEvent           *-- Scn                 : scn
LogMinerEvent           *-- TableId             : tableId

LogMinerEventRow        ..> EventType           : resolves via EventType.from()
LogMinerEventRow        ..> OracleDatabaseSchema : resolveTableId
LogMinerEventRow        ..> OracleConnectorConfig : getCatalogName
LogMinerEventRow        ..> LogMinerEventRowTooLargeException : throws (getSqlRedo)

DmlEvent                ..> LogMinerDmlEntry    : reads values from

note bottom of LogMinerEventRow
  **Flyweight Pattern**
  Single instance reused per LogMiner
  query row. 26 ResultSet column constants.
  getSqlRedo() handles CSF continuation rows
  (max 25 iterations = ~100 KB).
end note

note right of EventType
  O(1) lookup via
  static array indexed
  by operation code.
  UNSUPPORTED(255) for
  unknown op codes.
end note

note bottom of LogMinerEvent
  **NOTE:** No DdlEvent subclass.
  DDL, COMMIT, ROLLBACK events
  all use base LogMinerEvent
  with appropriate EventType.
  rowId packed as long via
  RowIdCodec for memory efficiency.
end note

@enduml
