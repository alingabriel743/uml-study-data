@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
}

title Oracle LogMiner Streaming

' ─────────────────────────────────────────────
'  External / framework interfaces
' ─────────────────────────────────────────────
interface "StreamingChangeEventSource\n<OraclePartition, OracleOffsetContext>" as StreamingChangeEventSource {
    +execute(context, partition, offsetContext): void
}

interface OracleCommonStreamingChangeEventSourceMetricsMXBean {
    +getCommittedTransactionCount(): long
    +getTotalCapturedDmlCount(): long
    +getWarningCount(): long
    +getErrorCount(): long
}

' ─────────────────────────────────────────────
'  io.debezium.connector.oracle
' ─────────────────────────────────────────────
package "io.debezium.connector.oracle" {

    class Scn implements Comparable {
        -{static} NULL: Scn
        -{static} ONE: Scn
        -longValue: long
        -bigIntegerValue: BigInteger
        -empty: boolean
        +{static} valueOf(int): Scn
        +{static} valueOf(long): Scn
        +{static} valueOf(String): Scn
        +isNull(): boolean
        +asBigInteger(): BigInteger
        +longValue(): long
        +add(value: Scn): Scn
        +subtract(value: Scn): Scn
        +compareTo(Scn): int
    }

    abstract class AbstractOracleStreamingChangeEventSourceMetrics {
        #schemaChangeParseErrorCount: AtomicLong
        #committedTransactionCount: AtomicLong
        #lastCapturedDmlCount: AtomicLong
        #maxCapturedDmlCount: AtomicLong
        #totalCapturedDmlCount: AtomicLong
        #warningCount: AtomicLong
        #errorCount: AtomicLong
        +reset(): void
        +setLastCapturedDmlCount(int): void
        +incrementCommittedTransactionCount(): void
        +incrementSchemaChangeParseErrorCount(): void
        +incrementWarningCount(): void
        +incrementErrorCount(): void
    }

}

' ─────────────────────────────────────────────
'  io.debezium.connector.oracle.logminer
' ─────────────────────────────────────────────
package "io.debezium.connector.oracle.logminer" {

    interface LogMinerStreamingChangeEventSourceMetricsMXBean {
        +getCurrentScn(): BigInteger
        +getOffsetScn(): BigInteger
        +getCommittedScn(): BigInteger
        +getOldestScn(): BigInteger
        +getBatchSize(): int
        +getSleepTimeInMilliseconds(): long
        +getScnFreezeCount(): long
        +getMiningSessionLowerBounds(): BigInteger
        +getMiningSessionUpperBounds(): BigInteger
        +getNumberOfActiveTransactions(): long
        +getNumberOfRolledBackTransactions(): long
        +getAbandonedTransactionIds(): Set<String>
        +getNumberOfEventsInBuffer(): long
    }

    abstract class AbstractLogMinerStreamingChangeEventSource {
        -connectorConfig: OracleConnectorConfig
        -jdbcConnection: OracleConnection
        -dispatcher: EventDispatcher<OraclePartition, TableId>
        -errorHandler: ErrorHandler
        -clock: Clock
        -schema: OracleDatabaseSchema
        -metrics: LogMinerStreamingChangeEventSourceMetrics
        -sessionContext: LogMinerSessionContext
        -dmlParser: LogMinerDmlParser
        -logCollector: LogFileCollector
        -effectiveOffset: OracleOffsetContext
        -offsetActivityMonitor: OffsetActivityMonitor
        --
        +init(offsetContext: OracleOffsetContext): void
        +execute(context, partition, offsetContext): void
        +processEvent(event: LogMinerEventRow): void
        +calculateUpperBounds(lower: Scn, prevUpper: Scn, current: Scn): Scn
        +executeAndProcessQuery(stmt: PreparedStatement): void
        +resolveFlushStrategy(): LogWriterFlushStrategy
        +getMetrics(): LogMinerStreamingChangeEventSourceMetrics
        +getLogMinerContext(): LogMinerSessionContext
        ..abstract..
        #executeLogMiningStreaming(): void
        #enqueueEvent(event: LogMinerEventRow, dispatched: LogMinerEvent): void
        #handleCommitEvent(event: LogMinerEventRow): void
        #handleRollbackEvent(event: LogMinerEventRow): void
        #handleStartEvent(event: LogMinerEventRow): void
        #handleSchemaChangeEvent(event: LogMinerEventRow): void
        #handleTruncateEvent(event: LogMinerEventRow): void
        #handleDataChangeEvent(event: LogMinerEventRow): void
        #isNoDataProcessedInBatchAndAtEndOfArchiveLogs(): boolean
    }

    class LogMinerStreamingChangeEventSourceMetrics <<@ThreadSafe>> {
        -connectorConfig: OracleConnectorConfig
        -currentScn: AtomicReference<Scn>
        -offsetScn: AtomicReference<Scn>
        -commitScn: AtomicReference<Scn>
        -oldestScn: AtomicReference<Scn>
        -miningSessionScnRange: AtomicReference<ScnRange>
        -miningFetchScnRange: AtomicReference<ScnRange>
        -batchSize: AtomicInteger
        -sleepTime: AtomicLong
        -activeTransactionCount: AtomicLong
        -rolledBackTransactionCount: AtomicLong
        -batchProcessingDuration: DurationHistogramMetric
        -fetchQueryDuration: DurationHistogramMetric
        -miningSessionStartupDuration: DurationHistogramMetric
        -userGlobalAreaMemory: MaxLongValueMetric
        -abandonedTransactionIds: LRUSet<String>
        -batchMetrics: BatchMetrics
        --
        +reset(): void
        +setCurrentScn(scn: Scn): void
        +setOffsetScn(scn: Scn): void
        +setCommitScn(scn: Scn): void
        +setOldestScnDetails(scn: Scn, time: Instant): void
        +setLastMiningSessionRange(lower: Scn, upper: Scn): void
        +setLastMiningFetchRange(lower: Scn, upper: Scn): void
        +setBatchSize(int): void
        +setSleepTime(long): void
        +calculateLagFromSource(changeTime: Instant): void
        +incrementScnFreezeCount(): void
        +addAbandonedTransactionId(id: String): void
        +getBatchMetrics(): BatchMetrics
    }

    class LogMinerSessionContext implements AutoCloseable {
        -connection: OracleConnection
        -useContinuousMining: boolean
        -strategy: LogMiningStrategy
        -sessionStarted: boolean
        -currentSessionStartScn: Scn
        -currentSessionEndScn: Scn
        -lastSessionStartTime: Duration
        --
        +startSession(startScn: Scn, endScn: Scn, ...): void
        +endMiningSession(): void
        +getCurrentSessionStartScn(): Scn
        +getCurrentSessionEndScn(): Scn
        +getLastSessionStartTime(): Duration
        +close(): void
    }

    class ScnRange <<record>> {
        +lowerBounds: Scn
        +upperBounds: Scn
        +{static} empty(): ScnRange
    }

    class BatchMetrics <<inner static>> {
        -schemaChangeCount: int
        -dataChangeCount: int
        -insertCount: int
        -updateCount: int
        -deleteCount: int
        -commitCount: int
        -rollbackCount: int
        -jdbcRows: int
        -processedRows: int
        --
        +schemaChangeObserved(): void
        +dataChangeEventObserved(type: EventType): void
        +commitObserved(): void
        +rollbackObserved(): void
        +rowObserved(): void
        +rowProcessed(): void
        +updateStreamingMetrics(): void
        +hasProcessedAnyTransactions(): boolean
        +reset(): void
    }

    class DurationHistogramMetric <<inner static, @ThreadSafe>> {
        -min: AtomicReference<Duration>
        -max: AtomicReference<Duration>
        -last: AtomicReference<Duration>
        -total: AtomicReference<Duration>
        +set(lastDuration: Duration): void
        +getMinimum(): Duration
        +getMaximum(): Duration
        +getLast(): Duration
        +getTotal(): Duration
        +reset(): void
    }

    class MaxLongValueMetric <<inner static, @ThreadSafe>> {
        -value: AtomicLong
        -max: AtomicLong
        +setValue(long): void
        +setValueAndCalculateMax(long): void
        +getValue(): long
        +getMax(): long
        +reset(): void
    }

    class "LRUSet<T>" as LRUSet <<inner static, @ThreadSafe>> {
        -cache: AtomicReference<LRUCacheMap<T,T>>
        -capacity: int
        +add(value: T): void
        +getAll(): Set<T>
        +reset(): void
    }

}

' ─────────────────────────────────────────────
'  Inheritance & Interface Realization
' ─────────────────────────────────────────────
AbstractLogMinerStreamingChangeEventSource ..|> StreamingChangeEventSource

AbstractOracleStreamingChangeEventSourceMetrics ..|> OracleCommonStreamingChangeEventSourceMetricsMXBean

LogMinerStreamingChangeEventSourceMetrics --|> AbstractOracleStreamingChangeEventSourceMetrics
LogMinerStreamingChangeEventSourceMetrics ..|> LogMinerStreamingChangeEventSourceMetricsMXBean

LogMinerStreamingChangeEventSourceMetricsMXBean --|> OracleCommonStreamingChangeEventSourceMetricsMXBean

' ─────────────────────────────────────────────
'  Composition & Aggregation
' ─────────────────────────────────────────────
AbstractLogMinerStreamingChangeEventSource *-- LogMinerStreamingChangeEventSourceMetrics : metrics
AbstractLogMinerStreamingChangeEventSource *-- LogMinerSessionContext : sessionContext

LogMinerStreamingChangeEventSourceMetrics *-- BatchMetrics : batchMetrics
LogMinerStreamingChangeEventSourceMetrics *-- ScnRange : miningSessionScnRange\nminingFetchScnRange
LogMinerStreamingChangeEventSourceMetrics *-- DurationHistogramMetric : batchProcessing/\nfetch/session\ndurations
LogMinerStreamingChangeEventSourceMetrics *-- MaxLongValueMetric : ugaMemory\npgaMemory
LogMinerStreamingChangeEventSourceMetrics *-- LRUSet : abandonedTxIds\nrolledBackTxIds

BatchMetrics ..> LogMinerStreamingChangeEventSourceMetrics : updateStreamingMetrics()

ScnRange *-- Scn : lowerBounds\nupperBounds
LogMinerSessionContext *-- Scn : currentSessionStartScn\ncurrentSessionEndScn

LogMinerStreamingChangeEventSourceMetrics ..> Scn : currentScn\noffsetScn\ncommitScn

@enduml
