@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Oracle Snapshot

' ─────────────────────────────────────────────
' External base classes / interfaces (collapsed)
' ─────────────────────────────────────────────
package "io.debezium.relational" #DDE8F0 {
    abstract class RelationalSnapshotChangeEventSource<P, O> {
        + execute(ChangeEventSourceContext, P, O): void
        # doExecute(...): void
        # createDataEventsForTable(...): void
    }
    abstract class RelationalSnapshotContext<P, O> {
        + catalogName: String
        + onDemand: boolean
    }
    abstract class HistorizedRelationalDatabaseSchema {
        + applySchemaChange(SchemaChangeEvent): void
    }
}

package "io.debezium.snapshot.spi" #DDE8F0 {
    interface SnapshotLock {
        + name(): String
        + tableLockingStatement(Duration, String): Optional<String>
    }
    interface SnapshotQuery {
        + name(): String
        + snapshotQuery(String, List<String>): Optional<String>
    }
    interface BeanRegistryAware {
        + injectBeanRegistry(BeanRegistry): void
    }
}

' ─────────────────────────────────────────────
' Oracle connector — core snapshot classes
' ─────────────────────────────────────────────
package "io.debezium.connector.oracle" {

    class OracleSnapshotChangeEventSource {
        - connectorConfig: OracleConnectorConfig
        - jdbcConnection: OracleConnection
        - databaseSchema: OracleDatabaseSchema
        --
        + prepare(OraclePartition, boolean): SnapshotContext<...>
        # getAllTableIds(RelationalSnapshotContext<...>): Set<TableId>
        # lockTablesForSchemaSnapshot(...): void
        # releaseSchemaSnapshotLocks(...): void
        # determineSnapshotOffset(...): void
        # readTableStructure(...): void
        # enhanceOverriddenSelect(...): String
        # getCreateTableEvent(...): SchemaChangeEvent
        # getSnapshotSelect(...): Optional<String>
        # createDataEventsForTableCallable(...): Callable<Void>
        # isTableSnapshotErrorRetriable(SQLException): boolean
        # copyOffset(...): OracleOffsetContext
        + close(): void
    }
    note right of OracleSnapshotChangeEventSource
      PDB support: prepare() / close() call
      setSessionToPdb / resetSessionToCdb.
      Retry on ORA-01466 (table changed
      during AS OF SCN flashback query).
    end note

    class OracleSnapshotContext <<private static>> {
        ~ preSchemaSnapshotSavepoint: Savepoint
        --
        OracleSnapshotContext(OraclePartition, String catalogName, boolean onDemand)
    }

    class OracleDatabaseSchema {
        + ATTRIBUTE_OBJECT_ID: String
        + ATTRIBUTE_DATA_OBJECT_ID: String
        - NO_SUCH_TABLE: TableId
        --
        - ddlParser: OracleDdlParser
        - lobColumnsByTableId: Map<TableId, List<Column>>
        - tableIdCache: Map<String, TableId>
        - valueConverters: OracleValueConverters
        - objectIdToTableId: LRUCacheMap<Long, TableId>
        - extendedStringsSupported: boolean
        - lastObjectTableIdLookup: LastObjectTableIdLookup
        --
        + getTables(): Tables
        + getDdlParser(): OracleDdlParser
        + applySchemaChange(SchemaChangeEvent): void
        + resolveTableId(String, String, String): TableId
        + getTableIdByObjectId(Long, Long): TableId
        + getLobColumnsForTable(TableId): List<Column>
        + isColumnUnavailableValuePlaceholder(Column, Object): boolean
        # buildAndRegisterSchema(Table): void
        # removeSchema(TableId): void
    }
    note right of OracleDatabaseSchema
      LOB cache tracks CLOB/NCLOB/BLOB/
      SQLXML and extended VARCHAR > 4000.
      LRU + last-lookup optimises
      objectId -> TableId resolution.
    end note

    class LastObjectTableIdLookup <<record>> {
        + objectId: Long
        + dataObjectId: Long
        + tableId: TableId
    }

    class OracleValueConverters {
        + UNAVAILABLE_VALUE: Object
        + EMPTY_BLOB_FUNCTION: String
        + EMPTY_CLOB_FUNCTION: String
        + EMPTY_EXTENDED_STRING: String
        --
        + schemaBuilder(Column): SchemaBuilder
        + converter(Column, Field): ValueConverter
        + getUnavailableValuePlaceholderBinary(): byte[]
        + getUnavailableValuePlaceholderString(): String
    }
}

' ─────────────────────────────────────────────
' Snapshot lock strategies
' ─────────────────────────────────────────────
package "io.debezium.connector.oracle.snapshot.lock" {

    class SharedSnapshotLock {
        <<@ConnectorSpecific(OracleConnector)>>
        --
        + name(): String
        + configure(Map<String,?>): void
        + tableLockingStatement(Duration, String): Optional<String>
    }
    note bottom of SharedSnapshotLock
      LOCK TABLE %s IN ROW SHARE MODE
    end note

    class NoSnapshotLock {
        <<@ConnectorSpecific(OracleConnector)>>
        --
        + name(): String
        + configure(Map<String,?>): void
        + tableLockingStatement(Duration, String): Optional<String>
    }
    note bottom of NoSnapshotLock
      Returns Optional.empty() — no locking
    end note
}

' ─────────────────────────────────────────────
' Snapshot query strategy
' ─────────────────────────────────────────────
package "io.debezium.connector.oracle.snapshot.query" {

    class SelectAllSnapshotQuery {
        <<@ConnectorSpecific(OracleConnector)>>
        --
        - beanRegistry: BeanRegistry
        --
        + name(): String
        + configure(Map<String,?>): void
        + injectBeanRegistry(BeanRegistry): void
        + snapshotQuery(String, List<String>): Optional<String>
    }
    note right of SelectAllSnapshotQuery
      Generates: SELECT %s FROM %s AS OF SCN %s
      Reads current SCN from OracleOffsetContext
      via BeanRegistry injection.
    end note
}

' ─────────────────────────────────────────────
' Support / referenced types (lightweight)
' ─────────────────────────────────────────────
package "io.debezium.connector.oracle (support)" #EEF2E6 {
    class OracleConnectorConfig {
        + getPdbName(): String
        + getAdapter(): ConnectorAdapter
        + getSnapshotRetryDatabaseErrorsMaxRetries(): int
    }
    class OracleConnection {
        + setSessionToPdb(String): void
        + resetSessionToCdb(): void
    }
    class SnapshotterService <<interface-like>> {
        + getSnapshotLock(): SnapshotLock
        + getSnapshotQuery(): SnapshotQuery
        + getSnapshotter(): Snapshotter
    }
}

' ─────────────────────────────────────────────
' Inheritance
' ─────────────────────────────────────────────
OracleSnapshotChangeEventSource --|> RelationalSnapshotChangeEventSource
OracleSnapshotContext           --|> RelationalSnapshotContext
OracleDatabaseSchema            --|> HistorizedRelationalDatabaseSchema
SharedSnapshotLock              ..|> SnapshotLock
NoSnapshotLock                  ..|> SnapshotLock
SelectAllSnapshotQuery          ..|> SnapshotQuery
SelectAllSnapshotQuery          ..|> BeanRegistryAware

' ─────────────────────────────────────────────
' Composition / association
' ─────────────────────────────────────────────
OracleSnapshotChangeEventSource *-- OracleConnectorConfig      : connectorConfig
OracleSnapshotChangeEventSource *-- OracleConnection           : jdbcConnection
OracleSnapshotChangeEventSource *-- OracleDatabaseSchema       : databaseSchema
OracleSnapshotChangeEventSource ..> SnapshotterService         : uses
OracleSnapshotChangeEventSource ..> OracleSnapshotContext      : creates

OracleDatabaseSchema *-- OracleValueConverters                 : valueConverters
OracleDatabaseSchema *-- LastObjectTableIdLookup               : lastObjectTableIdLookup

@enduml
