@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #EEF2FF
    BorderColor #6366F1
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F59E0B
}

title PostgreSQL Connector Core

' ─────────────────────────────────────────────
' External / Base classes
' ─────────────────────────────────────────────

abstract class RelationalBaseSourceConnector <<external>> {
}

abstract class RelationalDatabaseConnectorConfig <<external>> {
}

abstract class JdbcConnection <<external>> {
}

abstract class "CommonOffsetContext<SourceInfo>" as CommonOffsetContext <<external>> {
}

interface ConfigDescriptor <<external>> {
}

interface "OffsetContext.Loader<PostgresOffsetContext>" as OffsetContextLoader <<external>> {
    +load(offset: Map<String, ?>): PostgresOffsetContext
}

class TransactionContext <<external>> {
}

class "IncrementalSnapshotContext<TableId>" as IncrementalSnapshotContext <<external>> {
}

' ─────────────────────────────────────────────
' io.debezium.connector.postgresql
' ─────────────────────────────────────────────

package "io.debezium.connector.postgresql" {

    class PostgresConnector {
        - props: Map<String, String>
        {static} + READ_ONLY_SUPPORTED_VERSION: int = 13
        --
        + version(): String
        + taskClass(): Class<? extends Task>
        + start(props: Map<String, String>): void
        + stop(): void
        + taskConfigs(maxTasks: int): List<Map<String, String>>
        + config(): ConfigDef
        + exactlyOnceSupport(connectorConfig: Map): ExactlyOnceSupport
        # validateConnection(configValues: Map, config: Configuration): void
        # validateAllFields(config: Configuration): Map<String, ConfigValue>
        {static} - checkReadOnlyMode(conn: PostgresConnection, cfg: PostgresConnectorConfig): void
        {static} - checkLoginReplicationRoles(conn: PostgresConnection): void
        {static} - testConnection(conn: PostgresConnection): void
    }

    class PostgresConnectorConfig {
        - logicalDecodingMessageFilter: LogicalDecodingMessageFilter
        - hStoreHandlingMode: HStoreHandlingMode
        - intervalHandlingMode: IntervalHandlingMode
        - schemaRefreshMode: SchemaRefreshMode
        - lsnFlushMode: LsnFlushMode
        - snapshotMode: SnapshotMode
        - snapshotIsolationMode: SnapshotIsolationMode
        - snapshotLockingMode: SnapshotLockingMode
        - readOnlyConnection: boolean
        - offsetSlotMismatchStrategy: OffsetSlotMismatchStrategy
        {static} + PLUGIN_NAME: Field
        {static} + SLOT_NAME: Field
        {static} + SSL_MODE: Field
        {static} + SNAPSHOT_MODE: Field
        {static} + ALL_FIELDS: Field.Set
        --
        + PostgresConnectorConfig(config: Configuration)
        + databaseName(): String
        + plugin(): LogicalDecoder
        + slotName(): String
        + slotSeekToKnownOffsetOnStart(): boolean
        + publicationName(): String
        + isReadOnlyConnection(): boolean
        + getSnapshotMode(): SnapshotMode
        + getJdbcConfig(): JdbcConfiguration
        {static} + configDef(): ConfigDef
        + getConnectionValidationTimeout(): Duration
        + maxRetries(): int
        + retryDelay(): Duration
    }

    enum SnapshotMode <<PostgresConnectorConfig>> {
        ALWAYS
        INITIAL
        NO_DATA
        INITIAL_ONLY
        WHEN_NEEDED
        CONFIGURATION_BASED
        CUSTOM
    }

    enum LogicalDecoder <<PostgresConnectorConfig>> {
        PGOUTPUT
        DECODERBUFS
        --
        {abstract} + messageDecoder(config, connection): MessageDecoder
    }

    enum OffsetSlotMismatchStrategy <<PostgresConnectorConfig>> {
        FAIL
        WARN
        TRUST_GREATER_LSN
    }

    enum SecureConnectionMode <<PostgresConnectorConfig>> {
        DISABLED
        ALLOW
        PREFER
        REQUIRED
        VERIFY_CA
        VERIFY_FULL
    }

    class PostgresOffsetContext {
        - sourceInfoSchema: Schema
        - lastSnapshotRecord: boolean
        - lastCompletelyProcessedLsn: Lsn
        - lastCommitLsn: Lsn
        - streamingStoppingLsn: Lsn
        - transactionContext: TransactionContext
        - incrementalSnapshotContext: IncrementalSnapshotContext<TableId>
        {static} + LAST_COMPLETELY_PROCESSED_LSN_KEY: String = "lsn_proc"
        {static} + LAST_COMMIT_LSN_KEY: String = "lsn_commit"
        --
        + getOffset(): Map<String, ?>
        + preSnapshotStart(onDemand: boolean): void
        + preSnapshotCompletion(): void
        + updateWalPosition(lsn: Lsn, lastProcessedLsn: Lsn, commitTime: Instant, txId: Long, xmin: Long, tableId: TableId, type: Operation): void
        + updateCommitPosition(lsn: Lsn, lastProcessedLsn: Lsn): void
        + updateOrigin(originName: String, originLsn: Lsn): void
        + lsn(): Lsn
        + lastCompletelyProcessedLsn(): Lsn
        + lastCommitLsn(): Lsn
        + xmin(): Long
        {static} + initialContext(config: PostgresConnectorConfig, conn: PostgresConnection, clock: Clock): PostgresOffsetContext
        + event(tableId: DataCollectionId, instant: Instant): void
        + getTransactionContext(): TransactionContext
        + getIncrementalSnapshotContext(): IncrementalSnapshotContext<?>
    }

    class "PostgresOffsetContext.Loader" as OffsetContextLoaderImpl {
        + load(offset: Map<String, ?>): PostgresOffsetContext
    }
}

note bottom of PostgresConnectorConfig
  Additional inner enums (not shown):
  HStoreHandlingMode {JSON, MAP}
  IntervalHandlingMode {NUMERIC, STRING}
  SnapshotIsolationMode {SERIALIZABLE, READ_COMMITTED, ...}
  SnapshotLockingMode {SHARED, NONE, CUSTOM}
  AutoCreateMode {ALL_TABLES, FILTERED, NO_TABLES}
  LsnFlushMode {CONNECTOR, DRIVER, CONNECTOR_AND_DRIVER}
  LsnFlushTimeoutAction {WARN, IGNORE}
end note

' ─────────────────────────────────────────────
' io.debezium.connector.postgresql.connection
' ─────────────────────────────────────────────

package "io.debezium.connector.postgresql.connection" {

    class PostgresConnection {
        - typeRegistry: TypeRegistry
        - defaultValueConverter: PostgresDefaultValueConverter
        {static} + CONNECTION_STREAMING: String
        {static} + CONNECTION_SLOT_INFO: String
        {static} + CONNECTION_DROP_SLOT: String
        {static} + CONNECTION_HEARTBEAT: String
        {static} + CONNECTION_GENERAL: String
        {static} - MAX_ATTEMPTS_FOR_OBTAINING_REPLICATION_SLOT: int = 900
        {static} # FACTORY: ConnectionFactory
        --
        + PostgresConnection(config: JdbcConfiguration, connectionUsage: String)
        + PostgresConnection(config: PostgresConnectorConfig, typeRegistry: TypeRegistry, connectionUsage: String)
        + connectionString(): String
        + getReplicationSlotState(slotName: String, pluginName: String): SlotState
        + getSlotXmin(slotName: String, pluginName: String): Long
        + dropReplicationSlot(slotName: String): boolean
        + dropPublication(publicationName: String): boolean
        + currentTransactionId(): Long
        + currentXLogLocation(): long
        + serverInfo(): ServerInfo
        + validateLogPosition(partition: Partition, offset: OffsetContext, config: CommonConnectorConfig): boolean
        {static} + createTypeRegistry(config: JdbcConfiguration): TypeRegistry
    }

    class "ServerInfo.ReplicationSlot" as ReplicationSlot {
        - active: boolean
        - latestFlushedLsn: Lsn
        - restartLsn: Lsn
        - catalogXmin: Long
        {static} + INVALID: ReplicationSlot
        --
        + asSlotState(): SlotState
    }
}

' ─────────────────────────────────────────────
' io.debezium.connector.postgresql.spi
' ─────────────────────────────────────────────

package "io.debezium.connector.postgresql.spi" {

    class SlotState {
        - latestFlushedLsn: Lsn
        - restartLsn: Lsn
        - catalogXmin: Long
        - active: boolean
        --
        + SlotState(lastFlushLsn: Lsn, restartLsn: Lsn, catXmin: Long, active: boolean)
        + slotLastFlushedLsn(): Lsn
        + slotRestartLsn(): Lsn
        + slotCatalogXmin(): Long
        + slotIsActive(): boolean
    }
}

' ─────────────────────────────────────────────
' Inheritance relationships
' ─────────────────────────────────────────────

PostgresConnector --|> RelationalBaseSourceConnector
PostgresConnector ..|> ConfigDescriptor
PostgresConnectorConfig --|> RelationalDatabaseConnectorConfig
PostgresConnection --|> JdbcConnection
PostgresOffsetContext --|> CommonOffsetContext

' ─────────────────────────────────────────────
' Inner class / enum nesting
' ─────────────────────────────────────────────

PostgresConnectorConfig +-- SnapshotMode
PostgresConnectorConfig +-- LogicalDecoder
PostgresConnectorConfig +-- OffsetSlotMismatchStrategy
PostgresConnectorConfig +-- SecureConnectionMode
PostgresOffsetContext +-- OffsetContextLoaderImpl
OffsetContextLoaderImpl ..|> OffsetContextLoader

' ─────────────────────────────────────────────
' Composition / aggregation
' ─────────────────────────────────────────────

PostgresOffsetContext *-- "1" TransactionContext : contains
PostgresOffsetContext *-- "1" IncrementalSnapshotContext : contains

' ─────────────────────────────────────────────
' Dependencies
' ─────────────────────────────────────────────

PostgresConnector ..> PostgresConnectorConfig : uses (validates config\n& reads ALL_FIELDS)
PostgresConnector ..> PostgresConnection : creates for\nvalidation

PostgresConnection ..> PostgresConnectorConfig : reads JDBC config
PostgresConnection ..> ReplicationSlot : uses internally\n(fetchReplicationSlotInfo)
PostgresConnection ..> SlotState : returns from\ngetReplicationSlotState()

ReplicationSlot ..> SlotState : converts via\nasSlotState()

PostgresOffsetContext ..> PostgresConnectorConfig : constructor / Loader
PostgresOffsetContext ..> PostgresConnection : initialContext() reads\ncurrentXLogLocation()\ncurrentTransactionId()

@enduml
