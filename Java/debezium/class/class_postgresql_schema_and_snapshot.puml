@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title PostgreSQL Schema & Snapshot

' ─── External / Framework base classes ───────────────────────────────────────
package "io.debezium (framework)" {
    abstract class RelationalDatabaseSchema
    abstract class RelationalSnapshotChangeEventSource<P, O>
    abstract class RelationalSnapshotContext<P, O>
    abstract class JdbcValueConverters
    interface Configurable
}

' ─── Snapshotter SPI ─────────────────────────────────────────────────────────
package "io.debezium.spi.snapshot" {
    interface Snapshotter {
        +name(): String
        +shouldSnapshotData(offsetExists: boolean, snapshotInProgress: boolean): boolean
        +shouldSnapshotSchema(offsetExists: boolean, snapshotInProgress: boolean): boolean
        +shouldStream(): boolean
        +shouldSnapshotOnSchemaError(): boolean
        +shouldSnapshotOnDataError(): boolean
        +shouldStreamEventsStartingFromSnapshot(): boolean
        +snapshotCompleted(): void
        +snapshotAborted(): void
    }
}

Snapshotter ..|> Configurable

' ─── Snapshot mode strategies ────────────────────────────────────────────────
package "io.debezium.snapshot.mode" {
    abstract class BeanAwareSnapshotter {
        #beanRegistry
        ' Base for all concrete snapshot strategies
    }

    class InitialSnapshotter {
        +name(): String
        +shouldSnapshotData(offsetExists, snapshotInProgress): boolean
        +shouldSnapshotSchema(offsetExists, snapshotInProgress): boolean
        +shouldStream(): boolean
        +shouldSnapshotOnSchemaError(): boolean
        +shouldSnapshotOnDataError(): boolean
    }

    class AlwaysSnapshotter {
        +name(): String
        +shouldSnapshotData(offsetExists, snapshotInProgress): boolean
        +shouldSnapshotSchema(offsetExists, snapshotInProgress): boolean
        +shouldStream(): boolean
    }

    class NeverSnapshotter {
        +name(): String
        +shouldSnapshotData(offsetExists, snapshotInProgress): boolean
        +shouldSnapshotSchema(offsetExists, snapshotInProgress): boolean
        +shouldStream(): boolean
    }

    class WhenNeededSnapshotter {
        +name(): String
        +shouldSnapshotData(offsetExists, snapshotInProgress): boolean
        +shouldSnapshotSchema(offsetExists, snapshotInProgress): boolean
        +shouldStream(): boolean
    }

    class InitialOnlySnapshotter {
        +name(): String
        +shouldSnapshotData(offsetExists, snapshotInProgress): boolean
        +shouldSnapshotSchema(offsetExists, snapshotInProgress): boolean
        +shouldStream(): boolean
    }

    class NoDataSnapshotter {
        +name(): String
        +shouldSnapshotData(offsetExists, snapshotInProgress): boolean
        +shouldSnapshotSchema(offsetExists, snapshotInProgress): boolean
        +shouldStream(): boolean
    }

    class RecoverySnapshotter {
        +name(): String
        +shouldSnapshotData(offsetExists, snapshotInProgress): boolean
        +shouldSnapshotSchema(offsetExists, snapshotInProgress): boolean
        +shouldStream(): boolean
    }
}

BeanAwareSnapshotter ..|> Snapshotter
InitialSnapshotter --|> BeanAwareSnapshotter
AlwaysSnapshotter --|> BeanAwareSnapshotter
NeverSnapshotter --|> BeanAwareSnapshotter
WhenNeededSnapshotter --|> BeanAwareSnapshotter
InitialOnlySnapshotter --|> BeanAwareSnapshotter
NoDataSnapshotter --|> BeanAwareSnapshotter
RecoverySnapshotter --|> BeanAwareSnapshotter

' ─── PostgreSQL type system ───────────────────────────────────────────────────
package "io.debezium.connector.postgresql.connection" {
    class PostgresType {
        +{static} UNKNOWN: PostgresType
        -name: String
        -oid: int
        -jdbcId: int
        -parentType: PostgresType
        -elementType: PostgresType
        -typeInfo: TypeInfo
        -modifiers: int
        -enumValues: List<String>
        +isArrayType(): boolean
        +isRootType(): boolean
        +isEnumType(): boolean
        +getOid(): int
        +getJdbcId(): int
        +getElementType(): PostgresType
        +getParentType(): PostgresType
        +getRootType(): PostgresType
        +getEnumValues(): List<String>
        +getDefaultLength(): int
        +getDefaultScale(): int
    }

    class TypeRegistry {
        -nameToType: Map<String, PostgresType>
        -oidToType: Map<Integer, PostgresType>
        -connection: PostgresConnection
        -sqlTypeMapper: SqlTypeMapper
        -geometryOid: int
        -geographyOid: int
        -citextOid: int
        -hstoreOid: int
        -ltreeOid: int
        -vectorOid: int
        +{static} TYPE_NAME_GEOMETRY: String
        +{static} TYPE_NAME_HSTORE: String
        +{static} TYPE_NAME_TSVECTOR: String
        +get(oid: int): PostgresType
        +get(name: String): PostgresType
        +get(schemaName: String, typeName: String): PostgresType
        +addType(type: PostgresType, schemaName: String): void
        +getRegisteredTypes(): Collection<PostgresType>
        +geometryOid(): int
        +geographyOid(): int
        +hstoreOid(): int
        +citextOid(): int
        +ltreeOid(): int
        +getLongTypeNames(): Map<String, String>
    }
}

PostgresType "1" o--> "0..1" PostgresType : parentType\n(domain base)
PostgresType "1" o--> "0..1" PostgresType : elementType\n(array element)
TypeRegistry "1" *--> "many" PostgresType : registers

' ─── Core PostgreSQL connector classes ───────────────────────────────────────
package "io.debezium.connector.postgresql" {

    class PgOid <<constants>> {
        +{static} JSONB_OID: int = 3802
        +{static} INET_OID: int = 869
        +{static} CIDR_OID: int = 650
        +{static} MACADDR_OID: int = 829
        +{static} MACADDR8_OID: int = 774
        +{static} INT4RANGE_OID: int = 3904
        +{static} NUM_RANGE_OID: int = 3906
        +{static} INT8RANGE_OID: int = 3926
        +{static} TSRANGE_OID: int = 3908
        +{static} TSTZRANGE_OID: int = 3910
        +{static} DATERANGE_OID: int = 3912
        +{static} TSVECTOR_OID: int = 3614
    }

    class PostgresValueConverter {
        -typeRegistry: TypeRegistry
        -includeUnknownDatatypes: boolean
        -hStoreMode: HStoreHandlingMode
        -intervalMode: IntervalHandlingMode
        -databaseCharset: Charset
        -jsonFactory: JsonFactory
        -unchangedToastedPlaceholder: UnchangedToastedPlaceholder
        -moneyFractionDigits: int
        +{static} of(config: PostgresConnectorConfig, charset: Charset, typeRegistry: TypeRegistry): PostgresValueConverter
        +schemaBuilder(column: Column): SchemaBuilder
        +numericSchema(column: Column): SchemaBuilder
        +hstoreSchema(): SchemaBuilder
        +moneySchema(): SchemaBuilder
        +arrayElementSchema(column: Column): SchemaBuilder
        +converter(column: Column, field: Field): ValueConverter
    }

    class PostgresSchema {
        +{static} PUBLIC_SCHEMA_NAME: String = "public"
        -tableIdToToastableColumns: Map<TableId, List<String>>
        -relationIdToTableId: Map<Integer, TableId>
        -readToastableColumns: boolean
        -connectorConfig: PostgresConnectorConfig
        +getTableSchemaBuilder(config, converter, defaultValueConverter, registry): TableSchemaBuilder
        +refresh(conn: PostgresConnection, printReplicaIdentityInfo: boolean): void
        +refresh(conn: PostgresConnection, tableId: TableId, refreshToastable: boolean): void
        +refresh(conn: PostgresConnection, tableId: TableId, refreshToastable: boolean, removeGeneratedColumns: boolean): void
        +refreshFromIncrementalSnapshot(conn: PostgresConnection, tableId: TableId): void
        +refreshSchemas(): void
        +refreshToastableColumnsMap(conn: PostgresConnection, tableId: TableId): void
        +isFilteredOut(tableId: TableId): boolean
        +parse(table: String): TableId
        +getToastableColumnsForTableId(tableId: TableId): List<String>
        +applySchemaChangesForTable(relationId: int, table: Table): void
        +tableFor(relationId: int): Table
        +tableInformationComplete(): boolean
    }

    class PostgresSnapshotChangeEventSource {
        -connectorConfig: PostgresConnectorConfig
        -jdbcConnection: PostgresConnection
        -schema: PostgresSchema
        -slotCreatedInfo: SlotCreationResult
        -startingSlotInfo: SlotState
        +getSnapshottingTask(partition: PostgresPartition, offsetContext: PostgresOffsetContext): SnapshottingTask
        +prepare(partition: PostgresPartition, onDemand: boolean): SnapshotContext
        +connectionCreated(ctx: RelationalSnapshotContext): void
        +getAllTableIds(ctx: RelationalSnapshotContext): Set<TableId>
        +lockTablesForSchemaSnapshot(context: ChangeEventSourceContext, ctx: RelationalSnapshotContext): void
        +releaseSchemaSnapshotLocks(ctx: RelationalSnapshotContext): void
        +determineSnapshotOffset(ctx: RelationalSnapshotContext, offsetContext: PostgresOffsetContext): void
        +updateOffsetForSnapshot(offsetContext: PostgresOffsetContext): void
        +readTableStructure(context, ctx, offsetContext, task: SnapshottingTask): void
        +getCreateTableEvent(ctx: RelationalSnapshotContext, table: Table): SchemaChangeEvent
        +getSnapshotSelect(ctx: RelationalSnapshotContext, tableId: TableId, columns: List<String>): Optional<String>
        +setSnapshotTransactionIsolationLevel(deferrable: boolean): void
        +completed(ctx: SnapshotContext): void
        +aborted(ctx: SnapshotContext): void
        +copyOffset(ctx: RelationalSnapshotContext): PostgresOffsetContext
    }

    class PostgresSnapshotContext {
        ' Inner class of PostgresSnapshotChangeEventSource
    }
}

' ─── Inheritance ─────────────────────────────────────────────────────────────
PostgresSchema --|> RelationalDatabaseSchema
PostgresSnapshotChangeEventSource --|> RelationalSnapshotChangeEventSource
PostgresValueConverter --|> JdbcValueConverters
PostgresSnapshotContext --|> RelationalSnapshotContext

' ─── Compositions / associations ─────────────────────────────────────────────
PostgresSnapshotChangeEventSource *--> PostgresSchema : schema
PostgresSnapshotChangeEventSource *--> PostgresConnectorConfig : connectorConfig
PostgresSnapshotChangeEventSource *--> PostgresConnection : jdbcConnection
PostgresSnapshotChangeEventSource +-- PostgresSnapshotContext : <<inner class>>
PostgresSnapshotChangeEventSource ..> SnapshotterService : uses (getSnapshotter,\ngetSnapshotLock,\ngetSnapshotQuery)

PostgresSchema *--> PostgresConnectorConfig : connectorConfig
PostgresSchema ..> PostgresValueConverter : creates via\ngetTableSchemaBuilder()

PostgresValueConverter *--> TypeRegistry : typeRegistry
PostgresValueConverter ..> PgOid : uses OID\nconstants

' ─── Stub references (shown minimally) ───────────────────────────────────────
class PostgresConnectorConfig <<external>>
class PostgresConnection <<external>>
class SnapshotterService <<external>> {
    +getSnapshotter(): Snapshotter
    +getSnapshotLock(): SnapshotLock
    +getSnapshotQuery(): SnapshotQuery
}

@enduml
