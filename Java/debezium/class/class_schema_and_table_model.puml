@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Schema & Table Model

' ─── SPI: base identity abstraction ──────────────────────────────────────
package "io.debezium.spi.schema" {
    interface DataCollectionId {
        +identifier(): String
        +parts(): List<String>
        +databaseParts(): List<String>
        +schemaParts(): List<String>
    }
}

' ─── Schema-level abstractions ────────────────────────────────────────────
package "io.debezium.schema" {

    interface DatabaseSchema<I> {
        +schemaFor(id: I): DataCollectionSchema
        +dataCollectionIds(): Collection<I>
        +tableInformationComplete(): boolean
        +assureNonEmptySchema(): void
        +isHistorized(): boolean
    }

    interface HistorizedDatabaseSchema<I> {
        +recover(offsets: Offsets): void
        +initializeStorage(): void
        +record(event: SchemaChangeEvent, changes: TableChanges): void
    }

    interface DataCollectionSchema {
        +id(): DataCollectionId
        +keySchema(): Schema
        +getEnvelopeSchema(): Envelope
    }

    HistorizedDatabaseSchema --|> DatabaseSchema
}

' ─── Relational model ─────────────────────────────────────────────────────
package "io.debezium.relational" {

    class TableId <<Immutable>> {
        -catalogName: String
        -schemaName: String
        -tableName: String
        -id: String
        +{static} parse(str: String): TableId
        +catalog(): String
        +schema(): String
        +table(): String
        +identifier(): String
        +parts(): List<String>
        +toLowercase(): TableId
        +toDoubleQuoted(): TableId
        +toBracketQuoted(): TableId
        +compareTo(other: TableId): int
        +compareToIgnoreCase(other: TableId): int
    }

    interface Column <<Immutable>> {
        +{static} UNSET_INT_VALUE: int
        +name(): String
        +position(): int
        +jdbcType(): int
        +nativeType(): int
        +typeName(): String
        +typeExpression(): String
        +charsetName(): String
        +length(): int
        +scale(): Optional<Integer>
        +isOptional(): boolean
        +isAutoIncremented(): boolean
        +isGenerated(): boolean
        +defaultValueExpression(): Optional<String>
        +hasDefaultValue(): boolean
        +enumValues(): List<String>
        +comment(): String
        +edit(): ColumnEditor
        +{static} editor(): ColumnEditor
    }

    interface Table <<Immutable>> {
        +id(): TableId
        +columns(): List<Column>
        +columnWithName(name: String): Column
        +primaryKeyColumnNames(): List<String>
        +primaryKeyColumns(): List<Column>
        +filterColumns(predicate: Predicate<Column>): List<Column>
        +retrieveColumnNames(): List<String>
        +defaultCharsetName(): String
        +comment(): String
        +attributes(): List<Attribute>
        +attributeWithName(name: String): Attribute
        +isPrimaryKeyColumn(columnName: String): boolean
        +isAutoIncremented(columnName: String): boolean
        +isGenerated(columnName: String): boolean
        +isOptional(columnName: String): boolean
        +edit(): TableEditor
        +{static} editor(): TableEditor
    }

    interface TableEditor <<NotThreadSafe>> {
        +tableId(): TableId
        +tableId(id: TableId): TableEditor
        +columns(): List<Column>
        +columnWithName(name: String): Column
        +primaryKeyColumnNames(): List<String>
        +addColumns(cols: Column...): TableEditor
        +setColumns(cols: Column...): TableEditor
        +removeColumn(name: String): TableEditor
        +updateColumn(col: Column): TableEditor
        +reorderColumn(name: String, afterName: String): TableEditor
        +renameColumn(oldName: String, newName: String): TableEditor
        +setPrimaryKeyNames(names: String...): TableEditor
        +setUniqueValues(): TableEditor
        +setDefaultCharsetName(charset: String): TableEditor
        +setComment(comment: String): TableEditor
        +addAttribute(attr: Attribute): TableEditor
        +create(): Table
    }

    class TableSchema <<Immutable>> {
        -id: TableId
        -keySchema: Schema
        -valueSchema: Schema
        -envelopeSchema: Envelope
        -keyGenerator: StructGenerator
        -valueGenerator: StructGenerator
        +id(): TableId
        +keySchema(): Schema
        +valueSchema(): Schema
        +getEnvelopeSchema(): Envelope
        +keyFromColumnData(columnData: Object[]): Struct
        +valueFromColumnData(columnData: Object[]): Struct
    }

    interface StructGenerator <<functional>> {
        +generateValue(columnData: Object[]): Struct
    }

    class Tables <<ThreadSafe>> {
        -tablesByTableId: ConcurrentMap<TableId, Table>
        -changes: Set<TableId>
        -tableIdCaseInsensitive: boolean
        -lock: FunctionalReadWriteLock
        +forTable(id: TableId): Table
        +overwriteTable(table: Table): Table
        +subset(filter: TableFilter): Tables
        +tableIds(): Set<TableId>
        +drainChanges(): Set<TableId>
        +size(): int
        +clear(): void
        +clone(): Tables
    }

    interface "Tables.TableFilter" as TableFilter <<functional>> {
        +isIncluded(id: TableId): boolean
    }

    interface "Tables.ColumnNameFilter" as ColumnNameFilter <<functional>> {
        +matches(catalog: String, schema: String,\n  table: String, column: String): boolean
    }

    abstract class RelationalDatabaseSchema {
        #config: RelationalDatabaseConnectorConfig
        #topicNamingStrategy: TopicNamingStrategy<TableId>
        #schemaBuilder: TableSchemaBuilder
        #tableFilter: TableFilter
        #columnFilter: ColumnNameFilter
        #columnMappers: ColumnMappers
        #customKeysMapper: KeyMapper
        #tables: Tables
        -schemasByTableId: ConcurrentMap<TableId, TableSchema>
        +tableIds(): Set<TableId>
        +schemaFor(id: TableId): TableSchema
        +tableFor(id: TableId): Table
        +buildAndRegisterSchema(table: Table): void
        +refresh(table: Table): void
        +refreshSchema(id: TableId): void
        +clearSchemas(): void
        +removeSchema(id: TableId): void
        +tables(): Tables
        +isHistorized(): boolean
    }

    abstract class HistorizedRelationalDatabaseSchema {
        #schemaHistory: SchemaHistory
        #historizedConnectorConfig: HistorizedRelationalDatabaseConnectorConfig
        #recoveredTables: boolean
        +recover(offsets: Offsets): void
        +initializeStorage(): void
        +{abstract} getDdlParser(): DdlParser
        +record(event: SchemaChangeEvent, changes: TableChanges): void
        +isHistorized(): boolean
        +getSchemaHistory(): SchemaHistory
        +storeOnlyCapturedTables(): boolean
        +storeOnlyCapturedDatabases(): boolean
        +skipSchemaChangeEvent(event: SchemaChangeEvent): boolean
    }
}

' ─── Inheritance hierarchy ────────────────────────────────────────────────
RelationalDatabaseSchema             ..|> DatabaseSchema           : implements\n«DatabaseSchema<TableId>»
HistorizedRelationalDatabaseSchema   --|> RelationalDatabaseSchema  : extends
HistorizedRelationalDatabaseSchema   ..|> HistorizedDatabaseSchema  : implements\n«HistorizedDatabaseSchema<TableId>»

TableId    ..|> DataCollectionId : implements
TableSchema ..|> DataCollectionSchema : implements

' ─── Composition inside RelationalDatabaseSchema ─────────────────────────
RelationalDatabaseSchema  *--  Tables                    : tables
RelationalDatabaseSchema  "1" *-- "0..*" TableSchema     : schemasByTableId

' ─── HistorizedRelationalDatabaseSchema extra dependencies ───────────────
HistorizedRelationalDatabaseSchema ..> SchemaHistory : history >
HistorizedRelationalDatabaseSchema ..> DdlParser     : <<creates>> >

' ─── Tables inner functional interfaces (nested) ─────────────────────────
Tables +-- TableFilter
Tables +-- ColumnNameFilter

' ─── Tables content ───────────────────────────────────────────────────────
Tables "1" o-- "0..*" Table : tablesByTableId

' ─── Table structure ──────────────────────────────────────────────────────
Table  "1" *-- "1..*" Column     : columns
Table         ..>      TableId   : identified by
Table         ..>      TableEditor : produces via edit()
TableEditor   ..>      Table     : creates via create()

' ─── TableSchema associations ────────────────────────────────────────────
TableSchema   o--  TableId       : id
TableSchema  *--  StructGenerator : key + value generators

@enduml
