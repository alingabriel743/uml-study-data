@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}
skinparam note {
    BackgroundColor #E8F4FD
    BorderColor #5BA4CF
}

title SQL Server Connector

' ─────────────────────────────────────────────
' External base classes / interfaces (debezium-core)
' ─────────────────────────────────────────────
package "debezium-core" #E9ECEF {
    abstract class RelationalBaseSourceConnector {
    }

    abstract class HistorizedRelationalDatabaseConnectorConfig {
    }

    abstract class JdbcConnection {
        +connect(): JdbcConnection
        +execute(sql: String): void
        +query(sql: String): ResultSet
    }

    abstract class "CommonOffsetContext<SourceInfo>" as CommonOffsetContext {
    }

    abstract class ChangeTable {
        +getSourceTableId(): TableId
        +getCaptureInstance(): String
        +getChangeTableId(): TableId
        +getChangeTableObjectId(): int
    }

    interface ConfigDescriptor {
    }

    interface OffsetContext {
        +getOffset(): Map<String,?>
        +getSourceInfoSchema(): Schema
        +event(dataCollectionId: DataCollectionId, ts: Instant): void
    }

    interface "OffsetContext.Loader<SqlServerOffsetContext>" as OffsetContextLoader {
        +load(offset: Map<String,?>): SqlServerOffsetContext
    }
}

' ─────────────────────────────────────────────
' SQL Server Connector package
' ─────────────────────────────────────────────
package "io.debezium.connector.sqlserver" #D4EDDA {

    class SqlServerConnector <<@SupportsMultiTask>> {
        - properties: Map<String, String>
        --
        + version(): String
        + start(props: Map<String,String>): void
        + stop(): void
        + taskClass(): Class<? extends Task>
        + taskConfigs(maxTasks: int): List<Map<String,String>>
        + config(): ConfigDef
        + getConfigFields(): Field.Set
        + exactlyOnceSupport(config: Map<String,String>): ExactlyOnceSupport
        # validateConnection(configValues: Map, config: Configuration): void
        # validateAllFields(config: Configuration): Map<String,ConfigValue>
        - connect(cfg: SqlServerConnectorConfig): SqlServerConnection
        - buildTaskConfigs(conn: SqlServerConnection, cfg: SqlServerConnectorConfig, maxTasks: int): List<Map<String,String>>
    }

    class SqlServerConnectorConfig {
        + {static} MAX_TRANSACTIONS_PER_ITERATION_CONFIG_NAME: String
        # {static} DEFAULT_PORT: int = 1433
        # {static} DEFAULT_MAX_TRANSACTIONS_PER_ITERATION: int = 500
        - databaseNames: List<String>
        - instanceName: String
        - snapshotMode: SnapshotMode
        - snapshotIsolationMode: SnapshotIsolationMode
        - snapshotLockingMode: SnapshotLockingMode
        - readOnlyDatabaseConnection: boolean
        - maxTransactionsPerIteration: int
        - dataQueryMode: DataQueryMode
        - streamingFetchSize: int
        --
        + SqlServerConnectorConfig(config: Configuration)
        + getDatabaseNames(): List<String>
        + useSingleDatabase(): boolean
        + getJdbcConfig(): SqlServerJdbcConfiguration
        + getSnapshotMode(): SnapshotMode
        + getSnapshotIsolationMode(): SnapshotIsolationMode
        + getSnapshotLockingMode(): Optional<SnapshotLockingMode>
        + isReadOnlyDatabaseConnection(): boolean
        + getMaxTransactionsPerIteration(): int
        + getDataQueryMode(): DataQueryMode
        + getStreamingFetchSize(): int
        + supportsOperationFiltering(): boolean
        + {static} configDef(): ConfigDef
    }

    enum SnapshotMode {
        ALWAYS
        INITIAL
        INITIAL_ONLY
        NO_DATA
        RECOVERY
        WHEN_NEEDED
        CONFIGURATION_BASED
        CUSTOM
    }

    enum SnapshotIsolationMode {
        EXCLUSIVE
        SNAPSHOT
        REPEATABLE_READ
        READ_COMMITTED
        READ_UNCOMMITTED
    }

    enum SnapshotLockingMode {
        EXCLUSIVE
        NONE
        CUSTOM
    }

    enum DataQueryMode {
        FUNCTION
        DIRECT
    }

    class SqlServerConnection {
        + {static} INSTANCE_NAME: String = "instance"
        - config: SqlServerConnectorConfig
        - useSingleDatabase: boolean
        - getAllChangesForTable: String
        - queryFetchSize: int
        - defaultValueConverter: SqlServerDefaultValueConverter
        - optionRecompile: boolean
        --
        + getMaxLsn(databaseName: String): Lsn
        + getMaxTransactionLsn(databaseName: String): Lsn
        + getMinLsn(databaseName: String, changeTable: String): Lsn
        + getNthTransactionLsnFromBeginning(db: String, maxOffset: int): Lsn
        + incrementLsn(databaseName: String, lsn: Lsn): Lsn
        + getChangesForTable(changeTable: SqlServerChangeTable, fromLsn: Lsn, toLsn: Lsn): ResultSet
        + getChangeTables(databaseName: String): List<SqlServerChangeTable>
        + getNewChangeTables(db: String, fromLsn: Lsn, toLsn: Lsn): List<SqlServerChangeTable>
        + getTableSchemaFromTable(db: String, changeTable: SqlServerChangeTable): Table
        + retrieveRealDatabaseName(databaseName: String): String
        + checkIfConnectedUserHasAccessToCDCTable(db: String): boolean
        + validateLogPosition(partition: Partition, offset: OffsetContext, config: CommonConnectorConfig): boolean
        + isAgentRunning(databaseName: String): boolean
        + getDefaultValueConverter(): SqlServerDefaultValueConverter
        - buildGetAllChangesForTableQuery(mode: DataQueryMode, skipped: Set): String
        # {static} createUrlPattern(config: SqlServerConnectorConfig, useSingleDb: boolean): String
    }

    class SqlServerOffsetContext {
        - sourceInfoSchema: Schema
        - transactionContext: TransactionContext
        - incrementalSnapshotContext: IncrementalSnapshotContext<TableId>
        - eventSerialNo: long
        --
        + SqlServerOffsetContext(connectorConfig: SqlServerConnectorConfig, position: TxLogPosition, snapshot: SnapshotType, snapshotCompleted: boolean, eventSerialNo: long, transactionContext: TransactionContext, incrementalSnapshotContext: IncrementalSnapshotContext<TableId>)
        + getOffset(): Map<String,?>
        + getSourceInfoSchema(): Schema
        + getChangePosition(): TxLogPosition
        + getEventSerialNo(): long
        + setChangePosition(position: TxLogPosition, eventCount: int): void
        + isSnapshotCompleted(): boolean
        + event(tableId: DataCollectionId, timestamp: Instant): void
        + getTransactionContext(): TransactionContext
        + getIncrementalSnapshotContext(): IncrementalSnapshotContext<?>
        + getSourceTime(): Instant
    }

    class "SqlServerOffsetContext.Loader" as SqlServerOffsetContextLoader <<static>> {
        + load(offset: Map<String,?>): SqlServerOffsetContext
    }

    class SqlServerChangeTable {
        - {static} CDC_SCHEMA: String = "cdc"
        - startLsn: Lsn
        - stopLsn: Lsn
        - capturedColumns: List<String>
        --
        + SqlServerChangeTable(sourceTableId: TableId, captureInstance: String, changeTableObjectId: int, startLsn: Lsn, capturedColumns: List<String>)
        + getStartLsn(): Lsn
        + getStopLsn(): Lsn
        + setStopLsn(stopLsn: Lsn): void
        + getCapturedColumns(): List<String>
        - {static} resolveChangeTableId(sourceTableId: TableId, captureInstance: String): TableId
    }
}

' ─────────────────────────────────────────────
' Inheritance relationships
' ─────────────────────────────────────────────
SqlServerConnector --|> RelationalBaseSourceConnector
SqlServerConnector ..|> ConfigDescriptor

SqlServerConnectorConfig --|> HistorizedRelationalDatabaseConnectorConfig

SqlServerConnection --|> JdbcConnection

SqlServerOffsetContext --|> CommonOffsetContext
SqlServerOffsetContext ..|> OffsetContext

SqlServerOffsetContextLoader ..|> OffsetContextLoader

SqlServerChangeTable --|> ChangeTable

' ─────────────────────────────────────────────
' Composition / containment
' ─────────────────────────────────────────────
SqlServerConnectorConfig *-- SnapshotMode         : inner enum
SqlServerConnectorConfig *-- SnapshotIsolationMode : inner enum
SqlServerConnectorConfig *-- SnapshotLockingMode   : inner enum
SqlServerConnectorConfig *-- DataQueryMode         : inner enum

SqlServerOffsetContext +-- SqlServerOffsetContextLoader : inner class

' ─────────────────────────────────────────────
' Key dependencies / associations
' ─────────────────────────────────────────────
SqlServerConnector ..> SqlServerConnectorConfig  : creates / reads config
SqlServerConnector ..> SqlServerConnection       : creates via connect()

SqlServerConnection "1" o-- "1" SqlServerConnectorConfig  : holds config
SqlServerConnection ..> SqlServerChangeTable              : returns / accepts
SqlServerConnection ..> SqlServerOffsetContext            : casts offset (validateLogPosition)

SqlServerOffsetContext ..> SqlServerConnectorConfig : constructor param

@enduml
