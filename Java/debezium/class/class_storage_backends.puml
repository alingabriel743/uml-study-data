@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Storage Backends

' ─── External / Kafka Connect types ─────────────────────────────────────────

package "org.apache.kafka.connect.storage\n(Kafka Connect — external)" <<Rectangle>> {

    interface OffsetBackingStore <<external>> {
        +configure(config: WorkerConfig): void
        +start(): void
        +stop(): void
        +get(keys: Collection<ByteBuffer>): Future<Map>
        +set(values: Map<ByteBuffer,ByteBuffer>, cb: Callback): Future<Void>
        +connectorPartitions(connectorName: String): Set
    }

    abstract class MemoryOffsetBackingStore <<external>> {
        #data: Map<ByteBuffer,ByteBuffer>
        +start(): void
        +stop(): void
        +get(keys: Collection<ByteBuffer>): Future<Map>
        +set(values: Map<ByteBuffer,ByteBuffer>, cb: Callback): Future<Void>
        #save(): void
    }

    class FileOffsetBackingStore <<external>> {
    }

    class KafkaOffsetBackingStore <<external>> {
    }

    MemoryOffsetBackingStore ..|> OffsetBackingStore
    FileOffsetBackingStore ..|> OffsetBackingStore
    KafkaOffsetBackingStore ..|> OffsetBackingStore
}

' ─── Redis Storage Backend ───────────────────────────────────────────────────

package "io.debezium.storage.redis" {

    interface RedisClient {
        +disconnect(): void
        +close(): void
        +xadd(key: String, hash: Map<String,String>): String
        +xrange(key: String): List<Map<String,String>>
        +xlen(key: String): long
        +hgetAll(key: String): Map<String,String>
        +hset(key: byte[], field: byte[], value: byte[]): long
        +waitReplicas(replicas: int, timeout: long): long
        +info(section: String): String
        +clientList(): String
    }

    class JedisClient {
        -jedis: Jedis
        +JedisClient(jedis: Jedis)
    }

    class JedisClusterClient {
        -jedisCluster: JedisCluster
        -{static} MAX_ATTEMPTS: int = 10
        -{static} DELAY_MILLIS: int = 200
        +JedisClusterClient(jedisCluster: JedisCluster)
        +waitReplicas(): void
        +clientList(): void
        +xadd(hashes: List): List<String>
    }

    class WaitReplicasRedisClient {
        -delegate: RedisClient
        -replicas: int
        -timeout: long
        -retry: boolean
        -delay: long
        +WaitReplicasRedisClient(delegate: RedisClient, replicas: int, timeout: long, retry: boolean, delay: long)
        +hset(key: byte[], field: byte[], value: byte[]): long
        +xadd(key: String, hash: Map): String
    }

    class RedisConnection {
        -address: String
        -dbIndex: int
        -user: String
        -password: String
        -connectionTimeout: int
        -socketTimeout: int
        -sslEnabled: boolean
        -clusterEnabled: boolean
        +{static} getInstance(config: RedisCommonConfig): RedisConnection
        +getRedisClient(clientName: String, waitEnabled: boolean, waitTimeout: long, waitRetry: boolean, waitRetryDelay: long): RedisClient
        +validateHostPort(address: String): void
    }

    class RedisCommonConfig {
        -address: String
        -dbIndex: int
        -user: String
        -password: String
        -sslEnabled: boolean
        -hostnameVerificationEnabled: boolean
        -initialRetryDelay: Integer
        -maxRetryDelay: Integer
        -maxRetryCount: Integer
        -connectionTimeout: Integer
        -socketTimeout: Integer
        -waitEnabled: boolean
        -waitTimeout: long
        -waitRetryEnabled: boolean
        -waitRetryDelay: long
        -clusterEnabled: boolean
        +RedisCommonConfig(config: Configuration, prefix: String)
        +init(config: Configuration): void
        +getAllConfigurationFields(): List<Field>
    }

    JedisClient ..|> RedisClient
    JedisClusterClient ..|> RedisClient
    WaitReplicasRedisClient ..|> RedisClient
    WaitReplicasRedisClient o-- RedisClient : delegate
    RedisConnection ..> RedisClient : creates
}

package "io.debezium.storage.redis.offset" {

    class RedisOffsetBackingStoreConfig {
        -redisKeyName: String
        +RedisOffsetBackingStoreConfig(config: Configuration)
        +init(config: Configuration): void
        +getRedisKeyName(): String
        +getAllConfigurationFields(): List<Field>
    }

    class RedisOffsetBackingStore {
        -config: RedisOffsetBackingStoreConfig
        -client: volatile RedisClient
        +configure(workerConfig: WorkerConfig): void
        +configure(config: RedisOffsetBackingStoreConfig): void
        +start(): void
        +stop(): void
        -connect(): void
        -load(): void
        +save(): void
        +connectorPartitions(connectorName: String): Set
    }

    RedisOffsetBackingStoreConfig --|> RedisCommonConfig
    RedisOffsetBackingStore --|> MemoryOffsetBackingStore
    RedisOffsetBackingStore *-- RedisOffsetBackingStoreConfig : config
    RedisOffsetBackingStore --> RedisClient : uses
    RedisOffsetBackingStore ..> RedisConnection : creates via getInstance()
}

' ─── JDBC Storage Backend ────────────────────────────────────────────────────

package "io.debezium.storage.jdbc" {

    class JdbcCommonConfig {
        -jdbcUrl: String
        -user: String
        -password: String
        -waitRetryDelay: Duration
        -maxRetryCount: int
        +JdbcCommonConfig(config: Configuration, prefix: String)
        +init(config: Configuration): void
    }

    class RetriableConnection {
        +executeWithRetry(consumer: ConnectionConsumer, operation: String, withCommit: boolean): void
        +close(): void
    }
}

package "io.debezium.storage.jdbc.offset" {

    class JdbcOffsetBackingStoreConfig {
        -tableName: String
        -tableCreate: String
        -tableSelect: String
        -tableDelete: String
        -tableInsert: String
        +JdbcOffsetBackingStoreConfig(config: Configuration)
        +init(config: Configuration): void
        +getTableName(): String
        +getTableCreate(): String
        +getTableSelect(): String
        +getTableDelete(): String
        +getTableInsert(): String
    }

    class JdbcOffsetBackingStore {
        -config: JdbcOffsetBackingStoreConfig
        -data: ConcurrentHashMap<String,String>
        -executor: ExecutorService
        -recordInsertSeq: AtomicInteger
        -conn: RetriableConnection
        +configure(workerConfig: WorkerConfig): void
        +start(): void
        +stop(): void
        +get(keys: Collection<ByteBuffer>): Future<Map>
        +set(values: Map<ByteBuffer,ByteBuffer>, cb: Callback): Future<Void>
        -save(): void
        -load(): void
        -initializeTable(): void
        +connectorPartitions(connectorName: String): Set
    }

    JdbcOffsetBackingStoreConfig --|> JdbcCommonConfig
    JdbcOffsetBackingStore ..|> OffsetBackingStore
    JdbcOffsetBackingStore *-- JdbcOffsetBackingStoreConfig : config
    JdbcOffsetBackingStore *-- RetriableConnection : conn
}

' ─── Kubernetes ConfigMap Backend ────────────────────────────────────────────

package "io.debezium.storage.configmap" {

    class ConfigMapOffsetStore {
        +configure(workerConfig: WorkerConfig): void
        +start(): void
        +stop(): void
        +get(keys: Collection<ByteBuffer>): Future<Map>
        +set(values: Map<ByteBuffer,ByteBuffer>, cb: Callback): Future<Void>
        +connectorPartitions(connectorName: String): Set
    }

    ConfigMapOffsetStore ..|> OffsetBackingStore
}

@enduml
