    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2E86C1
}
skinparam enum {
    BackgroundColor #FEF9E7
    BorderColor #D4AC0D
}
skinparam abstractClass {
    BackgroundColor #F4ECF7
    BorderColor #7D3C98
}

title Utility Classes — debezium-util

' ─────────────────────────────────────────────
'  io.debezium.util
' ─────────────────────────────────────────────
package "io.debezium.util" {

    class MathOps <<immutable>> <<utility>> {
        --
        +{static} add(Number, Number): Number
        +{static} add(Short, Number): Number
        +{static} add(Integer, Number): Number
        +{static} add(Long, Number): Number
        +{static} add(Float, Number): Number
        +{static} add(Double, Number): Number
        +{static} add(BigInteger, Number): Number
        +{static} add(BigDecimal, Number): Number
        +{static} add(AtomicInteger, Number): Number
        +{static} add(AtomicLong, Number): Number
        --
        -MathOps()
    }

    class Strings <<thread-safe>> <<utility>> {
        --
        +{static} setOf(String, Function, Function): Set<T>
        +{static} listOf(String, Function, Function): List<T>
        +{static} setOfRegex(String, int): Set<Pattern>
        +{static} listOfRegex(String, int): List<Pattern>
        +{static} splitLines(String): List<String>
        +{static} join(CharSequence, Iterable<T>): String
        +{static} trim(String): String
        +{static} pad(String, ...): String
        +{static} justify(Justify, ...): String
        +{static} asNumber(String): Number
        +{static} asDuration(String): Duration
        +{static} replaceVariables(String, Function): String
        +{static} isNullOrEmpty(String): boolean
        +{static} isUuid(String): boolean
        +{static} mask(String, String, String...): String
        +{static} toSnakeCase(String): String
        +{static} hexStringToByteArray(String): byte[]
    }

    interface CharacterPredicate <<Strings inner>> {
        +test(char): boolean
    }

    enum Justify <<Strings inner>> {
        LEFT
        RIGHT
        CENTER
    }

    class RegExSplitter <<Strings inner>> {
        +{static} split(String, int): String[]
        +tokenize(CharacterStream, Tokens): void
    }

    class IoUtil <<immutable>> <<utility>> {
        -{static} LOGGER: Logger
        --
        +{static} readBytes(InputStream): byte[]
        +{static} readBytes(File): byte[]
        +{static} readLines(InputStream, Consumer<String>): void
        +{static} readLines(Path, Consumer<String>): void
        +{static} read(InputStream): String
        +{static} read(File): String
        +{static} getResourceAsStream(String, ClassLoader, ...): InputStream
        +{static} createDirectory(Path): File
        +{static} createFile(Path): File
        +{static} delete(File): void
        +{static} getAvailablePort(): int
        +{static} loadProperties(ClassLoader, String): Properties
        +{static} readClassPathResource(String): String
    }

    interface Clock {
        +{static} SYSTEM: Clock
        --
        +{abstract} currentTimeInMillis(): long
        +{default} currentTime(): Instant
        +{default} currentTimeInNanos(): long
        +{default} currentTimeInMicros(): long
        +{default} currentTimeAsInstant(): Instant
        +{static} system(): Clock
    }

    abstract class Stopwatch {
        +{abstract} start(): Stopwatch
        +{abstract} stop(): Stopwatch
        +{abstract} durations(): Durations
        --
        +{static} reusable(): Stopwatch
        +{static} accumulating(): Stopwatch
        +{static} multiple(): StopwatchSet
    }

    interface "Stopwatch.Durations" as StopwatchDurations <<Stopwatch inner>> {
        +statistics(): Statistics
    }

    interface "Stopwatch.Statistics" as StopwatchStatistics <<Stopwatch inner>> {
        +getCount(): long
        +getMaximum(): Duration
        +getMinimum(): Duration
        +getTotal(): Duration
        +getAverage(): Duration
    }

    interface "Stopwatch.StopwatchSet" as StopwatchSet <<Stopwatch inner>> {
        +create(): Stopwatch
        +await(): void
        +await(long, TimeUnit): void
    }

    class Collect <<utility>> {
        --
        +{static} fixedSizeMap(int): Map<K,V>
        +{static} unmodifiableSet(T...): Set<T>
        +{static} arrayListOf(T, T...): List<T>
        +{static} mapOf(K, V): Map<K,V>
        +{static} hashMapOf(K, V): Map<K,V>
        +{static} propertiesOf(String, String): Properties
        +{static} set(List<T>, int, T, T): void
        +{static} minus(Set<T>, Set<T>): Set<T>
        +{static} isNullOrEmpty(Collection<T>): boolean
    }
}

' ─────────────────────────────────────────────
'  io.debezium.text
' ─────────────────────────────────────────────
package "io.debezium.text" {

    class TokenStream <<not-thread-safe>> {
        +{static} ANY_VALUE: String
        +{static} ANY_TYPE: int
        #inputString: String
        -caseSensitive: boolean
        -tokenizer: Tokenizer
        -tokenIterator: ListIterator<Token>
        -currentToken: Token
        --
        +TokenStream(String, Tokenizer, boolean)
        +start(): TokenStream
        +rewind(): void
        +mark(): Marker
        +rewind(Marker): boolean
        +advance(Marker): boolean
        +consume(): String
        +peek(): String
        +consume(String): TokenStream
        +consume(char): TokenStream
        +consume(int): TokenStream
        +canConsume(String): boolean
        +canConsumeAnyOf(String, String...): boolean
        +matches(String): boolean
        +matchesAnyOf(String, String...): boolean
        +hasNext(): boolean
        +previousPosition(): Position
        +nextPosition(): Position
        +getContentFrom(Marker): String
    }

    interface "TokenStream.Tokenizer" as Tokenizer <<TokenStream inner>> {
        +tokenize(CharacterStream, Tokens): void
    }

    interface "TokenStream.CharacterStream" as TSCharStream <<TokenStream inner>> {
        +hasNext(): boolean
        +next(): char
        +isNext(char): boolean
        +index(): int
        +position(): Position
    }

    interface "TokenStream.Tokens" as TSTokens <<TokenStream inner>> {
        +addToken(Position, int, int, int): void
        +addToken(int, int, int): void
    }

    interface "TokenStream.Token" as TSToken <<TokenStream inner>> {
        +type(): int
        +startIndex(): int
        +endIndex(): int
        +length(): int
        +value(): String
        +position(): Position
        +matches(String): boolean
        +matches(char): boolean
        +matches(int): boolean
        +withType(int): Token
    }

    class "TokenStream.Marker" as TSMarker <<TokenStream inner>> {
        +compareTo(Marker): int
    }

    class "TokenStream.CaseSensitiveToken" as CaseSensToken <<TokenStream inner>> {
    }

    class "TokenStream.CaseInsensitiveToken" as CaseInsensToken <<TokenStream inner>> {
    }

    abstract class "TokenStream.TokenFactory" as TSTokenFactory <<TokenStream inner>> {
    }

    class "TokenStream.CaseSensitiveTokenFactory" as CaseSensFactory <<TokenStream inner>> {
    }

    class "TokenStream.CaseInsensitiveTokenFactory" as CaseInsensFactory <<TokenStream inner>> {
    }

    class "TokenStream.CharacterArrayStream" as CharArrayStream <<TokenStream inner>> {
    }
}

