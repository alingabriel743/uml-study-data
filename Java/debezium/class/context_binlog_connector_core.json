  "inheritance_hierarchy": {
    "BinlogConnector": "RelationalBaseSourceConnector → BaseSourceConnector (Kafka Connect SourceConnector)",
    "BinlogConnectorConfig": "HistorizedRelationalDatabaseConnectorConfig → RelationalDatabaseConnectorConfig → CommonConnectorConfig",
