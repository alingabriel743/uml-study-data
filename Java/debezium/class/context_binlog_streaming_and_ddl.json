  "event_handler_registration": {
    "note": "Registered in execute() via eventHandlers EnumMap, dispatched in onEvent()",
    "handlers": [
      "STOP → handleServerStop(O, Event)",
      "HEARTBEAT → handleServerHeartbeat(P, O, Event)",
      "INCIDENT → handleServerIncident(P, O, Event)",
      "ROTATE → handleRotateLogsEvent(O, Event)",
      "TABLE_MAP → handleUpdateTableMetadata(P, O, Event)",
      "QUERY → handleQueryEvent(P, O, Event) — triggers DDL parsing via schema",
      "TRANSACTION_PAYLOAD → handleTransactionPayload(P, O, ChangeEventSourceContext, Event)",
      "WRITE_ROWS/EXT_WRITE_ROWS → handleInsert(P, O, Event)",
      "UPDATE_ROWS/EXT_UPDATE_ROWS → handleUpdate(P, O, Event)",
      "DELETE_ROWS/EXT_DELETE_ROWS → handleDelete(P, O, Event)",
      "VIEW_CHANGE → viewChange(O, Event)",
      "XA_PREPARE → prepareTransaction(O, Event)",
      "XID → handleTransactionCompletion(P, O, Event)",
      "GTID (abstract getGtidEventType()) → handleGtidEvent(P, O, Event, Predicate<String>)"
    ]
  },

  "gtid_tracking": {
    "flow": [
      "execute(): reads GtidSet from server via connection.knownGtidSet()",
      "execute(): filters with connection.filterGtidSet()",
      "execute(): calls client.setGtidSet() + effectiveOffsetContext.setCompletedGtidSet() + initializeGtidSet()",
      "handleGtidEvent() [abstract]: called on GTID event; subclasses update offsetContext with new GTID",
      "setGtidChanged(String gtid): protected helper, calls offsetContext.resetGtidSet()",
      "BinlogOffsetContext.setCompletedGtidSet(String): stores GTID_SET_KEY='gtids' in offset map"
    ],
    "config_fields": ["GTID_SOURCE_INCLUDES", "GTID_SOURCE_EXCLUDES", "GTID_SOURCE_FILTER_DML_EVENTS", "IGNORE_GTID_ON_RECOVERY"]
  },

  "ddl_parsing_flow": [
    "handleQueryEvent() receives QUERY binlog event with DDL SQL",
    "handleQueryEvent() calls schema.applySchemaChange(SchemaChangeEvent)",
    "BinlogDatabaseSchema.applySchemaChange() calls ddlParser.parse() (AbstractDdlParser/AntlrDdlParser)",
    "AntlrDdlParser.parse() tokenizes DDL → builds ParseTree → walks with AntlrDdlParserListener",
    "MySqlAntlrDdlParserListener/MariaDbAntlrDdlParserListener updates Tables model",
    "BinlogDatabaseSchema.applySchemaChange() handles CREATE/ALTER/DROP: buildAndRegisterSchema() or removeSchema()",
    "DDL is also stored in schema history via record()"
  ],

  "important_notes": [
    "BinlogStreamingChangeEventSource is abstract; MySQL/MariaDB connectors provide concrete implementations",
    "'BinlogAntlrDdlParser' in scope = conceptual label; actual classes are MySqlAntlrDdlParser and MariaDbAntlrDdlParser",
    "BinaryLogClient is from mysql-binlog-connector library (shyiko), registered as EventListener",
    "GTID tracking is split: BinlogStreamingChangeEventSource handles client setup; BinlogOffsetContext stores state",
    "BinlogDatabaseSchema.assignTableNumber() maps binlog table numbers to TableId (cleared on ROTATE event)",
    "ReaderThreadLifecycleListener inner class handles connect/disconnect/failure callbacks from BinaryLogClient",
    "eventHandlers EnumMap uses BlockingConsumer<Event> — event dispatch is synchronous in binlog reader thread"
  ]
}
