  "key_relationships": [
    "JdbcConfiguration extends Configuration",
    "CommonConnectorConfig composes Configuration (field: config)",
    "CommonConnectorConfig composes DefaultBeanRegistry + DefaultServiceRegistry",
    "RelationalDatabaseConnectorConfig extends CommonConnectorConfig",
    "RelationalDatabaseConnectorConfig composes JdbcConfiguration (field: jdbcConfig)",
    "RelationalDatabaseConnectorConfig composes RelationalTableFilters + ColumnNameFilter",
    "Field.Set composes Map<String, Field>",
    "Field uses Validator (field), Recommender (field), GroupEntry (field)",
    "Field.Validator uses Configuration + Field + ValidationOutput (method params)",
    "Field.Recommender uses Configuration + Field (method params)",
    "CommonConnectorConfig declares static final Field instances (many)",
    "RelationalDatabaseConnectorConfig declares static final Field instances (many)",
    "All enum types (Version, BinaryHandlingMode, etc.) implement EnumeratedValue interface"
  ],

  "key_patterns": [
    "Field is immutable — all with*() methods return new Field copies (fluent builder clone pattern)",
    "Configuration is an interface; instantiated via static factory methods (from, empty, create/build)",
    "JdbcConfiguration uses Adapter pattern — adapt() wraps a Configuration without subclassing",
    "CommonConnectorConfig constructor reads all config values into typed final fields upfront",
    "RelationalDatabaseConnectorConfig uses config.subset(DATABASE_CONFIG_PREFIX, true) to extract JDBC config",
    "Field.group() registers Fields to Kafka ConfigDef, converting Debezium validators to Kafka validators",
    "Validators compose via Validator.and() — supports chained multi-validator rules"
  ],

  "important_notes": [
    "Field uses Kafka ConfigDef.Type, ConfigDef.Width, ConfigDef.Importance as metadata types",
    "Configuration.validate() delegates to Field.validate() per field — walks dependents recursively",
    "CommonConnectorConfig.getConfig() is @Deprecated — callers should use typed accessor methods",
    "RelationalDatabaseConnectorConfig merges database.* prefix config with driver.* prefix config into jdbcConfig",
    "EnumeratedValue is a shared interface for all enum-based config options with getValue() + static parse()",
    "Field.Set is the container type used to register groups of fields (e.g. ALL_FIELDS in each config class)",
    "INTERNAL_PREFIX = 'internal.' used by createInternal() for framework-internal fields not exposed to users"
  ],

