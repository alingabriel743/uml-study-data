  "key_relationships": [
    "AbstractDdlParser implements DdlParser",
    "DdlChanges implements DdlParserListener",
    "AbstractDdlParser COMPOSES DdlChanges (ddlChanges field, created in constructor)",
    "AbstractSchemaHistory implements SchemaHistory",
    "MemorySchemaHistory extends AbstractSchemaHistory",
    "HistorizedRelationalDatabaseSchema extends RelationalDatabaseSchema",
    "HistorizedRelationalDatabaseSchema implements HistorizedDatabaseSchema<TableId>",
    "HistorizedRelationalDatabaseSchema COMPOSES SchemaHistory (schemaHistory field)",
    "HistorizedRelationalDatabaseSchema USES DdlParser (via abstract getDdlParser())",
    "AbstractSchemaHistory USES SchemaHistoryListener (listener field)",
    "AbstractSchemaHistory USES HistoryRecordComparator",
    "AbstractSchemaHistory USES TableChangesSerializer<Array> (JsonTableChangeSerializer)",
    "AbstractSchemaHistory calls DdlParser.parse() during recovery",
    "DdlParserListener.Event <|-- TableEvent <|-- TableCreatedEvent/TableAlteredEvent/TableDroppedEvent/TableTruncatedEvent",
    "DdlParserListener.Event <|-- TableIndexEvent <|-- TableIndexCreatedEvent/TableIndexDroppedEvent",
    "DdlParserListener.Event <|-- DatabaseEvent <|-- DatabaseCreatedEvent/DatabaseAlteredEvent/DatabaseDroppedEvent/DatabaseSwitchedEvent",
    "DdlParserListener.Event <|-- SetVariableEvent",
    "TableChanges COMPOSES TableChange (list of changes)",
    "SchemaHistory record() / recover() USES TableChanges"
  ],

  "key_flows": {
    "ddl_parsing": "AbstractDdlParser.parse(ddl, tables) → parser logic → signalXxx(tableId, stmt) → signalChangeEvent(Event) → ddlChanges.handle(event) → event accumulated in DdlChanges.events list",
    "schema_history_record": "HistorizedRelationalDatabaseSchema.record(SchemaChangeEvent, TableChanges) → schemaHistory.record(partition, offset, db, schema, ddl, tableChanges, timestamp) → AbstractSchemaHistory: create HistoryRecord → storeRecord(record) → listener.onChangeApplied(record)",
    "schema_history_recover": "HistorizedRelationalDatabaseSchema.recover(offsets) → schemaHistory.recover(offsets, tables, ddlParser) → AbstractSchemaHistory: listener.recoveryStarted() → recoverRecords(consumer) → for each HistoryRecord: listener.onChangeFromHistory() → [apply via TableChanges OR ddlParser.parse(ddl, schema)] → listener.onChangeApplied() → listener.recoveryStopped() → buildAndRegisterSchema() for all tables"
  },

  "important_notes": [
    "DdlChanges is both a DdlParserListener and the return value of DdlParser.parse(); it accumulates events grouped by database",
    "AbstractSchemaHistory supports dual recovery strategies: logical TableChanges (preferred when preferDdl=false) or DDL string re-parse via DdlParser",
    "skipUnparseableDDL flag in AbstractSchemaHistory controls whether ParsingException is swallowed or rethrown during recovery",
    "DDL_FILTER is a regex list in SchemaHistory config to exclude certain DDL patterns (RDS heartbeats, GRANT/REVOKE, views, etc.)",
    "HistorizedRelationalDatabaseSchema.getDdlParser() is abstract — each connector (MySQL, Postgres, etc.) provides its own parser implementation",
    "DdlParserListener is @FunctionalInterface — can be used as lambda"
  ],

