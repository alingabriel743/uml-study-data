    {
      "name": "AbstractSchemaHistory",
      "type": "abstract class",
      "package": "io.debezium.relational.history",
      "implements": ["SchemaHistory"],
      "fields": [
        "config: Configuration (protected)",
        "comparator: HistoryRecordComparator (private)",
        "skipUnparseableDDL: boolean (private)",
        "ddlFilter: Predicate<String> (private)",
        "listener: SchemaHistoryListener (private)",
        "useCatalogBeforeSchema: boolean (private)",
        "preferDdl: boolean (private)",
        "tableChangesSerializer: TableChangesSerializer<Array> (private) — JsonTableChangeSerializer"
      ],
      "methods": [
        "configure(Configuration, HistoryRecordComparator, SchemaHistoryListener, boolean): void",
        "start(): void  — calls listener.started()",
        "stop(): void   — calls listener.stopped()",
        "record(...): void  — creates HistoryRecord, calls storeRecord(), listener.onChangeApplied()",
        "recover(...): void  — calls listener.recoveryStarted() → recoverRecords() → for each apply via TableChanges or ddlParser.parse() → listener.onChangeApplied() → listener.recoveryStopped()",
        "storeRecord(HistoryRecord): void (abstract protected)",
        "recoverRecords(Consumer<HistoryRecord>): void (abstract protected)",
        "initializeStorage(): void (no-op override)"
      ],
      "recovery_logic": "If preferDdl=false AND tableChanges present: apply via schema.overwriteTable/removeTable. Else: call ddlParser.setCurrentDatabase/Schema + ddlParser.parse(ddl, schema). skipUnparseableDDL controls error tolerance."
