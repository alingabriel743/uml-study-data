    "AsyncEmbeddedEngine depends_on RecordProcessor (creates via createRecordProcessor)",
    "AsyncEmbeddedEngine.PollRecords uses EngineSourceTask and RecordProcessor",
    "EngineSourceConnector wraps SourceConnector (Kafka Connect)",
    "EngineSourceTask wraps SourceTask (Kafka Connect)",
    "EngineSourceConnectorContext holds OffsetBackingStore + OffsetStorageReader + OffsetStorageWriter",
    "EngineSourceTaskContext holds OffsetCommitPolicy + Transformations",
    "DebeziumEngine uses ServiceLoader to find BuilderFactory (default: ConvertingAsyncEngineBuilderFactory)"
  ],

  "lifecycle_flow": [
    "1. DebeziumEngine.create() → ServiceLoader finds ConvertingAsyncEngineBuilderFactory",
    "2. BuilderFactory.builder(format) → returns AsyncEngineBuilder",
    "3. AsyncEngineBuilder.using(config/consumer/callbacks).build() → creates AsyncEmbeddedEngine",
    "4. AsyncEmbeddedEngine.run(): State CREATING→INITIALIZING (initializeConnector, start SourceConnector)",
    "5. State INITIALIZING→CREATING_TASKS: createSourceTasks() → creates EngineSourceTask instances",
    "6. State CREATING_TASKS→STARTING_TASKS: startSourceTasks() → calls task.start(config)",
    "7. State STARTING_TASKS→POLLING_TASKS: runTasksPolling() → submits PollRecords to taskService",
    "8. PollRecords loop: task.poll() → RecordProcessor.processRecords(records) → committer.markBatchFinished()",
    "9. close()/stop: State→STOPPING, stopPollingIfNeeded(), stopSourceTasks(), stopConnector(), State→STOPPED",
    "10. finishShutDown() → CompletionCallback.handle(success, message, error)"
  ],

  "record_processor_selection": {
    "handler!=null, no recordConverter": "ParallelSmtBatchProcessor",
    "handler!=null, recordConverter present": "ParallelSmtAndConvertBatchProcessor",
    "consumer only, ORDERED, no recordConverter": "ParallelSmtConsumerProcessor",
    "consumer only, ORDERED, recordConverter present": "ParallelSmtAndConvertConsumerProcessor",
    "consumer only, UNORDERED, no recordConverter": "ParallelSmtAsyncConsumerProcessor",
    "consumer only, UNORDERED, recordConverter present": "ParallelSmtAndConvertAsyncConsumerProcessor"
  },

  "important_notes": [
    "AsyncEmbeddedEngine is the main implementation; there is no separate legacy EmbeddedEngine class in this codebase scope",
    "DebeziumEngine is in debezium-api module; AsyncEmbeddedEngine and configs are in debezium-embedded module",
    "State enum ordering matters: CREATING < INITIALIZING < CREATING_TASKS < STARTING_TASKS < POLLING_TASKS < STOPPING < STOPPED",
    "Cannot stop engine while in STARTING_TASKS state (resource leak risk)",
    "OffsetKeyConverter/OffsetValueConverter always use JsonConverter with schemas disabled",
    "taskService runs polling tasks; recordService runs SMT/conversion pipeline in parallel",
    "AsyncEngineConfig.RECORD_PROCESSING_WITH_SERIAL_CONSUMER=true wraps Consumer in default ChangeConsumer (EmbeddedEngine compatibility mode)"
  ],

