    {
      "name": "CancellableResultSet",
      "type": "class",
      "pattern": "Decorator",
      "implements": ["ResultSet"],
      "fields": [
        "- resultSet: ResultSet (delegate)"
      ],
      "constructors": [
        "- CancellableResultSet(ResultSet resultSet) [private]"
      ],
      "static_methods": [
        "+ from(resultSet: ResultSet): CancellableResultSet"
      ],
      "key_overrides": [
        "+ close(): void — cancels parent Statement (getStatement().cancel()) if result set is open AND not after last row, then delegates to resultSet.close()",
        "All other ResultSet methods: pure delegation to resultSet"
      ],
      "purpose": "Optimizes close() for large snapshot queries by cancelling un-exhausted result sets at the server, avoiding full row scan"
    },
