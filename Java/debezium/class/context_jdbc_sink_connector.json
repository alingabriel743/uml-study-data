  "key_relationships": [
    "JdbcSinkConnector extends SinkConnector, implements ConfigDescriptor",
    "JdbcSinkConnector creates JdbcSinkConnectorTask (taskClass())",
    "JdbcSinkConnectorTask extends SinkTask",
    "JdbcSinkConnectorTask composes JdbcChangeEventSink",
    "JdbcSinkConnectorTask uses DatabaseDialectResolver.resolve() → DatabaseDialect",
    "JdbcSinkConnectorTask creates DefaultRecordWriter or UnnestRecordWriter based on config",
    "JdbcSinkConnectorConfig implements SinkConnectorConfig (external debezium-sink)",
    "JdbcSinkConnectorConfig composes CollectionNamingStrategy (resolved via TemporaryBackwardCompatibleCollectionNamingStrategyProxy)",
    "JdbcSinkConnectorConfig composes ColumnNamingStrategy (default: DefaultColumnNamingStrategy)",
    "JdbcChangeEventSink implements ChangeEventSink",
    "JdbcChangeEventSink depends_on RecordWriter, DatabaseDialect",
    "JdbcChangeEventSink uses Buffer (RecordBuffer or ReducedRecordBuffer) per CollectionId",
    "DefaultRecordWriter implements RecordWriter",
    "DefaultRecordWriter depends_on DatabaseDialect, JdbcSinkConnectorConfig, QueryBinderResolver",
    "UnnestRecordWriter extends DefaultRecordWriter",
    "GeneralDatabaseDialect implements DatabaseDialect",
    "PostgresDatabaseDialect extends GeneralDatabaseDialect",
    "MySqlDatabaseDialect extends GeneralDatabaseDialect",
    "MariaDbDatabaseDialect extends MySqlDatabaseDialect",
    "OracleDatabaseDialect extends GeneralDatabaseDialect",
    "Db2DatabaseDialect extends GeneralDatabaseDialect",
    "Db2iDatabaseDialect extends GeneralDatabaseDialect",
    "DatabaseDialectProvider inner classes implement DatabaseDialectProvider (one per dialect)",
    "DatabaseDialectResolver uses ServiceLoader<DatabaseDialectProvider>",
    "RecordBuffer implements Buffer",
    "ReducedRecordBuffer implements Buffer",
    "DefaultColumnNamingStrategy implements ColumnNamingStrategy",
    "TemporaryBackwardCompatibleCollectionNamingStrategyProxy implements CollectionNamingStrategy"
  ],

  "schema_evolution_logic": [
    "checkAndApplyTableChangesIfNeeded: if table missing → createTable (requires SchemaEvolutionMode=BASIC)",
    "If createTable fails → try alterTableIfNeeded",
    "If table exists → alterTableIfNeeded",
    "alterTableIfNeeded: calls dialect.resolveMissingFields(); if missing fields → getAlterTableStatement()",
    "SchemaEvolutionMode.NONE → no CREATE/ALTER allowed, throws SQLException"
  ],

  "insert_mode_sql_mapping": {
    "INSERT": "dialect.getInsertStatement() or getBatchInsertStatement() if available",
    "UPSERT": "dialect.getUpsertStatement() or getBatchUpsertStatement() if available (requires PK fields)",
    "UPDATE": "dialect.getUpdateStatement()",
    "DELETE": "dialect.getDeleteStatement()"
  },

  "important_notes": [
    "UnnestRecordWriter is opt-in via dialect.postgres.unnest.insert.enabled=true; uses SQL UNNEST arrays for 5-10x perf on PG",
    "DatabaseDialectResolver uses Java ServiceLoader for pluggable dialect registration",
    "Each concrete dialect class has a static inner *Provider class implementing DatabaseDialectProvider",
    "Buffer selection: use.reduction.buffer=true → ReducedRecordBuffer (deduplicates by PK), else RecordBuffer",
    "JdbcSinkConnectorConfig.getHibernateConfiguration() builds Hibernate config from connector properties; users can pass 'hibernate.*' prefix properties",
    "CollectionNamingStrategy is from debezium-sink module (external); wrapped in proxy for backward compatibility",
    "Retry logic in DefaultRecordWriter.executeWithRetries(): retries on dialect.getCommunicationExceptions() up to flushMaxRetries times"
  ],

