        "+ getNumberOfUnchangedEventsSkipped(): long",
        "+ onUnchangedEventSkipped(partition): void",
        "+ onEvent(...): void — super.onEvent + streamingMeter.onEvent + activityMonitoringMeter.onEvent (if advancedMetrics)",
        "+ pause(): void", "+ resume(): void",
        "+ getNumberOfCreateEventsSeen(): Map<String,Long>",
        "+ getNumberOfDeleteEventsSeen(): Map<String,Long>",
        "+ getNumberOfUpdateEventsSeen(): Map<String,Long>",
        "+ getNumberOfTruncateEventsSeen(): Map<String,Long>",
        "+ reset(): void — super.reset() + streamingMeter.reset() + connectionMeter.reset() + activityMonitoringMeter.reset()"
      ],
      "notes": "If skipMessagesWithoutChange, streamingMeter.enableUnchangedEventsMetric() called. Advanced metrics guarded by taskContext.getConfig().isAdvancedMetricsEnabled()"
    },
