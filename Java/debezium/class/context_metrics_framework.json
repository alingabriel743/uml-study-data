  "classes": [
    {
      "name": "Metrics",
      "package": "io.debezium.metrics",
      "type": "abstract_class",
      "annotations": ["@ThreadSafe"],
      "fields": [
        "- name: ObjectName",
        "- registered: boolean (volatile)"
      ],
      "methods": [
        "+ register(): void (synchronized) — calls JmxUtils.registerMXBean(name, this)",
        "+ unregister(): void (synchronized) — calls JmxUtils.unregisterMXBean(name)",
        "# metricName(connectorType, connectorName, contextName, customTags): ObjectName",
        "# metricName(connectorType, tags): ObjectName — builds 'debezium.<type>:type=connector-metrics,...'"
      ],
      "notes": "Base JMX registration; ObjectName is 'debezium.<connectorType>:type=connector-metrics,context=<ctx>,server=<name>'"
    },
    {
      "name": "PipelineMetrics<P extends Partition>",
      "package": "io.debezium.pipeline.metrics",
      "type": "abstract_class",
      "annotations": ["@ThreadSafe"],
      "extends": "Metrics",
      "implements": ["DataChangeEventListener<P>", "ChangeEventSourceMetricsMXBean"],
      "fields": [
        "# metadataProvider: EventMetadataProvider",
        "- changeEventQueueMetrics: ChangeEventQueueMetrics",
        "# taskContext: CdcSourceTaskContext",
        "- commonEventMeter: CommonEventMeter"
      ],
      "methods": [
        "+ onEvent(partition, source, offset, key, value, operation): void — delegates to commonEventMeter",
        "+ onFilteredEvent(partition, event): void — delegates to commonEventMeter",
        "+ onFilteredEvent(partition, event, operation): void — delegates to commonEventMeter",
        "+ onErroneousEvent(partition, event): void — delegates to commonEventMeter",
        "+ onErroneousEvent(partition, event, operation): void — delegates to commonEventMeter",
        "+ onConnectorEvent(partition, event): void — no-op",
        "+ getLastEvent(): String",
        "+ getMilliSecondsSinceLastEvent(): long",
        "+ getTotalNumberOfEventsSeen(): long",
        "+ getTotalNumberOfCreateEventsSeen(): long",
        "+ getTotalNumberOfUpdateEventsSeen(): long",
        "+ getTotalNumberOfDeleteEventsSeen(): long",
        "+ getNumberOfEventsFiltered(): long",
        "+ getNumberOfErroneousEvents(): long",
        "+ reset(): void — resets commonEventMeter",
        "+ getQueueTotalCapacity(): int — delegates to changeEventQueueMetrics",
        "+ getQueueRemainingCapacity(): int",
        "+ getMaxQueueSizeInBytes(): long",
        "+ getCurrentQueueSizeInBytes(): long"
      ]
    },
