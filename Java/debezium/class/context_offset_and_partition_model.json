  "key_relationships": [
    "CommonOffsetContext implements OffsetContext",
    "CommonOffsetContext composes BaseSourceInfo (T sourceInfo)",
    "CommonOffsetContext depends_on TransactionContext (via getTransactionContext() — implemented by subclasses)",
    "OffsetContext.Loader<O> produces OffsetContext instances via load(Map)",
    "BaseSourceInfo extends AbstractSourceInfo",
    "AbstractPartition implements Partition",
    "BinlogPartition extends AbstractPartition",
    "SqlServerPartition extends AbstractPartition",
    "SqlServerPartition.Provider implements Partition.Provider<SqlServerPartition>",
    "OffsetContext uses TransactionContext (getTransactionContext())",
    "OffsetContext uses IncrementalSnapshotContext (getIncrementalSnapshotContext())",
    "AbstractSourceInfo uses CommonConnectorConfig (holds config)",
    "AbstractSourceInfo uses SourceInfoStructMaker (schema/struct generation)",
    "TransactionContext uses DataCollectionId (event tracking)",
    "MongoDbOffsetContext extends CommonOffsetContext<SourceInfo>",
    "BinlogOffsetContext<T extends BinlogSourceInfo> extends CommonOffsetContext<T>",
    "PostgresOffsetContext extends CommonOffsetContext<SourceInfo>",
    "OracleOffsetContext extends CommonOffsetContext<SourceInfo>",
    "SqlServerOffsetContext extends CommonOffsetContext<SourceInfo>"
  ],

  "offset_persistence_model": [
    "OffsetContext.getOffset() → Map<String,?> serialized as Kafka Connect source offset",
    "TransactionContext.store(offset) → injects OFFSET_TRANSACTION_ID + per-table counts into offset map",
    "TransactionContext.load(offsets) → reconstructs from flat Map (static factory)",
    "OffsetContext.Loader.load(Map) → reconstructs full OffsetContext from stored offset on restart",
    "SNAPSHOT_COMPLETED_KEY ('snapshot_completed') stored in offset by CommonOffsetContext",
    "AbstractSourceInfo.SNAPSHOT_KEY ('snapshot') stored as SnapshotType string value"
  ],

  "snapshot_lifecycle": [
    "preSnapshotStart(onDemand) → sets snapshot=INITIAL|BLOCKING, sourceInfo.setSnapshot(TRUE), snapshotCompleted=false",
    "preSnapshotCompletion() → snapshotCompleted=true",
    "postSnapshotCompletion() → sourceInfo.setSnapshot(FALSE), snapshot=null",
    "incrementalSnapshotEvents() → sourceInfo.setSnapshot(INCREMENTAL), snapshot=INCREMENTAL",
    "isInitialSnapshotRunning() → snapshot==INITIAL && !snapshotCompleted"
  ],

  "important_notes": "OffsetContext and Partition are the two core SPI interfaces in io.debezium.pipeline.spi. CommonOffsetContext is the abstract base for all connector-specific offset contexts and carries the sourceInfo (SourceInfo extends BaseSourceInfo extends AbstractSourceInfo). TransactionContext is embedded inside OffsetContext implementations to track active in-flight transactions across restarts. AbstractPartition is the shared relational base for connector partitions. No OffsetStore class found in the codebase — the 'store' behavior is handled via OffsetContext.getOffset() and TransactionContext.store().",

