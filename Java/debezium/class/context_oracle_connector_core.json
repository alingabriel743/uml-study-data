  "key_value_types": [
    "Scn — Oracle System Change Number wrapper (BigInteger-based)",
    "CommitScn — multi-thread commit SCN tracker",
    "OracleDatabaseVersion — parsed Oracle DB version",
    "SourceInfo — Oracle-specific source info extending AbstractSourceInfo"
  ],

  "important_notes": [
    "ConnectorAdapter enum controls streaming strategy: XSTREAM (OCI JDBC), LOG_MINER (buffered, thin JDBC), LOG_MINER_UNBUFFERED (thin JDBC), OLR (OpenLogReplicator).",
    "OracleConnectorConfig.streamingAdapter is set in constructor via ConnectorAdapter.getInstance(), loaded reflectively.",
    "OracleOffsetContext uses Builder pattern (create().scn().build()); private constructor.",
    "OraclePartition.Provider uses PDB name when set, otherwise CDB database name.",
    "OracleConnection overrides JdbcConnection to handle CDB/PDB session switching via ALTER SESSION SET CONTAINER.",
    "OracleConnector enforces maxTasks=1 (no parallelism at connector level)."
  ],

