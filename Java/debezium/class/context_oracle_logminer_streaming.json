  ],

  "execute_flow": [
    "execute() → prepareJdbcConnection() + checkDatabaseAndTableState() + logOnlineRedoLogSizes()",
    "execute() → computeStartScnForFirstMiningSession() [on first run] → getOffsetContext().setScn(startScn)",
    "execute() → executeLogMiningStreaming() [abstract, subclass implements mining loop]",
    "executeAndProcessQuery(stmt) → stmt.executeQuery() → metrics.setLastDurationOfFetchQuery()",
    "executeAndProcessQuery → while(hasNextWithMetricsUpdate(rs)) → LogMinerEventRow.fromResultSet() → processEvent(event)",
    "processEvent(event) → switch(EventType) → handleStartEvent / handleCommitEvent / handleRollbackEvent / handleSchemaChangeEvent / handleDataChangeEvent / handleSelectLobLocatorEvent / etc.",
    "handleDataChangeEvent() → executeDataChangeEventPreDispatchSteps() → getTableForDataEvent() → dispatchDataChangeEventInternal()",
    "calculateUpperBounds(lower, prevUpper, currentScn) → adjusts batchSize & sleepTime, returns Scn upper bound"
  ],

  "important_notes": [
    "AbstractLogMinerStreamingChangeEventSource is the template-method base for both buffered and unbuffered LogMiner adapters",
    "Scn uses long for performance and falls back to BigInteger on overflow; NULL is sentinel (empty=true, longValue=0)",
    "ScnRange is a Java record nested inside LogMinerStreamingChangeEventSourceMetrics",
    "BatchMetrics is a non-thread-safe per-iteration accumulator; updateStreamingMetrics() pushes to parent AtomicLong fields",
    "DurationHistogramMetric tracks min/max/last/total Duration atomically; used for 7 timing dimensions",
    "LogMinerSessionContext is named 'sessionContext' in the parent and exposed as getLogMinerContext()",
    "LogMinerStreamingChangeEventSourceMetrics is @ThreadSafe; all mutable state is via Atomic types",
    "resolveFlushStrategy() selects ReadOnly/RAC/Commit based on config flags"
  ],

