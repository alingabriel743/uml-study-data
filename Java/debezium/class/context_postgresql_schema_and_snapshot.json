    "PostgresType self-references: parentType: PostgresType (domain base), elementType: PostgresType (array element)",
    "PostgresValueConverter uses PgOid constants (dependency)",
    "InitialSnapshotter extends BeanAwareSnapshotter implements Snapshotter",
    "AlwaysSnapshotter extends BeanAwareSnapshotter implements Snapshotter",
    "NeverSnapshotter extends BeanAwareSnapshotter implements Snapshotter",
    "WhenNeededSnapshotter extends BeanAwareSnapshotter implements Snapshotter",
