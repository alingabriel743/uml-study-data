  "key_relationships": [
    "RelationalDatabaseSchema implements DatabaseSchema<TableId>",
    "HistorizedRelationalDatabaseSchema extends RelationalDatabaseSchema",
    "HistorizedRelationalDatabaseSchema implements HistorizedDatabaseSchema<TableId>",
    "TableSchema implements DataCollectionSchema",
    "TableId implements DataCollectionId, Comparable<TableId>",
    "Table (interface) produces TableEditor via edit()",
    "TableEditor creates Table via create()",
    "RelationalDatabaseSchema composes Tables (1-to-1)",
    "RelationalDatabaseSchema composes SchemasByTableId (ConcurrentMap<TableId,TableSchema>)",
    "RelationalDatabaseSchema depends_on TableSchemaBuilder (builds TableSchema from Table)",
    "Tables contains Map<TableId, Table> (TablesById)",
    "Table has_many Column (List<Column>)",
    "Table has_many Attribute (List<Attribute>)",
    "Table identified_by TableId",
    "TableSchema identified_by TableId",
    "TableSchema uses StructGenerator (key + value)",
    "TableSchema uses Envelope (envelopeSchema)",
    "Column extends Comparable<Column> (ordered by position)",
    "HistorizedRelationalDatabaseSchema composes SchemaHistory",
    "HistorizedRelationalDatabaseSchema depends_on DdlParser (abstract getDdlParser())"
  ],

  "inheritance_hierarchy": [
    "DatabaseSchema<I> (interface)",
    "  └─ RelationalDatabaseSchema (abstract, implements DatabaseSchema<TableId>)",
    "       └─ HistorizedRelationalDatabaseSchema (abstract, also implements HistorizedDatabaseSchema<TableId>)",
    "DataCollectionSchema (interface)",
    "  └─ TableSchema (implements DataCollectionSchema)",
    "DataCollectionId (interface)",
    "  └─ TableId (final, implements DataCollectionId + Comparable<TableId>)"
  ],

  "important_notes": [
    "Table and Column are @Immutable interfaces; mutable via TableEditor / ColumnEditor (builder pattern)",
    "TableEditorImpl and NoOpTableEditorImpl are concrete TableEditor implementations",
    "ColumnEditorImpl is the concrete Column editor",
    "Tables is @ThreadSafe using FunctionalReadWriteLock; SchemasByTableId uses ConcurrentHashMap",
    "TableId supports optional catalog+schema+table triple; dot-separated identifier computed at construction",
    "TableSchema wraps Kafka Connect Schema (key + value) plus Envelope and StructGenerator lambdas",
    "RelationalDatabaseSchema.buildAndRegisterSchema() calls TableSchemaBuilder.create() then stores result in SchemasByTableId",
    "HistorizedRelationalDatabaseSchema adds SchemaHistory recovery (DDL replay) and SchemaChangeEvent recording",
    "Tables.TableFilter and Tables.ColumnNameFilter are nested functional interfaces used throughout the schema"
  ],

  "source_files_analyzed": [
