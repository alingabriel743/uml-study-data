@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam ArrowColor #495057
skinparam ArrowThickness 1.2
skinparam nodesep 40
skinparam ranksep 50

title Debezium — Component Architecture

' ─────────────────────────────────────────────
'  Foundation Layer
' ─────────────────────────────────────────────
package "Foundation" {
    [debezium-api\n<size:10>(Engine API, Formats, SPI)</size>] as api
    [debezium-config\n<size:10>(Configuration Framework)</size>] as config
    [debezium-util\n<size:10>(Utility Classes)</size>] as util
}

' ─────────────────────────────────────────────
'  Core Infrastructure
' ─────────────────────────────────────────────
package "Core Infrastructure" {
    [debezium-connector-common\n<size:10>(Connector Core Engine)</size>] as core
    [debezium-ddl-parser\n<size:10>(ANTLR-based DDL Parsing)</size>] as ddl
    [debezium-storage\n<size:10>(Offset & Schema Storage)</size>] as storage
}

' ─────────────────────────────────────────────
'  Embedded Engine
' ─────────────────────────────────────────────
package "Embedded Engine" {
    [debezium-embedded\n<size:10>(Standalone Embedded Runner)</size>] as embedded
}

' ─────────────────────────────────────────────
'  Kafka Connect Plugins
' ─────────────────────────────────────────────
package "Kafka Connect Plugins" {
    [debezium-connect-plugins\n<size:10>(Converters & SMTs)</size>] as connect
    [debezium-scripting\n<size:10>(Script-based Filters & Routers)</size>] as scripting
}

' ─────────────────────────────────────────────
'  Source Connectors
' ─────────────────────────────────────────────
package "Source Connectors" {

    package "Binlog-Based (MySQL / MariaDB)" {
        [debezium-connector-binlog\n<size:10>(Shared Binlog Infrastructure)</size>] as binlog
        [debezium-connector-mysql\n<size:10>(MySQL Connector)</size>] as mysql
        [debezium-connector-mariadb\n<size:10>(MariaDB Connector)</size>] as mariadb
    }

    [debezium-connector-postgres\n<size:10>(PostgreSQL Connector)</size>] as postgres
    [debezium-connector-oracle\n<size:10>(Oracle Connector)</size>] as oracle
    [debezium-connector-mongodb\n<size:10>(MongoDB Connector)</size>] as mongodb
    [debezium-connector-sqlserver\n<size:10>(SQL Server Connector)</size>] as sqlserver
}

' ─────────────────────────────────────────────
'  Sink Connectors
' ─────────────────────────────────────────────
package "Sink Connectors" {
    [debezium-sink\n<size:10>(Sink Connector Framework)</size>] as sink
    [debezium-connector-jdbc\n<size:10>(JDBC Sink Connector)</size>] as jdbc
}

' ─────────────────────────────────────────────
'  AI / ML Extensions
' ─────────────────────────────────────────────
package "AI / ML Extensions" {
    [debezium-ai-docling\n<size:10>(Document Field Extraction)</size>] as docling
    [debezium-ai-embeddings\n<size:10>(Embeddings Core & SMT)</size>] as embeddings

    package "Embedding Providers" {
        [HuggingFace Provider] as hf
        [MiniLM Provider] as minilm
        [Ollama Provider] as ollama
        [VoyageAI Provider] as voyage
    }
}

' ─────────────────────────────────────────────
'  Observability
' ─────────────────────────────────────────────
package "Observability" {
    [debezium-openlineage\n<size:10>(Data Lineage Integration)</size>] as openlineage
}

' ═══════════════════════════════════════════
'  Dependencies
' ═══════════════════════════════════════════

' Foundation → Core Infrastructure
core --> api        : uses
core --> config     : uses
core --> util       : uses

' Core Infrastructure internal
storage --> api

' Embedded Engine
embedded --> core   : extends

' Kafka Connect Plugins
connect --> core    : extends
connect --> util    : uses
connect --> embedded : optional

' Scripting
scripting --> connect : extends

' Source Connectors — Binlog base
binlog --> core     : extends
binlog --> ddl      : parses with
binlog --> storage  : uses

' MySQL & MariaDB build on Binlog
mysql --> binlog    : extends
mariadb --> binlog  : extends

' Other source connectors
postgres   --> core : extends
oracle     --> core : extends
oracle     --> ddl  : parses with
mongodb    --> core : extends
sqlserver  --> core : extends

' Sink Connectors
sink --> core       : extends
sink --> connect    : uses
jdbc --> core       : extends

' AI Extensions
docling    --> connect  : extends (SMT)
embeddings --> connect  : extends (SMT)
hf      --> embeddings  : implements
minilm  --> embeddings  : implements
ollama  --> embeddings  : implements
voyage  --> embeddings  : implements

' Observability
openlineage --> core : integrates with

@enduml
