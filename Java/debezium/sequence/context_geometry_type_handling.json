        "converterFor(RelationalColumn, ConverterRegistration<SchemaBuilder>): void",
        "getConfigFields(): Field.Set"
      ],
      "config_props": ["selector (regex, table.column format)", "length.checker (boolean, default true)"]
    },
    "BinlogChangeRecordEmitter": {
      "type": "class",
      "extends": "RelationalChangeRecordEmitter<BinlogPartition>",
      "fields": ["Operation operation", "OffsetContext offset", "Object[] before", "Object[] after"],
      "constructor": "BinlogChangeRecordEmitter(P partition, OffsetContext offset, Clock clock, Operation operation, Serializable[] before, Serializable[] after, BinlogConnectorConfig connectorConfig)",
      "methods": [
