        "static convertUnsignedSmallint(int): int",
        "static convertUnsignedMediumint(int): int",
        "static convertUnsignedInteger(long): long",
        "static convertUnsignedBigint(BigDecimal): BigDecimal"
      ],
      "correction_constants": ["TINYINT+256", "SMALLINT+65536", "MEDIUMINT+16777216", "INT+4294967296", "BIGINT+18446744073709551616"]
    },
    "TinyIntOneToBooleanConverter": {
      "type": "class",
      "implements": ["CustomConverter<SchemaBuilder,RelationalColumn>", "ConfigDescriptor"],
      "fields": ["Predicate<RelationalColumn> selector", "boolean lengthChecker=true"],
      "methods": [
