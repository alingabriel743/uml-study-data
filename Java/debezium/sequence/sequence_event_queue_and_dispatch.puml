@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequenceArrowColor #495057
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #495057
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam sequenceGroupFontColor #212529
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F9A825
skinparam activationBarBorderColor #6C757D
skinparam activationBarBackgroundColor #DEE2E6

title Change Event Queue and Dispatch Flow

' ── Participants ────────────────────────────────────────────
participant "ProducerThread\n(Connector Source)" as producer
participant "EventDispatcher" as dispatcher
participant "DataCollectionFilter" as filter
participant "ChangeRecordEmitter" as emitter
participant "StreamingChangeRecordReceiver" as receiver
participant "TopicNamingStrategy" as topicNaming
participant "PostProcessorRegistry" as postProc
participant "ChangeEventCreator" as creator
participant "ChangeEventQueue\n<DataChangeEvent>" as queue
participant "QueueProvider\n(DefaultQueueProvider)" as queueProvider
participant "ConsumerThread\n(Kafka Connect)" as consumer
participant "Kafka Broker" as kafka

' ══════════════════════════════════════════════════════════════
' PRODUCER SIDE — Enqueue Path
' ══════════════════════════════════════════════════════════════

== Producer Side: Dispatch & Enqueue ==

producer -> dispatcher : dispatchDataChangeEvent(\n  partition, dataCollectionId, changeRecordEmitter)
activate dispatcher

dispatcher -> filter : isIncluded(dataCollectionId)
activate filter
filter --> dispatcher : true / false
deactivate filter

alt Collection is included

    dispatcher -> emitter : emitChangeRecords(dataCollectionSchema, receiver)
    activate emitter

    emitter -> receiver : changeRecord(\n  partition, schema, operation,\n  key, value, offset, headers)
    activate receiver

    receiver -> topicNaming : dataChangeTopic(dataCollectionId)
    activate topicNaming
    topicNaming --> receiver : topicName
    deactivate topicNaming

    opt Post-processing enabled
        receiver -> postProc : doPostProcessing(key, value)
        activate postProc
        postProc --> receiver : transformedKey, transformedValue
        deactivate postProc
    end

    receiver -> creator : createDataChangeEvent(SourceRecord)
    activate creator
    creator --> receiver : DataChangeEvent
    deactivate creator

    ' ── Enqueue with backpressure ──────────────────────────
    receiver -> queue : enqueue(DataChangeEvent)
    activate queue

    note over queue
      Acquires ReentrantLock
    end note

    loop Queue full (size ≥ maxQueueSize OR bytes ≥ maxQueueSizeInBytes)
        queue -> queue : isNotFull.await(pollIntervalMillis)
        note right of queue
          Blocks producer until
          consumer drains records
        end note
    end

    queue -> queueProvider : poll/enqueue — queue.add(record)
    activate queueProvider
    queueProvider --> queue : ok
    deactivate queueProvider

    alt Batch threshold OR byte threshold reached
        queue -> queue : isFull.signalAll()\n[wake consumer early]
    end

    note over queue
      Releases ReentrantLock
    end note

    queue --> receiver : (void)
    deactivate queue

    ' ── Tombstone on DELETE ────────────────────────────────
    opt emitTombstonesOnDelete = true AND operation = DELETE
        receiver -> queue : enqueue(DataChangeEvent[tombstone])
        activate queue
        queue -> queueProvider : queue.add(tombstoneRecord)
        activate queueProvider
        queueProvider --> queue : ok
        deactivate queueProvider
        queue --> receiver : (void)
        deactivate queue
    end

    receiver --> emitter : (void)
    deactivate receiver

    emitter --> dispatcher : (void)
    deactivate emitter

else Collection is excluded
    dispatcher -> dispatcher : skip event (filtered out)
end

dispatcher --> producer : (void)
deactivate dispatcher

' ══════════════════════════════════════════════════════════════
' CONSUMER SIDE — Poll & Forward to Kafka
' ══════════════════════════════════════════════════════════════

== Consumer Side: Poll & Forward ==

consumer -> queue : poll()
activate queue

note over queue
  Acquires ReentrantLock
  Sets Timer = min(pollInterval, RETURN_CONTROL_INTERVAL)
end note

loop Drain records up to maxBatchSize
    queue -> queueProvider : poll() [remove head record]
    activate queueProvider
    queueProvider --> queue : DataChangeEvent (or null)
    deactivate queueProvider
end

alt Batch not full AND bytes below threshold AND timer not expired
    queue -> queue : isNotFull.signalAll()\n[unblock producer]
    queue -> queue : isFull.await(remainingTimeout)\n[wait for more records]
end

queue -> queue : isNotFull.signalAll()\n[signal producer — queue drained]

note over queue
  Releases ReentrantLock
end note

queue --> consumer : List<DataChangeEvent>\n(up to maxBatchSize records)
deactivate queue

consumer -> kafka : forward records to Kafka broker\n(SourceRecord batch)
activate kafka
kafka --> consumer : ack / offset commit
deactivate kafka

@enduml
