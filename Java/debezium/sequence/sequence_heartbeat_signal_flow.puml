@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #495057
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceParticipantFontColor #212529
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #6C757D
skinparam sequenceGroupBackgroundColor #E9ECEF22
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F9A825

title Heartbeat and Signal Channel Flow

participant "BinlogClient" as client
participant "BinlogStreamingChangeEventSource" as streaming
participant "EventDispatcher" as dispatcher
participant "HeartbeatImpl" as heartbeat
participant "ChangeEventQueue" as queue
participant "BinlogHeartbeatErrorHandler" as errHandler
participant "SignalProcessor" as sigProc
participant "SourceSignalChannel" as sourceChan
participant "SignalAction" as sigAction

== Heartbeat Setup ==

[-> dispatcher : init(config, heartbeatFactory)
activate dispatcher

dispatcher -> heartbeat : new HeartbeatImpl(\n  heartbeatInterval, topicName,\n  logicalName, schemaNameAdjuster, queue)
activate heartbeat
note right of heartbeat
  heartbeatTimeout = Threads.timer(
    Clock.SYSTEM, heartbeatInterval)
end note
heartbeat --> dispatcher : scheduledHeartbeat
deactivate heartbeat

dispatcher -> client : setHeartbeatInterval(\n  keepAliveInterval * 0.8f)
note right of client
  Server-level keep-alive heartbeat
  (separate from Debezium heartbeat topic)
end note

deactivate dispatcher

== Binlog Server Heartbeat Event (EventType.HEARTBEAT) ==

client -> streaming : emit(Event[EventType.HEARTBEAT])
activate streaming

streaming -> streaming : eventHandlers[HEARTBEAT].accept(event)\n-> handleServerHeartbeat(partition, offsetContext, event)

streaming -> dispatcher : dispatchServerHeartbeatEvent(\n  partition, offsetContext)
activate dispatcher

dispatcher -> dispatcher : update milliSecondsBehindSource metric
note right of dispatcher
  Server HEARTBEAT events do NOT
  emit records to Kafka topic
end note

dispatcher --> streaming : (metric updated)
deactivate dispatcher

deactivate streaming

== Periodic Debezium Heartbeat Emission (per binlog event) ==

client -> streaming : emit(Event[any type])
activate streaming

streaming -> streaming : eventHandlers[eventType].accept(event)\n[normal event processing]

streaming -> dispatcher : dispatchHeartbeatEvent(\n  partition, offsetContext)
activate dispatcher

dispatcher -> heartbeat : emitWithDelay(\n  partition.getSourcePartition(), offsetContext)
activate heartbeat

alt heartbeatTimeout.expired()
    heartbeat -> heartbeat : emit(partition, offset)
    heartbeat -> heartbeat : heartbeatTimeout = resetHeartbeat()\n[Threads.timer reset]

    heartbeat -> queue : enqueue(new DataChangeEvent(\n  SourceRecord -> '__debezium-heartbeat.<logicalName>'))
    activate queue
    note right of queue
      key:   Struct{serverName=logicalName}
      value: Struct{ts_ms=Instant.now().toEpochMilli()}
    end note
    queue --> heartbeat : (enqueued)
    deactivate queue
else timer not yet expired
    heartbeat -> heartbeat : skip emission
end

heartbeat --> dispatcher : (done)
deactivate heartbeat
dispatcher --> streaming : (done)
deactivate dispatcher
deactivate streaming

== Forced Heartbeat (alwaysDispatchHeartbeatEvent) ==

[-> dispatcher : alwaysDispatchHeartbeatEvent(\n  partition, offsetContext)
activate dispatcher

dispatcher -> heartbeat : emit(partition, offset)\n[unconditional — no timer check]
activate heartbeat

heartbeat -> queue : enqueue(DataChangeEvent)
activate queue
queue --> heartbeat : (enqueued)
deactivate queue

heartbeat --> dispatcher : (done)
deactivate heartbeat
deactivate dispatcher

== Heartbeat Error Handling ==

heartbeat -> heartbeat : [heartbeat action query throws SQLException]
activate heartbeat

heartbeat -> errHandler : onError(SQLException)
activate errHandler

alt sqlState == '42000' (access denied)\nor sqlState == '3D000' (unknown database)
    errHandler -> errHandler : throw DebeziumException
else other SQL error
    errHandler -> errHandler : no-op (silently ignored)
end

errHandler --> heartbeat : (handled)
deactivate errHandler
deactivate heartbeat

== Signal Table Polling (Scheduled Channels) ==

loop every signalPollInterval (default 5000 ms)
    sigProc -> sigProc : scheduleAtFixedRate: process()
    activate sigProc

    loop for each enabled SignalChannelReader\n(Kafka, File, JMX, InProcess)
        sigProc -> sigProc : channelReader.read() -> List<SignalRecord>
    end

    loop for each SignalRecord
        sigProc -> sigProc : processSignal(signalRecord, null)\n-> signalActions.get(signalRecord.getType())

        sigProc -> sigAction : action.arrived(\n  SignalPayload{partition, id, type, data, offset})
        activate sigAction
        sigAction --> sigProc : (action executed)
        deactivate sigAction
    end

    deactivate sigProc
end

== Signal via Source (Signal Table CDC Event) ==

client -> streaming : emit(Event for signal data collection)
activate streaming

streaming -> dispatcher : dispatchDataChangeEvent(\n  partition, changeRecordEmitter)
activate dispatcher

dispatcher -> dispatcher : isASignalEventToProcess(\n  dataCollectionId, operation) == true

dispatcher -> sourceChan : process(Struct value)
activate sourceChan
sourceChan -> sourceChan : SignalRecord.buildSignalRecordFromChangeEventSource(\n  value, config)\n-> signals.add(signalRecord)
sourceChan --> dispatcher : (signal queued)
deactivate sourceChan

dispatcher -> sigProc : processSourceSignal(partition)\n[immediate, synchronous]
activate sigProc

sigProc -> sourceChan : read() -> List<SignalRecord>
activate sourceChan
sourceChan --> sigProc : List<SignalRecord>
deactivate sourceChan

sigProc -> sigAction : action.arrived(\n  SignalPayload{partition, id, type, data, offset})
activate sigAction
sigAction --> sigProc : (action executed)
deactivate sigAction

sigProc --> dispatcher : (done)
deactivate sigProc

dispatcher --> streaming : (done)
deactivate dispatcher
deactivate streaming

@enduml
