@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #495057
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #6C757D
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam sequenceGroupFontColor #212529
skinparam noteBorderColor #6C757D
skinparam noteBackgroundColor #FFF3CD

title Redis Offset/Schema Storage Flow

participant "Connector\n(KafkaConnect Worker)" as connector
participant "RedisOffsetBackingStore" as offsetStore
participant "RedisSchemaHistory" as schemaHistory
participant "RedisOffsetBackingStoreConfig\n/ RedisSchemaHistoryConfig" as storeConfig
participant "RedisCommonConfig" as commonConfig
participant "RedisConnection" as redisConn
participant "JedisClient" as jedisClient
participant "WaitReplicasRedisClient" as waitClient
participant "JedisClusterClient" as clusterClient
participant "Redis Server" as redis

== Offset Store Startup ==

connector -> offsetStore : configure(WorkerConfig)
activate offsetStore
offsetStore -> storeConfig : new(Configuration)\n[prefix: 'offset.storage.redis.']
activate storeConfig
storeConfig -> commonConfig : super(config, "offset.storage.")
activate commonConfig
commonConfig -> commonConfig : subset(prefix, true)\nvalidateAndRecord(fields)\ninit(config)
deactivate commonConfig
deactivate storeConfig

connector -> offsetStore : start()
offsetStore -> offsetStore : connect()\n[closeClient() if existing]
offsetStore -> redisConn : getInstance(config)\n[address, dbIndex, user, password,\ntimeouts, SSL, clusterEnabled]
activate redisConn
offsetStore -> redisConn : getRedisClient("debezium:offsets",\nwaitEnabled, waitTimeout, waitRetry, waitRetryDelay)

redisConn -> redisConn : DefaultJedisClientConfig.Builder\n.database().connectionTimeoutMillis()\n.socketTimeoutMillis().ssl()

alt clusterEnabled = true
    redisConn -> clusterClient : new JedisCluster(nodes, config) + ping()
    activate clusterClient
    redisConn --> offsetStore : JedisClusterClient\n[no WAIT wrapper in cluster mode]
    deactivate clusterClient
else clusterEnabled = false
    redisConn -> jedisClient : new Jedis(HostAndPort, config)\n+ ping()\n+ clientSetname("debezium:offsets")
    activate jedisClient
    alt waitEnabled = true
        redisConn -> waitClient : new WaitReplicasRedisClient\n(jedisClient, replicas=1,\nwaitTimeout, waitRetry, waitRetryDelay)
        activate waitClient
        redisConn --> offsetStore : WaitReplicasRedisClient
    else waitEnabled = false
        redisConn --> offsetStore : JedisClient
    end
end
deactivate redisConn

== Load Offsets (Connector Resume) ==

offsetStore -> offsetStore : load()
note right of offsetStore
  Mutiny Uni with indefinite retry
  + exponential backoff
  (initialDelay → maxDelay)
end note

offsetStore -> jedisClient : hgetAll("metadata:debezium:offsets")\n[async Uni with backoff retry]
activate jedisClient
jedisClient -> redis : HGETALL metadata:debezium:offsets
activate redis
redis --> jedisClient : Map<String, String> offsets
deactivate redis
jedisClient --> offsetStore : raw offset map
deactivate jedisClient

offsetStore -> offsetStore : deserialize bytes\n→ ByteBuffer map (data)

opt RedisClientConnectionException
    offsetStore -> offsetStore : connect() — reconnect
    note right : Retries indefinitely\nafter reconnect
end

deactivate offsetStore

== Save Offsets (Write Path) ==

connector -> offsetStore : save()\n[called by MemoryOffsetBackingStore on flush]
activate offsetStore
note right of offsetStore
  Fixed backoff: 1s → 2s
  retried indefinitely per entry
end note

alt waitEnabled = true (WaitReplicasRedisClient)
    offsetStore -> waitClient : hset(keyName.getBytes(),\nfield_bytes, value_bytes)
    activate waitClient
    waitClient -> jedisClient : hset(key, field, value)
    activate jedisClient
    jedisClient -> redis : HSET metadata:debezium:offsets field value
    activate redis
    redis --> jedisClient : OK
    deactivate redis
    jedisClient --> waitClient : OK
    deactivate jedisClient
    waitClient -> jedisClient : waitReplicas(1, timeout)
    activate jedisClient
    jedisClient -> redis : WAIT 1 <timeout>
    activate redis
    redis --> jedisClient : reachedReplicas
    deactivate redis
    jedisClient --> waitClient : reachedReplicas
    deactivate jedisClient
    opt reachedReplicas != expected AND retry = true
        waitClient -> waitClient : sleep(delay)\nretry hset + wait loop
    end
    waitClient --> offsetStore : OK
    deactivate waitClient
else waitEnabled = false
    offsetStore -> jedisClient : hset(keyName.getBytes(),\nfield_bytes, value_bytes)
    activate jedisClient
    jedisClient -> redis : HSET metadata:debezium:offsets field value
    activate redis
    redis --> jedisClient : OK
    deactivate redis
    jedisClient --> offsetStore : OK
    deactivate jedisClient
end
deactivate offsetStore

== Schema History — Startup ==

connector -> schemaHistory : configure(config, comparator, listener, useCatalog)
activate schemaHistory
schemaHistory -> storeConfig : new RedisSchemaHistoryConfig(config)\n[prefix: 'schema.history.internal.redis.']
activate storeConfig
storeConfig -> commonConfig : super(config, "schema.history.internal.")
deactivate storeConfig

connector -> schemaHistory : start() → doWithRetry(() → connect())
schemaHistory -> redisConn : getInstance(config)
activate redisConn
schemaHistory -> redisConn : getRedisClient("debezium:schema_history",\nwaitEnabled, ...)
redisConn --> schemaHistory : RedisClient
deactivate redisConn

== Schema History — Write ==

connector -> schemaHistory : storeRecord(HistoryRecord)
schemaHistory -> schemaHistory : DocumentWriter.write(record.document())\n→ String line (JSON)
note right of schemaHistory
  doWithRetry loop:
  maxRetryCount attempts,
  exponential backoff
end note
schemaHistory -> jedisClient : xadd(redisKeyName,\n{schema: line})
activate jedisClient
jedisClient -> redis : XADD debezium:schema_history * schema <json>
activate redis
redis --> jedisClient : stream entry ID
deactivate redis
jedisClient --> schemaHistory : entryId
deactivate jedisClient

== Schema History — Read (Recover) ==

connector -> schemaHistory : recoverRecords(consumer)
schemaHistory -> jedisClient : xrange(redisKeyName)
activate jedisClient
jedisClient -> redis : XRANGE debezium:schema_history - +
activate redis
redis --> jedisClient : List<Map<String,String>> entries
deactivate redis
jedisClient --> schemaHistory : entries
deactivate jedisClient

loop for each entry
    schemaHistory -> schemaHistory : DocumentReader.read(entry.get("schema"))\n→ HistoryRecord
    schemaHistory -> connector : consumer.accept(record)
end

deactivate schemaHistory

@enduml
