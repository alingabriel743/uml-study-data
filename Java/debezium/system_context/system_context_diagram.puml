@startuml
title Debezium CDC Platform — System Context Diagram

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actor {
    BackgroundColor<<Person>> #08427B
    FontColor<<Person>> #FFFFFF
    BorderColor<<Person>> #052E56
}

skinparam package {
    BackgroundColor #F5F5F5
    BorderColor #BDBDBD
    FontColor #424242
    FontStyle bold
}

skinparam arrow {
    Color #424242
    FontSize 10
    FontColor #616161
}

' ── Actors ──────────────────────────────────────────────────────────────────
actor "Data Engineer\n[Connector Developer]" as engineer <<Person>>
actor "Platform Operator\n[Admin / DevOps]" as operator <<Person>>
actor "CI/CD Pipeline\n[GitHub Actions / Maven]" as cicd <<Person>>
actor "Downstream Consumer\n[App / Microservice]" as consumer <<Person>>

' ── Core System ─────────────────────────────────────────────────────────────
rectangle "**Debezium**\n[Change Data Capture Platform]\n\nCaptures row-level database changes\nvia log-based CDC and streams them\nas structured events to Apache Kafka\nand other sinks via Kafka Connect." as system <<System>>

' ── Source Databases ────────────────────────────────────────────────────────
package "Source Databases" {
    rectangle "**MySQL / Percona Server**\n[Relational Database]\n\nRead from binlog stream\nfor full change history.\nSupports GTID & snapshot." as mysql <<Database>>

    rectangle "**MariaDB**\n[Relational Database]\n\nBinlog-based CDC via\nMariaDB GTID protocol.\nSnapshot + streaming modes." as mariadb <<Database>>

    rectangle "**PostgreSQL**\n[Relational Database]\n\nLogical replication slot\nor pgoutput/wal2json\nplugin-based CDC." as postgres <<Database>>

    rectangle "**Oracle**\n[Enterprise Database]\n\nLogMiner-based CDC.\nDDL/DML captured via\nredo log inspection." as oracle <<Database>>

    rectangle "**MongoDB**\n[Document Database]\n\nOplog / Change Streams\nfor document-level CDC\nacross replica sets & shards." as mongodb <<Database>>
}

' ── Storage Backends ────────────────────────────────────────────────────────
package "Offset & Schema History Storage" {
    rectangle "**Apache Kafka**\n[Schema History Topic]\n\nStores connector schema\nhistory for DDL tracking\nand restartability." as kafkastorage <<Queue>>

    rectangle "**Redis**\n[Offset & Schema Store]\n\nOffset backing store and\nschema history via Jedis /\nJedis Cluster client." as redis <<Cache>>

    rectangle "**Amazon S3**\n[Schema History Bucket]\n\nDurable object storage\nfor schema history files\n(AWS SDK v2)." as s3 <<Infrastructure>>

    rectangle "**JDBC Storage**\n[Relational Offset Store]\n\nDatabase-backed offset\nand schema history\nsupporting any JDBC DB." as jdbcstorage <<Database>>
}

' ── Streaming Platform ──────────────────────────────────────────────────────
package "Streaming Platform" {
    rectangle "**Apache Kafka**\n[Event Streaming Broker]\n\nPrimary sink for all CDC\nevents published as\nstructured Avro/JSON records." as kafka <<Queue>>

    rectangle "**Kafka Connect**\n[Connector Runtime]\n\nManages connector lifecycle,\ntask scaling, REST API for\noperator configuration." as kafkaconnect <<Infrastructure>>
}

' ── Observability ───────────────────────────────────────────────────────────
package "Observability" {
    rectangle "**OpenLineage**\n[Data Lineage Platform]\n\nReceives lineage events\nvia HTTP transport\nfrom DebeziumOpenLineageEmitter." as openlineage <<External>>

    rectangle "**OpenTelemetry / Tracing**\n[Distributed Tracing]\n\nKafka producer instrumented\nwith tracing interceptor\nfor span propagation." as otel <<External>>

    rectangle "**JMX / Micrometer**\n[Metrics Endpoint]\n\nConnector snapshot &\nstreaming metrics exposed\nvia JMX MBeans." as jmx <<External>>
}

' ── Deployment Infrastructure ───────────────────────────────────────────────
package "Deployment Infrastructure" {
    rectangle "**OpenShift / Kubernetes**\n[Container Orchestrator]\n\nStrimzi Kafka Operator\nmanages Debezium connector\ndeployments on OCP." as ocp <<Infrastructure>>

    rectangle "**Docker / Testcontainers**\n[Container Runtime]\n\nLocal dev/test environment\nfor connectors using\npre-built DB containers." as docker <<Infrastructure>>
}

' ── Relationships: Actors → System ──────────────────────────────────────────
engineer --> system : "REST API\n(connector config & deploy)"
operator --> kafkaconnect : "REST API\n(manage connectors,\nset replicas, log levels)"
cicd --> system : "Maven / CLI\n(build, test, benchmark)"
kafka --> consumer : "Kafka protocol\n(consume CDC events)"

' ── System → Source Databases ───────────────────────────────────────────────
system --> mysql : "JDBC / Binlog protocol\n(read binlog, snapshot\ntable data)"
system --> mariadb : "JDBC / Binlog protocol\n(read MariaDB binlog,\nGTID streaming)"
system --> postgres : "JDBC / Replication slot\n(logical decoding,\nwal2json / pgoutput)"
system --> oracle : "JDBC / LogMiner\n(redo log mining,\nDDL+DML capture)"
system --> mongodb : "MongoDB Wire protocol\n(oplog tailing /\nchange stream API)"

' ── System → Streaming Platform ─────────────────────────────────────────────
system --> kafkaconnect : "Kafka Connect SPI\n(connector tasks, SMTs,\nheartbeat events)"
kafkaconnect --> kafka : "Kafka protocol\n(publish CDC records\nto topic partitions)"
kafka --> system : "Kafka protocol\n(signal channel,\nincremental snapshot signals)"

' ── System → Storage Backends ───────────────────────────────────────────────
system --> kafkastorage : "Kafka producer/consumer\n(write/read schema\nhistory DDL events)"
system --> redis : "Redis protocol (Jedis)\n(store offsets &\nschema history)"
system --> s3 : "AWS SDK v2 (HTTPS)\n(upload/download\nschema history files)"
system --> jdbcstorage : "JDBC\n(persist offsets &\nschema history rows)"

' ── System → Observability ──────────────────────────────────────────────────
system --> openlineage : "HTTP / REST\n(emit data lineage\nevents per run)"
system --> otel : "OTel SDK\n(trace Kafka producer\nrecord spans)"
system --> jmx : "JMX protocol\n(expose snapshot &\nstreaming metrics)"

' ── System → Deployment Infrastructure ──────────────────────────────────────
system --> ocp : "OCP REST API\n(operator: set replicas,\nimage pull secrets)"
system --> docker : "Docker API\n(spin up test DB\ncontainers)"

@enduml
