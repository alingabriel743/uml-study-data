@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A6EA5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Binlog Position Tracking and Offset Management

left to right direction

actor "Binlog Streaming\nEngine" as StreamingEngine
actor "Kafka Connect\nFramework" as KafkaConnect
actor "BinlogSourceTask\n(Connector)" as SourceTask
actor "External Operator" as Operator
actor "Database\n(MySQL/MariaDB)" as Database

rectangle "Binlog Position Tracking and Offset Management" {

    usecase "Track Current\nBinlog Position" as UC1
    note right of UC1
      Updates file, position,
      row, serverId, threadId
      via BinlogSourceInfo
    end note

    usecase "Track GTID-Based\nPosition" as UC9

    usecase "Manage Transaction\nBoundary for\nExactly-Once Safety" as UC4
    note right of UC4
      Saves BEGIN position as restart
      point; advances after COMMIT
    end note

    usecase "Persist Offset\nto Kafka Connect" as UC2

    usecase "Serialize Position\nto Source Info Struct" as UC7
    note right of UC7
      Builds Kafka Connect Struct
      with server_id, gtid, file,
      pos, row, thread, table
    end note

    usecase "Restore Offset\non Restart" as UC3

    usecase "Skip Events/Rows\non Restart\n(At-Least-Once)" as UC5
    note right of UC5
      Re-reads and skips already-
      processed events/rows using
      restartEventsToSkip / restartRowsToSkip
    end note

    usecase "Override Binlog\nPosition via Signal" as UC6
    note right of UC6
      'set-binlog-position' signal
      with file/position or GTID set;
      persisted via heartbeat event
    end note

    usecase "Validate Binlog\nConfiguration" as UC8
    note right of UC8
      Ensures ROW binlog_format,
      FULL binlog_row_image;
      checks for purged binlogs
    end note
}

' --- Actor → Use Case associations ---
StreamingEngine --> UC1
StreamingEngine --> UC4
StreamingEngine --> UC5
StreamingEngine --> UC9

KafkaConnect --> UC2
KafkaConnect --> UC7

SourceTask --> UC3
SourceTask --> UC8

Operator --> UC6

Database --> UC8

' --- Include / Extend relationships ---
UC9 ..> UC1 : <<include>>
UC7 ..> UC2 : <<include>>
UC3 <.. UC5 : <<extend>>
UC6 ..> UC3 : <<include>>

@enduml
