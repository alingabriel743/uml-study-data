@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #4A90D9
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Charset Registry\nMySQL/MariaDB Character Set Metadata Resolution

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────────
actor "MySQL\nConnector" as MySQLConnector
actor "MariaDB\nConnector" as MariaDBConnector
actor "Binlog\nField Reader" as BinlogFieldReader
actor "MySQL JDBC\nDriver" as MySQLDriver #EEF4FF

' ── System Boundary ──────────────────────────────────────────────────────────
rectangle "Charset Registry Subsystem" {

    usecase "Register Charset\nService Provider" as UC1
    note right of UC1
      Connector registers its
      CharsetRegistry ServiceProvider
      with DefaultServiceRegistry at startup
    end note

    usecase "Initialize Charset\nRegistry" as UC2
    note right of UC2
      Lazy init on first getService() call:
      inject → configure → start
    end note

    usecase "Resolve Collation Name\nfor Collation Index" as UC4

    usecase "Resolve Charset Name\nfor Collation Index" as UC5

    usecase "Resolve Java Encoding\nfor Charset Name" as UC6
    note right of UC6
      Returns Java encoding (e.g. UTF-8,
      Cp1252) for binary string decoding
    end note

    usecase "Get Charset\nMap Size" as UC7
    note right of UC7
      MySQL: CharsetMapping.MAP_SIZE
      MariaDB: 1024
    end note
}

' ── Actor → Use Case Associations ───────────────────────────────────────────
MySQLConnector    --> UC1
MariaDBConnector  --> UC1

MySQLConnector    --> UC2
MariaDBConnector  --> UC2

BinlogFieldReader --> UC4
BinlogFieldReader --> UC5
BinlogFieldReader --> UC6
BinlogFieldReader --> UC7

' ── External Actor Dependencies ─────────────────────────────────────────────
UC2 ..> MySQLDriver : <<uses>>\n(MySQL: delegates to\nCharsetMapping static methods)

@enduml
