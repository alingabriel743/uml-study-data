@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Connector Configuration Management

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────────
actor "Operator" as Operator
actor "BinlogDatabase\n(MySQL / MariaDB)" as BinlogDatabase
actor "ServiceRegistry" as ServiceRegistry
actor "OpenShift Cluster" as OpenShiftCluster

' ── System Boundary ─────────────────────────────────────────────────────────
rectangle "Debezium Binlog Connector Configuration Subsystem" {

    ' Connection & Security
    usecase "Configure Connection\nProperties" as UC01
    note right of UC01
      hostname, port (3306), user,
      password, server ID, query timeout
    end note

    usecase "Configure SSL Settings" as UC02
    note right of UC02
      keystore / truststore paths
      and passwords
    end note

    ' Snapshot & Streaming
    usecase "Set Snapshot Mode" as UC03
    note right of UC03
      always | initial | no_data |
      recovery | never | custom …
    end note

    usecase "Set Binlog Streaming\nOptions" as UC06
    note right of UC06
      buffer size, net read/write
      timeouts, row count threshold
    end note

    ' Filters
    usecase "Configure Table /\nDatabase Filters" as UC04
    note right of UC04
      include/exclude lists,
      ignore built-in system tables
    end note

    usecase "Configure GTID Filters" as UC05
    note right of UC05
      GTID source include/exclude,
      DML event filtering, recovery
    end note

    ' Data & Event Handling
    usecase "Configure Data Type\nHandling" as UC07
    note right of UC07
      time precision, BIGINT UNSIGNED
      mode, time adjuster, cursor fetch
    end note

    usecase "Configure Event\nHandling Modes" as UC08
    note right of UC08
      deserialization failure mode,
      inconsistent schema mode,
      include SQL query flag
    end note

    ' Validation
    usecase "Validate Configuration" as UC09
    usecase "Validate Binlog Database\nConfiguration" as UC10
    usecase "Validate Snapshot\nFeasibility" as UC11

    ' Service & Operator Infrastructure
    usecase "Register Charset Service" as UC12
    usecase "Manage Operator\nLifecycle" as UC13
    usecase "Configure Operator\nEnvironment" as UC14
    usecase "Deploy Pull Secret" as UC15
}

' ── Operator relationships ───────────────────────────────────────────────────
Operator --> UC01
Operator --> UC02
Operator --> UC03
Operator --> UC04
Operator --> UC05
Operator --> UC06
Operator --> UC07
Operator --> UC08
Operator --> UC09
Operator --> UC13
Operator --> UC14
Operator --> UC15

' ── BinlogDatabase relationships ─────────────────────────────────────────────
BinlogDatabase --> UC10
BinlogDatabase --> UC11

' ── ServiceRegistry relationships ─────────────────────────────────────────────
ServiceRegistry --> UC12

' ── OpenShift Cluster relationships ───────────────────────────────────────────
OpenShiftCluster --> UC13
OpenShiftCluster --> UC14
OpenShiftCluster --> UC15

' ── Include relationships (validation depends on config use cases) ─────────────
UC09 ..> UC03 : <<include>>
UC09 ..> UC05 : <<include>>
UC09 ..> UC07 : <<include>>

' ── Extension relationships ───────────────────────────────────────────────────
UC10 ..> UC09 : <<extend>>
UC11 ..> UC09 : <<extend>>

@enduml
