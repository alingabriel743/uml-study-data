@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7EC6
    FontColor #1B3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Custom Type Converters

left to right direction

actor "Developer" as dev
actor "ConnectorTask" as task
actor "ServiceLoader\n(SPI)" as spi

rectangle "Custom Type Converter Framework" {

    usecase "Register Converter\nvia Connector Config\n(converters=<name>)" as UC1
    usecase "Configure Converter\nwith Prefix-Scoped\nProperties (<name>.*)" as UC2
    usecase "Instantiate Converter\nClass (<name>.type)" as UC3
    usecase "Register Converter\nvia SPI\n(CustomConverterFactory)" as UC4
    usecase "Initialize\nCustomConverterRegistry" as UC5
    usecase "Look Up Converter\nfor Column\n(converterFor)" as UC6
    usecase "Register Schema\nOverride for Column" as UC7
    usecase "Transform Column Value\nduring CDC Processing" as UC8
    usecase "Skip Conversion\n(No Matching Converter)" as UC9

}

' Developer interactions
dev --> UC1 : sets connector config
dev --> UC2 : provides properties
dev --> UC4 : registers SPI factory

' ConnectorTask interactions
task --> UC5 : requests via\nDefaultServiceRegistry
task --> UC6 : at schema build time
task --> UC8 : during row processing

' SPI / ServiceLoader interactions
spi --> UC4 : discovers\nCustomConverterFactory

' Include relationships (mandatory sub-steps)
UC1 ..> UC3 : <<include>>
UC1 ..> UC2 : <<include>>
UC3 ..> UC2 : <<include>>
UC4 ..> UC5 : <<include>>
UC1 ..> UC5 : <<include>>
UC6 ..> UC7 : <<include>>

' Extend relationships (conditional flows)
UC6 <.. UC8 : <<extend>>
UC6 <.. UC9 : <<extend>>\ncondition: no match found

note bottom of UC2
  Properties scoped by prefix:
  <name>.type=com.example.MyConverter
  <name>.selector=schema.table.column
end note

note bottom of UC8
  First converter match wins.
  Wraps Converter.convert(x)
  as a ValueConverter.
end note

note right of UC4
  META-INF/services/
  io.debezium.converters.custom
  .CustomConverterFactory
end note

@enduml
