@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Data Transformation (SMT)

left to right direction

actor "Application\nDeveloper" as AppDev
actor "Kafka Connect\nPlatform" as KafkaConnect
actor "Scripting\nEngine" as ScriptingEngine #DDEEFF
actor "Benchmark\nHarness" as Benchmark #E8F5E9

rectangle "Debezium SMT Framework" {

    package "SMT Configuration" {
        usecase "Configure\nContentBasedRouter" as UC1
        usecase "Configure\nFilter SMT" as UC2
        usecase "Select Scripting\nLanguage / Engine" as UC3
        usecase "Apply Null\nHandling Policy" as UC4
    }

    package "Record Processing" {
        usecase "Route Record\nto New Topic" as UC5
        usecase "Filter Out\nChange Event" as UC6
    }

    package "Performance Benchmarking" {
        usecase "Benchmark Filter\nSMT Performance" as UC7
        usecase "Measure SMT\nOverhead (NoOp vs NewRecord)" as UC8
    }
}

' Application Developer interactions
AppDev --> UC1 : configures\ntopic.expression
AppDev --> UC2 : configures\ncondition
AppDev --> UC3 : selects language\n(jsr223.* | wasm.*)
AppDev --> UC4 : sets\nnull.handling.mode

' Kafka Connect Platform interactions
KafkaConnect --> UC5 : invokes\nContentBasedRouter
KafkaConnect --> UC6 : invokes\nFilter

' Scripting Engine interactions
ScriptingEngine --> UC5 : evaluates\ntopic.expression
ScriptingEngine --> UC6 : evaluates\ncondition

' Benchmark Harness interactions
Benchmark --> UC7 : runs FilterSmtPerf\n(JMH @Benchmark)
Benchmark --> UC8 : runs SmtOverheadPerf\n(JMH @Benchmark)

' Include relationships
UC1 ..> UC3 : <<include>>\nengine selection
UC2 ..> UC3 : <<include>>\nengine selection
UC1 ..> UC4 : <<include>>\nnull handling
UC2 ..> UC4 : <<include>>\nnull handling
UC5 ..> UC1 : <<include>>\napply config
UC6 ..> UC2 : <<include>>\napply config

' Notes
note right of UC3
  Supported engines:
  • jsr223.groovy → Jsr223Engine
  • jsr223.graal.js → GraalJsEngine
  • wasm.chicory → WasmEngine
  • wasm.chicory-interpreter → WasmEngine
end note

note right of UC5
  doApply():
  engine.eval(record, String.class)
  → non-null: record.newRecord(topicName)
  → null: pass-through original record
end note

note right of UC6
  doApply():
  engine.eval(record, Boolean.class)
  → true: pass-through record
  → false: return null (dropped)
end note

note bottom of UC7
  Benchmarks: java(), groovy(),
  javascript(), chicory(),
  chicoryInterpreter()
end note

note bottom of UC8
  Benchmarks: base(),
  noop(), newRecord()
end note

@enduml
