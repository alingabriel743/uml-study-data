@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7FBF
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343A40
}
skinparam ArrowColor #495057
skinparam ArrowFontColor #495057

title DDL Schema Change Handling

left to right direction

actor "MySqlAntlrDdlParser\n(DDL Parser)" as ddlParser
actor "MySqlDdlParserPerf\n(JMH Benchmark)" as perfBench
actor "DdlParserListener\n(Event Subscriber)" as ddlListener

rectangle "MySqlAntlrDdlParserListener\n(DDL Schema Change Handling)" {

    usecase "Create View" as UC1
    note right of UC1
      Triggered by enterCreateView /
      exitCreateView parser events.
      Handler: CreateViewParserListener
    end note

    usecase "Alter View" as UC2
    note right of UC2
      Triggered by enterAlterView /
      exitAlterView parser events.
      Handler: AlterViewParserListener
    end note

    usecase "Drop View" as UC3
    note right of UC3
      Triggered by enterDropView.
      Supports multi-view syntax.
      Handler: DropViewParserListener
    end note

    usecase "Resolve View Column\nDefinitions" as UC4
    note right of UC4
      Dynamically scoped listener.
      Handler: ViewSelectedColumnsParserListener
      Added on enter, removed on exit.
    end note

    usecase "Signal TableCreatedEvent\n(isView=true)" as UC5
    usecase "Signal TableAlteredEvent\n(isView=true)" as UC6
    usecase "Signal TableDroppedEvent\n(isView=true)" as UC7

    usecase "Benchmark DDL\nParsing Performance" as UC8
    note right of UC8
      JMH @Benchmark — measures
      parser.parse() with 1–50 columns
    end note

}

' Actor -> Use Case associations
ddlParser --> UC1
ddlParser --> UC2
ddlParser --> UC3
ddlParser --> UC8

perfBench --> UC8

' DdlParserListener receives events
UC5 --> ddlListener
UC6 --> ddlListener
UC7 --> ddlListener

' Include relationships
UC1 ..> UC4 : <<include>>
UC2 ..> UC4 : <<include>>

' Extend relationships (event signalling)
UC1 ..> UC5 : <<extend>>
UC2 ..> UC6 : <<extend>>
UC3 ..> UC7 : <<extend>>

@enduml
