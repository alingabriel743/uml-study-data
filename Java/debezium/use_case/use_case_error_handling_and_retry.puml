@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 11

title Error Handling and Retry

left to right direction

' ── External Actors ──────────────────────────────────────────────
actor "Producer Thread\n(Streaming / Snapshot)" as producer
actor "BinlogSourceTask\n(MySQL / MariaDB Connector)" as task
actor "Kafka Connect\nFramework" as kafka
actor "RetryingCallable\n(Embedded Engine)" as retrying

' ── System Boundary ──────────────────────────────────────────────
rectangle "Error Handling & Retry" {

    ' ── Core error intake ──
    usecase "Report Producer Error\nsetProducerThrowable()" as UC1
    usecase "Classify Error\nas Retriable\n(IOException / SQLException)" as UC2
    usecase "Classify Error as\nNon-Retriable\n(SQL Error 1236 — binlog fatal)" as UC3
    usecase "Apply Custom Retriable\nException Regex\n(custom.retriable.exception)" as UC4

    ' ── Retry policy ──
    usecase "Track Retry Count\nvs. errors.max.retries" as UC5
    usecase "Signal Connector Restart\n(emit RetriableException)" as UC6
    usecase "Signal Connector Stop\n(emit ConnectException)" as UC7

    ' ── Counter lifecycle ──
    usecase "Reset Retry Counter\nAfter Successful Poll" as UC8
    usecase "Preserve Retry Count\nAcross Restarts" as UC9

    ' ── Heartbeat errors ──
    usecase "Handle Heartbeat SQL Error\n(42000 / 3D000 → fatal\nothers → ignored)" as UC10

    ' ── Standalone retry wrapper ──
    usecase "Retry Callable Action\nwith DelayStrategy\n(RetryingCallable)" as UC11

    ' ── Configuration validation ──
    usecase "Validate Binlog\nConfiguration\n(format=ROW, row_image=FULL)" as UC12
}

' ── Actor → Use-Case associations ────────────────────────────────
producer    --> UC1

task        --> UC8
task        --> UC10
task        --> UC12

kafka       --> UC6 : restarts task
kafka       --> UC7 : stops task

retrying    --> UC11

' ── Include / Extend relationships ───────────────────────────────
UC1         ..> UC2  : <<include>>
UC1         ..> UC3  : <<include>>
UC2         ..> UC4  : <<extend>>\ncustom config present
UC2         ..> UC5  : <<include>>
UC5         ..> UC6  : <<extend>>\nretriable && retries remain
UC5         ..> UC7  : <<extend>>\nnot retriable or retries exhausted
UC6         ..> UC9  : <<include>>
UC8         ..> UC1  : <<extend>>\nresets on next error

@enduml
