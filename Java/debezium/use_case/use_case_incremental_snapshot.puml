@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #336699
    FontColor #1a1a2e
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam ArrowColor #495057

title Incremental Snapshot

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────────
actor "Operator" as operator
actor "NotificationService\n(Log / JMX / Kafka)" as notifSvc <<system>>
actor "SnapshotterService\n(SPI Registry)" as snapshotterSvc <<system>>
actor "BinlogReadOnly\nEventSource" as binlogSrc <<system>>

' ── System boundary ─────────────────────────────────────────────────────────
rectangle "Debezium Incremental Snapshot System" {

    usecase "Initiate Incremental Snapshot\n<size:10>[signal: execute-snapshot]</size>" as UC1
    usecase "Pause Incremental Snapshot\n<size:10>[signal: pause-snapshot]</size>" as UC2
    usecase "Resume Incremental Snapshot\n<size:10>[signal: resume-snapshot]</size>" as UC3
    usecase "Stop Incremental Snapshot\n<size:10>[signal: stop-snapshot]</size>" as UC4
    usecase "Monitor Snapshot Progress\n<size:10>[STARTED | IN_PROGRESS | COMPLETED\nPAUSED | RESUMED | ABORTED]</size>" as UC5
    usecase "Manage Snapshot Window\n<size:10>[snapshot-window-open / snapshot-window-close]</size>" as UC6
    usecase "Process Binlog Events\nDuring Snapshot\n<size:10>[GTID watermark deduplication]</size>" as UC7
    usecase "Evaluate Snapshot Mode\n<size:10>[shouldSnapshotData / shouldStream]</size>" as UC8

}

' ── Operator associations ────────────────────────────────────────────────────
operator --> UC1
operator --> UC2
operator --> UC3
operator --> UC4
operator --> UC5

' ── NotificationService associations ────────────────────────────────────────
notifSvc --> UC5

' ── SnapshotterService associations ─────────────────────────────────────────
snapshotterSvc --> UC8

' ── BinlogReadOnly associations ──────────────────────────────────────────────
binlogSrc --> UC7

' ── Include relationships ────────────────────────────────────────────────────
UC1 ..> UC5 : <<include>>
UC2 ..> UC5 : <<include>>
UC3 ..> UC5 : <<include>>
UC4 ..> UC5 : <<include>>
UC7 ..> UC6 : <<include>>
UC1 ..> UC8 : <<include>>

' ── Extend relationships ─────────────────────────────────────────────────────
UC7 <.. UC3 : <<extend>>\nif binlog read-only

@enduml
