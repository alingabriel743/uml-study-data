@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Initial Snapshot\n<size:11>//Database administrator triggers and monitors a full initial table snapshot//</size>

left to right direction

actor "Database\nAdministrator" as DBA
actor "Connector\nFramework" as CF #D0E8FF
actor "Notification\nChannel" as NC

rectangle "Debezium Binlog Connector  (MySQL / MariaDB)" {

    usecase "Configure Snapshot Mode\n<size:10>(snapshot.mode, custom.name)</size>" as UC1
    usecase "Provision Snapshotter Service\n<size:10>(SnapshotterServiceProvider)</size>" as UC2
    usecase "Initiate Full Table Snapshot\n<size:10>(BinlogSnapshotContext + STARTED)</size>" as UC3
    usecase "Acquire Database Lock\n<size:10>(FLUSH TABLES WITH READ LOCK)</size>" as UC4
    usecase "Capture Table Schema\n<size:10>(SHOW CREATE TABLE + DDL events)</size>" as UC5
    usecase "Determine Binlog Snapshot Offset\n<size:10>(record binlog position / GTID)</size>" as UC6
    usecase "Release Schema Locks\n<size:10>(early global unlock, minimal locking)</size>" as UC7
    usecase "Snapshot Table Data\n<size:10>(read all rows, forward-only cursor)</size>" as UC8
    usecase "Monitor Snapshot Progress\n<size:10>(IN_PROGRESS / CHUNK notifications)</size>" as UC9
    usecase "Release Data Locks\n<size:10>(UNLOCK TABLES + delayed schema)</size>" as UC10
    usecase "Complete Snapshot\n<size:10>(mark last record + COMPLETED)</size>" as UC11
    usecase "Receive Snapshot Status Notification\n<size:10>(STARTED / COMPLETED / ABORTED / SKIPPED)</size>" as UC12
    usecase "Abort Snapshot\n<size:10>(identity last event + ABORTED)</size>" as UC13

}

' --- DBA interactions ---
DBA --> UC1
DBA --> UC9
DBA --> UC12

' --- Connector Framework interactions ---
CF --> UC2
CF --> UC3
CF --> UC4
CF --> UC5
CF --> UC6
CF --> UC7
CF --> UC8
CF --> UC10
CF --> UC11
CF --> UC13

' --- Notification Channel receives ---
UC12 --> NC
UC9  --> NC

' --- Include / Extend relationships ---
UC3 ..> UC2 : <<extend>>
UC7 ..> UC4 : <<extend>>
UC10 ..> UC7 : <<include>>
UC11 ..> UC10 : <<include>>
UC13 ..> UC3  : <<extend>>

@enduml
