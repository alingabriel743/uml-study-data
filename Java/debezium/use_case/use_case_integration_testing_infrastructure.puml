@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #336699
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057

title Integration Testing Infrastructure

left to right direction

' ── Actors ────────────────────────────────────────────────────────
actor "Test Engineer" as TestEngineer
actor "Quarkus Test\nFramework" as QuarkusTestFramework
actor "Docker /\nTestcontainers" as DockerTC

' ── System boundary ───────────────────────────────────────────────
rectangle "Integration Test Infrastructure\n(debezium-testing-testcontainers + binlog test utilities)" {

    ' -- PostgreSQL lifecycle --
    usecase "Start PostgreSQL Container\n(PostgresTestResourceLifecycleManager)" as UC1
    usecase "Stop PostgreSQL Container" as UC2
    usecase "Expose PostgreSQL\nConfig Properties" as UC1a

    ' -- Apicurio lifecycle --
    usecase "Start Apicurio Schema\nRegistry Container\n(ApicurioTestResourceLifeCycleManager)" as UC3
    usecase "Stop Apicurio Container" as UC4
    usecase "Resolve Container\nImage Version" as UC3a
    usecase "Resolve Apicurio\nRegistry URL" as UC8

    ' -- Kafka + Schema Registry lifecycle --
    usecase "Start Kafka + Schema\nRegistry Containers\n(SchemaRegistryTestResourceLifecycleManager)" as UC5
    usecase "Stop Schema Registry\nContainer" as UC6
    usecase "Create Shared\nDocker Network" as UC5a

    ' -- Binlog connection --
    usecase "Obtain Binlog Test\nDatabase Connection\n(TestConnectionService)" as UC7
    usecase "Discover Test Connection\nProvider via SPI\n(MySQL / MariaDB)" as UC7a

}

' ── Actor → Use-case relationships ────────────────────────────────

' Quarkus Test Framework drives container lifecycle
QuarkusTestFramework --> UC1
QuarkusTestFramework --> UC2
QuarkusTestFramework --> UC3
QuarkusTestFramework --> UC4
QuarkusTestFramework --> UC5
QuarkusTestFramework --> UC6

' Test Engineer initiates test run and uses helpers directly
TestEngineer --> QuarkusTestFramework : triggers test run
TestEngineer --> UC7
TestEngineer --> UC8

' Docker/Testcontainers is invoked by the start use-cases
UC1 --> DockerTC : provisions container
UC3 --> DockerTC : provisions container
UC5 --> DockerTC : provisions containers\n(parallel via Startables.deepStart)
UC2 --> DockerTC : destroys container
UC4 --> DockerTC : destroys container
UC6 --> DockerTC : destroys container

' ── Include relationships ──────────────────────────────────────────
UC1 ..> UC1a  : <<include>>
UC3 ..> UC3a  : <<include>>
UC3 ..> UC8   : <<extend>>
UC5 ..> UC5a  : <<include>>
UC7 ..> UC7a  : <<include>>

@enduml
