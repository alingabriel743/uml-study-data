@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam ArrowColor #495057

title Kafka Connect Component Discovery

left to right direction

' ─── Actors ───────────────────────────────────────────────────────────────────
actor "SchemaGenerator\nPlatform" as platform
actor "JVM ClassLoader"          as classloader
actor "JAR File System"          as jarfs
actor "Jandex Library"           as jandex

' ─── System boundary ──────────────────────────────────────────────────────────
rectangle "KafkaConnectDiscoveryService" {

    usecase "Discover Kafka Connect\nComponents\n(discoverKafkaConnectComponents)" as UC1
    usecase "Scan Classpath\nfor KC JARs\n(indexKafkaConnectJars)" as UC2
    usecase "Index KC JAR File\n(indexJarFile)" as UC3
    usecase "Load Pre-built\nJandex Index\n(tryLoadPrebuiltIndex)" as UC4
    usecase "Build Jandex Index\nfrom JAR Classes\n(createIndexFromJarClasses)" as UC5
    usecase "Query Index for\nComponent Implementations\n(discoverComponentType)" as UC6
    usecase "Extract JAR Path\nfrom URL\n(extractJarPath)" as UC7

    note right of UC1
      Returns:
      Map<ComponentType, List<Class<?>>>
      Types: TRANSFORMATION, CONVERTER,
      HEADER_CONVERTER, PREDICATE
    end note

    note bottom of UC6
      Filters applied:
      • Class starts with "org.apache.kafka."
      • Class is not abstract
      • Loadable via Class.forName()
    end note
}

' ─── Actor → Use Case associations ───────────────────────────────────────────
platform    --> UC1
classloader --> UC2
jarfs       --> UC3
jarfs       --> UC7
jandex      --> UC4
jandex      --> UC5
jandex      --> UC6

' ─── Include relationships ────────────────────────────────────────────────────
UC1 ..> UC2 : <<include>>
UC1 ..> UC6 : <<include>>
UC2 ..> UC3 : <<include>>
UC2 ..> UC7 : <<include>>

' ─── Extend relationships ─────────────────────────────────────────────────────
UC4 ..> UC3 : <<extend>>\ntry pre-built index first
UC5 ..> UC3 : <<extend>>\nfallback: scan .class files

@enduml
