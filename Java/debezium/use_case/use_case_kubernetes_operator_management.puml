@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}

title Kubernetes Operator Management

left to right direction

actor "Platform Engineer" as PlatformEngineer
actor "OpenShift Cluster\n(fabric8 API)" as OpenShiftCluster

rectangle "Kubernetes / OpenShift Operator Management\n(Debezium Testing Framework)" {

    ' --- Lifecycle ---
    usecase "Deploy / Update Operator" as UC1
    usecase "Enable Operator\n(scale to 1 replica)" as UC2
    usecase "Disable Operator\n(scale to 0 replicas)" as UC3
    usecase "Scale Connector Replicas" as UC4

    ' --- Image / Pull Secret ---
    usecase "Deploy Image Pull Secret" as UC5
    usecase "Set Image Pull Secret\non Deployment" as UC6

    ' --- Image Pull Policy ---
    usecase "Set Always Pull Policy" as UC7
    usecase "Set Operand Always Pull Policy\n(Strimzi)" as UC12

    ' --- Environment Variables ---
    usecase "Set Environment Variable" as UC8
    usecase "Unset Environment Variable" as UC9
    usecase "Configure Operand Image\nPull Secrets (Strimzi)" as UC10
    usecase "Set Operator Log Level\n(Strimzi)" as UC11

    ' --- Readiness ---
    usecase "Wait for Operator\nAvailability" as UC13
}

' ---- Actor → Use Case associations ----
PlatformEngineer --> UC1
PlatformEngineer --> UC2
PlatformEngineer --> UC3
PlatformEngineer --> UC4
PlatformEngineer --> UC5
PlatformEngineer --> UC6
PlatformEngineer --> UC7
PlatformEngineer --> UC8
PlatformEngineer --> UC9
PlatformEngineer --> UC10
PlatformEngineer --> UC11
PlatformEngineer --> UC12

OpenShiftCluster --> UC13

' ---- Include relationships ----
UC5 ..> UC6  : <<include>>
UC1 ..> UC13 : <<include>>
UC2 ..> UC13 : <<include>>

' ---- Extend relationships ----
UC10 ..> UC8  : <<extend>>
UC11 ..> UC8  : <<extend>>
UC12 ..> UC7  : <<extend>>

' ---- Notes ----
note bottom of UC4
  setSingleReplica() is a
  shortcut setting replicas = 1
end note

note right of UC13
  Polls OpenShift Deployments API
  until condition = Available
  (timeout scaled by env)
end note

note right of OpenShiftCluster
  StrimziOperatorController
  ApicurioOperatorController
  (both extend OperatorController)
end note

@enduml
