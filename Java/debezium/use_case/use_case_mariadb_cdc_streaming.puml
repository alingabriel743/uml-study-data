@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}

title MariaDB CDC Streaming

left to right direction

actor "Kafka Connect\nPlatform" as KafkaConnect #D0E8FF
actor "MariaDB\nDatabase" as MariaDB #D6F5D6
actor "Apache Kafka\n(Broker)" as Kafka #FFE8CC

rectangle "MariaDB CDC Streaming System" {

    package "Connector Lifecycle" {
        usecase "Deploy Connector" as UC1
        usecase "Bootstrap CDC Pipeline" as UC3
        usecase "Validate Binlog\nConfiguration" as UC2
        usecase "Stop / Cleanup" as UC14
    }

    package "Binlog Streaming" {
        usecase "Connect to\nMariaDB Binlog" as UC4
        usecase "Stream Binlog Events" as UC5
        usecase "Handle GTID\nTransaction" as UC6
        usecase "Track Binlog\nPosition" as UC7
    }

    package "Change Event Processing" {
        usecase "Dispatch DML\nChange Events" as UC8
        usecase "Capture SQL Query\n(ANNOTATE_ROWS)" as UC9
        usecase "Handle Schema\nChanges (DDL)" as UC10
        usecase "Publish Change\nRecords to Kafka" as UC12
    }

    package "Reliability & Monitoring" {
        usecase "Handle Streaming\nErrors" as UC11
        usecase "Heartbeat /\nKeep-alive" as UC13
    }
}

' --- KafkaConnect actor associations ---
KafkaConnect --> UC1 : deploys
KafkaConnect --> UC3 : starts task
KafkaConnect --> UC14 : stops connector

' --- Connector Lifecycle include relationships ---
UC3 ..> UC2 : <<include>>
UC3 ..> UC4 : <<include>>
UC3 ..> UC13 : <<include>>

' --- MariaDB as external binlog source ---
UC4 --> MariaDB : connects via\nBinaryLogClient
MariaDB --> UC5 : delivers raw\nbinlog events

' --- Streaming event handling ---
UC5 ..> UC6 : <<include>>
UC5 ..> UC7 : <<include>>
UC5 ..> UC8 : <<include>>
UC5 <.. UC9 : <<extend>>\n(if sql.query.include=true)
UC5 <.. UC10 : <<extend>>\n(on DDL / QUERY event)
UC5 <.. UC11 : <<extend>>\n(on error)

' --- Change event publishing ---
UC8 ..> UC12 : <<include>>
UC10 ..> UC12 : <<include>>
UC12 --> Kafka : enqueues\nSourceRecords

@enduml
