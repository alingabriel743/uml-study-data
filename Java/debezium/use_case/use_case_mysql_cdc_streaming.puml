@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam arrow {
    Color #495057
    FontColor #495057
    FontSize 11
}

title MySQL CDC Streaming

left to right direction

actor "DBA / Operator" as dba
actor "Kafka Connect\nFramework" as kcf
actor "MySQL Database\n(BinaryLogClient)" as mysql
actor "Kafka Broker" as kafka #D5F5E3

rectangle "MySQL CDC Streaming Pipeline (Debezium)" {

    ' ── Configuration & Deployment ──
    usecase "Configure MySQL\nConnector" as UC1
    usecase "Deploy Connector\nTask" as UC2
    usecase "Initialize Task &\nValidate Binlog" as UC3

    ' ── Core Streaming ──
    usecase "Stream Binlog\nChange Events" as UC4

    ' ── DML Event Handlers ──
    usecase "Handle INSERT /\nWRITE_ROWS Event" as UC5
    usecase "Handle UPDATE /\nUPDATE_ROWS Event" as UC6
    usecase "Handle DELETE /\nDELETE_ROWS Event" as UC7

    ' ── Special Event Handlers ──
    usecase "Handle DDL /\nSchema Change Event" as UC8
    usecase "Handle GTID Event" as UC9
    usecase "Handle Transaction\nPayload (Compressed)" as UC10

    ' ── Position & File Tracking ──
    usecase "Rotate Binlog File" as UC11
    usecase "Track Binlog Position\n/ Source Metadata" as UC12

    ' ── Output & Error Handling ──
    usecase "Dispatch Change\nEvent to Kafka" as UC13
    usecase "Handle Streaming\nError" as UC14
    usecase "Handle Heartbeat\nError" as UC15
    usecase "Monitor Streaming\nMetrics" as UC16

    ' ── Lifecycle ──
    usecase "Handle BinaryLogClient\nLifecycle Events" as UC17

}

' ── Actor → Use Case associations ──
dba       --> UC1

kcf       --> UC2
kcf       --> UC3
kcf       --> UC14
kcf       --> UC15
kcf       --> UC16

mysql     --> UC4
mysql     --> UC11
mysql     --> UC17

kafka     --> UC13

' ── Include relationships ──
UC4  ..> UC16 : <<include>>
UC11 ..> UC12 : <<include>>

' ── Extend relationships ──
UC5  ..> UC4 : <<extend>>
UC6  ..> UC4 : <<extend>>
UC7  ..> UC4 : <<extend>>
UC8  ..> UC4 : <<extend>>
UC9  ..> UC4 : <<extend>>
UC10 ..> UC4 : <<extend>>
UC14 ..> UC4 : <<extend>>
UC13 ..> UC4 : <<extend>>

note bottom of UC3
  Validates:
  • binlog_format = ROW
  • binlog_row_image = FULL
  • snapshot feasibility
  • schema history
end note

note bottom of UC14
  MySQL error 1236
  (ER_MASTER_FATAL_ERROR_READING_BINLOG)
  is NON-RETRIABLE
end note

@enduml
