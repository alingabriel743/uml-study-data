@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}

title Notifications and Monitoring

left to right direction

' ── Primary actors (left side) ──────────────────────────────────────
actor "Connector / Pipeline" as connector
actor "Administrator" as admin

' ── External consumer actors (right side) ───────────────────────────
actor "Kafka Consumer /\nMonitoring System" as kafka
actor "JMX Client" as jmx
actor "Log Aggregator" as logAgg

rectangle "Debezium Notification System" {

    ' ── Channel configuration ────────────────────────────────────────
    usecase "Configure Notification\nChannels" as UC1

    ' ── Initial snapshot lifecycle ───────────────────────────────────
    usecase "Notify Initial Snapshot\nStarted" as UC2
    usecase "Notify Initial Snapshot\nTable In Progress" as UC3
    usecase "Notify Initial Snapshot\nTable Chunk Progress" as UC4
    usecase "Notify Initial Snapshot\nTable Completed" as UC5
    usecase "Notify Initial Snapshot\nCompleted / Aborted / Skipped" as UC6

    ' ── Incremental snapshot lifecycle ───────────────────────────────
    usecase "Notify Incremental\nSnapshot Started" as UC7
    usecase "Notify Incremental\nSnapshot In Progress" as UC8
    usecase "Notify Incremental\nTable Scan Completed" as UC9
    usecase "Notify Incremental\nSnapshot Paused / Resumed" as UC10
    usecase "Notify Incremental\nSnapshot Aborted / Completed" as UC11

    ' ── Shared dispatch ──────────────────────────────────────────────
    usecase "Dispatch Notification\nto Enabled Channels" as UCDISP

    ' ── Channel delivery ─────────────────────────────────────────────
    usecase "Receive Notification\nvia Log Channel" as UC12
    usecase "Receive Notification\nvia Kafka Sink Topic" as UC13
    usecase "Receive Notification\nvia JMX Broadcast" as UC14

    ' ── JMX query & lifecycle ────────────────────────────────────────
    usecase "Query Stored\nJMX Notifications" as UC15
    usecase "Stop Notification\nService" as UC16
}

' ── Actor → use-case associations ────────────────────────────────────
admin     --> UC1

connector --> UC2
connector --> UC3
connector --> UC4
connector --> UC5
connector --> UC6
connector --> UC7
connector --> UC8
connector --> UC9
connector --> UC10
connector --> UC11
connector --> UC16

logAgg    --> UC12
kafka     --> UC13
jmx       --> UC14
jmx       --> UC15

' ── Snapshot notifications <<include>> dispatch ───────────────────────
UC2  ..> UCDISP : <<include>>
UC3  ..> UCDISP : <<include>>
UC4  ..> UCDISP : <<include>>
UC5  ..> UCDISP : <<include>>
UC6  ..> UCDISP : <<include>>
UC7  ..> UCDISP : <<include>>
UC8  ..> UCDISP : <<include>>
UC9  ..> UCDISP : <<include>>
UC10 ..> UCDISP : <<include>>
UC11 ..> UCDISP : <<include>>

' ── Dispatch <<include>> channel delivery ────────────────────────────
UCDISP ..> UC12 : <<include>>
UCDISP ..> UC13 : <<include>>
UCDISP ..> UC14 : <<include>>

@enduml
