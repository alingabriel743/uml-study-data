@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAD
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam ArrowColor #495057

title Performance Benchmarking\nJMH Micro-Benchmarks for Core CDC Pipeline Components

left to right direction

actor "Performance\nEngineer" as PE
actor "JMH Runner\n(Harness)" as JMH <<system>>

rectangle "Debezium JMH Micro-Benchmark Suite\n(debezium-microbenchmark)" {

    package "ChangeEventQueue Benchmarks" {
        usecase "Benchmark Producer\nThroughput\n(enqueue ops/sec)" as UC1
        usecase "Benchmark Consumer\nThroughput\n(poll ops/sec)" as UC2
        usecase "Benchmark Full Queue Cycle\n(10M records, 1 producer)\n[AverageTime, ms]" as UC3
        usecase "Benchmark Multi-Writer Queue\n(10 producers × 1M records)\n[AverageTime, ms]" as UC4
    }

    package "SMT Overhead Benchmarks" {
        usecase "Benchmark SMT\nNewRecord Overhead\n(ops/μs)" as UC5
        usecase "Benchmark SMT\nNoOp Overhead\n(ops/μs)" as UC6
        usecase "Benchmark SMT\nBase (empty method)\n[JMH baseline]" as UC7
    }

    package "Relational Metadata Benchmarks" {
        usecase "Benchmark IncrementalSnapshot\nContext Serialization\n(ops/sec, N tables)" as UC8
        usecase "Benchmark TableId\nParsing\n[AverageTime, ns]" as UC9
    }

    package "MySQL DDL Parser Benchmarks" {
        usecase "Benchmark MySQL DDL\nParser (ANTLR)\n[AverageTime, μs]" as UC10
    }

    usecase "Configure Benchmark\nParameters\n(pollInterval, columnCount, etc.)" as UC_CFG
    usecase "Manage JVM Warmup\n& Measurement Lifecycle\n(@Setup / @TearDown)" as UC_JVM

}

' --- Performance Engineer initiates all benchmarks ---
PE --> UC1
PE --> UC2
PE --> UC3
PE --> UC4
PE --> UC5
PE --> UC6
PE --> UC7
PE --> UC8
PE --> UC9
PE --> UC10
PE --> UC_CFG

' --- JMH Runner manages lifecycle ---
JMH --> UC_JVM
JMH --> UC1
JMH --> UC2
JMH --> UC3
JMH --> UC4
JMH --> UC5
JMH --> UC6
JMH --> UC7
JMH --> UC8
JMH --> UC9
JMH --> UC10

' --- Include relationships ---
UC1 ..> UC_CFG : <<include>>
UC2 ..> UC_CFG : <<include>>
UC3 ..> UC_CFG : <<include>>
UC4 ..> UC_CFG : <<include>>
UC8 ..> UC_CFG : <<include>>
UC10 ..> UC_CFG : <<include>>

UC1 ..> UC_JVM : <<include>>
UC3 ..> UC_JVM : <<include>>
UC5 ..> UC_JVM : <<include>>
UC9 ..> UC_JVM : <<include>>
UC10 ..> UC_JVM : <<include>>

' --- Extend: contention variant extends the single-producer baseline ---
UC3 <.. UC4 : <<extend>>\nconcurrent writers

' --- Extend: NoOp and Base are baseline variants of NewRecord ---
UC5 <.. UC6 : <<extend>>\nno-op baseline
UC5 <.. UC7 : <<extend>>\nempty baseline

note bottom of UC_JVM
  JMH controls:
  • @Fork(1) per benchmark
  • @State(Scope.Thread)
  • Warmup + Measurement iterations
  • Collects throughput / avg-time metrics
end note

note right of PE
  Triggers benchmarks via JMH CLI
  Analyzes throughput, latency,
  and scalability results
end note

@enduml
