@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057

title Post-Processing Pipeline

left to right direction

actor "Developer" as developer
actor "Connector\n(BaseSourceTask)" as connector
actor "EventDispatcher" as dispatcher
actor "PostProcessorFactory\n(SPI)" as spi #E9ECEF

rectangle "Post-Processing Pipeline" {

    usecase "Configure Post-Processors\n<size:10>(custom.post.processors config)</size>" as UC1
    usecase "Register\nPostProcessorRegistryServiceProvider" as UC2
    usecase "Load and Instantiate\nPostProcessors" as UC3
    usecase "Inject Dependencies\ninto PostProcessors" as UC4
    usecase "Apply Post-Processors\nto Change Record" as UC5
    usecase "Re-select Columns\n<size:10>(ReselectColumnsPostProcessor)</size>" as UC6
    usecase "Supply External PostProcessors\nvia SPI" as UC7
    usecase "Shut Down and\nClose PostProcessors" as UC8

}

' Developer interactions
developer --> UC1
developer --> UC6

' Connector (BaseSourceTask) interactions
connector --> UC2
connector --> UC3
connector --> UC4
connector --> UC8

' EventDispatcher interactions
dispatcher --> UC5

' SPI interactions
spi --> UC7

' Use case relationships
UC3 ..> UC4 : <<include>>
UC5 ..> UC6 : <<include>>
UC7 ..> UC3 : <<extend>>

note bottom of UC6
  Re-queries DB via JdbcConnection
  to patch mutable Struct in-place
  before change event is enqueued
end note

note right of UC5
  Iterates PostProcessorRegistry.getProcessors()
  and calls processor.apply(key, value)
  on every snapshot or streaming change event
end note

@enduml
