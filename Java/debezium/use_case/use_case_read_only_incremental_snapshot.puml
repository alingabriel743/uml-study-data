@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #1A1A2E
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Read-Only Incremental Snapshot\n<size:11><i>Read-replica use cases: performing incremental snapshots without locking the primary database</i></size>

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────────
actor "Binlog Source Task" as BinlogSourceTask #D0E8FF
actor "Operator\n<size:10>(Signal Producer)</size>" as Operator #D4EDDA
actor "Read Replica\nDatabase" as ReadReplicaDB #FFE8CC

' ── System boundary ─────────────────────────────────────────────────────────
rectangle "Read-Only Incremental Snapshot System\n<size:10>(BinlogReadOnlyIncrementalSnapshotChangeEventSource)</size>" {

    ' Setup & Configuration
    usecase "Configure Read-Only\nConnection\n<size:9>read.only=true\n(BinlogConnectorConfig)</size>" as UC1
    usecase "Validate Snapshot\nFeasibility\n<size:9>checks binlog purge,\nsnapshotter.shouldSnapshotData()</size>" as UC2
    usecase "Validate Binlog\nConfiguration\n<size:9>ROW format + FULL\nrow image required</size>" as UC3
    usecase "Resolve No-Lock\nSnapshot Strategy\n<size:9>NoneSnapshotLock:\ntableLockingStatement() = empty</size>" as UC4

    ' Snapshot Context
    usecase "Manage Snapshot\nContext State\n<size:9>BinlogReadOnlyIncrementalSnapshotContext:\nGTID watermarks + window state</size>" as UC12

    ' Operator-driven
    usecase "Add Data Collections\nto Snapshot\n<size:9>signal → addDataCollectionNamesToSnapshot()</size>" as UC5
    usecase "Stop Snapshot\n<size:9>signal → requestStopSnapshot()</size>" as UC11

    ' Replica-driven event processing
    usecase "Process Binlog\nMessage\n<size:9>updateWindowState();\nclose window → sendWindowEvents + readChunk</size>" as UC6
    usecase "Process Heartbeat\nEvent\n<size:9>readUntilGtidChange();\nloop until high watermark reached</size>" as UC7
    usecase "Process Filtered /\nTransaction Events\n<size:9>updateWindowState();\nreadUntilGtidChange() on commit</size>" as UC8

    ' GTID Watermarking
    usecase "Track GTID\nWatermarks\n<size:9>emitWindowOpen → setLowWatermark\nemitWindowClose → setHighWatermark\ngetExecutedGtidSet() [abstract]</size>" as UC9

    ' Failover guard
    usecase "Re-read Chunk on\nServer Identity Change\n<size:9>hasServerIdentifierChanged()\n→ rereadChunk() on failover</size>" as UC10
}

' ── Actor → Use Case associations ────────────────────────────────────────────
BinlogSourceTask --> UC1
BinlogSourceTask --> UC2
BinlogSourceTask --> UC3
BinlogSourceTask --> UC4
BinlogSourceTask --> UC12

Operator --> UC5
Operator --> UC11

ReadReplicaDB --> UC6
ReadReplicaDB --> UC7
ReadReplicaDB --> UC8

' ── Include / Extend relationships ───────────────────────────────────────────
UC2 ..> UC3   : <<include>>\nvalidate binlog config
UC4 ..> UC12  : <<include>>\nuses snapshot context

UC6 ..> UC9   : <<include>>\ntrack GTID window
UC7 ..> UC9   : <<include>>\ntrack GTID window
UC8 ..> UC9   : <<include>>\ntrack GTID window

UC10 ..> UC9  : <<extend>>\nserver identity changed\nduring window close

UC5 ..> UC12  : <<include>>\nupdate context state
UC11 ..> UC12 : <<include>>\nupdate context state

@enduml
