@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Schema Registry Integration

left to right direction

' ── Primary actors ──────────────────────────────────────────────
actor "Developer / Tester" as DevTester
actor "Quarkus Test\nFramework" as Quarkus

' ── Internal system actor ────────────────────────────────────────
actor "Debezium\nConnector" as Connector

' ── External systems ─────────────────────────────────────────────
actor "Apicurio\nRegistry" as Apicurio #DDEEFF
actor "Confluent Schema\nRegistry" as Confluent #DDEEFF
actor "Kafka Broker" as Kafka #DDEEFF
actor "PostgreSQL\nDatabase" as Postgres #DDEEFF

' ── System boundary ──────────────────────────────────────────────
rectangle "Schema Registry Integration" {

    ' ── Apicurio sub-system ──────────────────────────────────────
    package "Apicurio Registry Support" {
        usecase "Start Apicurio\nRegistry Container" as UC1
        usecase "Manage Apicurio Registry\nLifecycle (Quarkus)" as UC2
        usecase "Convert CDC Events\nto JSON with Schema" as UC5
        usecase "Convert CDC Events\nto Avro with Schema" as UC6
        usecase "Convert CDC Events to\nCloudEvents with Avro Data" as UC7
        usecase "Auto-Register Schema" as UC8
        usecase "Retrieve Latest Schema" as UC9
    }

    ' ── Confluent sub-system ─────────────────────────────────────
    package "Confluent Schema Registry Support" {
        usecase "Start Confluent Schema\nRegistry Container" as UC4
        usecase "Manage Confluent Registry\nLifecycle (Quarkus)" as UC3
    }

    ' ── Cross-cutting use cases ───────────────────────────────────
    package "Connector & Validation" {
        usecase "Register Kafka Connector\nwith Schema Registry Config" as UC11
        usecase "Validate Connector Behavior\nwith Invalid Config" as UC10
    }
}

' ── Developer / Tester relationships ────────────────────────────
DevTester --> UC1
DevTester --> UC4
DevTester --> UC11
DevTester --> UC10

' ── Quarkus Test Framework relationships ────────────────────────
Quarkus --> UC2
Quarkus --> UC3

' ── Debezium Connector relationships ────────────────────────────
Connector --> UC5
Connector --> UC6
Connector --> UC7
Connector --> UC8
Connector --> UC9

' ── Include relationships ────────────────────────────────────────
UC2 ..> UC1 : <<include>>
UC3 ..> UC4 : <<include>>
UC5 ..> UC8 : <<include>>
UC5 ..> UC9 : <<include>>
UC6 ..> UC8 : <<include>>
UC6 ..> UC9 : <<include>>
UC7 ..> UC8 : <<include>>
UC7 ..> UC9 : <<include>>
UC11 ..> UC1 : <<include>>

' ── External system interactions ────────────────────────────────
UC1 --> Apicurio : hosts
UC5 --> Apicurio : registers / validates schema
UC6 --> Apicurio : registers / validates schema
UC7 --> Apicurio : registers / validates schema
UC4 --> Confluent : hosts
UC3 --> Kafka : requires bootstrap
UC4 --> Kafka : connects via network
UC11 --> Postgres : CDC source

@enduml
