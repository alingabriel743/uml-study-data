@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F9A825

title Service Registry and Dependency Injection

left to right direction

actor "Connector\nFramework" as framework
actor "Service\nProvider" as provider
actor "Snapshotter\nServiceProvider" as snapshotProvider

note right of snapshotProvider
  Concrete ServiceProvider
  for SnapshotterService
  (uses Java ServiceLoader)
end note

rectangle "Service Registry Framework  (DefaultServiceRegistry)" {

    package "Service Registration" {
        usecase "Register Pre-built\nService Instance" as UC1
        usecase "Register Service\nProvider (Lazy)" as UC2
    }

    package "Service Resolution" {
        usecase "Retrieve Service\nby Type (getService)" as UC3
        usecase "Safely Retrieve Service\n(tryGetService → null on miss)" as UC4
        usecase "Lazily Initialize\nService on First Access" as UC5
    }

    package "Service Lifecycle (Multi-Phase Init)" {
        usecase "Inject @InjectService\nDependencies" as UC6
        usecase "Inject ServiceRegistry\nReference (ServiceRegistryAware)" as UC7
        usecase "Configure Service\n(Configurable)" as UC8
        usecase "Start Service\n(Startable)" as UC9
        usecase "Shutdown All Services\nin Reverse Order (Closeable)" as UC10
    }

    package "SnapshotterService Creation" {
        usecase "Create SnapshotterService\nvia ServiceProvider" as UC11
        usecase "Resolve Snapshotter\nvia Java ServiceLoader" as UC12
        usecase "Inject BeanRegistry\ninto Snapshotter" as UC13
    }

    package "Error Handling" {
        usecase "Raise\nUnknownServiceException" as UC14
        usecase "Raise\nServiceDependencyException" as UC15
    }
}

' --- ConnectorFramework interactions ---
framework --> UC1 : pre-registers BeanRegistry\nat startup
framework --> UC2 : registers connector\nservice providers
framework --> UC3 : requests service\nby class type
framework --> UC4 : optionally resolves\nnon-critical services
framework --> UC10 : triggers graceful\nshutdown

' --- ServiceProvider interactions ---
provider --> UC2 : supplies factory\nfor service type
provider --> UC5 : createService(config, registry)

' --- SnapshotterServiceProvider interactions ---
snapshotProvider --> UC11 : implements\nServiceProvider<SnapshotterService>
snapshotProvider --> UC12 : loads Snapshotter SPI\nimplementations

' --- include / extend relationships ---

UC4 ..> UC3 : <<include>>

UC3 ..> UC5 : <<include>>\n(on cache miss)

UC5 ..> UC6 : <<include>>
UC5 ..> UC7 : <<include>>
UC5 ..> UC8 : <<include>>
UC5 ..> UC9 : <<include>>

UC6 ..> UC3 : <<include>>\n(recursive dep resolution)

UC11 ..> UC12 : <<include>>
UC13 <.. UC11 : <<extend>>\n(if BeanRegistryAware)

UC14 <.. UC3 : <<extend>>\n(no registration found)
UC15 <.. UC6 : <<extend>>\n(required=true & missing)

@enduml
