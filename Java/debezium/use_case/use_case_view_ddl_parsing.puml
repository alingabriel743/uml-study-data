@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #1A3C5E
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title View DDL Parsing\nANTLR Listeners Parse SQL VIEW Definitions and Extract Column Metadata

left to right direction

' ── Left-side actors (initiators) ──────────────────────────────────────────
actor "ANTLR Parser\nEngine" as ANTLREngine #D0E8FF
actor "MySqlAntlrDdlParser\n(Coordinator)" as DdlParser #D4EDDA

' ── Right-side actors (receivers / stores) ──────────────────────────────────
actor "DatabaseTables\n(Schema Registry)" as DbTables #FFE5B4
actor "DDL Event\nConsumer" as EventConsumer #F8D7DA

' ── System boundary ──────────────────────────────────────────────────────────
rectangle "MySQL / MariaDB View DDL Parser" {

    usecase "Parse CREATE VIEW" as UC1
    usecase "Parse ALTER VIEW"  as UC2
    usecase "Parse DROP VIEW"   as UC3

    usecase "Extract VIEW\nSelected Columns\n(ViewSelectedColumnsParserListener)" as UC4

    usecase "Skip View\nProcessing\n[skipViews = true]" as UC5

    usecase "Signal View\nLifecycle Event\n(Create / Alter / Drop)" as UC6

    usecase "Overwrite Table\nin Schema Registry" as UC8
}

' ── ANTLR Engine triggers DDL parse use-cases ────────────────────────────────
ANTLREngine --> UC1 : enterCreateView /\nexitCreateView
ANTLREngine --> UC2 : enterAlterView /\nexitAlterView
ANTLREngine --> UC3 : enterDropView

' ── Coordinator controls guard & signalling ──────────────────────────────────
DdlParser --> UC5 : skipViews flag
DdlParser --> UC6 : signalCreateView /\nsignalAlterView /\nsignalDropView

' ── Include: column extraction is embedded in CREATE / ALTER ─────────────────
UC1 ..> UC4 : <<include>>
UC2 ..> UC4 : <<include>>

' ── Include: schema is written after parsing ─────────────────────────────────
UC1 ..> UC8 : <<include>>
UC2 ..> UC8 : <<include>>

' ── Include: lifecycle event is always signalled ─────────────────────────────
UC1 ..> UC6 : <<include>>
UC2 ..> UC6 : <<include>>
UC3 ..> UC6 : <<include>>

' ── Extend: any DDL listener may be short-circuited ─────────────────────────
UC1 <.. UC5 : <<extend>>\n[skipViews=true]
UC2 <.. UC5 : <<extend>>\n[skipViews=true]
UC3 <.. UC5 : <<extend>>\n[skipViews=true]

' ── Schema registry interactions ─────────────────────────────────────────────
UC8  --> DbTables : overwriteTable /\nremoveTable
UC4  --> DbTables : forTable\n(alias lookup)
UC3  --> DbTables : removeTable\n(per fullId)

' ── Downstream event delivery ────────────────────────────────────────────────
UC6  --> EventConsumer : signalCreateView\nsignalAlterView\nsignalDropView

' ── Notes ────────────────────────────────────────────────────────────────────
note right of UC4
  Dynamically registered by
  Create/AlterViewParserListener.
  Resolves SELECT * / tbl.* / col AS alias.
  Removed after exitCreate/AlterView.
end note

note right of UC5
  DropViewParserListener skips signal
  when skipViews=true.
  Create/AlterView always signal.
end note

note bottom of UC2
  Throws ParsingException if
  target VIEW does not exist
  in DatabaseTables.
end note

@enduml
