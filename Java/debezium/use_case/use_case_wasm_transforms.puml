@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title WebAssembly (WASM) Transforms\n(Debezium CDC — Kafka Connect SMTs)

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────
actor "Developer" as dev
actor "Kafka Connect\nRuntime" as kcr
actor "WASM Module\n(.wasm file)" as wasm

' ── System Boundary ──────────────────────────────────────────────────────
rectangle "WASM Transforms System" {

    ' ── Configuration ────────────────────────────────────────────────────
    package "SMT Configuration" {
        usecase "Select WASM Engine Mode\n(wasm.chicory JIT or\nwasm.chicory-interpreter)" as UC_ENGINE
        usecase "Configure topic.expression\nwith file: URI (.wasm)" as UC_ROUTER_EXPR
        usecase "Configure condition\nwith file: URI (.wasm)" as UC_FILTER_EXPR
        usecase "Restrict Scope via\ntopic.regex Pattern" as UC_TOPIC_REGEX
        usecase "Set Null Handling Mode\n(keep / drop / evaluate)" as UC_NULL_CFG
    }

    ' ── Routing ──────────────────────────────────────────────────────────
    package "Content-Based Routing (ContentBasedRouter)" {
        usecase "Deploy WASM Module\nfor Topic Routing" as UC_DEPLOY_ROUTER
        usecase "Route Record to\nNew Kafka Topic" as UC_ROUTE
        usecase "Keep Original Topic\n(WASM returns null)" as UC_KEEP_TOPIC
    }

    ' ── Filtering ────────────────────────────────────────────────────────
    package "Record Filtering (Filter)" {
        usecase "Deploy WASM Module\nfor Record Filtering" as UC_DEPLOY_FILTER
        usecase "Pass Record Downstream\n(WASM returns true)" as UC_PASS
        usecase "Drop Record\n(WASM returns false)" as UC_DROP
    }

    ' ── WASM Execution & Host ABI ─────────────────────────────────────────
    package "WASM Execution & Host ABI (ChicoryEngine)" {
        usecase "Invoke process(rootObjPtr)\non WASM Module" as UC_PROCESS
        usecase "Access Record Fields\n(key, value, topic, headers)" as UC_ACCESS_FIELDS
        usecase "Navigate Nested Struct\nvia Dot-Path (get)" as UC_DOT_PATH
        usecase "Access Array Elements\n(getArrayElem / getArraySize)" as UC_ARRAY
        usecase "Introspect Schema Metadata\n(getSchemaName / getSchemaType)" as UC_SCHEMA_META
        usecase "Materialize Typed Value\n(getString, getBool, getInt*, etc.)" as UC_MATERIALIZE
    }

    ' ── Error & Validation ───────────────────────────────────────────────
    package "Validation & Error Handling" {
        usecase "Fail Fast on Unsupported\nWASM Engine Name" as UC_ERR_ENGINE
        usecase "Fail Fast on Malformed\n.wasm File URI" as UC_ERR_URI
        usecase "Fail Fast on Invalid\nWASM Return Type" as UC_ERR_RETURN
    }
}

' ── Actor → Use Case Relationships ───────────────────────────────────────

' Developer configures the SMTs
dev --> UC_ENGINE
dev --> UC_ROUTER_EXPR
dev --> UC_FILTER_EXPR
dev --> UC_TOPIC_REGEX
dev --> UC_NULL_CFG
dev --> UC_DEPLOY_ROUTER
dev --> UC_DEPLOY_FILTER

' Kafka Connect Runtime invokes the SMT pipeline
kcr --> UC_ROUTE
kcr --> UC_PASS
kcr --> UC_DROP
kcr --> UC_KEEP_TOPIC
kcr --> UC_PROCESS

' WASM Module participates in execution via Host ABI callbacks
wasm --> UC_ACCESS_FIELDS
wasm --> UC_DOT_PATH
wasm --> UC_ARRAY
wasm --> UC_SCHEMA_META
wasm --> UC_MATERIALIZE

' ── Include / Extend Relationships ───────────────────────────────────────

' Routing depends on configuration
UC_DEPLOY_ROUTER ..> UC_ENGINE       : <<include>>
UC_DEPLOY_ROUTER ..> UC_ROUTER_EXPR  : <<include>>

' Filtering depends on configuration
UC_DEPLOY_FILTER ..> UC_ENGINE       : <<include>>
UC_DEPLOY_FILTER ..> UC_FILTER_EXPR  : <<include>>

' Both transforms use topic regex scoping (extend — optional)
UC_ROUTE         ..> UC_TOPIC_REGEX  : <<extend>>
UC_PASS          ..> UC_TOPIC_REGEX  : <<extend>>

' Routing and Filtering invoke the WASM process function
UC_ROUTE         ..> UC_PROCESS      : <<include>>
UC_PASS          ..> UC_PROCESS      : <<include>>
UC_DROP          ..> UC_PROCESS      : <<include>>
UC_KEEP_TOPIC    ..> UC_PROCESS      : <<include>>

' WASM field access sub-operations
UC_ACCESS_FIELDS ..> UC_DOT_PATH     : <<include>>
UC_ACCESS_FIELDS ..> UC_MATERIALIZE  : <<include>>
UC_ACCESS_FIELDS ..> UC_ARRAY        : <<extend>>
UC_ACCESS_FIELDS ..> UC_SCHEMA_META  : <<extend>>

' Null handling extends routing and filtering
UC_ROUTE         ..> UC_NULL_CFG     : <<extend>>
UC_PASS          ..> UC_NULL_CFG     : <<extend>>

' Error cases extend configuration and execution
UC_DEPLOY_ROUTER ..> UC_ERR_URI      : <<extend>>
UC_DEPLOY_FILTER ..> UC_ERR_URI      : <<extend>>
UC_ENGINE        ..> UC_ERR_ENGINE   : <<extend>>
UC_PROCESS       ..> UC_ERR_RETURN   : <<extend>>

@enduml
