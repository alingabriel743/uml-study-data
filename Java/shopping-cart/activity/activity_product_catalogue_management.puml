@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Product Catalogue Management

|Admin|
start
:Select Product Catalogue Operation;

split
  -> [Add Product];
  |Admin|
  :Provide product name, type, info,\nprice, quantity, image;

  |ProductServiceImpl|
  if (prodId provided?) then (no)
    :Generate prodId\nvia IDUtil.generateId();
  else (yes)
  endif
  :Construct ProductBean\n(id, name, type, info,\nprice, quantity, image);

  |Database|
  :Open connection\nvia DBUtil.provideConnection();
  :INSERT INTO product VALUES\n(pid, pname, ptype, pinfo,\npprice, pquantity, image);
  if (Rows affected > 0?) then (yes)
    :status = "Product Added Successfully\nwith Product Id: {id}";
  else (no / SQLException)
    :status = "Product Updation Failed!"\nor "Error: {message}";
  endif
  :Close connection\nDBUtil.closeConnection();

  |ProductServiceImpl|
  :Return status to Admin;

split again
  -> [Remove Product];
  |Admin|
  :Provide prodId to remove;

  |ProductServiceImpl|
  |Database|
  :Open connection\nvia DBUtil.provideConnection();
  :DELETE FROM product\nWHERE pid = ?;
  if (Rows affected > 0?) then (yes)
    :status = "Product Removed Successfully!";
    :DELETE FROM usercart\nWHERE prodid = ?\n(cascade cart cleanup);
  else (no / SQLException)
    :status = "Product Removal Failed!"\nor "Error: {message}";
  endif
  :Close connection\nDBUtil.closeConnection();

  |ProductServiceImpl|
  :Return status to Admin;

split again
  -> [Update Product (with image)];
  |Admin|
  :Provide prevProduct &\nupdatedProduct (with new image);

  |ProductServiceImpl|
  if (prevProduct.prodId ==\nupdatedProduct.prodId?) then (no)
    :Return "Both Products are Different,\nUpdation Failed!";
    stop
  else (yes)
  endif

  |Database|
  :Open connection\nvia DBUtil.provideConnection();
  :UPDATE product SET pname, ptype, pinfo,\npprice, pquantity, image WHERE pid = ?;
  if (Rows affected > 0?) then (yes)
    :status = "Product Updated Successfully!";
  else (no)
    :status = "Product Updation Failed!";
  endif
  :Close connection\nDBUtil.closeConnection();

  |ProductServiceImpl|
  :Return status to Admin;

split again
  -> [Update Product (no image / restock check)];
  |Admin|
  :Provide prevProductId &\nupdatedProduct (no image);

  |ProductServiceImpl|
  if (prevProductId ==\nupdatedProduct.prodId?) then (no)
    :Return "Both Products are Different,\nUpdation Failed!";
    stop
  else (yes)
  endif
  :Fetch prevQuantity via\ngetProductQuantity(prevProductId);

  |Database|
  :Open connection\nvia DBUtil.provideConnection();
  :UPDATE product SET pname, ptype, pinfo,\npprice, pquantity WHERE pid = ?\n(image column unchanged);
  if (Rows affected > 0?) then (yes)
    |ProductServiceImpl|
    if (prevQuantity < updatedQuantity?\n(stock restocked)) then (yes)
      :Query DemandServiceImpl\n.haveDemanded(prodId)\n→ List<DemandBean>;
      if (Demand list not empty?) then (yes)
        repeat
          :Get user email &\nfirst name via\nUserServiceImpl.getFName();
          :Send restock email via\nMailMessage.productAvailableNow\n(email, fname, prodName, prodId);
          :Remove demand record via\nDemandServiceImpl.removeProduct\n(userName, prodId);
        repeat while (More demand records?)
        :Append "And Mail Send\nto customers..." to status;
      else (no)
        :status = "Product Updated Successfully!";
      endif
    else (no restock)
      :status = "Product Updated Successfully!";
    endif
  else (no)
    :status = "Product Not available\nin the store!";
  endif

  |Database|
  :Close connection\nDBUtil.closeConnection();

  |ProductServiceImpl|
  :Return status to Admin;

split again
  -> [Update Product Price];
  |Admin|
  :Provide prodId & updatedPrice;

  |Database|
  :Open connection\nvia DBUtil.provideConnection();
  :UPDATE product SET pprice = ?\nWHERE pid = ?;
  if (Rows affected > 0?) then (yes)
    :status = "Price Updated Successfully!";
  else (no / SQLException)
    :status = "Price Updation Failed!"\nor "Error: {message}";
  endif
  :Close connection\nDBUtil.closeConnection();

  |ProductServiceImpl|
  :Return status to Admin;

split again
  -> [Search Products];
  |Admin|
  :Provide search keyword;

  |ProductServiceImpl|
  :Wrap term: '%' + search + '%';

  |Database|
  :Open connection\nvia DBUtil.provideConnection();
  :SELECT * FROM product\nWHERE lower(ptype) LIKE ?\nOR lower(pname) LIKE ?\nOR lower(pinfo) LIKE ?;
  if (Rows found?) then (yes)
    repeat
      :Construct ProductBean\n(id, name, type, info,\nprice, quantity, imageStream);
      :Add to products list;
    repeat while (More rows in ResultSet?)
  else (no / SQLException)
    :Return empty list\n(log stack trace);
  endif
  :Close connection\nDBUtil.closeConnection();

  |ProductServiceImpl|
  :Return List<ProductBean> to Admin;

split again
  -> [Get Product Details];
  |Admin|
  :Provide prodId;

  |Database|
  :Open connection\nvia DBUtil.provideConnection();
  :SELECT * FROM product\nWHERE pid = ?;
  if (Row found (rs.next())?) then (yes)
    :Construct ProductBean\n(id, name, type, info,\nprice, quantity, imageStream);
  else (no / SQLException)
    :Return null\n(log stack trace);
  endif
  :Close connection\nDBUtil.closeConnection();

  |ProductServiceImpl|
  :Return ProductBean or null;

split again
  -> [Get Product Image];
  |Admin|
  :Provide prodId;

  |Database|
  :Open connection\nvia DBUtil.provideConnection();
  :SELECT image FROM product\nWHERE pid = ?;
  if (Row found (rs.next())?) then (yes)
    :image = rs.getBytes("image");
  else (no)
    :Return null;
  endif
  :Close connection\nDBUtil.closeConnection();

  |ProductServiceImpl|
  :Return byte[] image or null;

end split

|Admin|
:Receive operation result;
stop

@enduml
