@startuml activity_product_demand_tracking

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Product Demand Tracking

|Customer|
start

fork
  |Customer|
  :Submit demand for\nunavailable product\n(userId, prodId, demandQty);

  |DemandServiceImpl|
  :addProduct(userId, prodId, demandQty);
  :DBUtil.provideConnection();

  |Database|
  :SELECT * FROM user_demand\nWHERE username=? AND prodid=?;

  |DemandServiceImpl|
  if (Demand record\nalready exists?) then (yes)
    :Set flag = true\n(duplicate — skip insert);
  else (no)
    |Database|
    :INSERT INTO user_demand\nVALUES(userId, prodId, demandQty);

    |DemandServiceImpl|
    if (Insert successful?\n(rows affected > 0)) then (yes)
      :Set flag = true;
    else (no)
      :Set flag = false;
    endif
  endif

  |DemandServiceImpl|
  :DBUtil.closeConnection\n(con, ps, ps2, rs);
  :Return flag\n(true = success);

fork again
  |Customer|
  :Submit demand via\nDemandBean object;

  |DemandServiceImpl|
  :addProduct(DemandBean userDemandBean);
  note right
    Convenience overload —
    extracts userName, prodId,
    demandQty from DemandBean
  end note
  :Delegate to\naddProduct(userName, prodId, demandQty);
  :Return delegated result;

fork again
  |Customer|
  :Request to remove\ndemand record\n(userId, prodId);

  |DemandServiceImpl|
  :removeProduct(userId, prodId);
  :DBUtil.provideConnection();

  |Database|
  :SELECT * FROM user_demand\nWHERE username=? AND prodid=?;

  |DemandServiceImpl|
  if (Demand record\nexists?) then (yes)
    |Database|
    :DELETE FROM user_demand\nWHERE username=? AND prodid=?;

    |DemandServiceImpl|
    if (Delete successful?\n(rows affected > 0)) then (yes)
      :Set flag = true;
    else (no)
      :Set flag = false;
    endif
  else (no)
    :Record not found —\nSet flag = true\n(idempotent removal);
  endif

  |DemandServiceImpl|
  :DBUtil.closeConnection\n(con, ps, ps2, rs);
  :Return flag;

fork again
  |Customer|
  :Request demand list\nfor a product (prodId);

  |DemandServiceImpl|
  :haveDemanded(prodId);
  :Initialize empty\nList<DemandBean>;
  :DBUtil.provideConnection();

  |Database|
  :SELECT * FROM user_demand\nWHERE prodid=?;

  |DemandServiceImpl|
  while (ResultSet has\nnext row?) is (yes)
    :Create DemandBean\n(username, prodId, quantity);
    :Add DemandBean\nto demandList;
  endwhile (no more rows)

  :DBUtil.closeConnection\n(con, ps, rs);
  :Return demandList\n(may be empty);

end fork

|DemandServiceImpl|
note right
  **Error Handling (all flows)**
  SQLException caught:
  - addProduct / removeProduct → flag = false
  - haveDemanded → print stack trace,
    return empty list
end note

stop

@enduml
