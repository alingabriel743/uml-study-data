@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
skinparam activityBackgroundColor #F8F9FA
skinparam activityBorderColor #495057
skinparam activityArrowColor #495057
skinparam activityFontColor #212529
skinparam swimlaneBackgroundColor #E9ECEF
skinparam swimlaneBorderColor #6C757D
skinparam noteBorderColor #ADB5BD
skinparam noteBackgroundColor #FFF9C4

title Shopping Cart Flow

|#EBF5FB|Customer|
|#D6EAF8|CartServiceImpl|
|#D5F5E3|ExternalServices|
|#FEF9E7|Database|

|Customer|
start
note right
  Customer selects one of the
  available cart operations
end note

split

  ' ============================================================
  ' OPERATION 1: Add Product to Cart
  ' ============================================================
  :Add Product to Cart\n(userId, prodId, prodQty);

  |CartServiceImpl|
  :addProductToCart\n(userId, prodId, prodQty);

  |Database|
  :Open DB Connection;
  :SELECT * FROM usercart\nWHERE username=? AND prodid=?;

  |CartServiceImpl|
  if (Product already in cart?) then (yes)
    :Read existing cartQuantity;

    |ExternalServices|
    :ProductServiceImpl\n.getProductDetails(prodId);
    :Return ProductBean\nwith availableQty;

    |CartServiceImpl|
    :newTotal = prodQty + cartQuantity;

    if (availableQty < newTotal?) then (yes — stock shortage)
      :updateProductToCart\n(userId, prodId, availableQty);

      |ExternalServices|
      :Create DemandBean\n(userId, prodId, deficit);
      :DemandServiceImpl\n.addProduct(demandBean);

      |CartServiceImpl|
      if (Demand registered?) then (yes)
        :Append email-notification\nto status message;
      else (no)
        :Set partial-add\nstatus only;
      endif
    else (no — full quantity available)
      :updateProductToCart\n(userId, prodId, newTotal);
    endif
  else (no — product not yet in cart)
    #FFCCCC:Return "Failed to Add into Cart"\n(use updateProductToCart to insert new rows);
  endif

  |Database|
  :Close DB Connection;

  |Customer|
  :Receive add confirmation;

split again

  ' ============================================================
  ' OPERATION 2: Update Quantity / Insert or Delete Row
  ' ============================================================
  :Update Cart Quantity\n(userId, prodId, newQty);

  |CartServiceImpl|
  :updateProductToCart\n(userId, prodId, prodQty);

  |Database|
  :Open DB Connection;
  :SELECT * FROM usercart\nWHERE username=? AND prodid=?;

  |CartServiceImpl|
  if (Row exists in cart?) then (yes)
    if (prodQty > 0?) then (yes — set new quantity)
      |Database|
      :UPDATE usercart\nSET quantity = prodQty\nWHERE username=? AND prodid=?;
      |CartServiceImpl|
      :Return "Product Successfully\nUpdated to Cart!";
    else (no — qty = 0, remove row)
      |Database|
      :DELETE FROM usercart\nWHERE username=? AND prodid=?;
      |CartServiceImpl|
      :Return "Product Successfully\nUpdated in Cart!";
    endif
  else (no — new product, insert row)
    |Database|
    :INSERT INTO usercart\nVALUES (userId, prodId, prodQty);
    |CartServiceImpl|
    :Return "Product Successfully\nUpdated to Cart!";
  endif

  |Database|
  :Close DB Connection;

  |Customer|
  :Receive quantity update confirmation;

split again

  ' ============================================================
  ' OPERATION 3: Remove Product from Cart (decrement by 1)
  ' ============================================================
  :Remove Product from Cart\n(userId, prodId);

  |CartServiceImpl|
  :removeProductFromCart\n(userId, prodId);

  |Database|
  :Open DB Connection;
  :SELECT * FROM usercart\nWHERE username=? AND prodid=?;

  |CartServiceImpl|
  if (Product found in cart?) then (yes)
    :Read current prodQuantity;
    :prodQuantity -= 1;
    if (prodQuantity > 0?) then (yes — units still remain)
      |Database|
      :UPDATE usercart\nSET quantity = prodQuantity\nWHERE username=? AND prodid=?;
    else (no — last unit removed)
      |Database|
      :DELETE FROM usercart\nWHERE username=? AND prodid=?;
    endif
    |CartServiceImpl|
    :Return "Product Successfully\nremoved from the Cart!";
  else (no)
    #FFCCCC:Return "Product Not\nAvailable in the cart!";
  endif

  |Database|
  :Close DB Connection;

  |Customer|
  :Receive removal confirmation;

split again

  ' ============================================================
  ' OPERATION 4: View Cart Contents & Count
  ' ============================================================
  :View Cart Contents\n(userId);

  |CartServiceImpl|
  :getAllCartItems(userId);

  |Database|
  :Open DB Connection;
  :SELECT * FROM usercart\nWHERE username=?;
  :Return full ResultSet;

  |CartServiceImpl|
  repeat
    :Create CartBean\n(userId, prodId, quantity);
    :Add CartBean to items list;
  repeat while (More rows in ResultSet?) is (yes)
  ->no;

  :getCartCount(userId);

  |Database|
  :Open DB Connection;
  :SELECT SUM(quantity)\nFROM usercart WHERE username=?;

  |CartServiceImpl|
  if (Sum result present and not null?) then (yes)
    :count = SUM(quantity);
  else (no — empty cart)
    :count = 0;
  endif

  |Database|
  :Close DB Connection;

  |CartServiceImpl|
  :Return List<CartBean>\nand total item count;

  |Customer|
  :Display cart items\nand total quantities;

end split

|Customer|
stop

@enduml
