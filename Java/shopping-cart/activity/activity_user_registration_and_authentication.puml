@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title User Registration & Authentication

|User/Browser|
start

fork
  ' ====================== REGISTRATION FLOW ======================
  :Submit Registration Form\n(username, mobileNo, email,\naddress, pinCode, password,\nconfirmPassword);

  |RegisterSrv|
  :doGet() receives HTTP request;

  if (password == confirmPassword?) then (yes)
    :Create UserBean\n(userName, mobileNo, emailId,\naddress, pinCode, password);

    |UserServiceImpl|
    :registerUser(UserBean) called;
    :isRegistered(email) check;

    |DBUtil / Database|
    :provideConnection();
    :SELECT * FROM user\nWHERE email = ?;

    |UserServiceImpl|
    if (Email already in DB?) then (yes)
      :status = "Email Id\nAlready Registered!";
    else (no)
      |DBUtil / Database|
      :provideConnection();
      :INSERT INTO user VALUES\n(email, name, mobile,\naddress, pincode, password);

      |UserServiceImpl|
      if (rows affected > 0?) then (yes)
        :status = "User Registered\nSuccessfully!";

        |MailMessage|
        :registrationSuccess\n(email, firstName);

        |UserServiceImpl|
      else (no)
        :status = "User Registration\nFailed!";
      endif
    endif

    |DBUtil / Database|
    :closeConnection(ps);

    |RegisterSrv|
    :Forward to\nregister.jsp?message=status;

    |User/Browser|
    :View registration result;

  else (no)
    |RegisterSrv|
    :status = "Password\nnot matching!";
    :Forward to\nregister.jsp?message=status;

    |User/Browser|
    :View error message;
  endif

fork again
  ' ====================== LOGIN FLOW ======================
  :Submit Login Form\n(username, password, usertype);

  |LoginSrv|
  :doGet() receives HTTP request;

  if (userType == "admin"?) then (yes)
    if (username == "admin@gmail.com"\nAND password == "admin"?) then (yes)
      :Create HttpSession;
      :setAttribute\n(username, password,\nusertype = "admin");
      :Forward to\nadminViewProduct.jsp;

      |User/Browser|
      :Access Admin Dashboard;

    else (no)
      :Forward to\nlogin.jsp?message=\n"Login Denied!";

      |User/Browser|
      :View login error;
    endif

  else (no — customer)
    |UserServiceImpl|
    :isValidCredential\n(username, password);

    |DBUtil / Database|
    :provideConnection();
    :SELECT * FROM user\nWHERE email = ?\nAND password = ?;

    |UserServiceImpl|
    if (ResultSet has row?) then (yes)
      :return "valid";
    else (no)
      :return "Login Denied!\nIncorrect Username\nor Password";
    endif

    |DBUtil / Database|
    :closeConnection(con, ps, rs);

    |LoginSrv|
    if (status == "valid"?) then (yes)
      |UserServiceImpl|
      :getUserDetails\n(username, password);

      |DBUtil / Database|
      :provideConnection();
      :SELECT * FROM user\nWHERE email = ?\nAND password = ?;
      :Build UserBean from ResultSet\n(name, mobile, email,\naddress, pinCode, password);
      :return UserBean;

      |LoginSrv|
      :HttpSession.setAttribute\n("userdata", userBean);
      :HttpSession.setAttribute\n(username, password,\nusertype = "customer");
      :Forward to\nuserHome.jsp;

      |User/Browser|
      :Access Customer Home;

    else (no)
      |LoginSrv|
      :Forward to\nlogin.jsp?message=status;

      |User/Browser|
      :View login error;
    endif
  endif

end fork

stop

@enduml
