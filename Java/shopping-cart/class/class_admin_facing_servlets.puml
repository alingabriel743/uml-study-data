@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Admin-Facing Servlet Layer

' ─── External / Framework ───────────────────────────────────────────
package "javax.servlet.http" {
    class HttpServlet <<framework>> {
    }
}

package "java.io" {
    interface Serializable <<interface>> {
    }
}

' ─── Service Interfaces ──────────────────────────────────────────────
package "com.shashi.service" {
    interface ProductService <<interface>> {
        +addProduct(name: String, type: String, info: String, price: double, qty: int, image: InputStream): String
        +removeProduct(prodId: String): String
        +updateProductWithoutImage(prevProductId: String, updated: ProductBean): String
        +getProductDetails(prodId: String): ProductBean
    }

    interface OrderService <<interface>> {
        +shipNow(orderId: String, prodId: String): String
    }

    interface UserService <<interface>> {
        +getFName(emailId: String): String
    }
}

' ─── Service Implementations ─────────────────────────────────────────
package "com.shashi.service.impl" {
    class ProductServiceImpl {
        +addProduct(name: String, type: String, info: String, price: double, qty: int, image: InputStream): String
        +addProduct(product: ProductBean): String
        +removeProduct(prodId: String): String
        +updateProduct(prev: ProductBean, updated: ProductBean): String
        +updateProductWithoutImage(prevProductId: String, updated: ProductBean): String
        +updateProductPrice(prodId: String, price: double): String
        +getProductDetails(prodId: String): ProductBean
        +getProductPrice(prodId: String): double
        +sellNProduct(prodId: String, n: int): boolean
        +getProductQuantity(prodId: String): int
    }

    class OrderServiceImpl {
        +shipNow(orderId: String, prodId: String): String
    }

    class UserServiceImpl {
        +getFName(emailId: String): String
        +getUserDetails(emailId: String, password: String): UserBean
    }
}

' ─── Beans ───────────────────────────────────────────────────────────
package "com.shashi.beans" {
    class ProductBean {
        -prodId: String
        -prodName: String
        -prodType: String
        -prodInfo: String
        -prodPrice: double
        -prodQuantity: int
        -prodImage: InputStream
        +getProdId(): String
        +setProdId(prodId: String): void
        +getProdName(): String
        +setProdName(prodName: String): void
        +getProdType(): String
        +setProdType(prodType: String): void
        +getProdPrice(): double
        +setProdPrice(prodPrice: double): void
        +getProdQuantity(): int
        +setProdQuantity(prodQuantity: int): void
        +getProdImage(): InputStream
        +setProdImage(prodImage: InputStream): void
    }
}

' ─── Utility ─────────────────────────────────────────────────────────
package "com.shashi.utility" {
    class MailMessage <<utility>> {
        +{static} registrationSuccess(emailId: String, name: String): void
        +{static} transactionSuccess(recipientEmail: String, name: String, transId: String, amount: double): void
        +{static} orderShipped(recipientEmail: String, name: String, transId: String, amount: double): void
        +{static} productAvailableNow(recipientEmail: String, name: String, prodName: String, prodId: String): void
        +{static} sendMessage(toEmailId: String, subject: String, htmlText: String): String
    }
}

' ─── Admin-Facing Servlets ───────────────────────────────────────────
package "com.shashi.srv" {

    class AddProductSrv <<servlet>> {
        ' @WebServlet("/AddProductSrv")
        ' @MultipartConfig(maxFileSize=16177215)
        -{static} final serialVersionUID: long
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of AddProductSrv
      Auth: usertype == 'admin'
      Reads: name, type, info, price,
             quantity, image (Part)
      Delegates → ProductServiceImpl.addProduct()
      Forwards → addProduct.jsp
    end note

    class RemoveProductSrv <<servlet>> {
        ' @WebServlet("/RemoveProductSrv")
        -{static} final serialVersionUID: long
        +RemoveProductSrv()
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of RemoveProductSrv
      Auth: usertype == 'admin'
      Reads: prodid
      Delegates → ProductServiceImpl.removeProduct()
      Forwards → removeProduct.jsp
    end note

    class UpdateProductSrv <<servlet>> {
        ' @WebServlet("/UpdateProductSrv")
        -{static} final serialVersionUID: long
        +UpdateProductSrv()
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of UpdateProductSrv
      Auth: usertype == 'admin'
      Reads: pid, name, type, info, price, qty
      Constructs ProductBean
      Delegates → ProductServiceImpl.updateProductWithoutImage()
      Forwards → updateProduct.jsp
    end note

    class ShipmentServlet <<servlet>> {
        ' @WebServlet("/ShipmentServlet")
        -{static} final serialVersionUID: long
        +ShipmentServlet()
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of ShipmentServlet
      Auth: usertype != null (any role)
      Reads: orderid, prodid, userid, amount
      Delegates → OrderServiceImpl.shipNow()
      On SUCCESS → MailMessage.orderShipped()
      Includes shippedItems.jsp / unshippedItems.jsp
    end note

    class FansMessage <<servlet>> {
        ' @WebServlet("/fansMessage")
        -{static} final serialVersionUID: long
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of FansMessage
      No auth guard
      Reads: name, email, comments
      Delegates → MailMessage.sendMessage()
      Includes index.jsp with JS alert
    end note
}

' ─── Inheritance ─────────────────────────────────────────────────────
AddProductSrv    --|> HttpServlet
RemoveProductSrv --|> HttpServlet
UpdateProductSrv --|> HttpServlet
ShipmentServlet  --|> HttpServlet
FansMessage      --|> HttpServlet

ProductBean      ..|> Serializable

ProductServiceImpl ..|> ProductService
OrderServiceImpl   ..|> OrderService
UserServiceImpl    ..|> UserService

' ─── Dependencies (servlet → service / utility) ──────────────────────
AddProductSrv    ..> ProductServiceImpl : <<instantiates>>\naddProduct()
RemoveProductSrv ..> ProductServiceImpl : <<instantiates>>\nremoveProduct()
UpdateProductSrv ..> ProductServiceImpl : <<instantiates>>\nupdateProductWithoutImage()
UpdateProductSrv ..> ProductBean        : <<creates>>

ShipmentServlet  ..> OrderServiceImpl   : <<instantiates>>\nshipNow()
ShipmentServlet  ..> UserServiceImpl    : <<instantiates>>\ngetFName()
ShipmentServlet  ..> MailMessage        : <<static call>>\norderShipped()

FansMessage      ..> MailMessage        : <<static call>>\nsendMessage()

@enduml
