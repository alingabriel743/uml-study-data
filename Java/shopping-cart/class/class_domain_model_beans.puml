@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
}

title Domain Model — Data Beans\n<size:11><i>com.shashi.beans — Plain Java Beans (manual JDBC, no ORM)</i></size>

interface Serializable <<java.io.Serializable>> {
}

package "com.shashi.beans" {

    class UserBean {
        - name: String
        - mobile: Long
        - email: String
        - address: String
        - pinCode: int
        - password: String
        ..
        + getName(): String
        + setName(String): void
        + getMobile(): Long
        + setMobile(Long): void
        + getEmail(): String
        + setEmail(String): void
        + getAddress(): String
        + setAddress(String): void
        + getPinCode(): int
        + setPinCode(int): void
        + getPassword(): String
        + setPassword(String): void
    }

    class ProductBean {
        - prodId: String
        - prodName: String
        - prodType: String
        - prodInfo: String
        - prodPrice: double
        - prodQuantity: int
        - prodImage: InputStream
        ..
        + getProdId(): String
        + setProdId(String): void
        + getProdName(): String
        + setProdName(String): void
        + getProdType(): String
        + setProdType(String): void
        + getProdInfo(): String
        + setProdInfo(String): void
        + getProdPrice(): double
        + setProdPrice(double): void
        + getProdQuantity(): int
        + setProdQuantity(int): void
        + getProdImage(): InputStream
        + setProdImage(InputStream): void
    }

    class CartBean {
        + userId: String
        + prodId: String
        + quantity: int
        ..
        + getUserId(): String
        + setUserId(String): void
        + getProdId(): String
        + setProdId(String): void
        + getQuantity(): int
        + setQuantity(int): void
    }

    class OrderBean {
        - transactionId: String
        - productId: String
        - quantity: int
        - amount: Double
        - shipped: int
        ..
        + getTransactionId(): String
        + setTransactionId(String): void
        + getProductId(): String
        + setProductId(String): void
        + getQuantity(): int
        + setQuantity(int): void
        + getAmount(): Double
        + setAmount(Double): void
        + getShipped(): int
        + setShipped(int): void
    }

    class OrderDetails <<DTO>> {
        - orderId: String
        - productId: String
        - prodName: String
        - qty: String
        - amount: String
        - shipped: int
        - time: Timestamp
        - prodImage: InputStream
        ..
        + getOrderId(): String
        + setOrderId(String): void
        + getProductId(): String
        + setProductId(String): void
        + getProdName(): String
        + setProdName(String): void
        + getQty(): String
        + setQty(String): void
        + getAmount(): String
        + setAmount(String): void
        + getShipped(): int
        + setShipped(int): void
        + getTime(): Timestamp
        + setTime(Timestamp): void
        + getProdImage(): InputStream
        + setProdImage(InputStream): void
    }

    class TransactionBean {
        - transactionId: String
        - userName: String
        - transDateTime: Timestamp
        - transAmount: double
        ..
        + getTransactionId(): String
        + setTransactionId(String): void
        + getUserName(): String
        + setUserName(String): void
        + getTransDateTime(): Timestamp
        + setTransDateTime(Timestamp): void
        + getTransAmount(): double
        + setTransAmount(double): void
    }

    class DemandBean {
        - userName: String
        - prodId: String
        - demandQty: int
        ..
        + getUserName(): String
        + setUserName(String): void
        + getProdId(): String
        + setProdId(String): void
        + getDemandQty(): int
        + setDemandQty(int): void
    }

}

package "com.shashi.utility" {
    class IDUtil {
        + {static} generateId(): String
        + {static} generateTransId(): String
    }
}

' ── Serializable implementations ──────────────────────────────
UserBean        ..|> Serializable
ProductBean     ..|> Serializable
CartBean        ..|> Serializable
OrderBean       ..|> Serializable
OrderDetails    ..|> Serializable
TransactionBean ..|> Serializable
DemandBean      ..|> Serializable

' ── Logical FK references (by String key, no ORM) ─────────────
CartBean        ..>  UserBean        : userId → email
CartBean        ..>  ProductBean     : prodId → prodId
OrderBean       ..>  TransactionBean : transactionId → transactionId
OrderBean       ..>  ProductBean     : productId → prodId
TransactionBean ..>  UserBean        : userName → email
DemandBean      ..>  UserBean        : userName → email
DemandBean      ..>  ProductBean     : prodId → prodId

' ── OrderDetails: read-model DTO aggregating multiple beans ────
OrderDetails    ..>  OrderBean       : aggregates data from
OrderDetails    ..>  TransactionBean : aggregates data from
OrderDetails    ..>  ProductBean     : aggregates data from

' ── TransactionBean uses IDUtil for auto ID generation ─────────
TransactionBean ..>  IDUtil          : generateTransId()

' ── Notes ──────────────────────────────────────────────────────
note right of CartBean
  <b>Encapsulation gap:</b> fields are
  declared <b>public</b> (not private).
  userId references UserBean.email.
end note

note right of OrderDetails
  <b>Read-model DTO</b> — not persisted as-is.
  Flattens OrderBean + TransactionBean
  + ProductBean data for display.
  qty and amount stored as String.
end note

note right of TransactionBean
  Auto-generates transactionId via IDUtil
  and records current Timestamp in most
  constructors when not explicitly provided.
  shipped flag: 0 = pending, 1 = shipped
  (also applies to OrderBean.shipped)
end note

@enduml
