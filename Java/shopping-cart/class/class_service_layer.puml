@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D0E8FF
    BorderColor #2C7DBE
    FontColor #1A3A5C
}
skinparam note {
    BackgroundColor #FFFBCC
    BorderColor #C8B400
}

title Service Layer — Business Logic Implementations

' ─────────────────────────────────────────
'  SERVICE INTERFACES
' ─────────────────────────────────────────
package "com.shashi.service" {

    interface UserService {
        +registerUser(userName: String, mobileNo: Long, emailId: String,\n  address: String, pinCode: int, password: String): String
        +registerUser(user: UserBean): String
        +isRegistered(emailId: String): boolean
        +isValidCredential(emailId: String, password: String): String
        +getUserDetails(emailId: String, password: String): UserBean
        +getFName(emailId: String): String
        +getUserAddr(userId: String): String
    }

    interface ProductService {
        +addProduct(prodName: String, prodType: String, prodInfo: String,\n  prodPrice: double, prodQuantity: int, prodImage: InputStream): String
        +addProduct(product: ProductBean): String
        +removeProduct(prodId: String): String
        +updateProduct(prevProduct: ProductBean, updatedProduct: ProductBean): String
        +updateProductPrice(prodId: String, updatedPrice: double): String
        +getAllProducts(): List<ProductBean>
        +getAllProductsByType(type: String): List<ProductBean>
        +searchAllProducts(search: String): List<ProductBean>
        +getImage(prodId: String): byte[]
        +getProductDetails(prodId: String): ProductBean
        +updateProductWithoutImage(prevProductId: String, updatedProduct: ProductBean): String
        +getProductPrice(prodId: String): double
        +sellNProduct(prodId: String, n: int): boolean
        +getProductQuantity(prodId: String): int
    }

    interface CartService {
        +addProductToCart(userId: String, prodId: String, prodQty: int): String
        +updateProductToCart(userId: String, prodId: String, prodQty: int): String
        +getAllCartItems(userId: String): List<CartBean>
        +getCartCount(userId: String): int
        +getCartItemCount(userId: String, itemId: String): int
        +removeProductFromCart(userId: String, prodId: String): String
        +removeAProduct(userId: String, prodId: String): boolean
    }

    interface OrderService {
        +paymentSuccess(userName: String, paidAmount: double): String
        +addOrder(order: OrderBean): boolean
        +addTransaction(transaction: TransactionBean): boolean
        +countSoldItem(prodId: String): int
        +getAllOrders(): List<OrderBean>
        +getOrdersByUserId(emailId: String): List<OrderBean>
        +getAllOrderDetails(userEmailId: String): List<OrderDetails>
        +shipNow(orderId: String, prodId: String): String
    }

    interface DemandService {
        +addProduct(userId: String, prodId: String, demandQty: int): boolean
        +addProduct(userDemandBean: DemandBean): boolean
        +removeProduct(userId: String, prodId: String): boolean
        +haveDemanded(prodId: String): List<DemandBean>
    }

    interface TransService {
        +getUserId(transId: String): String
    }
}

' ─────────────────────────────────────────
'  SERVICE IMPLEMENTATIONS
' ─────────────────────────────────────────
package "com.shashi.service.impl" {

    class UserServiceImpl {
        +registerUser(userName: String, mobileNo: Long, emailId: String,\n  address: String, pinCode: int, password: String): String
        +registerUser(user: UserBean): String
        +isRegistered(emailId: String): boolean
        +isValidCredential(emailId: String, password: String): String
        +getUserDetails(emailId: String, password: String): UserBean
        +getFName(emailId: String): String
        +getUserAddr(userId: String): String
    }

    class ProductServiceImpl {
        +addProduct(prodName: String, prodType: String, prodInfo: String,\n  prodPrice: double, prodQuantity: int, prodImage: InputStream): String
        +addProduct(product: ProductBean): String
        +removeProduct(prodId: String): String
        +updateProduct(prevProduct: ProductBean, updatedProduct: ProductBean): String
        +updateProductPrice(prodId: String, updatedPrice: double): String
        +getAllProducts(): List<ProductBean>
        +getAllProductsByType(type: String): List<ProductBean>
        +searchAllProducts(search: String): List<ProductBean>
        +getImage(prodId: String): byte[]
        +getProductDetails(prodId: String): ProductBean
        +updateProductWithoutImage(prevProductId: String, updatedProduct: ProductBean): String
        +getProductPrice(prodId: String): double
        +sellNProduct(prodId: String, n: int): boolean
        +getProductQuantity(prodId: String): int
    }

    class CartServiceImpl {
        +addProductToCart(userId: String, prodId: String, prodQty: int): String
        +updateProductToCart(userId: String, prodId: String, prodQty: int): String
        +getAllCartItems(userId: String): List<CartBean>
        +getCartCount(userId: String): int
        +getCartItemCount(userId: String, itemId: String): int
        +removeProductFromCart(userId: String, prodId: String): String
        +removeAProduct(userId: String, prodId: String): boolean
        +getProductCount(userId: String, prodId: String): int
    }

    class OrderServiceImpl {
        +paymentSuccess(userName: String, paidAmount: double): String
        +addOrder(order: OrderBean): boolean
        +addTransaction(transaction: TransactionBean): boolean
        +countSoldItem(prodId: String): int
        +getAllOrders(): List<OrderBean>
        +getOrdersByUserId(emailId: String): List<OrderBean>
        +getAllOrderDetails(userEmailId: String): List<OrderDetails>
        +shipNow(orderId: String, prodId: String): String
    }

    class DemandServiceImpl {
        +addProduct(userId: String, prodId: String, demandQty: int): boolean
        +addProduct(userDemandBean: DemandBean): boolean
        +removeProduct(userId: String, prodId: String): boolean
        +haveDemanded(prodId: String): List<DemandBean>
    }

    class TransServiceImpl {
        +getUserId(transId: String): String
    }
}

' ─────────────────────────────────────────
'  BEAN / DATA CLASSES
' ─────────────────────────────────────────
package "com.shashi.beans" {

    class UserBean {
        -name: String
        -mobile: Long
        -email: String
        -address: String
        -pinCode: int
        -password: String
    }

    class ProductBean {
        -prodId: String
        -prodName: String
        -prodType: String
        -prodInfo: String
        -prodPrice: double
        -prodQuantity: int
        -prodImage: InputStream
    }

    class CartBean {
        +userId: String
        +prodId: String
        +quantity: int
    }

    class OrderBean {
        -transactionId: String
        -productId: String
        -quantity: int
        -amount: Double
        -shipped: int
    }

    class OrderDetails {
        -orderId: String
        -productId: String
        -prodName: String
        -qty: String
        -amount: String
        -shipped: int
        -time: Timestamp
        -prodImage: InputStream
    }

    class TransactionBean {
        -transactionId: String
        -userName: String
        -transDateTime: Timestamp
        -transAmount: double
    }

    class DemandBean {
        -userName: String
        -prodId: String
        -demandQty: int
    }
}

' ─────────────────────────────────────────
'  UTILITY CLASSES
' ─────────────────────────────────────────
package "com.shashi.utility" {

    class DBUtil {
        -{static} conn: Connection
        +{static} provideConnection(): Connection
        +{static} closeConnection(con: Connection): void
        +{static} closeConnection(rs: ResultSet): void
        +{static} closeConnection(ps: PreparedStatement): void
    }

    class IDUtil {
        +{static} generateId(): String
        +{static} generateTransId(): String
    }

    class MailMessage {
        +{static} registrationSuccess(emailId: String, name: String): void
        +{static} transactionSuccess(recipientEmail: String, name: String,\n  transId: String, transAmount: double): void
        +{static} productAvailableNow(recipientEmail: String, name: String,\n  prodName: String, prodId: String): void
        +{static} orderShipped(recipientEmail: String, name: String,\n  transId: String, transAmount: double): void
    }
}

' ─────────────────────────────────────────
'  INTERFACE IMPLEMENTATIONS
' ─────────────────────────────────────────
UserServiceImpl    ..|> UserService
ProductServiceImpl ..|> ProductService
CartServiceImpl    ..|> CartService
OrderServiceImpl   ..|> OrderService
DemandServiceImpl  ..|> DemandService
TransServiceImpl   ..|> TransService

' ─────────────────────────────────────────
'  CROSS-SERVICE DEPENDENCIES (direct instantiation)
' ─────────────────────────────────────────
OrderServiceImpl   ..> CartServiceImpl    : <<uses>>\npaymentSuccess()
OrderServiceImpl   ..> ProductServiceImpl : <<uses>>\npaymentSuccess()
OrderServiceImpl   ..> UserServiceImpl    : <<uses>>\npaymentSuccess()

ProductServiceImpl ..> DemandServiceImpl  : <<uses>>\nupdateProductWithoutImage()
ProductServiceImpl ..> UserServiceImpl    : <<uses>>\nupdateProductWithoutImage()

CartServiceImpl    ..> ProductServiceImpl : <<uses>>\naddProductToCart()
CartServiceImpl    ..> DemandServiceImpl  : <<uses>>\naddProductToCart()

' ─────────────────────────────────────────
'  UTILITY DEPENDENCIES
' ─────────────────────────────────────────
UserServiceImpl    ..> DBUtil      : <<uses>>
ProductServiceImpl ..> DBUtil      : <<uses>>
CartServiceImpl    ..> DBUtil      : <<uses>>
OrderServiceImpl   ..> DBUtil      : <<uses>>
DemandServiceImpl  ..> DBUtil      : <<uses>>
TransServiceImpl   ..> DBUtil      : <<uses>>

ProductServiceImpl ..> IDUtil      : <<uses>>
OrderServiceImpl   ..> IDUtil      : <<uses>>

UserServiceImpl    ..> MailMessage : <<notifies>>
ProductServiceImpl ..> MailMessage : <<notifies>>
OrderServiceImpl   ..> MailMessage : <<notifies>>

' ─────────────────────────────────────────
'  NOTES
' ─────────────────────────────────────────
note bottom of OrderServiceImpl
  <b>paymentSuccess()</b> is the checkout orchestrator:
  fetch cart → create TransactionBean → per item:
  addOrder + removeFromCart + sellNProduct
  → addTransaction → send mail
  (no rollback on partial failure)
end note

note bottom of ProductServiceImpl
  <b>updateProductWithoutImage()</b> triggers
  demand notification pipeline:
  haveDemanded() → productAvailableNow()
  → removeProduct() per waiting customer
end note

note bottom of CartServiceImpl
  <b>addProductToCart()</b> caps qty at stock level
  and auto-creates DemandBean for shortfall
end note

@enduml
