@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Customer-Facing Servlet Layer

' ─────────────────────────────────────────
' Base class (external – javax.servlet)
' ─────────────────────────────────────────
package "javax.servlet.http" <<Frame>> {
    class HttpServlet {
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
}

' ─────────────────────────────────────────
' Customer-Facing Servlets
' ─────────────────────────────────────────
package "com.shashi.srv" {

    class LoginSrv <<Servlet>> {
        -{static} final serialVersionUID: long
        --
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of LoginSrv : @WebServlet("/LoginSrv")\nSets session: username, password,\nusertype, userdata\nRedirects: adminViewProduct.jsp (admin)\nuserHome.jsp (customer)\nlogin.jsp?message=... (invalid)

    class LogoutSrv <<Servlet>> {
        -{static} final serialVersionUID: long
        --
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of LogoutSrv : @WebServlet("/LogoutSrv")\nInvalidates session attributes\nRedirects: login.jsp?message=Successfully Logged Out!

    class RegisterSrv <<Servlet>> {
        -{static} final serialVersionUID: long
        --
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of RegisterSrv : @WebServlet("/RegisterSrv")\nParams: username, mobile, email,\naddress, pincode, password\nRedirects: register.jsp?message=...

    class AddtoCart <<Servlet>> {
        -{static} final serialVersionUID: long
        --
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of AddtoCart : @WebServlet("/AddtoCart")\nSession guard: customer role required\nParams: pid, pqty\nBranches: remove / demand / update cart

    class UpdateToCart <<Servlet>> {
        -{static} final serialVersionUID: long
        --
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of UpdateToCart : @WebServlet("/UpdateToCart")\nSession guard: login required\nParams: pid, pqty\nIncludes: cartDetails.jsp

    class OrderServlet <<Servlet>> {
        -{static} final serialVersionUID: long
        --
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of OrderServlet : @WebServlet("/OrderServlet")\nSession guard: login required\nParam: amount (double)\nIncludes: orderDetails.jsp

    class ShowImage <<Servlet>> {
        -{static} final serialVersionUID: long
        --
        +doGet(request: HttpServletRequest, response: HttpServletResponse): void
        +doPost(request: HttpServletRequest, response: HttpServletResponse): void
    }
    note right of ShowImage : @WebServlet("/ShowImage")\nParam: pid\nResponse: image/jpeg binary\nFallback: noimage.jpg from context
}

' ─────────────────────────────────────────
' Service Layer
' ─────────────────────────────────────────
package "com.shashi.service.impl" {

    class UserServiceImpl {
        +isValidCredential(userName: String, password: String): String
        +getUserDetails(userName: String, password: String): UserBean
        +registerUser(user: UserBean): String
    }

    class CartServiceImpl {
        +getProductCount(userId: String, prodId: String): int
        +removeProductFromCart(userId: String, prodId: String): String
        +updateProductToCart(userId: String, prodId: String, qty: int): String
    }

    class ProductServiceImpl {
        +getProductDetails(prodId: String): ProductBean
        +getImage(prodId: String): byte[]
    }

    class DemandServiceImpl {
        +addProduct(demandBean: DemandBean): boolean
    }

    class OrderServiceImpl {
        +paymentSuccess(userName: String, paidAmount: double): String
    }
}

' ─────────────────────────────────────────
' Bean / Model Classes
' ─────────────────────────────────────────
package "com.shashi.beans" {

    class UserBean {
        -name: String
        -mobile: Long
        -email: String
        -address: String
        -pinCode: int
        -password: String
        --
        +getName(): String
        +getMobile(): Long
        +getEmail(): String
        +getPassword(): String
    }

    class ProductBean {
        -prodId: String
        -prodName: String
        -prodType: String
        -prodPrice: double
        -prodQuantity: int
        --
        +getProdId(): String
        +getProdName(): String
        +getProdQuantity(): int
    }

    class DemandBean {
        -userName: String
        -prodId: String
        -demandQty: int
        --
        +getUserName(): String
        +getProdId(): String
        +getDemandQty(): int
    }
}

' ─────────────────────────────────────────
' Inheritance – all servlets extend HttpServlet
' ─────────────────────────────────────────
LoginSrv     --|> HttpServlet
LogoutSrv    --|> HttpServlet
RegisterSrv  --|> HttpServlet
AddtoCart    --|> HttpServlet
UpdateToCart --|> HttpServlet
OrderServlet --|> HttpServlet
ShowImage    --|> HttpServlet

' ─────────────────────────────────────────
' Servlet → Service dependencies
' ─────────────────────────────────────────
LoginSrv     ..> UserServiceImpl  : uses
RegisterSrv  ..> UserServiceImpl  : uses

AddtoCart    ..> CartServiceImpl    : uses
AddtoCart    ..> ProductServiceImpl : uses
AddtoCart    ..> DemandServiceImpl  : uses

UpdateToCart ..> CartServiceImpl    : uses
UpdateToCart ..> ProductServiceImpl : uses
UpdateToCart ..> DemandServiceImpl  : uses

OrderServlet ..> OrderServiceImpl   : uses
ShowImage    ..> ProductServiceImpl : uses

' ─────────────────────────────────────────
' Servlet → Bean dependencies
' ─────────────────────────────────────────
LoginSrv     ..> UserBean    : creates / reads
RegisterSrv  ..> UserBean    : creates

AddtoCart    ..> ProductBean : reads
AddtoCart    ..> DemandBean  : creates

UpdateToCart ..> ProductBean : reads
UpdateToCart ..> DemandBean  : creates

' ─────────────────────────────────────────
' Service return types (composition)
' ─────────────────────────────────────────
UserServiceImpl    ..> UserBean    : returns
ProductServiceImpl ..> ProductBean : returns

@enduml
