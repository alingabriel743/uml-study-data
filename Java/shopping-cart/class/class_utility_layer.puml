@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Utility Layer — Infrastructure & Cross-Cutting Concerns

package "com.shashi.utility" {

    class DBUtil <<utility>> {
        {static} - conn: Connection
        --
        + DBUtil()
        + {static} provideConnection(): Connection
        + {static} closeConnection(con: Connection): void
        + {static} closeConnection(rs: ResultSet): void
        + {static} closeConnection(ps: PreparedStatement): void
    }

    class JavaMailUtil <<utility>> {
        --
        + {static} sendMail(recipientMailId: String): void
        # {static} sendMail(recipient: String, subject: String, htmlTextMessage: String): void
        - {static} prepareMessage(session: Session, myAccountEmail: String, recipientEmail: String): Message
        - {static} prepareMessage(session: Session, myAccountEmail: String, recipientEmail: String, subject: String, htmlTextMessage: String): Message
    }

    class MailMessage <<utility>> {
        --
        + {static} registrationSuccess(emailId: String, name: String): void
        + {static} transactionSuccess(recipientEmail: String, name: String, transId: String, transAmount: double): void
        + {static} orderShipped(recipientEmail: String, name: String, transId: String, transAmount: double): void
        + {static} productAvailableNow(recipientEmail: String, name: String, prodName: String, prodId: String): void
        + {static} sendMessage(toEmailId: String, subject: String, htmlTextMessage: String): String
    }

    class IDUtil <<utility>> {
        --
        + {static} generateId(): String
        + {static} generateTransId(): String
    }

    class TestMail <<test>> {
        --
        + {static} main(args: String[]): void
    }

}

package "java.sql" <<external>> {
    interface Connection
    interface ResultSet
    interface PreparedStatement
}

package "jakarta.mail" <<external>> {
    class Session
    class Transport
    class MimeMessage
}

package "java.util" <<external>> {
    class ResourceBundle
}

package "java.text / java.util" <<external>> {
    class SimpleDateFormat
    class Date
}

' ── Internal dependencies ──────────────────────────────────────────
MailMessage ..> JavaMailUtil : «delegates all mail\nsending to»
TestMail    ..> JavaMailUtil : «smoke-test calls»

' ── DBUtil external deps ────────────────────────────────────────────
DBUtil ..> Connection       : «manages singleton»
DBUtil ..> ResultSet        : «closes»
DBUtil ..> PreparedStatement: «closes»
DBUtil ..> ResourceBundle   : «reads db config»

' ── JavaMailUtil external deps ──────────────────────────────────────
JavaMailUtil ..> Session     : «builds SMTP session»
JavaMailUtil ..> Transport   : «sends message»
JavaMailUtil ..> MimeMessage : «creates»
JavaMailUtil ..> ResourceBundle : «reads SMTP config»

' ── IDUtil external deps ────────────────────────────────────────────
IDUtil ..> SimpleDateFormat : «formats timestamp»
IDUtil ..> Date             : «current timestamp»

' ── Notes ───────────────────────────────────────────────────────────
note right of DBUtil
  Lazy singleton pattern.
  Config via 'application' ResourceBundle:
    db.connectionString
    db.driverName
    db.username / db.password
  closeConnection(Connection) is a no-op.
end note

note right of JavaMailUtil
  SMTP: smtp.gmail.com:587 (STARTTLS).
  Credentials via 'application' ResourceBundle:
    mailer.email / mailer.password
  sendMail(String,String,String) is protected —
  intended for MailMessage & TestMail only.
end note

note bottom of MailMessage
  Public API for all business emails.
  All methods delegate to
  JavaMailUtil.sendMail(recipient, subject, html).
  sendMessage() returns "SUCCESS" or "FAILURE".
end note

note bottom of IDUtil
  Timestamp IDs — no randomness.
  Product ID  : "P" + yyyyMMddhhmmss
  Transaction : "T" + yyyyMMddhhmmss
  Collision possible within same second.
end note

note bottom of TestMail
  Standalone smoke-test (main() entry point).
  Not a JUnit test.
  Hardcoded recipient: ellison.alumni@gmail.com
end note

@enduml
