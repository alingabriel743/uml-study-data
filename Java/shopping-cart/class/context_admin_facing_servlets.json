{
  "scope": "admin_facing_servlets",
  "title": "Admin-Facing Servlet Layer",
  "diagram_type": "class",
  "package": "com.shashi.srv",

  "classes": [
    {
      "name": "AddProductSrv",
      "package": "com.shashi.srv",
      "stereotype": "servlet",
      "annotations": ["@WebServlet(\"/AddProductSrv\")", "@MultipartConfig(maxFileSize=16177215)"],
      "extends": "HttpServlet",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "doGet_logic": [
        "Session check: usertype=='admin', username != null, password != null",
        "Redirect to login.jsp on failure",
        "Read params: name, type, info, price(double), quantity(int), image(Part→InputStream)",
        "new ProductServiceImpl().addProduct(name, type, info, price, quantity, imageStream): String",
        "Forward to addProduct.jsp?message=status"
      ]
    },
    {
      "name": "RemoveProductSrv",
      "package": "com.shashi.srv",
      "stereotype": "servlet",
      "annotations": ["@WebServlet(\"/RemoveProductSrv\")"],
      "extends": "HttpServlet",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "RemoveProductSrv()",
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "doGet_logic": [
        "Session check: usertype=='admin', username/password not null",
        "Read param: prodid",
        "new ProductServiceImpl().removeProduct(prodId): String",
        "Forward to removeProduct.jsp?message=status"
      ]
    },
    {
      "name": "UpdateProductSrv",
      "package": "com.shashi.srv",
      "stereotype": "servlet",
      "annotations": ["@WebServlet(\"/UpdateProductSrv\")"],
      "extends": "HttpServlet",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "UpdateProductSrv()",
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "doGet_logic": [
        "Session check: usertype=='admin', username/password not null (returns on failure)",
        "Read params: pid, name, type, info, price(Double), quantity(Integer)",
        "Construct ProductBean and set all fields",
        "new ProductServiceImpl().updateProductWithoutImage(prodId, productBean): String",
        "Forward to updateProduct.jsp?prodid=pid&message=status"
      ]
    },
    {
      "name": "ShipmentServlet",
      "package": "com.shashi.srv",
      "stereotype": "servlet",
      "annotations": ["@WebServlet(\"/ShipmentServlet\")"],
      "extends": "HttpServlet",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "ShipmentServlet()",
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "doGet_logic": [
        "Session check: usertype != null",
        "Read params: orderid, prodid, userid, amount(Double)",
        "new OrderServiceImpl().shipNow(orderId, prodId): String",
        "If SUCCESS: MailMessage.orderShipped(userName, new UserServiceImpl().getFName(userName), orderId, amount)",
        "If FAILURE: pagename = unshippedItems.jsp, else shippedItems.jsp",
        "Include page via RequestDispatcher; inject JS to set #message innerHTML"
      ]
    },
    {
      "name": "FansMessage",
      "package": "com.shashi.srv",
      "stereotype": "servlet",
      "annotations": ["@WebServlet(\"/fansMessage\")"],
      "extends": "HttpServlet",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "doGet_logic": [
        "No auth/session check",
        "Read params: name, email, comments",
        "Build HTML email body string",
        "MailMessage.sendMessage('ellison.alumni@gmail.com', 'Fans Message | name | email', htmlBody): String",
        "Include index.jsp; print JS alert with send status"
      ]
    },
    {
      "name": "ProductServiceImpl",
      "package": "com.shashi.service.impl",
      "implements": "ProductService",
      "relevant_methods": [
        "addProduct(String name, String type, String info, double price, int qty, InputStream image): String",
        "addProduct(ProductBean product): String",
        "removeProduct(String prodId): String",
        "updateProduct(ProductBean prev, ProductBean updated): String",
        "updateProductWithoutImage(String prevProductId, ProductBean updated): String",
        "updateProductPrice(String prodId, double price): String",
        "getProductDetails(String prodId): ProductBean",
        "getProductPrice(String prodId): double",
        "sellNProduct(String prodId, int n): boolean",
        "getProductQuantity(String prodId): int"
      ]
    },
    {
      "name": "OrderServiceImpl",
      "package": "com.shashi.service.impl",
      "implements": "OrderService",
      "relevant_methods": [
        "shipNow(String orderId, String prodId): String"
      ]
    },
    {
      "name": "UserServiceImpl",
      "package": "com.shashi.service.impl",
      "implements": "UserService",
      "relevant_methods": [
        "getFName(String emailId): String"
      ]
    },
    {
      "name": "ProductBean",
      "package": "com.shashi.beans",
      "implements": "Serializable",
      "fields": [
        "prodId: String",
        "prodName: String",
        "prodType: String",
        "prodInfo: String",
        "prodPrice: double",
        "prodQuantity: int",
        "prodImage: InputStream"
      ],
      "methods": [
        "getProdId(): String", "setProdId(String): void",
        "getProdName(): String", "setProdName(String): void",
        "getProdType(): String", "setProdType(String): void",
        "getProdInfo(): String", "setProdInfo(String): void",
        "getProdPrice(): double", "setProdPrice(double): void",
        "getProdQuantity(): int", "setProdQuantity(int): void",
        "getProdImage(): InputStream", "setProdImage(InputStream): void"
      ]
    },
    {
      "name": "MailMessage",
      "package": "com.shashi.utility",
      "stereotype": "utility",
      "methods": [
        "static registrationSuccess(String emailId, String name): void",
        "static transactionSuccess(String recipientEmail, String name, String transId, double amount): void",
        "static orderShipped(String recipientEmail, String name, String transId, double amount): void",
        "static productAvailableNow(String recipientEmail, String name, String prodName, String prodId): void",
        "static sendMessage(String toEmailId, String subject, String htmlText): String"
      ]
    }
  ],

  "relationships": [
    "AddProductSrv extends HttpServlet",
    "RemoveProductSrv extends HttpServlet",
    "UpdateProductSrv extends HttpServlet",
    "ShipmentServlet extends HttpServlet",
    "FansMessage extends HttpServlet",
    "ProductBean implements Serializable",
    "ProductServiceImpl implements ProductService",
    "OrderServiceImpl implements OrderService",
    "UserServiceImpl implements UserService",
    "AddProductSrv depends_on ProductServiceImpl (instantiates, calls addProduct)",
    "RemoveProductSrv depends_on ProductServiceImpl (instantiates, calls removeProduct)",
    "UpdateProductSrv depends_on ProductServiceImpl (instantiates, calls updateProductWithoutImage)",
    "UpdateProductSrv depends_on ProductBean (creates and populates)",
    "ShipmentServlet depends_on OrderServiceImpl (instantiates, calls shipNow)",
    "ShipmentServlet depends_on UserServiceImpl (instantiates, calls getFName)",
    "ShipmentServlet depends_on MailMessage (static call orderShipped)",
    "FansMessage depends_on MailMessage (static call sendMessage)"
  ],

  "common_patterns": [
    "All 5 servlets extend HttpServlet and delegate doPost → doGet",
    "Admin servlets (Add/Remove/Update Product) enforce usertype=='admin' session check before processing",
    "ShipmentServlet checks usertype != null (any logged-in user role)",
    "FansMessage has no authentication guard",
    "All service instances created inline (new XxxServiceImpl()) — no DI framework",
    "All servlets use RequestDispatcher.forward() or include() for JSP navigation"
  ],

  "url_mappings": [
    "AddProductSrv → /AddProductSrv",
    "RemoveProductSrv → /RemoveProductSrv",
    "UpdateProductSrv → /UpdateProductSrv",
    "ShipmentServlet → /ShipmentServlet",
    "FansMessage → /fansMessage"
  ],

  "source_files_analyzed": [
    "src/com/shashi/srv/AddProductSrv.java",
    "src/com/shashi/srv/RemoveProductSrv.java",
    "src/com/shashi/srv/UpdateProductSrv.java",
    "src/com/shashi/srv/ShipmentServlet.java",
    "src/com/shashi/srv/FansMessage.java",
    "src/com/shashi/service/impl/ProductServiceImpl.java (signatures only)",
    "src/com/shashi/service/impl/OrderServiceImpl.java (signatures only)",
    "src/com/shashi/service/impl/UserServiceImpl.java (signatures only)",
    "src/com/shashi/beans/ProductBean.java (fields + accessors)",
    "src/com/shashi/utility/MailMessage.java (static method signatures)"
  ]
}
