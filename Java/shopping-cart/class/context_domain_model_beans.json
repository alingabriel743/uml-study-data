        "+ getTransAmount(): double", "+ setTransAmount(double): void"
      ],
      "dependencies": ["IDUtil.generateTransId() — external utility for ID generation"],
      "notes": "userName FK → UserBean.email. transactionId is auto-generated UUID-style via IDUtil when not explicitly provided."
