  ],
  "key_relationships": [
    "All 7 classes implement java.io.Serializable (no inheritance hierarchy between beans)",
    "CartBean.userId --references--> UserBean.email (logical FK)",
    "CartBean.prodId --references--> ProductBean.prodId (logical FK)",
    "OrderBean.transactionId --references--> TransactionBean.transactionId (logical FK)",
    "OrderBean.productId --references--> ProductBean.prodId (logical FK)",
    "OrderDetails aggregates data from OrderBean + TransactionBean + ProductBean (read-model DTO)",
    "TransactionBean.userName --references--> UserBean.email (logical FK)",
    "DemandBean.userName --references--> UserBean.email (logical FK)",
    "DemandBean.prodId --references--> ProductBean.prodId (logical FK)",
    "TransactionBean depends_on IDUtil (com.shashi.utility.IDUtil) for ID generation"
  ],
  "domain_notes": [
    "No ORM annotations — plain Java beans (manual JDBC expected in service/DAO layer)",
    "All logical relationships are by String key (email for user, prodId for product, transactionId for order)",
    "CartBean fields are public (not private) — inconsistent encapsulation",
    "OrderDetails is a flattened read-model DTO, not stored as-is; qty/amount are String for display",
    "TransactionBean auto-generates its ID and timestamp in most constructors via IDUtil",
    "shipped field in OrderBean/OrderDetails is int flag: 0=not shipped, 1=shipped"
  ],
  "source_files_analyzed": [
