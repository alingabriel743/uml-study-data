{
  "scope": "user_facing_servlets",
  "title": "Customer-Facing Servlet Layer",
  "diagram_type": "class",
  "package": "com.shashi.srv",

  "classes": [
    {
      "name": "LoginSrv",
      "url_pattern": "/LoginSrv",
      "extends": "HttpServlet",
      "annotation": "@WebServlet(\"/LoginSrv\")",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "dependencies": ["UserServiceImpl", "UserBean", "HttpSession"],
      "service_calls": [
        "UserServiceImpl.isValidCredential(userName, password): String",
        "UserServiceImpl.getUserDetails(userName, password): UserBean"
      ],
      "session_attributes_set": ["username", "password", "usertype", "userdata"],
      "redirects": ["adminViewProduct.jsp (admin)", "userHome.jsp (valid customer)", "login.jsp?message=... (invalid)"]
    },
    {
      "name": "LogoutSrv",
      "url_pattern": "/LogoutSrv",
      "extends": "HttpServlet",
      "annotation": "@WebServlet(\"/LogoutSrv\")",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "dependencies": ["HttpSession"],
      "service_calls": [],
      "session_attributes_set": ["username→null", "password→null", "usertype→null", "userdata→null"],
      "redirects": ["login.jsp?message=Successfully Logged Out!"]
    },
    {
      "name": "RegisterSrv",
      "url_pattern": "/RegisterSrv",
      "extends": "HttpServlet",
      "annotation": "@WebServlet(\"/RegisterSrv\")",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "dependencies": ["UserServiceImpl", "UserBean"],
      "service_calls": [
        "UserServiceImpl.registerUser(UserBean): String"
      ],
      "params_read": ["username", "mobile (Long)", "email", "address", "pincode (int)", "password", "confirmPassword"],
      "redirects": ["register.jsp?message=..."]
    },
    {
      "name": "AddtoCart",
      "url_pattern": "/AddtoCart",
      "extends": "HttpServlet",
      "annotation": "@WebServlet(\"/AddtoCart\")",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "dependencies": ["CartServiceImpl", "ProductServiceImpl", "DemandServiceImpl", "ProductBean", "DemandBean", "HttpSession"],
      "service_calls": [
        "ProductServiceImpl.getProductDetails(prodId): ProductBean",
        "CartServiceImpl.getProductCount(userId, prodId): int",
        "CartServiceImpl.removeProductFromCart(userId, prodId): String",
        "CartServiceImpl.updateProductToCart(userId, prodId, qty): String",
        "DemandServiceImpl.addProduct(DemandBean): boolean"
      ],
      "session_check": "username, password, usertype == 'customer' required; else redirect login.jsp",
      "params_read": ["pid", "pqty (int)"],
      "logic_branches": [
        "pQty==cartQty → removeProductFromCart → include userHome.jsp",
        "availableQty < pQty → updateProductToCart(availableQty) + addProduct(demandBean) → include cartDetails.jsp",
        "else → updateProductToCart(pQty) → include userHome.jsp"
      ]
    },
    {
      "name": "UpdateToCart",
      "url_pattern": "/UpdateToCart",
      "extends": "HttpServlet",
      "annotation": "@WebServlet(\"/UpdateToCart\")",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "dependencies": ["CartServiceImpl", "ProductServiceImpl", "DemandServiceImpl", "ProductBean", "DemandBean", "HttpSession"],
      "service_calls": [
        "ProductServiceImpl.getProductDetails(prodId): ProductBean",
        "CartServiceImpl.updateProductToCart(userId, prodId, qty): String",
        "DemandServiceImpl.addProduct(DemandBean): boolean"
      ],
      "session_check": "username, password required; else redirect login.jsp",
      "params_read": ["pid", "pqty (int)"],
      "logic_branches": [
        "availableQty < pQty → updateProductToCart(availableQty) + addProduct(demandBean) → include cartDetails.jsp",
        "else → updateProductToCart(pQty) → include cartDetails.jsp"
      ]
    },
    {
      "name": "OrderServlet",
      "url_pattern": "/OrderServlet",
      "extends": "HttpServlet",
      "annotation": "@WebServlet(\"/OrderServlet\")",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "dependencies": ["OrderServiceImpl", "HttpSession"],
      "service_calls": [
        "OrderServiceImpl.paymentSuccess(userName, paidAmount): String"
      ],
      "session_check": "username, password required; else redirect login.jsp",
      "params_read": ["amount (double)"],
      "redirects": ["orderDetails.jsp (include)"]
    },
    {
      "name": "ShowImage",
      "url_pattern": "/ShowImage",
      "extends": "HttpServlet",
      "annotation": "@WebServlet(\"/ShowImage\")",
      "fields": [
        "serialVersionUID: long (static final)"
      ],
      "methods": [
        "doGet(HttpServletRequest, HttpServletResponse): void",
        "doPost(HttpServletRequest, HttpServletResponse): void"
      ],
      "dependencies": ["ProductServiceImpl"],
      "service_calls": [
        "ProductServiceImpl.getImage(prodId): byte[]"
      ],
      "params_read": ["pid"],
      "logic_branches": [
        "image != null → write bytes to ServletOutputStream",
        "image == null → read noimage.jpg from context, write bytes"
      ],
      "response_type": "binary image (image/jpeg)"
    }
  ],

  "external_service_classes": [
    {
      "name": "UserServiceImpl",
      "methods_used": [
        "isValidCredential(String userName, String password): String",
        "getUserDetails(String userName, String password): UserBean",
        "registerUser(UserBean user): String"
      ]
    },
    {
      "name": "CartServiceImpl",
      "methods_used": [
        "getProductCount(String userId, String prodId): int",
        "removeProductFromCart(String userId, String prodId): String",
        "updateProductToCart(String userId, String prodId, int qty): String"
      ]
    },
    {
      "name": "ProductServiceImpl",
      "methods_used": [
        "getProductDetails(String prodId): ProductBean",
        "getImage(String prodId): byte[]"
      ]
    },
    {
      "name": "DemandServiceImpl",
      "methods_used": [
        "addProduct(DemandBean demandBean): boolean"
      ]
    },
    {
      "name": "OrderServiceImpl",
      "methods_used": [
        "paymentSuccess(String userName, double paidAmount): String"
      ]
    }
  ],

  "bean_classes": [
    {
      "name": "UserBean",
      "constructor_used": "UserBean(userName, mobileNo, emailId, address, pinCode, password)"
    },
    {
      "name": "ProductBean",
      "fields_accessed": ["prodQuantity", "prodName", "prodId"]
    },
    {
      "name": "DemandBean",
      "constructor_used": "DemandBean(userName, prodId, demandQty)"
    }
  ],

  "key_relationships": [
    "LoginSrv extends HttpServlet",
    "LogoutSrv extends HttpServlet",
    "RegisterSrv extends HttpServlet",
    "AddtoCart extends HttpServlet",
    "UpdateToCart extends HttpServlet",
    "OrderServlet extends HttpServlet",
    "ShowImage extends HttpServlet",
    "LoginSrv depends_on UserServiceImpl",
    "LoginSrv depends_on UserBean",
    "RegisterSrv depends_on UserServiceImpl",
    "RegisterSrv depends_on UserBean",
    "AddtoCart depends_on CartServiceImpl",
    "AddtoCart depends_on ProductServiceImpl",
    "AddtoCart depends_on DemandServiceImpl",
    "AddtoCart depends_on ProductBean",
    "AddtoCart depends_on DemandBean",
    "UpdateToCart depends_on CartServiceImpl",
    "UpdateToCart depends_on ProductServiceImpl",
    "UpdateToCart depends_on DemandServiceImpl",
    "UpdateToCart depends_on ProductBean",
    "UpdateToCart depends_on DemandBean",
    "OrderServlet depends_on OrderServiceImpl",
    "ShowImage depends_on ProductServiceImpl"
  ],

  "common_patterns": [
    "All servlets extend HttpServlet and route doPost → doGet",
    "Session-guarded servlets (AddtoCart, UpdateToCart, OrderServlet) redirect to login.jsp on missing session",
    "LoginSrv hardcodes admin credentials (admin@gmail.com / admin); customer auth delegated to UserServiceImpl",
    "AddtoCart and UpdateToCart share identical demand-recording logic when stock is insufficient",
    "ShowImage falls back to noimage.jpg from servlet context when product image is null"
  ],

  "source_files_analyzed": [
    "src/com/shashi/srv/LoginSrv.java",
    "src/com/shashi/srv/LogoutSrv.java",
    "src/com/shashi/srv/RegisterSrv.java",
    "src/com/shashi/srv/AddtoCart.java",
    "src/com/shashi/srv/UpdateToCart.java",
    "src/com/shashi/srv/OrderServlet.java",
    "src/com/shashi/srv/ShowImage.java"
  ]
}
