@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}
skinparam database {
    BackgroundColor #FFF3CD
    BorderColor #856404
}
skinparam arrow {
    Color #495057
}

title E-Commerce Application — Component Architecture\n(com.shashi)

' ─── Presentation Layer ───────────────────────────────────────
package "Presentation Layer  (com.shashi.srv)" {
    [User Servlets\n<<LoginSrv, RegisterSrv, LogoutSrv>>] as userSrv
    [Product Servlets\n<<AddProductSrv, UpdateProductSrv,\nRemoveProductSrv, ShowImage>>] as productSrv
    [Cart Servlets\n<<AddtoCart, UpdateToCart>>] as cartSrv
    [Order & Shipment Servlets\n<<OrderServlet, ShipmentServlet>>] as orderSrv
    [Messaging Servlet\n<<FansMessage>>] as messageSrv
}

' ─── Service Layer ────────────────────────────────────────────
package "Service Layer  (com.shashi.service)" {
    interface "UserService" as IUserSvc
    interface "ProductService" as IProductSvc
    interface "CartService" as ICartSvc
    interface "OrderService" as IOrderSvc
    interface "DemandService" as IDemandSvc
    interface "TransService" as ITransSvc
}

' ─── Service Implementation Layer ─────────────────────────────
package "Service Implementation Layer  (com.shashi.service.impl)" {
    [UserServiceImpl] as userImpl
    [ProductServiceImpl] as productImpl
    [CartServiceImpl] as cartImpl
    [OrderServiceImpl] as orderImpl
    [DemandServiceImpl] as demandImpl
    [TransServiceImpl] as transImpl
}

' ─── Domain Model Layer ───────────────────────────────────────
package "Domain Model Layer  (com.shashi.beans)" {
    [UserBean] as userBean
    [ProductBean] as productBean
    [CartBean] as cartBean
    [OrderBean / OrderDetails] as orderBean
    [TransactionBean] as transBean
    [DemandBean] as demandBean
}

' ─── Utility Layer ────────────────────────────────────────────
package "Utility Layer  (com.shashi.utility)" {
    [DBUtil] as dbUtil
    [JavaMailUtil] as mailUtil
    [IDUtil] as idUtil
    [MailMessage] as mailMsg
}

' ─── Constants ────────────────────────────────────────────────
package "Constants  (com.shashi.constants)" {
    [IUserConstants] as constants
}

' ─── External Systems ─────────────────────────────────────────
database "Relational Database" as DB
actor "SMTP Mail Server" as SMTP

' ─── Relationships: Presentation → Service interfaces ─────────
userSrv    --> IUserSvc    : uses
productSrv --> IProductSvc : uses
productSrv --> IDemandSvc  : uses
cartSrv    --> ICartSvc    : uses
cartSrv    --> IDemandSvc  : uses
cartSrv    --> IProductSvc : uses
orderSrv   --> IOrderSvc   : uses
orderSrv   --> IUserSvc    : uses
messageSrv --> mailMsg     : uses

' ─── Relationships: Implementations → Interfaces ──────────────
IUserSvc    <|.. userImpl    : implements
IProductSvc <|.. productImpl : implements
ICartSvc    <|.. cartImpl    : implements
IOrderSvc   <|.. orderImpl   : implements
IDemandSvc  <|.. demandImpl  : implements
ITransSvc   <|.. transImpl   : implements

' ─── Relationships: Implementations → Domain Model ────────────
userImpl    --> userBean    : uses
productImpl --> productBean : uses
productImpl --> demandBean  : uses
cartImpl    --> cartBean    : uses
cartImpl    --> productBean : uses
cartImpl    --> demandBean  : uses
orderImpl   --> cartBean    : uses
orderImpl   --> orderBean   : uses
orderImpl   --> transBean   : uses
demandImpl  --> demandBean  : uses

' ─── Relationships: Implementations → Utilities ───────────────
userImpl    --> dbUtil   : queries
productImpl --> dbUtil   : queries
cartImpl    --> dbUtil   : queries
orderImpl   --> dbUtil   : queries
demandImpl  --> dbUtil   : queries
transImpl   --> dbUtil   : queries

userImpl    --> mailMsg  : sends mail
productImpl --> mailMsg  : sends mail
orderImpl   --> mailMsg  : sends mail
productImpl --> idUtil   : generates ID

userImpl --> constants : uses

' ─── Relationships: Utility → External ───────────────────────
dbUtil   --> DB   : JDBC
mailMsg  --> mailUtil : delegates
mailUtil --> SMTP : sends email
orderSrv --> mailMsg : sends shipment notification

@enduml
