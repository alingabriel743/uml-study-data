@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam node {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam artifact {
    BackgroundColor #DEE2E6
    BorderColor #495057
}
skinparam database {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
}
skinparam actor {
    BackgroundColor #FFF3CD
    BorderColor #856404
}
skinparam cloud {
    BackgroundColor #D4EDDA
    BorderColor #155724
}

title Shopping Cart — Deployment Diagram

actor "End User\n(Browser)" as user
actor "Admin\n(Browser)" as admin

node "Client Machine" <<Device>> {
    artifact "Web Browser\n(HTML / CSS / JS / Bootstrap)" as browser
}

node "Application Server" <<Apache Tomcat v8.0+>> {
    artifact "shopping-cart.war" as war {
        artifact "JSP Views\n(index, login, userHome,\nadminHome, cart, payment,\norderDetails, …)" as jsps
        artifact "Java Servlets\n(UserServlet, CartServlet,\nOrderServlet, ProductServlet, …)" as servlets
        artifact "Service Layer\n(UserService, CartService,\nOrderService, ProductService,\nDemandService, TransactionService)" as services
        artifact "Domain Beans\n(UserBean, ProductBean, CartBean,\nOrderBean, TransactionBean, …)" as beans
        artifact "Utilities\n(DBUtil, JavaMailUtil, IDUtil)" as utils
    }
}

database "MySQL Server\n(localhost:3306)" <<MySQL 8>> {
    artifact "shopping-cart\ndatabase" as db
}

cloud "Gmail SMTP\n(smtp.gmail.com:587)" as smtp

user --> browser : "HTTP requests"
admin --> browser : "HTTP requests"
browser --> war : "HTTP / HTTPS\n(port 8080)"
servlets --> services : "calls"
services --> beans : "uses"
services --> utils : "calls"
utils --> db : "JDBC\n(mysql-connector-java)"
utils --> smtp : "SMTP / TLS\n(Jakarta Mail)\norder & shipping\nnotifications"

note right of war
  Packaged as WAR (Maven)
  Deployed to Tomcat webapps/
  Context path: /shopping-cart
end note

note bottom of db
  Schema: shopping-cart
  Tables: user, product, cart,
  orders, transaction, demand
end note

note right of smtp
  Triggered on:
  - User Registration
  - Order Placed
  - Item Restocked
  - Item Shipped / Delivered
end note

@enduml
