@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #495057
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceParticipantFontColor #212529
skinparam sequenceActorBorderColor #495057
skinparam sequenceActorBackgroundColor #E9ECEF
skinparam sequenceLifeLineBorderColor #ADB5BD
skinparam sequenceGroupBorderColor #6C757D
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam sequenceGroupFontColor #212529
skinparam noteBorderColor #6C757D
skinparam noteBackgroundColor #FFF9C4

title Order Placement and Payment Flow

actor "Customer\n(Browser)" as Customer
participant "OrderServlet" as OrderServlet
participant "HttpSession" as Session
participant "OrderServiceImpl" as OrderService
participant "CartServiceImpl" as CartService
participant "ProductServiceImpl" as ProductService
participant "TransactionBean" as TransactionBean
participant "IDUtil" as IDUtil
participant "OrderBean" as OrderBean
participant "DBUtil" as DBUtil
database "Database" as DB
participant "UserServiceImpl" as UserService
participant "MailMessage" as MailMessage
participant "JavaMailUtil" as JavaMailUtil
participant "SMTP Server\n(smtp.gmail.com:587)" as SMTP
participant "orderDetails.jsp" as JSP

== Request Received ==

Customer -> OrderServlet : GET /OrderServlet?amount=<paidAmount>
activate OrderServlet

OrderServlet -> Session : getAttribute("username")
OrderServlet -> Session : getAttribute("password")
Session --> OrderServlet : userName, password

alt Session Expired (username or password is null)
    OrderServlet --> Customer : redirect → login.jsp?message=Session Expired
    note right of OrderServlet : Flow terminates here\nif session is invalid
end

== Payment Processing ==

OrderServlet -> OrderService : paymentSuccess(userName, paidAmount)
activate OrderService

OrderService -> CartService : getAllCartItems(userName)
activate CartService
CartService -> DBUtil : provideConnection()
DBUtil --> CartService : Connection
CartService -> DB : SELECT cart items WHERE userId = userName
DB --> CartService : List<CartBean>
CartService --> OrderService : cartItems (List<CartBean>)
deactivate CartService

alt Cart is Empty (cartItems.size() == 0)
    OrderService --> OrderServlet : "Order Placement Failed!"
    note right of OrderService : No items to process
end

== Transaction Initialisation ==

OrderService -> TransactionBean : new TransactionBean(userName, paidAmount)
activate TransactionBean
TransactionBean -> IDUtil : generateTransId()
activate IDUtil
note right of IDUtil : Generates "T" + yyyyMMddhhmmss\ntimestamp string
IDUtil --> TransactionBean : transactionId (e.g. "T20260417134502")
deactivate IDUtil
TransactionBean -> TransactionBean : System.currentTimeMillis() → transDateTime (Timestamp)
TransactionBean --> OrderService : transactionBean (with transactionId, transDateTime)
deactivate TransactionBean

== Order Items Loop ==

loop For each CartBean item in cartItems

    OrderService -> ProductService : getProductPrice(item.getProdId())
    activate ProductService
    ProductService -> DBUtil : provideConnection()
    DBUtil --> ProductService : Connection
    ProductService -> DB : SELECT price WHERE prodId = item.getProdId()
    DB --> ProductService : price (double)
    ProductService --> OrderService : price
    deactivate ProductService

    OrderService -> OrderBean : new OrderBean(transactionId, prodId, quantity, price * qty)
    activate OrderBean
    note right of OrderBean : shipped defaults to 0
    OrderBean --> OrderService : orderBean
    deactivate OrderBean

    OrderService -> DBUtil : provideConnection()
    DBUtil --> OrderService : Connection
    OrderService -> DB : INSERT INTO orders\n(transid, prodid, quantity, amount, shipped=0)
    DB --> OrderService : addOrder result (boolean)

    alt addOrder succeeded
        OrderService -> CartService : removeAProduct(userName, prodId)
        activate CartService
        CartService -> DBUtil : provideConnection()
        DBUtil --> CartService : Connection
        CartService -> DB : DELETE FROM cart\nWHERE userId = userName AND prodId = prodId
        DB --> CartService : removeAProduct result (boolean)
        CartService --> OrderService : removeAProduct result
        deactivate CartService

        alt removeAProduct succeeded
            OrderService -> ProductService : sellNProduct(prodId, quantity)
            activate ProductService
            ProductService -> DBUtil : provideConnection()
            DBUtil --> ProductService : Connection
            ProductService -> DB : UPDATE products SET stock = stock - quantity\nWHERE prodId = prodId
            DB --> ProductService : sellNProduct result (boolean)
            ProductService --> OrderService : sellNProduct result
            deactivate ProductService
        else removeAProduct failed
            note over OrderService : Break loop — order placement failed
        end

    else addOrder failed
        note over OrderService : Break loop — order placement failed
    end

end

== Transaction Persistence & Confirmation ==

alt All items ordered successfully

    OrderService -> DBUtil : provideConnection()
    DBUtil --> OrderService : Connection
    OrderService -> DB : INSERT INTO transactions\n(transid, username, time, amount)
    DB --> OrderService : addTransaction result (boolean)

    alt addTransaction succeeded

        OrderService -> UserService : getFName(userName)
        activate UserService
        UserService -> DBUtil : provideConnection()
        DBUtil --> UserService : Connection
        UserService -> DB : SELECT fname WHERE email = userName
        DB --> UserService : firstName
        UserService --> OrderService : firstName
        deactivate UserService

        OrderService -> MailMessage : transactionSuccess(userName, firstName, transId, transAmount)
        activate MailMessage
        note right of MailMessage : Builds HTML email body\nwith order confirmation details
        MailMessage -> JavaMailUtil : sendMail(recipient, "Order Placed at Ellison Electronics", htmlBody)
        activate JavaMailUtil
        JavaMailUtil -> SMTP : Transport.send(MimeMessage) via STARTTLS
        activate SMTP
        SMTP --> JavaMailUtil : (sent / MessagingException)
        deactivate SMTP
        JavaMailUtil --> MailMessage : (void / throws MessagingException)
        deactivate JavaMailUtil
        MailMessage --> OrderService : (void)
        deactivate MailMessage

        OrderService --> OrderServlet : "Order Placed Successfully!"

    else addTransaction failed
        OrderService --> OrderServlet : "Order Placement Failed!"
    end

else One or more items failed
    OrderService --> OrderServlet : "Order Placement Failed!"
end

deactivate OrderService

== Response Rendering ==

OrderServlet -> JSP : RequestDispatcher.include(request, response)
activate JSP
JSP --> OrderServlet : HTML page content
deactivate JSP

OrderServlet --> Customer : HTML page\n(inline JS injects status into #message element)
deactivate OrderServlet

@enduml
