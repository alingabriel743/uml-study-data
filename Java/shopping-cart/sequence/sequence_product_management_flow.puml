@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipant underline
skinparam sequenceLifeLineBorderColor #495057
skinparam sequenceLifeLineBackgroundColor #F8F9FA
skinparam sequenceBoxBorderColor #6C757D
skinparam sequenceBoxBackgroundColor #E9ECEF
skinparam sequenceGroupBorderColor #495057
skinparam sequenceGroupFontColor #212529
skinparam noteFontSize 11
skinparam noteBorderColor #6C757D
skinparam noteBackgroundColor #FFF9C4

title Admin Product Management Flow

actor "Admin (Browser)" as Admin

box "Servlet Layer" #E8F4FD
    participant "AddProductSrv" as AddSrv
    participant "UpdateProductSrv" as UpdateSrv
    participant "RemoveProductSrv" as RemoveSrv
    participant "ShowImage" as ShowImg
end box

box "Session / Request" #F0F4E8
    participant "HttpSession" as Session
end box

box "Service Layer" #FDF4E8
    participant "ProductServiceImpl" as ProductSvc
    participant "DemandServiceImpl" as DemandSvc
    participant "UserServiceImpl" as UserSvc
end box

box "Utility" #F4E8FD
    participant "IDUtil" as IDUtil
    participant "DBUtil" as DBUtil
    participant "MailMessage" as Mail
end box

database "Database" as DB

' ─────────────────────────────────────────────
' ADD PRODUCT
' ─────────────────────────────────────────────
== ADD PRODUCT ==

Admin -> AddSrv : POST /AddProductSrv\n(name, type, info, price, quantity, image)
activate AddSrv

AddSrv -> Session : getAttribute("usertype")
activate Session
Session --> AddSrv : "admin"
deactivate Session

alt usertype != "admin"
    AddSrv --> Admin : redirect → login.jsp
else usertype == "admin"

    AddSrv -> Session : getAttribute("username"), getAttribute("password")
    activate Session
    Session --> AddSrv : credentials
    deactivate Session

    AddSrv -> AddSrv : part.getInputStream() — extract image
    AddSrv -> ProductSvc : addProduct(name, type, info, price, qty, imageStream)
    activate ProductSvc

    ProductSvc -> IDUtil : generateId()
    activate IDUtil
    IDUtil --> ProductSvc : prodId (unique)
    deactivate IDUtil

    ProductSvc -> ProductSvc : new ProductBean(prodId, name, type, info, price, qty, image)
    ProductSvc -> DBUtil : provideConnection()
    activate DBUtil
    DBUtil --> ProductSvc : Connection
    deactivate DBUtil

    ProductSvc -> DB : INSERT INTO product\nVALUES(pid, pname, ptype, pinfo, pprice, pquantity, image)
    activate DB
    DB --> ProductSvc : rows affected (k)
    deactivate DB

    ProductSvc -> DBUtil : closeConnection(con), closeConnection(ps)
    ProductSvc --> AddSrv : status String ("Product Added Successfully" / error)
    deactivate ProductSvc

    AddSrv --> Admin : forward → addProduct.jsp?message=<status>
end

deactivate AddSrv

' ─────────────────────────────────────────────
' UPDATE PRODUCT (without image)
' ─────────────────────────────────────────────
== UPDATE PRODUCT ==

Admin -> UpdateSrv : POST /UpdateProductSrv\n(pid, name, type, info, price, quantity)
activate UpdateSrv

UpdateSrv -> Session : getAttribute("usertype")
activate Session
Session --> UpdateSrv : "admin"
deactivate Session

alt usertype != "admin"
    UpdateSrv --> Admin : redirect → login.jsp
else usertype == "admin"

    UpdateSrv -> UpdateSrv : new ProductBean(); set all fields
    UpdateSrv -> ProductSvc : updateProductWithoutImage(prodId, productBean)
    activate ProductSvc

    ProductSvc -> DBUtil : provideConnection()
    activate DBUtil
    DBUtil --> ProductSvc : Connection
    deactivate DBUtil

    ProductSvc -> DB : SELECT pquantity FROM product WHERE pid=?\n(getProductQuantity — prev qty)
    activate DB
    DB --> ProductSvc : prevQuantity
    deactivate DB

    ProductSvc -> DB : UPDATE product SET pname, ptype, pinfo,\npprice, pquantity WHERE pid=?
    activate DB
    DB --> ProductSvc : rows affected
    deactivate DB

    opt update success AND new quantity > prevQuantity
        note over ProductSvc : Restock detected — notify\ndemanding users via email

        ProductSvc -> DemandSvc : haveDemanded(prodId)
        activate DemandSvc
        DemandSvc --> ProductSvc : List<DemandBean>
        deactivate DemandSvc

        loop for each DemandBean
            ProductSvc -> UserSvc : getFName(demand.userName)
            activate UserSvc
            UserSvc --> ProductSvc : firstName
            deactivate UserSvc

            ProductSvc -> Mail : productAvailableNow(email, firstName, prodName, prodId)
            activate Mail
            Mail --> ProductSvc : email sent
            deactivate Mail

            ProductSvc -> DemandSvc : removeProduct(userName, prodId)
            activate DemandSvc
            DemandSvc --> ProductSvc : demand cleared
            deactivate DemandSvc
        end
    end

    ProductSvc -> DBUtil : closeConnection(con), closeConnection(ps)
    ProductSvc --> UpdateSrv : status String
    deactivate ProductSvc

    UpdateSrv --> Admin : forward → updateProduct.jsp?prodid=<id>&message=<status>
end

deactivate UpdateSrv

' ─────────────────────────────────────────────
' REMOVE PRODUCT
' ─────────────────────────────────────────────
== REMOVE PRODUCT ==

Admin -> RemoveSrv : POST /RemoveProductSrv (prodid)
activate RemoveSrv

RemoveSrv -> Session : getAttribute("usertype")
activate Session
Session --> RemoveSrv : "admin"
deactivate Session

alt usertype != "admin"
    RemoveSrv --> Admin : redirect → login.jsp
else usertype == "admin"

    RemoveSrv -> ProductSvc : removeProduct(prodId)
    activate ProductSvc

    ProductSvc -> DBUtil : provideConnection()
    activate DBUtil
    DBUtil --> ProductSvc : Connection
    deactivate DBUtil

    ProductSvc -> DB : DELETE FROM product WHERE pid=?
    activate DB
    DB --> ProductSvc : rows affected
    deactivate DB

    opt delete success
        ProductSvc -> DB : DELETE FROM usercart WHERE prodid=?\n(cascade cart cleanup)
        activate DB
        DB --> ProductSvc : rows affected
        deactivate DB
    end

    ProductSvc -> DBUtil : closeConnection(con),\ncloseConnection(ps), closeConnection(ps2)
    ProductSvc --> RemoveSrv : status String
    deactivate ProductSvc

    RemoveSrv --> Admin : forward → removeProduct.jsp?message=<status>
end

deactivate RemoveSrv

' ─────────────────────────────────────────────
' SHOW IMAGE
' ─────────────────────────────────────────────
== SHOW IMAGE ==

Admin -> ShowImg : GET /ShowImage?pid=<prodId>
activate ShowImg

ShowImg -> ProductSvc : getImage(prodId)
activate ProductSvc

ProductSvc -> DBUtil : provideConnection()
activate DBUtil
DBUtil --> ProductSvc : Connection
deactivate DBUtil

ProductSvc -> DB : SELECT image FROM product WHERE pid=?
activate DB
DB --> ProductSvc : byte[] imageData
deactivate DB

ProductSvc --> ShowImg : byte[] imageData
deactivate ProductSvc

alt imageData == null
    ShowImg -> ShowImg : ImageIO.read("images/noimage.jpg")\n(fallback from FileSystem)
end

ShowImg --> Admin : response.getOutputStream().write(imageBytes)
deactivate ShowImg

@enduml
