@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipant underline
skinparam sequenceBoxBackgroundColor #E9ECEF
skinparam sequenceBoxBorderColor #6C757D
skinparam sequenceLifeLineBorderColor #495057
skinparam sequenceGroupBackgroundColor #F1F3F5
skinparam sequenceGroupBorderColor #868E96
skinparam sequenceGroupFontColor #212529
skinparam sequenceGroupHeaderFontColor #212529
skinparam activationBorderColor #495057
skinparam activationBackgroundColor #DEE2E6
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F9A825

title User Login and Logout Flow

actor "User / Browser" as User

participant "LoginSrv\n@WebServlet(/LoginSrv)" as LoginSrv
participant "LogoutSrv\n@WebServlet(/LogoutSrv)" as LogoutSrv
participant "UserServiceImpl" as UserSvc
participant "DBUtil" as DBUtil
database "Database" as DB
participant "HttpSession" as Session
participant "UserBean" as UserBean

== LOGIN FLOW ==

User -> LoginSrv : GET /LoginSrv?username=&password=&usertype=
activate LoginSrv
note right of LoginSrv : doPost delegates to doGet

LoginSrv -> LoginSrv : getParameter("userName")\ngetParameter("password")\ngetParameter("usertype")

alt userType == "admin"

    LoginSrv -> LoginSrv : check hardcoded credentials\n(admin@gmail.com / admin)

    alt valid admin credentials
        LoginSrv -> Session : getSession()
        activate Session
        LoginSrv -> Session : setAttribute("username", userName)
        LoginSrv -> Session : setAttribute("password", password)
        LoginSrv -> Session : setAttribute("usertype", "admin")
        Session --> LoginSrv : session updated
        deactivate Session
        LoginSrv --> User : forward → adminViewProduct.jsp
    else invalid admin credentials
        LoginSrv --> User : include → login.jsp?message=Login Denied!
    end

else userType == "customer"

    LoginSrv -> UserSvc : new UserServiceImpl()
    activate UserSvc
    LoginSrv -> UserSvc : isValidCredential(userName, password)

    UserSvc -> DBUtil : provideConnection()
    activate DBUtil
    DBUtil --> UserSvc : Connection
    deactivate DBUtil

    UserSvc -> DB : SELECT * FROM user\nWHERE email=? AND password=?
    activate DB
    DB --> UserSvc : ResultSet
    deactivate DB

    UserSvc -> DBUtil : closeConnection(con, ps, rs)
    activate DBUtil
    DBUtil --> UserSvc : closed
    deactivate DBUtil

    UserSvc --> LoginSrv : "valid" | error message
    deactivate UserSvc

    alt status == "valid"

        LoginSrv -> UserSvc : getUserDetails(userName, password)
        activate UserSvc

        UserSvc -> DBUtil : provideConnection()
        activate DBUtil
        DBUtil --> UserSvc : Connection
        deactivate DBUtil

        UserSvc -> DB : SELECT * FROM user\nWHERE email=? AND password=?
        activate DB
        DB --> UserSvc : ResultSet
        deactivate DB

        UserSvc -> UserBean : new UserBean(name, mobile,\nemail, address, pinCode, password)
        activate UserBean
        UserBean --> UserSvc : UserBean populated
        deactivate UserBean

        UserSvc -> DBUtil : closeConnection(con, ps, rs)
        activate DBUtil
        DBUtil --> UserSvc : closed
        deactivate DBUtil

        UserSvc --> LoginSrv : UserBean
        deactivate UserSvc

        LoginSrv -> Session : getSession()
        activate Session
        LoginSrv -> Session : setAttribute("userdata", userBean)
        LoginSrv -> Session : setAttribute("username", userName)
        LoginSrv -> Session : setAttribute("password", password)
        LoginSrv -> Session : setAttribute("usertype", "customer")
        Session --> LoginSrv : session updated
        deactivate Session

        LoginSrv --> User : forward → userHome.jsp

    else status != "valid"
        LoginSrv --> User : forward → login.jsp?message=<error>
    end

end

deactivate LoginSrv

== LOGOUT FLOW ==

User -> LogoutSrv : GET /LogoutSrv
activate LogoutSrv
note right of LogoutSrv : doPost delegates to doGet

LogoutSrv -> Session : getSession()
activate Session

LogoutSrv -> Session : setAttribute("username", null)
LogoutSrv -> Session : setAttribute("password", null)
LogoutSrv -> Session : setAttribute("usertype", null)
LogoutSrv -> Session : setAttribute("userdata", null)

note over Session : Session attributes nullified\n(session.invalidate() NOT called)

Session --> LogoutSrv : session cleared
deactivate Session

LogoutSrv --> User : forward → login.jsp?message=Successfully Logged Out!
deactivate LogoutSrv

@enduml
