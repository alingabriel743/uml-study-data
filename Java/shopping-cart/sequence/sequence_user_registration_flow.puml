@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceGroupBorderColor #6C757D
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam sequenceLifeLineBorderColor #495057
skinparam sequenceActiveBorderColor #495057
skinparam sequenceActiveBackgroundColor #DEE2E6
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F0C040

title User Registration Flow

actor "User (Browser)" as User
participant "RegisterSrv\n<<HttpServlet>>" as RegisterSrv
participant "UserBean" as UserBean
participant "UserServiceImpl\n<<UserService>>" as UserServiceImpl
participant "DBUtil" as DBUtil
database "Database\n(user table)" as Database
participant "MailMessage" as MailMessage
participant "JavaMailUtil" as JavaMailUtil
participant "SMTP Server\n(smtp.gmail.com:587)" as SMTPServer

== Form Submission ==

User -> RegisterSrv : GET/POST /RegisterSrv\n(username, mobile, email, address, pincode, password, confirmPassword)
activate RegisterSrv

RegisterSrv -> RegisterSrv : validate: password == confirmPassword?

alt passwords do not match
    RegisterSrv --> User : forward register.jsp\n?message=Password not matching!
else passwords match

    == Build User Object ==

    RegisterSrv -> UserBean : new UserBean(userName, mobileNo, emailId,\naddress, pinCode, password)
    activate UserBean
    UserBean --> RegisterSrv : user
    deactivate UserBean

    RegisterSrv -> UserServiceImpl : new UserServiceImpl()
    activate UserServiceImpl

    == Register User ==

    RegisterSrv -> UserServiceImpl : registerUser(user): String
    note right of UserServiceImpl : Checks for duplicate email\nbefore inserting

    UserServiceImpl -> UserServiceImpl : isRegistered(user.getEmail()): boolean

    UserServiceImpl -> DBUtil : provideConnection(): Connection
    activate DBUtil
    DBUtil -> Database : DriverManager.getConnection\n(connectionString, username, password)
    activate Database
    Database --> DBUtil : Connection
    deactivate Database
    DBUtil --> UserServiceImpl : connection
    deactivate DBUtil

    UserServiceImpl -> Database : SELECT * FROM user WHERE email=?
    activate Database
    Database --> UserServiceImpl : ResultSet (exists or empty)
    deactivate Database

    UserServiceImpl -> DBUtil : closeConnection(con, ps, rs)

    alt email already registered
        UserServiceImpl --> RegisterSrv : "Email Id Already Registered!"
        RegisterSrv --> User : forward register.jsp\n?message=Email Id Already Registered!

    else email not yet registered

        == Insert New User ==

        UserServiceImpl -> DBUtil : provideConnection(): Connection
        activate DBUtil
        DBUtil -> Database : DriverManager.getConnection\n(connectionString, username, password)
        activate Database
        Database --> DBUtil : Connection
        deactivate Database
        DBUtil --> UserServiceImpl : connection
        deactivate DBUtil

        UserServiceImpl -> Database : INSERT INTO user VALUES\n(email, name, mobile, address, pincode, password)
        activate Database
        Database --> UserServiceImpl : rowsAffected (k)
        deactivate Database

        alt INSERT failed (k == 0)
            UserServiceImpl --> RegisterSrv : "User Registration Failed!"
            RegisterSrv --> User : forward register.jsp\n?message=User Registration Failed!

        else INSERT successful (k > 0)

            == Send Welcome Email ==

            UserServiceImpl -> MailMessage : registrationSuccess(user.getEmail(), firstName)
            note right of UserServiceImpl : firstName = user.getName().split(' ')[0]
            activate MailMessage

            MailMessage -> MailMessage : build HTML welcome email\n(promo code: ELLISON500, 10% OFF up to 500 Rs)

            MailMessage -> JavaMailUtil : sendMail(recipient, "Registration Successfull", htmlTextMessage)
            activate JavaMailUtil

            JavaMailUtil -> JavaMailUtil : configure SMTP props\n(smtp.gmail.com:587, STARTTLS)
            JavaMailUtil -> JavaMailUtil : load credentials from\nResourceBundle 'application'
            JavaMailUtil -> JavaMailUtil : Session.getInstance(properties, Authenticator)
            JavaMailUtil -> JavaMailUtil : prepareMessage(session, senderEmail,\nrecipient, subject, htmlTextMessage): MimeMessage

            JavaMailUtil -> SMTPServer : Transport.send(message)
            activate SMTPServer
            SMTPServer --> JavaMailUtil : delivery acknowledgement
            deactivate SMTPServer

            deactivate JavaMailUtil
            deactivate MailMessage

            UserServiceImpl -> DBUtil : closeConnection(ps)
            note right of DBUtil : Note: closeConnection(ps) called\ntwice here (duplicate — minor bug)
            UserServiceImpl -> DBUtil : closeConnection(ps)

            UserServiceImpl --> RegisterSrv : "User Registered Successfully!"
            deactivate UserServiceImpl

            RegisterSrv --> User : forward register.jsp\n?message=User Registered Successfully!
        end

    end

end

deactivate RegisterSrv

@enduml
