@startuml
title Ellison Electronics — Shopping Cart\nSystem Context Diagram

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actor {
    BackgroundColor<<Person>> #08427B
    FontColor<<Person>> #FFFFFF
    BorderColor<<Person>> #052E56
}

skinparam arrow {
    Color #424242
    FontSize 10
    FontColor #616161
}

' ── Actors ──────────────────────────────────────────────────────────────────
actor "Customer
[Browser / Mobile Web]" as customer <<Person>>

actor "Admin / Store Manager
[Browser Dashboard]" as admin <<Person>>

' ── Core System ─────────────────────────────────────────────────────────────
rectangle "**Ellison Electronics**
**Shopping Cart**
[Java EE · Servlet/JSP · Maven WAR]

E-commerce platform for browsing products,
managing a shopping cart, placing orders,
processing payments (demo), and tracking shipments.
Deployed on Apache Tomcat 8.0+." as system <<System>>

' ── Application Server ───────────────────────────────────────────────────────
rectangle "**Apache Tomcat**
[Servlet Container]

Hosts and routes HTTP requests
to Java Servlets & JSP views.
Manages HTTP sessions." as tomcat <<Infrastructure>>

' ── Data Stores ──────────────────────────────────────────────────────────────
rectangle "**MySQL Server**
[Relational Database]

Stores users, products, cart items,
orders, transactions, and
demand/out-of-stock records." as mysql <<Database>>

' ── External Services ────────────────────────────────────────────────────────
rectangle "**Gmail SMTP**
[smtp.gmail.com:587]

Transactional email delivery:
registration confirmation, order placed,
shipment / delivery update, stock alert." as gmail <<External>>

' ── Relationships ────────────────────────────────────────────────────────────
customer --> tomcat : "HTTP/HTTPS\n(Browse products, register,\nlogin, cart, checkout)"
admin --> tomcat : "HTTP/HTTPS\n(Manage products, view orders,\nmark shipment status)"

tomcat --> system : "In-process\n(Servlet dispatch /\nJSP rendering)"
system --> tomcat : "HTTP Response\n(HTML/JSP pages,\nredirects, images)"

system --> mysql : "JDBC (mysql-connector-java 8.0.33)\n(SELECT / INSERT / UPDATE / DELETE\nfor users, products, orders, cart)"

system --> gmail : "SMTP + STARTTLS\n(Jakarta Mail 2.x, port 587)\n(Send transactional emails:\nregistration, order, shipment,\nstock availability)"
gmail --> customer : "SMTP → INBOX\n(Order confirmation,\nshipment notification,\nstock alert email)"

@enduml
