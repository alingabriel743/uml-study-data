@startuml use_case_admin_product_management

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #1A3A5C
    FontStyle bold
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #FFF9E6
skinparam NoteBorderColor #D4A900

title Admin Product Management

left to right direction

actor "Admin" as Admin

rectangle "Admin Product Management System" {

    usecase "Validate Admin Session" as UC0
    note right of UC0
      Checks session: usertype=admin,
      username & password not null.
      Redirects to login.jsp on failure.
    end note

    usecase "Add Product" as UC1
    note bottom of UC1
      POST /AddProductSrv
      Stores name, type, info,
      price, quantity, image (BLOB).
      Auto-generates Product ID.
    end note

    usecase "Remove Product" as UC2
    note bottom of UC2
      POST /RemoveProductSrv
      DELETE from product table +
      cascade DELETE from usercart.
    end note

    usecase "Update Product" as UC3
    note bottom of UC3
      POST /UpdateProductSrv
      Updates name, type, info,
      price, quantity (no image swap).
    end note

    usecase "Update Product Price" as UC6
    note bottom of UC6
      ProductServiceImpl
      .updateProductPrice()
      UPDATE product SET pprice.
    end note

    usecase "View / Browse Products" as UC4
    note bottom of UC4
      adminViewProduct.jsp
      SELECT * FROM product
      → displays full catalogue.
    end note

    usecase "Notify Waiting Customers\non Restock" as UC5
    note right of UC5
      Triggered when updated quantity
      exceeds previous quantity.
      Queries user_demand → sends
      restock email → clears demand.
    end note

    usecase "Upload Product Image" as UC1a

}

' ── Actor associations ──────────────────────────────────────
Admin --> UC0
Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC6
Admin --> UC4
Admin --> UC1a

' ── Include: every admin action requires session validation ─
UC1 ..> UC0 : <<include>>
UC2 ..> UC0 : <<include>>
UC3 ..> UC0 : <<include>>
UC6 ..> UC0 : <<include>>
UC4 ..> UC0 : <<include>>

' ── Include: adding a product includes image upload ─────────
UC1 ..> UC1a : <<include>>

' ── Extend: restock notification extends product update ─────
UC5 .up.> UC3 : <<extend>>\n[quantity increased]

@enduml
