@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057

title Order Placement and Payment

left to right direction

actor "Customer" as Customer
actor "Admin" as Admin
actor "Email System\n(SMTP / JavaMailUtil)" as EmailSystem

rectangle "Order Placement and Payment" {

    usecase "Place Order /\nComplete Payment" as UC1
    usecase "Validate Customer Session" as UC_VS
    usecase "Receive Payment\nConfirmation Email" as UC3
    usecase "View Order History" as UC2

    usecase "Ship Order" as UC4
    usecase "Validate Admin Session" as UC_VAS
    usecase "Receive Shipment\nNotification Email" as UC5
    usecase "View All Orders" as UC6
    usecase "Look Up\nTransaction Owner" as UC7

}

' Customer associations
Customer --> UC1
Customer --> UC2
Customer --> UC3
Customer --> UC5

' Admin associations
Admin --> UC4
Admin --> UC6
Admin --> UC7

' Email System associations
EmailSystem --> UC3
EmailSystem --> UC5

' Include relationships
UC1 ..> UC_VS  : <<include>>
UC1 ..> UC3    : <<include>>
UC4 ..> UC_VAS : <<include>>
UC4 ..> UC5    : <<include>>

@enduml
