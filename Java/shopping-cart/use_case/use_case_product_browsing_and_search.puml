@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}

title Product Browsing and Search

left to right direction

actor "Customer\n(Authenticated)" as Customer
actor "Guest\n(Public)" as Guest

rectangle "Product Browsing and Search" {

    usecase "Browse All Products" as UC1
    note right of UC1
      GET userHome.jsp (no params)
      ProductServiceImpl.getAllProducts()
    end note

    usecase "Search Products\nby Keyword" as UC2
    note right of UC2
      GET userHome.jsp?search=<keyword>
      LIKE match on ptype, pname, pinfo
    end note

    usecase "Browse by\nCategory / Type" as UC3
    note right of UC3
      GET userHome.jsp?type=<category>
      Filtered by product type
    end note

    usecase "View Product Details" as UC5
    note right of UC5
      ProductServiceImpl.getProductDetails()
      Returns full ProductBean
    end note

    usecase "Send Fan /\nContact Message" as UC6
    note right of UC6
      POST /fansMessage
      Sends HTML email via MailMessage
    end note

}

' Actor → Use Case associations
Customer --> UC1
Customer --> UC2
Customer --> UC3
Customer --> UC5
Customer --> UC6

Guest --> UC1
Guest --> UC2
Guest --> UC3
Guest --> UC6

' Extend relationships — fallback to all products on empty results
UC2 ..> UC1 : <<extend>>\nempty results fallback
UC3 ..> UC1 : <<extend>>\nempty results fallback

@enduml
