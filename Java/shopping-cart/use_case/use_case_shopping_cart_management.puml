@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}

title Shopping Cart Management

left to right direction

actor "Customer" as Customer

rectangle "Shopping Cart Management" {

    usecase "Add Product to Cart" as UC_Add
    usecase "Update Cart Quantity" as UC_Update
    usecase "Remove Product from Cart" as UC_Remove
    usecase "Remove Single Product Entry" as UC_RemoveSingle
    usecase "View Cart Items" as UC_View
    usecase "Get Cart Count" as UC_Count

    usecase "Validate Customer Session" as UC_Session
    usecase "Check Product Availability" as UC_Availability
    usecase "Register Demand for\nOut-of-Stock Product" as UC_Demand

}

' Customer associations
Customer --> UC_Add
Customer --> UC_Update
Customer --> UC_Remove
Customer --> UC_RemoveSingle
Customer --> UC_View
Customer --> UC_Count

' <<include>> relationships
UC_Add ..> UC_Session : <<include>>
UC_Add ..> UC_Availability : <<include>>
UC_Update ..> UC_Session : <<include>>
UC_Update ..> UC_Availability : <<include>>

' <<extend>> relationships
UC_Demand ..> UC_Add : <<extend>>
UC_Demand ..> UC_Update : <<extend>>

note right of UC_Demand
  Triggered when requested
  quantity exceeds available
  stock. Records demand and
  notifies customer by email
  when restocked.
end note

note bottom of UC_Remove
  Decrements quantity by 1;
  deletes cart entry when
  quantity reaches 0.
end note

@enduml
