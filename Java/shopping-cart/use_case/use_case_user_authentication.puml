@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C7BE5
    FontColor #1A1A2E
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title User Authentication

left to right direction

actor "Customer" as customer
actor "Admin" as admin

rectangle "User Authentication System\n(Servlet-based)" {

    usecase "Register" as UC_REGISTER
    usecase "Login" as UC_LOGIN
    usecase "Logout" as UC_LOGOUT

    usecase "Validate Password Match" as UC_VALIDATE_PASS
    usecase "Check Email Already Registered\n(isRegistered)" as UC_CHECK_EMAIL
    usecase "Send Registration Email\n(MailMessage.registrationSuccess)" as UC_SEND_EMAIL

    usecase "Validate Credentials\n(isValidCredential)" as UC_VALIDATE_CRED
    usecase "Get User Details\n(getUserDetails)" as UC_USER_DETAILS

    usecase "Admin Login\n(Hardcoded Credential Bypass)" as UC_ADMIN_LOGIN
}

' --- Primary actor associations ---
customer --> UC_REGISTER
customer --> UC_LOGIN
customer --> UC_LOGOUT

admin --> UC_LOGIN

' --- Include relationships ---
UC_REGISTER ..> UC_VALIDATE_PASS    : <<include>>
UC_REGISTER ..> UC_CHECK_EMAIL      : <<include>>
UC_REGISTER ..> UC_SEND_EMAIL       : <<include>>

UC_LOGIN ..> UC_VALIDATE_CRED       : <<include>>
UC_LOGIN ..> UC_USER_DETAILS        : <<include>>

' --- Extend relationships ---
UC_ADMIN_LOGIN .up.> UC_LOGIN       : <<extend>>

' --- Admin directly initiates Admin Login ---
admin --> UC_ADMIN_LOGIN

note bottom of UC_ADMIN_LOGIN
  Hardcoded check:
  admin@gmail.com / admin
  Bypasses UserServiceImpl entirely.
  Forwards to adminViewProduct.jsp
end note

note right of UC_REGISTER
  /RegisterSrv
  Delegates to UserServiceImpl.registerUser()
  Stores user in DB via JDBC (plain-text password)
end note

note right of UC_LOGIN
  /LoginSrv
  Populates HttpSession:
  username, password, usertype, userdata (UserBean)
end note

note right of UC_LOGOUT
  /LogoutSrv
  Clears all HttpSession attributes
  Forwards to login.jsp
end note

@enduml
