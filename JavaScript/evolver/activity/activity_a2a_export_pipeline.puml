@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
}

skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title A2A Export Pipeline\n<size:11>(scripts/a2a_export.js — main())</size>

|CLI / main()|
start

:Parse CLI arguments\n--json, --protocol, --hello\n--persist, --include-events;

|Asset Store|
fork
  :loadCapsules()\n→ Capsule[];
fork again
  :loadGenes()\n→ Gene[];
fork again
  :readAllEvents()\n→ Event[];
end fork

|A2A Filter|
:exportEligibleCapsules\n({capsules, events});
:exportEligibleGenes\n({genes});
:Merge eligible assets\neligible = eligibleCapsules\n.concat(eligibleGenes);

if (--include-events flag set?) then (yes)
  :Filter events:\nisAllowedA2AAsset(e)\n&& e.type === 'EvolutionEvent';
  :Enrich events:\nset schema_version = SCHEMA_VERSION\nset asset_id = computeAssetId(ev)\n(if missing);
  :Append to eligible:\neligible = eligible\n.concat(eligibleEvents);
else (no)
  :Skip event inclusion;
endif

|CLI / main()|
if (--hello OR --protocol flag set?) then (yes)
  :buildHello\n({geneCount, capsuleCount});

  |Output|
  :Write hello JSON\nto stdout;

  |CLI / main()|
  if (--persist?) then (yes)
    |Output|
    :getTransport().send(hello)\n[errors swallowed];
  else (no)
  endif
else (no)
endif

|CLI / main()|
if (--protocol flag set?) then (yes)
  |A2A Filter|
  :FOR EACH eligible asset;

  |Output|
  :buildPublish({asset});
  :Write publish JSON\nto stdout;

  |CLI / main()|
  if (--persist?) then (yes)
    |Output|
    :getTransport().send(msg)\n[errors swallowed];
  else (no)
  endif

  |CLI / main()|
  :Return\n(exit pipeline early);
  stop
else (no)
endif

if (--json flag set?) then (yes)
  |Output|
  :JSON.stringify(eligible, null, 2)\nWrite pretty-printed JSON array\nto stdout;
  |CLI / main()|
  :Return;
  stop
else (no)
  |Output|
  :FOR EACH eligible asset\nWrite JSON.stringify(asset)\nto stdout (NDJSON);
endif

|CLI / main()|
stop

note right
  <b>Error Boundary</b>
  Top-level try/catch wraps main()
  Errors written to stderr
  process.exit(1)
end note

@enduml
