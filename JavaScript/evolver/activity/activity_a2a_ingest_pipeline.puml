@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}
skinparam note {
    BackgroundColor #E8F4FD
    BorderColor #3498DB
}

title A2A Ingest Pipeline\n<size:11><i>Ingesting agent-to-agent payloads: validation, transformation, storage, and acknowledgment</i></size>

|#E3F2FD|Orchestrator (main)|
start

:Wrap execution in top-level try/catch\n(exit code 1 on uncaught error);

:Resolve CLI args\n(optional --inputPath);

:Read environment variables\n**A2A_SOURCE**, **A2A_EXTERNAL_CONFIDENCE_FACTOR**\n**A2A_EMIT_DECISIONS**, **A2A_SIGNALS**;

if (inputPath provided?) then (yes)
    |#E8F5E9|a2a (Parser / Filter)|
    :a2a.readTextIfExists(inputPath);
else (no)
    |Orchestrator (main)|
    :readStdin()\nfs.readFileSync(0, 'utf8');
endif

|a2a (Parser / Filter)|
:a2a.parseA2AInput(text)\n→ parsed[] array of objects;

|Orchestrator (main)|
:parseSignalsFromEnv(A2A_SIGNALS)\nJSON.parse → fallback to comma-split\n→ signals[];

note right
  **Counters initialised:**
  accepted = 0
  rejected = 0
end note

:Begin loop over each parsed object **obj**;

|a2a (Parser / Filter)|
if (a2a.isAllowedA2AAsset(obj)?) then (allowed)
else (skip)
    |Orchestrator (main)|
    :Skip object\n(continue loop);
    note right: Object not permitted\nby asset allowlist
    stop
endif

|Orchestrator (main)|
if (obj.asset_id present\nand is string?) then (yes)
    |#FFF8E1|contentHash (Integrity)|
    :contentHash.verifyAssetId(obj);
    if (Integrity check passes?) then (pass)
    else (fail)
        |Orchestrator (main)|
        :rejected++;
        if (A2A_EMIT_DECISIONS === 'true'?) then (yes)
            |#FCE4EC|a2aProto (Protocol)|
            :a2aProto.buildDecision(\n  decision: 'reject',\n  reason: 'asset_id integrity check failed'\n);
            :a2aProto.getTransport().send(dm);
            note right: Errors swallowed
        else (no)
        endif
        |Orchestrator (main)|
        :Continue to next object;
        stop
    endif
else (no asset_id)
endif

|a2a (Parser / Filter)|
:a2a.lowerConfidence(obj, {source, factor})\n→ staged;

note right
  **factor** = A2A_EXTERNAL_CONFIDENCE_FACTOR
  (default: 0.6)
end note

if (staged is truthy?) then (yes)
else (falsy / skip)
    |Orchestrator (main)|
    :Skip object\n(continue loop);
    stop
endif

|#EDE7F6|assetStore (Storage)|
:assetStore.appendExternalCandidateJsonl(staged)\n→ JSONL written to external candidate store;

|#E0F7FA|memGraph (Graph)|
:memGraph.recordExternalCandidate(\n  {asset: staged, source, signals}\n);

note right
  Errors are **swallowed**
  (try/catch no-op)
end note

|Orchestrator (main)|
if (A2A_EMIT_DECISIONS === 'true'?) then (yes)
    |a2aProto (Protocol)|
    :a2aProto.buildDecision(\n  decision: 'quarantine',\n  reason: 'staged as external candidate'\n);
    :a2aProto.getTransport().send(dm2);
    note right: Errors are **swallowed**\n(try/catch no-op)
else (no)
endif

|Orchestrator (main)|
:accepted++;

:More objects in parsed[]?;

note right
  Loop back for next object
end note

:Write summary to stdout\n**"accepted=N rejected=M"**;

stop

@enduml
