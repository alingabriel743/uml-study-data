@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleFontColor #212529
    TitleBackgroundColor #E9ECEF
}

title ATP Service Publish & Update\n<size:11><color:#6C757D>src/atp/serviceHelper.js  →  POST {hubUrl}/a2a/service/{publish|update}</color></size>

|#D6EAF8|Caller|
start

if (Operation?) then (Publish New Service)
  :publishService(svc)\n<size:10>{ title, description, capabilities, use_cases,\npricePerTask, executionMode, maxConcurrent, recipeId }</size>;
else (Update Existing Service)
  :updateService(listingId, updates)\n<size:10>{ listingId: string, updates: arbitrary fields object }</size>;
endif

|#D5F5E3|serviceHelper|

:getHubUrl()\n<size:10>via a2aProtocol — trailing slashes stripped</size>;

if (hubUrl present?) then (no)
  #FADBD8:Return\n{ ok: false,\n  error: "no_hub_url" };
  detach
else (yes)
endif

:getNodeId()  →  nodeId\n<size:10>via a2aProtocol</size>;
:Read HTTP_TRANSPORT_TIMEOUT_MS\n<size:10>from config module</size>;

if (Operation?) then (Publish)
  :Set endpoint:\nhubUrl + "/a2a/service/publish";
  :Build publish request body\n<size:10>{\n  sender_id: nodeId,\n  title,  description,  capabilities,  use_cases,\n  price_per_task: Math.max(1, Math.round(pricePerTask || 10)),\n  execution_mode: executionMode || "exclusive",\n  max_concurrent: Math.max(1, Math.round(maxConcurrent || 3)),\n  recipe_id\n}</size>;
else (Update)
  :Set endpoint:\nhubUrl + "/a2a/service/update";
  :Build update request body\n<size:10>{\n  sender_id: nodeId,\n  listing_id: listingId,\n  ...updates   ← spread of arbitrary update fields\n}</size>;
endif

:buildHubHeaders()  →  headers\n<size:10>via a2aProtocol (auth + content-type)</size>;

:POST fetch(endpoint,\n<size:10>{ method: "POST", headers,\n  body: JSON.stringify(body),\n  signal: AbortSignal.timeout(timeout) }</size>);

|#E8DAEF|ATP Hub Registry|

:Receive HTTP POST request;
:Process service registration\nor update in registry;
:Return HTTP response;

|serviceHelper|

if (Network / timeout\nerror thrown?) then (yes — catch)
  #FADBD8:Return\n{ ok: false,\n  error: err.message };
  detach
else (no — response received)
endif

if (res.ok?) then (no — non-2xx HTTP status)
  :Read res.text()\n<size:10>capture body for error context</size>;
  #FADBD8:Return\n{ ok: false,\n  status: res.status,\n  error: text.slice(0, 400) };
  detach
else (yes — HTTP 2xx)
endif

:Parse res.json()  →  data;
#C8E6C9:Return\n{ ok: true, data };

|Caller|
:Receive result\n<size:10>Promise<{ ok, data?, error?, status? }></size>;
stop

@enduml
