@startuml activity_direct_message_flow

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
}

skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Direct Message (DM) Flow

|Caller|
start

:Choose DM operation;

|Caller|
if (Which operation?) then (Send DM)

    |Caller|
    :Invoke DmHandler.send()\n{ recipientNodeId, content, metadata };

    |DmHandler|
    if (recipientNodeId provided?) then (no)
        :Throw Error:\n"recipientNodeId is required";
        |Caller|
        :Handle Error;
        stop
    else (yes)
    endif

    if (content provided?) then (no)
        :Throw Error:\n"content is required";
        |Caller|
        :Handle Error;
        stop
    else (yes)
    endif

    :Default metadata to {} if not supplied;
    :Stamp sent_at = new Date().toISOString();
    :Build store payload\n{ type: 'dm', recipient_node_id,\n  content, metadata, sent_at,\n  priority: 'normal' };

    |store|
    :store.send(payload);
    :Enqueue DM message;
    :Return send result;

    |Caller|
    :Receive send confirmation;

elseif (Which operation?) then (Poll for DMs)

    |Caller|
    :Invoke DmHandler.poll({ limit? });

    |DmHandler|
    :Default limit to 20 if not provided;
    :Build query\n{ type: 'dm', limit };

    |store|
    :store.poll(query);
    :Fetch up to <limit> pending DMs\nof type 'dm';
    :Return array of pending DM messages;

    |Caller|
    :Receive pending DM messages;

elseif (Which operation?) then (Acknowledge DMs)

    |Caller|
    :Invoke DmHandler.ack(messageIds);

    |DmHandler|
    :Pass messageIds to store.ack();

    |store|
    :store.ack(messageIds);
    :Mark messages as read/acknowledged;
    :Return acknowledgement confirmation;

    |Caller|
    :Receive acknowledgement result;

else (List DM History)

    |Caller|
    :Invoke DmHandler.list({ limit?, offset? });

    |DmHandler|
    :Default limit to 20 if not provided;
    :Default offset to 0 if not provided;
    :Build query\n{ type: 'dm', limit, offset };

    |store|
    :store.list(query);
    :Fetch paginated DM history\n(type='dm', with limit + offset);
    :Return paginated DM records;

    |Caller|
    :Receive DM history page;

endif

|Caller|
stop

@enduml
