@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontStyle bold
}
skinparam note {
    BackgroundColor #E8F4FD
    BorderColor #5B9BD5
    FontColor #212529
}

title GEP Event Appending\n<size:10>scripts/gep_append_event.js  →  src/gep/assetStore.js</size>

|CLI Script|
start
:Parse CLI arguments\n(process.argv.slice(2));

if (File path argument\npresent?) then (yes)
  :readTextIfExists(inputPath)\nfs.readFileSync(path, 'utf8')\nReturns '' on missing file or error;
else (no)
  :readStdin()\nfs.readFileSync(fd=0, 'utf8')\nReturns '' on read error;
endif

|Input Parser|
:parseInput(rawText)\nTrim raw string;

if (Raw text is empty?) then (yes)
  :Return empty array [];
  |CLI Script|
  :No events to process;
  :Write "appended=0" to stdout;
  stop
else (no)
endif

:Attempt JSON.parse(rawText);

if (JSON.parse\nsucceeds?) then (yes)
  if (Result\nis Array?) then (yes)
    :Use parsed array as-is;
  else (no - Object)
    :Wrap single object in [ ] array;
  endif
else (no - SyntaxError)
  :Split text by newline characters;
  :Parse each line individually as JSONL\n(silently skip lines that fail to parse);
  :Collect all successfully parsed objects;
endif

:Produce items[] — array of candidate events;

|CLI Script|
:Initialize appended = 0;

repeat
  :Take next item from items[];

  |EvolutionEvent Validator|
  :isValidEvolutionEvent(item):
  Validate ev.type === 'EvolutionEvent';
  :Validate ev.id, ev.intent, ev.mutation_id\nare non-empty strings;
  :Validate ev.parent\nis null or string;
  :Validate ev.signals and ev.genes_used\nare Arrays;
  :Validate ev.personality_state\n(type='PersonalityState', fields rigor /\ncreativity / verbosity / risk_tolerance /\nobedience are finite numbers in [0, 1]);
  :Validate ev.blast_radius\n(finite numeric .files and .lines);
  :Validate ev.outcome\n(.status non-empty string, .score ∈ [0, 1]);

  if (ev.capsule_id\nfield present?) then (yes)
    :Validate capsule_id is null or string;
  else (no)
  endif

  if (All validation\nchecks passed?) then (yes)

    |Asset Store|
    :appendEventJsonl(eventObj);
    :getGepAssetsDir()\nResolve absolute GEP assets directory path;
    :ensureDir(gepAssetsDir)\nfs.mkdirSync(dir, { recursive: true })\nif directory does not yet exist;
    :eventsPath()\npath.join(gepAssetsDir, 'events.jsonl');
    :fs.appendFileSync(eventsPath,\nJSON.stringify(eventObj) + '\n', 'utf8')\nAtomically append one JSON line;

    |CLI Script|
    :appended += 1;

  else (no - invalid event)

    |CLI Script|
    :Skip item — silently continue\n(no error raised);

  endif

repeat while (More items\nin list?) is (yes)
-> (no);

:process.stdout.write\n('appended=' + appended + '\n');
stop

note
  **Top-Level Error Handler (wraps main())**
  catch(e):
    → process.stderr.write(e.message)
    → process.exit(1)
end note

@enduml
