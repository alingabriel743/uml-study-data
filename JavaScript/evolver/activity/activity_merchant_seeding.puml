@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Merchant Seeding\n<size:11><i>scripts/seed-merchants.js → merchantAgent → a2aProtocol → serviceHelper → hubClient</i></size>

|Script (seed-merchants.js)|
start

:Read environment variable\n**A2A_HUB_URL** or **EVOMAP_HUB_URL**;

if (Hub URL present?) then (no)
    :Log error: missing hub URL;
    :process.exit(1);
    stop
else (yes)
endif

:Log hub URL and\nservice count (3 SEED_SERVICES);

|merchantAgent|
if (Agent already running?\n(_running == true)) then (yes)
    :Skip start — return immediately;
    stop
else (no)
endif

:Set **_running = true**;

|a2aProtocol|
:sendHelloToHub()\n→ POST /a2a/hello;

if (hello.ok?) then (no)
    :Log error: registration failed;
    :Set _running = false;
    :Return (abort start);
    stop
else (yes)
endif

:Log registered node ID\nvia getNodeId();

|serviceHelper|
fork
    :publishService("Code Review Agent")\n→ POST /a2a/service/publish\n<size:10>capabilities: code_review, javascript, python, typescript\npricePerTask: $5 | maxConcurrent: 5</size>;
    if (result.ok?) then (yes)
        :Log "Published service:\nCode Review Agent";
    else (no)
        :Warn "Failed to publish:\nCode Review Agent";
    endif
fork again
    :publishService("Translation Agent")\n→ POST /a2a/service/publish\n<size:10>capabilities: translation, english, chinese, japanese\npricePerTask: $3 | maxConcurrent: 10</size>;
    if (result.ok?) then (yes)
        :Log "Published service:\nTranslation Agent";
    else (no)
        :Warn "Failed to publish:\nTranslation Agent";
    endif
fork again
    :publishService("Text Summarization Agent")\n→ POST /a2a/service/publish\n<size:10>capabilities: summarization, text_analysis, report, digest\npricePerTask: $2 | maxConcurrent: 10</size>;
    if (result.ok?) then (yes)
        :Log "Published service:\nText Summarization Agent";
    else (no)
        :Warn "Failed to publish:\nText Summarization Agent";
    endif
end fork

|a2aProtocol|
:startHeartbeat();

|Script (seed-merchants.js)|
:Log "[Seed] Merchant started.\nPolling for orders.";
:Register SIGINT + SIGTERM handlers\n→ merchantAgent.stop() + process.exit(0);
:Set poll interval every **30,000 ms**;

repeat
    |a2aProtocol|
    :consumeAvailableWork()\n(poll tick);

    if (Work available?) then (no)
        :Skip this poll tick\n(no work found);
    else (yes)
        |Script (seed-merchants.js)|
        :Iterate over each order\nin available work;

        :handleOrder(order);

        if (title / signals includes\n'review' or 'code_review'?) then (yes)
            :Return **code review result**\n<size:10>{ result, output, pass_rate: 1.0,\nprocessed_at: ISO timestamp }</size>;
        elseif (title / signals includes\n'translat' or 'translation'?) then (yes)
            :Return **translation result**\n<size:10>{ result, output, pass_rate: 1.0,\nprocessed_at: ISO timestamp }</size>;
        else (no match)
            :Return **summarization result**\n<size:10>{ result, output, pass_rate: 1.0,\nprocessed_at: ISO timestamp }</size>;
        endif

        if (proofPayload present\nAND atp_order_id present?) then (yes)
            |hubClient|
            :submitDelivery(orderId, proofPayload)\n→ POST /a2a/atp/deliver;

            if (delivery.ok?) then (yes)
                :Log "Delivered order: <id>";
            else (no)
                :Warn "Delivery failed: <error>";
            endif
        else (no)
            |Script (seed-merchants.js)|
            :Skip delivery submission;
        endif
    endif

repeat while (SIGINT / SIGTERM received?) is (no)
-> yes;

|merchantAgent|
:merchantAgent.stop()\n→ Set _running = false\n→ clearInterval(_pollInterval)\n→ stopHeartbeat()\n→ Log "[ATP-Merchant] Stopped";

|Script (seed-merchants.js)|
:process.exit(0);

stop

@enduml
