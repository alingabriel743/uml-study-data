@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}

title Recovery Loop\n<size:11><color:#6C757D>Two-layer fault recovery: outer supervisor (recover_loop.js) + inner daemon (index.js)</color></size>

|#D1ECF1|Outer Supervisor\n(recover_loop.js)|
start

:Read EVOLVER_RECOVER_WAIT_MS\n<size:10><color:#6C757D>default: 10 000 ms</color></size>;

:sleepMs(waitMs)\n<size:10><color:#6C757D>Synchronous — spawnSync('sleep', [ceil(ms/1000)])</color></size>;

:resolveWorkspaceRoot()\n<size:10><color:#6C757D>→ process.cwd()</color></size>;

:resolveEvolverEntry(workspaceRoot)\n<size:10><color:#6C757D>tries skills/evolver/index.js\nthen skills/capability-evolver/index.js</color></size>;

if (Evolver entry found?) then (no)
    #FFCCCC:console.error("entry not found")\nprocess.exit(2);
    kill
else (yes)
    :spawnSync(node, [entry, '--loop'])\n<size:10><color:#6C757D>Blocking — inherits stdio</color></size>;

    :process.exit(child.status ?? 1);
    kill
endif

|#D4EDDA|Inner Daemon\n(index.js --loop)|

start

:Setup timestamp-prefixed console logging\n<size:10><color:#6C757D>ts() prefix on log / warn / error</color></size>;

:acquireLock()\n<size:10><color:#6C757D>write evolver.pid with flag: wx (exclusive)</color></size>;

if (Lock acquired?) then (EEXIST — another instance)
    if (Is existing PID alive?) then (yes)
        #FFCCCC:log "Another instance running"\nprocess.exit(0);
        kill
    else (no — stale PID)
        :log "Taking over stale lock"\nOverwrite evolver.pid;
    endif
else (acquired)
endif

fork
    :Register SIGINT / SIGTERM handlers\n<size:10><color:#6C757D>→ releaseLock() + stopEventStream() + exit(0)</color></size>;
fork again
    :Register uncaughtException handler\n<size:10><color:#6C757D>→ releaseLock() + exit(1)</color></size>;
fork again
    :Register unhandledRejection counter\n<size:10><color:#6C757D>count ≥ 5 → releaseLock() + exit(1)</color></size>;
end fork

:Set ENV: EVOLVE_LOOP=true\nDefault EVOLVE_BRIDGE='false';

:Parse config from env vars\n<size:10><color:#6C757D>minSleepMs=2000 · maxSleepMs=300000\nidleThresholdMs=500 · pendingSleepMs=120000\nmaxCyclesPerProcess=100 · maxRssMb=500</color></size>;

fork
    :a2aProtocol.startHeartbeat()\n<size:10><color:#6C757D>or mailboxTransport if A2A_TRANSPORT=mailbox</color></size>;
fork again
    :startEventStream();
end fork

:merchantAgent.start()\n<size:10><color:#6C757D>if atpMode=auto|on and hubUrl set</color></size>;

:Init cycleCount=0\ncurrentSleepMs=minSleepMs\nomlsMultiplier=1;

repeat

    :cycleCount++;

    group #FFF8E7 Pending-Solidify Gate
        :readJsonSafe(evolution_solidify_state.json)\n→ solidifyState;

        if (isPendingSolidify(solidifyState)?\n<size:10>last_run.run_id exists AND\nrun_ids differ from last_solidify</size>) then (yes)
            #FFF3CD:await sleepMs(max(pendingSleepMs, minSleepMs))\n<size:10><color:#856404>STALL — wait for external solidify decision</color></size>;
            backward: skip evolution cycle;
        else (no)
        endif
    end group

    group #EAF4FB Evolution Cycle
        :t0 = Date.now(); ok = false;

        if (await evolve.run()) then (throws error)
            #FFCCCC:console.error(evolveError)\n<size:10>ok stays false</size>;
        else (success)
            :ok = true;
            if (EVOLVE_BRIDGE = 'false'?) then (yes)
                :Re-read solidifyState;
                if (isPendingSolidify?) then (yes)
                    :rejectPendingRun(statePath)\n<size:10><color:#6C757D>Set last_solidify.rejected=true\nreason='loop_bridge_disabled_autoreject'\nAtomic write via tmp+rename</color></size>;
                else (no)
                endif
            else (no)
            endif
        endif

        :dt = Date.now() - t0;
    end group

    group #F0FFF0 Adaptive Sleep
        if (!ok OR dt < idleThresholdMs (500ms)?) then (yes — idle/failed)
            :currentSleepMs = min(maxSleepMs,\nmax(minSleepMs, currentSleepMs × 2))\n<size:10><color:#6C757D>Exponential backoff</color></size>;
        else (no — active)
            :currentSleepMs = minSleepMs\n<size:10><color:#6C757D>Reset to minimum</color></size>;
        endif
    end group

    group #F5F0FF OMLS Idle Scheduling
        :getScheduleRecommendation();
        if (schedule.enabled AND sleep_multiplier > 0?) then (yes)
            :omlsMultiplier = schedule.sleep_multiplier;
            if (should_distill?) then (yes)
                :shouldDF() → autoDF()\n<size:10><color:#6C757D>Failure distillation</color></size>;
            else (no)
            endif
            if (should_explore?) then (yes)
                :tryExplore([], schedule, repoRoot)\n<size:10><color:#6C757D>Idle exploration</color></size>;
            else (no)
            endif
        else (no)
        endif
    end group

    group #FFF0F0 Suicide / Self-Restart Check
        if (suicideEnabled?) then (yes)
            :memMb = RSS / 1024 / 1024;
            if (cycleCount ≥ maxCyclesPerProcess(100)\nOR memMb > maxRssMb(500)?) then (yes)
                if (spawn detached child\n(node index.js --loop)) then (success)
                    :child.unref()\nreleaseLock()\nprocess.exit(0);
                    kill
                else (spawn error)
                    #FFCCCC:log spawn error\ncontinue current process;
                endif
            else (no)
            endif
        else (no — disabled)
        endif
    end group

    group #F8F8F8 Saturation Multiplier
        if (signals includes 'force_steady_state'?) then (yes)
            :saturationMultiplier = 4;
        elseif (signals includes 'evolution_saturation'?) then (yes)
            :saturationMultiplier = 2;
        else (no signal)
            :saturationMultiplier = 1;
        endif
    end group

    group #EAF4FB Final Sleep
        :jitter = random(0..249) ms\ntotalSleepMs = max(minSleepMs,\n  (currentSleepMs + jitter)\n  × saturationMultiplier\n  × omlsMultiplier);
        :await sleepMs(totalSleepMs);
    end group

repeat while (while(true) — loop continues) is (next cycle)
->outer error caught: log loopErr + sleep max(minSleepMs\, 10000) + continue;

stop

@enduml
