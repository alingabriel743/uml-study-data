@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #EAF4FB
skinparam NoteBorderColor #5B9BD5

title Session Creation & Joining

|Agent / Client|
|routes.js (HTTP Layer)|
|SessionHandler|
|store (Mailbox)|

' ══════════════════════════════════════════════════
'  FLOW A — CREATE SESSION
' ══════════════════════════════════════════════════

|Agent / Client|
start
:Call **POST /session/create**\n{title, description,\n invite_node_ids, max_participants};

|routes.js (HTTP Layer)|
if (title missing?) then (yes)
    :Return **HTTP 400**\n"title is required";
    stop
else (no)
endif

if (sessionHandler\navailable?) then (yes)

    |SessionHandler|
    :**createSession()**\n{title, description,\n inviteNodeIds, maxParticipants};

    if (title truthy?) then (no)
        :throw Error\n"title is required";
        stop
    else (yes)
    endif

    :Sanitize inviteNodeIds\n→ slice to max 10 items;
    :Sanitize maxParticipants\n→ clamp to [2 .. 20], default 5;
    :Stamp **created_at**\n= new Date().toISOString();

    |store (Mailbox)|
    :store.send({\n  type: 'session_create',\n  payload: {title, description,\n    invite_node_ids,\n    max_participants, created_at},\n  priority: **'high'**\n});
    :Return result to SessionHandler;

    |SessionHandler|
    :Return store result\nto route;

else (no)

    |store (Mailbox)|
    :store.send({\n  type: 'session_create',\n  payload: {title, description,\n    invite_node_ids,\n    max_participants}\n}) directly;
    :Return result to route;

endif

|routes.js (HTTP Layer)|
:Respond **{body: result}**;

' ══════════════════════════════════════════════════
'  FLOW B — JOIN SESSION
' ══════════════════════════════════════════════════

|Agent / Client|
:Call **POST /session/join**\n{session_id};

|routes.js (HTTP Layer)|
if (session_id missing?) then (yes)
    :Return **HTTP 400**\n"session_id is required";
    stop
else (no)
endif

if (sessionHandler\navailable?) then (yes)

    |SessionHandler|
    :**joinSession({sessionId})**;

    if (sessionId truthy?) then (no)
        :throw Error\n"sessionId is required";
        stop
    else (yes)
    endif

    :Stamp **joined_at**\n= new Date().toISOString();

    |store (Mailbox)|
    :store.send({\n  type: 'session_join',\n  payload: {session_id, joined_at},\n  priority: **'normal'**\n});
    :Return result to SessionHandler;

    |SessionHandler|
    :Return store result\nto route;

else (no)

    |store (Mailbox)|
    :store.send({\n  type: 'session_join',\n  payload: {session_id}\n}) directly;
    :Return result to route;

endif

|routes.js (HTTP Layer)|
:Respond **{body: result}**;

' ══════════════════════════════════════════════════
'  FLOW C — LEAVE SESSION (lifecycle completion)
' ══════════════════════════════════════════════════

|Agent / Client|
:Call **POST /session/leave**\n{session_id};

|routes.js (HTTP Layer)|
if (session_id missing?) then (yes)
    :Return **HTTP 400**\n"session_id is required";
    stop
else (no)
endif

if (sessionHandler\navailable?) then (yes)

    |SessionHandler|
    :**leaveSession({sessionId})**;
    :Stamp **left_at**\n= new Date().toISOString();

    |store (Mailbox)|
    :store.send({\n  type: 'session_leave',\n  payload: {session_id, left_at},\n  priority: **'normal'**\n});
    :Return result to SessionHandler;

    |SessionHandler|
    :Return store result\nto route;

else (no)

    |store (Mailbox)|
    :store.send({\n  type: 'session_leave',\n  payload: {session_id}\n}) directly;
    :Return result to route;

endif

|routes.js (HTTP Layer)|
:Respond **{body: result}**;

|Agent / Client|
stop

@enduml
