@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activityBackgroundColor #F8F9FA
skinparam activityBorderColor #495057
skinparam activityArrowColor #495057
skinparam activityFontColor #212529
skinparam swimlaneBorderColor #6C757D
skinparam swimlaneTitleFontColor #212529
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F9A825

title Session Polling & Event Handling

|#E3F2FD|Client / Caller|
|#E8F5E9|routes.js|
|#FFF3E0|SessionHandler|
|#FCE4EC|MailboxStore|

start

' ══════════════════════════════════════
'  FLOW 1 — Poll Session Invites
' ══════════════════════════════════════

|Client / Caller|
#E3F2FD:POST /session/invites/poll\n{ body.limit? };

|routes.js|
:Extract body.limit\n(optional request parameter);

if (sessionHandler\navailable?) then (yes)
  :Delegate to\nsessionHandler.pollInvites({ limit });
  |SessionHandler|
  :Resolve effective limit\n(limit || **10**)\ntype = **collaboration_invite**;
  |MailboxStore|
  :store.poll({\n  type: 'collaboration_invite',\n  limit\n});
  :Return invite messages array;
  |routes.js|
else (no — fallback)
  |MailboxStore|
  :store.poll({\n  type: 'collaboration_invite',\n  limit: body.limit || **10**\n});
  :Return invite messages array;
  |routes.js|
endif

:Build response:\n{ messages, count: messages.length };

|Client / Caller|
:Receive collaboration\ninvite messages;

' ══════════════════════════════════════
'  FLOW 2 — Poll Session Events  (no HTTP route — programmatic only)
' ══════════════════════════════════════

:Call sessionHandler\n.pollSessionEvents({ limit? });

note right
  No HTTP route registered.
  Called programmatically
  by internal components.
end note

|SessionHandler|
:Resolve effective limit\n(limit || **20**)\ntype = **session_event**;

|MailboxStore|
:store.poll({\n  type: 'session_event',\n  limit\n});
:Return session events array;

|Client / Caller|
:Receive session event messages;

' ══════════════════════════════════════
'  FLOW 3 — List Active Sessions
' ══════════════════════════════════════

:GET /session/list\n{ query.limit? };

|routes.js|
:Extract query.limit\n(optional query parameter);

if (sessionHandler\navailable?) then (yes)
  :Delegate to\nsessionHandler.listActiveSessions();
  |SessionHandler|
  :Prepare fixed query:\n  type = **session_create**\n  direction = **outbound**\n  limit = **50**;
  |MailboxStore|
  :store.list({\n  type: 'session_create',\n  direction: 'outbound',\n  limit: 50\n});
  :Return outbound\nsession_create messages;
  |routes.js|
else (no — fallback)
  |MailboxStore|
  :store.list({\n  type: 'session_create',\n  direction: 'outbound',\n  limit: query.limit || **20**\n});
  :Return outbound\nsession_create messages;
  |routes.js|
endif

:Build response:\n{ sessions, count: sessions.length };

|Client / Caller|
:Receive active sessions list;

stop

@enduml
