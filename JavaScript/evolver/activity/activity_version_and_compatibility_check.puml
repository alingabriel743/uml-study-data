@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
    StartColor #495057
    EndColor #495057
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Version Suggestion & Wrapper Compatibility Check

|suggest_version.js|
start

:Read **package.json**\nextract baseVersion (semver);

:getBaseReleaseCommit()\ngit log --grep='chore(release): prepare v';

if (baseCommit found?) then (yes)
    :getCommitSubjectsSince(baseCommit)\ngit log <baseCommit>..HEAD --pretty=%s;
else (no)
    :getCommitSubjectsSince(null)\ngit log -n 30 --pretty=%s;
endif

:Collect subjects[];

:inferBumpFromSubjects(subjects);

if (BREAKING CHANGE or '!:' in subjects?) then (yes)
    :bump = **major**\nreason: breaking change marker;
elseif ('^feat:' match in subjects?) then (yes)
    :bump = **minor**\nreason: feature commit detected;
elseif ('^fix:|^perf:' match in subjects?) then (yes)
    :bump = **patch**\nreason: fix/perf commit detected;
elseif (subjects empty?) then (yes)
    :bump = **none**\nreason: no commits since base release;
else (default)
    :bump = **patch**\nreason: default for non-breaking changes;
endif

if (bump == 'none'?) then (yes)
    :suggestedVersion = baseVersion (unchanged);
else (no)
    if (bump == 'major'?) then (yes)
        :suggestedVersion = (major+1).0.0;
    elseif (bump == 'minor'?) then (yes)
        :suggestedVersion = major.(minor+1).0;
    else (patch)
        :suggestedVersion = major.minor.(patch+1);
    endif
endif

:ensureDir(memory/)\nWrite memory/semver_suggestion.json\n{baseVersion, baseCommit, subjects, decision, suggestedVersion};

:Print JSON result to stdout;

|check_wrapper_compat.js|

:Parse CLI arguments;

if (--diff flag present?) then (yes)
    :getChangedFiles()\ngit diff --name-only HEAD~1 → changedFiles[];
    :Filter INTERFACE_CONTRACT\nto entries in changedFiles;
    if (filtered contracts empty?) then (yes)
        :Print "No wrapper-affecting\nfiles changed.";
        end
    else (no)
        :Use filtered contract list\n(subset of 6 entries);
    endif
else (no)
    :Use full INTERFACE_CONTRACT\n(6 interface entries);
endif

fork
    :checkInterface(src/ops/self_repair.js)\nexport: repair();
fork again
    :checkInterface(src/ops/commentary.js)\nexport: getComment();
fork again
    :checkInterface(src/ops/cleanup.js)\nexport: run();
fork again
    :checkInterface(src/ops/skills_monitor.js)\nexport: run();
fork again
    :checkInterface(src/ops/health_check.js)\nexport: runHealthCheck();
fork again
    :checkInterface(src/gep/bridge.js)\nexport: renderSessionsSpawnCall();
end fork

note right
  Per interface:
  • File missing → MISSING
  • require() throws → ERROR
  • Export not a function → BROKEN
  • All exports OK → OK
end note

:Print results per file\n[OK] or [!!] prefix;

if (any MISSING / BROKEN / ERROR?) then (yes)
    :Print "<N> interface(s) broken.\nfeishu-evolver-wrapper needs update.";
    :Exit code **1** (failure);
    end
else (no)
    :Print "All <N> interface(s) compatible.";
    :Exit code **0** (success);
    end
endif

@enduml
