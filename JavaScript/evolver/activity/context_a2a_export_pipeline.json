{
  "scope": "a2a_export_pipeline",
  "title": "A2A Export Pipeline",
  "diagram_type": "activity",
  "description": "Exporting agent-to-agent records: querying, serializing, and writing output",
  "entry_point": "main() in scripts/a2a_export.js",

  "activity_steps": [
    "START",
    "Parse CLI args: --json, --protocol, --hello, --persist, --include-events",
    "Load data: loadCapsules(), loadGenes(), readAllEvents()",
    "Filter eligible assets: exportEligibleCapsules({capsules, events})",
    "Filter eligible genes: exportEligibleGenes({genes})",
    "Merge: eligible = eligibleCapsules.concat(eligibleGenes)",
    "[Decision] --include-events flag set?",
    "  YES → Filter events: isAllowedA2AAsset(e) && e.type === 'EvolutionEvent'",
    "       → Enrich events: set schema_version = SCHEMA_VERSION if missing",
    "       → Enrich events: set asset_id = computeAssetId(ev) if missing",
    "       → eligible = eligible.concat(eligibleEvents)",
    "  NO  → skip event inclusion",
    "[Decision] --hello OR --protocol flag set?",
    "  YES → buildHello({geneCount, capsuleCount})",
    "       → write hello JSON to stdout",
    "       → [Decision] --persist? → getTransport().send(hello) [swallow errors]",
    "[Decision] --protocol flag set?",
    "  YES → FOR EACH eligible asset:",
    "           → buildPublish({asset})",
    "           → write publish JSON to stdout",
    "           → [Decision] --persist? → getTransport().send(msg) [swallow errors]",
    "        → RETURN (exit pipeline)",
    "[Decision] --json flag set?",
    "  YES → write JSON.stringify(eligible, null, 2) to stdout → RETURN",
    "  NO  → FOR EACH eligible asset: write JSON.stringify(asset) to stdout (NDJSON)",
    "END",
    "[Error boundary] catch(e) → write error to stderr → process.exit(1)"
  ],

  "decision_points": [
    {"condition": "--include-events", "true_path": "filter+enrich EvolutionEvents, append to eligible", "false_path": "skip"},
    {"condition": "--hello OR --protocol", "true_path": "emit HELLO handshake message", "false_path": "skip"},
    {"condition": "--persist (inside hello block)", "true_path": "getTransport().send(hello)", "false_path": "skip"},
    {"condition": "--protocol", "true_path": "emit PUBLISH per asset, optional persist, then return", "false_path": "continue"},
    {"condition": "--persist (inside protocol loop)", "true_path": "getTransport().send(msg)", "false_path": "skip"},
    {"condition": "--json", "true_path": "pretty-print JSON array to stdout, return", "false_path": "NDJSON line-per-asset to stdout"}
  ],

  "output_modes": [
    {"flag": "--protocol", "format": "NDJSON: hello msg + one publish msg per asset; optional transport.send()"},
    {"flag": "--json", "format": "Pretty-printed JSON array to stdout"},
    {"flag": "(default)", "format": "NDJSON: one JSON line per asset to stdout"}
  ],

  "key_functions": [
    "loadCapsules() → Capsule[]",
    "loadGenes() → Gene[]",
    "readAllEvents() → Event[]",
    "exportEligibleCapsules({capsules, events}) → Capsule[]",
    "exportEligibleGenes({genes}) → Gene[]",
    "isAllowedA2AAsset(asset) → boolean",
    "computeAssetId(asset) → string (may throw, swallowed)",
    "buildHello({geneCount, capsuleCount}) → HelloMessage",
    "buildPublish({asset}) → PublishMessage",
    "getTransport().send(msg) → void (may throw, swallowed)"
  ],

  "dependencies": [
    "assetStore: loadGenes, loadCapsules, readAllEvents",
    "a2a: exportEligibleCapsules, exportEligibleGenes, isAllowedA2AAsset",
    "a2aProtocol: buildPublish, buildHello, getTransport",
    "contentHash: computeAssetId, SCHEMA_VERSION"
  ],

  "error_handling": "Top-level try/catch wraps main(); errors written to stderr, process exits with code 1. Inner persist calls also swallow errors silently.",

  "important_notes": "Pipeline always loads all three asset types (capsules, genes, events) upfront. Events are opt-in via --include-events and must pass isAllowedA2AAsset + type=EvolutionEvent. --protocol mode short-circuits before --json check. --hello alone (without --protocol) emits only the hello message then falls through to default NDJSON output.",

  "source_files_analyzed": ["scripts/a2a_export.js"]
}
