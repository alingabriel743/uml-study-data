{
  "scope": "merchant_seeding",
  "title": "Merchant Seeding",
  "diagram_type": "activity",
  "description": "Seeding the system with merchant data: loading config, creating records, and confirming persistence",

  "entry_point": "main() in scripts/seed-merchants.js",

  "activities": [
    "START",
    "Read env: A2A_HUB_URL or EVOMAP_HUB_URL",
    "[No hub URL] → log error + process.exit(1)",
    "Log hub URL and service count (3 SEED_SERVICES)",
    "Call merchantAgent.start({ services, onOrder: handleOrder, pollMs: 30000 })",
    "  [Already running] → skip, return",
    "  Set _running = true",
    "  Call sendHelloToHub() → POST /a2a/hello",
    "  [hello.ok == false] → log error, _running = false, return",
    "  Log registered node ID via getNodeId()",
    "  FOR EACH service in SEED_SERVICES:",
    "    Call publishService(svc) → POST /a2a/service/publish",
    "    [result.ok] → log 'Published service: <title>'",
    "    [result.ok == false] → warn 'Failed to publish: <title>'",
    "  END FOR",
    "  Call startHeartbeat()",
    "  Set pollInterval every 30000ms:",
    "    Call consumeAvailableWork() from a2aProtocol",
    "    [no work] → return (skip iteration)",
    "    FOR EACH order in work:",
    "      Call handleOrder(order):",
    "        [title/signals includes 'review' or 'code_review'] → return code review result",
    "        [title/signals includes 'translat' or 'translation'] → return translation result",
    "        [else] → return summarization result",
    "        Return { result, output, pass_rate: 1.0, processed_at: ISO timestamp }",
    "      [proofPayload && order.atp_order_id] → Call submitDelivery(orderId, proofPayload) → POST /a2a/atp/deliver",
    "        [delivery.ok] → log 'Delivered order: <id>'",
    "        [delivery.ok == false] → warn 'Delivery failed: <error>'",
    "    END FOR",
    "  END INTERVAL",
    "Log '[Seed] Merchant started. Polling for orders.'",
    "Register SIGINT handler → merchantAgent.stop() + process.exit(0)",
    "Register SIGTERM handler → merchantAgent.stop() + process.exit(0)",
    "WAIT (event loop active)",
    "[SIGINT / SIGTERM received]",
    "  Call merchantAgent.stop():",
    "    _running = false",
    "    clearInterval(_pollInterval)",
    "    Call stopHeartbeat()",
    "    Log '[ATP-Merchant] Stopped'",
    "  process.exit(0)",
    "END"
  ],

  "decision_points": [
    "hubUrl present? → continue : exit(1)",
    "merchantAgent._running? → skip start : proceed",
    "hello.ok? → continue : abort start",
    "publishService result.ok? → log success : log warning",
    "work available? → process orders : skip poll tick",
    "order matches 'review'? → code review result",
    "order matches 'translat'? → translation result",
    "else → summarization result",
    "proofPayload && atp_order_id present? → submitDelivery : skip",
    "delivery.ok? → log success : log warning",
    "SIGINT/SIGTERM received? → stop + exit"
  ],

  "seed_data": [
    { "title": "Code Review Agent", "capabilities": ["code_review","javascript","python","typescript","bug_detection"], "pricePerTask": 5, "maxConcurrent": 5 },
    { "title": "Translation Agent", "capabilities": ["translation","english","chinese","japanese","localization"], "pricePerTask": 3, "maxConcurrent": 10 },
    { "title": "Text Summarization Agent", "capabilities": ["summarization","text_analysis","report","digest"], "pricePerTask": 2, "maxConcurrent": 10 }
  ],

  "key_calls": [
    "sendHelloToHub() → a2aProtocol → POST /a2a/hello",
    "publishService(svc) → serviceHelper → POST /a2a/service/publish",
    "startHeartbeat() → a2aProtocol",
    "consumeAvailableWork() → a2aProtocol (poll tick)",
    "handleOrder(order) → local function returning proof payload",
    "submitDelivery(orderId, proofPayload) → hubClient → POST /a2a/atp/deliver",
    "merchantAgent.stop() → clearInterval + stopHeartbeat()"
  ],

  "modules": [
    "scripts/seed-merchants.js — entry point, defines SEED_SERVICES + handleOrder, calls main()",
    "src/atp/merchantAgent.js — start()/stop()/isRunning()/getStatus()",
    "src/atp/serviceHelper.js — publishService() → POST /a2a/service/publish",
    "src/atp/hubClient.js — submitDelivery(), getMerchantTier(), listProofs()",
    "src/gep/a2aProtocol.js — sendHelloToHub(), getNodeId(), startHeartbeat(), stopHeartbeat(), consumeAvailableWork()"
  ],

  "important_notes": "Script is a one-time bootstrap run (node scripts/seed-merchants.js). Requires A2A_HUB_URL env var. Registers 3 services via marketplace API, then enters polling loop (30s) consuming and fulfilling orders until SIGINT/SIGTERM. handleOrder dispatches by title/signals keywords; always returns pass_rate=1.0.",

  "source_files_analyzed": [
    "scripts/seed-merchants.js",
    "src/atp/merchantAgent.js",
    "src/atp/serviceHelper.js",
    "src/atp/hubClient.js",
    "src/atp/index.js"
  ]
}
