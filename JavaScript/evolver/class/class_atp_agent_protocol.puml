@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title ATP Agent Protocol\nAgent-to-agent trading protocol (src/atp)

' ─────────────────────────────────────────
'  ATP Modules
' ─────────────────────────────────────────
package "src/atp" {

    class AtpIndex <<barrel>> {
        .. re-exports ..
        +consumerAgent
        +merchantAgent
        +hubClient
        +serviceHelper
        +defaultHandler
    }

    class ConsumerAgent <<singleton>> {
        -_initialized: boolean
        --
        +orderService(opts: OrderOptions): Promise<ApiResponse>
        +confirmDelivery(orderId: string): Promise<ApiResponse>
        +requestAiJudge(orderId: string): Promise<ApiResponse>
        +settle(orderId: string): Promise<ApiResponse>
        +dispute(orderId: string, reason: string): Promise<ApiResponse>
        +checkOrder(orderId: string): Promise<ApiResponse>
        +getPolicy(): Promise<ApiResponse>
        +orderAndWait(opts: OrderAndWaitOptions): Promise<ApiResponse>
        -ensureInitialized(): Promise<void>
    }

    class MerchantAgent <<singleton>> {
        -_running: boolean
        -_pollInterval: Interval
        ~DEFAULT_POLL_MS: 30000
        --
        +start(opts: StartOptions): Promise<void>
        +stop(): void
        +isRunning(): boolean
        +getStatus(): Promise<object>
    }

    class HubClient <<singleton>> {
        --
        +placeOrder(opts: OrderOptions): Promise<ApiResponse>
        +submitDelivery(orderId: string, proof: ProofPayload): Promise<ApiResponse>
        +verifyDelivery(orderId: string, action: string): Promise<ApiResponse>
        +settleOrder(orderId: string): Promise<ApiResponse>
        +disputeOrder(orderId: string, reason: string): Promise<ApiResponse>
        +getMerchantTier(nodeId?: string): Promise<ApiResponse>
        +getOrderStatus(orderId: string): Promise<ApiResponse>
        +listProofs(opts?: object): Promise<ApiResponse>
        +getAtpPolicy(): Promise<ApiResponse>
        -_hubPost(path: string, body: object, timeoutMs?: number): Promise<ApiResponse>
        -_hubGet(path: string, timeoutMs?: number): Promise<ApiResponse>
    }

    class ServiceHelper <<singleton>> {
        --
        +publishService(svc: ServiceListing): Promise<ApiResponse>
        +updateService(listingId: string, updates: object): Promise<ApiResponse>
    }

    class DefaultHandler <<utility>> {
        .. reads env vars ..
        ~EVOLVER_ATP_SERVICES
        ~EVOLVER_AGENT_NAME
        ~EVOLVER_MODEL_NAME
        ~EVOLVER_ATP
        --
        +defaultOrderHandler(order: object): ProofPayload
        +resolveAtpServices(): object[]
        +getAtpMode(): "on" | "off" | "auto"
    }
}

' ─────────────────────────────────────────
'  External Dependency
' ─────────────────────────────────────────
package "src/gep" {
    class A2aProtocol <<external>> {
        --
        +getNodeId(): string
        +sendHelloToHub(): Promise<void>
        +buildHubHeaders(): object
        +getHubUrl(): string
        +startHeartbeat(): void
        +stopHeartbeat(): void
        +consumeAvailableWork(): object[]
    }
}

' ─────────────────────────────────────────
'  Data Types
' ─────────────────────────────────────────
package "Data Types" {
    class OrderOptions <<datatype>> {
        +capabilities: string[]
        +budget: number
        +routingMode: "fastest" | "cheapest" | "auction" | "swarm"
        +verifyMode: "auto" | "ai_judge" | "bilateral"
        +question?: string
        +signals?: string[]
        +minReputation?: number
    }

    class ProofPayload <<datatype>> {
        +result: string
        +output: string
        +pass_rate: number
        +processed_at: ISO8601
        +processor: string
    }

    class ServiceListing <<datatype>> {
        +title: string
        +description?: string
        +capabilities?: string[]
        +useCases?: string[]
        +pricePerTask: number
        +executionMode: "exclusive" | "open" | "swarm"
        +maxConcurrent: number
        +recipeId?: string
    }

    class ApiResponse <<datatype>> {
        +ok: boolean
        +data?: object
        +status?: number
        +error?: string
    }
}

' ─────────────────────────────────────────
'  Barrel Aggregation
' ─────────────────────────────────────────
AtpIndex o-- ConsumerAgent  : aggregates
AtpIndex o-- MerchantAgent  : aggregates
AtpIndex o-- HubClient      : aggregates
AtpIndex o-- ServiceHelper  : aggregates
AtpIndex o-- DefaultHandler : aggregates

' ─────────────────────────────────────────
'  Module Dependencies
' ─────────────────────────────────────────
ConsumerAgent ..> HubClient     : uses (placeOrder,\nverifyDelivery, settleOrder,\ndisputeOrder, getOrderStatus,\ngetAtpPolicy)
ConsumerAgent ..> A2aProtocol   : uses (getNodeId,\nsendHelloToHub)

MerchantAgent ..> ServiceHelper : uses (publishService)
MerchantAgent ..> HubClient     : uses (submitDelivery,\ngetMerchantTier, listProofs)
MerchantAgent ..> A2aProtocol   : uses (getNodeId, sendHelloToHub,\nstartHeartbeat, stopHeartbeat,\nconsumeAvailableWork)

ServiceHelper ..> A2aProtocol   : uses (getNodeId,\nbuildHubHeaders, getHubUrl)
HubClient     ..> A2aProtocol   : uses (getHubUrl,\nbuildHubHeaders, getNodeId)

' ─────────────────────────────────────────
'  Data-type usage
' ─────────────────────────────────────────
ConsumerAgent  ..> OrderOptions   : <<parameter>>
ConsumerAgent  ..> ApiResponse    : <<returns>>
MerchantAgent  ..> ProofPayload   : <<submits>>
HubClient      ..> OrderOptions   : <<parameter>>
HubClient      ..> ProofPayload   : <<parameter>>
HubClient      ..> ApiResponse    : <<returns>>
ServiceHelper  ..> ServiceListing : <<parameter>>
DefaultHandler ..> ProofPayload   : <<returns>>

note bottom of DefaultHandler
  Purely functional — no HTTP calls.
  Falls back to built-in capability set:
  code_evolution / bug_fix /
  code_review / refactoring
end note

note right of HubClient
  Sole HTTP layer for all ATP endpoints.
  Routes: POST /a2a/atp/order, /deliver,
  /verify, /settle, /dispute
  GET  /a2a/atp/merchant/tier,
       /a2a/atp/order/:id, /proofs, /policy
end note

@enduml
