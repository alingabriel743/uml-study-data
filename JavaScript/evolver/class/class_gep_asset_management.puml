@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title GEP Asset Management

package "src/gep — Modules" {

    class AssetStore <<module>> {
        -{static} FAILED_CAPSULES_MAX: number = 200
        -{static} FAILED_CAPSULES_TRIM_TO: number = 100
        --
        -ensureDir(dir): void
        -readJsonIfExists(filePath, fallback): any
        -writeJsonAtomic(filePath, obj): void
        -ensureSchemaFields(obj): obj
        ..path helpers..
        -genesPath(): string
        -capsulesPath(): string
        -capsulesJsonlPath(): string
        -eventsPath(): string
        -candidatesPath(): string
        -failedCapsulesPath(): string
        ..public API..
        +loadGenes(): Gene[]
        +loadCapsules(): Capsule[]
        +readAllEvents(): EventRecord[]
        +getLastEventId(): string | null
        +appendEventJsonl(eventObj): void
        +appendCandidateJsonl(candidateObj): void
        +appendExternalCandidateJsonl(obj): void
        +readRecentCandidates(limit): object[]
        +readRecentExternalCandidates(limit): object[]
        +upsertGene(geneObj): void
        +appendCapsule(capsuleObj): void
        +upsertCapsule(capsuleObj): void
        +appendFailedCapsule(capsuleObj): void
        +readRecentFailedCapsules(limit): object[]
        +ensureAssetFiles(): void
        +buildValidationCmd(relModules: string[]): string
    }

    class AssetCallLog <<module>> {
        ..public API..
        +logAssetCall(entry: AssetCallEntry): void
        +readCallLog(opts?): AssetCallEntry[]
        +summarizeCallLog(opts?): CallLogSummary
        +getLogPath(): string
    }

    class Assets <<module>> {
        ..public API..
        +formatAssetPreview(preview: any): string
        +normalizeAsset(asset: object): object
    }

    class ContentHash <<module>> {
        -{static} SCHEMA_VERSION: string = "1.6.0"
        --
        +computeContentHash(obj, excludeFields?): string
        +computeAssetId(obj, excludeFields?): string
        +verifyAssetId(asset): boolean
    }

    class IntegrityCheck <<module>> {
        -{static} _cachedResult: boolean | null
        -{static} _violationFlag: boolean
        --
        +checkIntegrity(forceRecheck?): boolean
        +wasViolated(): boolean
        +waitForIntegrityDelay(): Promise<void>
        +wrapIfViolated(result): object | null
    }

}

package "Data Structures" {

    class Gene <<data>> {
        +type: string = "Gene"
        +id: string
        +category: string
        +signals_match: string[]
        +preconditions: string[]
        +strategy: string[]
        +constraints: Constraints
        +validation: string[]
        +anti_patterns?: string[]
        +schema_version?: string
        +asset_id?: string
    }

    class Capsule <<data>> {
        +type: string = "Capsule"
        +id: string
        +schema_version?: string
        +asset_id?: string
    }

    class AssetCallEntry <<data>> {
        +timestamp: string
        +run_id: string
        +action: string
        +asset_id?: string
        +asset_type?: string
        +source_node_id?: string
        +chain_id?: string
        +score?: number
        +mode?: string
        +signals?: string[]
        +reason?: string
        +extra?: object
    }

    class CallLogSummary <<data>> {
        +total_entries: number
        +unique_assets: number
        +unique_runs: number
        +by_action: Record<string, number>
        +entries: AssetCallEntry[]
    }

}

' ─── Relationships ───────────────────────────────────────────

' AssetStore depends on ContentHash for ID computation and schema version
AssetStore ..> ContentHash : uses\ncomputeAssetId / SCHEMA_VERSION

' Assets depends on ContentHash for normalisation
Assets ..> ContentHash : uses\nnormalizeAsset → computeAssetId

' AssetStore manages domain objects
AssetStore "1" o-- "0..*" Gene        : manages
AssetStore "1" o-- "0..*" Capsule     : manages

' AssetCallLog manages call entries and produces summaries
AssetCallLog "1" o-- "0..*" AssetCallEntry  : manages
AssetCallLog ..> CallLogSummary              : produces

' CallLogSummary aggregates entries
CallLogSummary *-- AssetCallEntry : aggregates

' External crypto dependency (Node built-in)
note bottom of ContentHash
  Uses Node:crypto (SHA256)
  Object keys sorted before hashing.
  Code is obfuscated (RC4-like cipher).
end note

note bottom of IntegrityCheck
  Anti-tamper guard: verifies SHA256
  hashes of project files against a
  registry. Result is cached; exposes
  violation flag, delay & wrap helpers.
  Code is obfuscated (RC4-like cipher).
end note

note right of AssetStore
  Dual storage per collection:
  • .json  — primary (atomic writes via .tmp → rename)
  • .jsonl — append-only (merged on load; JSONL wins by id)
  failed_capsules.json trimmed to 100 when size > 200.
  Tail-read optimisation for candidates files > 1 MB.
end note

@enduml
