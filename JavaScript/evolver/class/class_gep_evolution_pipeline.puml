@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title GEP Evolution Pipeline

' ─────────────────────────────────────────────
'  DATA TYPES
' ─────────────────────────────────────────────
package "GEP Data Types" {

    class Gene <<entity>> {
        +id: string
        +category: string
        +signals_match: string[]
        +strategy: string[]
        +validation: string[]
        +constraints: object
        +summary: string
        +anti_patterns: object[]
        +learning_history: object[]
        +a2a: any
    }

    class Capsule <<entity>> {
        +id: string
        +gene: string
        +trigger: string[]
        +summary: string
        +confidence: float
        +outcome: object
        +failure_reason: string
        +blast_radius: any
        +success_streak: number
        +a2a: any
    }

    class Mutation <<entity>> {
        +id: string
        +category: repair|optimize|innovate
        +trigger_signals: string[]
        +target: string
        +expected_effect: string
        +risk_level: low|medium|high
        +rationale: string
    }

    class StrategyPreset <<entity>> {
        +name: string
        +repair: float
        +optimize: float
        +innovate: float
        +explore: float
        +repairLoopThreshold: number
        +label: string
        +description: string
    }

    class Candidate <<entity>> {
        +id: string
        +type: string
        +source: string
        +tags: string[]
        +gene: any
        +score: number
    }

    class PersonalityState <<entity>> {
        +rigor: float
        +risk_tolerance: float
        +creativity: float
    }
}

' ─────────────────────────────────────────────
'  CORE PIPELINE MODULES
' ─────────────────────────────────────────────
package "GEP Core Modules" {

    class StrategyModule <<module>> {
        +resolveStrategy(signals): StrategyPreset
        +getStrategyNames(): string[]
        +STRATEGIES: Record<string, StrategyPreset>
        --
        ' Presets: balanced, innovate, harden,
        ' repair-only, early-stabilize, steady-state
        ' Priority: env-var → signals → default
    }

    class CandidatesModule <<module>> {
        +extractCapabilityCandidates(opts): Candidate[]
        +expandSignals(signals, transcript): string[]
        +renderCandidatesPreview(candidates, limit): string
        --
        ' Derives structured tags from weak signals
        ' Builds candidates from failed capsules
        ' e.g. "problem:performance", "action:optimize"
    }

    class CandidateEvalModule <<module>> {
        +generateCandidatesPreview(opts): EvalResult
        --
        ' Calls extractCapabilityCandidates()
        ' Scores external candidates via matchPatternToSignals()
        ' Filters/sorts by score, returns preview + new candidates
    }

    class SelectorModule <<module>> {
        +selectGene(genes, signals, opts): SelectionResult
        +selectCapsule(capsules, signals): Capsule
        +selectGeneAndCapsule(opts): GeneSelectionResult
        +computeDriftIntensity(opts): float
        +matchPatternToSignals(pattern, signals): boolean
        --
        ' Memory-based score multipliers (preferredGeneId)
        ' Drift = 1/sqrt(genePoolSize) + offset (0.3→0.02)
        ' Supports "baseName:snippet" signal matching
    }

    class MutationModule <<module>> {
        +buildMutation(opts): Mutation
        +isValidMutation(m): boolean
        +normalizeMutation(m): Mutation
        +isHighRiskMutationAllowed(personalityState): boolean
        +isHighRiskPersonality(personalityState): boolean
        +clamp01(n): float
        --
        ' error signals → "repair"
        ' feature_request (no errors) → "innovate"
        ' high-risk personality → downgrades to "optimize"
    }

    class SolidifyModule <<module>> {
        +solidify(opts): void
        +computeProcessScores(opts): ProcessScores
        +classifyFailureMode(opts): FailureMode
        +adaptGeneFromLearning(opts): void
        +buildSoftFailureLearningSignals(opts): string[]
        +readStateForSolidify(statePath): State
        --
        ' On success: appends learning signals to gene
        ' On failure: records anti_patterns
        ' Writes evolution_solidify_state.json
    }
}

' ─────────────────────────────────────────────
'  SUPPORTING MODULES
' ─────────────────────────────────────────────
package "GEP Supporting Modules" {

    class AssetStore <<module>> {
        +readRecentCandidates(): Candidate[]
        +readRecentExternalCandidates(): Candidate[]
        +readRecentFailedCapsules(): Capsule[]
        +appendCandidateJsonl(candidate): void
        +upsertGene(gene): void
        +appendCapsule(capsule): void
        +appendFailedCapsule(capsule): void
        --
        ' JSONL / JSON file I/O for genes,
        ' capsules, candidates, events
    }

    class PolicyCheck <<module>> {
        +checkConstraints(opts): ConstraintResult
        +classifyBlastSeverity(opts): BlastSeverity
        +buildFailureReason(opts): string
        --
        ' Constraint checking, blast radius analysis,
        ' validation command allowlist
    }

    class GitOps <<module>> {
        +normalizeRelPath(path): string
        +isCriticalProtectedPath(path): boolean
        --
        ' Git diff operations
        ' Critical path protection
    }

    class LlmReview <<module>> {
        +buildReviewPrompt(opts): string
        +runLlmReview(prompt): ReviewResult
        --
        ' LLM-based diff review
    }
}

' ─────────────────────────────────────────────
'  PIPELINE FLOW (step 1 → 8)
' ─────────────────────────────────────────────

' Step 1 — Strategy resolution
StrategyModule ..> StrategyPreset : «produces»

' Step 2–3 — Candidate generation & storage
CandidatesModule ..> Candidate : «produces»
CandidatesModule ..> SelectorModule : uses matchPatternToSignals()

CandidateEvalModule ..> CandidatesModule : calls extractCapabilityCandidates()\nrenderCandidatesPreview()
CandidateEvalModule ..> AssetStore : reads failed capsules\n& recent candidates
CandidateEvalModule ..> SelectorModule : uses matchPatternToSignals()

' Step 4 — Gene & capsule selection
SelectorModule ..> Gene : «selects»
SelectorModule ..> Capsule : «selects»
SelectorModule ..> AssetStore : reads Gene[]\n& Capsule[]

' Step 5 — Mutation building
MutationModule ..> Mutation : «produces»
MutationModule ..> SelectorModule : receives selectedGene
MutationModule ..> PersonalityState : checks risk personality

' Step 8 — Solidification (post-LLM)
SolidifyModule ..> Gene : adaptGeneFromLearning()
SolidifyModule ..> Capsule : records outcome
SolidifyModule ..> AssetStore : upsertGene()\nappendCapsule()\nappendFailedCapsule()
SolidifyModule ..> PolicyCheck : checkConstraints()\nclassifyBlastSeverity()
SolidifyModule ..> GitOps : normalizeRelPath()\nisCriticalProtectedPath()
SolidifyModule ..> LlmReview : buildReviewPrompt()\nrunLlmReview()

' Feedback loop: solidification updates genes used by selector
Gene ..> SelectorModule : signals_match\n+ learning_history\nfeed future selection

@enduml
