@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title GEP Exploration & Prompts\n(Exploration Loop, Prompt Construction, Git Operations, Idle Scheduling, Local State Awareness)

' ─────────────────────────────────────────────
' Data Types
' ─────────────────────────────────────────────
package "Data Types" {

    class ScheduleRecommendation <<datatype>> {
        +enabled: boolean
        +idle_seconds: number
        +intensity: "signal_only"|"normal"|"aggressive"|"deep"
        +sleep_multiplier: number
        +should_distill: boolean
        +should_reflect: boolean
        +should_deep_evolve: boolean
        +should_explore: boolean
    }

    class GepPromptOptions <<datatype>> {
        +nowIso: string
        +context: string
        +signals: string[]
        +selector: object
        +parentEventId: string | null
        +selectedGene: Gene | null
        +capsuleCandidates: string
        +genesPreview: string
        +capsulesPreview: string
        +capabilityCandidatesPreview: string
        +externalCandidatesPreview: string
        +hubMatchedBlock: string
        +cycleId: string
        +recentHistory: string
        +failedCapsules: any[]
        +hubLessons: any[]
        +strategyPolicy: object | null
        +initialUserPrompt: string | null
    }

    class HistoryAnalysis <<datatype>> {
        +suppressedSignals: Set<string>
        +recentIntents: string[]
        +consecutiveRepairCount: number
        +emptyCycleCount: number
        +consecutiveEmptyCycles: number
        +consecutiveFailureCount: number
        +recentFailureCount: number
        +recentFailureRatio: number
        +signalFreq: Record<string, number>
        +geneFreq: Record<string, number>
    }

    class LocalStatePaths <<datatype>> {
        +nodeIdFile: string
        +nodeSecretFile: string
        +envFile: string
        +memoryDir: string
        +evolutionDir: string
        +skillsDir: string
    }

}

' ─────────────────────────────────────────────
' GEP Core Modules
' ─────────────────────────────────────────────
package "GEP Core (src/gep/)" {

    class IdleScheduler <<module>> {
        --Constants--
        ~IDLE_THRESHOLD_SECONDS: number
        ~DEEP_IDLE_THRESHOLD_SECONDS: number
        --Functions--
        +getSystemIdleSeconds(): number
        +determineIntensity(idleSeconds: number): string
        +getScheduleRecommendation(): ScheduleRecommendation
        +readScheduleState(): object
        +writeScheduleState(state: object): void
    }
    note right of IdleScheduler
        Cross-platform idle detection
        (win32/darwin/linux).
        Persists state to
        idle_schedule_state.json.
        Env: OMLS_ENABLED,
        OMLS_IDLE_THRESHOLD,
        OMLS_DEEP_IDLE_THRESHOLD
    end note

    class ExploreModule <<module>> {
        --Functions--
        +tryExplore(signals: string[], schedule: ScheduleRecommendation, repoRoot: string): Promise<object>
        ~isIgnoredPath(path: string): boolean
        ~isCodeFile(path: string): boolean
        ~readFileAsync(path: string, opts): Promise<string>
        ~scanDirectory(dir: string, depth: number): Promise<FileInfo[]>
        ~extractXmlTag(content: string, tag: string): string
        ~buildExploreResult(fileInfos: FileInfo[], repoRoot: string): ExploreResult
    }
    note right of ExploreModule
        Obfuscated source.
        Scans repo source files,
        filters code files (.js/.ts/.py etc.),
        skips node_modules/.git/dist.
        Returns discovered signals
        for the evolution cycle.
    end note

    class SignalsModule <<module>> {
        --Functions--
        +extractSignals(opts: object): string[]
        +hasOpportunitySignal(signals: string[]): boolean
        +analyzeRecentHistory(recentEvents: EvolutionEvent[]): HistoryAnalysis
        ~_extractRegex(corpus, lower, errorHit): string[]
        ~_extractKeywordScore(lower: string): string[]
        ~_extractLLM(corpus: string): string[]
        ~_mergeSignals(regexSignals, scoreSignals, llmSignals): string[]
    }
    note right of SignalsModule
        3-layer signal extraction:
        L1: Regex (deterministic, 0ms)
        L2: Keyword score (weighted)
        L3: LLM via hub API
             (rate-limited: 1/5 cycles)
        Post-processes: dedup, stagnation,
        saturation, failure streak signals.
    end note

    class LocalStateAwareness <<module>> {
        --Functions--
        +captureLocalState(): string
        +captureLocalStatePaths(): LocalStatePaths
        +captureNodeIdentity(): string[]
        +captureEnvConfig(): string[]
        +captureEvolutionState(): string[]
        +captureMemoryState(): string[]
        +captureSkillsState(): string[]
    }
    note right of LocalStateAwareness
        Reads: node_id, node_secret,
        .env, evolution_state.json,
        personality_state.json,
        MEMORY.md, memory_graph.jsonl,
        evolution_narrative.md.
        Produces context string for
        GepPromptOptions.context.
    end note

    class PromptModule <<module>> {
        --Functions--
        +buildGepPrompt(opts: GepPromptOptions): string
    }
    note right of PromptModule
        Obfuscated source.
        Constructs full LLM prompt string
        for a GEP evolution cycle.
        Embeds signals, selected gene,
        candidates, ethics/constitutional
        constraints (SOUL.md).
        Output consumed by solidify.js.
    end note

    class GitOpsModule <<module>> {
        --Constants--
        ~DIFF_SNAPSHOT_MAX_CHARS: number
        ~CRITICAL_PROTECTED_PREFIXES: string[]
        ~CRITICAL_PROTECTED_FILES: string[]
        --Functions--
        +runCmd(cmd: string, opts?: object): string
        +tryRunCmd(cmd: string, opts?): object
        +normalizeRelPath(relPath: string): string
        +countFileLines(absPath: string): number
        +gitListChangedFiles(opts: object): string[]
        +gitListUntrackedFiles(repoRoot: string): string[]
        +captureDiffSnapshot(repoRoot: string): string
        +isGitRepo(dir: string): boolean
        +isCriticalProtectedPath(relPath: string): boolean
        +rollbackTracked(repoRoot: string): void
        +rollbackNewUntrackedFiles(opts: object): object
    }
    note right of GitOpsModule
        Centralized git CLI invocations.
        Rollback modes: hard / stash / none
        (env: EVOLVER_ROLLBACK_MODE).
        Never deletes MEMORY.md, SOUL.md,
        IDENTITY.md, AGENTS.md or
        skills/ during rollback.
    end note

}

' ─────────────────────────────────────────────
' External consumers (shown for integration)
' ─────────────────────────────────────────────
package "Integration Context" {

    class IndexDaemon <<caller>> {
        +evolutionLoop(): void
    }

    class SolidifyModule <<caller>> {
        +solidify(opts): Promise<void>
    }

    class A2AProtocol <<external>> {
        +getHubUrl(): string
        +postSignalAnalyze(corpus): string[]
    }

    class PathsModule <<utility>> {
        +getRepoRoot(): string
        +getEvolutionDir(): string
        +getMemoryDir(): string
        +getSkillsDir(): string
        +getWorkspaceRoot(): string
    }

}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' IdleScheduler produces ScheduleRecommendation
IdleScheduler ..> ScheduleRecommendation : produces

' ExploreModule uses ScheduleRecommendation as input
ExploreModule ..> ScheduleRecommendation : consumes

' PromptModule uses GepPromptOptions as input
PromptModule ..> GepPromptOptions : consumes

' SignalsModule produces HistoryAnalysis
SignalsModule ..> HistoryAnalysis : produces

' LocalStateAwareness produces LocalStatePaths
LocalStateAwareness ..> LocalStatePaths : produces

' LocalStateAwareness feeds context into GepPromptOptions
LocalStateAwareness ..> GepPromptOptions : populates context

' Signals feed into GepPromptOptions
SignalsModule ..> GepPromptOptions : populates signals[]

' IndexDaemon orchestrates the exploration loop
IndexDaemon ..> IdleScheduler : calls getScheduleRecommendation()
IndexDaemon ..> ExploreModule : calls tryExplore() when should_explore
IndexDaemon ..> SignalsModule : calls extractSignals()

' SolidifyModule uses prompt + git operations
SolidifyModule ..> PromptModule : calls buildGepPrompt()
SolidifyModule ..> GitOpsModule : uses for diff capture & rollback

' SignalsModule uses A2AProtocol for LLM layer
SignalsModule ..> A2AProtocol : _extractLLM() via hub API

' Module path dependencies
IdleScheduler ..> PathsModule : getEvolutionDir()
LocalStateAwareness ..> PathsModule : getRepoRoot(), getMemoryDir(),\ngetEvolutionDir(), getSkillsDir()
GitOpsModule ..> PathsModule : getRepoRoot()
ExploreModule ..> PathsModule : (indirect)
PromptModule ..> PathsModule : getEvolutionDir()

@enduml
