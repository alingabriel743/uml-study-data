@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title GEP Hub & Integration

package "Core Protocol (src/gep/)" {

  class a2aProtocol <<module>> {
    +PROTOCOL_NAME: string
    +PROTOCOL_VERSION: string
    +VALID_MESSAGE_TYPES: string[]
    --
    +buildMessage(messageType, payload): ProtocolMessage
    +buildHello(name?): ProtocolMessage
    +buildPublish(asset): ProtocolMessage
    +buildFetch(assetType, localId): ProtocolMessage
    +buildReport(assetId, validationReport): ProtocolMessage
    +buildDecision(decision, assetId): ProtocolMessage
    +buildRevoke(assetId, reason): ProtocolMessage
    +isValidProtocolMessage(msg): boolean
    +unwrapAssetFromMessage(msg): asset|null
    +sendHeartbeat(): Promise
    +sendHelloToHub(): Promise
    +hubOpenEventStream(opts): EventStream
    +startHeartbeat(): void
    +stopHeartbeat(): void
    +consumeAvailableWork(): Promise
    +registerTransport(name, transport): void
    +getNodeId(): string
    +getHubUrl(): string
    +getHubNodeSecret(): string
    +buildHubHeaders(): Headers
    +getA2ADir(): string
  }

  class a2a <<module>> {
    --
    +isAllowedA2AAsset(obj): boolean
    +lowerConfidence(asset, opts): asset|null
    +isBlastRadiusSafe(blastRadius): boolean
    +computeCapsuleSuccessStreak(params): number
    +isCapsuleBroadcastEligible(capsule, opts): boolean
    +exportEligibleCapsules(params): Capsule[]
    +isGeneBroadcastEligible(gene): boolean
    +exportEligibleGenes(params): Gene[]
    +parseA2AInput(text): asset[]
    +readTextIfExists(filePath): string
  }

  class directoryClient <<module>> {
    --
    +searchByQuery(query, opts?): Promise
    +searchBySignals(signals, opts?): Promise
    +getAgentProfile(nodeId): Promise
    +discoverForTask(task, opts?): Promise
  }

  class hubSearch <<module>> {
    -_cache: Map
    --
    +search(query): Promise
  }

  class mailboxTransport <<module>> {
    --
    +send(message): Promise
    +receive(opts): Promise
    +list(opts): Promise
    +registerMailboxTransport(): void
  }

  class bridge <<module>> {
    --
    +clip(text, maxChars): string
    +writePromptArtifact(params): GepPromptArtifact
    +renderSessionsSpawnCall(params): string
  }

  class signals <<module>> {
    +OPPORTUNITY_SIGNALS: string[]
    +SIGNAL_PROFILES: object
    --
    +extractSignals(context): string[]
    +hasOpportunitySignal(signals): boolean
    +analyzeRecentHistory(recentEvents): HistoryAnalysis
    -_extractRegex(corpus, lower, errorHit): string[]
    -_extractKeywordScore(lower): string[]
    -_extractLLM(corpus): string[]
    -_mergeSignals(regexSignals, scoreSignals, llmSignals): string[]
  }

  class personality <<module>> {
    --
    +normalizePersonalityState(ps): PersonalityState
    +personalityKey(ps): string
    +defaultPersonalityState(): PersonalityState
  }

}

package "Data Types" {

  class ProtocolMessage <<datatype>> {
    +protocol: string
    +message_type: string
    +message_id: string
    +timestamp: string
    +payload: object
    +node_id?: string
  }

  class Gene <<datatype>> {
    +id: string
    +type: string
    +strategy: string[]
    +validation: string[]
    +schema_version: string
    +asset_id: string
  }

  class Capsule <<datatype>> {
    +id: string
    +type: string
    +confidence: number
    +outcome: object
    +schema_version: string
    +asset_id: string
  }

  class EvolutionEvent <<datatype>> {
    +id: string
    +type: string
    +capsule_id: string
    +outcome: object
    +intent: string
    +personality_state: PersonalityState
    +meta: object
  }

  class PersonalityState <<datatype>> {
    +current: object
    +stats: object
  }

  class GepPromptArtifact <<datatype>> {
    +type: string
    +at: string
    +cycle_id: string
    +run_id: string
    +prompt_path: string
    +meta: object
  }

}

' Module dependencies
a2a ..> a2aProtocol : uses (unwrapAssetFromMessage)
directoryClient ..> a2aProtocol : uses (getNodeId, buildHubHeaders)
mailboxTransport ..> a2aProtocol : registers as transport 'mailbox'

' Data type production
a2aProtocol ..> ProtocolMessage : builds
a2a ..> Gene : exports eligible
a2a ..> Capsule : exports eligible
a2a ..> EvolutionEvent : reads events
bridge ..> GepPromptArtifact : produces
personality ..> PersonalityState : manages
EvolutionEvent *-- PersonalityState : embeds

@enduml
