@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title GEP Identity & Security

' ─────────────────────────────────────────────
'  IDENTITY PACKAGE
' ─────────────────────────────────────────────
package "Identity" {

  class DeviceId <<module>> {
    +getDeviceId(): string
    +isContainer(): boolean
    --
    -_readCachedId(): string
    -_writeNewId(id: string): void
    -_computeStableHash(): string
  }

  class EnvFingerprintObject <<data>> {
    +device_id: string
    +node_version: string
    +platform: string
    +arch: string
    +os_release: string
    +hostname: string
    +evolver_version: string
    +client: string
    +client_version: string
    +region: string
    +cwd: string
    +container: boolean
    +captured_at: string
  }

  class EnvFingerprint <<module>> {
    +captureEnvFingerprint(): EnvFingerprintObject
    +fingerprintEnv(fp: EnvFingerprintObject): string
    +envFingerprintMatch(fp1: EnvFingerprintObject, fp2: EnvFingerprintObject): boolean
  }
}

note bottom of DeviceId
  Obfuscated. Generates and caches
  a stable UUID from system attributes.
  Also detects Docker/container env.
end note

note right of EnvFingerprintObject
  hostname and cwd are SHA-256
  hashed to avoid leaking local paths.
end note

' ─────────────────────────────────────────────
'  CRYPTOGRAPHY PACKAGE
' ─────────────────────────────────────────────
package "Cryptography" {

  class EncryptResult <<data>> {
    +ciphertext: Buffer
    +iv: Buffer
    +authTag: Buffer
  }

  class Crypto <<module>> {
    +{static} ALGORITHM: string
    +{static} KEY_BYTES: number
    +{static} IV_BYTES: number
    +{static} AUTH_TAG_BYTES: number
    --
    +generateKey(): Buffer
    +encrypt(plaintext: Buffer, key: Buffer): EncryptResult
    +decrypt(ciphertext: Buffer, key: Buffer, iv: Buffer, authTag: Buffer): Buffer
    +pack(parts: EncryptResult): Buffer
    +unpack(buf: Buffer): EncryptResult
  }

  class PrivacyClient <<module>> {
    -{static} HUB_URL: string
    -{static} PRIVACY_TIMEOUT_MS: number
    --
    +submitPrivacyTask(opts: object): Promise
    +uploadEncryptedBlob(plaintext: Buffer, opts: object): Promise
    +executeSealedTool(opts: object): Promise
    +getPrivacyStatus(taskId: string): Promise
    +getPrivacyResult(taskId: string, key: Buffer): Promise
    +getToolTemplates(): Promise
    +parsePrivacyParams(body: string): object
  }
}

note bottom of Crypto
  AES-256-GCM authenticated encryption.
  KEY=32B · IV=12B · authTag=16B.
  Obfuscated source.
end note

note right of PrivacyClient
  Privacy-preserving compute pattern:
  encrypt locally → upload ciphertext
  → execute sealed tool → retrieve
  + decrypt result.
end note

' ─────────────────────────────────────────────
'  SECURITY & POLICY PACKAGE
' ─────────────────────────────────────────────
package "Security & Policy" {

  class Shield <<module>> {
    -_initialized: boolean
    -_triggered: boolean
    -_envSnapshot: object
    --
    +init(): void
    +check(): void
    +isTriggered(): boolean
    +freezeExports(obj: object): void
    --
    -_detectDebugger(): void
    -_checkEnvDrift(): void
    -_captureEnvSnapshot(): object
    -_freezeProperties(obj: object): void
  }

  class PolicyCheck <<module>> {
    +checkPolicy(env: EnvFingerprintObject): object
    +buildPolicyReport(): object
    --
    -_evaluateRule(rule: object, env: object): boolean
    -_buildRuleSet(rules: Array): Set
    -_mergePolicies(p1: object, p2: object): object
    -_filterRules(rules: Array, env: object): Array
  }

  class LeakEntry <<data>> {
    +type: string
    +value: string
    +suggestion: string
  }

  class LeakResult <<data>> {
    +found: boolean
    +leaks: LeakEntry[]
  }

  class Sanitize <<module>> {
    -{static} REDACTED: string
    -{static} REDACT_PATTERNS: RegExp[]
    -{static} LEAK_SCANNERS: object[]
    -{static} ENV_SCAN_SKIP_KEYS: Set
    --
    +sanitizePayload(capsule: object): object
    +redactString(str: string): string
    +scanForLeaks(content: string): LeakResult
    +detectEnvValueLeaks(content: string): LeakEntry[]
    +fullLeakCheck(content: string): LeakResult
  }
}

note bottom of Shield
  Anti-tamper / runtime integrity guard.
  Detects debuggers via execArgv,
  NODE_OPTIONS, v8debug.
  Monitors critical env vars for drift.
  Obfuscated source.
end note

note bottom of Sanitize
  15 REDACT_PATTERNS (Bearer tokens,
  sk-* keys, GitHub tokens, AWS AKIA,
  PEM keys, emails, local paths, etc.).
  Applied before any outbound hub upload.
end note

' ─────────────────────────────────────────────
'  RELATIONSHIPS
' ─────────────────────────────────────────────

' Identity chain
EnvFingerprint --> DeviceId        : uses (getDeviceId, isContainer)
EnvFingerprint ..> EnvFingerprintObject : «creates»

' Crypto chain
Crypto ..> EncryptResult           : «produces»
PrivacyClient --> Crypto           : uses (generateKey, encrypt,\ndecrypt, pack, unpack)

' Policy & security chain
PolicyCheck --> EnvFingerprint     : uses (captureEnvFingerprint)
Shield ..> EnvFingerprint          : monitors overlapping env vars

' Sanitize output composition
Sanitize ..> LeakResult            : «returns»
LeakResult *-- LeakEntry           : contains

@enduml
