@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam stereotypeCBackgroundColor #D0E8FF
skinparam stereotypeABackgroundColor #FFE0B2
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title GEP Memory & Knowledge

' ─────────────────────────────────────────
'  Core GEP Modules
' ─────────────────────────────────────────
package "GEP Memory & Knowledge" {

    class memoryGraph <<module>> {
        +MEMORY_GRAPH_PATH : string
        +EVOLUTION_DIR : string
        --
        +computeSignalKey(signals: string[]): string
        +getMemoryAdvice(signals, genes, driftEnabled): MemoryAdvice
        +recordSignalSnapshot(signals, observations): MemoryGraphEvent
        +recordHypothesis(signals, selectedGene, driftEnabled): object
        +recordAttempt(signals, selectedGene, driftEnabled): object
        +recordOutcomeFromState(signals, observations): MemoryGraphEvent
        +computePredictiveBoost(baselineObserved, currentObserved, signals): PredictiveBoost
        +checkEpochBoundary(signals, envFingerprintKey, geneLibVersion): object
        +resetMemoryPreferences(reason, envFingerprintKey, geneLibVersion): object
        +readCurrentEpoch(): Epoch
    }

    class memoryGraphAdapter <<module>> {
        +MEMORY_GRAPH_URL : string
        --
        +recordExternalCandidate(asset, source, signals): void
    }

    class narrativeMemory <<module>> {
        .. API obfuscated ..
        ' 6 internal functions
        ' reads/writes narrative JSONL/JSON
    }

    class curriculum <<module>> {
        .. API obfuscated ..
        ' 11 internal functions
        ' signal: curriculum_target:frontier:*
    }

    class learningSignals <<module>> {
        --
        +extractTags(items: string[], context?: string): string[]
        +extractContext(capsule): string[]
        +scoreTagMatch(capsule, signalTags: string[]): number
    }
}

' ─────────────────────────────────────────
'  Data Types
' ─────────────────────────────────────────
package "Data Types" {

    class MemoryGraphEvent <<dataType>> {
        +type : "MemoryGraphEvent"
        +kind : signal|hypothesis|attempt|outcome|epoch_boundary
        +signal? : object
        +gene? : object
        +outcome? : object
        +epoch? : object
        +timestamp? : string
    }

    class MemoryAdvice <<dataType>> {
        +currentSignalKey : string
        +preferredGeneId : string | null
        +bannedGeneIds : Set<string>
        +explanation : string
        +totalAttempts? : number
    }

    class PredictiveBoost <<dataType>> {
        +boost : number
        +signal_clarity : number
        +frontier_touched : boolean
    }

    class Epoch <<dataType>> {
        +epoch_id : string
        +prev_env_fingerprint_key : string
        +prev_gene_lib_version? : string
    }
}

' ─────────────────────────────────────────
'  External Consumers
' ─────────────────────────────────────────
package "External Consumers" {

    class evolve <<orchestrator>> {
    }

    class solidify <<processor>> {
    }

    class selector <<selector>> {
    }

    class a2a_ingest <<ingestor>> {
    }
}

' ─────────────────────────────────────────
'  Persistent Storage (notes)
' ─────────────────────────────────────────
note bottom of memoryGraph
  Persistent files:
  • memory_graph.jsonl  (append-only event log)
  • memory_graph_state.json  (current state + epoch)
end note

' ─────────────────────────────────────────
'  Relationships — within GEP layer
' ─────────────────────────────────────────
memoryGraphAdapter ..> memoryGraph       : wraps via HTTP\n(fetch + AbortController)
curriculum         ..> memoryGraph       : computePredictiveBoost\n(frontier signals)
narrativeMemory    ..> memoryGraph       : sibling subsystem

' ─────────────────────────────────────────
'  Relationships — module → data types
' ─────────────────────────────────────────
memoryGraph ..> MemoryAdvice      : produces
memoryGraph ..> MemoryGraphEvent  : produces
memoryGraph ..> PredictiveBoost   : produces
memoryGraph ..> Epoch             : reads / writes

' ─────────────────────────────────────────
'  Relationships — external consumers
' ─────────────────────────────────────────
evolve      ..> memoryGraph        : getMemoryAdvice\nrecordHypothesis\nrecordAttempt\nrecordOutcomeFromState
evolve      ..> memoryGraphAdapter : recordExternalCandidate
solidify    ..> learningSignals    : extractTags\nbuildSoftFailureLearningSignals\nadaptGeneFromLearning
selector    ..> memoryGraph        : reads MemoryAdvice\n(bannedGeneIds, preferredGeneId)
a2a_ingest  ..> memoryGraphAdapter : recordExternalCandidate

@enduml
