@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam stereotypeCBackgroundColor #D0E8FF
skinparam stereotypeABackgroundColor #FFE8CC
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #ADB5BD
}

title GEP Skills & Publishing

' ─────────────────────────────────────────
'  Core GEP Modules
' ─────────────────────────────────────────
package "GEP Skills & Publishing" {

    class skillDistiller <<module>> {
        +sanitizeSignalsMatch(signals): array
        __
        ' Obfuscated (444KB) — core gene-to-skill
        ' distillation engine
    }

    class skillPublisher <<module>> {
        +sanitizeSkillName(rawName): string|null
        +toTitleCase(kebabName): string
        +deriveFallbackName(gene): string
        +geneToSkillMd(gene): string
        +extractStepVerb(step): string
        +stripLeadingVerb(step): string
        +publishSkillToHub(gene, opts): Promise
        +updateSkillOnHub(nodeId, skillId, content, opts, gene): Promise
    }

    class selfPR <<module>> {
        +isPublicNonObfuscated(filePath): boolean
        +isInCooldown(): boolean
        +computeDiffHash(changedFiles, repoRoot): string
        +isDuplicateDiff(diffHash): boolean
        +recordPR(diffHash): void
        +buildPRTitle(mutation): string
        +buildPRBody(opts): string
        +readState(): PRState
        +writeState(state): void
        +runGh(args, opts): GhResult
        +getGitDiff(changedFiles, repoRoot): string
        +maybeCreatePR(opts): Promise<PRResult|null>
    }

    class issueReporter <<module>> {
        +getConfig(): IssueConfig|null
        +shouldReport(signals, config): boolean
        +computeErrorKey(signals): string
        +extractErrorSignature(signals): string
        +extractStreakCount(signals): number
        +buildIssueBody(opts): string
        +readState(): IssueState
        +writeState(state): void
        +createGithubIssue(repo, title, body, token): Promise<IssueResult>
        +findExistingIssue(repo, title, token): Promise<IssueResult|null>
        +maybeReportIssue(opts): Promise<void>
    }

    class questionGenerator <<module>> {
        +generateQuestions(opts): Question[]
        +generateUrgentQuestions(opts): Question[]
        +buildStandardCandidates(signals, recentEvents, transcript, memory): Candidate[]
        +buildUrgentCandidates(opts): Candidate[]
        +isDuplicate(question, recentQuestions): boolean
        +extractErrorContext(transcript, maxLen): string
        +extractRecentGeneIds(recentEvents, count): string[]
        +readState(): QuestionState
        +writeState(state): void
    }

    class executionTrace <<module>> {
        +buildExecutionTrace(opts): TraceObject|null
        +getTraceLevel(): string
        +classifyBlastLevel(blast): string
        +inferToolChain(validationResults, blast): string[]
        +desensitizeFilePath(filePath): string|null
        +extractErrorSignature(errorText): string|null
    }
}

' ─────────────────────────────────────────
'  Data Types
' ─────────────────────────────────────────
package "Data Types" {

    class Gene <<dataType>> {
        +id: string
        +summary: string
        +signals_match: string[]
        +preconditions: string[]
        +strategy: string[]
        +constraints: object
        +validation: string[]
        +category: string
        +schema_version: string
    }

    class Capsule <<dataType>> {
        +id: string
        +outcome: Outcome
        +success_streak: number
        +trigger: string[]
        +genes_used: string[]
        +intent: string
    }

    class Mutation <<dataType>> {
        +category: string
        +risk: string
        +rationale: string
    }

    class BlastRadius <<dataType>> {
        +files: number
        +lines: number
        +all_changed_files: string[]
        +changed_files: string[]
    }

    class TraceObject <<dataType>> {
        +gene_id: string
        +mutation_category: string
        +signals_matched: string[]
        +outcome: string
        +files_changed_count: number
        +lines_added: number
        +lines_removed: number
        +validation_result: string
        +blast_radius: string
        +created_at: string
    }

    class Question <<dataType>> {
        +question: string
        +amount: number
        +signals: string[]
    }

    class PRResult <<dataType>> {
        +attempted: boolean
        +ok: boolean
        +pr_url: string
        +branch: string
        +diff_hash: string
        +reason: string
    }

    class IssueResult <<dataType>> {
        +number: number
        +url: string
    }
}

' ─────────────────────────────────────────
'  Shared Dependencies
' ─────────────────────────────────────────
package "Shared Dependencies" {

    class a2aProtocol <<module>> {
        +getHubUrl(): string
        +buildHubHeaders(): object
        +getNodeId(): string
    }

    class paths <<module>> {
        +getEvolutionDir(): string
        +getRepoRoot(): string
    }

    class sanitize <<module>> {
        +fullLeakCheck(content): boolean
        +redactString(s): string
    }

    class config <<module>> {
        +SELF_PR_COOLDOWN_MS: number
        +SELF_PR_MIN_SCORE: number
        +SELF_PR_MIN_STREAK: number
        +SELF_PR_MAX_FILES: number
        +SELF_PR_MAX_LINES: number
    }

    class envFingerprint <<module>> {
        +captureEnvFingerprint(): object
    }
}

' ─────────────────────────────────────────
'  Module → Shared Dependency Relationships
' ─────────────────────────────────────────
skillPublisher ..> skillDistiller     : uses sanitizeSignalsMatch
skillPublisher ..> a2aProtocol        : getNodeId, getHubUrl,\nbuildHubHeaders

selfPR          ..> paths             : getEvolutionDir,\ngetRepoRoot
selfPR          ..> sanitize          : fullLeakCheck, redactString
selfPR          ..> config            : SELF_PR_* constants

issueReporter   ..> paths             : getEvolutionDir
issueReporter   ..> sanitize          : redactString
issueReporter   ..> a2aProtocol       : getNodeId
issueReporter   ..> envFingerprint    : captureEnvFingerprint

questionGenerator ..> paths           : getEvolutionDir

' ─────────────────────────────────────────
'  Module → Data Type Relationships
' ─────────────────────────────────────────
skillPublisher  ..> Gene              : converts → Skill MD
skillPublisher  ..> Capsule           : reads metadata

selfPR          ..> Capsule           : evaluates for PR gates
selfPR          ..> Mutation          : derives PR title/body
selfPR          ..> PRResult          : «returns»

issueReporter   ..> IssueResult       : «returns»
issueReporter   ..> BlastRadius       : reads from signals

questionGenerator ..> Question        : «generates»

executionTrace  ..> Gene              : traces gene_id, category
executionTrace  ..> Mutation          : traces mutation_category
executionTrace  ..> BlastRadius       : classifies blast level
executionTrace  ..> TraceObject       : «builds»

note bottom of skillDistiller
  Obfuscated / minified (444 KB).
  Listed in OBFUSCATED_FILES; excluded
  from selfPR public-file gate.
end note

note right of executionTrace
  Only module with zero
  external dependencies.
  Uses Node built-in 'path' only.
  Controlled by EVOLVER_TRACE_LEVEL:
  none | minimal | standard | collaboration
end note

note right of selfPR
  Uses gh CLI (execSync) for PR flow:
  clone → checkout → copy → add/commit
  /push → gh pr create --label auto-mutation
  Gate chain: env_gate → score → streak
  → category → risk → files → lines
  → public_files → cooldown → dedup → leak
end note

note right of issueReporter
  Uses GitHub REST API (Bearer token).
  Deduplicates via findExistingIssue().
  Triggers on: failure_loop_detected or
  recurring_error + high_failure_ratio.
end note

@enduml
