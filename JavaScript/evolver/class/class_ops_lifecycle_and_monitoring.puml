@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Ops Lifecycle & Monitoring

package "src/ops" {

    class Lifecycle <<module>> {
        -WORKSPACE_ROOT: string
        -LOG_FILE: string
        -PID_FILE: string
        -MAX_SILENCE_MS: number
        --
        +start(options): {status, pid|pids}
        +stop(): {status, killed}
        +restart(options): {status, pid}
        +status(): {running, pids[], log}
        +tailLog(lines): {file, content}
        +checkHealth(): {healthy, reason?, silenceMinutes?, pids?}
        +getRunningPids(): number[]
        -isPidRunning(pid): boolean
        -getCmdLine(pid): string|null
        -getLoopScript(): string
    }

    class HealthCheck <<module>> {
        -criticalSecrets: string[]
        -optionalSecrets: string[]
        -_procCache: number
        --
        +runHealthCheck(): {status, timestamp, checks[]}
        -getDiskUsage(mount): {pct, freeMb}
    }

    note right of HealthCheck
      Checks:
      • env secrets (critical/warning/info)
      • disk_space: >80% warn, >90% critical
      • memory: >95% critical
      • process_count: >2000 warn (Linux, 60s TTL)
    end note

    class SelfRepair <<module>> {
        -LOCK_MAX_AGE_MS: number
        -EVOLVE_GIT_RESET: string
        --
        +repair(gitRoot?): string[]
    }

    note right of SelfRepair
      Repair steps:
      • abort pending rebase/merge
      • remove stale .git/index.lock
      • fetch origin or hard reset
    end note

    class Cleanup <<module>> {
        -MAX_AGE_MS: number
        -MIN_KEEP: number
        -MAX_FILES: number
        -target: string
        --
        +run(): number
        -safeBatchDelete(batch: string[]): number
    }

    note right of Cleanup
      Phase 1: Age-based deletion
      Phase 2: Cap-based deletion
    end note

    class SkillsMonitor <<module>> {
        -IGNORE_LIST: Set<string>
        -mainFile: string
        --
        +run(options?: {autoHeal:boolean}): Array<{name, issues[]}>
        +checkSkill(skillName): {name, issues[]}|null
        +autoHeal(skillName, issues[]): string[]
    }

    note right of SkillsMonitor
      Checks per skill:
      • package.json valid/exists
      • node_modules non-empty
      • SKILL.md presence
      Auto-heal: npm install, create SKILL.md stub
    end note

    class Innovation <<module>> {
        -categories: string[]
        --
        +generateInnovationIdeas(): string[]
        -listSkills(): string[]
    }

    note right of Innovation
      Finds 2 weakest skill categories
      and returns top 3 targeted ideas.
      Categories: feishu, dev, media,
      security, automation, data
    end note

    class Trigger <<module>> {
        -WAKE_FILE: string
        --
        +send(): boolean
        +clear(): void
        +isPending(): boolean
    }

    note right of Trigger
      File-based wake signal:
      memory/evolver_wake.signal
    end note
}

package "Shared Infrastructure" {

    class Paths <<utility>> {
        +getRepoRoot(): string
        +getWorkspaceRoot(): string
        +getEvolverLogPath(): string
        +getEvolutionDir(): string
        +getSkillsDir(): string
    }

    class Config <<utility>> {
        +MAX_SILENCE_MS: number
        +LOCK_MAX_AGE_MS: number
        +CLEANUP_MAX_AGE_MS: number
        +CLEANUP_MIN_KEEP: number
        +CLEANUP_MAX_FILES: number
    }
}

' --- Internal method relationships ---
SkillsMonitor ..> SkillsMonitor : run() calls\ncheckSkill() + autoHeal()

' --- Cross-module dependency: Lifecycle uses HealthCheck internally ---
Lifecycle ..> HealthCheck : checkHealth() uses\nprocess liveness check

' --- Config dependencies ---
Lifecycle ..> Config : reads MAX_SILENCE_MS
SelfRepair ..> Config : reads LOCK_MAX_AGE_MS
Cleanup ..> Config : reads cleanup settings

' --- Paths dependencies ---
Lifecycle ..> Paths : getWorkspaceRoot\ngetEvolverLogPath
SelfRepair ..> Paths : getRepoRoot
Cleanup ..> Paths : getEvolutionDir
SkillsMonitor ..> Paths : getSkillsDir
Innovation ..> Paths : getSkillsDir
Trigger ..> Paths : getWorkspaceRoot

@enduml
