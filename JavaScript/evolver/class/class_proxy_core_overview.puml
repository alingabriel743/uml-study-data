@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Proxy Core Overview

' ─────────────────────────────────────────
' Core Proxy Package
' ─────────────────────────────────────────
package "Proxy Entry Point (src/proxy)" {

    class EvoMapProxy {
        +hubUrl: string
        +dataDir: string
        +port: number|undefined
        +logger: object
        -_skillPath: string|null
        -_started: boolean
        --
        +store: MailboxStore|null
        +server: ProxyHttpServer|null
        +sync: SyncEngine|null
        +lifecycle: LifecycleManager|null
        +taskMonitor: TaskMonitor|null
        +skillUpdater: SkillUpdater|null
        +dmHandler: DmHandler|null
        +sessionHandler: SessionHandler|null
        ==
        +start(): Promise<{url, port, nodeId}>
        +stop(): Promise<void>
        +mailbox: MailboxStore <<get>>
        -_proxyHttp(path: string, body: object): Promise<object>
        -_getHubMailboxStatus(): Promise<object>
    }

    note right of EvoMapProxy
      Top-level orchestrator.
      start() instantiates all sub-components.
      _proxyHttp() handles 401/403 by calling
      lifecycle.reAuthenticate() and retrying.
      Wraps 13 OUTBOUND_ROUTES to call
      sync.notifyNewOutbound().
    end note
}

' ─────────────────────────────────────────
' HTTP Server Package
' ─────────────────────────────────────────
package "HTTP Server (src/proxy/server)" {

    class ProxyHttpServer {
        +routes: object
        +basePort: number
        +actualPort: number|null
        +logger: object
        -server: http.Server|null
        ==
        +start(): Promise<{port, url}>
        +stop(): Promise<void>
        -_handleRequest(req, res): Promise<void>
        -_matchRoute(method, pathname): object|null
    }

    note bottom of ProxyHttpServer
      Binds to 127.0.0.1 only.
      DEFAULT_PORT=19820, MAX_PORT_ATTEMPTS=100.
      Supports :param route segments.
    end note

    class "«module»\nSettings" as SettingsModule {
        +SETTINGS_DIR: string
        +SETTINGS_FILE: string
        ==
        +readSettings(): object
        +writeSettings(data): void
        +clearSettings(): void
        +isStaleProxy(): boolean
        +clearIfStale(): void
        +getProxyUrl(): string
    }

    note bottom of SettingsModule
      Persists {proxy: {url, pid, started_at}}
      to ~/.evolver/settings.json for
      client discovery.
    end note

    class "«factory»\nbuildRoutes" as BuildRoutes {
        ==
        +buildRoutes(store, proxyHandlers,\n  taskMonitor, extensions): routeMap
        ..Route Groups..
        Mailbox: /mailbox/*
        Asset:   /asset/*
        Task:    /task/*
        DM:      /dm/*
        Session: /session/*
        System:  /proxy/status|config|hub-status
    }
}

' ─────────────────────────────────────────
' Lifecycle / Auth Package
' ─────────────────────────────────────────
package "Lifecycle & Auth (src/proxy/lifecycle)" {

    class LifecycleManager {
        +hubUrl: string
        +store: MailboxStore
        +logger: object
        +getTaskMeta: function|null
        -_heartbeatTimer: Timeout|null
        -_running: boolean
        -_startedAt: number|null
        -_consecutiveFailures: number
        -_reauthInProgress: boolean
        ==
        +nodeId: string <<get>>
        +nodeSecret: string|null <<get>>
        -_buildHeaders(): object
        +hello(opts): Promise<{ok, nodeId, response}>
        +reAuthenticate(): Promise<boolean>
        +heartbeat(opts): Promise<{ok, response}>
        +startHeartbeatLoop(intervalMs?): void
        +stopHeartbeatLoop(): void
        -_shouldUpgrade(minVersion): boolean
    }

    note right of LifecycleManager
      GEP-A2A protocol: hello on startup,
      heartbeat every 6 min with exponential backoff.
      MAX_REAUTH_ATTEMPTS=2.
      Auth flow: 401/403 → reAuthenticate()
        → hello(rotateSecret:true) → heartbeat()
    end note

    class AuthError {
        +name: "AuthError"
        +statusCode: number
        ==
        +constructor(message: string, statusCode: number)
    }
}

' ─────────────────────────────────────────
' Referenced Components (abbreviated)
' ─────────────────────────────────────────
package "Composed Components (referenced)" {

    class MailboxStore {
        +constructor(dataDir)
        +send()
        +writeInbound()
        +writeInboundBatch(messages)
        +poll()
        +pollOutbound()
        +ack(messageIds)
        +list()
        +countPending()
        +getState(key)
        +setState(key, value)
    }

    class SyncEngine {
        +start()
        +stop()
        +notifyNewOutbound()
        -_handleAuthError(source)
    }

    class TaskMonitor {
        +subscribe()
        +unsubscribe()
        +recordClaim(taskId)
        +recordComplete(taskId, startedAt)
        +getMetrics()
        +getHeartbeatMeta()
    }

    class SkillUpdater {
        +setSkillPath(filePath)
        +processSkillUpdate(message)
        +pollAndApply()
    }

    class DmHandler {
        +send()
        +poll()
        +ack(messageIds)
        +list()
    }

    class SessionHandler {
        +createSession()
        +joinSession()
        +leaveSession()
        +sendMessage()
        +delegateSubtask()
        +submitResult()
        +pollInvites()
        +listActiveSessions()
    }
}

' ─────────────────────────────────────────
' Built-in Error
' ─────────────────────────────────────────
class Error <<built-in>> {
    +message: string
    +stack: string
}

' ─────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────

' EvoMapProxy compositions
EvoMapProxy *-- ProxyHttpServer       : server
EvoMapProxy *-- LifecycleManager      : lifecycle
EvoMapProxy *-- MailboxStore          : store
EvoMapProxy *-- SyncEngine            : sync
EvoMapProxy *-- TaskMonitor           : taskMonitor
EvoMapProxy *-- SkillUpdater          : skillUpdater
EvoMapProxy *-- DmHandler             : dmHandler
EvoMapProxy *-- SessionHandler        : sessionHandler

' EvoMapProxy dependencies
EvoMapProxy ..> BuildRoutes           : calls on start()
EvoMapProxy ..> AuthError             : catches 401/403

' ProxyHttpServer dependencies
ProxyHttpServer ..> SettingsModule    : writeSettings / clearSettings / clearIfStale

' LifecycleManager dependencies
LifecycleManager o-- MailboxStore     : reads/writes state

' buildRoutes dependencies
BuildRoutes ..> MailboxStore          : store handlers
BuildRoutes ..> TaskMonitor           : task handlers
BuildRoutes ..> DmHandler             : dm handlers
BuildRoutes ..> SessionHandler        : session handlers

' Inheritance
AuthError --|> Error

@enduml
