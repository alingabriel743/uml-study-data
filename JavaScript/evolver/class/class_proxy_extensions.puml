@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}
skinparam note {
    BackgroundColor #F1F3F5
    BorderColor #ADB5BD
    FontColor #495057
}

title Proxy Extensions

' ─────────────────────────────────────────
'  Shared Store Interface (duck-typed)
' ─────────────────────────────────────────
interface "Store" as Store {
    +send(type, payload, priority?): Promise
    +poll(type, limit): Array
    +ack(messageIds): Promise
    +list(type, direction, limit, offset): Array
    +setState(key, value): void
    +getState(key): any
    +countPending(direction): number
}

' ─────────────────────────────────────────
'  proxy/extensions package
' ─────────────────────────────────────────
package "proxy/extensions" {

    class SessionHandler {
        -store: Store
        -logger: Logger
        --
        +constructor(store, logger)
        +createSession(title, description, inviteNodeIds, maxParticipants): Promise
        +joinSession(sessionId): Promise
        +leaveSession(sessionId): Promise
        +sendMessage(sessionId, toNodeId, msgType, payload): Promise
        +delegateSubtask(sessionId, toNodeId, title, description, role): Promise
        +submitResult(sessionId, taskId, resultAssetId, summary): Promise
        +pollInvites(limit): Array
        +pollSessionEvents(limit): Array
        +listActiveSessions(): Array
    }

    class DmHandler {
        -store: Store
        -logger: Logger
        --
        +constructor(store, logger)
        +send(recipientNodeId, content, metadata): Promise
        +poll(limit): Array
        +ack(messageIds): Promise
        +list(limit, offset): Array
    }

    class SkillUpdater {
        -store: Store
        -skillPath: string
        -logger: Logger
        --
        +constructor(store, skillPath, logger)
        +setSkillPath(filePath): void
        +processSkillUpdate(message): boolean
        +pollAndApply(): number
    }

}

' ─────────────────────────────────────────
'  proxy/task package
' ─────────────────────────────────────────
package "proxy/task" {

    class TaskMonitor {
        -store: Store
        -logger: Logger
        -_stats: TaskStats
        --
        +constructor(store, logger)
        -_restoreStats(): void
        +subscribed: boolean  <<getter>>
        +subscribe(filters): Promise
        +unsubscribe(): Promise
        +recordClaim(taskId): void
        +recordComplete(taskId, startedAt): void
        +recordFailed(taskId): void
        +recordTaskReceived(count): void
        +getMetrics(): object
        +getHeartbeatMeta(): object
    }

    class TaskStats {
        +tasks_received: number
        +tasks_claimed: number
        +tasks_completed: number
        +tasks_failed: number
        +last_claim_at: string
        +last_complete_at: string
        +avg_completion_ms: number
        -_completion_times: number[]
    }

}

' ─────────────────────────────────────────
'  Node.js built-in dependencies
' ─────────────────────────────────────────
package "Node.js Built-ins" {
    class "fs" as NodeFs <<module>> {
        +mkdirSync(path, options): void
        +copyFileSync(src, dest): void
        +writeFileSync(path, data): void
    }

    class "path" as NodePath <<module>> {
        +dirname(filePath): string
    }
}

' ─────────────────────────────────────────
'  Relationships
' ─────────────────────────────────────────

' All four extension classes depend on the Store interface
SessionHandler  ..>  Store        : uses
DmHandler       ..>  Store        : uses
SkillUpdater    ..>  Store        : uses
TaskMonitor     ..>  Store        : uses

' TaskMonitor owns its internal stats object
TaskMonitor     *--  TaskStats    : contains

' SkillUpdater depends on Node.js built-ins for file I/O
SkillUpdater    ..>  NodeFs       : file I/O
SkillUpdater    ..>  NodePath     : path resolution

' ─────────────────────────────────────────
'  Design notes
' ─────────────────────────────────────────
note bottom of Store
  Duck-typed interface — no formal
  class defined. Fulfilled at runtime
  by MailboxStore (proxy/mailbox/store.js).
  All extensions receive it via constructor
  injection.
end note

note right of SkillUpdater
  Backup-before-write strategy:
  copies skill.md → skill.md.bak
  before overwriting with new content.
  Only class with filesystem access.
end note

note right of TaskMonitor
  Restores persisted stats from store
  state on construction. Maintains a
  rolling window (max 100 entries) for
  avg_completion_ms calculation.
end note

@enduml
