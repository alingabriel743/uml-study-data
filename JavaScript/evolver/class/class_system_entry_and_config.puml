@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title System Entry Points & Configuration

package "Entry Point" {
    class "index (EntryPoint)" as index << (M,#ADD8E6) module >> {
        +commands: [run, solidify, distill, review, fetch, asset-log, setup-hooks]
        +flags: --loop, --mad-dog, --verbose, -v
        -lock_file: evolver.pid
        --
        +main(): Promise<void>
        +sleepMs(ms: number): Promise<void>
        +readJsonSafe(p: string): object|null
        +rejectPendingRun(statePath: string): boolean
        +isPendingSolidify(state: object): boolean
        +parseMs(v: any, fallback: number): number
        -acquireLock(): boolean
        -releaseLock(): void
    }
}

package "Evolution Engine" {
    class "EvolveOrchestrator" as EvolveOrchestrator << (M,#ADD8E6) module >> {
        ' obfuscated core; only external API exposed
        --
        +run(): Promise<void>
    }
}

package "Configuration & Paths" {
    class "Config" as Config << (M,#ADD8E6) module >> {
        .. Network ..
        +HELLO_TIMEOUT_MS: 15000
        +HEARTBEAT_TIMEOUT_MS: 10000
        +HEARTBEAT_INTERVAL_MS: 360000
        +EVENT_POLL_TIMEOUT_MS: 60000
        +HTTP_TRANSPORT_TIMEOUT_MS: 15000
        +SECRET_CACHE_TTL_MS: 60000
        .. Solidify ..
        +VALIDATION_TIMEOUT_MS: 180000
        +CANARY_TIMEOUT_MS: 30000
        +SOLIDIFY_MAX_RETRIES: 2
        +MIN_PUBLISH_SCORE: 0.78
        .. Evolution Loop ..
        +REPAIR_LOOP_THRESHOLD: 3
        +SESSION_ARCHIVE_TRIGGER: 100
        +IDLE_FETCH_INTERVAL_MS: 600000
        +PROMPT_MAX_CHARS: 24000
        +DORMANT_TTL_MS: 3600000
        .. Ops ..
        +MAX_SILENCE_MS: 1800000
        +LOCK_MAX_AGE_MS: 600000
        +LEAK_CHECK_MODE: warn
        .. Self-PR ..
        +SELF_PR_MIN_SCORE: 0.85
        +SELF_PR_COOLDOWN_MS: 86400000
        --
        +envInt(key: string, fallback: number): number
        +envFloat(key: string, fallback: number): number
        +envStr(key: string, fallback: string): string
    }

    class "Paths" as Paths << (M,#ADD8E6) module >> {
        -_cachedRepoRoot: string|null
        +env: EVOLVER_REPO_ROOT, EVOLVER_USE_PARENT_GIT
        +env: EVOLVER_LOGS_DIR, MEMORY_DIR
        +env: EVOLUTION_DIR, GEP_ASSETS_DIR, SKILLS_DIR
        --
        +getRepoRoot(): string
        +getWorkspaceRoot(): string
        +getLogsDir(): string
        +getEvolverLogPath(): string
        +getMemoryDir(): string
        +getSessionScope(): string|null
        +getEvolutionDir(): string
        +getGepAssetsDir(): string
        +getSkillsDir(): string
        +getNarrativePath(): string
        +getEvolutionPrinciplesPath(): string
        +getReflectionLogPath(): string
    }
}

package "Safety" {
    class "Canary" as Canary << (M,#FFD700) module >> {
        +trigger: forked child by solidify pipeline
        +exit_0: safe
        +exit_nonzero: broken index.js
        --
        ' no exported methods; runs as child process
    }
}

package "Hub Integration" {
    class "TaskReceiver" as TaskReceiver << (M,#ADD8E6) module >> {
        +HUB_URL: process.env.A2A_HUB_URL
        +TASK_STRATEGY: greedy|balanced|conservative
        +TASK_MIN_CAPABILITY_MATCH: number
        +MIN_COMMITMENT_MS: 300000
        +MAX_COMMITMENT_MS: 86400000
        --
        +fetchTasks(opts?: { questions? }): Promise<object>
        +selectBestTask(tasks: Array, memoryEvents?: Array): object|null
        +estimateCapabilityMatch(task: object, memoryEvents: Array): number
        +scoreTask(task: object, capabilityMatch: number): object
        +claimTask(taskId: string, opts?: object): Promise<boolean>
        +completeTask(taskId: string, assetId: string): Promise<boolean>
        +taskToSignals(task: object): string[]
        +taskToSignalsWithPrivacy(task: object): string[]
        +detectPrivacyTask(task: object): object|null
        +claimWorkerTask(taskId: string): Promise<object|null>
        +completeWorkerTask(assignmentId: string, resultAssetId: string): Promise<boolean>
        +estimateCommitmentDeadline(task: object): string|null
    }
}

' External dependencies (shown as boundary actors)
class "a2aProtocol" as a2aProtocol << (E,#C8E6C9) external >> {
    +startHeartbeat(): void
    +startEventStream(): void
    +getHubUrl(): string
    +buildHubHeaders(): object
    +getNodeId(): string
}

class "solidify" as solidify << (E,#C8E6C9) external >> {
    +solidify(opts: object): Promise<void>
}

' ─── Relationships ───────────────────────────────────────────────

' index → EvolveOrchestrator: calls run() each loop cycle
index ..> EvolveOrchestrator : <<calls>>\nevolve.run()

' index → Paths: resolves file system paths
index ..> Paths : <<uses>>\npath resolution

' index → TaskReceiver: fetches urgent question bounties
index ..> TaskReceiver : <<uses>>\nfetchTasks({ questions })

' index → solidify pipeline
index ..> solidify : <<invokes>>\nsolidify({ intent, dryRun })

' index → a2aProtocol: network / heartbeat
index ..> a2aProtocol : <<uses>>\nstartHeartbeat/EventStream

' Canary load-tests index.js as a child process
Canary ..> index : <<load-tests>>\nrequire('../index.js')

' TaskReceiver → a2aProtocol: node identity & hub headers
TaskReceiver ..> a2aProtocol : <<depends on>>\ngetNodeId(), buildHubHeaders()

note bottom of Config
  All constants are module-level singletons.
  Every value is env-overridable via
  envInt / envFloat / envStr helpers.
  No class state — zero external dependencies.
end note

note bottom of Paths
  Singleton cache: _cachedRepoRoot is
  resolved once per process lifetime.
  All paths env-overridable.
  Dependencies: only Node.js path + fs.
end note

note right of Canary
  Safety gate in the solidify pipeline.
  Forks a child process that attempts
  require('../index.js').
  exit(0) = safe ✔  |  exit(≠0) = broken ✘
end note

@enduml
