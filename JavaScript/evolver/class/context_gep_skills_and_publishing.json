{
  "scope": "gep_skills_and_publishing",
  "title": "GEP Skills & Publishing",
  "diagram_type": "class",
  "description": "Skill distillation, hub publishing, self-PR, issue reporting, question generation, and execution tracing",

  "classes": [
    {
      "name": "skillDistiller",
      "file": "src/gep/skillDistiller.js",
      "note": "Obfuscated/minified (444KB). Core gene-to-skill distillation engine.",
      "exported_symbols": ["sanitizeSignalsMatch"],
      "key_role": "Distills successful gene capsules into reusable skills; sanitizes signal arrays before publishing"
    },
    {
      "name": "skillPublisher",
      "file": "src/gep/skillPublisher.js",
      "functions": [
        "sanitizeSkillName(rawName): string|null",
        "toTitleCase(kebabName): string",
        "deriveFallbackName(gene): string",
        "geneToSkillMd(gene): string",
        "extractStepVerb(step): string",
        "stripLeadingVerb(step): string",
        "publishSkillToHub(gene, opts): Promise<{ok,result?,error?}>",
        "updateSkillOnHub(nodeId, skillId, content, opts, gene): Promise<{ok,result?,error?>}"
      ],
      "exports": ["geneToSkillMd", "publishSkillToHub", "updateSkillOnHub", "sanitizeSkillName", "toTitleCase"],
      "dependencies": ["a2aProtocol", "skillDistiller"],
      "key_data": {
        "publish_endpoint": "POST /a2a/skill/store/publish",
        "update_endpoint": "PUT /a2a/skill/store/update",
        "timeout_ms": 15000,
        "on_409": "calls updateSkillOnHub()",
        "skill_id_format": "skill_{kebab_name}",
        "body_fields": ["sender_id", "skill_id", "content", "category", "tags"]
      }
    },
    {
      "name": "selfPR",
      "file": "src/gep/selfPR.js",
      "functions": [
        "normalizeRel(filePath): string",
        "isPublicNonObfuscated(filePath): boolean",
        "getStatePath(): string",
        "readState(): {lastPRAt, recentDiffHashes}",
        "writeState(state): void",
        "isInCooldown(): boolean",
        "computeDiffHash(changedFiles, repoRoot): string",
        "isDuplicateDiff(diffHash): boolean",
        "recordPR(diffHash): void",
        "buildPRBody({capsule,mutation,gene,blastRadius}): string",
        "buildPRTitle(mutation): string",
        "runGh(args, opts): {ok, out, err?}",
        "getGitDiff(changedFiles, repoRoot): string",
        "maybeCreatePR({capsule,event,mutation,gene,blastRadius}): Promise<result|null>"
      ],
      "exports": ["maybeCreatePR", "isPublicNonObfuscated", "isInCooldown", "isDuplicateDiff", "computeDiffHash", "buildPRTitle", "buildPRBody", "readState", "writeState", "recordPR"],
      "dependencies": ["paths", "sanitize", "config"],
      "key_data": {
        "env_gate": "EVOLVER_SELF_PR=true",
        "state_file": "self_pr_state.json",
        "gates_in_order": ["env_gate", "min_score", "min_streak", "category=optimize", "risk=low", "max_files", "max_lines", "public_non_obfuscated", "cooldown", "dedup_diff_hash", "leak_scan"],
        "cooldown": "SELF_PR_COOLDOWN_MS (24h default)",
        "pr_flow": "gh repo clone → git checkout -b → copy files → git add/commit/push → gh pr create --label auto-mutation"
      }
    },
    {
      "name": "issueReporter",
      "file": "src/gep/issueReporter.js",
      "functions": [
        "getConfig(): {repo, cooldownMs, minStreak}|null",
        "getGithubToken(): string",
        "getStatePath(): string",
        "readState(): {lastReportedAt, recentIssueKeys}",
        "writeState(state): void",
        "truncateNodeId(nodeId): string",
        "computeErrorKey(signals): string",
        "extractErrorSignature(signals): string",
        "extractStreakCount(signals): number",
        "formatRecentEvents(events): string",
        "buildIssueBody(opts): string",
        "shouldReport(signals, config): boolean",
        "createGithubIssue(repo, title, body, token): Promise<{number,url}>",
        "escapeSearchQuery(s): string",
        "findExistingIssue(repo, title, token): Promise<{number,url,title}|null>",
        "maybeReportIssue(opts): Promise<void>"
      ],
      "exports": ["maybeReportIssue", "buildIssueBody", "shouldReport", "findExistingIssue"],
      "dependencies": ["paths", "envFingerprint", "sanitize", "a2aProtocol"],
      "key_data": {
        "env_gate": "EVOLVER_AUTO_ISSUE (default true)",
        "state_file": "issue_reporter_state.json",
        "default_repo": "autogame-17/capability-evolver",
        "cooldown_ms": "24h default",
        "min_streak": 5,
        "trigger_conditions": ["failure_loop_detected", "recurring_error+high_failure_ratio"],
        "github_api": "POST https://api.github.com/repos/{repo}/issues",
        "dedup": "findExistingIssue() skips if open issue with same title exists"
      }
    },
    {
      "name": "questionGenerator",
      "file": "src/gep/questionGenerator.js",
      "functions": [
        "readState(): {lastAskedAt, lastUrgentAt, recentQuestions}",
        "writeState(state): void",
        "isDuplicate(question, recentQuestions): boolean",
        "extractErrorContext(transcript, maxLen): string",
        "extractRecentGeneIds(recentEvents, count): string[]",
        "buildStandardCandidates(signals, recentEvents, transcript, memory): Candidate[]",
        "buildUrgentCandidates(opts): Candidate[]",
        "generateQuestions(opts): {question,amount,signals}[]",
        "generateUrgentQuestions(opts): {question,amount,signals}[]"
      ],
      "exports": ["generateQuestions", "generateUrgentQuestions"],
      "dependencies": ["paths"],
      "key_data": {
        "state_file": "question_generator_state.json",
        "standard_cooldown_ms": "30 min",
        "urgent_cooldown_ms": "5 min",
        "max_per_cycle": 3,
        "max_urgent": 2,
        "standard_strategies": [
          "recurring_error → error signature question",
          "capability_gap → context question",
          "evolution_saturation → new directions question",
          "consecutive_failure_streak ≥3 → external help question",
          "user_feature_request → community solutions question",
          "perf_bottleneck → optimization question",
          "hub_search_miss_with_problem → ecosystem gap question",
          "repair_loop_detected → architectural help question",
          "plateau_pivot_required/suggested → paradigm shift question"
        ],
        "urgent_strategies": [
          "validationFailed → patch validation question",
          "lowConfidence → confidence score question",
          "llmReviewRejected → alternative impl question",
          "zeroBlastRadius + hadSignals → concrete steps question",
          "taskCompletionFailed → capability help question"
        ]
      }
    },
    {
      "name": "executionTrace",
      "file": "src/gep/executionTrace.js",
      "functions": [
        "getTraceLevel(): 'none'|'minimal'|'standard'|'collaboration'",
        "desensitizeFilePath(filePath): string|null",
        "extractErrorSignature(errorText): string|null",
        "inferToolChain(validationResults, blast): string[]",
        "classifyBlastLevel(blast): 'low'|'medium'|'high'|'unknown'",
        "buildExecutionTrace({gene,mutation,signals,blast,constraintCheck,validation,canary,outcomeStatus,startedAt,collaborationContext}): TraceObject|null"
      ],
      "exports": ["buildExecutionTrace", "desensitizeFilePath", "extractErrorSignature", "inferToolChain", "classifyBlastLevel", "getTraceLevel"],
      "dependencies": ["path (Node built-in)"],
      "key_data": {
        "env_var": "EVOLVER_TRACE_LEVEL: none|minimal|standard|collaboration (default: minimal)",
        "trace_levels": {
          "none": "returns null",
          "minimal": "gene_id, mutation_category, signals_matched, outcome, files_changed_count, lines_added/removed, validation_result, blast_radius",
          "standard": "adds file_types, validation_commands, error_signatures, tool_chain, validation_duration_ms, canary_ok",
          "collaboration": "adds collaboration block: role_decision, context_consumption, delegations, review_feedback, role_switch, session_id, team_size"
        },
        "desensitization": [
          "file paths → basename+ext only",
          "errors → type signature only (TypeError, ENOENT, HTTP_404)",
          "code content → never included",
          "secrets/env vars → stripped"
        ],
        "blast_thresholds": {
          "low": "≤3 files AND ≤50 lines",
          "medium": "≤10 files AND ≤200 lines",
          "high": "otherwise"
        }
      }
    }
  ],

  "key_relationships": [
    "skillPublisher depends_on skillDistiller (sanitizeSignalsMatch for signal cleaning)",
    "skillPublisher depends_on a2aProtocol (getHubUrl, buildHubHeaders, getNodeId)",
    "skillPublisher calls geneToSkillMd() then publishSkillToHub() → updateSkillOnHub() on 409",
    "selfPR depends_on paths (getEvolutionDir, getRepoRoot)",
    "selfPR depends_on sanitize (fullLeakCheck, redactString)",
    "selfPR depends_on config (SELF_PR_* constants)",
    "issueReporter depends_on envFingerprint (captureEnvFingerprint)",
    "issueReporter depends_on sanitize (redactString)",
    "issueReporter depends_on a2aProtocol (getNodeId)",
    "issueReporter depends_on paths (getEvolutionDir)",
    "questionGenerator depends_on paths (getEvolutionDir)",
    "executionTrace depends_on path (Node built-in only)",
    "All stateful modules read/write JSON state files under getEvolutionDir()"
  ],

  "shared_patterns": [
    "All modules use readState()/writeState() pattern with JSON files in evolutionDir",
    "All publishing/reporting modules are env-gated and cooldown-guarded",
    "skillPublisher and issueReporter both interact with external APIs (Hub, GitHub)",
    "selfPR and issueReporter both use deduplication (hash-based and title-based)",
    "sanitize.redactString() used by selfPR, issueReporter for PII/secret stripping",
    "a2aProtocol.getNodeId() used by skillPublisher and issueReporter as sender identity"
  ],

  "data_types": {
    "Gene": "{ id, summary, signals_match[], preconditions[], strategy[], constraints, validation[], category, schema_version, _distilled_meta }",
    "Capsule": "{ id, outcome: {score, status, reason}, success_streak, trigger[], genes_used[], intent }",
    "Mutation": "{ category, risk, rationale }",
    "BlastRadius": "{ files, lines, all_changed_files[], changed_files[] }",
    "TraceObject": "{ gene_id, mutation_category, signals_matched[], outcome, files_changed_count, lines_added, lines_removed, validation_result, blast_radius, ...level-specific fields, created_at }",
    "Question": "{ question: string, amount: number, signals: string[] }",
    "PRResult": "{ attempted: boolean, ok?: boolean, pr_url?: string, branch?: string, diff_hash?: string, reason?: string }",
    "IssueResult": "{ number: number, url: string }"
  },

  "important_notes": [
    "skillDistiller.js is obfuscated (444KB minified) - listed in OBFUSCATED_FILES in selfPR.js",
    "skillPublisher.geneToSkillMd() generates SKILL.md with frontmatter: name, description, When to Use, Trigger Signals, Preconditions, Strategy, Constraints, Validation, Metadata",
    "selfPR uses gh CLI (not GitHub API) for PR creation via execSync",
    "issueReporter uses GitHub REST API directly with Bearer token",
    "executionTrace is the only module with no external dependencies (pure Node built-ins)",
    "questionGenerator feeds into Hub A2A fetch payload.questions field for bounty creation"
  ],

  "source_files_analyzed": [
    "src/gep/skillPublisher.js",
    "src/gep/selfPR.js",
    "src/gep/issueReporter.js",
    "src/gep/questionGenerator.js",
    "src/gep/executionTrace.js",
    "src/gep/skillDistiller.js (obfuscated - metadata only)"
  ]
}
