{
  "scope": "ops_lifecycle_and_monitoring",
  "title": "Ops Lifecycle & Monitoring",
  "diagram_type": "class",
  "modules": [
    {
      "name": "Lifecycle",
      "file": "src/ops/lifecycle.js",
      "exports": ["start", "stop", "restart", "status", "tailLog", "checkHealth", "getRunningPids"],
      "methods": [
        "start(options): {status, pid|pids}",
        "stop(): {status, killed}",
        "restart(options): {status, pid}",
        "status(): {running, pids[], log}",
        "tailLog(lines): {file, content}|{error}",
        "checkHealth(): {healthy, reason?, silenceMinutes?, pids?}",
        "getRunningPids(): number[]",
        "isPidRunning(pid): boolean",
        "getCmdLine(pid): string|null",
        "getLoopScript(): string"
      ],
      "key_attributes": [
        "WORKSPACE_ROOT: string (from paths.getWorkspaceRoot)",
        "LOG_FILE: string (from paths.getEvolverLogPath)",
        "PID_FILE: memory/evolver_loop.pid",
        "MAX_SILENCE_MS: number (from config)"
      ],
      "dependencies": ["../gep/paths", "../config", "child_process", "fs", "path"],
      "behavior": "Spawns/stops detached node --loop process; checkHealth detects stagnation via log mtime vs MAX_SILENCE_MS"
    },
    {
      "name": "HealthCheck",
      "file": "src/ops/health_check.js",
      "exports": ["runHealthCheck"],
      "methods": [
        "runHealthCheck(): {status, timestamp, checks[]}",
        "getDiskUsage(mount): {pct, freeMb}|{pct, freeMb, error}"
      ],
      "key_attributes": [
        "criticalSecrets: ['FEISHU_APP_ID', 'FEISHU_APP_SECRET']",
        "optionalSecrets: ['OPENAI_API_KEY']",
        "status: 'ok'|'warning'|'error'",
        "_procCache: number (60s TTL, linux only)"
      ],
      "checks": [
        "env secrets (critical/warning/info severity)",
        "disk_space: >90% = critical, >80% = warning",
        "memory: >95% = critical",
        "process_count: >2000 = warning (linux only, 60s cache)"
      ],
      "dependencies": ["fs", "os", "child_process"]
    },
    {
      "name": "SelfRepair",
      "file": "src/ops/self_repair.js",
      "exports": ["repair"],
      "methods": [
        "repair(gitRoot?): string[]"
      ],
      "key_attributes": [
        "LOCK_MAX_AGE_MS: number (from config)",
        "EVOLVE_GIT_RESET: env flag for hard reset"
      ],
      "repair_steps": [
        "abort pending rebase (git rebase --abort)",
        "abort pending merge (git merge --abort)",
        "remove stale .git/index.lock if age > LOCK_MAX_AGE_MS",
        "hard reset to origin/main if EVOLVE_GIT_RESET=true, else git fetch origin"
      ],
      "returns": "array of action strings: ['rebase_aborted','merge_aborted','stale_lock_removed','fetch_ok'|'hard_reset_to_origin']",
      "dependencies": ["../gep/paths", "../config", "child_process", "fs", "path"]
    },
    {
      "name": "Cleanup",
      "file": "src/ops/cleanup.js",
      "exports": ["run"],
      "methods": [
        "run(): number",
        "safeBatchDelete(batch: string[]): number"
      ],
      "key_attributes": [
        "MAX_AGE_MS: CLEANUP_MAX_AGE_MS (from config)",
        "MIN_KEEP: CLEANUP_MIN_KEEP (from config)",
        "MAX_FILES: CLEANUP_MAX_FILES (from config)",
        "target: gep_prompt_*.json|txt in evolutionDir"
      ],
      "phases": [
        "Phase 1: Age-based — delete files older than MAX_AGE_MS, skip first MIN_KEEP newest",
        "Phase 2: Cap-based — if count > MAX_FILES, delete oldest beyond cap"
      ],
      "dependencies": ["../gep/paths", "../config", "fs", "path"]
    },
    {
      "name": "SkillsMonitor",
      "file": "src/ops/skills_monitor.js",
      "exports": ["run", "checkSkill", "autoHeal"],
      "methods": [
        "run(options?: {autoHeal:boolean}): Array<{name, issues[]}>",
        "checkSkill(skillName): {name, issues[]}|null",
        "autoHeal(skillName, issues[]): string[]"
      ],
      "key_attributes": [
        "IGNORE_LIST: Set<string> (common, input-validator, proactive-agent, security-audit + .skill_monitor_ignore file)",
        "mainFile: resolved from package.json#main or 'index.js'"
      ],
      "checks_per_skill": [
        "package.json valid/exists",
        "node_modules exists and non-empty if dependencies declared",
        "SKILL.md presence (if has package.json)"
      ],
      "auto_heal_actions": [
        "npm install --production (missing/empty node_modules)",
        "create SKILL.md stub (missing SKILL.md)"
      ],
      "dependencies": ["../gep/paths", "child_process", "fs", "path"]
    },
    {
      "name": "Innovation",
      "file": "src/ops/innovation.js",
      "exports": ["generateInnovationIdeas"],
      "methods": [
        "generateInnovationIdeas(): string[]",
        "listSkills(): string[]"
      ],
      "logic": "Categorizes skills by prefix/keyword into feishu/dev/media/security/automation/data; finds 2 weakest categories; generates targeted ideas; returns top 3",
      "categories": ["feishu", "dev", "media", "security", "automation", "data"],
      "dependencies": ["../gep/paths", "fs", "path"]
    },
    {
      "name": "Trigger",
      "file": "src/ops/trigger.js",
      "exports": ["send", "clear", "isPending"],
      "methods": [
        "send(): boolean",
        "clear(): void",
        "isPending(): boolean"
      ],
      "key_attributes": [
        "WAKE_FILE: memory/evolver_wake.signal"
      ],
      "behavior": "File-based wake signal; send() writes 'WAKE' to file; clear() removes it; isPending() checks existence",
      "dependencies": ["../gep/paths", "fs", "path"]
    }
  ],
  "shared_dependencies": {
    "../gep/paths": ["getRepoRoot", "getWorkspaceRoot", "getEvolverLogPath", "getEvolutionDir", "getSkillsDir"],
    "../config": ["MAX_SILENCE_MS", "LOCK_MAX_AGE_MS", "CLEANUP_MAX_AGE_MS", "CLEANUP_MIN_KEEP", "CLEANUP_MAX_FILES"]
  },
  "key_relationships": [
    "Lifecycle uses HealthCheck logic internally (checkHealth method)",
    "Lifecycle depends_on config.MAX_SILENCE_MS for stagnation detection",
    "SelfRepair depends_on config.LOCK_MAX_AGE_MS",
    "Cleanup depends_on config.CLEANUP_MAX_AGE_MS, CLEANUP_MIN_KEEP, CLEANUP_MAX_FILES",
    "SkillsMonitor depends_on paths.getSkillsDir",
    "Innovation depends_on paths.getSkillsDir (via listSkills)",
    "Trigger depends_on paths.getWorkspaceRoot (WAKE_FILE path)",
    "All modules depend_on ../gep/paths",
    "Lifecycle orchestrates: start→spawn process, stop→SIGTERM/SIGKILL, restart→stop+start",
    "SkillsMonitor.run() calls checkSkill() then autoHeal() per skill"
  ],
  "important_notes": [
    "All modules are plain JS function-export style (no classes)",
    "Lifecycle.checkHealth() is separate from HealthCheck.runHealthCheck() — former checks process liveness+log stagnation, latter checks system resources",
    "SelfRepair is git-focused only; EVOLVE_GIT_RESET env guards hard reset",
    "SkillsMonitor has configurable IGNORE_LIST via .skill_monitor_ignore file",
    "Innovation returns max 3 ideas; triggered externally on stagnation detection",
    "Trigger uses filesystem signal file for inter-process wake-up (polling pattern)"
  ],
  "source_files_analyzed": [
    "src/ops/lifecycle.js",
    "src/ops/health_check.js",
    "src/ops/self_repair.js",
    "src/ops/cleanup.js",
    "src/ops/skills_monitor.js",
    "src/ops/innovation.js",
    "src/ops/trigger.js"
  ]
}
