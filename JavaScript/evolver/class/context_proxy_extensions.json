{
  "scope": "proxy_extensions",
  "title": "Proxy Extensions",
  "diagram_type": "class",
  "description": "Session collaboration, DM messaging, skill hot-updating, and task monitoring extensions for the agent proxy layer.",

  "classes": [
    {
      "name": "SessionHandler",
      "file": "src/proxy/extensions/sessionHandler.js",
      "constructor_params": ["store", "logger"],
      "properties": ["store", "logger"],
      "methods": [
        "createSession({ title, description, inviteNodeIds, maxParticipants }): Promise",
        "joinSession({ sessionId }): Promise",
        "leaveSession({ sessionId }): Promise",
        "sendMessage({ sessionId, toNodeId, msgType, payload }): Promise",
        "delegateSubtask({ sessionId, toNodeId, title, description, role }): Promise",
        "submitResult({ sessionId, taskId, resultAssetId, summary }): Promise",
        "pollInvites({ limit }): Array",
        "pollSessionEvents({ limit }): Array",
        "listActiveSessions(): Array"
      ],
      "store_message_types": ["session_create", "session_join", "session_leave", "session_message", "session_delegate", "session_submit"],
      "store_poll_types": ["collaboration_invite", "session_event"],
      "validations": [
        "title required for createSession/delegateSubtask",
        "sessionId required for most methods",
        "taskId required for submitResult",
        "payload max 16KB in sendMessage",
        "inviteNodeIds capped at 10",
        "maxParticipants clamped 2–20 (default 5)",
        "role validated: builder|planner|reviewer (default builder)",
        "summary truncated to 200 chars"
      ]
    },
    {
      "name": "DmHandler",
      "file": "src/proxy/extensions/dmHandler.js",
      "constructor_params": ["store", "logger"],
      "properties": ["store", "logger"],
      "methods": [
        "send({ recipientNodeId, content, metadata }): Promise",
        "poll({ limit }): Array",
        "ack(messageIds): Promise",
        "list({ limit, offset }): Array"
      ],
      "store_message_types": ["dm"],
      "validations": [
        "recipientNodeId required",
        "content required"
      ]
    },
    {
      "name": "SkillUpdater",
      "file": "src/proxy/extensions/skillUpdater.js",
      "constructor_params": ["store", "skillPath", "logger"],
      "properties": ["store", "skillPath", "logger"],
      "external_dependencies": ["fs (Node.js)", "path (Node.js)"],
      "methods": [
        "setSkillPath(filePath): void",
        "processSkillUpdate(message): boolean",
        "pollAndApply(): number"
      ],
      "store_message_types_polled": ["skill_update"],
      "store_state_keys": ["last_skill_update", "skill_version"],
      "file_operations": [
        "mkdirSync (recursive dir creation)",
        "copyFileSync (backup to .bak before overwrite)",
        "writeFileSync (write new skill.md content)"
      ],
      "flow": [
        "pollAndApply() → store.poll({type:'skill_update'})",
        "for each msg → processSkillUpdate(msg)",
        "processSkillUpdate: validate skillPath + content → backup existing → writeFile → setState → ack"
      ]
    },
    {
      "name": "TaskMonitor",
      "file": "src/proxy/task/monitor.js",
      "constructor_params": ["store", "logger"],
      "properties": ["store", "logger", "_stats (object)"],
      "private_state": {
        "_stats": {
          "fields": ["tasks_received", "tasks_claimed", "tasks_completed", "tasks_failed", "last_claim_at", "last_complete_at", "avg_completion_ms", "_completion_times (rolling window 100)"]
        }
      },
      "methods": [
        "_restoreStats(): void  [constructor, reads store state]",
        "get subscribed(): boolean  [reads 'task_subscription' state]",
        "subscribe(filters): Promise",
        "unsubscribe(): Promise",
        "recordClaim(taskId): void",
        "recordComplete(taskId, startedAt): void  [updates rolling avg]",
        "recordFailed(taskId): void",
        "recordTaskReceived(count): void",
        "getMetrics(): object",
        "getHeartbeatMeta(): object"
      ],
      "store_message_types": ["task_subscribe", "task_unsubscribe"],
      "store_state_keys": ["task_monitor_stats", "task_subscription"],
      "store_queries": ["countPending({direction:'inbound'})"],
      "metrics_shape": {
        "getMetrics": ["subscribed", "tasks_received", "tasks_claimed", "tasks_completed", "tasks_failed", "tasks_pending", "last_claim_at", "last_complete_at", "avg_completion_ms"],
        "getHeartbeatMeta": ["task_subscription", "task_metrics{pending, claimed, completed, failed, avg_completion_ms}"]
      }
    }
  ],

  "shared_dependency": {
    "name": "store",
    "type": "injected interface (duck-typed)",
    "methods_used": [
      "store.send({ type, payload, priority? })",
      "store.poll({ type, limit })",
      "store.ack(messageIds)",
      "store.list({ type, direction, limit, offset })",
      "store.setState(key, value)",
      "store.getState(key)",
      "store.countPending({ direction })"
    ]
  },

  "key_relationships": [
    "SessionHandler depends_on store (composition via constructor injection)",
    "DmHandler depends_on store (composition via constructor injection)",
    "SkillUpdater depends_on store (composition via constructor injection)",
    "SkillUpdater depends_on fs (Node built-in, file I/O)",
    "SkillUpdater depends_on path (Node built-in, path resolution)",
    "TaskMonitor depends_on store (composition via constructor injection)",
    "All four classes share the same store interface contract",
    "All four classes accept optional logger (defaults to console)"
  ],

  "design_patterns": [
    "Dependency injection: store and logger passed via constructor",
    "Duck-typed store interface — no formal interface class defined",
    "Rolling window average: TaskMonitor._stats._completion_times capped at 100 entries",
    "Backup-before-write: SkillUpdater copies .bak before overwriting skill.md",
    "State persistence: TaskMonitor restores metrics from store state on construction"
  ],

  "important_notes": "All classes are plain ES5-style classes (no extends). Exported via CommonJS module.exports. No shared base class — they share the store interface only. SkillUpdater is the only class with filesystem access. TaskMonitor is the only class with a getter property (subscribed). SessionHandler is the most feature-rich with 6 send operations + 2 poll types + 1 list.",

  "source_files_analyzed": [
    "src/proxy/extensions/sessionHandler.js",
    "src/proxy/extensions/dmHandler.js",
    "src/proxy/extensions/skillUpdater.js",
    "src/proxy/task/monitor.js"
  ]
}
