@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam interface {
    BackgroundColor #D0E8FF
    BorderColor #3A7FC1
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}
skinparam ArrowColor #495057
skinparam ArrowThickness 1.2

title Evolver — System Component Diagram

' ─────────────────────────────────────────
' EXTERNAL SYSTEMS
' ─────────────────────────────────────────
package "External Systems" <<Cloud>> {
    [A2A Hub API] as hub
    [LLM Provider\n(Claude / Codex / Cursor)] as llm
    [GitHub / Git Remote] as git
}

' ─────────────────────────────────────────
' ENTRY POINT
' ─────────────────────────────────────────
package "Entry Point" {
    [index.js\n(Loop Bridge)] as entry
    note right of entry
      Lock management,
      loop-bridge control,
      solidify rejection
    end note
}

' ─────────────────────────────────────────
' CORE ENGINE
' ─────────────────────────────────────────
package "Core Engine  (src/)" {

    [Evolve Orchestrator\n(src/evolve.js)] as evolve

    package "GEP — Growth & Evolution Protocol  (src/gep/)" {

        package "Strategy & Selection" {
            [Strategy Engine\n(strategy.js)] as strategy
            [Candidate Selector\n(selector.js / candidates.js)] as selector
            [Candidate Evaluator\n(candidateEval.js)] as candidateEval
        }

        package "Learning & Memory" {
            [Memory Graph\n(memoryGraph.js)] as memoryGraph
            [Narrative Memory\n(narrativeMemory.js)] as narrativeMemory
            [Learning Signals\n(signals.js / learningSignals.js)] as signals
            [Curriculum\n(curriculum.js)] as curriculum
            [Mutation Engine\n(mutation.js)] as mutation
        }

        package "Skill Management" {
            [Skill Distiller\n(skillDistiller.js)] as skillDistiller
            [Skill Publisher\n(skillPublisher.js)] as skillPublisher
            [Solidify\n(solidify.js)] as solidify
        }

        package "Hub Integration" {
            [Hub Search\n(hubSearch.js)] as hubSearch
            [Hub Verify\n(hubVerify.js)] as hubVerify
            [Hub Review\n(hubReview.js)] as hubReview
            [A2A Protocol\n(a2aProtocol.js / a2a.js)] as a2aProto
        }

        package "Safety & Validation" {
            [Shield\n(shield.js)] as shield
            [Policy Check\n(policyCheck.js)] as policyCheck
            [Integrity Check\n(integrityCheck.js)] as integrityCheck
            [Validation Report\n(validationReport.js)] as validationReport
        }

        package "Task & Scheduling" {
            [Task Receiver\n(taskReceiver.js)] as taskReceiver
            [Idle Scheduler\n(idleScheduler.js)] as idleScheduler
            [LLM Prompt Builder\n(prompt.js)] as promptBuilder
        }

        package "Utilities" {
            [Asset Store\n(assetStore.js)] as assetStore
            [Mailbox Transport\n(mailboxTransport.js)] as mailboxTransport
            [Self PR\n(selfPR.js)] as selfPR
            [Paths & Config\n(paths.js / config.js)] as gepConfig
            [Reflection\n(reflection.js)] as reflection
        }
    }
}

' ─────────────────────────────────────────
' PROXY LAYER
' ─────────────────────────────────────────
package "Proxy Server  (src/proxy/)" {

    [EvoMapProxy\n(proxy/index.js)] as proxy

    package "Server" {
        [HTTP Server\n(server/http.js)] as httpServer
        [Route Handlers\n(server/routes.js)] as routes
        [Settings Store\n(server/settings.js)] as proxySettings
    }

    package "Mailbox" {
        [Mailbox Store\n(mailbox/store.js)] as mailboxStore
    }

    package "Sync" {
        [Sync Engine\n(sync/engine.js)] as syncEngine
        [Outbound Sync\n(sync/outbound.js)] as outboundSync
        [Inbound Sync\n(sync/inbound.js)] as inboundSync
    }

    package "Lifecycle" {
        [Lifecycle Manager\n(lifecycle/manager.js)] as lifecycleManager
    }

    package "Task" {
        [Task Monitor\n(task/monitor.js)] as taskMonitor
    }

    package "Extensions" {
        [DM Handler\n(extensions/dmHandler.js)] as dmHandler
        [Skill Updater\n(extensions/skillUpdater.js)] as skillUpdater
        [Session Handler\n(extensions/sessionHandler.js)] as sessionHandler
    }
}

' ─────────────────────────────────────────
' ATP — AGENT TRANSACTION PROTOCOL
' ─────────────────────────────────────────
package "ATP — Agent Transaction Protocol  (src/atp/)" {
    [Hub Client\n(hubClient.js)] as atpHubClient
    [Merchant Agent\n(merchantAgent.js)] as merchantAgent
    [Consumer Agent\n(consumerAgent.js)] as consumerAgent
    [Service Helper\n(serviceHelper.js)] as serviceHelper
    [Default Handler\n(defaultHandler.js)] as atpDefaultHandler
}

' ─────────────────────────────────────────
' ADAPTERS — AI AGENT INTEGRATIONS
' ─────────────────────────────────────────
package "Agent Adapters  (src/adapters/)" {
    [Hook Adapter\n(hookAdapter.js)] as hookAdapter
    [Claude Code Adapter\n(claudeCode.js)] as claudeAdapter
    [OpenAI Codex Adapter\n(codex.js)] as codexAdapter
    [Cursor Adapter\n(cursor.js)] as cursorAdapter

    package "Adapter Scripts" {
        [Session Start\n(evolver-session-start.js)] as sessionStart
        [Session End\n(evolver-session-end.js)] as sessionEnd
        [Signal Detect\n(evolver-signal-detect.js)] as signalDetect
    }
}

' ─────────────────────────────────────────
' OPERATIONS
' ─────────────────────────────────────────
package "Operations  (src/ops/)" {
    [Lifecycle Ops\n(lifecycle.js)] as opsLifecycle
    [Skills Monitor\n(skills_monitor.js)] as opsSkillsMonitor
    [Self Repair\n(self_repair.js)] as opsSelfRepair
    [Cleanup\n(cleanup.js)] as opsCleanup
    [Trigger\n(trigger.js)] as opsTrigger
    [Commentary\n(commentary.js)] as opsCommentary
}

' ─────────────────────────────────────────
' SCRIPTS & TEST
' ─────────────────────────────────────────
package "Build & CI Scripts  (scripts/)" {
    [Script Utilities\n(getChangedFiles,\ncheckInterface, etc.)] as scripts
}

package "Test Suite  (test/)" {
    [Unit & Integration Tests] as tests
}

' ─────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────

' Entry Point
entry --> evolve : starts evolution loop
entry --> solidify : solidify / reject pending run

' Evolve Orchestrator → GEP
evolve --> strategy : drives evolution cycle
evolve --> selector : selects skill candidates
evolve --> solidify : commits evolution
evolve --> signals : reads learning signals
evolve --> gepConfig : reads config & paths
evolve --> promptBuilder : builds LLM prompts
evolve --> shield : safety checks

' Evolve → Proxy (for agent comms)
evolve --> proxy : spawns / communicates via proxy

' GEP internal
strategy --> selector : feeds selected candidates
strategy --> mutation : applies mutations
selector --> candidateEval : evaluates candidates
selector --> memoryGraph : queries memory
skillDistiller --> skillPublisher : publishes distilled skills
skillPublisher --> hubSearch : uploads to hub
solidify --> git : commits & pushes
selfPR --> git : opens pull requests
taskReceiver --> a2aProto : receives A2A tasks
taskReceiver --> mailboxTransport : reads mailbox
a2aProto --> hub : A2A messaging
hubSearch --> hub : search / publish skills
hubVerify --> hub : verify skill hashes
hubReview --> hub : pull reviews
promptBuilder --> llm : LLM API calls

' GEP → Proxy mailbox
mailboxTransport --> mailboxStore : reads/writes messages

' Proxy internals
proxy --> httpServer : hosts HTTP API
proxy --> mailboxStore : persists messages
proxy --> syncEngine : manages sync
proxy --> lifecycleManager : auth & lifecycle
proxy --> taskMonitor : monitors running tasks
proxy --> dmHandler : handles DMs
proxy --> skillUpdater : applies skill updates
proxy --> sessionHandler : manages sessions
httpServer --> routes : delegates routing
routes --> mailboxStore : reads/writes mailbox
routes --> proxySettings : reads/writes settings
syncEngine --> outboundSync : sends to hub
syncEngine --> inboundSync : polls from hub
syncEngine --> lifecycleManager : checks auth
outboundSync --> hub : pushes messages
inboundSync --> hub : polls messages

' ATP
atpHubClient --> hub : ATP endpoints
merchantAgent --> atpHubClient : publishes services
consumerAgent --> atpHubClient : discovers services
serviceHelper --> atpHubClient : registers services
atpDefaultHandler --> atpHubClient : handles orders

' Adapters
hookAdapter --> claudeAdapter : routes to Claude
hookAdapter --> codexAdapter : routes to Codex
hookAdapter --> cursorAdapter : routes to Cursor
hookAdapter --> gepConfig : reads config
claudeAdapter --> llm : installs Claude hooks
codexAdapter --> llm : installs Codex hooks
cursorAdapter --> llm : installs Cursor hooks
sessionStart --> signals : records session signals
sessionEnd --> signals : records session signals
signalDetect --> signals : detects & records signals

' Ops
opsLifecycle --> gepConfig : reads paths & config
opsSelfRepair --> opsTrigger : triggers repair run
opsSkillsMonitor --> hubSearch : checks hub for skills
opsCommentary --> hub : posts commentary

' Tests
tests ..> evolve : tests
tests ..> proxy : tests
tests ..> atpHubClient : tests
tests ..> signals : tests
tests ..> memoryGraph : tests

@enduml
