@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam node {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam artifact {
    BackgroundColor #DEE2E6
    BorderColor #6C757D
    FontColor #212529
}
skinparam database {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
    FontColor #0C5460
}
skinparam component {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}
skinparam cloud {
    BackgroundColor #E2D9F3
    BorderColor #6F42C1
    FontColor #212529
}

title EvoMap Evolver — Deployment Diagram\n(@evomap/evolver v1.67.1)

' ─────────────────────────────────────────────
' LOCAL DEVELOPER MACHINE
' ─────────────────────────────────────────────
node "Developer Machine" <<Host>> {

    node "Evolver Daemon\n(Node.js Process)" <<Runtime>> {
        artifact "index.js --loop" as evolverDaemon
        artifact "Evolution Engine\n(src/evolve.js)" as evolveEngine
        artifact "GEP Core\n(src/gep/*)" as gepCore
        artifact "ATP Agent\n(src/atp/*)" as atpAgent
        artifact "Ops Manager\n(src/ops/*)" as opsManager
    }

    node "EvoMap Proxy\n(Optional HTTP Server)" <<Service>> {
        artifact "Proxy HTTP Server\n(src/proxy/server/http.js)" as proxyServer
        artifact "Sync Engine\n(src/proxy/sync/engine.js)" as syncEngine
        artifact "Lifecycle Manager\n(src/proxy/lifecycle/manager.js)" as lifecycleManager
        artifact "Task Monitor\n(src/proxy/task/monitor.js)" as taskMonitor
    }

    node "AI Coding Tool" <<IDE Plugin>> {
        artifact "Claude Code\n(src/adapters/claudeCode.js)" as claudeCode
        artifact "Cursor\n(src/adapters/cursor.js)" as cursor
        artifact "Codex\n(src/adapters/codex.js)" as codex
    }

    database "Local Filesystem\n(~/.evomap)" as localFS {
        artifact "Evolution State\n(evolution_solidify_state.json)" as evolutionState
        artifact "Memory Graph\n(memoryGraph)" as memoryGraph
        artifact "Gene / Skill Assets\n(assetStore)" as assetStore
        artifact "Mailbox Store\n(mailbox/)" as mailboxStore
        artifact "Evolver Log\n(evolver.log)" as evolverLog
    }
}

' ─────────────────────────────────────────────
' EVOMAP HUB (External Cloud Service)
' ─────────────────────────────────────────────
cloud "EvoMap Hub\n(evomap.ai)" as evoMapHub {
    component "A2A Hub API\n(/a2a/*)" as a2aApi
    component "Skill Store\n(/a2a/skill/store)" as skillStore
    component "Task Queue\n(/a2a/tasks)" as taskQueue
    component "Hub Review\n(/a2a/review)" as hubReview
    component "Mailbox\n(/a2a/mailbox)" as hubMailbox
}

' ─────────────────────────────────────────────
' GITHUB (External VCS)
' ─────────────────────────────────────────────
cloud "GitHub\n(github.com)" as github {
    component "EvoMap/evolver\n(upstream repo)" as evolverRepo
    component "Target Repository\n(self-PR destination)" as targetRepo
}

' ─────────────────────────────────────────────
' INTERNAL CONNECTIONS (local)
' ─────────────────────────────────────────────
evolverDaemon --> evolveEngine : "invokes"
evolveEngine --> gepCore : "uses"
evolveEngine --> opsManager : "triggers ops"
evolverDaemon --> atpAgent : "starts (ATP auto mode)"
evolverDaemon --> localFS : "read/write state"
gepCore --> localFS : "persist genes,\nmemory, logs"
gepCore --> proxyServer : "HTTP\n(mailbox transport mode)"

' Hooks: IDE tool -> Evolver Daemon
claudeCode ..> evolverDaemon : "hook events\n(session-start/end,\nsignal-detect)"
cursor ..> evolverDaemon : "hook events"
codex ..> evolverDaemon : "hook events"

' Proxy internal
proxyServer --> syncEngine : "delegates sync"
proxyServer --> lifecycleManager : "hello / heartbeat"
proxyServer --> taskMonitor : "task meta"
syncEngine --> mailboxStore : "buffer messages"

' ─────────────────────────────────────────────
' EXTERNAL CONNECTIONS
' ─────────────────────────────────────────────

' Direct A2A transport (default)
gepCore --> a2aApi : "HTTPS\nA2A Protocol\n(heartbeat, SSE events,\nasset fetch/validate)"
gepCore --> skillStore : "HTTPS\n(skill download / publish)"
gepCore --> taskQueue : "HTTPS\n(fetch tasks / urgent questions)"
gepCore --> hubReview : "HTTPS\n(post-solidify review)"
atpAgent --> a2aApi : "HTTPS\n(merchant / consumer orders)"

' Mailbox transport (optional, via proxy)
syncEngine --> hubMailbox : "HTTPS\n(mailbox sync)"
lifecycleManager --> a2aApi : "HTTPS\n(node hello / heartbeat)"

' GitHub
gepCore --> evolverRepo : "HTTPS / git\n(self-PR: contribute mutations)"
gepCore --> targetRepo : "git\n(apply mutations,\nrollback)"

@enduml
