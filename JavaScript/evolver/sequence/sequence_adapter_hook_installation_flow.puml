@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequence {
    ArrowColor #495057
    ActorBorderColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    ParticipantBorderColor #495057
    ParticipantBackgroundColor #F8F9FA
    ParticipantFontColor #212529
    BoxBorderColor #6C757D
    BoxBackgroundColor #E9ECEF
    DividerBackgroundColor #DEE2E6
    NoteBackgroundColor #FFF3CD
    NoteBorderColor #FFC107
}

title IDE Adapter Hook Installation Flow

actor Caller as caller
participant "hookAdapter\n(setupHooks)" as setupHooks
participant "hookAdapter\n(loadAdapter)" as loadAdapter
participant "hookAdapter\n(mergeJsonFile /\ncopyHookScripts /\nappendSectionToFile)" as adapterUtils
participant "claudeCode\n(install)" as claudeCode
participant "codex\n(install)" as codex
participant "cursor\n(install)" as cursor
participant "FileSystem" as fs

== Entry Point ==

caller -> setupHooks: setupHooks({ platform?, cwd?, force?,\nuninstall?, evolverRoot? })
activate setupHooks

alt platform not provided
    setupHooks -> setupHooks: detectPlatform(cwd)\n[scan cwd then homedir\nfor .cursor / .claude / .codex]
end

alt platform not detected
    setupHooks --> caller: { ok: false, error: 'platform_not_detected' }
end

setupHooks -> setupHooks: resolveConfigRoot(platformId, cwd)\n[returns cwd or homedir\nbased on detector presence]

setupHooks -> loadAdapter: loadAdapter(platformId)
activate loadAdapter

alt platformId === 'claude-code'
    loadAdapter --> setupHooks: require('./claudeCode.js')
else platformId === 'codex'
    loadAdapter --> setupHooks: require('./codex.js')
else platformId === 'cursor'
    loadAdapter --> setupHooks: require('./cursor.js')
else no match
    loadAdapter --> setupHooks: null
    setupHooks --> caller: { ok: false, error: 'no_adapter' }
end

deactivate loadAdapter

== Already-Installed Guard ==

opt !force && _evolver_managed exists in config
    setupHooks --> caller: { ok: true, skipped: true }
end

== Claude Code Install Path ==

group Claude Code [platformId === 'claude-code']
    setupHooks -> claudeCode: adapter.install({ configRoot, evolverRoot, force })
    activate claudeCode

    claudeCode -> claudeCode: buildClaudeHooks(evolverRoot)\n→ hooks JSON\n  SessionStart → evolver-session-start.js (3s)\n  PostToolUse[matcher=Write] → evolver-signal-detect.js (2s)\n  Stop → evolver-session-end.js (8s)

    claudeCode -> adapterUtils: mergeJsonFile(.claude/settings.json, hooksCfg)
    activate adapterUtils
    adapterUtils -> fs: read .claude/settings.json (if exists)
    adapterUtils -> adapterUtils: deepMerge(existing, hooksCfg)\nset _evolver_managed = true
    adapterUtils -> fs: atomic write via .tmp rename
    adapterUtils --> claudeCode: ok
    deactivate adapterUtils

    claudeCode -> adapterUtils: copyHookScripts(.claude/hooks, evolverRoot/src/adapters)
    activate adapterUtils
    adapterUtils -> fs: copy evolver-session-start.js → .claude/hooks/ (chmod 755)
    adapterUtils -> fs: copy evolver-signal-detect.js → .claude/hooks/ (chmod 755)
    adapterUtils -> fs: copy evolver-session-end.js → .claude/hooks/ (chmod 755)
    note right of adapterUtils: warns if source script\nnot found, continues
    adapterUtils --> claudeCode: copiedFiles[]
    deactivate adapterUtils

    claudeCode -> adapterUtils: appendSectionToFile(CLAUDE.md, EVOLVER_MARKER, mdSection)
    activate adapterUtils
    adapterUtils -> fs: read CLAUDE.md
    alt EVOLVER_MARKER already present
        adapterUtils --> claudeCode: skipped (idempotent)
    else
        adapterUtils -> fs: append mdSection to CLAUDE.md
        adapterUtils --> claudeCode: ok
    end
    deactivate adapterUtils

    claudeCode --> setupHooks: { ok: true, platform: 'claude-code',\nfiles: [settings.json, CLAUDE.md, ...hooks] }
    deactivate claudeCode
end

== Codex Install Path ==

group Codex [platformId === 'codex']
    setupHooks -> codex: adapter.install({ configRoot, evolverRoot, force })
    activate codex

    codex -> codex: buildCodexHooksJson(evolverRoot)\n→ hooks JSON\n  SessionStart, PostToolUse (no matcher), Stop

    codex -> adapterUtils: mergeJsonFile(.codex/hooks.json, hooksCfg)
    activate adapterUtils
    adapterUtils -> fs: deepMerge + atomic write via .tmp rename
    adapterUtils --> codex: ok
    deactivate adapterUtils

    codex -> adapterUtils: copyHookScripts(.codex/hooks, evolverRoot/src/adapters)
    activate adapterUtils
    adapterUtils -> fs: copy 3 hook scripts → .codex/hooks/ (chmod 755)
    adapterUtils --> codex: copiedFiles[]
    deactivate adapterUtils

    codex -> codex: ensureConfigToml(.codex)\n→ add [features] codex_hooks=true\nto .codex/config.toml if absent
    codex -> fs: write .codex/config.toml

    codex -> adapterUtils: appendSectionToFile(AGENTS.md, EVOLVER_MARKER, mdSection)
    activate adapterUtils
    adapterUtils -> fs: idempotent marker-based append
    adapterUtils --> codex: ok
    deactivate adapterUtils

    codex --> setupHooks: { ok: true, platform: 'codex',\nfiles: [hooks.json, config.toml, AGENTS.md, ...hooks] }
    deactivate codex
end

== Cursor Install Path ==

group Cursor [platformId === 'cursor']
    setupHooks -> cursor: adapter.install({ configRoot, evolverRoot, force })
    activate cursor

    cursor -> cursor: buildHooksJson(evolverRoot, isUserLevel)\n[isUserLevel = configRoot === homedir]\n→ version=1 hooks JSON\n  sessionStart → evolver-session-start.js (3s)\n  afterFileEdit[matcher=Write] → evolver-signal-detect.js (2s)\n  stop[loop_limit=1] → evolver-session-end.js (8s)\n  [paths relative to isUserLevel flag]

    cursor -> adapterUtils: mergeJsonFile(.cursor/hooks.json, hooksCfg)
    activate adapterUtils
    adapterUtils -> fs: deepMerge + atomic write via .tmp rename
    adapterUtils --> cursor: ok
    deactivate adapterUtils

    cursor -> adapterUtils: copyHookScripts(.cursor/hooks, evolverRoot/src/adapters)
    activate adapterUtils
    adapterUtils -> fs: copy 3 hook scripts → .cursor/hooks/ (chmod 755)
    adapterUtils --> cursor: copiedFiles[]
    deactivate adapterUtils

    note over cursor: No markdown section written\n(unlike Claude Code / Codex)

    cursor --> setupHooks: { ok: true, platform: 'cursor',\nfiles: [hooks.json, ...hooks] }
    deactivate cursor
end

== Result ==

setupHooks --> caller: { ok: true, platform: <platformId>, files: [...] }
deactivate setupHooks

@enduml
