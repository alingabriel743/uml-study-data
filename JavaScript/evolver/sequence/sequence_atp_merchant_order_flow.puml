@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #495057
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceParticipantFontColor #212529
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #6C757D
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam sequenceGroupFontColor #212529
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F9A825

title ATP Merchant Order Handling Flow

actor Caller as caller
participant "merchantAgent" as merchant
participant "a2aProtocol" as a2a
participant "serviceHelper" as svcHelper
participant "defaultOrderHandler" as orderHandler
participant "hubClient" as hub
participant "Hub (HTTP)" as hubHttp

' ── Startup ─────────────────────────────────────────────────────────
caller -> merchant : start({ services, onOrder, pollMs })
activate merchant

merchant -> a2a : sendHelloToHub()
activate a2a
a2a -> hubHttp : POST /a2a/hello
activate hubHttp
hubHttp --> a2a : { ok, error? }
deactivate hubHttp
a2a --> merchant : helloResult
deactivate a2a

alt hello failed
    merchant -> merchant : _running = false
    merchant --> caller : return (early exit)
end

merchant -> a2a : getNodeId()
activate a2a
a2a --> merchant : nodeId  [logs registered node]
deactivate a2a

' ── Service Registration ─────────────────────────────────────────────
loop for each service in opts.services
    merchant -> svcHelper : publishService(svc)
    activate svcHelper
    svcHelper -> hubHttp : register service
    activate hubHttp
    hubHttp --> svcHelper : { ok: true } | { ok: false, error }
    deactivate hubHttp
    svcHelper --> merchant : publishResult
    deactivate svcHelper
end

' ── Heartbeat + Poll Setup ───────────────────────────────────────────
merchant -> a2a : startHeartbeat()
note right of a2a : Heartbeat runs independently\nin the background

merchant -> merchant : setInterval(pollMs = 30 000 ms)

' ── Poll Cycle ───────────────────────────────────────────────────────
loop every pollMs
    merchant -> a2a : consumeAvailableWork()
    activate a2a
    a2a --> merchant : work[]  (array of orders)
    deactivate a2a

    alt work is empty
        merchant -> merchant : skip iteration
    else orders available
        loop for each order in work
            merchant -> orderHandler : onOrder(order)
            activate orderHandler

            orderHandler -> orderHandler : inspect order.title\n& order.signals
            note right of orderHandler
                Branching logic:
                • "review" / code_review|bug → code review result
                • "translat" / translation|localization → translation result
                • "summar" / summarization|digest → summary result
                • fallback → generic task result
            end note

            orderHandler --> merchant : proofPayload {\n  result, output,\n  pass_rate: 1.0,\n  processed_at,\n  processor: 'evolver-default'\n}
            deactivate orderHandler

            alt proofPayload truthy AND order.atp_order_id present
                merchant -> hub : submitDelivery(order.atp_order_id, proofPayload)
                activate hub

                hub -> a2a : getNodeId()
                activate a2a
                a2a --> hub : nodeId (sender_id)
                deactivate a2a

                hub -> hubHttp : POST /a2a/atp/deliver\n{ sender_id, order_id, proof_payload }
                activate hubHttp
                note right of hubHttp : fetch() with\nAbortSignal.timeout
                hubHttp --> hub : { ok, data? } | { ok: false, error }
                deactivate hubHttp

                hub --> merchant : deliveryResult
                deactivate hub

                alt delivery.ok == true
                    merchant -> merchant : log "Delivered order: <id>"
                else delivery.ok == false
                    merchant -> merchant : warn "Delivery failed: <error>"
                end
            end
        end
    end
end

deactivate merchant

@enduml
