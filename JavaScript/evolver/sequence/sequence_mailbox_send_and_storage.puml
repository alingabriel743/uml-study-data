@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    BoxBackgroundColor #E9ECEF
    DividerBorderColor #6C757D
    GroupBorderColor #6C757D
    GroupBackgroundColor #DEE2E6
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Mailbox Message Send and Storage

participant "Caller" as caller
participant "MailboxStore" as store
participant "generateUUIDv7()" as uuid
participant "safeParse()" as parse
participant "_appendMessage()" as append
participant "appendLine()" as appendLine
database "messages.jsonl\n(fs)" as jsonl
collections "InMemoryIndex\n(_messages Map)" as memMap
collections "_outbound[] /\n_inbound[]" as indexArr

== send() — Outbound Message ==

caller -> store : send({ type, payload, channel,\npriority, refId, expiresAt })
activate store

store -> uuid : generateUUIDv7()
activate uuid
uuid --> store : id (UUIDv7, timestamp-prefixed)
deactivate uuid

store -> parse : safeParse(payload)
activate parse
parse --> store : parsed payload (JSON or object)
deactivate parse

note over store
  Constructs message:
  { id, channel (default: 'evomap-hub'),
    direction: 'outbound', type,
    status: 'pending', payload, priority,
    ref_id, created_at: Date.now(),
    synced_at: null, expires_at,
    retry_count: 0, error: null }
end note

store -> append : _appendMessage(msg)
activate append

append -> appendLine : appendLine(messagesFile, msg)
activate appendLine
appendLine -> jsonl : fs.appendFileSync(\n  messages.jsonl,\n  JSON.stringify(msg) + '\\n')
activate jsonl
jsonl --> appendLine : (written)
deactivate jsonl
appendLine --> append : (done)
deactivate appendLine

append -> memMap : _messages.set(msg.id, msg)
activate memMap
memMap --> append : (stored in Map)
deactivate memMap

append -> indexArr : _outbound.push(msg.id)
activate indexArr
indexArr --> append : (id appended)
deactivate indexArr

append --> store : (done)
deactivate append

store --> caller : { message_id: id, status: 'pending' }
deactivate store

== writeInbound() — Inbound Message for Local Consumer ==

caller -> store : writeInbound({ id?, type, payload,\nchannel, priority, refId, expiresAt })
activate store

opt id not provided
    store -> uuid : generateUUIDv7()
    activate uuid
    uuid --> store : msgId (UUIDv7)
    deactivate uuid
end

store -> parse : safeParse(payload)
activate parse
parse --> store : parsed payload
deactivate parse

note over store
  Constructs message:
  { id: msgId, channel,
    direction: 'inbound', type,
    status: 'pending', payload, priority,
    ref_id, created_at: Date.now(),
    synced_at: null, expires_at,
    retry_count: 0, error: null }
end note

store -> append : _appendMessage(msg)
activate append

append -> appendLine : appendLine(messagesFile, msg)
activate appendLine
appendLine -> jsonl : fs.appendFileSync(\n  messages.jsonl,\n  JSON.stringify(msg) + '\\n')
activate jsonl
jsonl --> appendLine : (written)
deactivate jsonl
appendLine --> append : (done)
deactivate appendLine

append -> memMap : _messages.set(msg.id, msg)
activate memMap
memMap --> append : (stored in Map)
deactivate memMap

append -> indexArr : _inbound.push(msg.id)
activate indexArr
indexArr --> append : (id appended)
deactivate indexArr

append --> store : (done)
deactivate append

store --> caller : msgId
deactivate store

== writeInboundBatch() — Bulk Inbound Write ==

caller -> store : writeInboundBatch(messages[])
activate store

loop for each message m in messages[]
    store -> store : writeInbound(m)
end

store --> caller : ids[]
deactivate store

== _rebuildIndex() — Replay JSONL on Init / Compact ==

note over store
  Called on construction and after compact().
  Replays the full JSONL log to restore
  in-memory state from disk.
end note

store -> memMap : _messages.clear()
activate memMap
memMap --> store
deactivate memMap

store -> indexArr : _outbound = [], _inbound = []
activate indexArr
indexArr --> store
deactivate indexArr

store -> jsonl : readLines(messagesFile)\n[fs.readFileSync + split('\\n')]
activate jsonl
jsonl --> store : raw lines[]
deactivate jsonl

loop for each parsed row
    alt row._op === 'update'
        store -> memMap : Object.assign(\n  _messages.get(row.id), row.fields)
        activate memMap
        memMap --> store
        deactivate memMap
    else new message row
        store -> memMap : _messages.set(row.id, row)
        activate memMap
        memMap --> store
        deactivate memMap
    end
end

note over store
  Filter out terminal statuses:
  { synced, delivered, failed, rejected }
  Populate _outbound[] or _inbound[]
  based on msg.direction
end note

store -> indexArr : populate _outbound[] / _inbound[]\nfrom non-terminal messages
activate indexArr
indexArr --> store
deactivate indexArr

@enduml
