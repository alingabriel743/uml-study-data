@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #495057
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #6C757D
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam sequenceGroupFontColor #212529
skinparam sequenceGroupHeaderFontSize 11
skinparam noteFontSize 10
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F9A825

title Session Management Flow

actor "Agent" as Agent
participant "ProxyServer\n(HTTP)" as Proxy
participant "Router\n(buildRoutes)" as Router
participant "SessionHandler" as SH
participant "MailboxStore\n(~/.evomap/mailbox)" as Store

== Startup ==

Proxy -> SH : new SessionHandler({ store, logger })
activate SH
Proxy -> Router : buildRoutes(store, proxyHandlers,\ntaskMonitor, { sessionHandler: SH })
deactivate SH

== Create Session ==

Agent -> Proxy : POST /session/create\n{ title, description, invite_node_ids, max_participants }
activate Proxy
Proxy -> Router : route → createSession handler
activate Router
Router -> SH : createSession({ title, description,\ninviteNodeIds[], maxParticipants })
activate SH
note right of SH
  Validates: title required
  inviteNodeIds capped at 10
  maxParticipants clamped [2–20]
  default: 5
end note
SH -> Store : send({ type: 'session_create',\npayload: { title, description,\ninvite_node_ids, max_participants,\ncreated_at }, priority: 'high' })
activate Store
Store --> SH : message envelope (result)
deactivate Store
SH --> Router : result
deactivate SH
Router --> Proxy : 200 { body: result }
deactivate Router
Proxy --> Agent : 200 { body: result }
deactivate Proxy

== Poll Invites (Optional Pre-Join) ==

Agent -> Proxy : POST /session/invites/poll\n{ limit }
activate Proxy
Proxy -> Router : route → pollInvites handler
activate Router
Router -> SH : pollInvites({ limit })
activate SH
SH -> Store : poll({ type: 'collaboration_invite', limit })
activate Store
Store --> SH : { messages[], count }
deactivate Store
SH --> Router : { messages[], count }
deactivate SH
Router --> Proxy : 200 { body: { messages[], count } }
deactivate Router
Proxy --> Agent : 200 { invites[], count }
deactivate Proxy

== Join Session ==

Agent -> Proxy : POST /session/join\n{ session_id }
activate Proxy
Proxy -> Router : route → joinSession handler
activate Router
Router -> SH : joinSession({ sessionId })
activate SH
SH -> Store : send({ type: 'session_join',\npayload: { session_id, joined_at },\npriority: 'normal' })
activate Store
Store --> SH : result
deactivate Store
SH --> Router : result
deactivate SH
Router --> Proxy : 200 { body: result }
deactivate Router
Proxy --> Agent : 200 { body: result }
deactivate Proxy

== Send Message ==

Agent -> Proxy : POST /session/message\n{ session_id, to_node_id, msg_type, payload }
activate Proxy
Proxy -> Router : route → sendMessage handler
activate Router
Router -> SH : sendMessage({ sessionId, toNodeId,\nmsgType, payload })
activate SH
note right of SH
  Validates: payload must be object
  JSON-serialized size ≤ 16 KB
  msg_type defaults to 'context_update'
end note
SH -> Store : send({ type: 'session_message',\npayload: { session_id, to_node_id,\nmsg_type, payload, sent_at },\npriority: 'normal' })
activate Store
Store --> SH : result
deactivate Store
SH --> Router : result
deactivate SH
Router --> Proxy : 200 { body: result }
deactivate Router
Proxy --> Agent : 200 { body: result }
deactivate Proxy

== Delegate Subtask ==

Agent -> Proxy : POST /session/delegate\n{ session_id, to_node_id, title, description, role }
activate Proxy
Proxy -> Router : route → delegateSubtask handler
activate Router
Router -> SH : delegateSubtask({ sessionId, toNodeId,\ntitle, description, role })
activate SH
note right of SH
  Validates: role ∈ ['builder','planner','reviewer']
  defaults to 'builder'
end note
SH -> Store : send({ type: 'session_delegate',\npayload: { session_id, to_node_id,\ntitle, description, role,\ndelegated_at }, priority: 'high' })
activate Store
Store --> SH : result
deactivate Store
SH --> Router : result
deactivate SH
Router --> Proxy : 200 { body: result }
deactivate Router
Proxy --> Agent : 200 { body: result }
deactivate Proxy

== Submit Result ==

Agent -> Proxy : POST /session/submit\n{ session_id, task_id, result_asset_id, summary }
activate Proxy
Proxy -> Router : route → submitResult handler
activate Router
Router -> SH : submitResult({ sessionId, taskId,\nresultAssetId, summary })
activate SH
note right of SH
  summary truncated to 200 chars
end note
SH -> Store : send({ type: 'session_submit',\npayload: { session_id, task_id,\nresult_asset_id, summary,\nsubmitted_at }, priority: 'high' })
activate Store
Store --> SH : result
deactivate Store
SH --> Router : result
deactivate SH
Router --> Proxy : 200 { body: result }
deactivate Router
Proxy --> Agent : 200 { body: result }
deactivate Proxy

== Leave Session ==

Agent -> Proxy : POST /session/leave\n{ session_id }
activate Proxy
Proxy -> Router : route → leaveSession handler
activate Router
Router -> SH : leaveSession({ sessionId })
activate SH
SH -> Store : send({ type: 'session_leave',\npayload: { session_id, left_at },\npriority: 'normal' })
activate Store
Store --> SH : result
deactivate Store
SH --> Router : result
deactivate SH
Router --> Proxy : 200 { body: result }
deactivate Router
Proxy --> Agent : 200 { body: result }
deactivate Proxy

== List Active Sessions & Poll Events (Async) ==

Agent -> Proxy : GET /session/list
activate Proxy
Proxy -> Router : route → listActiveSessions handler
activate Router
Router -> SH : listActiveSessions()
activate SH
SH -> Store : list({ type: 'session_create',\ndirection: 'outbound', limit: 50 })
activate Store
Store --> SH : { sessions[], count }
deactivate Store
SH --> Router : { sessions[], count }
deactivate SH
Router --> Proxy : 200 { body: { sessions[], count } }
deactivate Router
Proxy --> Agent : 200 { sessions[], count }
deactivate Proxy

Agent -> Proxy : POST /session/events/poll\n{ limit }
activate Proxy
Proxy -> Router : route → pollSessionEvents handler
activate Router
Router -> SH : pollSessionEvents({ limit })
activate SH
SH -> Store : poll({ type: 'session_event', limit: 20 })
activate Store
Store --> SH : { messages[], count }
deactivate Store
SH --> Router : { messages[], count }
deactivate SH
Router --> Proxy : 200 { body: { messages[], count } }
deactivate Router
Proxy --> Agent : 200 { events[], count }
deactivate Proxy

@enduml
