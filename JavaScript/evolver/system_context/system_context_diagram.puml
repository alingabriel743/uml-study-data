@startuml
title Evolver (@evomap/evolver) — System Context Diagram

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actor {
    BackgroundColor<<Person>> #08427B
    FontColor<<Person>> #FFFFFF
    BorderColor<<Person>> #052E56
}

skinparam arrow {
    Color #424242
    FontSize 10
    FontColor #616161
}

' ── Actors ──────────────────────────────────────────────────────────────────
actor "Developer / Operator
[CLI User]

Runs evolver commands:
run, solidify, review,
distill, fetch" as developer <<Person>>

actor "AI Platform Agent
[Cursor / Claude Code / Codex]

Triggers hooks pre/post
tool execution; invokes
evolver via hook scripts" as ai_platform <<Person>>

actor "Automated CI
[Scheduled / Scripted]

Executes evolver loops,
recover scripts, and
lifecycle management" as ci_auto <<Person>>

' ── Core System ─────────────────────────────────────────────────────────────
rectangle "**Evolver**
[@evomap/evolver v1.67.1 · Node.js]

GEP-powered self-evolution engine
for AI coding agents. Analyses logs,
generates/solidifies code improvements,
manages skills, and coordinates
Agent-to-Agent (A2A) messaging via
a local proxy sidecar." as system <<System>>

' ── Local Infrastructure ────────────────────────────────────────────────────
rectangle "**EvoMapProxy**
[HTTP Sidecar · localhost:19820]

Local HTTP proxy server
intercepts AI platform
tool calls; routes mailbox,
sync, session, and task APIs" as proxy <<Infrastructure>>

rectangle "**Local Filesystem / Git Repo**
[Git CLI · execSync]

Source code workspace.
Diff, stash, rollback, commit,
and push via git CLI.
Evolution asset store (JSONL)" as git_local <<Database>>

' ── EvoMap Cloud ────────────────────────────────────────────────────────────
rectangle "**EvoMap Hub**
[https://evomap.ai · REST API]

Central registry and A2A hub.
Node registration (hello),
skill marketplace, task dispatch,
hub review, directory look-up,
and GEP candidate submission" as evomap_hub <<External>>

rectangle "**Skill Marketplace**
[evomap.ai/skills]

Downloadable & publishable
evolution skill packages.
Authenticated via node_secret
and A2A_HUB_URL token" as skill_store <<External>>

' ── External Developer Platforms ────────────────────────────────────────────
rectangle "**Cursor IDE**
[Hook Adapter · .cursor/]

Receives evolver-managed
hook scripts injected into
Cursor config directory" as cursor <<External>>

rectangle "**Claude Code**
[Hook Adapter · .claude/]

Receives evolver-managed
hook scripts injected into
Claude Code config directory" as claude_code <<External>>

rectangle "**OpenAI Codex**
[Hook Adapter · .codex/]

Receives evolver-managed
hook scripts injected into
Codex config directory" as codex <<External>>

' ── External Services ────────────────────────────────────────────────────────
rectangle "**GitHub API**
[https://api.github.com · REST]

Issue creation & dedup search.
Self-PR branch push and merge.
Requires GITHUB_TOKEN with
repo scope" as github <<External>>

rectangle "**GitHub Repository**
[git remote · SSH/HTTPS]

Remote origin for the
evolved codebase. Receives
self-improvement PRs pushed
by evolver-bot" as github_repo <<External>>

' ── Relationships ────────────────────────────────────────────────────────────

' Actors → System
developer --> system : "CLI (stdio)
(run, solidify, review,\ndistill, fetch commands)"
ai_platform --> system : "Hook invocation
(pre/post tool events\nvia shell scripts)"
ci_auto --> system : "Shell / Node.js
(scheduled loops,\nrecover_loop.js)"

' System ↔ Local Proxy
system --> proxy : "HTTP (localhost)
(spawn & control proxy;\nmailbox send/poll/ack,\nsession & task routes)"
proxy --> system : "HTTP (localhost)
(inbound sync poll;\ncallbacks to LifecycleManager)"

' System → Local Git/FS
system --> git_local : "Git CLI (execSync)
(diff, stash, commit,\nrollback, JSONL asset store)"

' System ↔ EvoMap Hub
system --> evomap_hub : "HTTPS REST
(node hello/register,\ntask fetch, hub review,\ndirectory lookup, GEP submit)"
evomap_hub --> system : "HTTPS REST
(task assignments,\ncandidate results,\nheartbeat ACK)"

' System → Skill Marketplace
system --> skill_store : "HTTPS REST
(skill download/fetch\nvia node_secret auth;\nskill publish/upload)"

' System → AI Platforms (hook injection)
system --> cursor : "File I/O
(inject hook scripts\ninto .cursor/ config)"
system --> claude_code : "File I/O
(inject hook scripts\ninto .claude/ config)"
system --> codex : "File I/O
(inject hook scripts\ninto .codex/ config)"

' System → GitHub API
system --> github : "HTTPS REST
(create/search issues;\nGITHUB_TOKEN auth)"

' System → GitHub Repo
system --> github_repo : "Git (SSH/HTTPS)
(push self-PR branches;\nevolver-bot commits)"

@enduml
