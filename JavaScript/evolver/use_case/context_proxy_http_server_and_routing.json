{
  "scope": "proxy_http_server_and_routing",
  "title": "Proxy HTTP Server & Routing",
  "diagram_type": "use_case",
  "system_boundary": "EvoMap Proxy HTTP Server (127.0.0.1:19820+)",

  "actors": [
    {
      "name": "External Client",
      "description": "Claude Agent or SDK consumer sending HTTP requests to the local proxy"
    },
    {
      "name": "EvoMapProxy",
      "description": "Top-level orchestrator class (src/proxy/index.js) that creates ProxyHttpServer with built routes"
    },
    {
      "name": "EvoMap Hub",
      "description": "Remote hub server; contacted by SyncEngine for outbound/inbound message sync"
    }
  ],

  "key_classes": [
    {
      "name": "ProxyHttpServer",
      "file": "src/proxy/server/http.js",
      "constructor": "constructor(routes, { port, logger })",
      "methods": [
        "async start() → { port, url }",
        "async stop()",
        "async _handleRequest(req, res)",
        "_matchRoute(method, pathname) → { handler, params } | null"
      ],
      "helpers": ["parseBody(req)", "sendJson(res, status, body)", "tryListen(server, port)", "matchPath(pattern, pathname)"],
      "constants": ["DEFAULT_PORT=19820", "MAX_PORT_ATTEMPTS=100"]
    },
    {
      "name": "buildRoutes",
      "file": "src/proxy/server/routes.js",
      "signature": "buildRoutes(store, proxyHandlers, taskMonitor, extensions) → routeMap",
      "extensions_destructured": ["dmHandler", "skillUpdater", "getHubMailboxStatus", "sessionHandler"]
    },
    {
      "name": "AuthError",
      "file": "src/proxy/lifecycle/manager.js",
      "extends": "Error",
      "fields": ["name='AuthError'", "statusCode"],
      "usage": "Thrown by InboundSync/OutboundSync on HTTP 401/403 from Hub; caught by SyncEngine which calls onAuthError() → lifecycle.reAuthenticate()"
    }
  ],

  "use_cases": [
    {
      "group": "Mailbox",
      "items": [
        { "name": "Send Message", "endpoint": "POST /mailbox/send", "actor": "External Client", "handler": "store.send()" },
        { "name": "Poll Messages", "endpoint": "POST /mailbox/poll", "actor": "External Client", "handler": "store.poll()" },
        { "name": "Acknowledge Messages", "endpoint": "POST /mailbox/ack", "actor": "External Client", "handler": "store.ack()" },
        { "name": "List Messages", "endpoint": "GET /mailbox/list", "actor": "External Client", "handler": "store.list()" },
        { "name": "Get Message Status", "endpoint": "GET /mailbox/status/:id", "actor": "External Client", "handler": "store.getById()" }
      ]
    },
    {
      "group": "Asset",
      "items": [
        { "name": "Validate Asset", "endpoint": "POST /asset/validate", "actor": "External Client", "handler": "proxyHandlers.assetValidate()" },
        { "name": "Fetch Asset", "endpoint": "POST /asset/fetch", "actor": "External Client", "handler": "proxyHandlers.assetFetch()" },
        { "name": "Search Assets", "endpoint": "POST /asset/search", "actor": "External Client", "handler": "proxyHandlers.assetSearch()" },
        { "name": "Submit Asset", "endpoint": "POST /asset/submit", "actor": "External Client", "handler": "store.send(type='asset_submit')" },
        { "name": "Get Asset Submissions", "endpoint": "GET /asset/submissions", "actor": "External Client", "handler": "store.list() + store._messages enrichment" }
      ]
    },
    {
      "group": "Task",
      "items": [
        { "name": "Subscribe to Tasks", "endpoint": "POST /task/subscribe", "actor": "External Client", "handler": "taskMonitor.subscribe() or store.send(type='task_subscribe')" },
        { "name": "Unsubscribe from Tasks", "endpoint": "POST /task/unsubscribe", "actor": "External Client", "handler": "taskMonitor.unsubscribe() or store.send()" },
        { "name": "List Available Tasks", "endpoint": "GET /task/list", "actor": "External Client", "handler": "store.poll(type='task_available')" },
        { "name": "Claim Task", "endpoint": "POST /task/claim", "actor": "External Client", "handler": "store.send(type='task_claim', priority='high') + taskMonitor.recordClaim()" },
        { "name": "Complete Task", "endpoint": "POST /task/complete", "actor": "External Client", "handler": "store.send(type='task_complete') + taskMonitor.recordComplete()" },
        { "name": "Get Task Metrics", "endpoint": "GET /task/metrics", "actor": "External Client", "handler": "taskMonitor.getMetrics()" }
      ]
    },
    {
      "group": "Direct Message",
      "items": [
        { "name": "Send Direct Message", "endpoint": "POST /dm/send", "actor": "External Client", "handler": "dmHandler.send() or store.send(type='dm')" },
        { "name": "Poll Direct Messages", "endpoint": "POST /dm/poll", "actor": "External Client", "handler": "dmHandler.poll() or store.poll(type='dm')" },
        { "name": "List Direct Messages", "endpoint": "GET /dm/list", "actor": "External Client", "handler": "dmHandler.list() or store.list(type='dm')" }
      ]
    },
    {
      "group": "Session (Collaboration)",
      "items": [
        { "name": "Create Session", "endpoint": "POST /session/create", "actor": "External Client", "handler": "sessionHandler.createSession() or store.send(type='session_create')" },
        { "name": "Join Session", "endpoint": "POST /session/join", "actor": "External Client", "handler": "sessionHandler.joinSession() or store.send(type='session_join')" },
        { "name": "Leave Session", "endpoint": "POST /session/leave", "actor": "External Client", "handler": "sessionHandler.leaveSession() or store.send(type='session_leave')" },
        { "name": "Send Session Message", "endpoint": "POST /session/message", "actor": "External Client", "handler": "sessionHandler.sendMessage() or store.send(type='session_message')" },
        { "name": "Delegate Subtask", "endpoint": "POST /session/delegate", "actor": "External Client", "handler": "sessionHandler.delegateSubtask() or store.send(type='session_delegate', priority='high')" },
        { "name": "Submit Session Result", "endpoint": "POST /session/submit", "actor": "External Client", "handler": "sessionHandler.submitResult() or store.send(type='session_submit', priority='high')" },
        { "name": "Poll Session Invites", "endpoint": "POST /session/invites/poll", "actor": "External Client", "handler": "sessionHandler.pollInvites() or store.poll(type='collaboration_invite')" },
        { "name": "List Sessions", "endpoint": "GET /session/list", "actor": "External Client", "handler": "sessionHandler.listActiveSessions() or store.list()" }
      ]
    },
    {
      "group": "System",
      "items": [
        { "name": "Check Proxy Status", "endpoint": "GET /proxy/status", "actor": "External Client", "handler": "store.countPending() + store.getState()" },
        { "name": "Get Proxy Config", "endpoint": "GET /proxy/config", "actor": "External Client", "handler": "returns PROXY_PROTOCOL_VERSION, SCHEMA_VERSION, channel" },
        { "name": "Get Hub Status", "endpoint": "GET /proxy/hub-status", "actor": "External Client", "handler": "getHubMailboxStatus() extension" }
      ]
    }
  ],

  "routing_mechanism": {
    "description": "ProxyHttpServer._handleRequest parses URL, builds routeKey='METHOD /path', calls _matchRoute which iterates route map entries and uses matchPath() for :param segment matching",
    "error_responses": {
      "404": "route not found",
      "400": "validation errors thrown with statusCode:400",
      "500": "unhandled errors default to 500"
    },
    "body_parsing": "parseBody() only for POST/PUT; query params via URL.searchParams"
  },

  "startup_flow": [
    "EvoMapProxy instantiates MailboxStore, builds proxyHandlers, creates routes via buildRoutes()",
    "ProxyHttpServer.start() calls clearIfStale(), creates http.Server, port-scans from 19820 up to 100 attempts",
    "On successful bind: writeSettings({ proxy: { url, pid, started_at } })",
    "On stop(): server.close() + clearSettings()"
  ],

  "auth_error_flow": [
    "InboundSync or OutboundSync receives HTTP 401/403 from Hub → throws new AuthError(msg, statusCode)",
    "SyncEngine catches AuthError → calls _handleAuthError(source) → calls onAuthError() callback",
    "onAuthError() is wired to EvoMapProxy: () => this.lifecycle.reAuthenticate()"
  ],

  "key_relationships": [
    "EvoMapProxy creates ProxyHttpServer with routes from buildRoutes()",
    "buildRoutes() depends_on MailboxStore (send/poll/ack/list/getById/countPending/getState)",
    "buildRoutes() depends_on proxyHandlers (assetValidate/assetFetch/assetSearch)",
    "buildRoutes() optionally depends_on taskMonitor, dmHandler, sessionHandler extensions",
    "ProxyHttpServer uses _matchRoute + matchPath for :param route resolution",
    "AuthError extends Error; used by sync layer, not HTTP routing layer"
  ],

  "important_notes": "Routes use optional extension pattern: if dmHandler/sessionHandler/taskMonitor present they take precedence over raw store.send(). All responses are JSON. Port written to settings file for SDK discovery. PROXY_PROTOCOL_VERSION and SCHEMA_VERSION sourced from mailbox/store.",

  "source_files_analyzed": [
    "src/proxy/server/http.js",
    "src/proxy/server/routes.js",
    "src/proxy/lifecycle/manager.js (AuthError only)",
    "src/proxy/index.js (EvoMapProxy class reference)"
  ]
}
