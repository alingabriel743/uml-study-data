@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #343A40
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 10

title Agent Identity & Environment Fingerprinting

left to right direction

' ─────────────────────────────────────────────
' Primary Actors (left side)
' ─────────────────────────────────────────────
actor "GEP Agent" as gepAgent
actor "PrivacyClient" as privacyClient
actor "PolicyCheck" as policyCheck

' ─────────────────────────────────────────────
' Secondary / External Actors (right side)
' ─────────────────────────────────────────────
actor "File System" as fileSystem #EDF2FF
actor "OS / Node.js Runtime" as osRuntime #EDF2FF
actor "Node.js Crypto" as nodeCrypto #EDF2FF

' ─────────────────────────────────────────────
' System Boundary
' ─────────────────────────────────────────────
rectangle "Agent Identity & Environment Fingerprinting" {

    ' ── DeviceId subsystem ──────────────────
    package "DeviceId\n(deviceId.js)" as pkgDeviceId {
        usecase "Get Stable Device ID\ngetDeviceId()" as UC1
        usecase "Detect Container\nEnvironment\nisContainer()" as UC2
    }

    ' ── EnvFingerprint subsystem ────────────
    package "EnvFingerprint\n(envFingerprint.js)" as pkgEnvFp {
        usecase "Capture Environment\nSnapshot\ncaptureEnvFingerprint()" as UC3
        usecase "Generate Environment\nFingerprint Key\nenvFingerprintKey(fp)" as UC4
        usecase "Check Same\nEnvironment Class\nisSameEnvClass(fp1, fp2)" as UC5
    }

    ' ── ContentHash subsystem ───────────────
    package "ContentHash\n(contentHash.js)" as pkgContentHash {
        usecase "Canonicalize\nAsset Data\ncanonicalize(value)" as UC6
        usecase "Compute Asset\nContent Hash\ncomputeAssetId(obj)" as UC7
        usecase "Verify Asset\nIntegrity\nverifyAssetId(obj)" as UC8
    }

    ' ── Crypto subsystem ────────────────────
    package "Crypto\n(crypto.js)\nAES-256-GCM" as pkgCrypto {
        usecase "Generate\nEncryption Key\ngenerateKey()" as UC9
        usecase "Encrypt Data\nencrypt(plaintext, key)" as UC10
        usecase "Decrypt Data\ndecrypt(ciphertext,\nkey, iv, authTag)" as UC11
        usecase "Pack Crypto\nPayload\npack({iv, authTag, ct})" as UC12
        usecase "Unpack Crypto\nPayload\nunpack(buf)" as UC13
    }

    ' ── Include relationships ────────────────
    UC3 ..> UC1 : <<include>>
    UC3 ..> UC2 : <<include>>
    UC5 ..> UC4 : <<include>>
    UC7 ..> UC6 : <<include>>
    UC8 ..> UC7 : <<include>>
}

' ─────────────────────────────────────────────
' GEP Agent → all use cases
' ─────────────────────────────────────────────
gepAgent --> UC1
gepAgent --> UC2
gepAgent --> UC3
gepAgent --> UC4
gepAgent --> UC5
gepAgent --> UC6
gepAgent --> UC7
gepAgent --> UC8
gepAgent --> UC9
gepAgent --> UC10
gepAgent --> UC11
gepAgent --> UC12
gepAgent --> UC13

' ─────────────────────────────────────────────
' PrivacyClient → Crypto use cases
' ─────────────────────────────────────────────
privacyClient --> UC9
privacyClient --> UC10
privacyClient --> UC11
privacyClient --> UC12
privacyClient --> UC13

' ─────────────────────────────────────────────
' PolicyCheck → captureEnvFingerprint
' ─────────────────────────────────────────────
policyCheck --> UC3

' ─────────────────────────────────────────────
' Secondary actors (right-side, driven by UCs)
' ─────────────────────────────────────────────
UC1 --> fileSystem : reads/writes\ndevice UUID file
UC3 --> fileSystem : reads\nevolver package.json
UC3 --> osRuntime  : process.version\nplatform / arch\nos.release / hostname / cwd
UC4 --> nodeCrypto : createHmac\n(sha256)
UC6 --> nodeCrypto : createHash\n(sha256)
UC7 --> nodeCrypto : createHash\n(sha256)
UC9  --> nodeCrypto : randomBytes
UC10 --> nodeCrypto : createCipheriv\n(aes-256-gcm)
UC11 --> nodeCrypto : createDecipheriv\n(aes-256-gcm)

@enduml
