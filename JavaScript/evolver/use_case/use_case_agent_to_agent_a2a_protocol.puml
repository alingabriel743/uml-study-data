@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #343A40
    BorderThickness 2
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 10

title Agent-to-Agent (A2A) Protocol\ngep-a2a v1.0.0 — evomap.ai Hub

top to bottom direction

' ── Actors ────────────────────────────────────────────────────
actor "Peer Agent\n(any GEP node)" as PeerAgent
actor "Consumer Agent\n(ATP)" as ConsumerAgent
actor "Merchant Agent\n(ATP)" as MerchantAgent
actor "Hub\n(evomap.ai)" as Hub <<external system>>

' ── System Boundary ───────────────────────────────────────────
rectangle "GEP A2A Protocol System  (src/gep/ · src/atp/)" {

    ' ── Group 1: Hub Registration & Connectivity ──────────────
    package "Hub Registration & Connectivity" as PKG1 {
        usecase "Register with Hub\n(Hello)" as UC01
        usecase "Send Heartbeat" as UC07
        usecase "Open Event Stream (SSE)" as UC08
    }

    ' ── Group 2: Asset Exchange ────────────────────────────────
    package "Asset Exchange" as PKG2 {
        usecase "Publish Asset to Peers\n(Gene / Capsule)" as UC02
        usecase "Export Eligible Capsules\n(score≥0.7, streak≥2)" as UC14
        usecase "Export Eligible Genes\n(strategy + validation)" as UC15
        usecase "Report Validation Result" as UC04
        usecase "Make Asset Decision\n(accept | reject | quarantine)" as UC05
        usecase "Revoke Asset" as UC06
        usecase "Receive & Lower-Confidence\nExternal Asset" as UC13
        usecase "Parse A2A Input\n(JSON / NDJSON)" as UC16
    }

    ' ── Group 3: Task & Bridge Operations ─────────────────────
    package "Task & Bridge Operations" as PKG3 {
        usecase "Fetch Tasks from Hub\n(greedy | balanced | conservative)" as UC03
        usecase "Spawn Sub-Agent via Bridge\n(sessions_spawn)" as UC17
        usecase "Write Prompt Artifact\nvia Bridge" as UC18
    }

    ' ── Group 4: Agent Discovery ───────────────────────────────
    package "Agent Discovery" as PKG4 {
        usecase "Discover Agents by Query\n(semantic search)" as UC09
        usecase "Discover Agents by Signals\n(keyword search)" as UC10
        usecase "Discover Agents for Task\n(combined search)" as UC11
        usecase "Get Agent Profile\n(capabilities, reputation, load)" as UC12
    }

    ' ── Group 5: ATP Service Marketplace ──────────────────────
    package "ATP Service Marketplace" as PKG5 {
        usecase "Order Service\n(fastest|cheapest|auction|swarm)" as UC19
        usecase "Verify / Settle Delivery\n(confirm | AI judge | force)" as UC20
        usecase "Publish Service &\nPoll for Work" as UC21
        usecase "Submit Delivery Proof" as UC22
    }
}

' ── Actor → Use Case Associations ─────────────────────────────

' PeerAgent
PeerAgent --> UC01
PeerAgent --> UC02
PeerAgent --> UC03
PeerAgent --> UC04
PeerAgent --> UC05
PeerAgent --> UC06
PeerAgent --> UC07
PeerAgent --> UC08
PeerAgent --> UC09
PeerAgent --> UC10
PeerAgent --> UC11
PeerAgent --> UC12
PeerAgent --> UC13
PeerAgent --> UC14
PeerAgent --> UC15
PeerAgent --> UC16
PeerAgent --> UC17
PeerAgent --> UC18

' ConsumerAgent
ConsumerAgent --> UC19
ConsumerAgent --> UC20

' MerchantAgent
MerchantAgent --> UC21
MerchantAgent --> UC22

' Hub (external — receives protocol messages)
UC01 --> Hub
UC03 --> Hub
UC07 --> Hub
UC08 --> Hub
UC09 --> Hub
UC10 --> Hub
UC12 --> Hub
UC19 --> Hub
UC21 --> Hub

' ── Include Relationships ──────────────────────────────────────
UC11 ..> UC09  : <<include>>
UC11 ..> UC10  : <<include>>
UC19 ..> UC01  : <<include>>
UC21 ..> UC01  : <<include>>
UC21 ..> UC07  : <<include>>

' ── Extend Relationships ───────────────────────────────────────
UC02 ..> UC14  : <<extend>>\nexport eligibility check
UC02 ..> UC15  : <<extend>>\nexport eligibility check
UC13 ..> UC16  : <<extend>>\nunwrap before processing

@enduml
