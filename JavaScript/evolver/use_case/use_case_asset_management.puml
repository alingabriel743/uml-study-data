@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C5F8A
    FontColor #1A2E45
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Asset Management

left to right direction

actor "Evolution Engine" as evo
actor "Hub Client" as hub
actor "Prompt Assembler" as prompt
actor "Validator" as validator

rectangle "Asset Management" {

    package "Gene & Capsule Storage" {
        usecase "Load Genes" as UC_LoadGenes
        usecase "Store / Update Gene" as UC_UpsertGene
        usecase "Load Capsules" as UC_LoadCapsules
        usecase "Store Capsule" as UC_StoreCapsule
        usecase "Update Capsule" as UC_UpsertCapsule
        usecase "Track Failed Capsule" as UC_FailedCapsule
    }

    package "Event & Candidate Tracking" {
        usecase "Record Evolution Event" as UC_AppendEvent
        usecase "Read Evolution Events" as UC_ReadEvents
        usecase "Submit Evolution Candidate" as UC_AppendCandidate
        usecase "Read Recent Candidates" as UC_ReadCandidates
        usecase "Submit External Candidate" as UC_ExtCandidate
    }

    package "Asset Call Logging" {
        usecase "Log Asset Call" as UC_LogCall
        usecase "Read Asset Call Log" as UC_ReadLog
        usecase "Summarize Call Log Statistics" as UC_SummarizeLog
    }

    package "Asset Normalization & Identity" {
        usecase "Format Asset Preview for Prompt" as UC_FormatPreview
        usecase "Normalize Asset\n(assign ID & version)" as UC_Normalize
        usecase "Compute Content Hash / Asset ID" as UC_Hash
        usecase "Verify Asset ID Integrity" as UC_VerifyId
    }

    package "System Integrity" {
        usecase "Check File Integrity" as UC_CheckIntegrity
        usecase "Generate Validation Command" as UC_BuildValidation
        usecase "Ensure Asset Files Exist" as UC_EnsureFiles
    }
}

' Evolution Engine interactions
evo --> UC_LoadGenes
evo --> UC_UpsertGene
evo --> UC_LoadCapsules
evo --> UC_StoreCapsule
evo --> UC_UpsertCapsule
evo --> UC_FailedCapsule
evo --> UC_AppendEvent
evo --> UC_ReadEvents
evo --> UC_AppendCandidate
evo --> UC_ReadCandidates
evo --> UC_EnsureFiles

' Hub Client interactions
hub --> UC_ExtCandidate
hub --> UC_LogCall
hub --> UC_ReadLog
hub --> UC_SummarizeLog

' Prompt Assembler interactions
prompt --> UC_FormatPreview
prompt --> UC_Normalize

' Validator interactions
validator --> UC_BuildValidation
validator --> UC_VerifyId

' Include relationships
UC_UpsertGene ..> UC_Hash : <<include>>
UC_StoreCapsule ..> UC_Hash : <<include>>
UC_UpsertCapsule ..> UC_Hash : <<include>>
UC_Normalize ..> UC_Hash : <<include>>
UC_VerifyId ..> UC_Hash : <<include>>
UC_SummarizeLog ..> UC_ReadLog : <<include>>

' Extend relationships
UC_CheckIntegrity ..> UC_UpsertGene : <<extend>>
UC_CheckIntegrity ..> UC_StoreCapsule : <<extend>>

@enduml
