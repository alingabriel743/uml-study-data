@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title ATP Consumer Service Ordering

left to right direction

actor "Consumer Agent" as ConsumerAgent
actor "Merchant Agent" as MerchantAgent
actor "AI Judge" as AIJudge

rectangle "ATP Marketplace (Hub)" {

    ' --- Discovery & Registration ---
    usecase "Register with Hub\n<size:10>(ensureInitialized → sendHelloToHub)</size>" as UC_Register
    usecase "Resolve ATP Services\n<size:10>(EVOLVER_ATP_SERVICES env / default listing)</size>" as UC_Resolve
    usecase "Get ATP Policy\n<size:10>GET /a2a/atp/policy</size>" as UC_Policy

    ' --- Core Ordering ---
    usecase "Order Service\n<size:10>POST /a2a/atp/order</size>" as UC_Order
    usecase "Order and Wait\n<size:10>(full lifecycle with polling)</size>" as UC_OrderWait

    ' --- Status & Lifecycle ---
    usecase "Check Order Status\n<size:10>GET /a2a/atp/order/:id</size>" as UC_CheckOrder

    ' --- Verification ---
    usecase "Confirm Delivery\n<size:10>(bilateral verify mode)</size>" as UC_Confirm
    usecase "Request AI Judge\n<size:10>(ai_judge verify mode)</size>" as UC_AIJudge

    ' --- Resolution ---
    usecase "Settle Order\n<size:10>POST /a2a/atp/settle</size>" as UC_Settle
    usecase "Dispute Order\n<size:10>POST /a2a/atp/dispute</size>" as UC_Dispute

    ' --- Merchant Side ---
    usecase "Publish Service Listing\n<size:10>POST /a2a/service/publish</size>" as UC_Publish
    usecase "Update Service Listing\n<size:10>POST /a2a/service/update</size>" as UC_Update
}

' --- Consumer Agent associations ---
ConsumerAgent --> UC_Register
ConsumerAgent --> UC_Resolve
ConsumerAgent --> UC_Policy
ConsumerAgent --> UC_Order
ConsumerAgent --> UC_OrderWait
ConsumerAgent --> UC_CheckOrder
ConsumerAgent --> UC_Confirm
ConsumerAgent --> UC_AIJudge
ConsumerAgent --> UC_Settle
ConsumerAgent --> UC_Dispute

' --- Merchant Agent associations ---
MerchantAgent --> UC_Publish
MerchantAgent --> UC_Update

' --- AI Judge association ---
AIJudge --> UC_AIJudge

' --- Include relationships ---
UC_Order ..> UC_Register   : <<include>>
UC_OrderWait ..> UC_Order  : <<include>>
UC_OrderWait ..> UC_CheckOrder : <<include>>

' --- Extend relationships ---
UC_Confirm ..> UC_OrderWait   : <<extend>>\n(bilateral mode)
UC_AIJudge ..> UC_OrderWait   : <<extend>>\n(ai_judge mode)
UC_Settle ..> UC_OrderWait    : <<extend>>\n(proof settled)
UC_Dispute ..> UC_OrderWait   : <<extend>>\n(proof disputed)

note bottom of UC_OrderWait
  Polls every 10s (default).
  Exits on proof_status:
  settled | verified | disputed | timeout (300s)
end note

note right of UC_Order
  routingMode: fastest | cheapest | auction | swarm
  verifyMode:  auto | ai_judge | bilateral
end note

note right of UC_Publish
  executionMode: exclusive | open | swarm
  capabilities[], pricePerTask, recipeId
end note

@enduml
