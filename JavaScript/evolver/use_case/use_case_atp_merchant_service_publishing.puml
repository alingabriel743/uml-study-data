@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

left to right direction

title ATP Merchant Service Publishing

' ── Actors ───────────────────────────────────────────────────
actor "Merchant Agent" as MerchantAgent
actor "Consumer Agent" as ConsumerAgent
actor "Hub Marketplace\n<<system>>" as HubMarketplace

' ── System Boundary ──────────────────────────────────────────
rectangle "ATP Service Publishing Platform" {

    ' --- Merchant publishing & lifecycle ---
    usecase "Register with Hub" as UC3
    note right of UC3
      sendHelloToHub()
      Prerequisite for all publishing.
      Aborts start() if it fails.
    end note

    usecase "Publish Service" as UC1
    note right of UC1
      publishService(svc)
      POST /a2a/service/publish
      Fields: title, capabilities,
      use_cases, price_per_task,
      execution_mode, max_concurrent
    end note

    usecase "Update Service" as UC2
    note right of UC2
      updateService(listingId, updates)
      POST /a2a/service/update
      Modifies price, mode, capacity…
    end note

    usecase "Maintain Heartbeat" as UC4
    note right of UC4
      startHeartbeat() / stopHeartbeat()
      Keeps listing active/discoverable
    end note

    ' --- Merchant status & audit ---
    usecase "Check Merchant Tier" as UC7
    note right of UC7
      getMerchantTier()
      GET /a2a/atp/merchant/tier?node_id=…
    end note

    usecase "View Recent Proofs" as UC8
    note right of UC8
      listProofs({ role:'merchant', limit:5 })
      Audit last 5 delivery proofs
    end note

    ' --- Consumer discovery & ordering ---
    usecase "Discover Services" as UC5
    usecase "Order Service" as UC6
    note right of UC6
      hubClient.orderService(opts)
      Returns order_id for tracking
    end note
}

' ── Actor → Use Case connections ─────────────────────────────
MerchantAgent --> UC3
MerchantAgent --> UC1
MerchantAgent --> UC2
MerchantAgent --> UC4
MerchantAgent --> UC7
MerchantAgent --> UC8

ConsumerAgent --> UC5
ConsumerAgent --> UC6

UC1 --> HubMarketplace
UC2 --> HubMarketplace
UC5 --> HubMarketplace
UC6 --> HubMarketplace
UC3 --> HubMarketplace
UC7 --> HubMarketplace

' ── Include / Extend relationships ───────────────────────────
UC1 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>
UC6 ..> UC5 : <<include>>

' UC5 is enabled by published listings from UC1
UC5 .up.> UC1 : <<extend>>\n(enabled by published listing)

@enduml
