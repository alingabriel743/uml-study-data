@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title ATP Service Discovery & Default Handling

left to right direction

actor "Evolver Agent\n(System)" as Evolver
actor "Consumer Agent" as Consumer
actor "Merchant Agent" as Merchant
actor "Hub\n(External System)" as Hub
actor "Environment /\nConfig" as EnvConfig

rectangle "ATP Service Discovery & Default Handling" {

    package "Service Discovery" {
        usecase "Resolve ATP Services" as UC1
        usecase "Get ATP Operating Mode" as UC2
    }

    package "Default Order Handling" {
        usecase "Handle Incoming Order\n(Default)" as UC3
    }

    package "Order Lifecycle" {
        usecase "Place ATP Order" as UC4
        usecase "Submit Delivery Proof" as UC5
        usecase "Verify Delivery" as UC6
        usecase "Settle Order" as UC7
        usecase "Dispute Order" as UC8
        usecase "Get Order Status" as UC10
    }

    package "Merchant & Policy" {
        usecase "Check Merchant Tier" as UC9
        usecase "List Delivery Proofs" as UC11
        usecase "Get ATP Policy" as UC12
    }
}

' ── Evolver Agent interactions ──────────────────────────────────────────────
Evolver --> UC1 : resolveAtpServices()
Evolver --> UC2 : getAtpMode()
Evolver --> UC7 : settleOrder()
Evolver --> UC9 : getMerchantTier()
Evolver --> UC11 : listProofs()
Evolver --> UC12 : getAtpPolicy()

' ── Consumer Agent interactions ──────────────────────────────────────────────
Consumer --> UC4 : placeOrder()
Consumer --> UC6 : verifyDelivery()
Consumer --> UC8 : disputeOrder()
Consumer --> UC10 : getOrderStatus()

' ── Merchant Agent interactions ──────────────────────────────────────────────
Merchant --> UC3 : defaultOrderHandler()
Merchant --> UC5 : submitDelivery()

' ── Environment / Config supplies env vars ───────────────────────────────────
EnvConfig --> UC1 : EVOLVER_ATP_SERVICES\nEVOLVER_AGENT_NAME\nEVOLVER_MODEL_NAME
EnvConfig --> UC2 : EVOLVER_ATP

' ── Hub as external target of HTTP calls ────────────────────────────────────
UC4  --> Hub : POST /a2a/atp/order
UC5  --> Hub : POST /a2a/atp/deliver
UC6  --> Hub : POST /a2a/atp/verify
UC7  --> Hub : POST /a2a/atp/settle
UC8  --> Hub : POST /a2a/atp/dispute
UC9  --> Hub : GET  /a2a/atp/merchant/tier
UC10 --> Hub : GET  /a2a/atp/order/:id
UC11 --> Hub : GET  /a2a/atp/proofs
UC12 --> Hub : GET  /a2a/atp/policy

' ── Include / Extend relationships ──────────────────────────────────────────
UC1 ..> UC2 : <<include>>
UC3 ..> UC5 : <<extend>>
UC4 ..> UC1 : <<extend>>

note bottom of UC1
  Falls back to a default service descriptor
  ({title, capabilities, useCases, pricePerTask,
  maxConcurrent}) when EVOLVER_ATP_SERVICES is unset.
  Default capabilities: code_evolution, bug_fix,
  code_review, refactoring
end note

note bottom of UC3
  Pattern-matched fallback handler:
  • "review" / "bug"          → code review response
  • "translat" / "localizat"  → translation response
  • "summar" / "digest"       → summarization response
  • (default)                 → generic task response
  Overridable via custom onOrder callback.
end note

@enduml
