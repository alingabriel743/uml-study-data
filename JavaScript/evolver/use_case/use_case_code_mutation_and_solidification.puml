@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Code Mutation & Solidification

left to right direction

actor "GEP Engine\n(Evolver)" as evolver
actor "Developer" as developer
actor "Test Runner\n(node/npm/npx)" as testrunner
actor "GitHub / gh CLI" as github

rectangle "Code Mutation & Solidification System" {

    usecase "Build Mutation\n(repair / optimize / innovate)" as UC1
    usecase "Validate Mutation\nFields & Defaults" as UC2
    usecase "Capture Diff Snapshot\n(blast radius)" as UC11
    usecase "Check Blast Radius\n& Constraints" as UC3
    usecase "Run Validation Tests\n(whitelisted commands)" as UC4
    usecase "Compute Process Scores\n(validation_pass_rate, blast_control)" as UC5
    usecase "Build Execution Trace\n(desensitized, levelled)" as UC6
    usecase "Solidify (Commit)\nChanges" as UC7
    usecase "Rollback Changes\n(hard / stash / none)" as UC8
    usecase "Review Pending\nMutation" as UC10
    usecase "Create Self-PR\n(evolver-bot branch)" as UC9

}

' --- GEP Engine (Evolver) initiates ---
evolver --> UC1
evolver --> UC7

' --- Developer initiates review ---
developer --> UC10

' --- Test Runner executes validation ---
testrunner --> UC4

' --- GitHub receives self-PR ---
github --> UC9

' --- UC-1: Build includes Validate ---
UC1 ..> UC2 : <<include>>

' --- UC-7: Solidify includes sub-steps ---
UC7 ..> UC11 : <<include>>
UC7 ..> UC3  : <<include>>
UC7 ..> UC4  : <<include>>
UC7 ..> UC5  : <<include>>
UC7 ..> UC6  : <<include>>

' --- UC-10: Developer review includes Solidify ---
UC10 ..> UC7 : <<include>>

' --- Extensions ---
UC8 ..> UC7  : <<extend>>\nsolidify gates fail
UC8 ..> UC10 : <<extend>>\ndeveloper rejects
UC9 ..> UC7  : <<extend>>\npost-solidify if\nqualification gates pass

note right of UC1
  Category selected by signal type:
  error → repair
  opportunity → innovate
  plateau → optimize/innovate
  High-risk personality:
  downgrades innovate → optimize
end note

note right of UC3
  Severity: within_limit / approaching_limit
  exceeded / critical_overrun / hard_cap_breach
  Blocks: hollow_commit, critical_path_modified
  (unless EVOLVE_ALLOW_SELF_MODIFY=true)
end note

note right of UC4
  Whitelist: node scripts/*.js,
  npm test/run/ci, npx <tool>
  Blocks: &&, ;, |, backtick,
  node -e/--eval, curl, rm
end note

note bottom of UC9
  Gates: EVOLVER_SELF_PR=true,
  category=optimize, risk=low,
  files/lines within limits,
  no obfuscated files, no secrets,
  24h cooldown, dedup via SHA256
  Never auto-merges.
end note

note bottom of UC8
  EVOLVER_ROLLBACK_MODE:
  hard (git reset --hard) |
  stash (git stash push) | none
  Skips CRITICAL_PROTECTED_FILES
end note

@enduml
