@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #336699
    FontColor #1a1a2e
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343a40
}

title Core Evolution & Configuration

left to right direction

' ── Actors ──────────────────────────────────────────────
actor "Operator\n(CLI / CI)" as Operator
actor "Daemon\n(--loop / --mad-dog)" as Daemon
actor "Environment\n(EVOLVER_* env vars)" as Environment
actor "ChildProcess\n(forked subprocess)" as ChildProcess

' ── System boundary ─────────────────────────────────────
rectangle "Core Evolution & Configuration (index.js / src/config.js / src/canary.js)" {

    usecase "Bootstrap .env\n& dotenv Loading" as UC09
    usecase "Load & Override\nSystem Configuration" as UC04
    usecase "Run Single\nEvolution Cycle" as UC01
    usecase "Start Continuous\nDaemon Loop" as UC02
    usecase "Acquire / Release\nSingleton Lock" as UC08
    usecase "Gate Cycle on\nPending Solidify" as UC03
    usecase "Adaptive Sleep\nBetween Cycles" as UC06
    usecase "Self-Restart Daemon\n(Suicide Gate)" as UC07
    usecase "Run Canary\nSmoke-Test Gate" as UC05

}

' ── Actor → Use-Case associations ───────────────────────
Operator  --> UC09
Operator  --> UC01
Operator  --> UC02

Daemon    --> UC03
Daemon    --> UC06
Daemon    --> UC07
Daemon    --> UC08

Environment --> UC04

ChildProcess --> UC05

' ── Include / Extend relationships ──────────────────────
UC02 ..> UC08 : <<include>>
UC03 <.. UC02 : <<extend>>
UC06 <.. UC02 : <<extend>>
UC07 <.. UC02 : <<extend>>

UC09 ..> UC04 : <<include>>

UC01 ..> UC04 : <<include>>
UC02 ..> UC04 : <<include>>
UC05 ..> UC04 : <<include>>

note bottom of UC05
  Spawned by the solidify pipeline
  as a pre-commit safety net.
  Exits 0 (safe) or 1 (abort).
end note

note right of UC04
  Pure constants evaluated once at
  require() time. No classes or state.
  Groups: Network · Solidify ·
  Evolution · Ops · Self-PR · Leak-check
end note

note right of UC07
  Triggered when cycleCount >= MAX_CYCLES
  or RSS > MAX_RSS_MB (default 500 MB).
  Spawns replacement process, then exits.
end note

@enduml
