@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Exploration, Strategy & Candidate Selection

left to right direction

' ── Primary Actor ──────────────────────────────────────────────────
actor "GEP Orchestrator" as GEP #DDEEFF

' ── Secondary Actor ────────────────────────────────────────────────
actor "Operator / CI" as Operator

' ── External Systems ───────────────────────────────────────────────
actor "Memory Graph" as MemoryGraph
actor "Asset Store\n(JSONL)" as AssetStore
actor "Workspace\nFilesystem" as WorkspaceFS

' ── System Boundary ────────────────────────────────────────────────
rectangle "GEP – Exploration, Strategy & Candidate Selection" {

    ' --- Workspace Exploration ---
    usecase "Explore Workspace\n<size:10>(explore.js)</size>" as UC1

    ' --- Strategy ---
    usecase "Resolve Evolution\nStrategy\n<size:10>(strategy.js)</size>" as UC2

    ' --- Candidate Pipeline ---
    usecase "Evaluate & Score\nCandidates\n<size:10>(candidateEval.js)</size>" as UC5

    usecase "Expand Signals\n<size:10>(candidates.js)</size>" as UC3

    usecase "Extract Capability\nCandidates\n<size:10>(candidates.js)</size>" as UC4

    usecase "Match Pattern\nto Signals\n<size:10>(selector.js)</size>" as UC6

    ' --- Gene / Capsule Selection ---
    usecase "Select Gene &\nCapsule (Combined)\n<size:10>(selector.js)</size>" as UC10

    usecase "Select Gene\n<size:10>(selector.js)</size>" as UC8

    usecase "Select Capsule\n<size:10>(selector.js)</size>" as UC9

    usecase "Compute Drift\nIntensity\n<size:10>(selector.js)</size>" as UC7
}

' ── Actor → Use Case relationships ────────────────────────────────
GEP --> UC1
GEP --> UC2
GEP --> UC5
GEP --> UC10

Operator ..> UC2 : <<influences>>\nEVOLVE_STRATEGY\nFORCE_INNOVATION

WorkspaceFS --> UC1 : provides source files

AssetStore --> UC5 : read candidates\n& failed capsules
UC5 --> AssetStore : persist new candidates

MemoryGraph --> UC10 : memoryAdvice\n(preferredGeneId,\nbannedGeneIds)
MemoryGraph --> UC8  : preferredGeneId\nbannedGeneIds

' ── Include relationships ──────────────────────────────────────────
UC5 ..> UC4  : <<include>>
UC5 ..> UC6  : <<include>>
UC4 ..> UC3  : <<include>>
UC10 ..> UC8 : <<include>>
UC10 ..> UC9 : <<include>>
UC8  ..> UC7 : <<include>>

@enduml
