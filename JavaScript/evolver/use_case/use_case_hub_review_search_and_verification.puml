@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6EA8
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343A40
}

title Hub Review, Search & Verification

left to right direction

actor "GEP Evolver" as evolver
actor "A2A Hub" as hub <<external system>>
actor "External LLM" as llm <<external system>>

note right of hub
  Remote hub at A2A_HUB_URL
  (offline → ok:false, offline:true)
end note

note right of llm
  Node subprocess
  (opt-in: EVOLVER_LLM_REVIEW=true)
end note

rectangle "Hub Review, Search & Verification" {

    package "Hub Search  (hubSearch.js)" {
        usecase "Search Hub for\nRelevant Skills" as UC1
        note bottom of UC1
          Semantic or keyword mode
          (HUBSEARCH_SEMANTIC);\n          in-memory LRU result cache
        end note
    }

    package "Hub Review  (hubReview.js)" {
        usecase "Check Skill\nExistence on Hub" as UC2
        usecase "Fetch Hub Review\nfor Contribution" as UC3
    }

    package "Hub Verify  (hubVerify.js)" {
        usecase "Request\nSolidify Permit" as UC4
        note bottom of UC4
          isSolidifyVerifyEnabled()
          requestSolidifyPermitSync()
          consumeOfflinePermit()
        end note
    }

    package "LLM Review  (llmReview.js)" {
        usecase "Run LLM-Based\nCode Review" as UC5
        usecase "Build Review\nPrompt" as UC6
        note bottom of UC6
          Truncates diff ≤6000 chars,
          signals ≤8, rationale ≤500 chars
        end note
    }
}

' --- GEP Evolver initiates all use cases ---
evolver --> UC1 : search skills
evolver --> UC2 : check existence
evolver --> UC3 : fetch peer review
evolver --> UC4 : gate solidification
evolver --> UC5 : review code diff

' --- Hub interactions ---
UC1 --> hub : HTTP search endpoint
UC2 --> hub : HTTP existence check
UC3 --> hub : HTTP review endpoint
UC4 --> hub : HTTP permit endpoint

' --- LLM interaction ---
UC5 --> llm : execFileSync subprocess\n(30 s timeout)

' --- Use-case relationships ---
UC5 ..> UC6 : <<include>>
UC4 ..> UC2 : <<extend>>
UC1 ..> UC2 : <<precedes>>
UC3 ..> UC1 : <<follows>>

@enduml
