@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7EBF
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Issue Reporting & Validation

left to right direction

actor "Evolver Agent" as evolver
actor "GitHub Hub" as github
actor "External Hub /\nJudge" as judge
actor "System\n(Automated)" as system

rectangle "Issue Reporting & Validation" {

    usecase "Report Recurring\nFailure" as UC1
    usecase "Build Validation\nReport" as UC2
    usecase "Validate Report\nIntegrity" as UC3
    usecase "Analyze Past\nFailures" as UC4
    usecase "Check Cooldown\n& Dedup" as UC5
    usecase "Find Existing\nIssue" as UC6
    usecase "Build Issue\nBody" as UC7
    usecase "Capture Env\nFingerprint" as UC8
    usecase "Compute Asset ID\n(Content Hash)" as UC9
    usecase "Sanitize Content\n(Redact Secrets)" as UC10
    usecase "Persist Reporter\nState" as UC11

}

' Actor → Use Case associations
evolver --> UC1
evolver --> UC2
judge   --> UC3
system  --> UC4
github  --> UC6

' Core include relationships
UC1 ..> UC5  : <<include>>
UC1 ..> UC7  : <<include>>
UC1 ..> UC11 : <<include>>
UC1 ..> UC4  : <<include>>

' Find Existing Issue extends the base report flow (dedup check)
UC6 ..> UC1  : <<extend>>

' Issue body build depends on env fingerprint + sanitization
UC7 ..> UC8  : <<include>>
UC7 ..> UC10 : <<include>>

' Validation report build
UC2 ..> UC8  : <<include>>
UC2 ..> UC9  : <<include>>

' Consumers validate the report before processing
UC2 ..> UC3  : <<include>>

@enduml
