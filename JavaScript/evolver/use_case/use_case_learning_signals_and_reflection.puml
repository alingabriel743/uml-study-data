@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #343A40
    FontColor #212529
    BorderThickness 2
}
skinparam packageStyle rectangle

left to right direction

title Learning Signals & Reflection

' ─── Actors ───────────────────────────────────────────────────────────────────
actor "GEP Evolver" as evolver
actor "LLM Hub\n<<external>>" as llm
actor "Evolution\nState Store\n<<external>>" as stateStore
actor "Gene / Capsule\n<<data>>" as gene

' ─── System Boundary ──────────────────────────────────────────────────────────
rectangle "Learning Signals & Reflection" {

    package "Signal Extraction Pipeline" #EBF3FB {
        usecase "Extract Signals\nfrom Session" as UC01
        usecase "Analyze Recent\nEvolution History" as UC06
        usecase "Extract via Regex\n(Layer 1)" as UC02
        usecase "Extract via Keyword\nScoring (Layer 2)" as UC03
        usecase "Extract via LLM\nSemantic Analysis (Layer 3)" as UC04
        usecase "Merge Signals\nfrom All Layers" as UC05
        usecase "Post-process &\nPrioritize Signals" as UC07
    }

    package "Signal Gating" #EBF5EB {
        usecase "Check for\nOpportunity Signal" as UC08
    }

    package "Learning Tags" #FFF8EB {
        usecase "Extract Learning\nTags from Capsule" as UC09
        usecase "Get Tags for\nSignal Object" as UC10
        usecase "Score Tag Match" as UC11
    }

    package "Reflection & Adaptation" #FBEAEA {
        usecase "Reflect on\nEvolution Outcome" as UC12
        usecase "Classify\nFailure Mode" as UC14
        usecase "Adapt Gene\nfrom Learning" as UC13
        usecase "Build Soft Failure\nLearning Signals" as UC15
    }

    package "Personality & State Awareness" #F3EBFB {
        usecase "Update\nPersonality State" as UC16
        usecase "Capture\nLocal State" as UC17
        usecase "Capture\nEvolution State" as UC18
        usecase "Generate\nPersonality Report" as UC19
    }

}

' ─── Actor → Use Case Associations ───────────────────────────────────────────
evolver --> UC01 : drives
evolver --> UC08 : gates evolution on
evolver --> UC09 : tags capsule via
evolver --> UC11 : ranks genes via
evolver --> UC12 : reflects per cycle
evolver --> UC14 : classifies failure via
evolver --> UC13 : adapts gene via
evolver --> UC17 : injects into prompt
evolver --> UC19 : reports personality via

llm --> UC04 : provides semantic\nanalysis

stateStore --> UC12 : reads/writes\nevolution state
stateStore --> UC16 : persists\npersonality traits
stateStore --> UC18 : supplies state\nfiles

gene --> UC09 : provides signals_match\n& learning_history
gene --> UC13 : updated by\noutcome

' ─── Include Relationships (UC01 orchestrates extraction pipeline) ─────────────
UC01 ..> UC06 : <<include>>
UC01 ..> UC02 : <<include>>
UC01 ..> UC03 : <<include>>
UC01 ..> UC05 : <<include>>
UC01 ..> UC07 : <<include>>

' LLM extraction extends UC01 (rate-limited every 5 cycles)
UC04 ..> UC01 : <<extend>>\n[every 5 cycles]

' Learning tag pipeline
UC09 ..> UC10 : <<include>>

' Adaptation pipeline
UC13 ..> UC15 : <<include>>\n[on soft failure]

' State awareness pipeline
UC17 ..> UC18 : <<include>>
UC18 .right.> UC16 : reads\npersonality_state.json

note bottom of UC07
  Post-processing rules:
  • Remove cosmetic signals when actionable exist
  • Suppress signals seen 3+ times in last 8 events
  • Force innovation after 3+ repair loops
  • Force innovation after 4+ empty cycles
  • Default to stable_success_plateau
end note

note right of UC13
  SUCCESS → broadens gene.signals_match
  with problem:/area: tags
  FAILURE → appends anti_patterns only
  (no broadening)
end note

note right of UC04
  Synchronous via execSync + curl
  Falls back silently on failure
end note

@enduml
