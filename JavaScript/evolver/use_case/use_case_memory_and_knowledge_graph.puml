@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #1A1A2E
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #F0F4FF
    BorderColor #3A7BD5
    FontColor #1A1A2E
    BorderThickness 2
}

title Memory & Knowledge Graph

left to right direction

' ── Actors ──────────────────────────────────────────
actor "GEP Agent" as gepAgent
actor "Session Hook" as sessionHook

actor "External A2A Agent" as a2aAgent #D5F5E3
actor "Hub" as hub #D5F5E3

' ── System Boundary ──────────────────────────────────
rectangle "Memory & Knowledge Graph System" {

    ' ── Signal & Event Recording ─────────────────────
    package "Signal & Event Recording" {
        usecase "Compute Signal Key\n<size:10>(computeSignalKey)</size>" as UC01
        usecase "Record Signal Snapshot\n<size:10>(recordSignalSnapshot)</size>" as UC02
        usecase "Record Hypothesis\n<size:10>(recordHypothesis)</size>" as UC03
        usecase "Record Evolution Attempt\n<size:10>(recordAttempt)</size>" as UC04
        usecase "Record Outcome\n<size:10>(recordOutcomeFromState)</size>" as UC05
        usecase "Compute Predictive Boost\n<size:10>(computePredictiveBoost)</size>" as UC06
    }

    ' ── Memory Querying & Epoch Management ───────────
    package "Memory Querying & Epoch Management" {
        usecase "Get Memory Advice\n<size:10>(getMemoryAdvice)</size>" as UC07
        usecase "Read Current Epoch\n<size:10>(readCurrentEpoch)</size>" as UC10
        usecase "Check Epoch Boundary\n<size:10>(checkEpochBoundary)</size>" as UC08
        usecase "Reset Memory Preferences\n<size:10>(resetMemoryPreferences)</size>" as UC09
    }

    ' ── Session Lifecycle ─────────────────────────────
    package "Session Lifecycle" {
        usecase "Inject Memory Context\non Session Start" as UC12
        usecase "Record Session Outcome\non Session End" as UC13
    }

    ' ── Narrative Memory ─────────────────────────────
    package "Narrative Memory" {
        usecase "Build / Update\nEvolution Narrative" as UC14
        usecase "Query Evolution\nNarrative" as UC15
    }

    ' ── External Integration ─────────────────────────
    package "External Integration" {
        usecase "Record External\nCandidate" as UC11
    }
}

' ── Actor → Use Case associations ────────────────────

gepAgent --> UC01
gepAgent --> UC02
gepAgent --> UC03
gepAgent --> UC04
gepAgent --> UC05
gepAgent --> UC06
gepAgent --> UC07
gepAgent --> UC08
gepAgent --> UC09
gepAgent --> UC10
gepAgent --> UC14
gepAgent --> UC15

sessionHook --> UC12
sessionHook --> UC13

a2aAgent --> UC11

UC13 --> hub : records outcome\nvia REST API

' ── Include / Extend relationships ───────────────────

UC03 .> UC01 : <<include>>
UC04 .> UC01 : <<include>>
UC05 .> UC06 : <<include>>
UC07 .> UC10 : <<include>>
UC09 .> UC08 : <<extend>>

' UC05 depends on state written by UC04
UC05 ..> UC04 : <<precedes>>

' Narrative is queried to inject context
UC12 ..> UC15 : <<include>>

@enduml
