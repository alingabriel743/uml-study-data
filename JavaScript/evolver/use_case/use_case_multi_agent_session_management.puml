@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #EEF2F7
    BorderColor #6C757D
}

title Multi-Agent Session Management

left to right direction

actor "Agent" as agent
actor "Hub\n(evomap-hub)" as hub
actor "Store\n(MailboxStore)" as store

rectangle "Multi-Agent Session Management" {

    package "Session Lifecycle" {
        usecase "Create Session\nPOST /session/create" as UC1
        usecase "Join Session\nPOST /session/join" as UC2
        usecase "Leave Session\nPOST /session/leave" as UC3
    }

    package "Collaboration" {
        usecase "Send Message\nPOST /session/message" as UC4
        usecase "Delegate Subtask\nPOST /session/delegate" as UC5
        usecase "Submit Result\nPOST /session/submit" as UC6
    }

    package "Event Polling" {
        usecase "Poll Session Events\nPOST /session/events/poll" as UC7
        usecase "Poll Collaboration Invites\nPOST /session/invites/poll" as UC8
        usecase "List Active Sessions\nGET /session/list" as UC9
    }

    usecase "Publish to Store\n(store.send)" as UC_SEND
    usecase "Poll from Store\n(store.poll)" as UC_POLL
    usecase "List from Store\n(store.list)" as UC_LIST
}

' Agent initiates all use cases
agent --> UC1
agent --> UC2
agent --> UC3
agent --> UC4
agent --> UC5
agent --> UC6
agent --> UC7
agent --> UC8
agent --> UC9

' Write operations use store.send (high/normal priority)
UC1 ..> UC_SEND : <<include>>
UC2 ..> UC_SEND : <<include>>
UC3 ..> UC_SEND : <<include>>
UC4 ..> UC_SEND : <<include>>
UC5 ..> UC_SEND : <<include>>
UC6 ..> UC_SEND : <<include>>

' Read operations
UC7 ..> UC_POLL : <<include>>
UC8 ..> UC_POLL : <<include>>
UC9 ..> UC_LIST : <<include>>

' Store interactions
UC_SEND --> store : outbound sync
UC_POLL --> store : destructive read
UC_LIST --> store : non-destructive read

' Hub interactions
store --> hub : flush outbound\nmessages
hub --> store : deliver session_event\n& collaboration_invite

note bottom of UC1
  title (required)
  inviteNodeIds (max 10)
  maxParticipants (2–20)
  Priority: high
end note

note bottom of UC5
  role: builder | planner | reviewer
  toNodeId = null → broadcast
  Priority: high
end note

note bottom of UC7
  Destructive read
  session_event type
  limit: 20
end note

@enduml
