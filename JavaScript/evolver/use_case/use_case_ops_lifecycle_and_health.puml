@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Ops: Lifecycle & Health

left to right direction

actor "Operator / CLI" as CLI
actor "Evolver Loop Process" as EvolverProc
actor "Wrapper / External Caller" as Wrapper
actor "Operating System" as OS

rectangle "Ops: Lifecycle & Health" {

    package "Lifecycle Management (lifecycle.js)" {
        usecase "Start Evolver Loop" as UC1
        usecase "Stop Evolver Loop" as UC2
        usecase "Restart Evolver Loop" as UC3
        usecase "Query Loop Status" as UC4
        usecase "Tail Log Output" as UC5
        usecase "Check Process Health" as UC6
        usecase "Discover Running PIDs" as UC7
        usecase "Resolve Loop Script Path" as UC9
    }

    package "System Health (health_check.js)" {
        usecase "Run System Health Check" as UC8
    }

    package "Wake Trigger (trigger.js)" {
        usecase "Send Wake Trigger" as UC10
        usecase "Check Trigger Pending" as UC11
        usecase "Clear Wake Trigger" as UC12
    }
}

' --- Operator / CLI relationships ---
CLI --> UC1
CLI --> UC2
CLI --> UC3
CLI --> UC4
CLI --> UC5
CLI --> UC6
CLI --> UC8

' --- Wrapper / External Caller relationships ---
Wrapper --> UC10
Wrapper --> UC11
Wrapper --> UC12

' --- Evolver Loop Process relationships ---
EvolverProc --> UC11 : polls signal

' --- Operating System relationships ---
OS --> UC7 : provides ps output & signals
OS --> UC9 : provides filesystem & env vars
OS --> UC8 : provides disk / memory / proc stats

' --- Include relationships ---
UC1 ..> UC7 : <<include>>
UC1 ..> UC9 : <<include>>
UC2 ..> UC7 : <<include>>
UC3 ..> UC2 : <<include>>
UC3 ..> UC1 : <<include>>
UC4 ..> UC7 : <<include>>
UC6 ..> UC7 : <<include>>

' --- Extend relationships ---
UC6 ..> UC3 : <<extend>>\n[if unhealthy]

@enduml
