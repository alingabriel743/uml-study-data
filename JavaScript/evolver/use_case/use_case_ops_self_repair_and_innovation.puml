@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Ops: Self-Repair & Innovation

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────────
actor "OpsScheduler\n(CLI / Automated Trigger)" as OpsScheduler
actor "Git System\n(git CLI / execSync)"        as GitSystem
actor "File System\n(fs module)"                as FileSystem
actor "Skills Directory\n(disk)"                as SkillsDir
actor "Evolution Directory\n(gep_prompt_* files)" as EvolveDir

' ── System Boundary ──────────────────────────────────────────────────────────
rectangle "Ops: Self-Repair & Innovation" {

    ' ── Self-Repair sub-system ───────────────────────────────────────────
    package "Self-Repair  [self_repair.js]" {
        usecase "Abort Pending Rebase"        as UC1
        usecase "Abort Pending Merge"         as UC2
        usecase "Remove Stale index.lock"     as UC3
        usecase "Safe Fetch from Origin"      as UC5
        usecase "Hard Reset to origin/main\n[EVOLVE_GIT_RESET=true]" as UC4
    }

    ' ── Innovation sub-system ────────────────────────────────────────────
    package "Innovation Analysis  [innovation.js]" {
        usecase "List Installed Skills"       as UC6a
        usecase "Generate Innovation Ideas"   as UC6
    }

    ' ── Cleanup sub-system ───────────────────────────────────────────────
    package "Artifact Cleanup  [cleanup.js]" {
        usecase "Clean Up Aged GEP Artifacts\n(Age-Based Pass)"  as UC7
        usecase "Clean Up GEP Artifacts\n(Count-Cap Pass)"       as UC8
    }
}

' ── OpsScheduler → Use Cases ──────────────────────────────────────────────
OpsScheduler --> UC1
OpsScheduler --> UC2
OpsScheduler --> UC3
OpsScheduler --> UC5
OpsScheduler --> UC6
OpsScheduler --> UC7

' ── External System Interactions ─────────────────────────────────────────
GitSystem  <-- UC1  : git rebase --abort
GitSystem  <-- UC2  : git merge --abort
FileSystem <-- UC3  : delete .git/index.lock
GitSystem  <-- UC5  : git fetch origin
GitSystem  <-- UC4  : git fetch + reset --hard
SkillsDir  <-- UC6a : readdir skills/
EvolveDir  <-- UC7  : scan gep_prompt_*
EvolveDir  <-- UC8  : delete oldest excess files

' ── Include / Extend Relationships ───────────────────────────────────────
UC4 ..> UC5  : <<extend>>\n[EVOLVE_GIT_RESET=true]
UC8 ..> UC7  : <<extend>>\n[count > MAX_FILES]
UC6 ..> UC6a : <<include>>

@enduml
