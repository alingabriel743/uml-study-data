@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Ops: Skills Monitoring & Commentary

left to right direction

actor "OpsSystem\n(Scheduler / CLI)" as OpsSystem
actor "Admin / Operator\n(Manual Trigger)" as Admin
actor "FileSystem\n(External)" as FileSystem

rectangle "Skills Monitoring & Commentary" {

    usecase "Run Skills Monitor" as UC1
    note right of UC1
      run(options: { autoHeal? })
      Returns issue report
    end note

    usecase "Check Individual\nSkill Health" as UC2
    note right of UC2
      Validates package.json,
      node_modules, SKILL.md
    end note

    usecase "Auto-Heal\nSkill Issues" as UC3
    note right of UC3
      npm install --production
      Creates SKILL.md stub
    end note

    usecase "Load Skill\nIgnore List" as UC4
    note right of UC4
      Reads .skill_monitor_ignore
      Hard-coded ignores applied
    end note

    usecase "Generate Cycle\nCommentary" as UC5
    note right of UC5
      getComment({ persona?,
      success?, duration? })
    end note

    usecase "Select Commentary\nPersona" as UC6
    note right of UC6
      standard / greentea / maddog
    end note

    usecase "Report Unresolved\nSkill Issues" as UC7
    note right of UC7
      CLI: prints JSON to stdout
      exit 1 if issues remain
    end note

}

' Actor → Use Case associations
OpsSystem --> UC1
OpsSystem --> UC5
OpsSystem --> UC7

Admin --> UC1
Admin --> UC5
Admin --> UC7

FileSystem --> UC4

' Include / Extend relationships
UC1 ..> UC2 : <<include>>\nper skill
UC1 ..> UC3 : <<include>>\nautoHeal=true
UC1 ..> UC4 : <<include>>\nat startup
UC5 ..> UC6 : <<include>>\npersona selection
UC7 ..> UC1 : <<extend>>\nCLI wrapper

@enduml
