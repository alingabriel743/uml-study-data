@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Proxy Direct Messaging

left to right direction

actor "Agent" as agent #D0E8FF

rectangle "Proxy Direct Messaging" {

    usecase "Send Direct Message\n<size:10><color:#6C757D>POST /dm/send</color></size>" as UC1
    usecase "Poll Direct Messages\n<size:10><color:#6C757D>POST /dm/poll</color></size>" as UC2
    usecase "List Direct Messages\n<size:10><color:#6C757D>GET /dm/list</color></size>" as UC4
    usecase "Acknowledge Messages\n<size:10><color:#6C757D>POST /mailbox/ack</color></size>" as UC3

    usecase "Route via DmHandler\n<size:10><color:#6C757D>(or fallback direct to Store)</color></size>" as UC_DELEGATE

}

actor "Store\n(MailboxStore)" as store #D4EDDA

' Agent initiates all DM operations
agent --> UC1
agent --> UC2
agent --> UC4
agent --> UC3

' Send, Poll and List flow through DmHandler delegation
UC1 .down.> UC_DELEGATE : <<include>>
UC2 .down.> UC_DELEGATE : <<include>>
UC4 .down.> UC_DELEGATE : <<include>>

' DmHandler (or fallback) calls Store for persistence
UC_DELEGATE --> store : store.send()\nstore.poll()\nstore.list()

' Acknowledge goes straight to Store (no DmHandler route)
UC3 --> store : store.ack()

note bottom of UC_DELEGATE
  DmHandler is an optional extension injected at startup
  (EvoMapProxy.start → new DmHandler({ store, logger })).
  If absent, routes call store.send/poll/list directly.
  Message type discriminator is always **'dm'**.
end note

note right of UC3
  No dedicated /dm/ack route.
  /mailbox/ack bypasses DmHandler
  and calls store.ack(message_ids) directly.
end note

@enduml
