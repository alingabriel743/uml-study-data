@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #343A40
    FontColor #212529
}

title Proxy HTTP Server & Routing

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────
actor "External Client\n(Claude Agent / SDK)" as client
actor "EvoMapProxy\n(Orchestrator)"           as proxy
actor "EvoMap Hub\n(Remote Server)"           as hub

' ── System Boundary ──────────────────────────────────────────────────────
rectangle "EvoMap Proxy HTTP Server  (127.0.0.1:19820+)" {

    ' ── Server Lifecycle ─────────────────────────────────────────────
    package "Server Lifecycle" {
        usecase "Start HTTP Server\n(port-scan 19820+)" as UC_Start
        usecase "Stop HTTP Server"                      as UC_Stop
        usecase "Match & Route Request\n(_matchRoute)"  as UC_Route
        note right of UC_Route
          Iterates route map,
          resolves :param segments
          via matchPath()
        end note
    }

    ' ── Mailbox ──────────────────────────────────────────────────────
    package "Mailbox  (/mailbox/*)" {
        usecase "Send Message\nPOST /mailbox/send"         as UC_MbSend
        usecase "Poll Messages\nPOST /mailbox/poll"        as UC_MbPoll
        usecase "Acknowledge Messages\nPOST /mailbox/ack"  as UC_MbAck
        usecase "List Messages\nGET /mailbox/list"         as UC_MbList
        usecase "Get Message Status\nGET /mailbox/status/:id" as UC_MbStatus
    }

    ' ── Asset ────────────────────────────────────────────────────────
    package "Asset  (/asset/*)" {
        usecase "Validate Asset\nPOST /asset/validate"         as UC_AssetVal
        usecase "Fetch Asset\nPOST /asset/fetch"               as UC_AssetFetch
        usecase "Search Assets\nPOST /asset/search"            as UC_AssetSearch
        usecase "Submit Asset\nPOST /asset/submit"             as UC_AssetSubmit
        usecase "Get Asset Submissions\nGET /asset/submissions" as UC_AssetSubs
    }

    ' ── Task ─────────────────────────────────────────────────────────
    package "Task  (/task/*)" {
        usecase "Subscribe to Tasks\nPOST /task/subscribe"       as UC_TaskSub
        usecase "Unsubscribe from Tasks\nPOST /task/unsubscribe" as UC_TaskUnsub
        usecase "List Available Tasks\nGET /task/list"           as UC_TaskList
        usecase "Claim Task\nPOST /task/claim"                   as UC_TaskClaim
        usecase "Complete Task\nPOST /task/complete"             as UC_TaskComplete
        usecase "Get Task Metrics\nGET /task/metrics"            as UC_TaskMetrics
    }

    ' ── Direct Message ───────────────────────────────────────────────
    package "Direct Message  (/dm/*)" {
        usecase "Send Direct Message\nPOST /dm/send"      as UC_DmSend
        usecase "Poll Direct Messages\nPOST /dm/poll"     as UC_DmPoll
        usecase "List Direct Messages\nGET /dm/list"      as UC_DmList
    }

    ' ── Session (Collaboration) ───────────────────────────────────────
    package "Session  (/session/*)" {
        usecase "Create Session\nPOST /session/create"              as UC_SessCreate
        usecase "Join Session\nPOST /session/join"                  as UC_SessJoin
        usecase "Leave Session\nPOST /session/leave"                as UC_SessLeave
        usecase "Send Session Message\nPOST /session/message"       as UC_SessMsg
        usecase "Delegate Subtask\nPOST /session/delegate"          as UC_SessDelegate
        usecase "Submit Session Result\nPOST /session/submit"       as UC_SessSubmit
        usecase "Poll Session Invites\nPOST /session/invites/poll"  as UC_SessInvites
        usecase "List Sessions\nGET /session/list"                  as UC_SessList
    }

    ' ── System ───────────────────────────────────────────────────────
    package "System  (/proxy/*)" {
        usecase "Check Proxy Status\nGET /proxy/status"       as UC_SysStatus
        usecase "Get Proxy Config\nGET /proxy/config"         as UC_SysConfig
        usecase "Get Hub Status\nGET /proxy/hub-status"       as UC_HubStatus
    }

}

' ── Actor → Use Case Relationships ───────────────────────────────────────

' EvoMapProxy lifecycle
proxy --> UC_Start
proxy --> UC_Stop

' External Client — Mailbox
client --> UC_MbSend
client --> UC_MbPoll
client --> UC_MbAck
client --> UC_MbList
client --> UC_MbStatus

' External Client — Asset
client --> UC_AssetVal
client --> UC_AssetFetch
client --> UC_AssetSearch
client --> UC_AssetSubmit
client --> UC_AssetSubs

' External Client — Task
client --> UC_TaskSub
client --> UC_TaskUnsub
client --> UC_TaskList
client --> UC_TaskClaim
client --> UC_TaskComplete
client --> UC_TaskMetrics

' External Client — Direct Message
client --> UC_DmSend
client --> UC_DmPoll
client --> UC_DmList

' External Client — Session
client --> UC_SessCreate
client --> UC_SessJoin
client --> UC_SessLeave
client --> UC_SessMsg
client --> UC_SessDelegate
client --> UC_SessSubmit
client --> UC_SessInvites
client --> UC_SessList

' External Client — System
client --> UC_SysStatus
client --> UC_SysConfig
client --> UC_HubStatus

' EvoMap Hub is queried for hub-status
UC_HubStatus --> hub

' All HTTP requests flow through routing
UC_MbSend      ..> UC_Route : <<include>>
UC_AssetVal    ..> UC_Route : <<include>>
UC_TaskClaim   ..> UC_Route : <<include>>
UC_DmSend      ..> UC_Route : <<include>>
UC_SessCreate  ..> UC_Route : <<include>>
UC_SysStatus   ..> UC_Route : <<include>>

@enduml
