@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Proxy Mailbox & Settings

left to right direction

' ── Actors ──────────────────────────────────────────────────
actor "Agent" as Agent
actor "Agent Bootstrap" as AgentBootstrap
actor "Hub / GEP Backend" as Hub #D9EAD3
actor "~/.evolver/settings.json" as SettingsFile #FFF2CC

' ── System Boundary ─────────────────────────────────────────
rectangle "Proxy Mailbox Module (src/proxy/)" {

    ' Mailbox Messaging
    package "Mailbox Messaging" {
        usecase "Send Outbound Message\n(POST /mailbox/send)" as UC01
        usecase "Poll Inbound Messages\n(POST /mailbox/poll)" as UC02
        usecase "Acknowledge Inbound Messages\n(POST /mailbox/ack)" as UC03
        usecase "List Messages by Type\n(GET /mailbox/list)" as UC04
        usecase "Get Message Status\n(GET /mailbox/status/:id)" as UC05
    }

    ' Proxy Server Lifecycle
    package "Proxy Server Lifecycle" {
        usecase "Start Proxy Server" as UC06
        usecase "Stop Proxy Server" as UC07
        usecase "Discover Proxy URL" as UC08
    }

    ' Proxy Introspection
    package "Proxy Introspection" {
        usecase "Get Proxy Status\n(GET /proxy/status)" as UC09
        usecase "Get Proxy Config\n(GET /proxy/config)" as UC10
    }

    ' Internal / Maintenance
    package "Internal & Maintenance" {
        usecase "Manage Cursors / State" as UC11
        usecase "Register Mailbox Transport" as UC13
    }
}

' ── Agent relationships ──────────────────────────────────────
Agent --> UC01 : send message
Agent --> UC02 : receive messages
Agent --> UC03 : ack delivery
Agent --> UC04 : browse messages
Agent --> UC05 : check status
Agent --> UC06 : start proxy
Agent --> UC07 : stop proxy
Agent --> UC08 : resolve proxy URL
Agent --> UC09 : inspect proxy
Agent --> UC10 : read config

' ── Agent Bootstrap ──────────────────────────────────────────
AgentBootstrap --> UC13 : register transport

' ── Hub / GEP Backend ────────────────────────────────────────
Hub --> UC11 : manage sync cursors

' ── Settings file read/write ─────────────────────────────────
UC06 --> SettingsFile : write proxy url + pid
UC07 --> SettingsFile : clear proxy entry
UC08 --> SettingsFile : read proxy url

' ── Include relationships ─────────────────────────────────────
UC01 ..> UC08 : <<include>>
UC02 ..> UC08 : <<include>>
UC04 ..> UC08 : <<include>>

@enduml
