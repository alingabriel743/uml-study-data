@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #FFFFFF
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #C8A000
    FontColor #333333
    FontSize 10
}

title Proxy Node Registration & Lifecycle

left to right direction

' ── Actors ────────────────────────────────────────────────────────────────
actor "Proxy Agent\n(LifecycleManager)" as proxyAgent
actor "Hub\n(A2A Hub Server)" as hub
actor "Store\n(MailboxStore)" as store
actor "EnvFingerprint" as envFp

' ── System boundary ───────────────────────────────────────────────────────
rectangle "LifecycleManager — Proxy Node Lifecycle" {

  usecase "Register with Hub\n//POST /a2a/hello//" as UC1
  usecase "Rotate Secret\n//hello(rotateSecret=true)//" as UC2
  usecase "Send Heartbeat\n//POST /a2a/heartbeat//" as UC3
  usecase "Re-authenticate\n//(up to 2 attempts)//" as UC4
  usecase "Start Heartbeat Loop\n//(default 6 min, backoff 30 min max)//" as UC5
  usecase "Stop Heartbeat Loop" as UC6
  usecase "Handle Hub Events\n//(write inbound batch)//" as UC7
  usecase "Handle Upgrade Required\n//(write proxy_upgrade_required)//" as UC8
  usecase "Re-register Unknown Node\n//(status=unknown_node)//" as UC9

}

' ── Proxy Agent initiates ─────────────────────────────────────────────────
proxyAgent --> UC1 : register / authenticate
proxyAgent --> UC3 : send heartbeat
proxyAgent --> UC5 : start loop
proxyAgent --> UC6 : stop loop

' ── Hub drives response-side use cases ───────────────────────────────────
hub --> UC7 : returns events[]
hub --> UC8 : returns min_proxy_version
hub --> UC9 : returns status=unknown_node

' ── External dependency connections ──────────────────────────────────────
UC1 --> envFp : capture env fingerprint
UC3 --> envFp : capture env fingerprint
UC1 --> store : persist node_id & node_secret
UC3 --> store : update last_heartbeat_at
UC7 --> store : write inbound batch\n(channel=evomap-hub)
UC8 --> store : write upgrade_required\nsystem message

' ── Include relationships ─────────────────────────────────────────────────
UC3 .down.> UC1  : <<include>>\nauto-register if no nodeId
UC3 .down.> UC4  : <<include>>\non 401 / 403 response
UC4 .down.> UC2  : <<include>>\nrotate secret
UC4 .down.> UC3  : <<include>>\nverify (_skipReauth=true)
UC5 .down.> UC3  : <<include>>\non each timer tick
UC9 .down.> UC1  : <<include>>\ncalls hello() to re-register

' ── Extend relationships ──────────────────────────────────────────────────
UC7 .up.> UC3 : <<extend>>\nevents present in response
UC8 .up.> UC3 : <<extend>>\nversion behind threshold
UC9 .up.> UC3 : <<extend>>\nunknown_node in response

' ── Key constants note ────────────────────────────────────────────────────
note bottom of UC5
  <b>Intervals & Timeouts</b>
  Default heartbeat: 360,000 ms (6 min)
  Min interval: 30,000 ms
  Hello timeout: 15,000 ms
  Heartbeat timeout: 10,000 ms
  Max reauth attempts: 2
  Backoff ceiling: 30 min
end note

@enduml
