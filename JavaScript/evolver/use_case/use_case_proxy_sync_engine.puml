@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9E6
    BorderColor #CCA300
}

title Proxy Sync Engine\n<size:11><color:#6C757D>Inbound and outbound sync operations keep local proxy state consistent with the hub</color></size>

left to right direction

actor "Proxy Node" as ProxyNode
actor "Hub\n<size:10>(Remote Server)</size>" as Hub
actor "Lifecycle\nManager" as LifecycleManager
actor "Mailbox\nStore" as MailboxStore

rectangle "Proxy Sync Engine" {

    package "Lifecycle Control" {
        usecase "Start Sync Engine" as UC1
        usecase "Stop Sync Engine" as UC2
        usecase "Accelerate Outbound Flush\n<size:9>reschedule timer → 100 ms</size>" as UC3
    }

    package "Outbound Sync" {
        usecase "Flush Outbound Messages\n<size:9>POST /a2a/mailbox/outbound  |  batch ≤ 50</size>" as UC4
        usecase "Retry Failed Outbound Message\n<size:9>retry_count < 10  →  incrementRetry()</size>" as UC8
        usecase "Write Inline Hub Response\nas Inbound Message" as UC9
    }

    package "Inbound Sync" {
        usecase "Pull Inbound Messages\n<size:9>POST /a2a/mailbox/inbound  |  limit 50</size>" as UC5
        usecase "Acknowledge Delivered Messages\n<size:9>POST /a2a/mailbox/ack</size>" as UC7
    }

    package "Error Handling" {
        usecase "Handle Auth Error\n<size:9>HTTP 401/403 → onAuthError callback</size>" as UC6
    }
}

' ── Primary actor initiates lifecycle ─────────────────────────────────────
ProxyNode --> UC1 : start
ProxyNode --> UC2 : stop
ProxyNode --> UC3 : new outbound queued

' ── Hub is the remote endpoint for all network operations ─────────────────
UC4 --> Hub : POST outbound batch
UC5 --> Hub : POST fetch inbound
UC7 --> Hub : POST ack delivered

' ── MailboxStore provides/persists all message state ─────────────────────
UC4 --> MailboxStore : pollOutbound /\nupdateStatusBatch
UC5 --> MailboxStore : getCursor /\nwriteInboundBatch
UC7 --> MailboxStore : list delivered
UC8 --> MailboxStore : incrementRetry /\nmarkFailed
UC9 --> MailboxStore : writeInboundBatch

' ── LifecycleManager handles re-auth on auth failures ────────────────────
UC6 --> LifecycleManager : invoke onAuthError

' ── <<include>> relationships ─────────────────────────────────────────────
UC4 ..> UC6 : <<include>>
UC5 ..> UC6 : <<include>>

' ── <<extend>> relationships ──────────────────────────────────────────────
UC3 ..> UC1 : <<extend>>\npost-start acceleration
UC8 ..> UC4 : <<extend>>\nrejected message
UC9 ..> UC4 : <<extend>>\ninline response present

note bottom of UC4
  Outbound intervals:
  • Immediate: 100 ms (notifyNewOutbound)
  • Pending remain: 1 s
  • Queue empty: 5 s
end note

@enduml
