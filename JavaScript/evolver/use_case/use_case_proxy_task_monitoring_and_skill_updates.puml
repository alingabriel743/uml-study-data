@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2E6DA4
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343A40
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontColor #555555
}

title Proxy Task Monitoring & Skill Updates

left to right direction

' ── Primary Actors ──────────────────────────────────────────────
actor "Proxy Agent" as ProxyAgent
actor "Administrator" as Admin

' ── External / Supporting Actors ────────────────────────────────
actor "Hub\n(Remote Message Bus)" as Hub  #D4EDDA
actor "Store\n(Persistent State)" as Store  #FFF3CD
actor "Filesystem" as FS  #FFF3CD

' ── System Boundary ─────────────────────────────────────────────
rectangle "Proxy Task & Skill Modules" {

    ' ── Task Monitor Use Cases ──────────────────────────────────
    package "Task Monitor" {
        usecase "Subscribe to\nTask Queue" as UC1
        usecase "Unsubscribe from\nTask Queue" as UC2
        usecase "Record Task\nClaimed" as UC3
        usecase "Record Task\nCompleted" as UC4
        usecase "Record Task\nFailed" as UC5
        usecase "View Task\nMetrics" as UC6
        usecase "Report Heartbeat\nMetadata" as UC7
    }

    ' ── Skill Updater Use Cases ─────────────────────────────────
    package "Skill Updater" {
        usecase "Poll & Apply\nSkill Updates" as UC8
        usecase "Process Single\nSkill Update" as UC9
        usecase "Configure\nSkill Path" as UC10
    }

    ' ── Lifecycle Utilities ─────────────────────────────────────
    package "Loop Bridge Utilities" {
        usecase "Check Pending\nSolidify" as UC11
        usecase "Reject Pending\nRun" as UC12
    }
}

' ── ProxyAgent → Task Monitor ────────────────────────────────────
ProxyAgent --> UC1 : subscribes
ProxyAgent --> UC2 : unsubscribes
ProxyAgent --> UC3 : on task claimed
ProxyAgent --> UC4 : on task completed
ProxyAgent --> UC5 : on task failed
ProxyAgent --> UC6 : reads metrics
ProxyAgent --> UC7 : heartbeat cycle
ProxyAgent --> UC8 : periodic polling
ProxyAgent --> UC11 : before each cycle
ProxyAgent --> UC12 : when bridge disabled

' ── Administrator ────────────────────────────────────────────────
Admin --> UC10 : sets skill path
Admin --> UC1  : configures capability filters

' ── Hub interactions ─────────────────────────────────────────────
Hub --> UC1   : delivers task messages\n(via Store)
Hub --> UC8   : delivers skill_update\nmessages (via Store)

' ── Store interactions ───────────────────────────────────────────
UC1  --> Store : getState / setState / send
UC3  --> Store : setState (metrics)
UC4  --> Store : setState (metrics + avg_ms)
UC5  --> Store : setState (metrics)
UC6  --> Store : getState / countPending
UC8  --> Store : poll / ack / setState
UC9  --> Store : setState\n(skill_version, last_skill_update)

' ── Filesystem interactions ──────────────────────────────────────
UC9  --> FS : write skill.md\n+ backup (.bak)
UC12 --> FS : atomic write\n(tmp → rename)

' ── Include / Extend relationships ───────────────────────────────
UC8 ..> UC9  : <<include>>
UC11 ..> UC1 : <<extend>>\n(gates cycle start)
UC11 ..> UC3 : <<extend>>\n(gates cycle start)
UC12 ..> UC8 : <<extend>>\n(auto-reject if\nbridge disabled)

' ── Notes ────────────────────────────────────────────────────────
note right of UC4
  Rolling 100-sample window
  for avg_completion_ms;
  persisted across restarts
end note

note right of UC9
  Backs up existing skill.md
  before overwriting;
  records skill_version in Store
end note

note bottom of UC12
  Auto-rejects with reason:
  "loop_bridge_disabled_autoreject
  _no_rollback"; state-only,
  no git rollback
end note

@enduml
