@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}

left to right direction

title Security, Integrity & Policy

actor "GEP Agent" as agent
actor "Hub\n(A2A Privacy API)" as hub
actor "Process\nEnvironment" as procenv

rectangle "Security, Integrity & Policy" {

    package "Shield  (shield.js)" as PKG_SHIELD {
        usecase "Detect Debugger /\nInspection" as UC_SHIELD_1
        usecase "Snapshot\nEnvironment" as UC_SHIELD_2
        usecase "Validate Environment\nUnchanged" as UC_SHIELD_3
        usecase "Check Compromised\nStatus" as UC_SHIELD_4
        usecase "Freeze Object\n(Tamper-Proof)" as UC_SHIELD_5
    }

    package "Integrity  (integrityCheck.js)" as PKG_INTEGRITY {
        usecase "Verify File\nIntegrity" as UC_INTEGRITY_1
        usecase "Wrap Result with\nIntegrity Status" as UC_INTEGRITY_3
        usecase "Apply Integrity-\nBased Delay" as UC_INTEGRITY_4
    }

    package "Policy  (policyCheck.js)" as PKG_POLICY {
        usecase "Evaluate Policy\nRules" as UC_POLICY_1
    }

    package "Sanitize  (sanitize.js)" as PKG_SANITIZE {
        usecase "Sanitize Capsule\nPayload" as UC_SANITIZE_1
        usecase "Redact Sensitive\nStrings" as UC_SANITIZE_2
        usecase "Scan Content\nfor Leaks" as UC_SANITIZE_3
        usecase "Detect Env\nValue Leaks" as UC_SANITIZE_4
        usecase "Full Leak\nCheck" as UC_SANITIZE_5
    }

    package "Privacy  (privacyClient.js)" as PKG_PRIVACY {
        usecase "Parse Privacy\nParams from Task" as UC_PRIVACY_6
        usecase "Submit Privacy\nComputing Task" as UC_PRIVACY_1
        usecase "Upload Encrypted\nBlob" as UC_PRIVACY_2
        usecase "Execute Sealed\nTool on Blob" as UC_PRIVACY_3
        usecase "Poll Privacy\nTask Status" as UC_PRIVACY_4
        usecase "Retrieve & Decrypt\nPrivacy Result" as UC_PRIVACY_5
    }
}

' ── GEP Agent ──────────────────────────────────────────
agent --> UC_SHIELD_1
agent --> UC_SHIELD_3
agent --> UC_SHIELD_4
agent --> UC_SHIELD_5
agent --> UC_INTEGRITY_1
agent --> UC_INTEGRITY_3
agent --> UC_INTEGRITY_4
agent --> UC_POLICY_1
agent --> UC_SANITIZE_1
agent --> UC_SANITIZE_5
agent --> UC_PRIVACY_6
agent --> UC_PRIVACY_1

' ── Process Environment ────────────────────────────────
procenv --> UC_SHIELD_1
procenv --> UC_SHIELD_3

' ── Hub (A2A Privacy API) ──────────────────────────────
UC_PRIVACY_1 --> hub
UC_PRIVACY_2 --> hub
UC_PRIVACY_3 --> hub
UC_PRIVACY_4 --> hub
UC_PRIVACY_5 --> hub

' ── Include relationships ──────────────────────────────
UC_SHIELD_1 ..> UC_SHIELD_2    : <<include>>
UC_SANITIZE_1 ..> UC_SANITIZE_2 : <<include>>
UC_SANITIZE_5 ..> UC_SANITIZE_3 : <<include>>
UC_SANITIZE_5 ..> UC_SANITIZE_4 : <<include>>

' ── Extend relationships ───────────────────────────────
UC_INTEGRITY_3 ..> UC_INTEGRITY_1 : <<extend>>
UC_PRIVACY_1   ..> UC_PRIVACY_2   : <<extend>>
UC_PRIVACY_2   ..> UC_PRIVACY_3   : <<extend>>
UC_PRIVACY_3   ..> UC_PRIVACY_4   : <<extend>>
UC_PRIVACY_4   ..> UC_PRIVACY_5   : <<extend>>

note bottom of UC_POLICY_1
  Fully obfuscated (~135K tokens).
  Enforces allow / block rules on
  agent actions (BLOCKED: prefix visible).
end note

note right of UC_PRIVACY_2
  AES-256-GCM client-side encryption.
  Hub never receives plaintext.
end note

@enduml
