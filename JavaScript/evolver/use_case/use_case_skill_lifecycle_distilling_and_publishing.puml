@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C7BBF
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #F0F4F8
    BorderColor #6C757D
    FontColor #343A40
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 10
skinparam ArrowFontColor #6C757D

title Skill Lifecycle: Distilling & Publishing

left to right direction

' ─── Actors ───────────────────────────────────────────────
actor "GEP Engine" as GEP #D0E8FF
actor "LLM Service" as LLM #FFF3CD
actor "Skill Hub" as HUB #D5F5E3
actor "Agent Proxy" as PROXY #E8D5F5
actor "Developer / Admin" as ADMIN #FFE8D5

' ─── System Boundary ──────────────────────────────────────
rectangle "Skill Lifecycle System" {

    ' ── Distillation Pipeline ─────────────────────────────
    package "Distillation Pipeline" {
        usecase "Check Distillation\nEligibility" as UC01
        usecase "Collect Distillation\nData" as UC02
        usecase "Analyze Patterns" as UC03
        usecase "Build Distillation\nPrompt" as UC05
        usecase "Prepare Distillation\nRequest" as UC04
        usecase "Synthesize Gene\nvia LLM" as UC06
        usecase "Complete\nDistillation" as UC07
        usecase "Validate Synthesized\nGene" as UC08
    }

    ' ── Heuristic (No-LLM) Path ───────────────────────────
    package "Auto Distill (No LLM)" {
        usecase "Auto Distill\n(Heuristic)" as UC09
        usecase "Synthesize Gene\nFrom Patterns" as UC10
    }

    ' ── Publishing ────────────────────────────────────────
    package "Skill Publishing" {
        usecase "Convert Gene\nto Skill.md" as UC13
        usecase "Publish Skill\nto Hub" as UC11
        usecase "Update Existing\nSkill on Hub" as UC12
    }

    ' ── Curriculum & Updates ──────────────────────────────
    package "Curriculum & Skill Updates" {
        usecase "Manage\nCurriculum" as UC14
        usecase "Poll and Apply\nSkill Update" as UC15
        usecase "Process Skill\nUpdate" as UC16
        usecase "Configure\nSkill Path" as UC17
    }
}

' ─── Actor → Use Case Relationships ──────────────────────
GEP --> UC01
GEP --> UC04
GEP --> UC07
GEP --> UC09
GEP --> UC11
GEP --> UC14

LLM --> UC06

PROXY --> UC15

ADMIN --> UC17
ADMIN --> UC01 : enable/disable\n(SKILL_DISTILLER)

HUB --> UC11 : receives skill\npublication

' ─── Include Relationships ────────────────────────────────
UC01 ..> UC02 : <<include>>
UC04 ..> UC02 : <<include>>
UC04 ..> UC03 : <<include>>
UC04 ..> UC05 : <<include>>
UC07 ..> UC08 : <<include>>
UC09 ..> UC02 : <<include>>
UC09 ..> UC03 : <<include>>
UC09 ..> UC10 : <<include>>
UC09 ..> UC08 : <<include>>
UC11 ..> UC13 : <<include>>
UC15 ..> UC16 : <<include>>

' ─── Extend Relationships ─────────────────────────────────
UC12 ..> UC11 : <<extend>>\non 409 conflict

' ─── Dependencies (data flow) ─────────────────────────────
UC06 ..> UC04 : reads promptPath
UC07 ..> UC06 : receives LLM\nresponse text

@enduml
