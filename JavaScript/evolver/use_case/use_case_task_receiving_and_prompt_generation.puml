@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #495057
    FontColor #212529
}

left to right direction

title Task Receiving & Prompt Generation

' ── Primary actors (left) ──────────────────────────────
actor "GEP Evolution\nCycle" as GEP
actor "Post-Solidify\nHook" as PostSolidify

' ── External systems (right) ──────────────────────────
actor "Hub\n(evomap.ai)" as Hub
actor "Peer Agent" as Peer

' ── System boundary ───────────────────────────────────
rectangle "Task Receiving & Prompt Generation" {

    ' --- Task Acquisition ---
    usecase "Fetch Tasks\nfrom Hub" as UC1
    usecase "Select Best Task" as UC2
    usecase "Claim Task\non Hub" as UC3
    usecase "Complete Task\non Hub" as UC4
    usecase "Claim & Complete\nWorker Pool Task" as UC5
    usecase "Extract Signals\nfrom Task" as UC6

    ' --- Prompt Generation ---
    usecase "Generate GEP\nEvolution Prompt" as UC8

    ' --- Question Generation ---
    usecase "Generate Standard\nProactive Questions" as UC9
    usecase "Generate Urgent\nQuestions (Post-Solidify)" as UC10
    usecase "Piggyback Questions\non Fetch Request" as UC12

    ' --- Peer Messaging ---
    usecase "Send Message\nvia Mailbox" as UC13
    usecase "Receive Messages\nvia Mailbox" as UC14
    usecase "Register Mailbox\nTransport" as UC15
}

' ── GEP actor → use case associations ─────────────────
GEP --> UC1
GEP --> UC2
GEP --> UC3
GEP --> UC4
GEP --> UC5
GEP --> UC6
GEP --> UC8
GEP --> UC9
GEP --> UC12
GEP --> UC13
GEP --> UC14
GEP --> UC15

' ── Post-Solidify Hook actor ───────────────────────────
PostSolidify --> UC10

' ── Hub participates in (secondary / right-side) ──────
Hub --> UC1
Hub --> UC3
Hub --> UC4
Hub --> UC5
Hub --> UC12

' ── Peer Agent participates in ─────────────────────────
Peer --> UC13
Peer --> UC14

' ── «include» / «extend» relationships ────────────────

' Piggybacked questions optionally extend the fetch call
UC1 <.. UC12 : <<extend>>

@enduml
