@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}

left to right direction

title Tool Adapter Integrations (Claude Code / Codex / Cursor)

actor "Developer" as developer
actor "FileSystem\n(configs, scripts,\nmarkdown docs)" as fs

rectangle "Tool Adapter Integration System" {

    package "Orchestration  [hookAdapter]" {
        usecase "Orchestrate Hook Setup\n[setupHooks()]" as UC15
        usecase "Auto-detect Platform\n[detectPlatform()]" as UC1
        usecase "Resolve Config Root\n[resolveConfigRoot()]" as UC2
        usecase "Load Platform Adapter\n[loadAdapter()]" as UC3
    }

    package "Claude Code Adapter" {
        usecase "Install Hooks\n(.claude/settings.json + CLAUDE.md\nSessionStart / PostToolUse / Stop)" as UC4
        usecase "Uninstall Hooks\n(filter settings.json,\nstrip CLAUDE.md marker)" as UC5
    }

    package "Codex Adapter" {
        usecase "Install Hooks\n(.codex/hooks.json + config.toml\n+ AGENTS.md + ensureConfigToml)" as UC6
        usecase "Uninstall Hooks\n(filter hooks.json,\nstrip AGENTS.md marker)" as UC7
    }

    package "Cursor Adapter" {
        usecase "Install Hooks\n(.cursor/hooks.json v1\nsessionStart / afterFileEdit / stop\nuser-level install supported)" as UC8
        usecase "Uninstall Hooks\n(removeEvolverHooks\n+ removeHookScripts)" as UC9
    }

    package "Shared Hook Utilities  [hookAdapter]" {
        usecase "Merge JSON Config File\n(deepMerge + _evolver_managed\natomic tmp-rename write)" as UC10
        usecase "Copy Hook Scripts\nto Platform Hooks Dir\n(evolver-session-start/signal-detect/session-end)" as UC11
        usecase "Inject Evolution Memory\nSection into Markdown\n(EVOLVER_MARKER guard)" as UC12
        usecase "Remove Evolver Hooks\nfrom JSON Config\n(filter evolver-session*/signal* keys)" as UC13
        usecase "Remove Hook Scripts\nfrom Platform Hooks Dir" as UC14
    }
}

' Developer is the primary actor who triggers the entry point
developer --> UC15

' Orchestration always includes: detect → resolve → load
UC15 ..> UC1 : <<include>>
UC15 ..> UC2 : <<include>>
UC15 ..> UC3 : <<include>>

' setupHooks conditionally delegates to the detected platform adapter
UC15 ..> UC4 : <<extend>>\n[platform=claudeCode, install]
UC15 ..> UC5 : <<extend>>\n[platform=claudeCode, uninstall]
UC15 ..> UC6 : <<extend>>\n[platform=codex, install]
UC15 ..> UC7 : <<extend>>\n[platform=codex, uninstall]
UC15 ..> UC8 : <<extend>>\n[platform=cursor, install]
UC15 ..> UC9 : <<extend>>\n[platform=cursor, uninstall]

' Claude Code install/uninstall include shared utilities
UC4 ..> UC10 : <<include>>
UC4 ..> UC11 : <<include>>
UC4 ..> UC12 : <<include>>
UC5 ..> UC13 : <<include>>
UC5 ..> UC14 : <<include>>

' Codex install/uninstall include shared utilities
UC6 ..> UC10 : <<include>>
UC6 ..> UC11 : <<include>>
UC6 ..> UC12 : <<include>>
UC7 ..> UC13 : <<include>>
UC7 ..> UC14 : <<include>>

' Cursor install/uninstall include shared utilities (no markdown injection)
UC8 ..> UC10 : <<include>>
UC8 ..> UC11 : <<include>>
UC9 ..> UC13 : <<include>>
UC9 ..> UC14 : <<include>>

' All shared utilities read/write the FileSystem
UC10 --> fs
UC11 --> fs
UC12 --> fs
UC13 --> fs
UC14 --> fs

@enduml
