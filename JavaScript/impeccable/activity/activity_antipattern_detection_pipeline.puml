@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam startColor #2D6A4F
skinparam endColor #C0392B

title Anti-Pattern Detection Pipeline

|CLI|
start
:Parse CLI arguments\n(--json, --fast, --help);

if (--help flag?) then (yes)
  :Print usage and exit;
  end
else (no)
endif

if (Input is a URL?) then (yes)

  |URL Scanner|
  :detectUrl(url)\nLaunch Puppeteer browser;
  :Navigate to live URL\nCapture rendered DOM;
  :Collect antipattern findings\nfrom live page;

else (no)
  if (Input is a directory?) then (yes)

    |Directory Scanner|
    :walkDir(dir)\nFilter SCANNABLE_EXTENSIONS\nSkip SKIP_DIRS\n(.next, node_modules, dist, etc.);
    :detectFrameworkConfig(dir)\nScan for next.config.*, vite.config.*\nnuxt.config.*, etc.;

    if (Framework dev server detected?) then (yes)
      :isPortListening(port, fingerprint)\nTCP probe + HTTP fingerprint check;
      :Warn user on stderr\n"Dev server available at localhost:PORT";
    else (no)
    endif

    :buildImportGraph(files)\nParse import statements\nResolve absolute paths\nBuild Map<file, Set<imported>>;

    if (>50 files and interactive TTY?) then (yes)
      :confirm() prompt\nAsk user to proceed;
      if (User cancels?) then (yes)
        end
      else (no)
      endif
    endif

    note right
      Iterate over each
      collected file path
    end note
    :For each file in directory;

  else (no — single file)
    :Single file input;
  endif

  if (File extension is HTML / HTM?) then (yes)

    |HTML Analyzer|
    :Read file content\nInline linked local <style>\n(replace <link> tags);
    :Parse with JSDOM\n(url: file://filePath);
    :buildBorderOverrideMap(document, window)\nPre-resolve CSS var() border values\njsdom silently drops;

    note right
      For each element in
      document.querySelectorAll('*')
    end note

    fork
      :checkElementBorders(tag, style, overrides)\nDetect side-tab\nDetect border-accent-on-rounded;
    fork again
      :checkElementColors(el, style, tag, window)\nDetect pure-black / pure-white\ngray-on-color, low-contrast\nAI color palette;
    fork again
      :checkElementGlow(tag, style, effectiveBg)\nDetect colored box-shadow glows\non dark backgrounds;
    fork again
      :checkElementMotion(tag, style)\nDetect bounce / elastic easing\nDetect layout property animation;
    fork again
      :checkElementIconTile(el, tag, window)\nDetect icon tile stacked\nabove heading (AI card template);
    end fork

    :checkPageTypography(doc, win)\noverused-font, single-font\ngradient-text, flat-type-hierarchy\nall-caps-body, wide-tracking;
    :checkPageLayout(doc, win)\nnested-cards, monotonous-spacing\neverything-centered, line-length\ncramped-padding;
    :checkPageQualityDOM(doc)\nskipped-heading, justified-text\ntiny-text, tight-leading;
    :Deduplicate findings[];

  else (no — CSS / JS / TS / Vue / Svelte / etc.)

    |Text / Regex Analyzer|
    :Split content into lines\nDetect file extension;
    :runRegexMatchers(lines, filePath, offset=0)\nMatch CSS antipattern regex patterns\nagainst each line;
    :extractStyleBlocks(content, ext)\nPull <style> blocks from\nVue / Svelte SFCs;

    if (Style blocks found?) then (yes)
      :runRegexMatchers() on each\nstyle block with adjusted line offset;
    else (no)
    endif

    :extractCSSinJS(content, ext)\nPull CSS template literals\nfrom JS / TS (styled-components etc.);

    if (CSS-in-JS blocks found?) then (yes)
      :runRegexMatchers() on each\nCSS-in-JS block with adjusted offset;
    else (no)
    endif

    :Deduplicate findings\n(same antipattern + snippet within 2 lines);

    if (isFullPage(content)?\n(<html> + <head> + <body> present) ) then (yes)
      :Run REGEX_ANALYZERS[]\nPage-level pattern checks;
    else (no)
    endif

  endif

  |CLI|
endif

:allFindings.push(...results);
:formatFindings(allFindings, jsonMode)\nRender text report or JSON array\nto stdout;

if (Findings were detected?) then (yes)
  :Exit with code 2\n(violations found);
else (no)
  :Exit with code 0\n(clean — no violations);
endif
stop

@enduml
