@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleFontColor #212529
    TitleBackgroundColor #E9ECEF
}
skinparam ArrowColor #495057

title Anti-Patterns Page Rendering

|Build Orchestration|
start
:generateSubPages(rootDir);
:await buildSubPageData(rootDir);

|Data Loading|
:readAntipatternRules(rootDir)
Read src/detect-antipatterns.mjs
Regex-extract ANTIPATTERNS array
Eval via new Function();

fork
  :Load DETECTION_LAYERS map
  (rule.id → 'cli' | 'browser');
fork again
  :Load VISUAL_EXAMPLES map
  (rule.id → inline HTML snippet);
fork again
  :Load LLM_ONLY_RULES array
  (undetectable rules);
end fork

:Merge detectedRules
rules.map(r ⇒ { ...r, layer: DETECTION_LAYERS[r.id] || 'cli',
              visual: VISUAL_EXAMPLES[r.id] || null });

:Merge llmRules
LLM_ONLY_RULES.map(r ⇒ { ...r, layer: 'llm',
              visual: VISUAL_EXAMPLES[r.id] || null });

:Combine rules = [...detectedRules, ...llmRules];

|Build Orchestration|
:Return { rules, skills, skillsByCategory,
          knownSkillIds, tutorials };

|Rendering|
:groupRulesBySection(rules)
Initialize primaryOrder:
['Visual Details','Typography','Color & Contrast',
 'Layout & Space','Motion','Interaction','Responsive'];

:Initialize bySection map
with primaryOrder keys + 'General quality';

:Assign each rule to
bySection[rule.skillSection || 'General quality'];

:Sort each section bucket
(slop category first, then quality;
alphabetical within category);

:Build final section order
[...primaryOrder, ...extraSections, 'General quality'];

fork
  :renderAntiPatternsSidebar(grouped)
  Filter sections where rule count > 0
  Map each section to
  <li><a href='#section-{slug}'>{name} {count}</a></li>
  Return <aside class='anti-patterns-sidebar'> HTML;
fork again
  :renderAntiPatternsMain(grouped, totalRules)
  Compute detectedCount (layer ≠ 'llm')
  Compute llmCount = totalRules − detectedCount;

  :Iterate over grouped.order;

  repeat
    if (section has rules?) then (yes)
      :slug = slugify(section);
      :Open <section id='section-{slug}'> with header + grid;

      :Iterate over rules in section;
      repeat
        :renderRuleCard(rule);
        :Resolve categoryLabel
        ('AI slop' | 'Quality');
        :Resolve layerLabel / layerTitle
        from LAYER_LABELS / LAYER_DESCRIPTIONS;
        if (rule.skillSection exists?) then (yes)
          :Build skillLink
          href='/impeccable#{anchor}';
        else (no)
        endif
        if (rule.visual exists?) then (yes)
          :Render visual preview block
          (inline HTML snippet);
        else (no)
        endif
        :<article class='rule-card'
        data-layer='{layer}'>;
      repeat while (more rules in section?) is (yes)
      ->no;

      :Close </section>;
    else (no)
      :Skip empty section;
    endif
  repeat while (more sections?) is (yes)
  ->no;

  :Return full HTML:
  header + legend <details> + section grids;
end fork

:wrapInDocsLayout(sidebarHtml, mainHtml)
Wrap in <div class='skills-layout'>;

:renderPage({ title: 'Anti-patterns | Impeccable',
  bodyHtml, activeNav: 'anti-patterns',
  canonicalPath: '/anti-patterns',
  bodyClass: 'sub-page skills-layout-page anti-patterns-page' })
Return full HTML document with head / nav / body;

|File System|
:fs.writeFileSync(
  public/anti-patterns/index.html, html, 'utf-8');

|Build Orchestration|
:Push output path to generated[];

stop

@enduml
