@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleFontColor #212529
    BackgroundColor #E9ECEF
    TitleBackgroundColor #DEE2E6
}
skinparam note {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
    FontColor #0C5460
}

title App Content Loading and Display

|Browser|
start
:Page script executes;
if (document.readyState\n=== 'loading'?) then (yes — not yet ready)
  :addEventListener(\n'DOMContentLoaded', init);
else (no — DOM already ready)
  :Call init() immediately;
endif

|app.js — init()|
:Initialize UI modules\n<size:10>initAnchorScroll · initHashTracking · initLensEffect\ninitScrollReveal · initGlassTerminal · initFrameworkViz\ninitFoundationGrid · initSectionNav</size>;
:Call loadContent() [async];

|app.js — loadContent()|
note right
  try / catch wraps
  all fetch & render logic
end note
:Promise.all([\n  fetch('/api/commands'),\n  fetch('/api/patterns')\n]);

|API|
:Return HTTP responses\nfor both endpoints;

|app.js — loadContent()|
if (commandsRes.ok?) then (no)
  #FFB3B3:throw Error(\n'Commands API failed: <status>');
  |Error Handling|
  :catch block triggered;
  :console.error(error);
  :showLoadError(error);
  if (.commands-gallery\nelement found?) then (yes)
    :Inject error HTML\n+ Retry button\n(onclick: location.reload());
  endif
  if (#patterns-categories\nelement found?) then (yes)
    :Inject error HTML\n+ Retry button\n(onclick: location.reload());
  endif
  stop
else (yes)
endif

|app.js — loadContent()|
if (patternsRes.ok?) then (no)
  #FFB3B3:throw Error(\n'Patterns API failed: <status>');
  |Error Handling|
  :catch block triggered;
  :console.error(error);
  :showLoadError(error);
  if (.commands-gallery\nelement found?) then (yes)
    :Inject error HTML\n+ Retry button\n(onclick: location.reload());
  endif
  if (#patterns-categories\nelement found?) then (yes)
    :Inject error HTML\n+ Retry button\n(onclick: location.reload());
  endif
  stop
else (yes)
endif

|app.js — loadContent()|
:commandsRes.json() → allCommands\n<size:10>(stored as module-level state)</size>;
:patternsRes.json() → patternsData\n<size:10>{ patterns: [], antipatterns: [] }</size>;
:renderTerminalLayout(allCommands)\n<size:10>[delegates to glass-terminal.js]</size>;
:initGalleryStack()\n<size:10>Wire card stack prev/next buttons + wheel events</size>;
:renderPatternsWithTabs(\n  patternsData.patterns,\n  patternsData.antipatterns\n);

|Rendering — renderPatternsWithTabs()|
if (container or data\nmissing?) then (yes — guard fails)
  :Return early (no-op);
  |app.js — init()|
  :document.body.classList\n.add('loaded');
  |Browser|
  :Page marked as loaded;
  stop
else (no — proceed)
endif
:Build antipatternMap\n<size:10>antipatterns array → Map(name → items)</size>;
:patterns.map → tabsHTML\n<size:10><button> per category — text via escapeHtml(cat.name)</size>;
:patterns.map → panelsHTML\n<size:10><div> per panel — list items via escapeHtml(item)</size>;

|Rendering — escapeHtml()|
if (typeof value\n!== 'string'?) then (yes)
  :Return empty string '';
else (no — is a string)
endif
:replaceAll special characters\n<size:10>& → &amp; · < → &lt; · > → &gt;\n" → &quot; · ' → &#39;</size>;
:Return XSS-safe\nsanitized string;

|Rendering — renderPatternsWithTabs()|
:container.innerHTML\n= tabsHTML + panelsHTML;
:Attach click delegate on container\n<size:10>Activates selected tab and\ncorresponding panel on click</size>;

|app.js — init()|
:document.body.classList\n.add('loaded');

|Browser|
:Page content fully rendered\nand interactive;
stop

@enduml
