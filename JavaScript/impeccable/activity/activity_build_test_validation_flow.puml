@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}

title Build Test Validation Flow

|Test Runner|
start
:beforeEach: rmSync TEST_DIR recursively (if exists);
:beforeEach: mkdirSync TEST_DIR fresh;

|Fixture Setup|
if (Integration test?) then (yes)
    :Write SKILL.md fixture to\nTEST_DIR/source/skills/<name>/SKILL.md;
    note right
      Frontmatter fields:
      name, description, license,
      user-invocable, argument-hint
      Body: "Please audit {{target}} for
      technical quality. Ask {{model}} for help."
    end note
else (no — unit test)
    :Spy / mock readSourceFiles,\nreadPatterns and all transformers;
endif

|Build Orchestration|
:Call utils.readSourceFiles(ROOT_DIR);
note right
  Scans source/skills/ entries
  For each skill dir:
    - Read SKILL.md
    - parseFrontmatter() → { frontmatter, body }
    - Read reference/ subdir → references[]
    - Read scripts/ subdir   → scripts[]
end note

if (skills.length > 0?) then (yes)
    :Return populated skills[];
else (no)
    :Return empty skills[];
endif

:Call utils.readPatterns(ROOT_DIR);
note right
  Reads source/skills/impeccable/SKILL.md
  Parses ### Section headings
  Collects DO lines  → patterns[]
  Collects DON'T lines → antipatterns[]
end note

if (impeccable/SKILL.md exists?) then (yes)
    :Return { patterns[], antipatterns[] };
else (no)
    :Return { patterns:[], antipatterns:[] };
endif

|Transformers|
:transformCursor(skills, DIST_DIR, patterns);
note right: → DIST_DIR/cursor/.cursor/skills/<name>/SKILL.md\n{{model}} → "the model"
:transformClaudeCode(skills, DIST_DIR, patterns);
note right: → DIST_DIR/claude-code/.claude/skills/<name>/SKILL.md\n{{model}} → "Claude"
:transformGemini(skills, DIST_DIR, patterns);
note right: → DIST_DIR/gemini/.gemini/skills/<name>/SKILL.md\n{{model}} → "Gemini"
:transformCodex(skills, DIST_DIR, patterns);
note right: → DIST_DIR/codex/.codex/skills/<name>/SKILL.md\n{{model}} → "GPT"

fork
    :transformAgents(skills, DIST_DIR, patterns);
    note right: → DIST_DIR/agents/.agents/skills/
fork again
    :transformKiro(skills, DIST_DIR, patterns);
    note right: → DIST_DIR/kiro/.kiro/skills/
end fork

|Assertions|
if (Integration test?) then (yes)

    :Assert output files exist;
    note right
      cursor/.cursor/skills/<name>/SKILL.md ✓
      claude-code/.claude/skills/<name>/SKILL.md ✓
      gemini/.gemini/skills/<name>/SKILL.md ✓
      codex/.codex/skills/<name>/SKILL.md ✓
      agents/.agents/skills/ ✓
      kiro/.kiro/skills/ ✓
    end note

    if (Running "verify transformations" test?) then (yes)
        :Read each provider's SKILL.md content;

        :Validate Cursor output:
        - Contains --- frontmatter block
        - name: audit present
        - {{target}} preserved (not replaced)
        - {{model}} → "the model";

        :Validate Claude Code output:
        - user-invocable: true present
        - {{target}} preserved
        - {{model}} → "Claude";

        :Validate Gemini output:
        - {{target}} preserved
        - {{model}} → "Gemini";

        :Validate Codex output:
        - {{target}} preserved
        - {{model}} → "GPT";
    else (no)
    endif

    if (Running "multiple skills" test?) then (yes)
        :Assert skills.length === 2;
        :Assert all four providers emitted
        files for both skill1 and skill2;
    else (no)
    endif

else (no — unit test)

    if (Running "empty source files" test?) then (yes)
        :Assert all transformers called
        with ([], DIST_DIR, patterns);
    else (no)
    endif

    if (Running "transformer order" test?) then (yes)
        :Assert callOrder ===
        ['cursor','claude-code','gemini','codex'];
    else (no)
    endif

    if (Running "agents + kiro included" test?) then (yes)
        :Assert transformAgents called;
        :Assert transformKiro called;
    else (no)
    endif

endif

|Test Runner|
:afterEach: rmSync TEST_DIR recursively;
stop

@enduml
