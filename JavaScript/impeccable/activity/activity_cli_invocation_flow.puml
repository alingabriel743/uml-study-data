@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
    StartColor #212529
    EndColor #212529
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}

title CLI Invocation Flow

|CLI Dispatcher|
start
:Parse **process.argv.slice(2)** → args[];
:Extract **command = args[0]**;

if (command is empty, --help, or -h?) then (yes)
    :Print usage / help text;
    end
else (no)
    if (command === '--version' or '-v'?) then (yes)
        :Read **package.json**;
        :Print **pkg.version**;
        end
    else (no)
        if (command === 'detect'?) then (yes)
            :Rewrite **process.argv**\n(strip 'detect' token);
            :Dynamic **import detectCli()**\nfrom src/detect-antipatterns.mjs;
            :await **detectCli()**;
            end
        else (no)
            if (command === 'live'?) then (yes)
                :Rewrite **process.argv**\n(strip 'live' token);
                :Dynamic **import liveCli()**\nfrom src/detect-antipatterns.mjs;
                :await **liveCli()**;
                end
            else (no)
                if (command === 'skills'?) then (yes)

|Skills Router|
                    :Receive **subArgs = args.slice(1)**;
                    :Extract **sub = subArgs[0]**;

                    if (sub is empty, 'help', --help, or -h?) then (yes)
                        :Call **showHelp()**;
                        :GET **https://impeccable.style/api/commands**;
                        :Print commands table;
                        end
                    else (no)
                        if (sub === 'install'?) then (yes)

|Install|
                            :Call **install(flags)**;
                            :Call **findProjectRoot()**\n(walk up from cwd until .git found);
                            if (isAlreadyInstalled(root) AND NOT --force?) then (already installed)
                                :Print "already installed" message;
                                end
                            else (not installed / --force)
                                :execSync **npx skills add pbakaus/impeccable**;
                                if (prefix flag provided?) then (yes)
                                    :Call **renameSkillsWithPrefix(root, prefix)**\n(rename dirs + fix symlinks + update SKILL.md refs);
                                else (no)
                                    :Infer prefix via **detectPrefix(root)**;
                                    if (existing prefix detected?) then (yes)
                                        :Apply prefix to new skills;
                                    else (no)
                                    endif
                                endif
                                :Call **cleanup deprecated** skills;
                                :Print "done" message;
                                end
                            endif

|Skills Router|
                        else (no)
                            if (sub === 'update'?) then (yes)

|Update|
                                :Call **update(flags)**;
                                :Call **cleanup deprecated** skills;
                                :Call **findProjectRoot()**;
                                :Call **findInstalledProviders(root)**\n(scan PROVIDER_DIRS for skill dirs);
                                :GET **https://impeccable.style/api/download/bundle/universal**\n→ unzip to tmpDir;
                                if (isUpToDate(root, providers, bundleDir)?\n(compare SKILL.md hashes)) then (up to date)
                                    :Print "already up to date";
                                    end
                                else (updates available)
                                    :Prompt user to **confirm update**;
                                    if (user confirmed?) then (yes)
                                        fork
                                            :For each provider dir;
                                            :Call **copyDirSync(bundleDir, providerDir)**;
                                        end fork
                                        :Re-apply **prefix** via renameSkillsWithPrefix();
                                        :Post-update **cleanup deprecated** skills;
                                        :Print "update complete";
                                    else (no)
                                        :Abort — print "cancelled";
                                    endif
                                    end
                                endif

|Skills Router|
                            else (no)
                                if (sub === 'check'?) then (yes)

|Check|
                                    :Call **check()**;
                                    :Call **findProjectRoot()**;
                                    if (isAlreadyInstalled(root)?) then (not installed)
                                        :Print "skills not installed";
                                        end
                                    else (installed)
                                        :Call **findInstalledProviders(root)**;
                                        :GET **/api/download/bundle/universal**\n→ unzip to tmpDir;
                                        :Call **isUpToDate()**\n(deduplicate providers, compare SKILL.md hashes);
                                        if (up to date?) then (yes)
                                            :Print "skills are up to date ✓";
                                        else (no)
                                            :Print "update available — run: skills update";
                                        endif
                                        end
                                    endif

|Skills Router|
                                else (unknown sub)
                                    :console.error "Unknown sub-command";
                                    :process.exit(1);
                                    end
                                endif
                            endif
                        endif
                    endif

|CLI Dispatcher|
                else (no match / other)
                    :Treat all args as\n**detect** arguments;
                    :Rewrite **process.argv**;
                    :Dynamic **import detectCli()**\nfrom src/detect-antipatterns.mjs;
                    :await **detectCli()** (shorthand);
                    end
                endif
            endif
        endif
    endif
endif

@enduml
