@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #E8F4FD
skinparam NoteBorderColor #5BA4CF

title Browser Extension Build Flow
caption Entry point: node scripts/build-extension.js

|Phase 1 — Build Detector|
start

:Read source file;
note right
  src/detect-antipatterns.mjs
end note

:Strip shebang line;
note right
  code.replace(/^#!.*\n/, '')
end note

:Strip @browser-strip-start /\n@browser-strip-end sections;
note right
  Removes Node.js-only code blocks
  between marker comments
end note

:Set IS_BROWSER = true;
note right
  Dead-code eliminates Node.js
  paths at runtime
end note

:Wrap in IIFE with window guard;
note right
  (function(){
    if(typeof window==='undefined') return;
    ...
  })()
end note

:Ensure extension/detector/ directory exists;

:Write extension/detector/detect.js;

:Log — Generated detect.js (size KB);

|Phase 2 — Extract Antipatterns|

:Re-read source for antipatterns extraction;

if (ANTIPATTERNS array found in source?) then (match found)
    :Evaluate JS object literals → array;
    note right
      new Function(`return [${apMatch[1]}]`)()
    end note

    :Map to JSON schema;
    note right
      { id, name, category, description }
      defaults: category='quality'
    end note

    :Write extension/detector/antipatterns.json;

    :Log — Generated antipatterns.json (N rules);
else (no match)
    note right
      Skip antipatterns extraction
    end note
endif

|Phase 3 — Zip Packaging|

:Ensure dist/ directory exists;

:Delete existing dist/extension.zip (if any);
note right
  Errors silently swallowed
end note

:zip -r dist/extension.zip . (from extension/ dir);
note right
  Excludes: STORE_LISTING.md, .DS_Store
end note

:Read zip file size;

:Log — Packaged extension.zip (size KB);

end

@enduml
