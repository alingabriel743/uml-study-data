@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activityBackgroundColor #F8F9FA
skinparam activityBorderColor #495057
skinparam activityArrowColor #495057
skinparam activityFontColor #212529
skinparam activityDiamondBackgroundColor #E9ECEF
skinparam activityDiamondBorderColor #6C757D
skinparam swimlaneWidth 220
skinparam swimlaneBorderColor #6C757D
skinparam swimlaneTitleFontColor #212529

title Gallery Stack Navigation Flow

|#DBEAFE|Browser / DOM|
start
:Page script evaluates;
if (DOM already ready?) then (yes)
else (no)
  :Wait for DOMContentLoaded event;
endif

|#FFF3CD|App Initialization|
:init();
note right
  Also invokes:
  initAnchorScroll(), initHashTracking(),
  initLensEffect(), initScrollReveal(),
  initGlassTerminal(), initFrameworkViz(),
  initFoundationGrid(), initSectionNav()
end note
:loadContent() — async;
fork
  :GET /api/commands;
fork again
  :GET /api/patterns;
end fork
:Await Promise.all([commands, patterns]);

if (All API responses OK?) then (no)
  :showLoadError(error);
  stop
else (yes)
endif

fork
  |#D1FAE5|Gallery Stack|
  :initGalleryStack();
  if (stack or container\nnot found in DOM?) then (yes)
    :Return early — no gallery;
    kill
  else (no)
  endif
  :Query all .gallery-stack-card elements → cards[];
  :Query .gallery-stack-counter;
  :Initialize state:\ncurrent = 0\ntotal = cards.length\nlastScroll = 0;
  :Define update():\ncard.dataset.offset =\n(i − current + total) % total;
  :Define next() and prev() functions;
  :Attach click: .gallery-stack-prev → prev();
  :Attach click: .gallery-stack-next → next();
  :Attach wheel: #gallery-stack\n(passive:false | preventDefault | 350ms throttle);
  :Call update() — set initial card offsets;

fork again
  |#FCE7F3|Patterns & Tabs|
  :renderPatternsWithTabs\n(patterns, antipatterns);
  if (Container or\ndata missing?) then (yes)
    :Return early — no patterns;
    kill
  else (no)
  endif
  :Build antipatternMap\n{ categoryName → items[] };
  :Generate tabsHTML\n(one <button> per category,\nfirst tab gets is-active);
  :Generate panelsHTML\n(do / don't columns per category,\nfirst panel gets is-active);
  :container.innerHTML =\ntabsHTML + panelsHTML;
  :Attach click delegation on container\n→ activate tab + matching panel by index;
end fork

|#DBEAFE|Browser / DOM|
:body.classList.add('loaded')\n— Page fully initialized;

== Runtime: Gallery Navigation Events ==

|#DBEAFE|Browser / DOM|
:User interacts with gallery\n(click button or wheel scroll);

|#D1FAE5|Gallery Stack|
if (Event type?) then (wheel scroll)
  if (Within 350ms of\nlast scroll event?) then (yes — throttled)
    :Discard event;
  else (no — process)
    :lastScroll = Date.now();
    if (deltaY > 0\n(scroll forward)?) then (yes)
      :next():\ncurrent = (current + 1) % total;
    else (no — scroll back)
      :prev():\ncurrent = (current − 1 + total) % total;
    endif
    :update():\nRecalculate data-offset for all cards;
    :CSS reads data-offset →\nReposition and restack cards;
  endif
else (click)
  if (Clicked .gallery-stack-next?) then (yes)
    :next():\ncurrent = (current + 1) % total;
  else (no — .gallery-stack-prev)
    :prev():\ncurrent = (current − 1 + total) % total;
  endif
  :update():\nRecalculate data-offset for all cards;
  :CSS reads data-offset →\nReposition and restack cards;
endif

== Runtime: Patterns Tab Events ==

|#DBEAFE|Browser / DOM|
:User clicks inside\n#patterns-categories area;

|#FCE7F3|Patterns & Tabs|
if (Click target is\n.patterns-tab?) then (yes)
  :Remove is-active from\nall tabs and panels;
  :Add is-active to clicked tab;
  :Add is-active to matching\npanel[data-index];
  :Active panel content becomes visible;
else (no)
  :Ignore click;
endif

stop

@enduml
