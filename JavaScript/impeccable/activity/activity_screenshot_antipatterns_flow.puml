@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
    StartColor #212529
    EndColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}

title Screenshot Anti-Patterns Flow

|Script (main)|
start
:Invoke main();

:Check dev server\nGET http://localhost:3000;

if (Server responding?) then (no)
    #FFD6D6:Print error:\n"Dev server not running.\nStart with: bun run dev";
    :Exit process (code 1);
    stop
else (yes)
endif

:Call screenshotAntipatterns();

|File System|
if (Output directory exists?\npublic/antipattern-images/) then (no)
    :Create output directory\n(recursive);
else (yes)
endif

:Read all .html files\nfrom public/antipattern-examples/;

if (HTML files found?) then (no)
    :Log "No HTML files found";
    stop
else (yes)
endif

|Script (main)|
:Log count of anti-pattern\nexamples to process;

|Browser (Playwright)|
:Launch Chromium\n(headless mode);
:Create browser context\nviewport: 1200x1200\ndeviceScaleFactor: 2x;

|Script (main)|
:Iterate over each HTML file;

repeat
    |Browser (Playwright)|
    :Open new page;
    :Navigate to\nhttp://localhost:3000/antipattern-examples/{file}\nwaitUntil: networkidle;
    :Wait 500ms for fonts to load;
    :Query page for .container element;

    if (.container element found?) then (yes)
        :Screenshot .container element\nas {name}.png (PNG format);
        |File System|
        :Save screenshot to\npublic/antipattern-images/{name}.png;
        |Script (main)|
        :Log "✓ Saved to {relative path}";
    else (no)
        |Browser (Playwright)|
        :Screenshot full page\nclipped to 1080x1080\nas {name}.png (PNG format);
        |File System|
        :Save screenshot (cropped)\nto public/antipattern-images/{name}.png;
        |Script (main)|
        :Log "✓ Saved (full page crop)\nto {relative path}";
    endif

    |Browser (Playwright)|
    :Close page;

repeat while (More HTML files?) is (yes)
-> no;

:Close browser;

|Script (main)|
:Log "✨ Done! Screenshots saved\nto public/antipattern-images/";

stop

@enduml
