@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
    StartColor #212529
    EndColor #212529
}

skinparam swimlane {
    BackgroundColor #FEFEFE
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleBorderColor #6C757D
}

title Dev Server Request Handling

|Startup|
start
:Import static HTML pages\n(homepage, cheatsheet, gallery, privacy);
:generateSubPages(ROOT_DIR)\n→ pre-build all sub-page HTML files;
:Log count of generated sub-pages;
:bun.serve({ port: PORT || 3000,\nroutes, fetch });

|Bun Router|
:HTTP Request Arrives;

switch (Match route?)
case (Static HTML\n/, /cheatsheet,\n/gallery, /privacy)
  :Return pre-imported\nHTML module directly;
  |HTTP Layer|
  :200 OK + HTML;

case (Generated sub-page\n/skills, /skills/:id,\n/anti-patterns, /visual-mode,\n/tutorials, /tutorials/:slug)
  |Bun Router|
  :Sanitize :id / :slug param\n(strip /[^a-z0-9-]/gi);
  :serveGenerated(\npublic/<section>/<id|slug>.html);

  |File System|
  if (bun.file(pagePath).exists()?) then (yes)
    :Stream file response\nContent-Type: text/html\nX-Content-Type-Options: nosniff\nX-Frame-Options: DENY;
    |HTTP Layer|
    :200 OK + HTML file;
  else (no)
    |HTTP Layer|
    :404 Not Found;
  endif

case (Static asset wildcard\n/assets/*, /css/*, /js/*,\n/fixtures/*, /antipattern-images/*,\n/antipattern-examples/*)
  |Bun Router|
  if (pathname.includes('..')?) then (yes)
    |HTTP Layer|
    :400 Bad Request;
  else (no)
    |Bun Router|
    :Build filePath\n('./public' + pathname\nor './tests' + pathname\nfor /fixtures/*);

    if (/js/* route?) then (yes)
      |File System|
      if (public/js/ file exists?) then (yes)
        :Serve from public/js/;
      else (no)
        :Fallback to\nsrc/detect-antipatterns-browser.js;
      endif
    else (no)
      |File System|
    endif

    if (assetFile.exists()?) then (yes)
      :Stream asset file\nwith correct Content-Type\nX-Content-Type-Options: nosniff\nX-Frame-Options: DENY / SAMEORIGIN;
      |HTTP Layer|
      :200 OK + Asset;
    else (no)
      |HTTP Layer|
      :404 Not Found;
    endif
  endif

case (API route\n/api/*)
  |API Handlers|
  switch (API endpoint?)
  case (/api/skills)
    :getSkills();
    :200 OK + JSON skills;
  case (/api/commands)
    :getCommands();
    :200 OK + JSON commands;
  case (/api/patterns)
    :getPatterns();
    :200 OK + JSON patterns;
  case (/api/command-source/:id)
    :getCommandSource(id);
    if (result.error?) then (yes)
      :4xx error JSON\n(result.status);
    else (no)
      if (result?) then (no)
        :404 Not Found;
      else (yes)
        :200 OK + JSON { content };
      endif
    endif
  case (/api/download/:type/:provider/:id)
    :handleFileDownload\n(type, provider, id);
    :200 OK + Download;
  case (/api/download/bundle/:provider)
    :handleBundleDownload(provider);
    :200 OK + Bundle;
  endswitch

  |HTTP Layer|
  :Response returned to client;

case (Fallback fetch\n(root-level static files))
  |Bun Router|
  if (pathname.includes('..')?) then (yes)
    |HTTP Layer|
    :400 Bad Request;
  else (no)
    |File System|
    :file('./public' + pathname);
    if (file.size > 0?) then (yes)
      :Stream static file;
      |HTTP Layer|
      :200 OK + Static File;
    else (no)
      |HTTP Layer|
      :404 Not Found;
    endif
  endif

endswitch

|HTTP Layer|
stop

@enduml
