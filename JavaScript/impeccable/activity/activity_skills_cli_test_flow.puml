@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleFontSize 13
    TitleFontStyle bold
}
skinparam note {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontSize 11
}

title Skills CLI Test Execution Flow\n<size:11><i>tests/skills-cli.test.js — bun:test integration suite</i></size>

|#DDEEFF|Test Runner|
start
:Probe npx availability\nexecSync('npx skills --version');

|#FFF9E6|CLI / execSync|
:Execute version probe\n(try / catch);

|#DDEEFF|Test Runner|
if (npx skills available?) then (yes)
  :hasNpxSkills = **true**\ndescribeNpx = describe;
else (no)
  :hasNpxSkills = **false**\ndescribeNpx = describe.skip;
endif

note right
  **Suite 1**
  already-installed detection
  (inline — no beforeAll/afterAll)
end note

|#E8F5E9|Filesystem|
:mkdtempSync() → tmpDir\nexecSync('git init');
:createFakeSkills(tmpDir)\n→ .claude/skills/{audit, polish, impeccable}/SKILL.md;

|#FFF9E6|CLI / execSync|
:run('skills install -y', {cwd: tmpDir});

|#FDECEA|Assertions|
:expect(output).toContain('already installed');

|#E8F5E9|Filesystem|
:mkdtempSync() → tmpDir2\nmkdirSync(.cursor/skills/i-impeccable)\nwriteFileSync(SKILL.md);

|#FFF9E6|CLI / execSync|
:run('skills install -y', {cwd: tmpDir2});

|#FDECEA|Assertions|
:expect(output).toContain('already installed');

|#E8F5E9|Filesystem|
:rmSync(tmpDir)\nrmSync(tmpDir2);

note right
  **Suite 2**
  prefix rename
  (beforeAll / afterAll)
end note

|#E8F5E9|Filesystem|
:beforeAll: mkdtempSync() → tmpDir\ncreate FakeSkills(tmpDir,\n  skills=[audit, polish, impeccable],\n  providers=['.claude', '.cursor']);

|#DDEEFF|Test Runner|
:writeFileSync(_test_rename.mjs\ninline helper: prefixSkillContent());

|#FFF9E6|CLI / execSync|
:execSync('node _test_rename.mjs <tmpDir> i-')\n→ JSON { count };

|#FDECEA|Assertions|
:expect(count).toBe(6)\n(3 skills × 2 providers);
:readdirSync(.claude/skills)\n→ i-audit, i-polish, i-impeccable ✓\n   audit, polish ABSENT ✓;
:readFileSync(i-audit/SKILL.md)\n→ name: i-audit, /i-polish,\n  'the i-impeccable skill'\n  no bare /audit ✓;
:readdirSync(.cursor/skills)\n→ i-audit, i-impeccable ✓;

|#E8F5E9|Filesystem|
:afterAll: rmSync(tmpDir, {recursive, force});

note right
  **Suite 3**
  skills update: direct download fallback
  (beforeAll / afterAll)
end note

|#E8F5E9|Filesystem|
:beforeAll: mkdtempSync() → tmpDir\nexecSync('git init')\nWrite stale SKILL.md for audit & impeccable\n  (frontmatter: stale: true);

|#FFF9E6|CLI / execSync|
:run('skills update -y',\n{cwd: tmpDir, timeout: 60000});

|#FDECEA|Assertions|
:expect(output).toContain('direct download');
:expect(output).toContain('Updated');
:readFileSync(audit/SKILL.md)\n→ 'stale: true' ABSENT ✓\n   'name:' present ✓;
:readdirSync(.claude/skills)\n→ expect skills.length > 5\n  (bundle delivers ~20 skills);

|#E8F5E9|Filesystem|
:afterAll: rmSync(tmpDir, {recursive, force});

note right
  **Suite 4**
  prefix round-trip: detect → undo → re-apply
  (beforeAll / afterAll)
end note

|#E8F5E9|Filesystem|
:beforeAll: mkdtempSync() → tmpDir\nWrite prefixed skills (i-audit, i-polish,\ni-impeccable) into .claude;

|#DDEEFF|Test Runner|
:writeFileSync(_detect.mjs)\n(scans ['.claude','.cursor','.agents']\nfor *-impeccable to infer prefix);

|#FFF9E6|CLI / execSync|
:execSync('node _detect.mjs');

|#FDECEA|Assertions|
:expect(output.trim()).toBe('i-');

|#DDEEFF|Test Runner|
:writeFileSync(_undo.mjs)\n(renameSync prefixed → bare;\nrewrite SKILL.md name + /refs);

|#FFF9E6|CLI / execSync|
:execSync('node _undo.mjs') → JSON array of skill names;

|#FDECEA|Assertions|
:readdirSync(.claude/skills)\n→ audit, polish, impeccable ✓\n   i-audit ABSENT ✓;
:readFileSync(audit/SKILL.md)\n→ name:audit, /audit, /polish,\n  'the impeccable skill'\n  no /i-audit ✓;

|#DDEEFF|Test Runner|
:writeFileSync(_reprefix.mjs)\n(same rename logic, re-applies 'i-' prefix);

|#FFF9E6|CLI / execSync|
:execSync('node _reprefix.mjs') → JSON array;

|#FDECEA|Assertions|
:readdirSync(.claude/skills)\n→ i-audit, i-polish, i-impeccable ✓\n   audit ABSENT ✓;
:readFileSync(i-audit/SKILL.md)\n→ name:i-audit, /i-polish,\n  'the i-impeccable skill' ✓;

|#E8F5E9|Filesystem|
:afterAll: rmSync(tmpDir, {recursive, force});

|#DDEEFF|Test Runner|
if (hasNpxSkills?) then (true)

  note right
    **Suite 5**
    full e2e with npx skills
    (beforeAll / afterAll)
  end note

  |#E8F5E9|Filesystem|
  :beforeAll: mkdtempSync() → tmpDir\nexecSync('git init');

  |#FFF9E6|CLI / execSync|
  :run('skills install -y',\n{cwd: tmpDir, timeout: 90000});

  |#FDECEA|Assertions|
  :expect(output).toContain('Done!');
  :hasSkills check:\nexistsSync(dir) && readdirSync(dir).length > 0\nacross ['.claude', '.cursor'] → true ✓;

  |#FFF9E6|CLI / execSync|
  :run('skills install -y --force --prefix=x-',\n{cwd: tmpDir, timeout: 90000});

  |#FDECEA|Assertions|
  :Iterate ['.claude','.cursor','.gemini',\n'.codex','.agents','.kiro']\n→ find non-empty skills dir;
  :expect all entries start with 'x-'\n(prefixed.length === skills.length) ✓;

  |#E8F5E9|Filesystem|
  :afterAll: rmSync(tmpDir, {recursive, force});

  |#DDEEFF|Test Runner|

else (false)
  |#DDEEFF|Test Runner|
  :Suite 5 **SKIPPED**\n(describe.skip — npx not available);
endif

stop

@enduml
