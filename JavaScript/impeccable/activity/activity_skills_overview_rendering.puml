@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}
skinparam note {
    BackgroundColor #EFF8FF
    BorderColor #4A90D9
}

title Skills Overview Page Rendering

|generateSubPages\n(Orchestrator)|
start

:Call **buildSubPageData**(rootDir);
note right
  Returns:
  • skillsByCategory
  • skills, tutorials
  • rules, knownSkillIds
end note

:Compute **outDirs**\n(public/skills, public/anti-patterns,\npublic/tutorials, public/visual-mode);

partition "Output Directory Setup" {
    repeat
        if (Output dir exists?) then (yes)
            :fs.rmSync(dir, {recursive: true});
        endif
        :fs.mkdirSync(dir, {recursive: true});
    repeat while (more outDirs?) is (yes)
    -> no;
}

:Call **renderDocsSidebar**(skillsByCategory, tutorials, null)\n→ sidebarHtml;
note right: current=null — no active\nitem highlighted in sidebar

|renderSkillsOverviewMain\n(HTML Builder)|

:Receive **skillsByCategory**;

:Compute **totalSkills**\nvia Object.values(skillsByCategory)\n.reduce() summing list lengths;

:Init **categoriesHtml** = '';

repeat
    :Get next category from **CATEGORY_ORDER**;
    :list = skillsByCategory[category] || [];

    if (list.length === 0?) then (yes)
        :Skip category\n(continue loop);
    else (no)
        :Map skills → chip anchor tags\n<a href='/skills/{id}'>/{id}</a>\nusing escapeHtml(s.id);

        :Build **<section class='skills-overview-category'>**\nwith: CATEGORY_LABELS[category] h2,\ncount badge, CATEGORY_DESCRIPTIONS[category],\nskill chips div;

        :Append section to **categoriesHtml**;
    endif
repeat while (more CATEGORY_ORDER entries?) is (yes)
-> no;

:Build **.skills-overview-header**\n(eyebrow=totalSkills, h1 "Skills",\nlede with /impeccable + /critique links);

:Build **.skills-overview-howto**\n(h2, guidance paragraph\nwith inline skill links);

:Wrap header + howto + categoriesHtml\nin **.skills-overview-categories** container;

:Return **mainHtml** string;

|generateSubPages\n(Orchestrator)|

:Call **wrapInDocsLayout**(sidebarHtml, mainHtml)\n→ bodyHtml\n(<div class='skills-layout'>);

:Call **renderPage**({\n  title: 'Skills | Impeccable',\n  description, bodyHtml,\n  activeNav: 'docs',\n  canonicalPath: '/skills',\n  bodyClass: 'sub-page skills-layout-page'\n})\n→ html;

:Compute **out** = path.join(outDirs.skills, 'index.html');

|File System\n(Node fs)|

:fs.writeFileSync(out, html, 'utf-8');

|generateSubPages\n(Orchestrator)|

:Push **out** → generated[];

stop

@enduml
