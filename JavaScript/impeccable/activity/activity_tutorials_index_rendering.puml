@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
    StartColor #212529
    EndColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Tutorials Index Page Rendering

|generateSubPages|
start

:Invoke **buildSubPageData**(rootDir);
note right
  Async call — resolves
  tutorials[], skillsByCategory,
  and other sub-page data
end note

|buildSubPageData|
:Load tutorial markdown files\nfrom rootDir;
:Parse frontmatter\n(slug, title, order, tagline, description, body);
:Sort tutorials by **order**;
:Group skills by **CATEGORY_ORDER**;
:Return data object\n{ tutorials, skillsByCategory, ... };

|generateSubPages|
if (data.tutorials.length === 0?) then (yes — no tutorials)
    :Skip tutorials index block;
    stop
else (no — tutorials exist)
endif

fork
    :Call **renderDocsSidebar**(\n  data.skillsByCategory,\n  data.tutorials,\n  current = null\n);
    note right
      Tutorials group rendered first,
      then skills grouped by CATEGORY_ORDER.
      current=null → no item highlighted
    end note
    :Return **sidebarHtml** string;
fork again
    :Call **renderTutorialsIndexMain**(data.tutorials);

    |renderTutorialsIndexMain|
    :Begin tutorial cards loop;
    repeat
        :Fetch next tutorial **t**;
        :**escapeHtml**(t.title)\n→ sanitized title;
        if (t.tagline present?) then (yes)
            :**escapeHtml**(t.tagline)\n→ sanitized tagline;
        else (no)
            :**escapeHtml**(t.description)\n→ sanitized description fallback;
        endif
        :String(t.order).padStart(2, '0')\n→ zero-padded order number;
        :Emit **<a class="tutorial-card">** block\n  with number, title, tagline, arrow;
    repeat while (more tutorials?) is (yes)
    ->no;
    :Wrap cards in **<div class="tutorials-content">**\n  with header (eyebrow count, <h1>, lede);
    :Return **mainHtml** string;

    |generateSubPages|
    :Receive **mainHtml**;
end fork

:Call **wrapInDocsLayout**(sidebarHtml, mainHtml);
note right
  Produces:
  <div class="skills-layout">
    <aside class="skills-sidebar">
    <div class="skills-main">
end note
:Return **bodyHtml** string;

:Call **renderPage**(\n  title: 'Tutorials | Impeccable',\n  description, bodyHtml,\n  activeNav: 'docs',\n  canonicalPath: '/tutorials',\n  bodyClass: 'sub-page skills-layout-page tutorials-page'\n);
:Return full site shell **html** string;

|File System|
:Resolve output path\n**out** = rootDir/public/tutorials/index.html;
:Call **fs.writeFileSync**(out, html, 'utf-8');
:File written to disk ✓;

|generateSubPages|
:generated.push(out)\n→ record output path;

stop

@enduml
