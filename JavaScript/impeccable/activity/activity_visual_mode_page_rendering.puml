@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Visual Mode Page Rendering

|Build Orchestrator\n(generateSubPages)|
start

:Receive call: **generateSubPages(rootDir)**
//called from build.js or server/index.js//;

:await **buildSubPageData(rootDir)**
//→ data: { skillsByCategory, tutorials,//
//  rules, knownSkillIds }//;

:Compute output path:
**outDirs.visualMode**
= path.join(rootDir, 'public/visual-mode');

if (visualMode dir exists?) then (yes)
    :fs.**rmSync**(visualMode, { recursive: true })
    //Purge stale files//;
else (no)
endif

:fs.**mkdirSync**(visualMode, { recursive: true });

|renderVisualModeMain\n(build-sub-pages.js)|

:Call **renderVisualModeMain()**
//reads module-scope GALLERY_ITEMS — no params//;

fork
    :Read **GALLERY_ITEMS**
    //from anti-patterns-catalog.js//
    Array<{ id, title, desc }>;
fork again
    note right
      Self-contained renderer —
      does not use the shared
      **data** object from
      buildSubPageData()
    end note
end fork

:For each item in GALLERY_ITEMS
→ build **specimenCard** HTML
  <a href="/antipattern-examples/{id}.html">
    <img src="../antipattern-images/{id}.png"/>
    title + desc
  </a>;

:Assemble **bodyHtml** sections:
1. **.visual-mode-page-header**
   (eyebrow + h1 + lede)
2. **.visual-mode-demo-wrap**
   (live iframe → visual-mode-demo.html)
3. **.visual-mode-methods**
   (three-card grid: /critique, npx, Chrome ext)
4. **.visual-mode-gallery#try-it-live**
   (specimen card grid from GALLERY_ITEMS);

:Return **bodyHtml** string
//Single-column layout, no sidebar//;

|renderPage\n(lib/render-page.js)|

:Call **renderPage**({
  title,
  description,
  bodyHtml,
  activeNav: 'visual-mode',
  canonicalPath: '/visual-mode',
  bodyClass: 'sub-page visual-mode-page-body'
});

:Resolve asset paths
//relative to page depth (default depth=1)//;

:Inject full HTML shell:
  <!DOCTYPE html>
  <head> meta + canonical + assets </head>
  <body>
    <nav> (activeNav='visual-mode' highlighted)
    + bodyHtml
    + <script> tags
  </body>;

:Sanitize dynamic strings via
**escapeHtml()** / **escapeAttr()**;

:Return full HTML **document string**;

|Build Orchestrator\n(generateSubPages)|

:Compute output file path:
**out** = path.join(outDirs.visualMode, 'index.html');

:fs.**writeFileSync**(out, html, 'utf-8')
→ writes **public/visual-mode/index.html**;

:generated.**push**(out);

note right
  Other page blocks execute next
  (skills, anti-patterns, tutorials)
end note

:Return **{ files: generated }**;

stop

@enduml
