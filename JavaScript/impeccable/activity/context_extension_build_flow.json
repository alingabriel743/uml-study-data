{
  "scope": "extension_build_flow",
  "title": "Browser Extension Build Flow",
  "diagram_type": "activity",
  "entry_point": "node scripts/build-extension.js",
  "description": "Sequential build pipeline that transforms detect-antipatterns.mjs into a browser-ready extension package (extension.zip).",

  "activities": [
    {
      "id": "start",
      "type": "start",
      "label": "Start build"
    },
    {
      "id": "read_source",
      "type": "action",
      "label": "Read source: src/detect-antipatterns.mjs",
      "detail": "fs.readFileSync(SOURCE, 'utf-8')"
    },
    {
      "id": "strip_shebang",
      "type": "action",
      "label": "Strip shebang line",
      "detail": "code.replace(/^#!.*\\n/, '')"
    },
    {
      "id": "strip_markers",
      "type": "action",
      "label": "Strip @browser-strip-start / @browser-strip-end sections",
      "detail": "Removes Node-only code blocks between marker comments"
    },
    {
      "id": "set_is_browser",
      "type": "action",
      "label": "Set IS_BROWSER = true",
      "detail": "Dead-code eliminates Node.js paths at runtime"
    },
    {
      "id": "wrap_iife",
      "type": "action",
      "label": "Wrap in IIFE with window guard",
      "detail": "Wraps transformed code in (function(){ if(typeof window==='undefined') return; ... })()"
    },
    {
      "id": "mkdir_detector",
      "type": "action",
      "label": "Ensure extension/detector/ directory exists",
      "detail": "fs.mkdirSync(path.dirname(DETECTOR_OUTPUT), { recursive: true })"
    },
    {
      "id": "write_detector",
      "type": "action",
      "label": "Write extension/detector/detect.js",
      "detail": "fs.writeFileSync(DETECTOR_OUTPUT, output)"
    },
    {
      "id": "log_detector",
      "type": "action",
      "label": "Log: Generated detect.js (size KB)"
    },
    {
      "id": "read_source_again",
      "type": "action",
      "label": "Re-read source for antipatterns extraction",
      "detail": "fs.readFileSync(SOURCE, 'utf-8') — fresh read"
    },
    {
      "id": "match_antipatterns",
      "type": "decision",
      "label": "ANTIPATTERNS array found in source?",
      "detail": "rawSource.match(/const ANTIPATTERNS = \\[([\\s\\S]*?)\\n\\];/)"
    },
    {
      "id": "parse_antipatterns",
      "type": "action",
      "label": "Evaluate JS object literals → array",
      "detail": "new Function(`return [${apMatch[1]}]`)()"
    },
    {
      "id": "map_antipatterns",
      "type": "action",
      "label": "Map to JSON schema: { id, name, category, description }",
      "detail": "Defaults: category='quality', description=''"
    },
    {
      "id": "write_ap_json",
      "type": "action",
      "label": "Write extension/detector/antipatterns.json",
      "detail": "fs.writeFileSync(AP_OUTPUT, JSON.stringify(apJson, null, 2) + '\\n')"
    },
    {
      "id": "log_ap",
      "type": "action",
      "label": "Log: Generated antipatterns.json (N rules)"
    },
    {
      "id": "mkdir_dist",
      "type": "action",
      "label": "Ensure dist/ directory exists",
      "detail": "fs.mkdirSync(path.join(ROOT, 'dist'), { recursive: true })"
    },
    {
      "id": "delete_old_zip",
      "type": "action",
      "label": "Delete existing dist/extension.zip (if any)",
      "detail": "fs.unlinkSync(zipPath) — errors silently swallowed"
    },
    {
      "id": "zip_extension",
      "type": "action",
      "label": "zip -r dist/extension.zip . (from extension/ dir)",
      "detail": "execSync('zip -r ... . -x STORE_LISTING.md .DS_Store', { cwd: EXT_DIR })"
    },
    {
      "id": "stat_zip",
      "type": "action",
      "label": "Read zip file size",
      "detail": "fs.statSync(zipPath).size"
    },
    {
      "id": "log_zip",
      "type": "action",
      "label": "Log: Packaged extension.zip (size KB)"
    },
    {
      "id": "end",
      "type": "end",
      "label": "Build complete"
    }
  ],

  "flow": [
    "start → read_source",
    "read_source → strip_shebang",
    "strip_shebang → strip_markers",
    "strip_markers → set_is_browser",
    "set_is_browser → wrap_iife",
    "wrap_iife → mkdir_detector",
    "mkdir_detector → write_detector",
    "write_detector → log_detector",
    "log_detector → read_source_again",
    "read_source_again → match_antipatterns",
    "match_antipatterns --[match found]--> parse_antipatterns",
    "match_antipatterns --[no match]--> mkdir_dist",
    "parse_antipatterns → map_antipatterns",
    "map_antipatterns → write_ap_json",
    "write_ap_json → log_ap",
    "log_ap → mkdir_dist",
    "mkdir_dist → delete_old_zip",
    "delete_old_zip → zip_extension",
    "zip_extension → stat_zip",
    "stat_zip → log_zip",
    "log_zip → end"
  ],

  "phases": [
    {
      "name": "Phase 1 — Build Detector",
      "activities": ["read_source", "strip_shebang", "strip_markers", "set_is_browser", "wrap_iife", "mkdir_detector", "write_detector", "log_detector"],
      "output": "extension/detector/detect.js"
    },
    {
      "name": "Phase 2 — Extract Antipatterns",
      "activities": ["read_source_again", "match_antipatterns", "parse_antipatterns", "map_antipatterns", "write_ap_json", "log_ap"],
      "output": "extension/detector/antipatterns.json"
    },
    {
      "name": "Phase 3 — Zip Packaging",
      "activities": ["mkdir_dist", "delete_old_zip", "zip_extension", "stat_zip", "log_zip"],
      "output": "dist/extension.zip"
    }
  ],

  "key_paths": {
    "SOURCE": "src/detect-antipatterns.mjs",
    "DETECTOR_OUTPUT": "extension/detector/detect.js",
    "AP_OUTPUT": "extension/detector/antipatterns.json",
    "ZIP_OUTPUT": "dist/extension.zip",
    "EXT_DIR": "extension/"
  },

  "important_notes": "Script uses top-level await-free ESM with dynamic import of 'child_process' (line 75). The antipatterns extraction uses new Function() to evaluate JS object literals. Zip excludes STORE_LISTING.md and .DS_Store. The script is run directly: node scripts/build-extension.js.",

  "source_files_analyzed": ["scripts/build-extension.js"]
}
