@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}
skinparam stereotype {
    CBackgroundColor #D0E8FF
    CBorderColor #3A7BD5
    IBackgroundColor #D4EDDA
    IBorderColor #28A745
}

title Anti-Pattern Detection (Browser Build)\nsrc/detect-antipatterns-browser.js  ·  Browser IIFE

' ─────────────────────────────────────────
'  DATA SHAPES
' ─────────────────────────────────────────
package "Data Shapes" {

    class AntiPatternDef <<data>> {
        +id: string
        +category: "slop" | "quality"
        +name: string
        +description: string
        +skillSection?: string
        +skillGuideline?: string
    }

    class Finding <<data>> {
        +id?: string
        +type?: string
        +snippet?: string
        +detail?: string
        +el?: HTMLElement
    }

    class RgbColor <<data>> {
        +r: number
        +g: number
        +b: number
        +a: number
    }

    class SerializedFinding <<data>> {
        +type: string
        +detail: string
        +selector: string
        +rect: DOMRectReadOnly
    }
}

' ─────────────────────────────────────────
'  CONFIGURATION & CONSTANTS
' ─────────────────────────────────────────
package "Configuration & Constants" {

    class Constants <<module>> {
        +IS_BROWSER: boolean = true
        +IS_NODE: boolean = false
        +SAFE_TAGS: Set<string>
        +BORDER_SAFE_TAGS: Set<string>
        +OVERUSED_FONTS: Set<string>
        +BRAND_FONT_DOMAINS: Record<string, string[]>
        +GENERIC_FONTS: Set<string>
        +HEADING_TAGS: Set<string>
        +QUALITY_TEXT_TAGS: Set<string>
        +LAYOUT_TRANSITION_PROPS: Set<string>
        +ANTIPATTERNS: AntiPatternDef[]
    }

    class ImpeccableConfig <<config>> {
        +disabledRules: string[]
        +lineLengthMax: number
        +spotlightBlur: boolean
    }

    note bottom of ImpeccableConfig
        Accessed via
        window.__IMPECCABLE_CONFIG__
    end note
}

' ─────────────────────────────────────────
'  UTILITIES
' ─────────────────────────────────────────
package "Utilities" {

    class ColorUtilities <<utility>> {
        +isBrandFontOnOwnDomain(font: string): boolean
        +isNeutralColor(color: string): boolean
        +parseRgb(color: string): RgbColor | null
        +relativeLuminance(rgb: RgbColor): number
        +contrastRatio(c1: RgbColor, c2: RgbColor): number
        +parseGradientColors(bgImage: string): RgbColor[]
        +hasChroma(c: RgbColor, threshold?: number): boolean
        +getHue(c: RgbColor): number
        +colorToHex(c: RgbColor): string
    }

    class BackgroundResolution <<dom-traversal>> {
        +resolveBackground(el: Element, win?): RgbColor | null
        +resolveGradientStops(el: Element, win?): RgbColor[] | null
        +resolveFontSizePx(el: Element, win?): number
        +resolveLengthPx(value: string, fontSizePx: number): number | null
    }

    note bottom of BackgroundResolution
        Walks parentElement chain.
        Returns null when gradient
        (no single solid colour).
    end note
}

' ─────────────────────────────────────────
'  PURE DETECTION CORE
' ─────────────────────────────────────────
package "Pure Detection Core" {

    class PureDetection <<core>> {
        +checkBorders(tag, widths, colors, radius): Finding[]
        +checkColors(opts): Finding[]
        +checkIconTile(opts): Finding[]
        +checkMotion(opts): Finding[]
        +checkGlow(opts): Finding[]
        +checkHtmlPatterns(html: string): Finding[]
        +checkQuality(opts): Finding[]
        +checkPageQualityFromDoc(doc: Document): Finding[]
        +isCardLikeFromProps(hasShadow, hasBorder, hasRadius, hasBg): boolean
        +isEmojiOnlyText(text: string): boolean
    }

    note right of PureDetection
        Shared with Node build.
        Receives pre-extracted plain values —
        NO direct DOM / getComputedStyle access.
    end note
}

' ─────────────────────────────────────────
'  BROWSER ADAPTERS
' ─────────────────────────────────────────
package "Browser Adapters" {

    class BrowserDOMAdapters <<adapter>> {
        +checkElementBordersDOM(el: Element): Finding[]
        +checkElementColorsDOM(el: Element): Finding[]
        +checkElementIconTileDOM(el: Element): Finding[]
        +checkElementMotionDOM(el: Element): Finding[]
        +checkElementGlowDOM(el: Element): Finding[]
        +checkElementAIPaletteDOM(el: Element): Finding[]
        +checkElementQualityDOM(el: Element): Finding[]
    }

    note right of BrowserDOMAdapters
        Extracts live values via
        getComputedStyle() and
        getBoundingClientRect(),
        then delegates to PureDetection.
    end note

    class BrowserPageChecks <<page-level>> {
        +checkTypography(): Finding[]
        +checkLayout(): Finding[]
        +isCardLikeDOM(el: Element): boolean
        +checkPageQualityDOM(): Finding[]
    }

    note right of BrowserPageChecks
        Operates on document globals.
        checkTypography: fontUsage Map,
          overused-font / single-font /
          flat-type-hierarchy rules.
        checkLayout: nested-cards via
          flaggedEls Set.
    end note
}

' ─────────────────────────────────────────
'  BROWSER UI ENGINE  (IIFE core)
' ─────────────────────────────────────────
package "Browser UI Engine  [IIFE]" {

    class BrowserUIEngine <<browser-only>> {
        ' Internal state
        -overlays: HTMLDivElement[]
        -overlayIndex: number
        -firstScanDone: boolean
        -spotlightBackdrop: HTMLDivElement | null
        -spotlightTarget: Element | null
        -spotlightTimer: number | null
        -TYPE_LABELS: Record<string, string>
        -RULE_CATEGORY: Record<string, string>
        -EXTENSION_MODE: boolean
        -visibilityObserver: IntersectionObserver
        -bodyResizeObserver: ResizeObserver
        -resizeRAF: number
        ' Public API
        +scan(): Finding[]
        ' UI helpers
        -highlight(el: Element, findings: Finding[]): void
        -showPageBanner(findings: Finding[]): void
        -positionOverlay(overlay: HTMLDivElement): void
        -repositionOverlays(): void
        -getSpotlightBackdrop(): HTMLDivElement
        -updateSpotlightClipPath(): void
        -showSpotlight(target: Element): void
        -hideSpotlight(): void
        -isInViewport(el: Element): boolean
        -isInFixedContext(el: Element): boolean
        -isElementHidden(el: Element): boolean
        -isLikelyHashedClass(c: string): boolean
        -buildSelectorSegment(el: Element): string
        -generateSelector(el: Element): string
        -serializeFindings(findings: Finding[]): SerializedFinding[]
        -printSummary(findings: Finding[]): void
    }

    note right of BrowserUIEngine
        Exposed as: **window.impeccableScan()**
        Guard: exits if typeof window === 'undefined'

        scan() flow (per element):
          1. querySelectorAll('*') — skip overlays / claude-* ids
          2. Run 7 checkElement*DOM() calls → collect findings
          3. Filter by _ruleOk(id) via __IMPECCABLE_CONFIG__
          4. findings.length > 0 → highlight(el, findings)
        Then page-level: checkTypography, checkLayout,
          checkPageQualityDOM, checkHtmlPatterns
        showPageBanner if page findings exist.

        EXTENSION_MODE: disabled auto-scan,
          listens for postMessage commands
          (scan / toggle-overlays / remove / highlight).
        Sends: postMessage({source:'impeccable-results'})
        Ready: postMessage({source:'impeccable-ready'})

        Auto-scan (standalone):
          DOMContentLoaded + setTimeout(scan, 100)
    end note
}

' ─────────────────────────────────────────
'  RELATIONSHIPS
' ─────────────────────────────────────────

' Constants holds rule definitions
Constants "1" *-- "20" AntiPatternDef : ANTIPATTERNS

' Color utilities work with RgbColor
ColorUtilities ..> RgbColor : produces / consumes

' Background resolution returns colours
BackgroundResolution ..> RgbColor : returns
BackgroundResolution ..> ColorUtilities : uses

' Pure detection depends on colour utilities
PureDetection ..> ColorUtilities : uses
PureDetection ..> Finding : produces

' Browser DOM adapters delegate to pure detection
BrowserDOMAdapters ..> PureDetection : delegates after\nextracting computed styles
BrowserDOMAdapters ..> BackgroundResolution : resolveBackground\nresolveGradientStops
BrowserDOMAdapters ..> Finding : produces

' Browser page checks delegate to pure detection
BrowserPageChecks ..> PureDetection : delegates\n(checkPageQualityFromDoc)
BrowserPageChecks ..> Finding : produces

' UI engine orchestrates everything
BrowserUIEngine ..> BrowserDOMAdapters : calls per element\n(7 checkElement*DOM)
BrowserUIEngine ..> BrowserPageChecks : calls page-level checks
BrowserUIEngine ..> PureDetection : checkHtmlPatterns\n(document.outerHTML)
BrowserUIEngine ..> ImpeccableConfig : reads\n__IMPECCABLE_CONFIG__
BrowserUIEngine ..> SerializedFinding : produces\n(EXTENSION_MODE)
BrowserUIEngine ..> Finding : aggregates\nall findings
BrowserUIEngine ..> Constants : reads\nANTIPATTERNS / flags

@enduml
