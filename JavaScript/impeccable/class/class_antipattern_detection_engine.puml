@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Anti-Pattern Detection Engine (Node.js)\n<size:10>src/detect-antipatterns.mjs — functional ES module</size>

' ─────────────────────────────────────────
' DATA SHAPES
' ─────────────────────────────────────────
package "Data Shapes" {

    class Finding {
        +antipattern : string
        +name : string
        +description : string
        +file : string
        +line : number
        +snippet : string
        +importedBy : string[]
    }

    class Antipattern {
        +id : string
        +category : string
        +name : string
        +description : string
        +skillSection : string
        +skillGuideline : string
    }

    class FrameworkConfig {
        +name : string
        +files : string[]
        +defaultPort : number
        +portRe : RegExp
        +fingerprint : object
    }

    class StyleBlock {
        +content : string
        +startLine : number
    }

    class BorderOverride {
        +Left : BorderSide
        +Right : BorderSide
        +Top : BorderSide
        +Bottom : BorderSide
    }
}

' ─────────────────────────────────────────
' CONSTANTS
' ─────────────────────────────────────────
package "Constants" {

    class Constants <<module-level>> {
        {static} +ANTIPATTERNS : Antipattern[]
        {static} +SAFE_TAGS : Set<string>
        {static} +BORDER_SAFE_TAGS : Set<string>
        {static} +OVERUSED_FONTS : Set<string>
        {static} +GENERIC_FONTS : Set<string>
        {static} +BRAND_FONT_DOMAINS : Record<string, string[]>
        {static} +SKIP_DIRS : Set<string>
        {static} +SCANNABLE_EXTENSIONS : Set<string>
        {static} +HTML_EXTENSIONS : Set<string>
        {static} +FRAMEWORK_CONFIGS : FrameworkConfig[]
        {static} +REGEX_MATCHERS : Array<RegexRule>
        {static} +REGEX_ANALYZERS : Function[]
    }
}

' ─────────────────────────────────────────
' DETECTION MODULE  (detect-antipatterns.mjs)
' ─────────────────────────────────────────
package "detect-antipatterns.mjs" {

    class CLIRunner <<entrypoint>> {
        +detectCli() : Promise<void>
        +liveCli() : Promise<void>
        +formatFindings(findings, jsonMode) : string
        -handleStdin() : Promise<Finding[]>
        -isPortListening(port, fingerprint) : Promise<object>
        -detectFrameworkConfig(dir) : FrameworkConfig
        -findOpenPort(start) : Promise<number>
    }

    class FileScanner <<utility>> {
        +walkDir(dir : string) : string[]
        +buildImportGraph(files : string[]) : Map<string, Set<string>>
        -resolveImport(specifier, fromDir, fileSet) : string
    }

    class HTMLDetector <<scanner>> {
        +detectHtml(filePath : string) : Promise<Finding[]>
        +detectUrl(url : string) : Promise<Finding[]>
        +isFullPage(content : string) : boolean
        -buildBorderOverrideMap(document, window) : Map<Element, BorderOverride>
    }

    class TextDetector <<scanner>> {
        +detectText(content : string, filePath : string) : Finding[]
        -extractStyleBlocks(content, ext) : StyleBlock[]
        -extractCSSinJS(content, ext) : StyleBlock[]
        -runRegexMatchers(lines, filePath, lineOffset, blockCtx) : Finding[]
    }

    class ElementCheckers <<dom-checker>> {
        +checkElementBorders(tag, style, overrides) : object[]
        +checkElementMotion(tag, style) : object[]
        +checkElementGlow(tag, style, effectiveBg) : object[]
        +checkElementColors(el, style, tag, window) : object[]
        +checkElementIconTile(el, tag, window) : object[]
        +checkElementQuality(el, style, tag, window) : object[]
        -checkBorders(tag, widths, colors, radius) : object[]
        -checkColors(opts) : object[]
        -checkGlow(opts) : object[]
        -checkMotion(opts) : object[]
        -checkIconTile(opts) : object[]
        -checkQuality(opts) : object[]
        -checkHtmlPatterns(html : string) : object[]
    }

    class PageCheckers <<dom-checker>> {
        +checkPageTypography(doc, win) : object[]
        +checkPageLayout(doc, win) : object[]
        -checkPageQualityFromDoc(doc) : object[]
        -resolveFontSizePx(el, win) : number
        -isCardLikeDOM(el) : boolean
        -isCardLike(el, win) : boolean
    }

    class ColorUtilities <<utility>> {
        +isNeutralColor(color : string) : boolean
        -parseRgb(color) : object
        -relativeLuminance(rgb) : number
        -contrastRatio(c1, c2) : number
        -parseGradientColors(bgImage) : object[]
        -hasChroma(c, threshold) : boolean
        -getHue(c) : number
        -colorToHex(c) : string
        -isNeutralBorderColor(str) : boolean
        -normalizeColorForCheck(value : string) : string
        -resolveBackground(el, win) : string
        -resolveGradientStops(el, win) : string[]
        -isBrandFontOnOwnDomain(font) : boolean
    }

    class FindingFactory <<factory>> {
        -finding(id, filePath, snippet, line) : Finding
        -getAP(id : string) : Antipattern
    }
}

' ─────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────

' CLI orchestration
CLIRunner ..> HTMLDetector      : calls detectHtml / detectUrl
CLIRunner ..> TextDetector      : calls detectText
CLIRunner ..> FileScanner       : calls walkDir, buildImportGraph
CLIRunner ..> FrameworkConfig   : detects dev server

' HTML scan pipeline
HTMLDetector ..> ElementCheckers  : loops DOM elements
HTMLDetector ..> PageCheckers     : full-page analysis
HTMLDetector ..> FindingFactory   : wraps raw hits → Finding
HTMLDetector ..> BorderOverride   : builds override map

' Text scan pipeline
TextDetector ..> StyleBlock       : extracts style blocks
TextDetector ..> FindingFactory   : wraps regex hits → Finding

' Elemental checks → helpers
ElementCheckers ..> ColorUtilities : color analysis
PageCheckers    ..> ColorUtilities : font/color resolution

' Factory
FindingFactory ..> Finding    : creates
FindingFactory ..> Antipattern : looks up via getAP()

' Constants ownership
Constants *-- Antipattern     : ANTIPATTERNS[]
Constants *-- FrameworkConfig : FRAMEWORK_CONFIGS[]

' Checkers read constants
ElementCheckers ..> Constants : reads SAFE_TAGS\nBORDER_SAFE_TAGS
PageCheckers    ..> Constants : reads OVERUSED_FONTS
TextDetector    ..> Constants : reads REGEX_MATCHERS\nREGEX_ANALYZERS
FileScanner     ..> Constants : reads SKIP_DIRS\nSCANNABLE_EXTENSIONS

@enduml
