@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Browser Extension UI (DevTools & Popup)

package "DevTools" {

    class DevToolsPage <<module singleton>> {
        -lifecyclePort: Port|null
        -firstConnect: boolean
        --
        +connectLifecycle(): void
        +heartbeatInterval(): void
    }

    class Panel <<module singleton>> {
        -port: Port|null
        -overlaysVisible: boolean
        -allAntipatterns: array
        -disabledRules: string[]
        -currentFindings: FindingItem[]
        -currentHoverSelector: string|null
        --
        +getPort(): Port
        +postToPort(msg): void
        +initSettings(): Promise<void>
        +initAutoScanControl(currentMode): void
        +initLineLengthControl(currentMode): void
        +initSpotlightBlurToggle(currentValue): void
        +renderSettings(): void
        +toggleRule(ruleId, enabled): Promise<void>
        +handlePortMessage(msg): void
        +renderFindings(findings: FindingItem[]): void
        +inspectElement(selector: string): void
        +updateToggleButton(): void
        +showScanning(): void
        +setHoveredItem(selector: string|null): void
        +getInspectedUrl(): Promise<string>
        +formatFindingsForCopy(findings): Promise<string>
        +copyToClipboard(text, btn): Promise<void>
        +escapeHtml(str: string): string
    }

    class Sidebar <<module singleton>> {
        -port: Port|null
        -currentFindings: FindingItem[]
        --
        +getPort(): Port
        +refreshForCurrentSelection(): void
        +render(items: FindingItem[]): void
        +renderEmpty(text: string): void
        +renderNoFindings(): void
        +escapeHtml(str: string): string
    }

}

package "Popup" {

    class Popup <<module singleton>> {
        -overlaysVisible: boolean
        --
        +getActiveTabId(): Promise<number>
        +updateFromState(state: State): void
        +loadState(): Promise<void>
    }

}

package "Shared Data Types" {

    class FindingItem <<data>> {
        +selector: string
        +tagName: string
        +isPageLevel: boolean
        +isHidden: boolean
        +findings: Finding[]
    }

    class Finding <<data>> {
        +type: string
        +name: string
        +category: "slop" | "quality"
        +detail: string
        +description: string
    }

    class State <<data>> {
        +findings: FindingItem[]
        +overlaysVisible: boolean
    }

}

class ServiceWorker <<external>> {
}

' --- Relationships ---

DevToolsPage ..> Panel        : creates via\ndevtools.panels.create()
DevToolsPage ..> Sidebar      : creates via\nelements.createSidebarPane()

DevToolsPage --> ServiceWorker : lifecycle port\n(impeccable-devtools-{tabId})
Panel         --> ServiceWorker : persistent port\n(impeccable-panel-{tabId})
Sidebar       --> ServiceWorker : persistent port\n(impeccable-sidebar-{tabId})
Popup         ..> ServiceWorker : sendMessage()\none-shot

Panel   o-- FindingItem : currentFindings
Sidebar o-- FindingItem : currentFindings
Panel   ..> State       : reads on connect

FindingItem *-- Finding : findings[ ]

@enduml
