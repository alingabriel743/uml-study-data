@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Build Pipeline Orchestration

' ─────────────────────────────────────────────
' Package: scripts (entry point + sub-page generator)
' ─────────────────────────────────────────────
package "scripts" {

    class BuildOrchestrator <<entrypoint>> {
        -ROOT_DIR: string
        -DIST_DIR: string
        --
        +build(): Promise<void>
        +generateCounts(rootDir, skills[], buildDir): number
        +validateAntipatternRules(rootDir): number
        +validateNoEmDashes(rootDir): number
        +validateSiteHeader(rootDir): number
        +buildStaticSite(extraEntrypoints[]): Promise<BunBuildResult>
        +assembleUniversal(distDir, suffix?): void
        +generateApiData(buildDir, skills[], patterns): void
        +copyDistToBuild(distDir, buildDir): void
        +generateCFConfig(buildDir): void
        +copyDirSync(src, dest): void
    }

    class SubPageGenerator <<service>> {
        --
        +generateSubPages(rootDir): Promise<{files: string[]}>
        +renderSkillDetail(skill, knownSkillIds): string
        +renderSkillDemo(skill): string
        +renderDocsSidebar(skillsByCategory, tutorials, current?): string
        +renderSkillsOverviewMain(skillsByCategory): string
        +renderAntiPatternsSidebar(grouped): string
        +renderAntiPatternsMain(grouped, totalRules): string
        +renderRuleCard(rule): string
        +renderTutorialsIndexMain(tutorials): string
        +renderTutorialDetail(tutorial, knownSkillIds): string
        +renderVisualModeMain(): string
        +wrapInDocsLayout(sidebarHtml, mainHtml): string
        +groupRulesBySection(rules): object
        +escapeHtml(str): string
        +escapeAttr(str): string
    }
}

' ─────────────────────────────────────────────
' Package: scripts/lib (supporting modules)
' ─────────────────────────────────────────────
package "scripts/lib" {

    class Utils <<utility>> {
        --
        +readSourceFiles(rootDir): {skills: Skill[]}
        +readPatterns(rootDir): {patterns, antipatterns}
        +parseFrontmatter(content): {frontmatter, body}
    }

    class TransformerFactory <<factory>> {
        +PROVIDERS: Record<string, ProviderConfig>
        --
        +createTransformer(providerConfig): TransformFn
        +TransformFn(skills[], distDir, options): void
    }

    class ZipBuilder <<utility>> {
        --
        +createAllZips(distDir): Promise<void>
    }

    class MarkdownRenderer <<renderer>> {
        --
        +renderMarkdown(body, options): string
        +slugify(text): string
    }

    class PageRenderer <<renderer>> {
        --
        +renderPage(title, description, bodyHtml, activeNav, canonicalPath, bodyClass): string
    }

    class SubPageDataBuilder <<data>> {
        +EXCLUDED_SKILLS: Set<string>
        +SKILL_CATEGORIES: Record<string, string>
        +CATEGORY_ORDER: string[]
        +CATEGORY_LABELS: Record<string, string>
        +CATEGORY_DESCRIPTIONS: Record<string, string>
        --
        +buildSubPageData(rootDir): Promise<SubPageDataModel>
        +readAntipatternRules(rootDir): AntipatternRule[]
        +readEditorialWrapper(contentDir, kind, slug): object
        +loadCommandDemos(rootDir): Promise<Record<string, Demo>>
    }
}

' ─────────────────────────────────────────────
' Package: content/site (catalog data)
' ─────────────────────────────────────────────
package "content/site" {

    class AntiPatternsCatalog <<data>> {
        +DETECTION_LAYERS: Record<string, string>
        +VISUAL_EXAMPLES: Record<string, string>
        +LLM_ONLY_RULES: Rule[]
        +GALLERY_ITEMS: GalleryItem[]
        +LAYER_LABELS: Record<string, string>
        +LAYER_DESCRIPTIONS: Record<string, string>
    }
}

' ─────────────────────────────────────────────
' Key Data Types
' ─────────────────────────────────────────────
package "Data Types" {

    class Skill <<dataType>> {
        +filePath: string
        +name: string
        +description: string
        +userInvocable: boolean
        +argumentHint: string
        +body: string
        +references: string[]
    }

    class SubPageDataModel <<dataType>> {
        +skills: Skill[]
        +skillsByCategory: Record<string, Skill[]>
        +knownSkillIds: Set<string>
        +rules: AntipatternRule[]
        +tutorials: Tutorial[]
    }

    class ProviderConfig <<dataType>> {
        +provider: string
        +configDir: string
    }

    class AntipatternRule <<dataType>> {
        +id: string
        +name: string
        +description: string
        +category: string
        +layer: string
        +skillSection: string
        +skillGuideline: string
        +visual: string
    }

    class Tutorial <<dataType>> {
        +slug: string
        +title: string
        +description: string
        +tagline: string
        +order: number
        +body: string
    }

    class Demo <<dataType>> {
        +id: string
        +caption: string
        +before: string
        +after: string
    }
}

' ─────────────────────────────────────────────
' Relationships — Orchestrator dependencies
' ─────────────────────────────────────────────
BuildOrchestrator ..> SubPageGenerator    : uses\ngenerateSubPages()
BuildOrchestrator ..> Utils               : uses\nreadSourceFiles()\nreadPatterns()
BuildOrchestrator ..> TransformerFactory  : uses\ncreateTransformer()\nPROVIDERS
BuildOrchestrator ..> ZipBuilder          : uses\ncreateAllZips()

' Sub-page generator dependencies
SubPageGenerator ..> SubPageDataBuilder   : uses\nbuildSubPageData()
SubPageGenerator ..> MarkdownRenderer     : uses\nrenderMarkdown()
SubPageGenerator ..> PageRenderer         : uses\nrenderPage()

' Sub-page data builder dependencies
SubPageDataBuilder ..> Utils              : uses\nreadSourceFiles()\nparseFrontmatter()
SubPageDataBuilder ..> AntiPatternsCatalog: uses\nDETECTION_LAYERS\nLLM_ONLY_RULES\nGALLERY_ITEMS

' Data type associations
BuildOrchestrator ..> Skill               : produces/consumes
BuildOrchestrator ..> ProviderConfig      : consumes
SubPageGenerator ..> SubPageDataModel     : consumes
SubPageDataBuilder ..> SubPageDataModel   : produces
SubPageDataBuilder ..> AntipatternRule    : produces
SubPageDataBuilder ..> Tutorial           : produces
SubPageDataBuilder ..> Demo               : produces
TransformerFactory ..> ProviderConfig     : consumes

@enduml
