@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Build Utilities & Packaging

package "scripts/lib" {

    class Utils <<module>> {
        +{static} PROVIDER_PLACEHOLDERS: Record<string, ProviderConfig>
        +{static} EXCLUDED_FROM_SUGGESTIONS: Set<string>
        --
        +parseFrontmatter(content: string): FrontmatterResult
        +readFilesRecursive(dir: string, fileList?: string[]): string[]
        +readSourceFiles(rootDir: string): SkillsResult
        +ensureDir(dirPath: string): void
        +cleanDir(dirPath: string): void
        +writeFile(filePath: string, content: string): void
        +readPatterns(rootDir: string): PatternsResult
        +replacePlaceholders(content: string, provider: string, commandNames?: string[], allSkillNames?: string[]): string
        +prefixSkillReferences(content: string, prefix: string, skillNames: string[], commandPrefix?: string): string
        +generateYamlFrontmatter(data: object): string
        -escapeRegex(str: string): string
    }

    class ZipPackager <<module>> {
        +createProviderZip(providerDir: string, distDir: string, providerName: string): Promise<void>
        +createAllZips(distDir: string): Promise<void>
    }

    class RenderPage <<module>> {
        -{static} cachedHeader: string | null
        +{static} ROOT_DIR: string
        +{static} HEADER_PARTIAL: string
        --
        +readHeaderPartial(): string
        +applyActiveNav(headerHtml: string, activeNav: string): string
        +renderPage(opts: RenderPageOpts): string
        -escapeHtml(str: string): string
        -escapeAttr(str: string): string
    }

    class RenderMarkdown <<module>> {
        +slugify(text: string): string
        +createRenderer(opts?: RendererOpts): Renderer
        +renderMarkdown(markdown: string, opts?: RendererOpts): string
        -resolveHref(href: string, ctx: ResolveContext): HrefResult
        -escapeHtml(str: string): string
        -escapeAttr(str: string): string
    }

}

package "Data Types" {

    class SkillEntry <<datatype>> {
        +name: string
        +description: string
        +license: string
        +compatibility: string
        +metadata: object | null
        +allowedTools: string
        +userInvocable: boolean
        +argumentHint: string
        +context: object | null
        +body: string
        +filePath: string
        +references: ReferenceFile[]
        +scripts: ScriptFile[]
    }

    class ReferenceFile <<datatype>> {
        +name: string
        +content: string
        +filePath: string
    }

    class ScriptFile <<datatype>> {
        +name: string
        +content: string
        +filePath: string
    }

    class PatternGroup <<datatype>> {
        +name: string
        +items: string[]
    }

    class ProviderConfig <<datatype>> {
        +model: string
        +config_file: string
        +ask_instruction: string
        +command_prefix: string
    }

    class RenderPageOpts <<datatype>> {
        +title: string
        +description: string
        +bodyHtml: string
        +activeNav?: string
        +canonicalPath?: string
        +extraHead: string
        +bodyClass: string
        +assetDepth: number
    }

}

' Internal call chains (within modules)
Utils ..> Utils : writeFile()\ncalls ensureDir()
Utils ..> Utils : readSourceFiles()\ncalls parseFrontmatter()
Utils ..> Utils : replacePlaceholders()\ncalls escapeRegex()
ZipPackager ..> ZipPackager : createAllZips()\ncalls createProviderZip()
RenderPage ..> RenderPage : renderPage()\ncalls readHeaderPartial()\n+ applyActiveNav()
RenderMarkdown ..> RenderMarkdown : renderMarkdown()\ncalls createRenderer()

' Cross-module dependencies
RenderPage ..> RenderMarkdown : <<uses>>

' Module → Data type relationships
Utils ..> SkillEntry : produces
Utils ..> PatternGroup : produces
Utils ..> ProviderConfig : reads from\nPROVIDER_PLACEHOLDERS
RenderPage ..> RenderPageOpts : accepts

' Data type compositions
SkillEntry *-- ReferenceFile : references
SkillEntry *-- ScriptFile : scripts

@enduml
