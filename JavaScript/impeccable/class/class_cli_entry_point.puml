@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9E6
    BorderColor #CCA800
    FontSize 11
}

title CLI Entry Point & Command Routing

package "bin/" {

    class cli <<module>> {
        -__dirname : string
        -args : string[]
        -command : string
        --
        +main() : async void
        +showHelp() : void
        +showVersion() : void
    }

    package "bin/commands/" {

        class skillsCli <<module>> {
            +{static} API_BASE : string
            +{static} PROVIDER_DIRS : string[]
            --
            +run(args : string[]) : async void
            -showHelp() : async void
            -install(flags : string[]) : async void
            -update(flags : string[]) : async void
            -check() : async void
            -findProjectRoot() : string
            -isAlreadyInstalled(root) : string|null
            -downloadAndExtractBundle() : Promise<string>
            -downloadFile(url, dest) : Promise<void>
            -hashSkillsDir(skillsDir) : string
            -isUpToDate(root, providers, bundleDir) : boolean
            -renameSkillsWithPrefix(root, prefix) : number
            -detectPrefix(root) : string
            -getSkillsVersion(root) : string|null
            -ask(question) : Promise<string>
        }

    }

}

package "src/" {

    class detectAntipatterns <<module>> {
        +{static} ANTIPATTERNS : object
        +{static} SCANNABLE_EXTENSIONS : string[]
        +{static} SKIP_DIRS : string[]
        +{static} FRAMEWORK_CONFIGS : object
        --
        +detectCli() : async void
        +liveCli() : async void
        +detectHtml(html) : findings
        +detectUrl(url) : Promise<findings>
        +detectText(text) : findings
        +walkDir(dir) : files[]
        +formatFindings(findings) : string
        +buildImportGraph(entry) : graph
        +detectFrameworkConfig(dir) : config
        +isPortListening(port) : boolean
    }

}

cli ..> detectAntipatterns : <<dynamic import>>\ndetect | live | default
cli ..> skillsCli : <<dynamic import>>\nskills

note right of cli
  **Command Routing (main IIFE)**
  ─────────────────────────────
  !command | --help | -h  → showHelp()
  --version | -v          → showVersion()
  detect                  → detectAntipatterns.detectCli()
  live                    → detectAntipatterns.liveCli()
  skills                  → skillsCli.run(args.slice(1))
  <default>               → detectAntipatterns.detectCli()
end note

note bottom of skillsCli
  **Sub-command Routing (run)**
  ─────────────────────────────
  !sub | help | --help    → showHelp()
  install                 → install(args.slice(1))
  update                  → update(args.slice(1))
  check                   → check()
  <unknown>               → console.error + exit 1
end note

@enduml
