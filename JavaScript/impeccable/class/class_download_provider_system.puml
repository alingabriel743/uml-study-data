@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Download Provider System

package "lib/download-providers.js" {
    class DownloadProvidersRegistry <<module>> {
        +{static} FILE_DOWNLOAD_PROVIDER_CONFIG_DIRS: Record<string,string> (frozen)
        +{static} FILE_DOWNLOAD_PROVIDERS: string[] (frozen)
        +{static} BUNDLE_DOWNLOAD_PROVIDERS: string[] (frozen)
        +{static} DOWNLOAD_PROVIDERS: string[] (frozen)
    }

    note right of DownloadProvidersRegistry
        FILE_DOWNLOAD_PROVIDERS (8 providers):
        cursor, claude-code, gemini, codex,
        agents, kiro, opencode, pi

        BUNDLE_DOWNLOAD_PROVIDERS (2 providers):
        universal, universal-prefixed

        DOWNLOAD_PROVIDERS = all 10 combined
    end note
}

package "functions/api/download" {
    class FileDownloadHandler <<CloudflarePagesFunction>> {
        -VALID_ID: RegExp = /^[a-zA-Z0-9_-]+$/
        --
        +onRequestGet(context): Promise<Response>
    }

    note bottom of FileDownloadHandler
        Route: GET /api/download/:type/:provider/:id
        - Validates type ('skill' | 'command')
        - Validates provider ∈ FILE_DOWNLOAD_PROVIDERS
        - Validates id against VALID_ID regex
        - Resolves: /_data/dist/{provider}/{configDir}/skills/{id}/SKILL.md
        - Returns: application/octet-stream, attachment
        - Cache: public, s-maxage=86400

        Errors: 400 Invalid type | provider | id
                404 File not found
    end note

    class BundleDownloadHandler <<CloudflarePagesFunction>> {
        +onRequestGet(context): Promise<Response>
    }

    note bottom of BundleDownloadHandler
        Route: GET /api/download/bundle/:provider
        - Validates provider ∈ BUNDLE_DOWNLOAD_PROVIDERS
        - Sanitizes provider name (alphanumeric + ._-)
        - Resolves: /_data/dist/{provider}.zip
        - Returns: application/zip
        - Filename: impeccable-style-{safeProvider}.zip
        - Cache: public, s-maxage=86400

        Errors: 400 Invalid provider
                404 Bundle not found
    end note
}

package "server/lib/validation.js" {
    class ValidationHelpers <<module>> {
        +{static} isAllowedProvider(provider): boolean
        +{static} isAllowedFileProvider(provider): boolean
        +{static} isAllowedBundleProvider(provider): boolean
    }
}

package "scripts/lib" {
    class ZipBuilder <<module>> {
        +{static} createProviderZip(provider): Promise<Buffer>
    }

    class TransformerShared <<module>> {
        +{static} transformProvider(provider, options): object
    }
}

class CloudflareAssets <<external>> {
    +fetch(url): Promise<Response>
}

' Registry internal relationships
DownloadProvidersRegistry ..> DownloadProvidersRegistry : FILE_DOWNLOAD_PROVIDERS\n= Object.keys(\nFILE_DOWNLOAD_PROVIDER_CONFIG_DIRS\n)

' Handler dependencies on registry
FileDownloadHandler ..> DownloadProvidersRegistry : uses FILE_DOWNLOAD_PROVIDERS\n& FILE_DOWNLOAD_PROVIDER_CONFIG_DIRS
BundleDownloadHandler ..> DownloadProvidersRegistry : uses BUNDLE_DOWNLOAD_PROVIDERS

' Handler dependency on Cloudflare asset binding
FileDownloadHandler ..> CloudflareAssets : context.env.ASSETS
BundleDownloadHandler ..> CloudflareAssets : context.env.ASSETS

' Validation helpers depend on registry
ValidationHelpers ..> DownloadProvidersRegistry : reads DOWNLOAD_PROVIDERS\nFILE_DOWNLOAD_PROVIDERS\nBUNDLE_DOWNLOAD_PROVIDERS

' Build-time tools use registry
ZipBuilder ..> DownloadProvidersRegistry : uses provider names
TransformerShared ..> DownloadProvidersRegistry : uses provider names

@enduml
