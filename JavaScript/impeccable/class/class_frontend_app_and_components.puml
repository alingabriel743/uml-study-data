@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F9A825
skinparam stereotypeFontSize 10
skinparam ArrowFontSize 10

title Frontend App & UI Components

package "App Entry Point" {
    class App <<module>> {
        -allCommands: Array
        ..
        -init(): void
        -loadContent(): Promise<void>
        -showLoadError(error): void
        -initGalleryStack(): void
        -renderPatternsWithTabs(patterns, antipatterns): void
        -escapeHtml(value: string): string
    }
    note right of App
        Entry point:
        DOMContentLoaded → init()
    end note
}

package "UI Components" {
    class GlassTerminal <<module>> {
        -magazineState: object
        -currentSplitInstance: SplitCompareInstance | null
        -currentCommandId: string | null
        -sourceCache: object
        ..
        +initGlassTerminal(): void
        +renderTerminalLayout(commands: Command[]): void
        -isMobile(): boolean
        -renderDesktopLayout(container, commands): void
        -renderMobileLayout(container, commands): void
        -renderSpread(cmd, index, isActive): string
        -initSpreadDemo(index: number): void
        -goToSpread(newIndex, commands): void
        -setupFisheyeList(commands, headerIndices): void
        -setupMagazineKeyboard(commands): void
        -setupMagazineIntersection(container): void
        -setupMobileInteractions(commands): void
        -setupStackTabs(): void
        -fetchCommandSource(cmdId: string): Promise<string|null>
        -updateSourceContent(cmdId: string): Promise<void>
        -truncateDescription(text, maxLen?): string
        -escapeHtml(text: string): string
    }

    class SectionNav <<module>> {
        -ticking: boolean
        ..
        +initSectionNav(): void
        -updateNav(): void
    }

    class FoundationGrid <<module>> {
        ..
        +initFoundationGrid(): void
    }

    class ArtGallery <<module>> {
        ..
        +initArtGallery(): void
        +renderGallery(skills: Skill[]): void
        -renderFrame(skill: Skill, index: number): string
        -renderComingSoonVisual(id: string): string
        -formatName(id: string): string
        -setupInteractions(): void
    }

    class Lens <<module>> {
        ..
        +initLensEffect(): void
    }
}

package "External Dependencies" {
    class SplitCompare <<module>> {
        +initSplitCompare(container, options): void
    }

    class DemoRenderer <<module>> {
        +renderCommandDemo(cmdId): void
        +initCommandDemo(cmdId, demoArea): void
        +renderSkillDemo(skillId): void
        +setupDemoTabs(): void
    }

    class DemoToggles <<module>> {
        +setupDemoToggles(): void
    }

    class Data <<module>> {
        +commandCategories: Array
        +commandRelationships: Array
        +betaCommands: Array
        +skillFocusAreas: object
        +dimensionGuidelineCounts: object
        +readySkills: Array
    }

    class FoundationAnimations <<module>> {
        +foundationAnimations: Map
    }

    class FrameworkViz <<module>> {
        +initFrameworkViz(): void
    }

    class ScrollUtils <<module>> {
        +initAnchorScroll(): void
        +initHashTracking(): void
    }

    class RevealUtils <<module>> {
        +initScrollReveal(): void
    }
}

' ── App → UI Components ──────────────────────────────────────────────────────
App ..> GlassTerminal  : initGlassTerminal()\nrenderTerminalLayout()
App ..> SectionNav     : initSectionNav()
App ..> FoundationGrid : initFoundationGrid()
App ..> Lens           : initLensEffect()
App ..> FrameworkViz   : initFrameworkViz()
App ..> ScrollUtils    : initAnchorScroll()\ninitHashTracking()
App ..> RevealUtils    : initScrollReveal()

' ── UI Components → External Dependencies ────────────────────────────────────
GlassTerminal  ..> SplitCompare        : initSplitCompare()
GlassTerminal  ..> DemoRenderer        : renderCommandDemo()\ninitCommandDemo()
GlassTerminal  ..> Data                : commandCategories\ncommandRelationships\nbetaCommands

Lens           ..> SplitCompare        : delegates to

FoundationGrid ..> Data                : skillFocusAreas\ndimensionGuidelineCounts
FoundationGrid ..> FoundationAnimations: foundationAnimations

ArtGallery     ..> Data                : readySkills\nskillFocusAreas
ArtGallery     ..> DemoRenderer        : renderSkillDemo()\nsetupDemoTabs()
ArtGallery     ..> DemoToggles         : setupDemoToggles()

@enduml
