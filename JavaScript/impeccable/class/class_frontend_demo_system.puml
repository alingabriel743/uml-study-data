@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Frontend Demo System

package "Rendering" {

    class DemoRenderer <<module>> {
        +renderCommandDemo(commandId: string): string
        +renderSkillDemo(skillId: string): string
        +initCommandDemo(commandId: string, container: Element): void
        +setupDemoTabs(): void
        -renderSkillTabDemo(skillId: string, tab: SkillTabDemo): string
    }

    class DemoToggles <<module>> {
        +setupDemoToggles(): void
        +setupCommandDemoToggles(allCommands: Command[], selectCommand: Function): void
        -handleDemoToggle(demoId: string, isAfter: boolean): void
        -handleCommandDemoToggle(demoId: string, isAfter: boolean): void
        -setupInteractiveButtons(): void
    }

}

package "Demo Registry" {

    class DemosIndex <<barrel>> {
        +commandDemos: Record<string, CommandDemo>
        +getCommandDemo(commandId: string): CommandDemo
        +skillDemos: Record<string, SkillDemo>
        +getSkillDemo(skillId: string): SkillDemo
    }

    class CommandDemoRegistry <<registry>> {
        +commandDemos: Record<string, CommandDemo>
        +getCommandDemo(commandId: string): CommandDemo | null
    }

    note right of CommandDemoRegistry
        Registered commands (16):
        animate, bolder, audit, critique,
        polish, optimize, harden, clarify,
        quieter, distill, colorize, delight,
        adapt, typeset, layout, overdrive
    end note

    class SkillDemoRegistry <<registry>> {
        +skillDemos: Record<string, SkillDemo>
        +getSkillDemo(skillId: string): SkillDemo | null
    }

    note right of SkillDemoRegistry
        Registered skills (7):
        ux-writing, spatial-design,
        motion-design, typography,
        interaction-design,
        color-and-contrast,
        responsive-design
    end note

}

package "Data Models" {

    class CommandDemo <<data object>> {
        +id: string
        +caption: string
        +before: string
        +after: string
        +onToggle(viewport: Element, isAfter: boolean): void
        +init(container: Element): void
    }

    note bottom of CommandDemo
        onToggle and init are optional.
        Only 'overdrive' has init().
        'shape' and 'impeccable' are NOT
        in registry — handled by DemoRenderer.
    end note

    class SkillDemo <<data object>> {
        +id: string
        +tabs: SkillTabDemo[]
    }

    class SkillTabDemo <<data object>> {
        +id: string
        +label: string
        +caption: string
        +hasToggle: boolean
        +before: string
        +after: string
        +beforeClass: string
        +afterClass: string
        +onToggle(viewport: Element, isAfter: boolean): void
        +onAfterRender(): void
    }

    note bottom of SkillTabDemo
        Toggle modes (in priority order):
        1. onToggle() — custom handler
        2. beforeClass/afterClass — CSS swap
        3. before/after — innerHTML swap
    end note

}

package "Data" {

    class DataModule <<constants>> {
        +readySkills: string[]
        +readyCommands: string[]
        +betaCommands: string[]
        +skillFocusAreas: Record<string, FocusArea[]>
        +dimensionGuidelineCounts: Record<string, number>
        +skillReferenceDomains: string[]
        +commandProcessSteps: Record<string, string[]>
        +commandCategories: Record<string, string>
        +skillRelationships: Record<string, object>
        +commandRelationships: Record<string, object>
    }

}

' Rendering depends on Registries
DemoRenderer ..> CommandDemoRegistry : uses getCommandDemo()
DemoRenderer ..> SkillDemoRegistry : uses getSkillDemo()
DemoToggles ..> CommandDemoRegistry : uses getCommandDemo()
DemoToggles ..> SkillDemoRegistry : uses getSkillDemo()

' DemoRenderer uses data models
DemoRenderer ..> CommandDemo : reads .before/.after/.caption/.init()
DemoRenderer ..> SkillTabDemo : renders via renderSkillTabDemo()

' DemoToggles uses data models
DemoToggles ..> CommandDemo : reads .before/.after, calls .onToggle()
DemoToggles ..> SkillTabDemo : reads .before/.after/.beforeClass/.afterClass,\ncalls .onToggle()/.onAfterRender()

' DemosIndex re-exports both registries
DemosIndex ..> CommandDemoRegistry : re-exports
DemosIndex ..> SkillDemoRegistry : re-exports

' Registries aggregate data models
CommandDemoRegistry o-- CommandDemo : aggregates 16 instances
SkillDemoRegistry o-- SkillDemo : aggregates 7 instances

' SkillDemo composes SkillTabDemos
SkillDemo *-- SkillTabDemo : composes 2-3 tabs

@enduml
