@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #FFF3CD
    BorderColor #856404
}
skinparam note {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
}

title Frontend Visual Effects

' ──────────────────────────────────────────────────
' liquid-canvas.js — physics-based canvas grid
' ──────────────────────────────────────────────────
package "liquid-canvas.js" {

    class Point <<inner class>> {
        +x: number
        +y: number
        +ox: number
        +oy: number
        +vx: number
        +vy: number
        --
        +constructor(x: number, y: number)
        +update(): void
    }

    note right of Point
      Closure-scoped — NOT exported.
      update() applies mouse repulsion,
      spring-back, friction & integration.
    end note

    class initHeroEffect <<function>> {
        ~points: Point[]
        ~mouse: {x, y, radius}
        ~animationId: number
        ~gap: number
        ~width: number
        ~height: number
        --
        -resize(): void
        -initGrid(): void
        -draw(): void
        -handleMouseMove(e: MouseEvent): void
        -handleMouseLeave(): void
    }
}

' liquid-canvas: initHeroEffect owns Point instances
initHeroEffect *-- Point : "creates / owns"

' ──────────────────────────────────────────────────
' hero-shader.js — WebGL mesh-gradient shader
' ──────────────────────────────────────────────────
package "hero-shader.js" {

    class initHeroShader <<function>> {
        ~uniforms: ShaderUniforms
        --
        +{static} init(container: HTMLElement): void
    }

    note bottom of initHeroShader
      Mounts WebGL mesh-gradient on #hero-shader.
      Uniforms: u_colors[4], u_distortion,
      u_swirl, u_grainMixer, u_fit, u_scale…
      Disposes on beforeunload.
    end note
}

' ──────────────────────────────────────────────────
' split-compare.js — before/after slider
' ──────────────────────────────────────────────────
package "split-compare.js" {

    interface SplitInstance {
        +destroy(): void
        +setPosition(percent: number): void
    }

    class initSplitCompare <<function>> {
        ~targetX: number
        ~currentX: number
        ~animationId: number
        --
        -recalcSkewOffset(): void
        -updateSplit(percent: number): void
        -retriggerAnimations(): void
        -animate(): void
        -startAnimation(): void
        -handleMouseEnter(): void
        -handleMouseLeave(): void
        -handleMouseMove(e: MouseEvent): void
        -handleTouchStart(e: TouchEvent): void
        -handleTouchMove(e: TouchEvent): void
        -handleTouchEnd(): void
    }

    class initAllSplitCompare <<function>> {
        +selector: string
        --
        +{static} init(selector: string): SplitInstance[]
    }
}

' split-compare: initSplitCompare produces a SplitInstance
initSplitCompare ..|> SplitInstance : "returns"
initAllSplitCompare o-- SplitInstance : "aggregates []"
initAllSplitCompare ..> initSplitCompare : "<<calls>>"

' ──────────────────────────────────────────────────
' framework-viz.js — periodic table of CLI commands
' ──────────────────────────────────────────────────
package "framework-viz.js" {

    class PeriodicTable {
        -container: HTMLElement
        -activeTooltip: HTMLElement | null
        -activeElement: HTMLButtonElement | null
        --
        +constructor(container: HTMLElement)
        +init(): void
        +renderTable(): void
        +createCategoryGroup(category: string, commands: string[]): HTMLElement
        +createElement(cmd: string, category: string): HTMLButtonElement
        +showTooltip(el: HTMLElement, cmd: string): void
        +hideTooltip(): void
    }

    class initFrameworkViz <<function>> {
        +{static} init(): void
    }
}

' framework-viz: factory function instantiates PeriodicTable
initFrameworkViz ..> PeriodicTable : "<<instantiates>>"

' ──────────────────────────────────────────────────
' External dependencies
' ──────────────────────────────────────────────────
package "@paper-design/shaders" <<external>> {

    class ShaderMount <<external>> {
        +constructor(container, shader, uniforms, ...)
        +destroy(): void
    }
}

' hero-shader uses ShaderMount from external library
initHeroShader ..> ShaderMount : "<<uses>>"

package "../data.js" <<module>> {

    class DataModule <<module>> {
        +commandCategories: Record<string, string[]>
        +commandRelationships: Record<string, string[]>
        +betaCommands: string[]
    }
}

' PeriodicTable depends on data module constants
PeriodicTable ..> DataModule : "<<imports>>"

@enduml
