@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam stereotypeCBackgroundColor #D0E8FF
skinparam stereotypeABackgroundColor #FFE8D0
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Server API Layer

' ─────────────────────────────────────────────
' HTTP Entry Point
' ─────────────────────────────────────────────
package "HTTP Server (server/index.js)" {
    class HttpServer <<module>> {
        .. Route Handlers ..
        GET /api/skills
        GET /api/commands
        GET /api/patterns
        GET /api/command-source/:id
        GET /api/download/:type/:provider/:id
        GET /api/download/bundle/:provider
        GET /skills, /anti-patterns, /tutorials/:slug
        GET /assets/*, /css/*, /js/*, /fixtures/*
        .. Methods ..
        +serveGenerated(pagePath: string): Promise<Response>
    }
}

' ─────────────────────────────────────────────
' API Handlers
' ─────────────────────────────────────────────
package "API Handlers (server/lib/api-handlers.js)" {
    class ApiHandlers <<module>> {
        +getSkills(): Promise<Skill[]>
        +getCommands(): Promise<Skill[]>
        +getCommandSource(id: string): Promise<CommandSourceResult>
        +getFilePath(type: string, provider: string, id: string): string | null
        +handleFileDownload(type: string, provider: string, id: string): Promise<Response>
        +getPatterns(): Promise<PatternResult>
        +handleBundleDownload(provider: string): Promise<Response>
        -readFileContent(filePath: string): Promise<string>
    }
}

' ─────────────────────────────────────────────
' Validation / Security Boundary
' ─────────────────────────────────────────────
package "Validation (server/lib/validation.js)" {
    class Validation <<module>> {
        .. Constants ..
        +{static} VALID_ID: RegExp
        +{static} ALLOWED_PROVIDERS: string[]
        +{static} ALLOWED_FILE_PROVIDERS: string[]
        +{static} ALLOWED_BUNDLE_PROVIDERS: string[]
        +{static} ALLOWED_TYPES: string[]
        .. Guard Functions ..
        +isValidId(id: string): boolean
        +isAllowedProvider(provider: string): boolean
        +isAllowedFileProvider(provider: string): boolean
        +isAllowedBundleProvider(provider: string): boolean
        +isAllowedType(type: string): boolean
        +sanitizeFilename(filename: string): string
    }
}

' ─────────────────────────────────────────────
' Shared Utilities
' ─────────────────────────────────────────────
package "Utilities (scripts/lib/utils.js)" {
    class Utils <<module>> {
        +parseFrontmatter(content: string): FrontmatterResult
        +readPatterns(rootDir: string): PatternResult
    }
}

' ─────────────────────────────────────────────
' Provider Config (lib/download-providers.js)
' ─────────────────────────────────────────────
package "Config (lib/download-providers.js)" {
    class DownloadProviders <<module>> {
        +{static} DOWNLOAD_PROVIDERS: string[]
        +{static} FILE_DOWNLOAD_PROVIDERS: string[]
        +{static} BUNDLE_DOWNLOAD_PROVIDERS: string[]
        +{static} FILE_DOWNLOAD_PROVIDER_CONFIG_DIRS: Record<string, string>
    }
}

' ─────────────────────────────────────────────
' Data Shapes
' ─────────────────────────────────────────────
class Skill <<data>> {
    +id: string
    +name: string
    +description: string
    +userInvocable: boolean
}

class PatternResult <<data>> {
    +patterns: Array
    +antipatterns: Array
}

class CommandSourceResult <<data>> {
    +content: string | null
    +error: string
    +status: number
}

class FrontmatterResult <<data>> {
    +frontmatter: object
    +body: string
}

' ─────────────────────────────────────────────
' Module Relationships
' ─────────────────────────────────────────────
HttpServer ..> ApiHandlers       : imports handlers >
ApiHandlers ..> Validation       : validates type / provider / id >
ApiHandlers ..> Utils            : parseFrontmatter / readPatterns >
ApiHandlers ..> DownloadProviders : reads FILE_DOWNLOAD_PROVIDER_CONFIG_DIRS >
Validation  ..> DownloadProviders : reads ALLOWED_*_PROVIDERS allowlists >

' Return-type associations
ApiHandlers ..> Skill             : returns >
ApiHandlers ..> PatternResult     : returns >
ApiHandlers ..> CommandSourceResult : returns >
Utils       ..> PatternResult     : produces >
Utils       ..> FrontmatterResult : produces >

note bottom of Validation
  Security boundary:
  every handler validates
  type / provider / id
  before filesystem access
end note

note right of HttpServer
  Runtime: Bun (bun:serve).
  No class-based OOP —
  all modules export
  plain functions.
end note

@enduml
