@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #333333
}

title Server Input Validation

package "lib" {
    class "download-providers.js" <<module>> {
        +{static} FILE_DOWNLOAD_PROVIDER_CONFIG_DIRS: Record<string, string>
        +{static} FILE_DOWNLOAD_PROVIDERS: string[]
        +{static} BUNDLE_DOWNLOAD_PROVIDERS: string[]
        +{static} DOWNLOAD_PROVIDERS: string[]
    }
}

package "server/lib" {
    class "validation.js" <<module>> {
        +{static} VALID_ID: RegExp
        +{static} ALLOWED_PROVIDERS: string[]
        +{static} ALLOWED_FILE_PROVIDERS: string[]
        +{static} ALLOWED_BUNDLE_PROVIDERS: string[]
        +{static} ALLOWED_TYPES: string[]
        --
        +isValidId(id: any): boolean
        +isAllowedProvider(provider: string): boolean
        +isAllowedFileProvider(provider: string): boolean
        +isAllowedBundleProvider(provider: string): boolean
        +isAllowedType(type: string): boolean
        +sanitizeFilename(filename: string): string
    }
}

note right of "download-providers.js"
  All arrays are <b>Object.freeze()</b>d
  <b>FILE_DOWNLOAD_PROVIDERS</b> (8 entries):
    cursor, claude-code, gemini, codex,
    agents, kiro, opencode, pi
  <b>BUNDLE_DOWNLOAD_PROVIDERS</b> (2 entries):
    universal, universal-prefixed
  <b>DOWNLOAD_PROVIDERS</b> = FILE + BUNDLE
end note

note right of "validation.js"
  <b>VALID_ID</b> = /^[a-zA-Z0-9_-]+$/
  <b>ALLOWED_TYPES</b> = ['skill', 'command']
  <b>sanitizeFilename</b>: strips all chars
    except [a-zA-Z0-9._-]
  Aliases import from download-providers.js:
    ALLOWED_PROVIDERS  → DOWNLOAD_PROVIDERS
    ALLOWED_FILE_PROVIDERS → FILE_DOWNLOAD_PROVIDERS
    ALLOWED_BUNDLE_PROVIDERS → BUNDLE_DOWNLOAD_PROVIDERS
end note

"validation.js" ..> "download-providers.js" : <<imports>>\nBUNDLE_DOWNLOAD_PROVIDERS\nDOWNLOAD_PROVIDERS\nFILE_DOWNLOAD_PROVIDERS

@enduml
