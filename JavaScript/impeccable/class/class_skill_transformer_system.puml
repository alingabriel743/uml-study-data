@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EEF4FF
    BorderColor #3D6DB5
    FontColor #212529
}
skinparam stereotypeCBackgroundColor #D4E6F1
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F0C040
}

title Skill Transformer System\n<size:11><color:#6C757D>Factory pattern for provider-specific skill transformers</color></size>

' ──────────────────────────────────────────────
'  DATA INTERFACES
' ──────────────────────────────────────────────
package "Data Shapes" {

    interface ProviderConfig {
        +provider: string
        +configDir: string
        +displayName: string
        +frontmatterFields?: string[]
        +bodyTransform?: (body, skill) => string
        +placeholderProvider?: string
    }

    interface FieldSpec {
        +sourceKey: string
        +yamlKey: string
        +condition?: (skill) => boolean
        +value?: (skill) => any
    }

    interface TransformOptions {
        +prefix?: string
        +outputSuffix?: string
        +skillsVersion?: string
    }

    interface Skill {
        +name: string
        +description: string
        +body: string
        +userInvocable?: boolean
        +argumentHint?: string
        +license?: string
        +compatibility?: any
        +metadata?: any
        +allowedTools?: any
        +references?: Reference[]
        +scripts?: Script[]
    }
}

' ──────────────────────────────────────────────
'  providers.js — Provider Registry
' ──────────────────────────────────────────────
package "transformers/providers.js" {

    class PROVIDERS <<registry>> {
        +cursor: ProviderConfig
        +"claude-code": ProviderConfig
        +gemini: ProviderConfig
        +codex: ProviderConfig
        +agents: ProviderConfig
        +kiro: ProviderConfig
        +opencode: ProviderConfig
        +pi: ProviderConfig
        +trae: ProviderConfig
        +"trae-cn": ProviderConfig
        +"rovo-dev": ProviderConfig
    }
}

' ──────────────────────────────────────────────
'  factory.js — Factory + Field Registry
' ──────────────────────────────────────────────
package "transformers/factory.js" {

    class FIELD_SPECS <<registry>> {
        +"user-invocable": FieldSpec
        +"argument-hint": FieldSpec
        +license: FieldSpec
        +compatibility: FieldSpec
        +metadata: FieldSpec
        +"allowed-tools": FieldSpec
    }

    class createTransformer <<factory>> {
        +createTransformer(config: ProviderConfig): TransformFn
        --
        -resolves placeholderKey
        -filters activeFields via frontmatterFields
        .. returned transform(skills, distDir, options) ..
        -cleanDir / ensureDir output dirs
        -collect allSkillNames & commandNames
        -buildFrontmatter from activeFields + FIELD_SPECS
        -generateYamlFrontmatter(frontmatterObj)
        -replacePlaceholders(body, placeholderKey)
        -replace {{scripts_path}} token
        -prefixSkillReferences() if prefix set
        -bodyTransform?(skillBody, skill)
        -writeFile(SKILL.md)
        -writeFile(reference/*.md)
        -writeFile(scripts/*)
    }
}

' ──────────────────────────────────────────────
'  shared.js — Legacy Shared Function
' ──────────────────────────────────────────────
package "transformers/shared.js" {

    class transformProvider <<function>> {
        +transformProvider(config, skills, distDir, options): void
        --
        {field} «legacy — NOT used by index.js»
        -buildFrontmatter: callback style
        -transformBody?: callback style
    }
}

note right of transformProvider
  Alternative/legacy design.
  Uses <b>buildFrontmatter</b> callback
  instead of declarative FIELD_SPECS.
  Superseded by <b>createTransformer</b>.
end note

' ──────────────────────────────────────────────
'  index.js — Transformer Module (9 instances)
' ──────────────────────────────────────────────
package "transformers/index.js" {

    class TransformerModule <<module>> {
        +transformCursor: TransformFn
        +transformClaudeCode: TransformFn
        +transformGemini: TransformFn
        +transformCodex: TransformFn
        +transformAgents: TransformFn
        +transformKiro: TransformFn
        +transformOpenCode: TransformFn
        +transformPi: TransformFn
        +transformRovoDev: TransformFn
        --
        +createTransformer (re-exported)
        +PROVIDERS (re-exported)
    }
}

note bottom of TransformerModule
  Each transformer = <b>createTransformer(PROVIDERS.x)</b>
  trae / trae-cn defined in PROVIDERS
  but NOT exported as named transforms.
end note

' ──────────────────────────────────────────────
'  utils.js — Shared Utilities
' ──────────────────────────────────────────────
package "lib/utils.js" {

    class UtilFunctions <<utilities>> {
        +cleanDir(dir: string): void
        +ensureDir(dir: string): void
        +writeFile(path: string, content: string): void
        +generateYamlFrontmatter(obj: object): string
        +replacePlaceholders(body, provider, cmds, skills): string
        +prefixSkillReferences(body, prefix, skills, cmdPrefix): string
        +PROVIDER_PLACEHOLDERS: Record<string, PlaceholderConfig>
    }
}

' ──────────────────────────────────────────────
'  RELATIONSHIPS
' ──────────────────────────────────────────────

' Registry compositions
PROVIDERS "1" *-- "1..*" ProviderConfig : contains
FIELD_SPECS "1" *-- "1..*" FieldSpec : contains

' ProviderConfig references FieldSpec keys via frontmatterFields
ProviderConfig ..> FieldSpec : references keys of

' Factory function relationships
createTransformer ..> ProviderConfig : consumes
createTransformer ..> FIELD_SPECS : filters via frontmatterFields
createTransformer ..> TransformOptions : accepts
createTransformer ..> Skill : transforms

' index.js instantiation
TransformerModule ..> createTransformer : instantiates (×9)
TransformerModule ..> PROVIDERS : configured from

' Utility dependencies
createTransformer ..> UtilFunctions : uses
transformProvider ..> UtilFunctions : uses

@enduml
