@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Test Suite

' ─────────────────────────────────────────────
' Data Shapes
' ─────────────────────────────────────────────
package "Data Shapes" {

    class Skill <<data>> {
        +name: string
        +description: string
        +body: string
        +userInvocable: boolean
        +argumentHint: string
        +license: string
        +compatibility: string
        +metadata: string
        +allowedTools: string
        +references: Reference[]
    }

    class Reference <<data>> {
        +name: string
        +content: string
        +filePath: string
    }

    class Finding <<data>> {
        +id: string
    }

    class Pattern <<data>> {
        +name: string
        +items: string[]
    }

    class TransformerConfig <<data>> {
        +provider: string
        +configDir: string
        +displayName: string
        +frontmatterFields: string[]
        +bodyTransform: Function
    }

    Skill *-- Reference : contains
}

' ─────────────────────────────────────────────
' src — Anti-pattern Detection
' ─────────────────────────────────────────────
package "src (Anti-pattern Detection)" {

    class DetectAntipatterns <<module>> {
        +ANTIPATTERNS: Record[]
        +FRAMEWORK_CONFIGS: Record[]
        +SCANNABLE_EXTENSIONS: string[]
        --
        +checkElementBorders(tag, style): Finding[]
        +checkElementMotion(tag, style): Finding[]
        +checkElementGlow(tag, style): Finding[]
        +isNeutralColor(color): boolean
        +isFullPage(el): boolean
        +detectText(html, filename): Finding[]
        +extractStyleBlocks(html): string[]
        +extractCSSinJS(content): string[]
        +walkDir(dir, exts): string[]
        +buildImportGraph(files): Record
        +resolveImport(from, importPath): string
        +detectFrameworkConfig(dir): string
        +isPortListening(port): Promise<boolean>
    }
}

' ─────────────────────────────────────────────
' scripts — Build Pipeline
' ─────────────────────────────────────────────
package "scripts (Build Pipeline)" {

    class Utils <<module>> {
        +parseFrontmatter(content): object
        +generateYamlFrontmatter(data): string
        +readFilesRecursive(dir): string[]
        +readSourceFiles(rootDir): object
        +readPatterns(rootDir): object
        +ensureDir(dirPath): void
        +cleanDir(dirPath): void
        +writeFile(filePath, content): void
        +replacePlaceholders(text, provider, skillNames): string
        +prefixSkillReferences(content, prefix, skillNames): string
    }

    class TransformerFactory <<module>> {
        +createTransformer(config: TransformerConfig): TransformFn
    }

    class BuildOrchestrator <<module>> {
        +transformCursor(skills, distDir, patterns): void
        +transformClaudeCode(skills, distDir, patterns): void
        +transformGemini(skills, distDir, patterns): void
        +transformCodex(skills, distDir, patterns): void
        +transformAgents(skills, distDir, patterns): void
        +transformKiro(skills, distDir, patterns): void
    }
}

' ─────────────────────────────────────────────
' bin — CLI Entrypoint
' ─────────────────────────────────────────────
package "bin (CLI)" {

    class SkillsCLI <<CLI>> {
        +install(args): void
        +update(args): void
        +detectPrefix(dir): string
        +undoPrefix(dir): void
        +applyPrefix(dir, prefix): void
    }
}

' ─────────────────────────────────────────────
' server — Download Validation
' ─────────────────────────────────────────────
package "server (Download Validation)" {

    class Validation <<module>> {
        +ALLOWED_BUNDLE_PROVIDERS: string[]
        +ALLOWED_FILE_PROVIDERS: string[]
        --
        +isAllowedBundleProvider(provider): boolean
        +isAllowedFileProvider(provider): boolean
        +isAllowedProvider(provider): boolean
    }

    class ApiHandlers <<module>> {
        +getFilePath(type, provider, name): string
        +handleFileDownload(type, provider, name): Promise<Response>
    }

    ApiHandlers ..> Validation : delegates to
}

' ─────────────────────────────────────────────
' tests — Test Files
' ─────────────────────────────────────────────
package "tests" {

    class AntiPatternTest <<test>> {
        +checkElementBorders tests
        +isNeutralColor tests
        +detectText tests
        +extractStyleBlocks tests
        +extractCSSinJS tests
        +walkDir tests
        +buildImportGraph / resolveImport tests
        +detectFrameworkConfig tests
        +isPortListening tests
        +CLI spawn tests
    }

    class SkillsCLITest <<test>> {
        -run(args, opts): string
        -createFakeSkills(root, skills, providers): void
        --
        +install already-installed detection tests
        +prefix rename tests
        +update direct download fallback tests
        +prefix round-trip tests
        +full e2e install tests
    }

    class BuildTest <<test>> {
        +build orchestration tests
        +integration full build output tests
        +verify per-provider transformations tests
    }

    class FactoryTest <<test>> {
        +dir structure creation tests
        +frontmatter allowlist tests
        +user-invocable / argument-hint tests
        +bodyTransform application tests
        +prefix + outputSuffix option tests
        +reference file copy tests
        +placeholder replacement tests
        +cleanDir before write tests
    }

    class UtilsTest <<test>> {
        +parseFrontmatter tests
        +generateYamlFrontmatter tests
        +ensureDir tests
        +cleanDir tests
        +writeFile tests
        +readFilesRecursive tests
        +readSourceFiles tests
        +readPatterns tests
        +replacePlaceholders tests
        +prefixSkillReferences tests
    }

    class DownloadValidationTest <<test>> {
        +bundle vs file provider tests
        +opencode / pi file path tests
        +HTTP 400 on bundle-only provider tests
    }
}

' ─────────────────────────────────────────────
' Test -> Module Under Test relationships
' ─────────────────────────────────────────────
AntiPatternTest    ..>  DetectAntipatterns   : tests
SkillsCLITest      ..>  SkillsCLI            : tests
BuildTest          ..>  BuildOrchestrator    : tests
BuildTest          ..>  Utils                : uses
FactoryTest        ..>  TransformerFactory   : tests
FactoryTest        ..>  Utils                : uses
UtilsTest          ..>  Utils                : tests
DownloadValidationTest ..> Validation        : tests
DownloadValidationTest ..> ApiHandlers       : tests

' ─────────────────────────────────────────────
' Module dependencies
' ─────────────────────────────────────────────
BuildOrchestrator  ..>  Utils               : readSourceFiles / readPatterns
BuildOrchestrator  ..>  TransformerFactory  : consumes transformers from
TransformerFactory ..>  Utils               : parseFrontmatter / generateYamlFrontmatter / replacePlaceholders
TransformerFactory ..>  TransformerConfig   : configured by

' ─────────────────────────────────────────────
' Data shape producers
' ─────────────────────────────────────────────
Utils              ..>  Skill               : produces
Utils              ..>  Pattern             : produces
DetectAntipatterns ..>  Finding             : produces

@enduml
