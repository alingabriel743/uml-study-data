{
  "scope": "browser_extension_ui",
  "title": "Browser Extension UI (DevTools & Popup)",
  "diagram_type": "class",
  "modules": [
    {
      "name": "DevToolsPage",
      "file": "extension/devtools/devtools.js",
      "type": "module_singleton",
      "state": ["lifecyclePort: Port|null", "firstConnect: boolean"],
      "methods": [
        "connectLifecycle(): void",
        "heartbeat interval (20s): ping → serviceWorker"
      ],
      "responsibilities": "Creates DevTools panel and Elements sidebar pane; manages lifecycle port to service worker; triggers auto-scan on first connect if autoScan==='devtools'",
      "messages_sent": ["{ action: 'scan' }", "{ action: 'ping' }"],
      "chrome_apis": ["chrome.devtools.panels.create()", "chrome.devtools.panels.elements.createSidebarPane()", "chrome.runtime.connect()", "chrome.storage.sync.get()"]
    },
    {
      "name": "Panel",
      "file": "extension/devtools/panel.js",
      "type": "module_singleton",
      "state": [
        "port: Port|null",
        "overlaysVisible: boolean",
        "allAntipatterns: array",
        "disabledRules: string[]",
        "currentFindings: FindingItem[]",
        "currentHoverSelector: string|null"
      ],
      "methods": [
        "getPort(): Port",
        "postToPort(msg): void",
        "initSettings(): async void",
        "initAutoScanControl(currentMode): void",
        "initLineLengthControl(currentMode): void",
        "initSpotlightBlurToggle(currentValue): void",
        "renderSettings(): void",
        "toggleRule(ruleId, enabled): async void",
        "handlePortMessage(msg): void",
        "renderFindings(findings: FindingItem[]): void",
        "inspectElement(selector: string): void",
        "updateToggleButton(): void",
        "showScanning(): void",
        "setHoveredItem(selector: string|null): void",
        "getInspectedUrl(): Promise<string>",
        "formatFindingsForCopy(findings): Promise<string>",
        "formatSingleFindingForCopy(item, finding): Promise<string>",
        "copyToClipboard(text, btn): async void",
        "fixSkillFor(type: string): string",
        "uniqueSkillsForFindings(findings): string[]",
        "escapeHtml(str: string): string"
      ],
      "port_name": "impeccable-panel-{tabId}",
      "messages_sent": ["scan", "toggle-overlays", "highlight { selector }", "unhighlight", "ping"],
      "messages_received": ["findings", "state", "overlays-toggled", "navigated", "page-pointer-active"],
      "storage_keys": ["disabledRules", "lineLengthMode", "spotlightBlur", "autoScan"],
      "chrome_apis": ["chrome.runtime.connect()", "chrome.storage.sync.get/set()", "chrome.devtools.inspectedWindow.eval()", "chrome.runtime.sendMessage()"],
      "constants": "FIX_SKILLS map: 28 rule-id → skill-name entries"
    },
    {
      "name": "Sidebar",
      "file": "extension/devtools/sidebar.js",
      "type": "module_singleton",
      "state": ["port: Port|null", "currentFindings: FindingItem[]"],
      "methods": [
        "getPort(): Port",
        "refreshForCurrentSelection(): void",
        "render(items: FindingItem[]): void",
        "renderEmpty(text: string): void",
        "renderNoFindings(): void",
        "escapeHtml(str: string): string"
      ],
      "port_name": "impeccable-sidebar-{tabId}",
      "messages_received": ["findings", "state"],
      "event_listeners": ["chrome.devtools.panels.elements.onSelectionChanged → refreshForCurrentSelection()"],
      "chrome_apis": ["chrome.runtime.connect()", "chrome.devtools.inspectedWindow.eval()"],
      "behavior": "On selection change, evals JS in inspected window to match $0 against known selectors; renders findings for matched element"
    },
    {
      "name": "Popup",
      "file": "extension/popup/popup.js",
      "type": "module_singleton",
      "state": ["overlaysVisible: boolean"],
      "methods": [
        "getActiveTabId(): Promise<number>",
        "updateFromState(state): void",
        "loadState(): async void"
      ],
      "messages_sent": ["{ action: 'get-state', tabId }", "{ action: 'scan', tabId }", "{ action: 'toggle-overlays', tabId }"],
      "messages_received": ["findings-updated", "overlays-toggled-broadcast"],
      "chrome_apis": ["chrome.tabs.query()", "chrome.runtime.sendMessage()", "chrome.runtime.onMessage.addListener()"],
      "note": "Uses one-shot sendMessage (not persistent port). No direct port to service worker."
    }
  ],
  "shared_data_types": {
    "FindingItem": {
      "selector": "string",
      "tagName": "string",
      "isPageLevel": "boolean",
      "isHidden": "boolean",
      "findings": "Finding[]"
    },
    "Finding": {
      "type": "string (rule id)",
      "name": "string",
      "category": "'slop' | 'quality'",
      "detail": "string",
      "description": "string"
    },
    "State": {
      "findings": "FindingItem[]",
      "overlaysVisible": "boolean"
    }
  },
  "key_relationships": [
    "DevToolsPage creates Panel (chrome.devtools.panels.create → panel.html/panel.js)",
    "DevToolsPage creates Sidebar (chrome.devtools.panels.elements.createSidebarPane → sidebar.html/sidebar.js)",
    "Panel depends_on ServiceWorker via persistent port (impeccable-panel-{tabId})",
    "Sidebar depends_on ServiceWorker via persistent port (impeccable-sidebar-{tabId})",
    "DevToolsPage depends_on ServiceWorker via lifecycle port (impeccable-devtools-{tabId})",
    "Popup depends_on ServiceWorker via one-shot sendMessage",
    "Panel reads/writes chrome.storage.sync (disabledRules, lineLengthMode, spotlightBlur, autoScan)",
    "Panel uses chrome.devtools.inspectedWindow (inspect element by selector)",
    "Sidebar uses chrome.devtools.inspectedWindow (match $0 selection to selectors)",
    "Panel sends 'disabled-rules-changed' runtime message to ServiceWorker on rule/setting change"
  ],
  "shared_patterns": [
    "Auto-reconnecting port: Panel, Sidebar, DevToolsPage all implement getPort() with onDisconnect → port=null pattern",
    "Heartbeat (setInterval 20s ping): Panel and DevToolsPage keep MV3 service worker alive",
    "escapeHtml(str): identical utility in both Panel and Sidebar",
    "Theme detection: Panel and Sidebar both apply 'theme-dark' class based on chrome.devtools.panels.themeName"
  ],
  "important_notes": "All modules are MV3 extension pages — no ES class syntax; modules act as singletons. ServiceWorker may be terminated after ~30s inactivity; all DevTools modules reconnect lazily. Popup has no persistent connection — uses sendMessage for all interactions. Panel is the primary UI: renderFindings() groups by category (slop/quality), then by rule type, builds full DOM tree. Sidebar is a lightweight read-only view showing findings for the DevTools-selected element ($0).",
  "source_files_analyzed": [
    "extension/devtools/devtools.js",
    "extension/devtools/panel.js",
    "extension/devtools/sidebar.js",
    "extension/popup/popup.js"
  ]
}
