{
  "scope": "build_pipeline",
  "title": "Build Pipeline Orchestration",
  "diagram_type": "class",
  "key_modules": [
    "scripts/build.js",
    "scripts/build-sub-pages.js",
    "scripts/lib/sub-pages-data.js",
    "scripts/lib/utils.js",
    "scripts/lib/transformers/index.js",
    "scripts/lib/zip.js",
    "scripts/lib/render-markdown.js",
    "scripts/lib/render-page.js",
    "content/site/anti-patterns-catalog.js"
  ],
  "classes": [
    {
      "name": "BuildOrchestrator",
      "file": "scripts/build.js",
      "type": "module",
      "stereotype": "<<entrypoint>>",
      "methods": [
        "build(): Promise<void>  [main async entry point]",
        "generateCounts(rootDir, skills[], buildDir): number",
        "validateAntipatternRules(rootDir): number",
        "validateNoEmDashes(rootDir): number",
        "validateSiteHeader(rootDir): number",
        "buildStaticSite(extraEntrypoints[]): Promise<BunBuildResult>",
        "assembleUniversal(distDir, suffix?): void",
        "generateApiData(buildDir, skills[], patterns): void",
        "copyDistToBuild(distDir, buildDir): void",
        "generateCFConfig(buildDir): void",
        "copyDirSync(src, dest): void"
      ],
      "constants": [
        "ROOT_DIR: string",
        "DIST_DIR: string"
      ]
    },
    {
      "name": "SubPageGenerator",
      "file": "scripts/build-sub-pages.js",
      "type": "module",
      "stereotype": "<<service>>",
      "methods": [
        "generateSubPages(rootDir): Promise<{ files: string[] }>",
        "renderSkillDetail(skill, knownSkillIds): string",
        "renderSkillDemo(skill): string",
        "renderDocsSidebar(skillsByCategory, tutorials, current?): string",
        "renderSkillsOverviewMain(skillsByCategory): string",
        "renderAntiPatternsSidebar(grouped): string",
        "renderAntiPatternsMain(grouped, totalRules): string",
        "renderRuleCard(rule): string",
        "renderTutorialsIndexMain(tutorials): string",
        "renderTutorialDetail(tutorial, knownSkillIds): string",
        "renderVisualModeMain(): string",
        "wrapInDocsLayout(sidebarHtml, mainHtml): string",
        "groupRulesBySection(rules): { order, bySection }",
        "escapeHtml(str): string",
        "escapeAttr(str): string"
      ]
    },
    {
      "name": "SubPageDataBuilder",
      "file": "scripts/lib/sub-pages-data.js",
      "type": "module",
      "stereotype": "<<data>>",
      "methods": [
        "buildSubPageData(rootDir): Promise<SubPageDataModel>",
        "readAntipatternRules(rootDir): AntipatternRule[]",
        "readEditorialWrapper(contentDir, kind, slug): { frontmatter, body } | null",
        "loadCommandDemos(rootDir): Promise<Record<string, Demo>>"
      ],
      "constants": [
        "EXCLUDED_SKILLS: Set<string>",
        "SKILL_CATEGORIES: Record<string, string>",
        "CATEGORY_ORDER: string[]",
        "CATEGORY_LABELS: Record<string, string>",
        "CATEGORY_DESCRIPTIONS: Record<string, string>"
      ],
      "re_exports": [
        "LAYER_LABELS",
        "LAYER_DESCRIPTIONS",
        "GALLERY_ITEMS"
      ]
    },
    {
      "name": "Utils",
      "file": "scripts/lib/utils.js",
      "type": "module",
      "stereotype": "<<utility>>",
      "methods": [
        "readSourceFiles(rootDir): { skills: Skill[] }",
        "readPatterns(rootDir): { patterns, antipatterns }",
        "parseFrontmatter(content): { frontmatter, body }"
      ]
    },
    {
      "name": "TransformerFactory",
      "file": "scripts/lib/transformers/index.js",
      "type": "module",
      "stereotype": "<<factory>>",
      "methods": [
        "createTransformer(providerConfig): TransformFn",
        "TransformFn(skills[], distDir, options): void  [options: { prefix?, outputSuffix?, skillsVersion }]"
      ],
      "constants": [
        "PROVIDERS: Record<string, ProviderConfig>  [cursor, claude, gemini, codex, agents, kiro, opencode, pi, trae-cn, trae]"
      ]
    },
    {
      "name": "ZipBuilder",
      "file": "scripts/lib/zip.js",
      "type": "module",
      "stereotype": "<<utility>>",
      "methods": [
        "createAllZips(distDir): Promise<void>"
      ]
    },
    {
      "name": "MarkdownRenderer",
      "file": "scripts/lib/render-markdown.js",
      "type": "module",
      "stereotype": "<<renderer>>",
      "methods": [
        "renderMarkdown(body, options): string",
        "slugify(text): string"
      ]
    },
    {
      "name": "PageRenderer",
      "file": "scripts/lib/render-page.js",
      "type": "module",
      "stereotype": "<<renderer>>",
      "methods": [
        "renderPage({ title, description, bodyHtml, activeNav, canonicalPath, bodyClass }): string"
      ]
    },
    {
      "name": "AntiPatternsCatalog",
      "file": "content/site/anti-patterns-catalog.js",
      "type": "module",
      "stereotype": "<<data>>",
      "constants": [
        "DETECTION_LAYERS: Record<string, string>",
        "VISUAL_EXAMPLES: Record<string, string>",
        "LLM_ONLY_RULES: Rule[]",
        "GALLERY_ITEMS: GalleryItem[]",
        "LAYER_LABELS: Record<string, string>",
        "LAYER_DESCRIPTIONS: Record<string, string>"
      ]
    }
  ],
  "key_data_types": [
    "Skill: { filePath, name, description, userInvocable, argumentHint, body, references }",
    "ProviderConfig: { provider, configDir }",
    "SubPageDataModel: { skills[], skillsByCategory, knownSkillIds, rules[], tutorials[] }",
    "AntipatternRule: { id, name, description, category, skillSection?, skillGuideline?, layer, visual? }",
    "Tutorial: { slug, title, description, tagline, order, body }",
    "Demo: { id, caption, before, after }"
  ],
  "relationships": [
    "BuildOrchestrator imports SubPageGenerator (generateSubPages)",
    "BuildOrchestrator imports Utils (readSourceFiles, readPatterns)",
    "BuildOrchestrator imports TransformerFactory (createTransformer, PROVIDERS)",
    "BuildOrchestrator imports ZipBuilder (createAllZips)",
    "SubPageGenerator imports SubPageDataBuilder (buildSubPageData, CATEGORY_ORDER, CATEGORY_LABELS, CATEGORY_DESCRIPTIONS, LAYER_LABELS, LAYER_DESCRIPTIONS, GALLERY_ITEMS)",
    "SubPageGenerator imports MarkdownRenderer (renderMarkdown, slugify)",
    "SubPageGenerator imports PageRenderer (renderPage)",
    "SubPageDataBuilder imports Utils (readSourceFiles, parseFrontmatter)",
    "SubPageDataBuilder imports AntiPatternsCatalog (DETECTION_LAYERS, VISUAL_EXAMPLES, LLM_ONLY_RULES, GALLERY_ITEMS, LAYER_LABELS, LAYER_DESCRIPTIONS)",
    "BuildOrchestrator uses Bun.build (external) for static site bundling"
  ],
  "build_flow": [
    "1. build() calls generateSubPages(ROOT_DIR) → returns subPageFiles[]",
    "2. build() calls buildStaticSite(subPageFiles) via Bun.build",
    "3. build() calls readSourceFiles(ROOT_DIR) → skills[]",
    "4. build() calls readPatterns(ROOT_DIR) → patterns",
    "5. For each PROVIDER: createTransformer(config)(skills, DIST_DIR, opts) [x2: normal + prefixed]",
    "6. build() calls assembleUniversal(DIST_DIR) and assembleUniversal(DIST_DIR, '-prefixed')",
    "7. build() calls createAllZips(DIST_DIR)",
    "8. build() calls generateApiData, copyDistToBuild, generateCFConfig",
    "9. build() calls generateCounts, validateAntipatternRules, validateSiteHeader, validateNoEmDashes",
    "10. process.exit(1) if any validation errors"
  ],
  "sub_page_flow": [
    "generateSubPages(rootDir) calls buildSubPageData(rootDir)",
    "buildSubPageData calls readSourceFiles → filters/maps skills + loadCommandDemos + readEditorialWrapper",
    "buildSubPageData calls readAntipatternRules → enriches with DETECTION_LAYERS + VISUAL_EXAMPLES + LLM_ONLY_RULES",
    "buildSubPageData reads tutorials from content/site/tutorials/*.md via parseFrontmatter",
    "generateSubPages calls renderDocsSidebar/renderSkillsOverviewMain/renderSkillDetail/renderAntiPatternsMain/renderTutorialsIndexMain/renderVisualModeMain",
    "Each render function pipes output through renderPage() → writes HTML to public/skills|anti-patterns|tutorials|visual-mode/"
  ],
  "important_notes": "Build uses Bun runtime (Bun.build for HTML bundling). PROVIDERS constant drives multi-provider transform loop (cursor, claude, gemini, codex, agents + variants). Both normal and '-prefixed' variants generated for each provider. Sub-pages are pre-generated to public/ then picked up by Bun's HTML loader. generateCounts reads src/detect-antipatterns.mjs via regex to extract rule IDs — no import needed. Build fails hard (process.exit(1)) on any validation error.",
  "source_files_analyzed": [
    "scripts/build.js",
    "scripts/build-sub-pages.js",
    "scripts/lib/sub-pages-data.js"
  ]
}
