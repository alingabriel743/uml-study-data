{
  "scope": "frontend_app_and_components",
  "title": "Frontend App & UI Components",
  "diagram_type": "class",
  "architecture_note": "All modules are functional (no ES classes). Each module is modelled as a class with its exported and internal methods as operations, and module-level state as attributes.",

  "modules": [
    {
      "name": "App",
      "file": "public/app.js",
      "type": "module / bootstrapper",
      "state": ["allCommands: Array (module-level)"],
      "exported_methods": [],
      "internal_methods": [
        "init(): void",
        "loadContent(): Promise<void>",
        "showLoadError(error): void",
        "initGalleryStack(): void",
        "renderPatternsWithTabs(patterns, antipatterns): void",
        "escapeHtml(value: string): string"
      ],
      "entry_point": "DOMContentLoaded → init()"
    },
    {
      "name": "GlassTerminal",
      "file": "public/js/components/glass-terminal.js",
      "type": "component module",
      "state": [
        "magazineState: { currentIndex, commands[], isTransitioning, keyboardBound, intersectionObserver }",
        "currentSplitInstance: SplitCompareInstance | null",
        "currentCommandId: string | null",
        "sourceCache: { [cmdId]: string }"
      ],
      "exported_methods": [
        "initGlassTerminal(): void",
        "renderTerminalLayout(commands: Command[]): void"
      ],
      "internal_methods": [
        "isMobile(): boolean",
        "renderDesktopLayout(container: Element, commands: Command[]): void",
        "renderMobileLayout(container: Element, commands: Command[]): void",
        "renderSpread(cmd: Command, index: number, isActive: boolean): string",
        "initSpreadDemo(index: number): void",
        "goToSpread(newIndex: number, commands: Command[]): void",
        "setupFisheyeList(commands: Command[], headerIndices: object[]): void",
        "setupMagazineKeyboard(commands: Command[]): void",
        "setupMagazineIntersection(container: Element): void",
        "setupMobileInteractions(commands: Command[]): void",
        "setupStackTabs(): void",
        "fetchCommandSource(cmdId: string): Promise<string|null>",
        "updateSourceContent(cmdId: string): Promise<void>",
        "truncateDescription(text: string, maxLen?: number): string",
        "escapeHtml(text: string): string"
      ]
    },
    {
      "name": "SectionNav",
      "file": "public/js/components/section-nav.js",
      "type": "component module",
      "state": ["ticking: boolean (closure)"],
      "exported_methods": [
        "initSectionNav(): void"
      ],
      "internal_methods": [
        "updateNav(): void"
      ],
      "dom_targets": ["#section-nav", ".section-nav-item[data-section]", "#hero", ".site-footer"]
