  ],

  "external_dependencies": [
    { "name": "SplitCompare", "file": "public/js/effects/split-compare.js", "exports": ["initSplitCompare(container, options)"] },
    { "name": "DemoRenderer", "file": "public/js/demo-renderer.js", "exports": ["renderCommandDemo(cmdId)", "initCommandDemo(cmdId, demoArea)", "renderSkillDemo(skillId)", "setupDemoTabs()"] },
    { "name": "DemoToggles", "file": "public/js/demo-toggles.js", "exports": ["setupDemoToggles()"] },
    { "name": "Data", "file": "public/js/data.js", "exports": ["commandCategories", "commandRelationships", "betaCommands", "commandProcessSteps", "skillFocusAreas", "dimensionGuidelineCounts", "readySkills"] },
    { "name": "FoundationAnimations", "file": "public/js/components/foundation-animations.js", "exports": ["foundationAnimations"] },
    { "name": "FrameworkViz", "file": "public/js/components/framework-viz.js", "exports": ["initFrameworkViz()"] },
    { "name": "ScrollUtils", "file": "public/js/utils/scroll.js", "exports": ["initAnchorScroll()", "initHashTracking()"] },
    { "name": "RevealUtils", "file": "public/js/utils/reveal.js", "exports": ["initScrollReveal()"] }
  ],

  "key_relationships": [
    "App depends_on GlassTerminal (calls initGlassTerminal, renderTerminalLayout)",
    "App depends_on SectionNav (calls initSectionNav)",
    "App depends_on FoundationGrid (calls initFoundationGrid)",
    "App depends_on Lens (calls initLensEffect)",
    "App depends_on FrameworkViz (calls initFrameworkViz)",
    "App depends_on ScrollUtils (calls initAnchorScroll, initHashTracking)",
    "App depends_on RevealUtils (calls initScrollReveal)",
    "GlassTerminal depends_on SplitCompare (calls initSplitCompare for split demo panels)",
    "GlassTerminal depends_on DemoRenderer (calls renderCommandDemo, initCommandDemo)",
    "GlassTerminal depends_on Data (reads commandCategories, commandRelationships, betaCommands)",
    "Lens depends_on SplitCompare (delegates fully to initSplitCompare)",
    "FoundationGrid depends_on Data (reads skillFocusAreas['impeccable'], dimensionGuidelineCounts)",
    "FoundationGrid depends_on FoundationAnimations (reads foundationAnimations map)",
    "ArtGallery depends_on Data (reads readySkills, skillFocusAreas)",
    "ArtGallery depends_on DemoRenderer (calls renderSkillDemo, setupDemoTabs)",
    "ArtGallery depends_on DemoToggles (calls setupDemoToggles)"
  ],

  "init_call_chain": [
    "DOMContentLoaded → App.init()",
    "init() → initAnchorScroll()",
    "init() → initHashTracking()",
    "init() → initLensEffect() → SplitCompare.initSplitCompare(#lens-comparison, {defaultPosition:50})",
    "init() → initScrollReveal()",
    "init() → initGlassTerminal()",
    "init() → initFrameworkViz()",
    "init() → initFoundationGrid() → reads Data.skillFocusAreas + FoundationAnimations → renders .foundation-grid",
    "init() → initSectionNav() → attaches scroll listener → updateNav() on rAF",
    "init() → loadContent() → fetch /api/commands + /api/patterns → renderTerminalLayout(commands) + initGalleryStack() + renderPatternsWithTabs()",
    "renderTerminalLayout(commands) → isMobile() ? renderMobileLayout() : renderDesktopLayout()",
    "renderDesktopLayout() → renderSpread() × N → initSpreadDemo() → renderCommandDemo() + initSplitCompare() + initCommandDemo()",
    "renderDesktopLayout() → setupFisheyeList() → goToSpread() on scroll/click",
    "renderDesktopLayout() → setupMagazineKeyboard() + setupMagazineIntersection()"
  ],

  "important_notes": "No ES classes used — all modules export plain functions. GlassTerminal is the most complex component with ~15 internal functions, mutable module-level state (magazineState, currentSplitInstance), responsive breakpoint switching (MOBILE_BREAKPOINT=900), fisheye scroll physics (BASE_H=36, MIN_SCALE=0.35, RADIUS=5, STEP=30), and lazy demo initialisation via IntersectionObserver. ArtGallery exports renderGallery but app.js does NOT import it directly — it is called from loadContent flow elsewhere. PeriodicTable is referenced in scope description but no corresponding file was found in public/js/.",
  "source_files_analyzed": [
    "public/app.js",
    "public/js/components/glass-terminal.js",
    "public/js/components/section-nav.js",
    "public/js/components/foundation-grid.js",
    "public/js/components/art-gallery.js",
    "public/js/components/lens.js"
  ]
}
