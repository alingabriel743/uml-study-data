        "label": "string",
        "caption": "string",
        "hasToggle": "boolean (default true)",
        "before": "string (HTML)",
        "after": "string (HTML) | null",
        "beforeClass": "string [optional — CSS class swap mode]",
        "afterClass": "string [optional — CSS class swap mode]",
        "onToggle": "(viewport: Element, isAfter: boolean) => void  [optional — motion-design]",
        "onAfterRender": "() => void  [optional — interaction-design/feedback]"
      }
    },
    {
      "name": "DataModule",
      "file": "public/js/data.js",
