  "classes": [
    {
      "name": "DemoRenderer",
      "file": "public/js/demo-renderer.js",
      "type": "module (exported functions)",
      "exported_functions": [
        "renderCommandDemo(commandId: string): string",
        "renderSkillDemo(skillId: string): string",
        "initCommandDemo(commandId: string, container: Element): void",
        "setupDemoTabs(): void"
      ],
      "private_functions": [
        "renderSkillTabDemo(skillId: string, tab: SkillTabDemo): string"
      ],
      "behavior_notes": [
        "renderCommandDemo: returns split-screen HTML or fallback guide HTML for 'impeccable'/'shape'",
        "renderSkillDemo: renders tabbed container (tabs shown only if tabs.length > 1)",
        "initCommandDemo: calls demo.init(demoArea) if the CommandDemo has an init function",
        "setupDemoTabs: attaches click listeners to .demo-tab buttons for panel switching"
      ]
    },
    {
      "name": "DemoToggles",
      "file": "public/js/demo-toggles.js",
      "type": "module (exported functions)",
      "exported_functions": [
        "setupDemoToggles(): void",
        "setupCommandDemoToggles(allCommands: Command[], selectCommand: (c: Command) => void): void"
      ],
      "private_functions": [
        "handleDemoToggle(demoId: string, isAfter: boolean): void",
        "handleCommandDemoToggle(demoId: string, isAfter: boolean): void",
        "setupInteractiveButtons(): void"
      ],
      "behavior_notes": [
        "setupDemoToggles: attaches click on .demo-toggle-switch; calls handleDemoToggle + setupInteractiveButtons",
        "setupCommandDemoToggles: attaches click on .command-demo-area .demo-toggle-switch; also wires .relationship-tag clicks to selectCommand callback",
        "handleDemoToggle: parses demoId into skillId + tabId; dispatches to tab.onToggle, CSS class swap, or innerHTML swap",
        "handleCommandDemoToggle: strips 'command-' prefix; dispatches to demo.onToggle or innerHTML swap",
        "setupInteractiveButtons: toggles .liked on .int-fb-active[data-action='like'] buttons"
      ]
    },
    {
      "name": "DemosIndex",
      "file": "public/js/demos/index.js",
      "type": "barrel module",
      "re_exports": [
        "commandDemos, getCommandDemo — from ./commands/index.js",
        "getSkillDemo, skillDemos — from ./skills/index.js"
      ]
    },
    {
      "name": "CommandDemoRegistry",
      "file": "public/js/demos/commands/index.js",
      "type": "module (registry + factory)",
      "exports": [
        "commandDemos: Record<string, CommandDemo>",
        "getCommandDemo(commandId: string): CommandDemo | null"
      ],
      "registered_commands": ["animate", "bolder", "audit", "critique", "polish", "optimize", "harden", "clarify", "quieter", "distill", "colorize", "delight", "adapt", "typeset", "layout", "overdrive"],
      "behavior_notes": "Returns commandDemos[commandId] || null. Commands not in map (shape, impeccable, etc.) return null — handled by DemoRenderer fallback."
    },
    {
      "name": "SkillDemoRegistry",
      "file": "public/js/demos/skills/index.js",
      "type": "module (registry + factory)",
      "exports": [
