        "readyCommands: string[]  — ['layout']",
        "betaCommands: string[]  — ['overdrive']",
        "skillFocusAreas: Record<string, {area, detail}[]>",
        "dimensionGuidelineCounts: Record<string, number>",
        "skillReferenceDomains: string[]",
        "commandProcessSteps: Record<string, string[]>",
        "commandCategories: Record<string, 'create'|'evaluate'|'refine'|'simplify'|'harden'|'system'>",
        "skillRelationships: Record<string, {description, referenceDomains}>",
        "commandRelationships: Record<string, {flow, leadsTo?, combinesWith?, pairs?}>"
      ]
    }
  ],

  "key_relationships": [
    "DemoRenderer depends_on CommandDemoRegistry (calls getCommandDemo)",
    "DemoRenderer depends_on SkillDemoRegistry (calls getSkillDemo)",
    "DemoToggles depends_on CommandDemoRegistry (calls getCommandDemo)",
    "DemoToggles depends_on SkillDemoRegistry (calls getSkillDemo)",
    "DemosIndex re_exports CommandDemoRegistry + SkillDemoRegistry",
    "CommandDemoRegistry aggregates 16 CommandDemo instances (one per file)",
    "SkillDemoRegistry aggregates 7 SkillDemo instances (one per file)",
    "SkillDemo composes 2-3 SkillTabDemo instances (tabs array)",
    "DemoRenderer uses CommandDemo (reads .before, .after, .caption, .id, calls .init())",
    "DemoToggles uses CommandDemo (reads .before, .after, calls .onToggle())",
    "DemoToggles uses SkillTabDemo (reads .before, .after, .beforeClass, .afterClass, calls .onToggle(), .onAfterRender())"
  ],

  "command_categories": {
    "create": ["shape", "impeccable craft", "impeccable"],
    "evaluate": ["critique", "audit"],
    "refine": ["typeset", "layout", "colorize", "animate", "delight", "bolder", "quieter", "overdrive"],
    "simplify": ["distill", "clarify", "adapt"],
    "harden": ["polish", "optimize", "harden"],
    "system": ["impeccable teach", "impeccable extract"]
  },

  "toggle_dispatch_logic": {
    "skill_toggle_priority": ["tab.onToggle (custom)", "tab.beforeClass/afterClass (CSS swap)", "tab.before/after (innerHTML swap)"],
    "command_toggle_priority": ["demo.onToggle (custom)", "demo.before/after (innerHTML swap)"]
  },

  "important_notes": [
    "No class-based OOP — all modules use plain objects and exported functions",
    "CommandDemo objects are pure data + optional function properties (init, onToggle)",
    "SkillTabDemo supports 3 toggle modes: custom handler, CSS class swap, HTML swap",
    "Only 'overdrive' CommandDemo has an init() method (for JS-driven animation setup)",
    "Commands 'impeccable' and 'shape' are NOT in CommandDemoRegistry — DemoRenderer handles them with inline static HTML",
    "setupCommandDemoToggles receives selectCommand callback from the parent page controller",
    "DemosIndex is a barrel re-exporter — adds no logic of its own"
  ]
}
