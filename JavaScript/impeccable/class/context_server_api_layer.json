{
  "scope": "server_api_layer",
  "title": "Server API Layer",
  "diagram_type": "class",
  "modules": [
    {
      "name": "server/index.js",
      "role": "HTTP entry point (Bun `serve`)",
      "functions": [
        "serveGenerated(pagePath: string): Promise<Response>"
      ],
      "routes": [
        "GET /api/skills → getSkills()",
        "GET /api/commands → getCommands()",
        "GET /api/patterns → getPatterns()",
        "GET /api/command-source/:id → getCommandSource(id)",
        "GET /api/download/:type/:provider/:id → handleFileDownload(type, provider, id)",
        "GET /api/download/bundle/:provider → handleBundleDownload(provider)",
        "GET /skills, /skills/:id, /anti-patterns, /visual-mode, /tutorials/:slug → serveGenerated()",
        "GET /assets/*, /css/*, /js/*, /fixtures/* → static file serving"
      ],
      "dependencies": ["server/lib/api-handlers.js", "scripts/build-sub-pages.js"]
    },
    {
      "name": "ApiHandlers",
      "file": "server/lib/api-handlers.js",
      "role": "Exported API handler functions",
      "functions": [
        "getSkills(): Promise<Array<{id, name, description, userInvocable}>>",
        "getCommands(): Promise<Array<{id, name, description, userInvocable}>>",
        "getCommandSource(id: string): Promise<string | {error: string, status: number} | null>",
        "getFilePath(type: string, provider: string, id: string): string | null",
        "handleFileDownload(type: string, provider: string, id: string): Promise<Response>",
        "getPatterns(): Promise<{patterns: Array, antipatterns: Array}>",
        "handleBundleDownload(provider: string): Promise<Response>"
      ],
      "internal_helpers": [
        "readFileContent(filePath: string): Promise<string>"
      ],
      "call_chains": [
        "getCommands() → getSkills() → readFileContent() + parseFrontmatter()",
        "getCommandSource(id) → isValidId() → readFileContent()",
        "getFilePath(type, provider, id) → FILE_DOWNLOAD_PROVIDER_CONFIG_DIRS[provider]",
        "handleFileDownload() → isAllowedType() + isAllowedFileProvider() + isValidId() + getFilePath() + sanitizeFilename()",
        "getPatterns() → readPatterns(PROJECT_ROOT)",
        "handleBundleDownload() → isAllowedBundleProvider() + sanitizeFilename()"
      ],
      "dependencies": ["server/lib/validation.js", "scripts/lib/utils.js", "lib/download-providers.js"]
    },
    {
      "name": "Validation",
      "file": "server/lib/validation.js",
      "role": "Input sanitization and allowlist guards",
      "functions": [
        "isValidId(id: string): boolean  // /^[a-zA-Z0-9_-]+$/",
        "isAllowedProvider(provider: string): boolean",
        "isAllowedFileProvider(provider: string): boolean",
        "isAllowedBundleProvider(provider: string): boolean",
        "isAllowedType(type: string): boolean  // ['skill','command']",
        "sanitizeFilename(filename: string): string  // strips non-alphanumeric except ._-"
      ],
      "constants": [
        "VALID_ID: RegExp",
        "ALLOWED_PROVIDERS: string[]",
        "ALLOWED_FILE_PROVIDERS: string[]",
        "ALLOWED_BUNDLE_PROVIDERS: string[]",
        "ALLOWED_TYPES: ['skill', 'command']"
      ],
      "dependencies": ["lib/download-providers.js"]
    },
    {
      "name": "Utils",
      "file": "scripts/lib/utils.js",
      "role": "Shared markdown/frontmatter parsing utilities",
      "functions": [
        "parseFrontmatter(content: string): {frontmatter: object, body: string}",
        "readPatterns(rootDir: string): {patterns: Array, antipatterns: Array}"
      ],
      "notes": "readPatterns reads source/skills/impeccable/SKILL.md and parses pattern/antipattern blocks"
    },
    {
      "name": "DownloadProviders",
      "file": "lib/download-providers.js",
      "role": "Provider config constants (external data source)",
      "exports": [
        "DOWNLOAD_PROVIDERS: string[]",
        "FILE_DOWNLOAD_PROVIDERS: string[]",
        "BUNDLE_DOWNLOAD_PROVIDERS: string[]",
        "FILE_DOWNLOAD_PROVIDER_CONFIG_DIRS: Record<string, string>"
      ]
    }
  ],
  "key_relationships": [
    "server/index.js depends_on ApiHandlers (imports getSkills, getCommands, getCommandSource, getPatterns, handleFileDownload, handleBundleDownload)",
    "ApiHandlers depends_on Validation (isValidId, isAllowedType, isAllowedFileProvider, isAllowedBundleProvider, sanitizeFilename)",
    "ApiHandlers depends_on Utils (parseFrontmatter, readPatterns)",
    "ApiHandlers depends_on DownloadProviders (FILE_DOWNLOAD_PROVIDER_CONFIG_DIRS)",
    "Validation depends_on DownloadProviders (DOWNLOAD_PROVIDERS, FILE_DOWNLOAD_PROVIDERS, BUNDLE_DOWNLOAD_PROVIDERS)",
    "getCommands() calls getSkills() — composition via filter",
    "server/index.js uses generateSubPages from scripts/build-sub-pages.js at startup"
  ],
  "data_shapes": {
    "Skill": "{id: string, name: string, description: string, userInvocable: boolean}",
    "PatternResult": "{patterns: Array, antipatterns: Array}",
    "CommandSourceResult": "string | {error: string, status: number} | null",
    "FilePathResult": "string | null"
  },
  "important_notes": "Runtime: Bun (uses bun:serve with route objects). No class-based OOP — all modules export plain functions. Validation is the security boundary: every handler validates type/provider/id before filesystem access. Files served from dist/<provider>/<configDir>/skills/<id>/SKILL.md. Bundle ZIPs at dist/<provider>.zip.",
  "source_files_analyzed": [
    "server/index.js",
    "server/lib/api-handlers.js",
    "server/lib/validation.js",
    "scripts/lib/utils.js (partial — function signatures only)"
  ]
}
