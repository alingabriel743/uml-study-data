@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam arrow {
    Color #495057
}

title CSS Antipattern Detector — Component Architecture

' ─────────────────────────────────────────
' CORE ENGINE
' ─────────────────────────────────────────
package "Core Detection Engine" #D8E8FF {
    [Antipattern Detector\n(detect-antipatterns.mjs)] as detector
    [Browser Detector\n(detect-antipatterns-browser.js)] as browserDetector
    detector ..> browserDetector : <<browser build>>
}

' ─────────────────────────────────────────
' SHARED LIBRARY
' ─────────────────────────────────────────
package "Shared Library" #FFE8CC {
    [Download Providers\n(lib/download-providers.js)] as downloadProviders
}

' ─────────────────────────────────────────
' CLI
' ─────────────────────────────────────────
package "CLI" #D8F0E0 {
    [CLI Entry Point\n(bin/cli.js)] as cli
}

cli --> detector : invokes detect / live / skills

' ─────────────────────────────────────────
' BROWSER EXTENSION
' ─────────────────────────────────────────
package "Browser Extension" #FFF3CC {

    package "Background" {
        [Service Worker\n(background/service-worker.js)] as bgWorker
    }

    package "Content" {
        [Content Script\n(content/content-script.js)] as contentScript
    }

    package "DevTools" {
        [DevTools Panel\n(devtools/panel.js)] as devtoolsPanel
        [DevTools Sidebar\n(devtools/sidebar.js)] as devtoolsSidebar
        [DevTools Bootstrap\n(devtools/devtools.js)] as devtoolsBootstrap
    }

    package "Popup" {
        [Extension Popup\n(popup/popup.js)] as popup
    }

    contentScript --> bgWorker : chrome.runtime.sendMessage\n(scan results)
    bgWorker --> contentScript : injects & triggers scan
    devtoolsPanel --> bgWorker : chrome.runtime.connect\n(port messaging)
    devtoolsBootstrap --> devtoolsPanel : creates panel
    devtoolsBootstrap --> devtoolsSidebar : creates sidebar
    popup --> bgWorker : reads extension state
}

bgWorker --> browserDetector : runs CSS antipattern scan

' ─────────────────────────────────────────
' WEB APPLICATION (Public)
' ─────────────────────────────────────────
package "Web Application" #E8F4FF {

    package "App Entry" {
        [App Bootstrap\n(public/app.js)] as webApp
    }

    package "UI Components" {
        [Lens Effect\n(components/lens.js)] as lens
        [Section Navigation\n(components/section-nav.js)] as sectionNav
        [Foundation Grid\n(components/foundation-grid.js)] as foundationGrid
        [Framework Viz\n(components/framework-viz.js)] as frameworkViz
        [Art Gallery\n(components/art-gallery.js)] as artGallery
    }

    package "Visual Effects" {
        [Hero Shader\n(effects/hero-shader.js)] as heroShader
        [Liquid Canvas\n(effects/liquid-canvas.js)] as liquidCanvas
    }

    package "Interactive Demos" {
        [Demo Renderer\n(js/demo-renderer.js)] as demoRenderer
        [Command Demos\n(demos/commands/index.js)] as commandDemos
        [Skill Demos\n(demos/skills/index.js)] as skillDemos
    }

    package "Utilities" {
        [Scroll & Anchor\n(utils/scroll.js)] as scrollUtil
        [Theme Toggle\n(utils/theme.js)] as themeUtil
        [Scroll Reveal\n(utils/reveal.js)] as revealUtil
    }

    webApp --> lens
    webApp --> sectionNav
    webApp --> foundationGrid
    webApp --> frameworkViz
    webApp --> heroShader
    webApp --> liquidCanvas
    webApp --> scrollUtil
    webApp --> themeUtil
    webApp --> revealUtil
    webApp --> demoRenderer
    demoRenderer --> commandDemos
    demoRenderer --> skillDemos
}

' ─────────────────────────────────────────
' SERVER
' ─────────────────────────────────────────
package "Server (Bun)" #F0E8FF {
    [HTTP Server\n(server/index.js)] as server
    [API Handlers\n(server/lib/api-handlers.js)] as apiHandlers
    [Request Validation\n(server/lib/validation.js)] as validation

    server --> apiHandlers : routes download\n& data requests
    server --> validation : validates requests
}

' ─────────────────────────────────────────
' SERVERLESS / EDGE FUNCTIONS
' ─────────────────────────────────────────
package "Serverless Functions\n(Cloudflare Pages)" #FFE8E8 {
    [Bundle Download\n(functions/api/download/bundle)] as bundleDownload
    [File Download\n(functions/api/download/{type}/{provider})] as fileDownload
}

' ─────────────────────────────────────────
' BUILD SCRIPTS
' ─────────────────────────────────────────
package "Build Toolchain" #E8F0E8 {
    [Build Orchestrator\n(scripts/build.js)] as buildScript
    [Extension Builder\n(scripts/build-extension.js)] as buildExtension
    [Sub-page Generator\n(scripts/build-sub-pages.js)] as buildSubPages

    package "Script Library" {
        [Script Utils\n(scripts/lib/utils.js)] as scriptUtils
        [Markdown Renderer\n(scripts/lib/render-markdown.js)] as markdownRenderer
        [Page Renderer\n(scripts/lib/render-page.js)] as pageRenderer
        [ZIP Builder\n(scripts/lib/zip.js)] as zipBuilder
        [Data Transformers\n(scripts/lib/transformers/index.js)] as transformers
    }

    buildScript --> scriptUtils
    buildScript --> transformers
    buildScript --> zipBuilder
    buildScript --> buildSubPages
    buildSubPages --> markdownRenderer
    buildSubPages --> pageRenderer
    buildSubPages --> scriptUtils
}

' ─────────────────────────────────────────
' CROSS-LAYER DEPENDENCIES
' ─────────────────────────────────────────
server --> buildSubPages : imports generateSubPages\nfor SSR
apiHandlers --> downloadProviders : resolves provider config
apiHandlers --> scriptUtils : reads patterns & frontmatter
bundleDownload --> downloadProviders : resolves bundle providers
fileDownload --> downloadProviders : resolves file providers
buildExtension --> browserDetector : bundles browser\ndetection script

@enduml
