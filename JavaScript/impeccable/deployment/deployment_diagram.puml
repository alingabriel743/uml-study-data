@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam node {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam artifact {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam database {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
    FontColor #0C5460
}
skinparam cloud {
    BackgroundColor #D4EDDA
    BorderColor #155724
    FontColor #155724
}

title Deployment Diagram — impeccable (impeccable.style)

' ─────────────────────────────────────────
' Developer / Local Environment
' ─────────────────────────────────────────
node "Developer Machine" <<Local>> {
    node "Bun Runtime" <<Runtime>> {
        artifact "Dev Server\n(server/index.js)" as devServer
        artifact "Build Scripts\n(scripts/build.js)" as buildScripts
    }

    artifact "Source Code\n(src/, public/, bin/)" as sourceCode
}

' ─────────────────────────────────────────
' GitHub — Source Control
' ─────────────────────────────────────────
cloud "GitHub\ngithub.com/pbakaus/impeccable" as github

' ─────────────────────────────────────────
' Production — Cloudflare Pages
' ─────────────────────────────────────────
cloud "Cloudflare Pages\nimpeccable.style" <<CDN / Hosting>> {
    artifact "Static Build Output\n(build/)" as staticBuild

    node "Edge Network" <<Cloudflare>> {
        artifact "HTML Pages\n(index, gallery, cheatsheet, …)" as htmlPages
        artifact "CSS & JS Assets\n(/css, /js, /assets)" as staticAssets
        artifact "Anti-Pattern Images\n(/antipattern-images)" as apImages
    }
}

' ─────────────────────────────────────────
' npm Registry — CLI Distribution
' ─────────────────────────────────────────
cloud "npm Registry\nnpmjs.com" as npmRegistry {
    artifact "impeccable npm package\n(v2.1.7)" as npmPackage
}

' ─────────────────────────────────────────
' End-User Environments
' ─────────────────────────────────────────
node "End User / CI Environment" <<Node.js >= 18>> {
    artifact "impeccable CLI\n(bin/cli.js)" as cli
    artifact "Anti-Pattern Detector\n(src/detect-antipatterns.mjs)" as detector
}

node "Browser Environment" <<User Browser>> {
    artifact "Web App\n(public/app.js)" as webApp
    artifact "Browser Detector\n(detect-antipatterns-browser.js)" as browserDetector
}

' ─────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────

sourceCode --> github : "git push"

github --> buildScripts : "triggers build"
buildScripts --> staticBuild : "bun run build\n→ build/"

staticBuild --> "Cloudflare Pages\nimpeccable.style" : "wrangler pages deploy"

staticBuild --> htmlPages : "deploy static HTML"
staticBuild --> staticAssets : "deploy CSS/JS"
staticBuild --> apImages : "deploy images"

devServer --> webApp : "serves /\n(HTTP :3000)"

sourceCode --> npmPackage : "npm publish"

npmPackage --> cli : "npx impeccable"
cli --> detector : "detect command"

webApp --> browserDetector : "loads via /js/"

"Browser Environment" --> "Cloudflare Pages\nimpeccable.style" : "HTTPS"

@enduml
