{
  "scope": "extension_devtools_panel_init",
  "title": "Extension DevTools Panel Initialization",
  "diagram_type": "sequence",
  "key_participants": [
    "Panel (panel.js)",
    "DOM",
    "chrome.runtime",
    "chrome.storage.sync",
    "ServiceWorker (port)",
    "chrome.devtools.inspectedWindow"
  ],
  "initialization_entry_point": "initSettings() called at script bottom (line 519)",
  "interaction_flow": [
    "Panel → chrome.storage.sync: get({ disabledRules, lineLengthMode, spotlightBlur, autoScan })",
    "Panel → fetch(chrome.runtime.getURL('detector/antipatterns.json')): load allAntipatterns[]",
    "Panel → Panel: renderSettings() — build settings UI from allAntipatterns + disabledRules",
    "Panel → Panel: initLineLengthControl(stored.lineLengthMode)",
    "Panel → Panel: initSpotlightBlurToggle(stored.spotlightBlur)",
    "Panel → Panel: initAutoScanControl(stored.autoScan)",
    "Panel → chrome.runtime: connect({ name: 'impeccable-panel-<tabId>' }) via getPort()",
    "getPort() → port: onMessage.addListener(handlePortMessage)",
    "getPort() → port: onDisconnect.addListener(() => port = null)",
    "Panel → setInterval(20000): postToPort({ action: 'ping' }) heartbeat"
  ],
  "sub_flows": {
    "initAutoScanControl": [
      "DOM: getElementById('auto-scan-mode')",
      "for each button: toggle 'active' class if btn.dataset.value === currentMode",
      "btn.click → chrome.storage.sync.set({ autoScan: mode })"
    ],
    "initLineLengthControl": [
      "DOM: getElementById('line-length-mode')",
      "for each button: toggle 'active' class if btn.dataset.value === currentMode",
      "btn.click → chrome.storage.sync.set({ lineLengthMode: mode })",
      "btn.click → chrome.runtime.sendMessage({ action: 'disabled-rules-changed' })"
    ],
    "initSpotlightBlurToggle": [
      "DOM: getElementById('spotlight-blur-toggle')",
      "cb.checked = currentValue",
      "cb.change → chrome.storage.sync.set({ spotlightBlur: cb.checked })",
      "cb.change → chrome.runtime.sendMessage({ action: 'disabled-rules-changed' })"
    ],
    "handlePortMessage": [
      "msg.action === 'page-pointer-active' → setHoveredItem(null)",
      "msg.action === 'findings' | 'state' → renderFindings(msg.findings) + updateToggleButton()",
      "msg.action === 'overlays-toggled' → overlaysVisible = msg.visible + updateToggleButton()",
      "msg.action === 'navigated' → showScanning()"
    ],
    "toggleRule": [
      "enabled=true → disabledRules.filter(id !== ruleId)",
      "enabled=false → disabledRules.push(ruleId)",
      "chrome.storage.sync.set({ disabledRules })",
      "chrome.runtime.sendMessage({ action: 'disabled-rules-changed' })"
    ],
    "port_management": [
      "getPort(): if port exists return it; else chrome.runtime.connect → attach listeners → return port",
      "postToPort(msg): getPort().postMessage(msg); on error → port=null → retry once with fresh port"
    ]
  },
  "state_variables": {
    "port": "null | chrome.runtime.Port — lazy, auto-recreated on disconnect",
    "overlaysVisible": "boolean, default true",
    "allAntipatterns": "array loaded from antipatterns.json",
    "disabledRules": "array of ruleId strings from chrome.storage.sync",
    "currentFindings": "array of findings from last port message"
  },
  "dom_elements_wired": {
    "btn-rescan": "click → showScanning() + postToPort({ action: 'scan' })",
    "btn-toggle": "click → postToPort({ action: 'toggle-overlays' })",
    "btn-settings": "click → toggle settingsContainer visibility",
    "btn-copy-all": "click → copyToClipboard(formatFindingsForCopy(currentFindings))",
    "auto-scan-mode buttons": "wired in initAutoScanControl()",
    "line-length-mode buttons": "wired in initLineLengthControl()",
    "spotlight-blur-toggle": "wired in initSpotlightBlurToggle()"
  },
  "theme_init": "chrome.devtools.panels.themeName === 'dark' → document.documentElement.classList.add('theme-dark')",
  "important_notes": "MV3 service worker can die after ~30s; port is null-reset on disconnect and lazily reconnected. Heartbeat ping every 20s keeps SW alive. toggleRule and both init controls all broadcast 'disabled-rules-changed' to the runtime after persisting.",
  "source_files_analyzed": ["extension/devtools/panel.js"]
}
