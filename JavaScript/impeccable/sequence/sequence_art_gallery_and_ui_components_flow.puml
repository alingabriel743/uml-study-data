@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    BoxBackgroundColor #F1F3F5
    GroupBorderColor #868E96
    GroupBackgroundColor #F8F9FA
    DividerBackgroundColor #DEE2E6
    DividerBorderColor #868E96
    NoteBackgroundColor #FFF9C4
    NoteBorderColor #F9A825
}

title Art Gallery and UI Components Flow

actor User as user
participant "Browser/DOM" as dom
participant "app.js" as app
participant "lens.js" as lens
participant "split-compare.js" as split
participant "section-nav.js" as secnav
participant "foundation-grid.js" as fgrid
participant "foundation-animations.js" as fanim
participant "art-gallery.js" as gallery
participant "data.js" as data
participant "demo-renderer.js" as demoRenderer
participant "demo-toggles.js" as demoToggles
participant "IntersectionObserver" as io
participant "ResizeObserver" as ro
participant "Window (RAF/scroll)" as win

== App Initialization ==

dom -> app : DOMContentLoaded\n[readyState === 'loading' → addEventListener\nelse → init() directly]
activate app

app -> lens : initLensEffect()
activate lens
lens -> dom : getElementById('lens-comparison') → container
alt #LightYellow container found
    lens -> split : initSplitCompare(container, { defaultPosition: 50 })
    activate split
    split -> dom : querySelector('.split-container',\n'.split-after', '.split-divider')
    split -> split : recalcSkewOffset()\nusing getBoundingClientRect()
    split -> ro : observe(splitContainer)
    activate ro
    note right of ro : Watches for size changes\nto recalculate skew offset
    ro --> split : resize callback
    deactivate ro
    split -> dom : updateSplit(position=50)\n→ sets clip-path + divider left
    split -> dom : addEventListener(mouseenter,\nmouseleave, mousemove) on hitArea
    split -> dom : addEventListener(touchstart,\ntouchend, touchmove) on splitContainer
    split --> lens : { destroy(), setPosition() } API
    deactivate split
end
deactivate lens

== Foundation Grid Initialization ==

app -> fgrid : initFoundationGrid()
activate fgrid
fgrid -> dom : querySelector('.foundation-grid') → container
alt #LightYellow container && skillFocusAreas['impeccable'] exist
    fgrid -> data : skillFocusAreas['impeccable'] → dimensions[]
    activate data
    data --> fgrid : dimensions[]
    fgrid -> data : dimensionGuidelineCounts → counts map
    data --> fgrid : counts map
    deactivate data
    fgrid -> fanim : foundationAnimations[dim.area] → SVG/HTML string
    activate fanim
    fanim --> fgrid : SVG/HTML animation string
    deactivate fanim
    fgrid -> dom : container.innerHTML =\nrendered foundation cards with plinth columns
end
deactivate fgrid

== Section Nav Initialization ==

app -> secnav : initSectionNav()
activate secnav
secnav -> dom : getElementById('section-nav') → nav
alt #LightYellow nav && #hero found
    secnav -> dom : querySelectorAll('.section-nav-item') → items\nmap to sectionIds[]
    secnav -> dom : getElementById('hero'),\nquerySelector('.site-footer')
    secnav -> secnav : updateNav() [initial call]
    secnav -> win : addEventListener('scroll',\nthrottled via requestAnimationFrame, passive:true)
end
deactivate secnav

== Art Gallery Rendering (Separate Entry) ==

note over gallery : art-gallery.js is NOT imported\nby app.js — loaded separately

user -> gallery : renderGallery(skills[])
activate gallery
gallery -> dom : querySelector('.skills-gallery') → container
alt #LightYellow container found
    gallery -> gallery : skills.filter(s => s.id !== 'impeccable')\n→ filteredSkills
    loop for each (skill, index) in filteredSkills
        gallery -> gallery : renderFrame(skill, index)
        activate gallery
        gallery -> data : readySkills.includes(skill.id) → isReady
        activate data
        data --> gallery : isReady: boolean
        gallery -> data : skillFocusAreas[skill.id] → focusAreas[]
        data --> gallery : focusAreas[]
        deactivate data
        gallery -> gallery : formatName(skill.id)\n→ displayName (hyphen→Title Case, 'ux'→'UX')
        alt #LightGreen isReady === true
            gallery -> demoRenderer : renderSkillDemo(skill.id)
            activate demoRenderer
            demoRenderer --> gallery : skill demo HTML
            deactivate demoRenderer
        else isReady === false
            gallery -> gallery : renderComingSoonVisual(skill.id)
        end
        deactivate gallery
    end
    gallery -> dom : container.innerHTML =\ngallery-track (frames) + gallery-map (dots)
    gallery -> gallery : setupInteractions()
    activate gallery
    gallery -> dom : querySelectorAll('.gallery-frame'),\n'.gallery-dot'
    gallery -> io : new IntersectionObserver(callback,\n{ root: track, threshold: 0.6 })
    activate io
    io -> dom : observe(each frame)
    note right of io : Fires when frame enters\nviewport at 60% visibility
    io --> gallery : frame intersection callback
    deactivate io
    gallery -> dom : frames: classList.add/remove('active')\ndots: classList.add/remove('is-active') + aria-selected
    gallery -> dom : dots: addEventListener('click')\n→ frame.scrollIntoView({ behavior: 'smooth', inline: 'center' })
    deactivate gallery
    gallery -> demoRenderer : setupDemoTabs()
    gallery -> demoToggles : setupDemoToggles()
end
deactivate gallery

== User Interactions at Runtime ==

group Lens / Split-Compare Interactions
    user -> split : mousemove → handleMouseMove()
    activate split
    split -> split : targetX = computed position
    split -> win : requestAnimationFrame(animate)
    win --> split : animation frame tick
    split -> split : lerp currentX → targetX\n→ updateSplit(currentX)
    alt #LightCoral threshold crossed (wasAbove && !isAbove)
        split -> split : retriggerAnimations()\n[hasCanvas → per-element CSS reset\nelse → clone-and-replace]
    end
    deactivate split
end

group Section Nav Scroll Updates
    user -> win : scroll event
    activate win
    win -> secnav : requestAnimationFrame(updateNav)\n[ticking guard prevents double-queue]
    deactivate win
    activate secnav
    secnav -> dom : compute heroBottom, footerTop, viewportMiddle
    secnav -> secnav : nav.classList.add/remove('is-visible')\nbased on scroll position
    secnav -> dom : iterate sectionIds →\nfind currentSection by offsetTop ≤ viewportMiddle
    secnav -> dom : build activeSections Set\n(sibling sections with same offsetTop ±4px)
    secnav -> dom : items: classList.add/remove('is-active')\nper activeSections membership
    deactivate secnav
end

deactivate app

@enduml
