@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #F8F9FA
    ParticipantBackgroundColor #F8F9FA
    ParticipantBorderColor #495057
    ParticipantFontColor #212529
    BoxBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    DividerBackgroundColor #DEE2E6
    GroupBackgroundColor #F1F3F5
    NoteBackgroundColor #FFF9C4
    NoteBorderColor #ADB5BD
}

title Demo Interaction Flow

actor User

box "demo-toggles.js" #E8F4FD
    participant "setupDemoToggles" as SDT
    participant "setupCommandDemoToggles" as SCDT
    participant "setupInteractiveButtons" as SIB
    participant "handleDemoToggle" as HDT
    participant "handleCommandDemoToggle" as HCDT
end box

box "demo-renderer.js" #EDF7ED
    participant "renderCommandDemo" as RCD
    participant "renderSkillDemo" as RSD
    participant "renderSkillTabDemo" as RSTD
    participant "initCommandDemo" as ICD
    participant "setupDemoTabs" as SDTABS
end box

box "Demo Data Layer" #FDF3E8
    participant "getSkillDemo\n(demos/skills/index.js)" as GSD
    participant "getCommandDemo\n(demos/commands/index.js)" as GCD
end box

participant "DOM" as DOM
participant "tab/demo Callbacks" as CB

' ─────────────────────────────────────────────
== Skill Demo Setup ==
' ─────────────────────────────────────────────

[-> SDT: setupDemoToggles()
activate SDT

SDT -> DOM: querySelectorAll('.demo-toggle-switch')
activate DOM
DOM --> SDT: toggleElements[]
deactivate DOM

note right of SDT
  Skips elements where
  dataset.initialized is set
  (guards against double-init)
end note

SDT -> SDT: attach click listener per toggle

SDT -> SIB: setupInteractiveButtons()
activate SIB
SIB -> DOM: querySelectorAll('.int-fb-active[data-action="like"]')
activate DOM
DOM --> SIB: likeButtons[]
deactivate DOM
SIB -> SIB: attach click listener per likeBtn
deactivate SIB

deactivate SDT

' ─────────────────────────────────────────────
== Skill Demo Toggle Interaction ==
' ─────────────────────────────────────────────

User -> DOM: click toggle (demoId)
activate DOM
DOM -> DOM: toggle 'active' class\nupdate aria-checked\nupdate label classes
DOM -> HDT: handleDemoToggle(demoId, isAfter)
deactivate DOM
activate HDT

HDT -> DOM: getElementById(demoId + '-viewport')
activate DOM
DOM --> HDT: viewport element
deactivate DOM

HDT -> DOM: viewport.dataset.state = 'before'|'after'
HDT -> HDT: split demoId → skillId + tabId\n(pop last segment)

HDT -> GSD: getSkillDemo(skillId)
activate GSD
GSD --> HDT: skill object
deactivate GSD

HDT -> HDT: find tab by tabId within skill.tabs

alt tab.onToggle exists
    HDT -> CB: tab.onToggle(viewport, isAfter)
    activate CB
    CB --> HDT: (handled — early return)
    deactivate CB
else tab.beforeClass / tab.afterClass exist
    HDT -> DOM: demo.className = isAfter ? afterClass : beforeClass
    note right: early return after CSS class swap
else tab.before / tab.after exist
    HDT -> DOM: viewport.innerHTML = isAfter ? tab.after : tab.before
    opt isAfter && tab.onAfterRender exists
        HDT -> CB: tab.onAfterRender()
        activate CB
        CB --> HDT: (post-render callback done)
        deactivate CB
    end
end

deactivate HDT

' ─────────────────────────────────────────────
== Command Demo Setup ==
' ─────────────────────────────────────────────

[-> SCDT: setupCommandDemoToggles(allCommands, selectCommand)
activate SCDT

SCDT -> DOM: querySelectorAll('.command-demo-area .demo-toggle-switch')
activate DOM
DOM --> SCDT: toggleElements[]
deactivate DOM
SCDT -> SCDT: attach click listener per toggle\n(guarded by dataset.initialized)

SCDT -> DOM: querySelectorAll('.relationship-tag')
activate DOM
DOM --> SCDT: relationshipTags[]
deactivate DOM
SCDT -> SCDT: attach click listener per tag

deactivate SCDT

' ─────────────────────────────────────────────
== Command Demo Toggle Interaction ==
' ─────────────────────────────────────────────

User -> DOM: click command toggle (demoId)
activate DOM
DOM -> DOM: toggle 'active' class\nupdate aria-checked + labels
DOM -> HCDT: handleCommandDemoToggle(demoId, isAfter)
deactivate DOM
activate HCDT

HCDT -> HCDT: strip 'command-' prefix → commandId

HCDT -> GCD: getCommandDemo(commandId)
activate GCD
GCD --> HCDT: demo object
deactivate GCD

HCDT -> DOM: getElementById(demoId + '-viewport')
activate DOM
DOM --> HCDT: viewport element
deactivate DOM
HCDT -> DOM: viewport.dataset.state = 'before'|'after'

alt demo.onToggle exists
    HCDT -> CB: demo.onToggle(viewport, isAfter)
    activate CB
    CB --> HCDT: (custom handler done)
    deactivate CB
else demo.before / demo.after exist
    HCDT -> DOM: viewport.innerHTML = isAfter ? demo.after : demo.before
end

deactivate HCDT

' ─────────────────────────────────────────────
== Relationship Tag Interaction ==
' ─────────────────────────────────────────────

User -> DOM: click .relationship-tag (commandId)
activate DOM
DOM -> DOM: allCommands.find(c => c.id === commandId)
DOM -> [: selectCommand(command)
deactivate DOM

' ─────────────────────────────────────────────
== Interactive Like Button ==
' ─────────────────────────────────────────────

User -> DOM: click likeBtn
activate DOM
DOM -> DOM: toggle 'liked' class
DOM -> DOM: nextElementSibling.textContent\n= 'Liked!' | 'Click to try!'
deactivate DOM

' ─────────────────────────────────────────────
== Command Demo Rendering ==
' ─────────────────────────────────────────────

[-> RCD: renderCommandDemo(commandId)
activate RCD

RCD -> GCD: getCommandDemo(commandId)
activate GCD
GCD --> RCD: demo | null
deactivate GCD

alt commandId === 'impeccable' && no demo
    RCD --> [: static usage guide HTML
else commandId === 'shape' && no demo
    RCD --> [: static planning process HTML
else no demo found
    RCD --> [: 'coming soon' placeholder HTML
else demo found
    RCD --> [: split-screen comparison HTML\n(demo-split-comparison:\n split-before, split-after,\n split-divider, demo-caption)
end

deactivate RCD

[-> ICD: initCommandDemo(commandId, container)
activate ICD

ICD -> GCD: getCommandDemo(commandId)
activate GCD
GCD --> ICD: demo object
deactivate GCD

ICD -> DOM: container.querySelector\n('.split-after .split-content') || container
activate DOM
DOM --> ICD: demoArea
deactivate DOM

ICD -> CB: demo.init(demoArea)
activate CB
CB --> ICD: (demo initialized)
deactivate CB

deactivate ICD

' ─────────────────────────────────────────────
== Skill Demo Rendering ==
' ─────────────────────────────────────────────

[-> RSD: renderSkillDemo(skillId)
activate RSD

RSD -> GSD: getSkillDemo(skillId)
activate GSD
GSD --> RSD: skill | null
deactivate GSD

alt no skill or no tabs
    RSD --> [: 'coming soon' placeholder HTML
else skill.tabs.length > 1
    RSD -> RSD: render tab buttons\n(.demo-tab, data-demo-tab, data-skill)
    loop for each tab in skill.tabs
        RSD -> RSTD: renderSkillTabDemo(skillId, tab)
        activate RSTD
        RSTD -> RSTD: compute demoId = skillId + '-' + tab.id\nhasToggle = tab.hasToggle !== false
        RSTD --> RSD: panel HTML\n(demo-toggle-switch + demo-viewport\n + demo-caption)
        deactivate RSTD
    end
    RSD --> [: full tabbed skill demo HTML
else single tab
    RSD -> RSTD: renderSkillTabDemo(skillId, tab)
    activate RSTD
    RSTD --> RSD: panel HTML
    deactivate RSTD
    RSD --> [: single-tab skill demo HTML
end

deactivate RSD

' ─────────────────────────────────────────────
== Demo Tab Switching ==
' ─────────────────────────────────────────────

[-> SDTABS: setupDemoTabs()
activate SDTABS

SDTABS -> DOM: querySelectorAll('.demo-tab')
activate DOM
DOM --> SDTABS: tabElements[]
deactivate DOM
SDTABS -> SDTABS: attach click listener per tab

deactivate SDTABS

User -> DOM: click .demo-tab (tabId)
activate DOM
DOM -> DOM: closest('.demo-tabbed-container')\nremove 'active' from all tabs + panels
DOM -> DOM: add 'active' to clicked tab\nand matching panel [data-demo-panel=tabId]
deactivate DOM

@enduml
