@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    BoxBackgroundColor #F1F3F5
    BoxBorderColor #ADB5BD
    GroupBorderColor #6C757D
    GroupFontColor #212529
    GroupHeaderFontColor #212529
    DividerBackgroundColor #DEE2E6
    DividerBorderColor #ADB5BD
    NoteBackgroundColor #FFF9C4
    NoteBorderColor #F0AD4E
}

title Extension DevTools Panel Initialization

participant "panel.js" as Panel
participant "DOM" as DOM
participant "chrome.storage.sync" as Storage
participant "chrome.runtime" as Runtime
participant "antipatterns.json" as Resource
participant "ServiceWorker (port)" as SW
participant "setInterval" as Timer

== Script Load ==

[-> Panel : initSettings()
activate Panel

Panel -> Runtime : devtools.panels.themeName
Runtime --> Panel : themeName
Panel -> DOM : classList.add('theme-dark') [if dark]

== Load Persisted Settings ==

Panel -> Storage : get({ disabledRules, lineLengthMode,\n  spotlightBlur, autoScan })
activate Storage
Panel -> Runtime : getURL('detector/antipatterns.json')
Runtime --> Panel : extensionFileURL
Panel -> Resource : fetch(extensionFileURL)
activate Resource
Resource --> Panel : allAntipatterns[]
deactivate Resource
Storage --> Panel : stored { disabledRules, lineLengthMode,\n  spotlightBlur, autoScan }
deactivate Storage

== Build Settings UI ==

Panel -> Panel : renderSettings(allAntipatterns, disabledRules)
activate Panel
Panel -> DOM : create rule checkboxes per antipattern
DOM --> Panel : checkboxes wired
deactivate Panel

== Control Initialization ==

Panel -> Panel : initLineLengthControl(stored.lineLengthMode)
activate Panel
Panel -> DOM : getElementById('line-length-mode')
DOM --> Panel : container
Panel -> DOM : toggle 'active' class\n[btn.dataset.value === currentMode]
note right of DOM
  btn.click listener registered:
  → storage.set({ lineLengthMode: mode })
  → runtime.sendMessage('disabled-rules-changed')
end note
deactivate Panel

Panel -> Panel : initSpotlightBlurToggle(stored.spotlightBlur)
activate Panel
Panel -> DOM : getElementById('spotlight-blur-toggle')
DOM --> Panel : checkbox
Panel -> DOM : cb.checked = spotlightBlur
note right of DOM
  cb.change listener registered:
  → storage.set({ spotlightBlur: cb.checked })
  → runtime.sendMessage('disabled-rules-changed')
end note
deactivate Panel

Panel -> Panel : initAutoScanControl(stored.autoScan)
activate Panel
Panel -> DOM : getElementById('auto-scan-mode')
DOM --> Panel : container
Panel -> DOM : toggle 'active' class\n[btn.dataset.value === currentMode]
note right of DOM
  btn.click listener registered:
  → storage.set({ autoScan: mode })
end note
deactivate Panel

== Port Setup (getPort) ==

Panel -> Runtime : connect({ name: 'impeccable-panel-<tabId>' })
activate Runtime
Runtime --> Panel : port
deactivate Runtime
Panel -> SW : port.onMessage.addListener(handlePortMessage)
Panel -> SW : port.onDisconnect.addListener(() => port = null)
note right of SW
  MV3 service worker can die after ~30s idle.
  Port is lazily re-created on next postToPort() call
  if port === null.
end note

== Heartbeat ==

Panel -> Timer : setInterval(20000, postToPort)
activate Timer
loop every 20 seconds
    Timer -> SW : postToPort({ action: 'ping' })
    note right of SW : Keeps service worker alive
end
deactivate Timer

deactivate Panel

== Incoming Port Messages (runtime) ==

SW -> Panel : port.onMessage(msg)
activate Panel

alt msg.action === 'page-pointer-active'
    Panel -> Panel : setHoveredItem(null)
else msg.action === 'findings' | 'state'
    Panel -> Panel : renderFindings(msg.findings)
    Panel -> Panel : updateToggleButton()
else msg.action === 'overlays-toggled'
    Panel -> Panel : overlaysVisible = msg.visible
    Panel -> Panel : updateToggleButton()
else msg.action === 'navigated'
    Panel -> Panel : showScanning()
end

deactivate Panel

== Rule Toggling ==

[-> Panel : toggleRule(ruleId, enabled)
activate Panel

alt enabled === true
    Panel -> Panel : disabledRules = disabledRules\n  .filter(id !== ruleId)
else enabled === false
    Panel -> Panel : disabledRules.push(ruleId)
end

Panel -> Storage : set({ disabledRules })
Panel -> Runtime : sendMessage({ action: 'disabled-rules-changed' })

deactivate Panel

@enduml
