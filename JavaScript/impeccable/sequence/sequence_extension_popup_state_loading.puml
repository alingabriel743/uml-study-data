@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    BoxBackgroundColor #F1F3F5
    DividerBackgroundColor #DEE2E6
    GroupBackgroundColor #F8F9FA
    GroupBorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F0AD00
    FontColor #212529
}

title Extension Popup State Loading

actor "Browser" as browser
participant "popup.js\n(PopupScript)" as popup
participant "chrome.tabs API" as tabs
participant "chrome.runtime\n(ServiceWorker)" as sw
participant "DOM" as dom

note over popup
  Script executes at
  bottom of popup.js (line 67)
  — no DOMContentLoaded needed
end note

browser -> popup : <script> evaluated on popup open
activate popup

popup -> dom : getElementById('count-number')\ngetElementById('count-label')\ngetElementById('btn-scan')\ngetElementById('btn-toggle')
activate dom
dom --> popup : countNumber, countLabel, btnScan, btnToggle
deactivate dom

popup -> popup : loadState()
activate popup

  popup -> popup : getActiveTabId()
  activate popup
    popup -> tabs : chrome.tabs.query({ active: true, currentWindow: true })
    activate tabs
    tabs --> popup : [tab]
    deactivate tabs
    popup --> popup : return tab?.id
  deactivate popup

  alt tabId is falsy (no active tab)
    popup -> popup : return (early exit — no tab)
  else tabId is valid
    popup -> sw : chrome.runtime.sendMessage(\n  { action: 'get-state', tabId },\n  callback: updateFromState\n)
    activate sw
    sw --> popup : state = { findings: [...], overlaysVisible: bool }\nor null (no scan yet)
    deactivate sw

    popup -> popup : updateFromState(state)
    activate popup

      alt state is falsy (idle — no scan has run)
        popup -> popup : return (early exit — leave DOM at defaults)
      else state exists (scan results available)
        note right of popup
          count = state.findings.reduce(
            (sum, f) => sum + f.findings.length, 0
          )
        end note

        popup -> dom : countNumber.textContent = String(count)
        activate dom
        dom --> popup : updated
        deactivate dom

        popup -> dom : countNumber.classList.toggle('has-findings', count > 0)
        activate dom
        dom --> popup : updated
        deactivate dom

        popup -> dom : countLabel.textContent =\n  count === 1 ? 'anti-pattern' : 'anti-patterns'
        activate dom
        dom --> popup : updated
        deactivate dom

        popup -> popup : overlaysVisible = (state.overlaysVisible !== false)

        popup -> dom : btnToggle.textContent =\n  overlaysVisible ? 'Hide overlays' : 'Show overlays'
        activate dom
        dom --> popup : updated
        deactivate dom
      end

    deactivate popup
  end

deactivate popup

== Real-time Updates (onMessage listener) ==

sw -> popup : onMessage({ action: 'findings-updated', findings: [...] })
activate popup
  note right of popup
    count = msg.findings.reduce(
      (sum, f) => sum + f.findings.length, 0
    )
  end note
  popup -> dom : countNumber.textContent = String(count)
  activate dom
  dom --> popup : updated
  deactivate dom
  popup -> dom : countNumber.classList.toggle('has-findings', count > 0)
  activate dom
  dom --> popup : updated
  deactivate dom
  popup -> dom : countLabel.textContent = 'anti-pattern' | 'anti-patterns'
  activate dom
  dom --> popup : updated
  deactivate dom
  popup -> dom : btnScan.textContent = 'Scan page'\nbtnScan.disabled = false
  activate dom
  dom --> popup : updated
  deactivate dom
deactivate popup

sw -> popup : onMessage({ action: 'overlays-toggled-broadcast', visible: bool })
activate popup
  popup -> popup : overlaysVisible = msg.visible
  popup -> dom : btnToggle.textContent =\n  visible ? 'Hide overlays' : 'Show overlays'
  activate dom
  dom --> popup : updated
  deactivate dom
deactivate popup

deactivate popup

@enduml
