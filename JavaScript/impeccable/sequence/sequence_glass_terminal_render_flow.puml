@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequence {
    ArrowColor #495057
    ActorBorderColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    ParticipantBorderColor #495057
    ParticipantBackgroundColor #F8F9FA
    ParticipantFontColor #212529
    BoxBackgroundColor #F1F3F5
    BoxBorderColor #6C757D
    DividerBackgroundColor #DEE2E6
    GroupBackgroundColor #E9ECEF
    NoteBackgroundColor #FFF9C4
    NoteBorderColor #F0C040
}

title Glass Terminal Render Flow

actor User
participant "App\n(app.js)" as App
participant "GlassTerminal\n(glass-terminal.js)" as GT
participant "data.js\n(commandCategories)" as Data
participant "DemoRenderer\n(demo-renderer.js)" as DR
participant "SplitCompare\n(split-compare.js)" as SC
participant "DOM / Browser" as DOM

== Initialisation ==

App -> GT : initGlassTerminal()\nnote right: no-op stub
activate GT
GT --> App : (ready)
deactivate GT

App -> App : loadContent()
activate App
App -> DOM : fetch /api/commands
DOM --> App : allCommands[]
deactivate App

App -> GT : renderTerminalLayout(allCommands)
activate GT

GT -> GT : isMobile()\nnote right: window.innerWidth <= 900?

== Desktop Layout ==

alt Desktop (innerWidth > 900)

    GT -> GT : renderDesktopLayout(container, commands)
    activate GT

    GT -> Data : read commandCategories,\ncommandRelationships,\nbetaCommands
    Data --> GT : category metadata

    GT -> GT : filter deprecated commands\ngroup + sort by categoryOrder

    GT -> DOM : read window.location.hash\n→ determine startIndex
    DOM --> GT : startIndex

    loop for each command (× N)
        GT -> GT : renderSpread(cmd, i, isActive)\n→ builds spread HTML
    end

    GT -> DOM : container.innerHTML =\nmagazine-container\n+ fisheye-list\n+ spreads[]
    deactivate GT

    GT -> GT : initSpreadDemo(startIndex)
    activate GT
    note over GT : magazineState.cmd = commands[startIndex]
    GT -> SC : currentSplitInstance.destroy()\n[if previous instance exists]
    activate SC
    SC --> GT
    deactivate SC
    GT -> DR : renderCommandDemo(cmd.id)\n[if demoArea not loaded — lazy]
    activate DR
    DR --> GT : injected HTML
    deactivate DR
    GT -> SC : initSplitCompare(splitComparison,\n{defaultPosition: 50})
    activate SC
    SC --> GT : splitInstance
    deactivate SC
    GT -> DR : initCommandDemo(cmd.id, demoArea)
    activate DR
    DR --> GT
    deactivate DR
    deactivate GT

    GT -> GT : setupFisheyeList(filteredCommands,\nheaderIndices)
    activate GT
    GT -> DOM : getElementById('fisheye-list')\nquerySelectorAll('.fisheye-item')
    DOM --> GT : listEl, items[]
    GT -> DOM : create scroll spacer div\nset scroll container height
    GT -> GT : layout(startIdx)\n[positions all items with fisheye\nscale/opacity via smoothstep]
    GT -> GT : activate(startIdx)\n[sets is-active class → goToSpread]
    deactivate GT

    GT -> GT : setupMagazineKeyboard(filteredCommands)
    activate GT
    GT -> DOM : addEventListener('keydown')
    deactivate GT

    GT -> GT : setupMagazineIntersection(container)
    activate GT
    GT -> DOM : new IntersectionObserver\non .magazine-container (threshold 0.1)
    deactivate GT

    == User Interactions (Desktop) ==

    group Scroll Event
        DOM -> GT : scroll event (passive)
        activate GT
        GT -> DOM : requestAnimationFrame
        DOM --> GT : frame callback
        GT -> GT : layout(center)\nfisheye scale+opacity update
        GT -> GT : activate(Math.round(center))
        GT -> GT : goToSpread(idx, commands)
        activate GT
        GT -> SC : currentSplitInstance.destroy()
        activate SC
        SC --> GT
        deactivate SC
        GT -> DOM : spreads[oldIdx].classList\nremove 'active', add 'exiting'
        GT -> DOM : spreads[newIdx].classList\nadd 'active', remove 'exiting'
        GT -> DOM : history.replaceState(\nnull, '', '#cmd-{cmd.id}')
        GT -> GT : initSpreadDemo(newIndex)
        note right: (see initSpreadDemo detail above)
        GT -> DOM : setTimeout(500ms)\n→ spreads[oldIdx].classList\n  .remove('exiting')
        deactivate GT
        deactivate GT
    end

    group Click on Fisheye Item
        User -> DOM : click .fisheye-item
        DOM -> GT : click event
        activate GT
        GT -> GT : scrollToIndex(i, 'smooth')
        note right: scrolls container;\nscroll event fires → activate() → goToSpread()
        deactivate GT
    end

    group Keyboard Navigation
        User -> DOM : keydown ArrowRight/Down\nor ArrowLeft/Up
        DOM -> GT : keydown event
        activate GT
        GT -> DOM : fisheyeList._scrollToCommand\n(currentIndex ± 1)
        note right: delegates to scrollToIndex,\nnot goToSpread directly
        deactivate GT
    end

    group IntersectionObserver (viewport entry)
        DOM -> GT : entry.isIntersecting
        activate GT
        GT -> GT : initSpreadDemo\n(magazineState.currentIndex)
        note right: re-activates demo\nwhen section scrolls into view
        deactivate GT
    end

else Mobile (innerWidth <= 900)

    == Mobile Layout ==

    GT -> GT : renderMobileLayout(container, commands)
    activate GT

    GT -> DR : renderCommandDemo(commands[0].id)\n[initial demo HTML]
    activate DR
    DR --> GT : injected HTML
    deactivate DR

    GT -> DOM : container.innerHTML =\nmobile-commands-layout\n(carousel pills + demo area\n+ info cards)

    GT -> GT : setupMobileInteractions(commands)
    activate GT
    GT -> SC : initSplitCompare(initialSplit,\n{defaultPosition: 50})
    activate SC
    SC --> GT : splitInstance
    deactivate SC
    GT -> DR : initCommandDemo(commands[0].id, demoArea)
    activate DR
    DR --> GT
    deactivate DR
    deactivate GT
    deactivate GT

    group Mobile Pill Click
        User -> DOM : click .mobile-cmd-pill
        DOM -> GT : click event
        activate GT
        GT -> SC : currentSplitInstance.destroy()
        activate SC
        SC --> GT
        deactivate SC
        GT -> DR : renderCommandDemo(cmdId)
        activate DR
        DR --> GT : injected HTML
        deactivate DR
        GT -> SC : initSplitCompare(splitComparison,\n{defaultPosition: 50})
        activate SC
        SC --> GT : splitInstance
        deactivate SC
        GT -> DR : initCommandDemo(cmdId, demoArea)
        activate DR
        DR --> GT
        deactivate DR
        deactivate GT
    end

end

== Responsive Resize ==

DOM -> GT : resize event\n(isMobile changed)
activate GT
note over GT : MOBILE_BREAKPOINT = 900px\nfull re-render triggered
GT -> GT : renderTerminalLayout(allCommands)\n→ renderMobileLayout or renderDesktopLayout
deactivate GT

deactivate GT

@enduml
