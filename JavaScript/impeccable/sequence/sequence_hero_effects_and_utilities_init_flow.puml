@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    GroupBorderColor #6C757D
    GroupBackgroundColor #DEE2E6
    DividerBackgroundColor #CED4DA
    DividerBorderColor #6C757D
    NoteBackgroundColor #FFF3CD
    NoteBorderColor #856404
}

title Hero Effects and Utilities Initialization Flow

actor Browser
participant "app.js\nDOMContentLoaded" as AppJS
participant "initAnchorScroll\n(scroll.js)" as AnchorScroll
participant "initScrollReveal\n(reveal.js)" as ScrollReveal
participant "inView\n(motion)" as InView
participant "initHeroEffect\n(liquid-canvas.js)" as HeroEffect
participant "initHeroShader\n(hero-shader.js)" as HeroShader
participant "ShaderMount\n(@paper-design/shaders)" as ShaderMount
participant "initSplitCompare\n(split-compare.js)" as SplitCompare
participant "initThemeToggle\n(theme.js)" as ThemeToggle
participant "localStorage" as LS
participant "DOM" as DOM
participant "IntersectionObserver" as IO
participant "ResizeObserver" as RO
participant "window" as Window

== app.js Bootstrap ==

Browser -> AppJS: DOMContentLoaded\n(or readyState != 'loading')
activate AppJS

AppJS -> AnchorScroll: initAnchorScroll()
activate AnchorScroll
AnchorScroll -> DOM: querySelectorAll("a[href^='#']")
DOM --> AnchorScroll: anchorLinks[]
AnchorScroll -> Window: addEventListener('click') on each link
note right of AnchorScroll
  On click → scrollTo({
    top: targetPos - 40,
    behavior: 'auto'
  })
end note
deactivate AnchorScroll

AppJS -> ScrollReveal: initScrollReveal()
activate ScrollReveal
ScrollReveal -> DOM: querySelectorAll("[data-reveal]")
DOM --> ScrollReveal: revealElements[]
loop for each [data-reveal] element
    ScrollReveal -> InView: inView(el, callback,\n{ margin: '-50px' })
    InView --> ScrollReveal: observer registered
end
note right of ScrollReveal
  On viewport entry:
  el.classList.add('revealed')
end note
deactivate ScrollReveal

deactivate AppJS

== initHeroEffect — Liquid Canvas (standalone) ==

Browser -> HeroEffect: initHeroEffect()
activate HeroEffect
HeroEffect -> DOM: getElementById('hero-canvas')
DOM --> HeroEffect: canvas | null

alt canvas not found
    HeroEffect --> Browser: return (no-op)
else canvas found
    HeroEffect -> Window: matchMedia('prefers-reduced-motion')
    alt reduced motion matches
        HeroEffect -> DOM: canvas.style.display = 'none'
        HeroEffect --> Browser: return (accessibility guard)
    else motion allowed
        HeroEffect -> DOM: canvas.getContext('2d')
        DOM --> HeroEffect: ctx

        HeroEffect -> HeroEffect: resize()
        activate HeroEffect
        HeroEffect -> DOM: getBoundingClientRect()
        DOM --> HeroEffect: { width, height }
        HeroEffect -> DOM: canvas.width/height = size * dpr
        HeroEffect -> DOM: ctx.scale(dpr, dpr)
        HeroEffect -> HeroEffect: initGrid()
        note right of HeroEffect
          Clears points[],
          computes gap (40px <768px, else 50px),
          creates Point(x, y) for each grid cell
        end note
        deactivate HeroEffect

        HeroEffect -> HeroEffect: draw()
        note right of HeroEffect
          ctx.clearRect → forEach point:
          point.update() [spring physics
          + mouse repulsion] → draw grid lines
          → requestAnimationFrame(draw)
        end note

        HeroEffect -> Window: addEventListener('resize', resize)
        HeroEffect -> DOM: parentElement.addEventListener\n('mousemove', handleMouseMove)
        HeroEffect -> DOM: parentElement.addEventListener\n('mouseleave', handleMouseLeave)

        HeroEffect -> IO: new IntersectionObserver(callback)
        IO --> HeroEffect: observer
        HeroEffect -> IO: observer.observe(canvas)
        note right of IO
          Not intersecting → cancelAnimationFrame
          Intersecting → draw()
        end note
    end
end
deactivate HeroEffect

== initHeroShader — WebGL Mesh Gradient (standalone) ==

Browser -> HeroShader: initHeroShader()
activate HeroShader
HeroShader -> DOM: getElementById('hero-shader')
DOM --> HeroShader: container | null

alt container not found
    HeroShader --> Browser: return (no-op)
else container found
    HeroShader -> Window: matchMedia('prefers-reduced-motion')
    alt reduced motion matches
        HeroShader -> DOM: container.style.display = 'none'
        HeroShader --> Browser: return (accessibility guard)
    else motion allowed
        HeroShader -> ShaderMount: new ShaderMount(container,\nmeshGradientFragmentShader,\nuniforms, undefined, speed=1.0)
        activate ShaderMount
        ShaderMount --> HeroShader: shader (WebGL animation running)
        deactivate ShaderMount
        HeroShader -> Window: addEventListener('beforeunload',\n() => shader.dispose())
    end
end
deactivate HeroShader

== initSplitCompare — Reusable Split View (called by GlassTerminal / LensEffect) ==

Browser -> SplitCompare: initSplitCompare(container, options)
activate SplitCompare
SplitCompare -> DOM: querySelector('.split-container,\n.split-after, .split-divider')
DOM --> SplitCompare: { splitContainer, splitAfter, divider }

alt any element missing
    SplitCompare --> Browser: return null
else all elements found
    SplitCompare -> SplitCompare: recalcSkewOffset()
    note right of SplitCompare
      getBoundingClientRect(splitContainer)
      skewOffset = tan(angle) * height / width
    end note

    SplitCompare -> RO: new ResizeObserver(recalcSkewOffset)
    RO --> SplitCompare: resizeObserver
    SplitCompare -> RO: observe(splitContainer)

    SplitCompare -> SplitCompare: updateSplit(defaultPosition=70)
    note right of SplitCompare
      Sets clip-path on .split-after
      Sets .split-divider left%
    end note

    SplitCompare -> DOM: hitArea.addEventListener\n('mouseenter / mouseleave / mousemove')
    SplitCompare -> DOM: splitContainer.addEventListener\n('touchstart / touchend / touchmove')
    note right of SplitCompare
      On move → targetX updated
      → startAnimation() → rAF(animate)
      → lerp currentX→targetX
      → updateSplit(currentX)

      On threshold cross (>animationThreshold=40%)
      → retriggerAnimations()
    end note

    SplitCompare --> Browser: { destroy(), setPosition(percent) }
end
deactivate SplitCompare

== initThemeToggle — Persistent Theme Preference (standalone) ==

Browser -> ThemeToggle: initThemeToggle()
activate ThemeToggle
ThemeToggle -> DOM: document.querySelector('.theme-toggle')
DOM --> ThemeToggle: toggle | null

alt toggle not found
    ThemeToggle --> Browser: return (no-op)
else toggle found
    ThemeToggle -> LS: localStorage.getItem('impeccable-theme')
    LS --> ThemeToggle: storedTheme | null
    note right of ThemeToggle
      getStoredTheme():
      returns storedTheme || 'system'
    end note

    ThemeToggle -> DOM: html.classList.remove('light', 'dark')
    alt theme === 'light' or 'dark'
        ThemeToggle -> DOM: html.classList.add(theme)
    end
    ThemeToggle -> DOM: update .theme-toggle-btn active states

    ThemeToggle -> DOM: toggle.addEventListener('click')
    note right of ThemeToggle
      On .theme-toggle-btn click:
      setStoredTheme(theme) → localStorage.setItem
      → applyTheme(theme)
    end note

    ThemeToggle -> Window: matchMedia('prefers-color-scheme: dark')\n.addEventListener('change', handler)
    note right of ThemeToggle
      If stored === 'system' or null
      → applyTheme('system')
    end note
end
deactivate ThemeToggle

@enduml
