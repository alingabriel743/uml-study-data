@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceParticipantBorderColor #495057
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceBoxBackgroundColor #E9ECEF
skinparam sequenceBoxBorderColor #6C757D
skinparam noteFontSize 11
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F0C040

title Page Render Utilities Flow

participant "BuildSubPages\n(build-sub-pages.js)" as builder
participant "parseFrontmatter\n(utils.js)" as parser
participant "renderPage\n(render-page.js)" as renderer
participant "readHeaderPartial\n(render-page.js)" as headerReader
participant "applyActiveNav\n(render-page.js)" as navApplier
participant "escapeHtml\n(render-page.js)" as escHtml
participant "escapeAttr\n(render-page.js)" as escAttr
participant "fs\n(node:fs)" as fs
database "FileSystem\n(public/)" as disk

== Parse Markdown Frontmatter ==

builder -> parser : parseFrontmatter(rawMarkdownContent)
activate parser

note right of parser
  Regex: /^---\n([\s\S]*?)\n---\n([\s\S]*)$/
  Parses YAML-style key-value pairs,
  booleans, flat arrays, and object arrays
end note

parser --> builder : { frontmatter: object, body: string }
deactivate parser

== Render Page ==

builder -> renderer : renderPage({ title, description,\nbodyHtml, activeNav, canonicalPath,\nextraHead?, bodyClass?, assetDepth? })
activate renderer

renderer -> headerReader : readHeaderPartial()
activate headerReader

alt cachedHeader is null (first call)
    headerReader -> fs : fs.readFileSync(HEADER_PARTIAL, 'utf8').trim()
    activate fs
    note right of fs
      HEADER_PARTIAL =
      ROOT_DIR/content/site/
      partials/header.html
    end note
    fs --> headerReader : raw HTML string
    deactivate fs
    headerReader -> headerReader : cachedHeader = rawHtml\n(cache populated for future calls)
else cachedHeader already set (subsequent calls)
    headerReader -> headerReader : return cachedHeader (cache hit)
end

headerReader --> renderer : cachedHeader (string)
deactivate headerReader

renderer -> navApplier : applyActiveNav(headerHtml, activeNav)
activate navApplier

alt activeNav is falsy
    navApplier -> navApplier : return headerHtml unchanged
else activeNav is set (e.g. "skills", "tutorials")
    navApplier -> navApplier : regex replace data-nav="{activeNav}"\n→ add aria-current="page"
end

navApplier --> renderer : modified headerHtml
deactivate navApplier

renderer -> escHtml : escapeHtml(title)
activate escHtml
note right of escHtml : Escapes &, <, >, ", '
escHtml --> renderer : safe title string
deactivate escHtml

renderer -> escAttr : escapeAttr(description)
activate escAttr
note right of escAttr : Escapes " only\n(for HTML attribute context)
escAttr --> renderer : safe description string
deactivate escAttr

renderer -> renderer : build <link rel="canonical"> tag\n(if canonicalPath provided)
renderer -> renderer : compute rel prefix\n(e.g. '../' × assetDepth, default=1)
renderer -> renderer : assemble full <!DOCTYPE html> string\n(header + body + inline scripts)

renderer --> builder : complete HTML string
deactivate renderer

== Write Output File ==

builder -> fs : fs.writeFileSync(outPath, html, 'utf-8')
activate fs
note right of builder
  Output paths:
  • public/skills/*.html
  • public/anti-patterns/*.html
  • public/tutorials/*.html
end note
fs -> disk : write HTML file to output directory
activate disk
disk --> fs : (written)
deactivate disk
fs --> builder : (void)
deactivate fs

@enduml
