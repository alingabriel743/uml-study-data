@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequence {
    ArrowColor #495057
    ActorBorderColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    ParticipantBorderColor #495057
    ParticipantBackgroundColor #F8F9FA
    ParticipantFontColor #212529
    BoxBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    NoteBackgroundColor #FFF9C4
    NoteBorderColor #F9A825
}

title Public App Content Loading

actor "Browser / DOM" as DOM

participant "init()" as init
participant "loadContent()" as load
participant "Fetch API" as api
participant "renderTerminalLayout()" as terminal
participant "initGalleryStack()" as gallery
participant "renderPatternsWithTabs()" as tabs
participant "showLoadError()" as errHandler
participant "escapeHtml()" as escape

' ─── Bootstrap ─────────────────────────────────────────────────────────────

alt document.readyState === 'loading'
    DOM -> init : DOMContentLoaded event
else already loaded
    DOM -> init : init() called immediately
end

activate init

note over init
  Setup phase: register all
  UI component initializers
end note

init -> DOM : initAnchorScroll()
init -> DOM : initHashTracking()
init -> DOM : initLensEffect()
init -> DOM : initScrollReveal()
init -> DOM : initGlassTerminal()
init -> DOM : initFrameworkViz()
init -> DOM : initFoundationGrid()
init -> DOM : initSectionNav()

' ─── Async Content Load ────────────────────────────────────────────────────

init -> load : loadContent()  [async]
activate load

note right of load
  Both fetches are launched in
  parallel via Promise.all()
end note

load -> api : GET /api/commands
load -> api : GET /api/patterns

activate api

api --> load : commandsRes (Response)
api --> load : patternsRes (Response)

deactivate api

' ─── Response Validation ───────────────────────────────────────────────────

alt commandsRes.ok === false
    load -> load : throw Error("Commands API failed: <status>")
    load -> errHandler : showLoadError(error)
    activate errHandler
    errHandler -> DOM : querySelector('.commands-gallery')\n→ set innerHTML (error UI)
    errHandler -> DOM : getElementById('patterns-categories')\n→ set innerHTML (error UI)
    deactivate errHandler
else patternsRes.ok === false
    load -> load : throw Error("Patterns API failed: <status>")
    load -> errHandler : showLoadError(error)
    activate errHandler
    errHandler -> DOM : querySelector('.commands-gallery')\n→ set innerHTML (error UI)
    errHandler -> DOM : getElementById('patterns-categories')\n→ set innerHTML (error UI)
    deactivate errHandler
else both responses OK
    load -> load : allCommands = await commandsRes.json()
    load -> load : patternsData = await patternsRes.json()

    ' ─── Render Commands in Glass Terminal ─────────────────────────────────
    load -> terminal : renderTerminalLayout(allCommands)
    activate terminal
    terminal --> load : (commands rendered)
    deactivate terminal

    ' ─── Init Gallery Card Stack ───────────────────────────────────────────
    load -> gallery : initGalleryStack()
    activate gallery

    gallery -> DOM : querySelector('.gallery-stack-container')
    gallery -> DOM : getElementById('gallery-stack')

    alt stack or container not found
        gallery -> gallery : early return (guard)
    else elements found
        gallery -> DOM : bind prev/next button click events
        gallery -> DOM : bind wheel event (debounced, 350 ms)\n→ deltaY > 0 ? next() : prev()
        gallery -> gallery : update() — set card data-offset attributes
    end

    deactivate gallery

    ' ─── Render Patterns with Tabbed Navigation ────────────────────────────
    load -> tabs : renderPatternsWithTabs(\n  patternsData.patterns,\n  patternsData.antipatterns)
    activate tabs

    alt container / patterns / antipatterns missing
        tabs -> tabs : early return (guard)
    else data valid
        note over tabs
          Build antipatternMap{name: items[]}
          for O(1) lookup by category name
        end note

        loop for each category name / tab label
            tabs -> escape : escapeHtml(cat.name)
            activate escape
            escape --> tabs : sanitized category name
            deactivate escape
        end

        loop for each pattern / antipattern item
            tabs -> escape : escapeHtml(item)
            activate escape
            escape --> tabs : sanitized item text
            deactivate escape
        end

        tabs -> DOM : set container.innerHTML\n(tabs + panels HTML)
        tabs -> DOM : addEventListener('click')\non container (event delegation\nfor .patterns-tab clicks)
    end

    deactivate tabs
end

deactivate load

' ─── Body "Loaded" State ───────────────────────────────────────────────────
init -> DOM : document.body.classList.add('loaded')

deactivate init

' ─── Runtime Tab Interaction ───────────────────────────────────────────────
DOM -> DOM : user clicks a tab
note right of DOM
  Event delegation fires on container.
  e.target.closest('.patterns-tab') check;
  null → ignored.
  Tab activated, panel shown.
end note

@enduml
