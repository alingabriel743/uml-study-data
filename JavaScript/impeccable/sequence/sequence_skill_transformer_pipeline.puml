@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    BoxBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    GroupBackgroundColor #DEE2E6
    GroupBorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Skill Transformer Pipeline

participant "build.js\n(Caller)" as build
participant "index.js\n(TransformerIndex)" as index
participant "factory.js\n(createTransformer)" as factory
participant "providers.js\n(PROVIDERS)" as providers
participant "utils.js\n(Utilities)" as utils
participant "FileSystem\n(Disk)" as fs

== Module Initialisation ==

build -> utils : readSourceFiles(ROOT_DIR)
activate utils
utils --> build : skills[]
deactivate utils

build -> providers : import PROVIDERS\n(11 provider configs)
activate providers
providers --> build : PROVIDERS map
deactivate providers

build -> index : import named transformers\n(transformCursor, transformClaudeCode, …)
activate index

loop for each provider key in PROVIDERS
    index -> factory : createTransformer(PROVIDERS[key])
    activate factory
    note right of factory
        Extracts: provider, configDir,
        displayName, frontmatterFields,
        bodyTransform, placeholderProvider.
        Maps frontmatterFields → activeFields
        via FIELD_SPECS allowlist.
    end note
    factory --> index : transform closure
    deactivate factory
end

index --> build : named transformer exports
deactivate index

== Transform Execution (per provider, run twice) ==

loop for each provider (plain run + prefixed run with prefix='i-')
    build -> build : resolve options\n{ prefix, outputSuffix, skillsVersion }
    activate build

    build -> utils : cleanDir(providerDir)
    activate utils
    utils --> build : done
    deactivate utils

    build -> utils : ensureDir(skillsDir)
    activate utils
    utils --> build : done
    deactivate utils

    loop for each skill in skills[]
        build -> build : build frontmatterObj\n{ name, description, version?, activeFields }

        build -> utils : generateYamlFrontmatter(frontmatterObj)
        activate utils
        utils --> build : YAML string
        deactivate utils

        build -> utils : replacePlaceholders(skill.body,\nplaceholderKey, commandNames, allSkillNames)
        activate utils
        note right of utils
            Resolves {{model}}, {{config_file}},
            and other provider-specific tokens.
        end note
        utils --> build : body (placeholders resolved)
        deactivate utils

        build -> build : replace {{scripts_path}}\nwith configDir/skills/skillName/scripts

        opt prefix is set
            build -> utils : prefixSkillReferences(skillBody,\nprefix, allSkillNames, cmdPrefix)
            activate utils
            utils --> build : rewritten body
            deactivate utils
        end

        opt config.bodyTransform is defined
            build -> build : config.bodyTransform(skillBody, skill)
            note right of build
                Provider-specific body
                post-processing hook.
            end note
        end

        build -> fs : writeFile(skillDir/SKILL.md,\nfrontmatter + body)
        activate fs
        fs --> build : ok
        deactivate fs

        opt skill has reference files
            build -> utils : ensureDir(refDir)
            activate utils
            utils --> build : ok
            deactivate utils

            loop for each reference
                build -> utils : replacePlaceholders(ref.content, …)
                activate utils
                utils --> build : resolved content
                deactivate utils
                build -> fs : writeFile(refDir/ref.name.md, content)
                activate fs
                fs --> build : ok
                deactivate fs
            end
        end

        opt skill has script files
            build -> utils : ensureDir(scriptsOutDir)
            activate utils
            utils --> build : ok
            deactivate utils

            loop for each script
                build -> fs : writeFile(scriptsOutDir/script.name,\nscript.content)
                activate fs
                fs --> build : ok
                deactivate fs
            end
        end
    end

    build -> build : console.log summary\n(skills, user-invocable, refs, scripts)
    deactivate build
end

== Post-Transform Distribution ==

build -> fs : copyDirSync(distDir → project configDirs)\n(.claude/skills, .cursor/skills, …)
activate fs
fs --> build : done
deactivate fs

@enduml
