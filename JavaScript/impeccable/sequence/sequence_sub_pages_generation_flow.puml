@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #495057
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceParticipantFontColor #212529
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #495057
skinparam sequenceGroupBackgroundColor #E9ECEF55
skinparam sequenceGroupFontColor #212529
skinparam sequenceBoxBorderColor #6C757D
skinparam sequenceBoxBackgroundColor #DEE2E620
skinparam noteBorderColor #6C757D
skinparam noteBackgroundColor #FFF3CD

title Sub-Pages Generation Flow

' ── Participants ──────────────────────────────────────────────
actor Caller as caller
participant "generateSubPages" as gsp
participant "buildSubPageData" as bspd
participant "readSourceFiles" as rsf
participant "loadCommandDemos" as lcd
participant "readEditorialWrapper" as rew
participant "readAntipatternRules" as rar
participant "fs" as fs
participant "renderMarkdown" as rmd
participant "renderPage" as rp

' ── Entry ──────────────────────────────────────────────────────
caller -> gsp : generateSubPages(rootDir)
activate gsp

' ── 1. DATA LOADING ────────────────────────────────────────────
group Data Loading Phase
    gsp -> bspd : buildSubPageData(rootDir)
    activate bspd

    bspd -> rsf : readSourceFiles(rootDir)
    activate rsf
    rsf --> bspd : { skills: rawSkills[] }
    deactivate rsf

    bspd -> lcd : loadCommandDemos(rootDir)
    activate lcd
    note right of lcd : async — imports JS\ndemo files per skill
    lcd --> bspd : demosMap
    deactivate lcd

    loop per skill
        bspd -> rew : readEditorialWrapper(contentDir, 'skills', skill.name)
        activate rew
        rew --> bspd : { frontmatter, body } | null
        deactivate rew
    end

    bspd -> rar : readAntipatternRules(rootDir)
    activate rar
    note right of rar : reads src/detect-antipatterns.mjs\nextracts ANTIPATTERNS[]\nmerges with LLM_ONLY_RULES
    rar --> bspd : rules[]
    deactivate rar

    bspd -> fs : readdirSync(content/site/tutorials/)
    activate fs
    fs --> bspd : tutorial *.md filenames
    deactivate fs

    bspd --> gsp : { skills, skillsByCategory,\n  knownSkillIds, rules, tutorials }
    deactivate bspd
end

' ── 2. PREPARE OUTPUT DIRS ─────────────────────────────────────
gsp -> fs : rmSync + mkdirSync\n(public/skills/, public/anti-patterns/,\n public/tutorials/, public/visual-mode/)
activate fs
fs --> gsp : dirs ready
deactivate fs

' ── 3. SKILLS INDEX PAGE ───────────────────────────────────────
group Skills Index Page
    gsp -> gsp : renderDocsSidebar(skillsByCategory, tutorials, null)
    gsp -> gsp : renderSkillsOverviewMain(skillsByCategory)
    gsp -> gsp : wrapInDocsLayout(sidebarHtml, mainHtml)
    gsp -> rp : renderPage({ title, description,\n  bodyHtml, activeNav:'docs',\n  canonicalPath:'/skills' })
    activate rp
    rp --> gsp : fullPageHtml
    deactivate rp
    gsp -> fs : writeFileSync('public/skills/index.html')
    activate fs
    fs --> gsp : ok
    deactivate fs
end

' ── 4. SKILL DETAIL PAGES ──────────────────────────────────────
group Skill Detail Pages
    loop per skill
        gsp -> gsp : renderDocsSidebar(skillsByCategory, tutorials,\n  { kind:'skill', id:skill.id })
        gsp -> gsp : renderSkillDetail(skill, knownSkillIds)

        note right of gsp
            renderSkillDetail internally:
            • renderMarkdown(skill.body, { knownSkillIds })
            • renderMarkdown(skill.editorial.body) if present
            • renderSkillDemo(skill) → demo HTML
            • renderMarkdown(ref.content) per reference
        end note

        gsp -> rmd : renderMarkdown(skill.body, options)
        activate rmd
        rmd --> gsp : bodyHtml
        deactivate rmd

        opt editorial present
            gsp -> rmd : renderMarkdown(skill.editorial.body, options)
            activate rmd
            rmd --> gsp : editorialHtml
            deactivate rmd
        end

        gsp -> gsp : wrapInDocsLayout(sidebarHtml, mainHtml)
        gsp -> rp : renderPage({ title, description,\n  bodyHtml,\n  canonicalPath:'/skills/{id}' })
        activate rp
        rp --> gsp : fullPageHtml
        deactivate rp
        gsp -> fs : writeFileSync('public/skills/{id}.html')
        activate fs
        fs --> gsp : ok
        deactivate fs
    end
end

' ── 5. ANTI-PATTERNS INDEX PAGE ────────────────────────────────
group Anti-Patterns Index Page
    gsp -> gsp : groupRulesBySection(data.rules)
    gsp -> gsp : renderAntiPatternsSidebar(grouped)
    gsp -> gsp : renderAntiPatternsMain(grouped, rules.length)
    note right of gsp : renderAntiPatternsMain\ncalls renderRuleCard(rule)\nfor each rule in each section
    gsp -> gsp : wrapInDocsLayout(sidebarHtml, mainHtml)
    gsp -> rp : renderPage({ title,\n  activeNav:'anti-patterns',\n  canonicalPath:'/anti-patterns' })
    activate rp
    rp --> gsp : fullPageHtml
    deactivate rp
    gsp -> fs : writeFileSync('public/anti-patterns/index.html')
    activate fs
    fs --> gsp : ok
    deactivate fs
end

' ── 6. TUTORIALS INDEX PAGE ────────────────────────────────────
group Tutorials Index Page
    gsp -> gsp : renderDocsSidebar(skillsByCategory, tutorials, null)
    gsp -> gsp : renderTutorialsIndexMain(tutorials)
    gsp -> gsp : wrapInDocsLayout(sidebarHtml, mainHtml)
    gsp -> rp : renderPage({ title,\n  canonicalPath:'/tutorials' })
    activate rp
    rp --> gsp : fullPageHtml
    deactivate rp
    gsp -> fs : writeFileSync('public/tutorials/index.html')
    activate fs
    fs --> gsp : ok
    deactivate fs
end

' ── 7. VISUAL MODE PAGE ────────────────────────────────────────
group Visual Mode Page
    gsp -> gsp : renderVisualModeMain()\nnote: uses GALLERY_ITEMS constant
    gsp -> rp : renderPage({ title,\n  activeNav:'visual-mode',\n  canonicalPath:'/visual-mode' })
    activate rp
    rp --> gsp : fullPageHtml
    deactivate rp
    gsp -> fs : writeFileSync('public/visual-mode/index.html')
    activate fs
    fs --> gsp : ok
    deactivate fs
end

' ── 8. TUTORIAL DETAIL PAGES ───────────────────────────────────
group Tutorial Detail Pages
    loop per tutorial
        gsp -> gsp : renderDocsSidebar(skillsByCategory, tutorials,\n  { kind:'tutorial', slug })
        gsp -> gsp : renderTutorialDetail(tutorial, knownSkillIds)

        gsp -> rmd : renderMarkdown(tutorial.body, { knownSkillIds })
        activate rmd
        rmd --> gsp : bodyHtml
        deactivate rmd

        gsp -> gsp : wrapInDocsLayout(sidebarHtml, mainHtml)
        gsp -> rp : renderPage({ title,\n  canonicalPath:'/tutorials/{slug}' })
        activate rp
        rp --> gsp : fullPageHtml
        deactivate rp
        gsp -> fs : writeFileSync('public/tutorials/{slug}.html')
        activate fs
        fs --> gsp : ok
        deactivate fs
    end
end

' ── Return ─────────────────────────────────────────────────────
gsp --> caller : { files: string[] }
deactivate gsp

@enduml
