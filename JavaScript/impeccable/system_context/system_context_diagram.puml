@startuml
title Impeccable — System Context Diagram

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actor {
    BackgroundColor<<Person>> #08427B
    FontColor<<Person>> #FFFFFF
    BorderColor<<Person>> #052E56
}

skinparam package {
    BackgroundColor #F5F5F5
    BorderColor #BDBDBD
    FontColor #424242
    FontStyle bold
}

skinparam arrow {
    Color #424242
    FontSize 10
    FontColor #616161
}

' ── Actors ──────────────────────────────────────────────────────────────────
actor "End User
[Browser / Web]" as enduser <<Person>>

actor "AI Coding Agent
[Claude, Cursor, etc.]" as aiagent <<Person>>

actor "Developer / CI-CD
[Node ≥18 / Bun]" as developer <<Person>>

actor "Browser User
[Chrome DevTools]" as chromeuser <<Person>>

' ── Core System ─────────────────────────────────────────────────────────────
rectangle "**Impeccable**
[JavaScript Library · CLI · Website · Extension]

Design anti-pattern detection engine
for AI coding agents and developers.
Detects CSS/HTML/UX issues in HTML files,
raw strings, URLs, and live web pages." as system <<System>>

' ── Hosting & Deployment ────────────────────────────────────────────────────
package "Hosting & Deployment" {
    rectangle "**Cloudflare Pages**
[Static Hosting + Functions]

Hosts impeccable.style,
serves the marketing site,
docs, gallery, and skill pages.
Runs API download Workers." as cloudflare <<Infrastructure>>

    rectangle "**GitHub**
[Source Control + CI/CD]

Hosts source code,
triggers builds and tests,
manages releases." as github <<External>>
}

' ── Package Distribution ─────────────────────────────────────────────────────
package "Package Distribution" {
    rectangle "**npm Registry**
[Package Repository]

Publishes the 'impeccable'
package (v2.1.7) for programmatic
use and CLI installation." as npm <<External>>

    rectangle "**Chrome Web Store**
[Extension Marketplace]

Distributes the Impeccable
Chrome DevTools extension
for browser-based scanning." as chromestore <<External>>
}

' ── Headless Browser Runtime ─────────────────────────────────────────────────
package "Headless Browser Runtime" {
    rectangle "**Puppeteer + Chromium**
[Headless Browser — optional dep]

Used for URL scanning mode:
renders target pages and runs
the detector script in-browser." as puppeteer <<External>>

    rectangle "**Playwright + Chromium**
[Headless Browser — dev tool]

Used to generate OG images,
promo tiles, and anti-pattern
screenshots during builds." as playwright <<External>>
}

' ── External Services ────────────────────────────────────────────────────────
package "External Services" {
    rectangle "**Google Fonts API**
[fonts.googleapis.com]

Provides web typography
(Cormorant Garamond,
Instrument Sans, Space Grotesk)
for the marketing website." as googlefonts <<External>>

    rectangle "**Target Websites**
[User-supplied URLs]

Any publicly accessible
web page submitted by users
for anti-pattern analysis." as targetweb <<External>>
}

' ── Runtime Dependencies ─────────────────────────────────────────────────────
package "Runtime Dependencies" {
    rectangle "**jsdom**
[HTML DOM Emulation]

Parses and emulates a
browser DOM for CLI analysis
of raw HTML strings and files." as jsdom <<External>>

    rectangle "**Bun Runtime**
[JavaScript Runtime + Server]

Powers the local dev server
(port 3000), build pipeline,
and test runner." as bun <<External>>
}

' ── Relationships ────────────────────────────────────────────────────────────

' End users interact with the hosted site
enduser --> system : "HTTPS\n(Browse impeccable.style,\ndownload skills & commands)"

' AI agents use the npm library
aiagent --> system : "npm import\n(programmatic anti-pattern\ndetection in agent context)"

' Developer / CI-CD uses the CLI
developer --> system : "CLI / Node.js\n(impeccable scan HTML/URL,\nrun in CI pipelines)"

' Chrome extension user
chromeuser --> system : "Chrome Extension API\n(DevTools panel — scan\nlive pages in browser)"

' System is deployed to Cloudflare
system --> cloudflare : "Wrangler Pages Deploy\n(build artefacts + Cloudflare\nWorker Functions)"

' Cloudflare serves end users
cloudflare --> enduser : "HTTPS\n(static site, HTML pages,\ndownloadable assets)"

' GitHub CI/CD
developer --> github : "git push / PR\n(source control,\nCI triggers)"
github --> system : "GitHub Actions\n(build, test, deploy)"

' npm publishing
system --> npm : "npm publish\n(package + CLI release\nfor Node ≥18 users)"
npm --> aiagent : "npm install\n(library download)"
npm --> developer : "npm install -g\n(CLI installation)"

' Chrome Web Store
system --> chromestore : "Extension ZIP upload\n(Chrome Web Store\npublish via wrangler/CI)"
chromestore --> chromeuser : "Extension install\n(Chrome Web Store\nbrowser download)"

' Puppeteer for URL scanning
system --> puppeteer : "puppeteer.launch()\n(headless Chromium —\nURL-mode scanning)"
puppeteer --> targetweb : "HTTPS GET\n(load & render\ntarget pages)"

' Playwright for build-time image gen
system --> playwright : "chromium.launch()\n(screenshot generation,\nOG image & promo tile)"

' Google Fonts loaded by website
system --> googlefonts : "HTTPS\n(preconnect + stylesheet\nfor web typography)"

' jsdom for CLI HTML parsing
system --> jsdom : "Node.js require\n(DOM parsing for\nHTML file / string mode)"

' Bun runtime
bun --> system : "Bun serve / bun run\n(local dev server\n& build pipeline)"

@enduml
