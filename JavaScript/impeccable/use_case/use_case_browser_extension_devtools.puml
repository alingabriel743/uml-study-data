@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam ArrowColor #495057

title Browser Extension: DevTools Panel & Sidebar

left to right direction

' ── Primary Actor ──────────────────────────────────────────
actor "DevTools User" as DevUser

' ── Secondary / External Actors ────────────────────────────
actor "Service Worker\n(background)" as SW #D0E8FF
actor "Content Script\n(injected tab)" as CS #D0E8FF
actor "chrome.storage.sync" as Storage #D8F0D8

' ── System Boundary ─────────────────────────────────────────
rectangle "Browser Extension: DevTools Panel & Sidebar" {

    ' ── Panel lifecycle ─────────────────────────────────────
    usecase "Open DevTools Panel" as UC01
    usecase "Auto-Reconnect Port\non SW Restart" as UC16

    ' ── Scanning ────────────────────────────────────────────
    usecase "Auto-Scan on\nDevTools Open" as UC02
    usecase "Scan / Rescan Page" as UC03
    usecase "Re-Scan on\nPage Navigation" as UC17

    ' ── Findings display ────────────────────────────────────
    usecase "View Anti-Pattern\nFindings" as UC04
    usecase "View Findings for\nSelected Element\n(Sidebar)" as UC15

    ' ── Element interaction ──────────────────────────────────
    usecase "Hover Finding to\nHighlight Element" as UC06
    usecase "Click Finding to\nInspect Element" as UC07
    usecase "Toggle Overlays" as UC05

    ' ── Copy ────────────────────────────────────────────────
    usecase "Copy Single Finding" as UC08
    usecase "Copy All Findings" as UC09

    ' ── Settings ────────────────────────────────────────────
    usecase "Open Settings Panel" as UC10
    usecase "Toggle Individual\nRule (Enable/Disable)" as UC11
    usecase "Configure Line\nLength Mode" as UC12
    usecase "Configure\nSpotlight Blur" as UC13
    usecase "Configure\nAuto-Scan Mode" as UC14
}

' ── DevTools User associations ──────────────────────────────
DevUser --> UC01
DevUser --> UC03
DevUser --> UC04
DevUser --> UC05
DevUser --> UC06
DevUser --> UC07
DevUser --> UC08
DevUser --> UC09
DevUser --> UC10
DevUser --> UC11
DevUser --> UC12
DevUser --> UC13
DevUser --> UC14
DevUser --> UC15

' ── Service Worker associations ─────────────────────────────
UC03 --> SW : triggers scan
UC05 --> SW : toggle-overlays
UC06 --> SW : highlight/unhighlight
UC17 --> SW : navigated event
SW --> UC04 : delivers findings
SW --> UC02 : triggers on connect
SW --> UC16

' ── Content Script associations ─────────────────────────────
SW --> CS : scan / highlight / toggle
CS --> SW : findings result

' ── Storage associations ────────────────────────────────────
UC11 --> Storage : save disabledRules
UC12 --> Storage : save lineLengthMode
UC13 --> Storage : save spotlightBlur
UC14 --> Storage : save autoScan
UC02 --> Storage : read autoScan

' ── Include relationships ────────────────────────────────────
UC02 ..> UC03 : <<include>>
UC03 ..> UC04 : <<include>>
UC06 ..> UC05 : <<include>>
UC11 ..> UC10 : <<include>>

' ── Extend relationships ─────────────────────────────────────
UC11 ..> UC03 : <<extend>>
UC12 ..> UC03 : <<extend>>
UC13 ..> UC03 : <<extend>>
UC15 ..> UC04 : <<extend>>
UC16 ..> UC01 : <<extend>>
UC17 ..> UC03 : <<extend>>

@enduml
