@startuml use_case_browser_extension_popup

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Browser Extension: Popup Scan & Overlay Controls

left to right direction

' ─── Actors ───────────────────────────────────────────────
actor "Extension User" as User

actor "Service Worker\n(service-worker.js)" as SW <<system>>
actor "Content Script\n(content-script.js)" as CS <<system>>
actor "Detector\n(detect.js)" as Detector <<system>>

' ─── System boundary ──────────────────────────────────────
rectangle "Browser Extension Popup (popup.js)" {

    usecase "Scan Page" as UC1
    usecase "View Findings Count" as UC2
    usecase "Toggle Overlays" as UC3
    usecase "Load Popup State on Open" as UC4

    usecase "Inject Content Script\n(ensureContentScriptInjected)" as UC_Inject <<include>>
    usecase "Load Scan Config\n(buildScanConfig)" as UC_Config <<include>>
}

' ─── Primary actor → use cases ────────────────────────────
User --> UC1 : clicks "Scan page"
User --> UC3 : clicks "Hide / Show overlays"
User --> UC4 : opens popup

' ─── Include / Extend relationships ───────────────────────
UC1 ..> UC_Inject  : <<include>>
UC1 ..> UC_Config  : <<include>>
UC1 ..> UC2        : <<extend>>\n(scan complete →\nfindings-updated)
UC3 ..> UC4        : <<extend>>\n(toggle broadcast →\nbutton state sync)

' ─── System actor participations ──────────────────────────
UC1 --> SW       : sendMessage\n{ action: 'scan', tabId }
UC2 --> SW       : sendMessage\n{ action: 'get-state', tabId }
UC3 --> SW       : sendMessage\n{ action: 'toggle-overlays', tabId }
UC4 --> SW       : sendMessage\n{ action: 'get-state', tabId }

SW --> CS        : tabs.sendMessage\n{ action: 'scan' / 'toggle-overlays' }
CS --> Detector  : postMessage\n{ source: 'impeccable-command' }
Detector --> CS  : postMessage\n{ source: 'impeccable-results' /\n'impeccable-overlays-toggled' }
CS --> SW        : sendMessage\n{ action: 'findings' / 'overlays-toggled' }
SW --> UC2       : broadcast\n{ action: 'findings-updated' }
SW --> UC3       : broadcast\n{ action: 'overlays-toggled-broadcast' }

@enduml
