@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Build Pipeline: Browser Extension Packaging

left to right direction

actor "Developer / CI" as devci
actor "Puppeteer\n(Headless Browser)" as puppeteer
actor "archiver\n(ZIP Library)" as archiver

rectangle "Extension Build System" {

    package "Extension Detector Build\n(build-extension.js)" {
        usecase "Build Extension\nDetector Script" as UC1
        usecase "Extract Antipatterns\nJSON Metadata" as UC2
        usecase "Package Extension\nas ZIP" as UC3
        note right of UC1
          Strips shebang + @browser-strip
          blocks, sets IS_BROWSER=true,
          wraps in IIFE →
          extension/detector/detect.js
        end note
        note right of UC2
          Parses ANTIPATTERNS array
          via new Function() →
          extension/detector/antipatterns.json
        end note
        note right of UC3
          execSync('zip -r dist/extension.zip .')
          → dist/extension.zip
          (Chrome Web Store upload)
        end note
    }

    package "Icon Generation\n(generate-extension-icons.js)" {
        usecase "Generate Extension\nIcons (PNG)" as UC4
        note bottom of UC4
          SVG → setViewport + screenshot
          → icon-16/32/48/128.png
        end note
    }

    package "Standalone Browser Build\n(build-browser-detector.js)" {
        usecase "Build Standalone\nBrowser Detector" as UC5
        note bottom of UC5
          Same IIFE transforms as UC1 →
          src/detect-antipatterns-browser.js
        end note
    }

    package "Provider Distribution\n(scripts/lib/zip.js)" {
        usecase "Create Provider\nZIP Bundles" as UC6
        note bottom of UC6
          archiver zlib level 9 →
          dist/universal.zip
          dist/universal-prefixed.zip
        end note
    }

    usecase "Read Source File\n(detect-antipatterns.mjs)" as SHARED
}

' Developer / CI → primary build tasks
devci --> UC1
devci --> UC2
devci --> UC3
devci --> UC4
devci --> UC5
devci --> UC6

' External actors driving specific use cases
puppeteer --> UC4
archiver --> UC6

' Include / extend relationships
UC1 ..> SHARED : <<include>>
UC2 ..> SHARED : <<include>>
UC5 ..> SHARED : <<include>>

UC2 ..> UC1 : <<extend>>\n(reads same source)

' Output annotations (notes as artifacts outside boundary)
note as N1
  <b>Inputs</b>
  src/detect-antipatterns.mjs
  extension/icons/icon.svg
end note

note as N2
  <b>Outputs</b>
  extension/detector/detect.js
  extension/detector/antipatterns.json
  dist/extension.zip
  extension/icons/icon-{16,32,48,128}.png
  src/detect-antipatterns-browser.js
  dist/universal.zip
  dist/universal-prefixed.zip
end note

@enduml
