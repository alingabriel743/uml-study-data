@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #343A40
    FontColor #212529
    BorderThickness 2
}

title Build Pipeline: Website Generation

left to right direction

' ── External Actors ──────────────────────────────────────────────
actor "Developer" as developer
actor "Bun Bundler" as bun
actor "Playwright\n(Chromium)" as playwright
actor "Puppeteer\n(Chrome)" as puppeteer
actor "File System" as fs
actor "Cloudflare Pages" as cf

' ── System Boundary ──────────────────────────────────────────────
rectangle "Build Pipeline  (build.js)" {

    ' ─── Sub-Page Generation ─────────────────────────────────────
    package "Sub-Page Generation" #EAF4FB {
        usecase "Generate Sub-Pages" as UC01
        usecase "Render Skills\nIndex & Detail Pages" as UC01a
        usecase "Render Anti-Patterns\nPage" as UC01b
        usecase "Render Tutorials\nIndex & Detail Pages" as UC01c
        usecase "Render Visual\nMode Page" as UC01d
        usecase "Render Shared\nDocs Sidebar" as UC01e
    }

    ' ─── Site Bundling & Static Assets ───────────────────────────
    package "Site Bundling & Static Assets" #EAF7EF {
        usecase "Build Static Site\n(HTML Bundle)" as UC02
    }

    ' ─── API & Cloudflare Config ─────────────────────────────────
    package "API & Cloudflare Config" #F5EEFF {
        usecase "Generate Static\nAPI Data" as UC07
        usecase "Generate Cloudflare\nPages Config" as UC08
    }

    ' ─── Validation Gates ────────────────────────────────────────
    package "Validation Gates" #FDECEA {
        usecase "Generate Authoritative\nCounts" as UC09
        usecase "Validate Antipattern\nRules" as UC10
    }

    ' ─── Standalone Asset Scripts ────────────────────────────────
    package "Standalone Asset Scripts" #F0F0F0 {
        usecase "Generate OG Image\n(1200x630 JPEG)" as UC13
        usecase "Generate Promo Tile\n(440x280 PNG)" as UC14
    }

}

' ── Actor → Use Case Associations ────────────────────────────────

' Developer triggers the main build and standalone scripts
developer --> UC01
developer --> UC02
developer --> UC13 : bun run og-image
developer --> UC14 : bun run promo-tile

' Bun Bundler performs HTML/JS/CSS minification and hashing
bun --> UC02

' Headless browsers power image generation
playwright --> UC13
puppeteer --> UC14

' File System as source and sink
fs --> UC01 : reads source/skills/,\nsource/tutorials/
fs --> UC10 : reads SKILL.md &\ndetect-antipatterns.mjs
UC02 --> fs : writes build/
UC07 --> fs : writes build/_data/api/
UC08 --> fs : writes _headers,\n_redirects, _routes.json
UC09 --> fs : writes public/js/\ngenerated/counts.js
UC13 --> fs : writes public/og-image.jpg
UC14 --> fs : writes extension/icons/\npromo-small.png

' Cloudflare Pages consumes the final build output
cf --> UC02 : deploys build/
cf --> UC08 : reads CF config

' ── <<include>> Relationships ────────────────────────────────────

' Generate Sub-Pages delegates to each page renderer
UC01 ..> UC01a : <<include>>
UC01 ..> UC01b : <<include>>
UC01 ..> UC01c : <<include>>
UC01 ..> UC01d : <<include>>

' Every docs page renderer includes the shared sidebar
UC01a ..> UC01e : <<include>>
UC01b ..> UC01e : <<include>>
UC01c ..> UC01e : <<include>>
UC01d ..> UC01e : <<include>>

' Sub-page HTML files are passed as entrypoints to the bundler
UC01 ..> UC02 : <<include>>

@enduml
