@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #FFFFFF
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9E6
    BorderColor #CCA800
    FontColor #212529
    FontSize 10
}
skinparam ArrowColor #495057

left to right direction

title CLI: Detect Anti-Patterns

' ── Actors ──────────────────────────────────────────
actor "Developer" as dev
actor "FileSystem" as fs
actor "Puppeteer\n(headless browser)" as puppeteer <<external>>
actor "jsdom\n(DOM engine)" as jsdom <<external>>

' ── System boundary ──────────────────────────────────
rectangle "Impeccable CLI  |  detect command" {

    ' Entry points
    usecase "Run detect command\n<size:10>impeccable detect [options] [targets]</size>" as UC1
    usecase "View help\n<size:10>--help flag</size>" as UC8
    usecase "View version\n<size:10>--version / -v flag</size>" as UC9

    ' Scan modes (one chosen per invocation)
    usecase "Scan directory\nfor anti-patterns" as UC2
    usecase "Scan single file\nfor anti-patterns" as UC3
    usecase "Scan URL\nfor anti-patterns" as UC4
    usecase "Scan stdin input" as UC5

    ' Analysis pipelines
    usecase "Analyze HTML file\n<size:10>jsdom pipeline — element & page checks</size>" as UC6
    usecase "Analyze non-HTML file\n<size:10>regex pipeline — REGEX_MATCHERS / ANALYZERS</size>" as UC7

    ' Output
    usecase "Report findings\n<size:10>grouped text  |  --json array output</size>" as UC10
}

' ── Developer interactions ───────────────────────────
dev --> UC1
dev --> UC8
dev --> UC9

' ── UC1 delegates to a scan mode (alternatives) ──────
UC1 ..> UC2  : <<include>>
UC1 ..> UC3  : <<include>>
UC1 ..> UC4  : <<include>>
UC1 ..> UC5  : <<include>>
UC1 ..> UC10 : <<include>>

' ── Scan modes invoke analysis pipelines ─────────────
UC2 ..> UC6 : <<include>>
UC2 ..> UC7 : <<include>>
UC6 <.. UC3 : <<extend>>
UC7 <.. UC3 : <<extend>>

' ── External system dependencies ─────────────────────
UC2    --> fs
UC3    --> fs
UC7    --> fs
UC4    --> puppeteer
UC6    --> jsdom

' ── Clarifying notes ─────────────────────────────────
note bottom of UC2
  walkDir() — skips node_modules, dist, .git
  buildImportGraph() — annotates importedBy
  detectFrameworkConfig() — Vite/Next/Nuxt/SvelteKit hint
  confirm() prompt if >50 files
end note

note bottom of UC7
  Supported: .css .scss .less
  .js .ts .jsx .tsx
  .vue .svelte .astro
  Extracts <style> blocks from SFCs
  Extracts CSS-in-JS template literals
end note

note top of UC6
  Inlines linked local stylesheets
  Element checks: borders, colors, glow,
    motion, icon-tile, quality
  Page checks: typography, layout,
    quality, HTML patterns
  --fast flag skips jsdom → uses UC7
end note

note bottom of UC10
  Exit 0: no findings (clean)
  Exit 2: one or more anti-patterns found
  Fields: file · line · antipattern id
          snippet · description · importedBy
end note

@enduml
