@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam ArrowColor #495057
skinparam ArrowFontColor #495057
skinparam ArrowFontSize 11
skinparam ArrowThickness 1.2
skinparam NoteBackgroundColor #FFF9C4
skinparam NoteBorderColor #F9A825

title CLI: Live Browser Detection Mode

left to right direction

actor "Developer" as Dev
actor "Browser\n(User Agent)" as Browser

rectangle "Impeccable Live Detection System" {

    ' ── Server Lifecycle ──────────────────────────────
    package "Server Lifecycle" {
        usecase "Start Live Server\n<size:10>npx impeccable live [--port]</size>" as UC1
        usecase "Find Open Port\n<size:10>findOpenPort(start=8400)</size>" as UC1a
        usecase "Write PID File\n<size:10>os.tmpdir()/impeccable-live.json</size>" as UC1b
        usecase "Print Inject Snippet\n<size:10>to console</size>" as UC1c

        usecase "Stop Live Server\n<size:10>npx impeccable live stop</size>" as UC2
        usecase "Remote Stop via HTTP\n<size:10>GET /stop → shutdown()</size>" as UC7

        usecase "View Live Mode Help\n<size:10>npx impeccable live --help</size>" as UC3
    }

    ' ── Browser Injection ─────────────────────────────
    package "Browser Overlay Injection" {
        usecase "Inject Overlay Script\n<size:10>run snippet in browser console</size>" as UC4
        usecase "Fetch Overlay Bundle\n<size:10>GET /detect.js (CORS: *)</size>" as UC4a
    }

    ' ── Real-Time Detection ───────────────────────────
    package "Real-Time Anti-Pattern Detection" {
        usecase "Scan DOM for Anti-Patterns\n<size:10>overlay script runs in page</size>" as UC5
        usecase "Render Overlay Highlights\n<size:10>CSS boxes + banner (z-index 100001+)</size>" as UC5a
        usecase "Toggle Overlays\n<size:10>◉/◎ button or postMessage</size>" as UC5b
        usecase "Re-Scan Page\n<size:10>remove overlays, re-run detection</size>" as UC5c
    }

    ' ── Server HTTP Endpoints ─────────────────────────
    package "Server HTTP Endpoints" {
        usecase "Health Check\n<size:10>GET /health → {status:'ok', port}</size>" as UC6
    }

}

' ── Actor → Use Case associations ────────────────────
Dev --> UC1
Dev --> UC2
Dev --> UC3
Dev --> UC4

Browser --> UC4a
Browser --> UC5
Browser --> UC6
Browser --> UC7

' ── Include / Extend relationships ───────────────────
UC1 ..> UC1a : <<include>>
UC1 ..> UC1b : <<include>>
UC1 ..> UC1c : <<include>>

UC2 ..> UC7  : <<include>>

UC4 ..> UC4a : <<include>>
UC4a .right.> UC5 : <<extend>>

UC5 ..> UC5a : <<include>>
UC5b .up.> UC5 : <<extend>>
UC5c .up.> UC5 : <<extend>>

' ── Notes ─────────────────────────────────────────────
note right of UC1
  Server binds to
  127.0.0.1 (loopback only).
  SIGINT/SIGTERM call shutdown()
  for clean exit.
end note

note bottom of UC5
  IntersectionObserver reveals
  overlays lazily (60 ms stagger,
  max 600 ms) as elements enter
  the viewport.
end note

@enduml
