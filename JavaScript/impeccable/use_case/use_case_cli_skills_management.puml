@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7FC1
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343A40
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontColor #4E342E
}

title CLI: Skills Management

left to right direction

' ─── Actors ───────────────────────────────────────────────────────────────
actor "Developer" as Dev

actor "ImpeccableStyle API\n(impeccable.style)" as API #D5F5E3 #1E8449
actor "npx skills\n(NpxSkills)" as Npx #FAD7A0 #A04000

' ─── System boundary ──────────────────────────────────────────────────────
rectangle "impeccable skills CLI  (bin/commands/skills.mjs)" {

    usecase "List Available Skills\n<size:10>impeccable skills [help]</size>" as UC1
    usecase "Install Skills\n<size:10>impeccable skills install [--force] [-y] [--prefix=p]</size>" as UC2
    usecase "Update Skills\n<size:10>impeccable skills update [-y]</size>" as UC3
    usecase "Check for Updates\n<size:10>impeccable skills check</size>" as UC4

    usecase "Find Project Root\n<size:10>walk up from cwd to .git</size>" as UC_Root
    usecase "Check Already Installed\n<size:10>scan PROVIDER_DIRS for sentinel</size>" as UC_Check
    usecase "Apply Skill Prefix\n<size:10>rename dirs + rewrite /command refs</size>" as UC_Prefix
    usecase "Download & Extract Bundle\n<size:10>GET /api/download/bundle/universal</size>" as UC_Bundle
    usecase "Compare Skill Hashes\n<size:10>normalise + SHA256 SKILL.md</size>" as UC_Hash
    usecase "Deduplicate Providers\n<size:10>resolve symlinks (.claude → .agents)</size>" as UC_Dedup
    usecase "Cleanup Deprecated Skills\n<size:10>run cleanup-deprecated.mjs</size>" as UC_Cleanup

}

' ─── Developer → primary use cases ────────────────────────────────────────
Dev --> UC1
Dev --> UC2
Dev --> UC3
Dev --> UC4

' ─── UC1: List Available Skills ───────────────────────────────────────────
UC1 --> API : GET /api/commands

' ─── UC2: Install Skills ──────────────────────────────────────────────────
UC2 ..> UC_Root    : <<include>>
UC2 ..> UC_Check   : <<include>>
UC2 --> Npx       : npx skills add pbakaus/impeccable
UC2 ..> UC_Prefix  : <<include>>\n[if prefix chosen]
UC2 ..> UC_Cleanup : <<extend>>\n[optional post-install]

' ─── UC3: Update Skills ───────────────────────────────────────────────────
UC3 ..> UC_Root    : <<include>>
UC3 ..> UC_Bundle  : <<include>>
UC3 ..> UC_Hash    : <<include>>
UC3 ..> UC_Dedup   : <<include>>
UC3 ..> UC_Prefix  : <<include>>\n[re-apply detected prefix]
UC3 ..> UC_Cleanup : <<extend>>\n[optional pre/post-update]
UC3 --> API       : GET /api/download/bundle/universal

' ─── UC4: Check for Updates ───────────────────────────────────────────────
UC4 ..> UC_Root   : <<include>>
UC4 ..> UC_Check  : <<include>>
UC4 ..> UC_Bundle : <<include>>
UC4 ..> UC_Hash   : <<include>>
UC4 --> API      : GET /api/download/bundle/universal

' ─── UC3 / UC4 relationship ───────────────────────────────────────────────
UC3 ..> UC4 : <<extend>>\n[performs same up-to-date check]

' ─── Notes ────────────────────────────────────────────────────────────────
note right of UC2
  install delegates actual
  file placement to npx skills;
  only prefix/cleanup logic
  is handled internally.
end note

note right of UC3
  update bypasses
  npx skills update (upstream bug)
  and downloads directly from API.
end note

note bottom of UC_Hash
  SKILL.md hashes are normalised
  (strip provider paths + version field)
  for portable comparison across
  install methods.
end note

@enduml
