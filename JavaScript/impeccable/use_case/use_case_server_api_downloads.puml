@startuml use_case_server_api_downloads

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Server API: File & Bundle Downloads

left to right direction

actor "API Consumer" as consumer

rectangle "Server API: File & Bundle Downloads" {

    ' ── Primary use cases ──────────────────────────────────────────
    usecase "Download Individual File\n<size:10>GET /api/download/:type/:provider/:id</size>" as UC_FileDownload
    usecase "Download Bundle\n<size:10>GET /api/download/bundle/:provider</size>" as UC_BundleDownload

    ' ── Validation sub-use cases ───────────────────────────────────
    usecase "Validate Type\n<size:10>isAllowedType(type)\n['skill', 'command']</size>" as UC_ValidateType
    usecase "Validate File Provider\n<size:10>isAllowedFileProvider(provider)\nFILE_DOWNLOAD_PROVIDERS</size>" as UC_ValidateFileProvider
    usecase "Validate ID\n<size:10>isValidId(id)\n/^[a-zA-Z0-9_-]+$/</size>" as UC_ValidateId
    usecase "Resolve File Path\n<size:10>getFilePath(type, provider, id)\ndist/{provider}/{configDir}/skills/{id}/SKILL.md</size>" as UC_ResolvePath
    usecase "Validate Bundle Provider\n<size:10>isAllowedBundleProvider(provider)\n['universal', 'universal-prefixed']</size>" as UC_ValidateBundleProvider

    ' ── Exception / extension use cases ───────────────────────────
    usecase "File Not Found\n<size:10>404 — file missing on disk</size>" as UC_FileNotFound
    usecase "Bundle Not Found\n<size:10>404 — zip missing on disk</size>" as UC_BundleNotFound

    ' ── Sanitise & stream (shared behaviour) ──────────────────────
    usecase "Sanitize Filename\n<size:10>sanitizeFilename()\nstrips non-[a-zA-Z0-9._-] chars</size>" as UC_Sanitize
    usecase "Stream File Response\n<size:10>Content-Type: application/octet-stream\nContent-Disposition: attachment</size>" as UC_StreamFile
    usecase "Stream Zip Response\n<size:10>Content-Type: application/zip\nContent-Disposition: attachment;\nfilename='impeccable-style-{provider}.zip'</size>" as UC_StreamZip
}

' ── Actor associations ─────────────────────────────────────────────
consumer --> UC_FileDownload
consumer --> UC_BundleDownload

' ── Include relationships (mandatory sub-flows) ────────────────────
UC_FileDownload ..> UC_ValidateType        : <<include>>
UC_FileDownload ..> UC_ValidateFileProvider : <<include>>
UC_FileDownload ..> UC_ValidateId          : <<include>>
UC_FileDownload ..> UC_ResolvePath         : <<include>>
UC_FileDownload ..> UC_Sanitize            : <<include>>
UC_FileDownload ..> UC_StreamFile          : <<include>>

UC_BundleDownload ..> UC_ValidateBundleProvider : <<include>>
UC_BundleDownload ..> UC_Sanitize               : <<include>>
UC_BundleDownload ..> UC_StreamZip              : <<include>>

' ── Extend relationships (exceptional / alternative flows) ─────────
UC_FileNotFound  ..> UC_FileDownload   : <<extend>>
UC_BundleNotFound ..> UC_BundleDownload : <<extend>>

note right of UC_FileDownload
  Failure responses:
  400 Invalid type
  400 Invalid provider
  400 Invalid file ID
  400 Invalid provider (null path)
  404 File not found
  500 Error downloading file
end note

note right of UC_BundleDownload
  Failure responses:
  400 Invalid provider
  404 Bundle not found
  500 Error downloading bundle
end note

note bottom of UC_ResolvePath
  Provider → config dir mapping:
  cursor → .cursor  |  claude-code → .claude
  gemini → .gemini  |  codex → .codex
  agents → .agents  |  kiro → .kiro
  opencode → .opencode  |  pi → .pi
end note

@enduml
