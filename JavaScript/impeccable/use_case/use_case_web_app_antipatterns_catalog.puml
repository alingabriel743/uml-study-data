@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Web App: Anti-Patterns Catalog

left to right direction

actor "Web Visitor" as visitor
actor "Dev Server\n(Bun)" as devServer
actor "Build System" as buildSystem

rectangle "Anti-Patterns Catalog  (/anti-patterns)" {

    usecase "Browse Anti-Patterns\nCatalog" as UC_Browse
    usecase "View Rule Card\n(id, name, category,\ndescription, visual example)" as UC_ViewCard
    usecase "Navigate Sections\nvia Sidebar TOC" as UC_Sidebar
    usecase "Distinguish Detection\nLayer (CLI / Browser / LLM)" as UC_Layer
    usecase "Expand 'How to Read\nThis' Legend" as UC_Legend
    usecase "View Gallery of\nReal-World Specimens\n(11 items)" as UC_Gallery
    usecase "View Live Specimen\nPage\n(/antipattern-examples/{id})" as UC_Specimen

    usecase "Serve Static\nCatalog Page\n(GET /anti-patterns)" as UC_Serve
    usecase "Fetch Patterns\nvia API\n(GET /api/patterns)" as UC_API

    usecase "Build Anti-Patterns\nStatic Page\n(public/anti-patterns/index.html)" as UC_Build
    usecase "Screenshot Anti-Pattern\nExamples\n(Playwright → PNG thumbnails)" as UC_Screenshot

}

' Web Visitor interactions
visitor --> UC_Browse
visitor --> UC_ViewCard
visitor --> UC_Sidebar
visitor --> UC_Legend
visitor --> UC_Gallery
visitor --> UC_Specimen

' Dev Server interactions
devServer --> UC_Serve
devServer --> UC_API

' Build System interactions
buildSystem --> UC_Build
buildSystem --> UC_Screenshot

' Include relationships (sub-steps of browsing)
UC_Browse ..> UC_ViewCard      : <<include>>
UC_Browse ..> UC_Sidebar       : <<include>>
UC_ViewCard ..> UC_Layer       : <<include>>

' Extend relationships (optional deeper navigation)
UC_Gallery <.. UC_Specimen     : <<extend>>

' Build feeds runtime
UC_Build ..> UC_Serve         : <<feeds>>
UC_Screenshot ..> UC_Gallery  : <<feeds>>

@enduml
