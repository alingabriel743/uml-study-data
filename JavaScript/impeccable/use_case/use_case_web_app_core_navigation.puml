@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Web App: Core Site Navigation

left to right direction

actor "Web Visitor" as visitor

rectangle "impeccable.style — Bun Web Server" {

    ' ── Static page entry points ──────────────────────────────
    package "Static Pages" {
        usecase "View Homepage\n<size:10>(GET /)</size>" as UC1
        usecase "View Cheatsheet\n<size:10>(GET /cheatsheet)</size>" as UC2
        usecase "View Gallery\n<size:10>(GET /gallery)</size>" as UC3
        usecase "View Privacy Policy\n<size:10>(GET /privacy)</size>" as UC4
    }

    ' ── Homepage dynamic content (auto-loaded) ───────────────
    package "Homepage — Dynamic Content" {
        usecase "Browse Commands\n<size:10>(Terminal View)</size>" as UC5
        usecase "Browse Patterns\n& Anti-Patterns" as UC6
        usecase "Navigate Gallery\nCard Stack" as UC7
        usecase "Navigate Page Sections\n<size:10>(Anchor / Hash)</size>" as UC10
    }

    ' ── Command card interactions ─────────────────────────────
    package "Command Card Actions" {
        usecase "Download Asset Bundle" as UC8
        usecase "Copy Command Text" as UC9
    }
}

' ── Actor → static pages ──────────────────────────────────────
visitor --> UC1
visitor --> UC2
visitor --> UC3
visitor --> UC4

' ── Homepage auto-loads dynamic content (include) ────────────
UC1 .> UC5  : <<include>>
UC1 .> UC6  : <<include>>
UC1 .> UC7  : <<include>>
UC1 .> UC10 : <<include>>

' ── Optional interactions from command cards (extend) ────────
UC8 .> UC5  : <<extend>>
UC9 .> UC5  : <<extend>>

note bottom of UC5
  loadContent() fetches /api/commands
  and renders renderTerminalLayout()
end note

note bottom of UC6
  loadContent() fetches /api/patterns
  and renders renderPatternsWithTabs()
end note

@enduml
