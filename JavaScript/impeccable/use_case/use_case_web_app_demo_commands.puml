@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7DC9
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Web App: Command Demos

left to right direction

actor "Web Visitor" as visitor

rectangle "Impeccable Web App — Command Demos" {

    usecase "View Command Demo\n<size:10><i>(renderCommandDemo)</i></size>" as UC1
    usecase "Toggle Before / After State\n<size:10><i>(handleCommandDemoToggle)</i></size>" as UC2
    usecase "Initialise Interactive\nDemo JS\n<size:10><i>(initCommandDemo)</i></size>" as UC3
    usecase "Navigate to\nRelated Command\n<size:10><i>(selectCommand callback)</i></size>" as UC4
    usecase "Interact with\nDemo Element\n<size:10><i>(setupInteractiveButtons)</i></size>" as UC5
    usecase "Browse Demo\nFallback / Static View\n<size:10><i>(placeholder or static panel)</i></size>" as UC6

}

' --- Actor → Use Case relationships ---
visitor --> UC1 : selects a command
visitor --> UC2 : clicks toggle switch
visitor --> UC4 : clicks relationship tag
visitor --> UC5 : clicks interactive element

' --- Include / Extend between use cases ---
UC1 ..> UC3 : <<include>>\npost-render init
UC1 <.. UC6 : <<extend>>\nno demo registered

' --- Supporting system components (secondary actors) ---
actor "Demo Registry\n<size:10>(commandDemos index)</size>" as registry #E8F5E9
actor "demo-renderer.js" as renderer #FFF3E0
actor "demo-toggles.js" as toggles #FCE4EC

UC1 --> registry : getCommandDemo()
UC2 --> registry : getCommandDemo()
UC3 --> registry : getCommandDemo()

UC1 --> renderer : returns split-screen HTML
UC6 --> renderer : returns fallback HTML

UC2 --> toggles : click handler / onToggle()
UC4 --> toggles : relationship-tag click handler
UC5 --> toggles : setupInteractiveButtons()

' --- Notes ---
note right of UC1
  Split-screen output:
  div.demo-split-comparison
  ├─ .split-before
  ├─ .split-after
  ├─ .split-divider
  └─ .demo-caption
  Special static views for
  'impeccable' and 'shape'
end note

note right of UC2
  Toggle guards double-init via
  toggle.dataset.initialized
  Updates aria-checked +
  .demo-toggle-label active class
end note

note bottom of registry
  16 registered commands:
  animate · bolder · audit · critique
  polish · optimize · harden · clarify
  quieter · distill · colorize · delight
  adapt · typeset · layout · overdrive
end note

@enduml
