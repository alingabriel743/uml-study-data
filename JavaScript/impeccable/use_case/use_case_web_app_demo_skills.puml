@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}

title Web App: Skill Demos

left to right direction

actor "Web Visitor" as visitor

rectangle "Skill Demos Web App  (public/js/demos/skills/)" {

    usecase "Browse Skill\nDemo Catalogue\n(7 registered demos)" as UC1

    package "Skill Demos" {
        usecase "View Responsive Design Demo\n[Touch Targets | Fluid Layout | Adaptive Content]" as UC2
        usecase "View Typography Demo\n[Font Pairing | Scale & Hierarchy]" as UC3
        usecase "View Motion Design Demo\n[Staggered Reveal | Micro-interactions | State Changes]" as UC4
        usecase "View Color & Contrast Demo\n[Color Harmony | Strategic Accent | Contrast Ratios]" as UC5
        usecase "View Interaction Design Demo\n[Button States | Affordances | Feedback]" as UC6
        usecase "View Spatial Design Demo\n[Grid Systems | Visual Weight | Breathing Room]" as UC7
        usecase "View UX Writing Demo\n[Error Messages | Button Labels | Empty States]" as UC8
    }

    package "Interaction Patterns" {
        usecase "Toggle Before / After\n(HTML swap or CSS class toggle)" as UC9
        usecase "View Static\nSide-by-Side Comparison" as UC10
        usecase "Replay CSS Animation\n(onToggle: DOM re-clone)" as UC11
        usecase "Interact with\nLive UI Element\n(onAfterRender: event binding)" as UC12
    }
}

' --- Actor to use cases ---
visitor --> UC1
visitor --> UC2
visitor --> UC3
visitor --> UC4
visitor --> UC5
visitor --> UC6
visitor --> UC7
visitor --> UC8

' --- Catalogue resolves each demo (include) ---
UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>
UC1 ..> UC5 : <<include>>
UC1 ..> UC6 : <<include>>
UC1 ..> UC7 : <<include>>
UC1 ..> UC8 : <<include>>

' --- Demos that always include the toggle interaction ---
UC3 ..> UC9 : <<include>>
UC4 ..> UC9 : <<include>>
UC5 ..> UC9 : <<include>>
UC6 ..> UC9 : <<include>>
UC7 ..> UC9 : <<include>>
UC8 ..> UC9 : <<include>>

' --- Demos that include static side-by-side (no toggle tabs) ---
UC2 ..> UC10 : <<include>>
UC11 ..> UC4  : <<extend>>
UC12 ..> UC6  : <<extend>>

note bottom of UC11
  Stagger tab re-clones DOM items
  via cloneNode(true) + replaceChild
  to replay CSS keyframe animation
end note

note bottom of UC12
  Feedback tab binds click handler
  on .int-fb-active[data-action=like]
  to toggle .liked class & update label
end note

@enduml
