@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangleBorderColor #6C757D
skinparam rectangleBackgroundColor #E9ECEF
skinparam rectangleFontColor #212529
skinparam rectangleFontSize 13
skinparam rectangleFontStyle bold
skinparam noteFontSize 10
skinparam noteFontColor #495057

title Web App: Skills Catalog

left to right direction

actor "Web Visitor" as visitor
actor "Build System\n(startup / CI)" as build

rectangle "Impeccable Web Server (Bun)" {

    usecase "Browse Skills Index\nGET /skills" as UC1
    usecase "View Skill Detail Page\nGET /skills/:id" as UC2
    usecase "Fetch Skills JSON\nGET /api/skills" as UC3
    usecase "Fetch Commands JSON\nGET /api/commands" as UC4
    usecase "Pre-generate Skills Pages\n(static HTML build)" as UC5
    usecase "Return 404\n(skill id not found)" as UC6

}

' Actor → Use-case associations
visitor --> UC1
visitor --> UC2
visitor --> UC3
visitor --> UC4
build   --> UC5

' Include: UC4 reuses UC3's logic (getCommands → getSkills)
UC4 .> UC3 : <<include>>

' Include: skill detail pages share the same sidebar navigation as the index
UC2 .> UC1 : <<include>>

' Include: static build pipeline reads the same skills data as the API
UC5 .> UC3 : <<include>>

' Extend: detail page can fail gracefully with a 404
UC6 .> UC2 : <<extend>>\n(id not found)

note bottom of UC1
  Serves pre-generated
  public/skills/index.html
  (category sections + skill chips)
end note

note bottom of UC2
  Sanitises id (alphanumeric + hyphen).
  Serves public/skills/{id}.html
  (hero, demo, editorial, references)
end note

note bottom of UC5
  generateSubPages() at startup:
  renders index + per-skill pages,
  writes to public/skills/
end note

@enduml
