@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #1A3D6B
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Web App: Tutorials

left to right direction

actor "Web Visitor" as visitor

rectangle "impeccable.style Web Server (Bun)" {

    usecase "View Tutorials Index\n<size:10><color:#6C757D>GET /tutorials</color></size>" as UC1
    usecase "View Tutorial Detail\n<size:10><color:#6C757D>GET /tutorials/:slug</color></size>" as UC2
    usecase "Navigate Docs Sidebar\n<size:10><color:#6C757D>sidebar: tutorials + skills</color></size>" as UC3
    usecase "Serve Pre-built HTML\n<size:10><color:#6C757D>serveGenerated()</color></size>" as UC4
    usecase "Sanitize Slug\n<size:10><color:#6C757D>[^a-z0-9-] stripped</color></size>" as UC5
    usecase "Handle Missing Page\n<size:10><color:#6C757D>404 Not Found</color></size>" as UC6

}

' Actor → primary use cases
visitor --> UC1
visitor --> UC2

' Include relationships
UC1 ..> UC3 : <<include>>
UC2 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>
UC2 ..> UC4 : <<include>>

' Extend relationships
UC2 ..> UC5 : <<include>>
UC4 ..> UC6 : <<extend>>

note bottom of UC3
  Sidebar lists all tutorials +
  skill categories with
  current-page highlighting
end note

note right of UC5
  Slug sanitised at request time:
  req.params.slug.replace(/[^a-z0-9-]/gi, '')
  Guards against path traversal
end note

note top of UC4
  HTML pre-generated at server
  startup via generateSubPages().
  Response includes security headers:
  X-Content-Type-Options, X-Frame-Options: DENY
end note

@enduml
