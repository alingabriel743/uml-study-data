@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #2D6A4F
    EndColor #C0392B
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}

title Anti-CSRF Token Flow\n<size:11><color:#6C757D>Generation and validation of CSRF tokens via AntiCSRFService</color></size>

|#EBF5FB|Client (GUI)|
|#EAF7F0|Token Endpoint|
|#FEF9E7|Backend AntiCSRFService|
|#FDF2F8|anticsrf Middleware|
|#FDEDEC|Protected Route Handler|

|Client (GUI)|
start
:Need to perform a state-mutating request\n<size:10>(logout / account deletion / revoke session)</size>;
:Call **gui/AntiCSRFService.token()**;
:Send **GET /get-anticsrf-token**\n<size:10>Authorization: Bearer <auth_token></size>;

|Token Endpoint|
if (Subdomain is 'api'?) then (yes)
    #FFB3B3:Return **404**\n<size:10>Cross-origin token fetch blocked</size>;
    stop
else (no)
endif

if (req.user authenticated?) then (no)
    #FFB3B3:Return **403 Forbidden**;
    stop
else (yes)
endif

:Call **AntiCSRFService.create_token(req.user.uuid)**;

|Backend AntiCSRFService|
if (Session queue exists in\nmap_session_to_tokens?) then (no)
    :Create new **CircularQueue(10)**\nand store in map;
else (yes)
    :Reuse existing **CircularQueue**\nfor session;
endif

:Call **generate_token_()**\n<size:10>crypto.randomBytes(32).toString('hex')</size>\n<size:10>→ 64-char hex string</size>;

if (CircularQueue at capacity (10)?) then (yes)
    :Evict oldest token\n<size:10>Circular overwrite — prevents memory growth</size>;
else (no)
endif

:Push new token into **CircularQueue**;

|Token Endpoint|
:Return **{ token }** to client;

|Client (GUI)|
:Attach token as **anti_csrf**\nfield in request body;
:Send state-mutating request\n<size:10>POST /logout, /down, or /auth/revoke-session</size>;

|anticsrf Middleware|
if (req.body.anti_csrf present?) then (no)
    #FFB3B3:**APIError**: 'anti-csrf-incorrect'\n<size:10>400 error response</size>;
    stop
else (yes)
endif

:Call **svc_antiCSRF.consume_token(\n  req.user.uuid,\n  req.body.anti_csrf)**;

|Backend AntiCSRFService|
if (CircularQueue found\nfor session UUID?) then (no)
    :Return **false**\n<size:10>No known session</size>;
else (yes)
    :Call **tokens.maybe_consume(token)**;
    if (Token found in queue?) then (yes)
        :Null out queue slot\n<size:10>One-time use — token consumed</size>;
        :Return **true**;
    else (no)
        :Return **false**\n<size:10>Invalid / expired / already used</size>;
    endif
endif

|anticsrf Middleware|
if (consume_token returned true?) then (no)
    #FFB3B3:Return **400**\n<size:10>{ message: 'incorrect anti-CSRF token' }</size>;
    stop
else (yes)
    :Call **next()** — token verified;
endif

|Protected Route Handler|
:Execute protected route logic\n<size:10>logout / account deletion / session revoke</size>;
#D5F5E3:Return **200 OK**\nOperation completed successfully;
stop

@enduml
