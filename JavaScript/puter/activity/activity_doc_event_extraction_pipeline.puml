@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
    StartColor #212529
    EndColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Documentation Event Extraction Pipeline\n<size:11>//node tools/doc_helper.js <directory> [output_file] [--generate-test] [--test-dir=<dir>] [--debug]//</size>

|#E3F2FD|CLI / main()|
start

:Parse process.argv\n(directory, outputFile, generateTest,\ntestOutputDir, debugMode);

if (args.length < 1?) then (yes)
    :Print usage message;
    :process.exit(1);
    stop
else (no)
endif

:Load manual_overrides.json.js\nbuild manualOverridesMap <Map<id, override>>;

:Initialize seenEvents = new Map();

:Seed seenEvents from manualOverrides\n(set fromManualOverride = true\nfor each override entry);

|#FFF3E0|scanDirectory()|
:scanDirectory(directory, seenEvents, debugMode);

repeat
    :readdirSync — read next entry;
    if (entry is a directory?) then (yes)
        :Recurse: scanDirectory(subdir,\nseenEvents, debugMode);
    else (no)
        if (entry ends with '.js'?) then (yes)
            |#F3E5F5|extractEventsFromFile()|
            :extractEventsFromFile\n(filePath, seenEvents, debugMode);

            :readFileSync(filePath, 'utf-8');

            :Detect hasAllowEffect\n(content includes 'event.allow'\n/ '.allow =' / '.allow=');

            repeat
                :Regex match:\nsvc_event.emit('eventName', eventArg);

                :checkForDuplicateEvent\n(eventId, filePath, seenEvents);

                if (seenEvents.has(eventId)?) then (yes)
                    if (fromManualOverride?) then (yes)
                        :Push "Using manual override"\nwarning → continue;
                    else (no)
                        :Push "Duplicate event"\nwarning → continue;
                    endif
                else (no — new event)
                    if (manualOverridesMap.has(eventId)?) then (yes)
                        :Apply override\n(fromManualOverride = true)\nseenEvents.set(id, override);
                    else (no)
                        :generateDescription(eventName)\n(keyed on: create/update/delete\n/progress/validate);

                        if (eventArg starts with '{'?) then (yes — inline object)
                            :Regex extract propertiesText\nfrom { ... } block;
                        else (no — variable reference)
                            :Regex search for\n'const|let|var varName = {...}'\nin file content;
                        endif

                        :extractProperties(\npropertiesText, propertyDetails,\nhasAllowEffect, eventName)\n\n• Strip comment lines\n• Tokenise property names\n• guessType(prop)\n• guessSummary(prop, eventName)\n• mutability: hasAllowEffect\n  ? 'effect' : 'no-effect';

                        :seenEvents.set(eventId,\n{ id, event, filename,\ndescription, properties,\nfromManualOverride: false });
                    endif
                endif
            repeat while (more emit() matches?) is (yes)
            ->no more matches;

            note right
                CATCH: any error →
                push "Error processing
                file: <message>" warning
            end note

            |#FFF3E0|scanDirectory()|
        else (no — skip)
        endif
    endif
repeat while (more directory entries?) is (yes)
->all entries processed;

|#E3F2FD|CLI / main()|

:Check unused manual overrides\n(forEach override: if event not found\nor not fromManualOverride → push warning);

:result = Array.from(seenEvents.values())\nSort alphabetically by id;

:formatEventsOutput(result)\n→ JS export string\n(export default [...] format);

if (outputFile provided?) then (yes)
    :fs.writeFileSync(outputFile, formattedOutput)\nLog: "Written to <outputFile>";
else (no)
    :console.log(formattedOutput)\n(print to stdout);
endif

if (--generate-test flag set?) then (yes)
    :generateTestExtension(result)\n→ JS stub with extension.on()\nlisteners per event;
    :mkdirSync(testOutputDir, recursive)\nif directory does not exist;
    :fs.writeFileSync(\ntestOutputDir/testex.js, testCode)\nLog: "Test extension written";
else (no)
endif

if (warnings.length > 0?) then (yes)
    :Partition warnings into:\n• duplicateEvents\n• overrideEvents\n• otherWarnings;
    :Print categorised warning summary\n(duplicate list, override list,\nother warnings);
else (no)
endif

stop

@enduml
