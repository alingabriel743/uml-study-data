@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F0AD4E
}

title File System Entry CRUD Operations\n(FSEntryController)

|Caller|
start
:Call CRUD operation\n(insert / update / delete / get);

|FSEntryController|

if (Operation type?) then (get(uuid))

  ' ─── READ PATH ───────────────────────────────────────────
  :Iterate currentState.queue:\napply() each op matching uuid\nto accumulate pending state;
  :Iterate deferredState.queue:\napply() each op matching uuid;
  if (Pending state is a diff\n(is_diff == true)?) then (yes)
    |Database|
    :SELECT <defaultProperties>\nFROM fsentries WHERE uuid=?;
    |FSEntryController|
    :Merge: { ...base_entry, ...pending_entry };
  else (no)
  endif
  |Caller|
  :Return entry\n(undefined if no pending ops\nand not found in DB);
  stop

elseif (insert) then (insert)

  ' ─── INSERT PATH ─────────────────────────────────────────
  :Validate required fields\n[uuid, parent_uid];
  if (Required field missing?) then (yes)
    #pink:Throw validation error;
    |Caller|
    :Receive validation error;
    stop
  else (no)
  endif
  |FSEntryController|
  :Sanitize entry against\nallowedForCreate field list;
  :new Insert(sanitized_entry)\nop.status = STATUS_PENDING;

elseif (update) then (update)

  ' ─── UPDATE PATH ─────────────────────────────────────────
  :Sanitize entry against allowedForUpdate\n[name, parent_uid, user_id, modified,\nshortcut_to, metadata, thumbnail,\nsize, path];
  :new Update(uuid, sanitized_entry)\nop.status = STATUS_PENDING;

else (delete)

  ' ─── DELETE PATH ─────────────────────────────────────────
  :new Delete(uuid)\nop.status = STATUS_PENDING;

endif

' ═══════════════════════════════════════════════════════════
'  SHARED  ─  enqueue_() FLOW
' ═══════════════════════════════════════════════════════════
|FSEntryController|
:enqueue_(op);

while (currentState.queue OR deferredState.queue\nat max_queue capacity (default 50)?) is (yes — backpressure)
  :Await queueSizePromise\n(caller suspended until slot opens);
endwhile (no — space available)

if (op instanceof BaseOperation?) then (no)
  #pink:Throw "Invalid operation";
  stop
else (yes)
endif

if (status == STATUS_READY?) then (yes — idle)
  :Push op → currentState.queue\nRegister uuid → currentState.updating_uuids;
else (no — STATUS_RUNNING_JOB)
  :Push op → deferredState.queue\nRegister uuid → deferredState.updating_uuids;
endif

if (entryListeners_[op.uuid] exists?) then (yes)
  :Fire all registered listener callbacks\nfor this uuid;
  :Delete entryListeners_[op.uuid];
else (no)
endif

:checkShouldExec_();

' ═══════════════════════════════════════════════════════════
'  SHARED  ─  exec_() FLOW  (triggered when STATUS_READY)
' ═══════════════════════════════════════════════════════════
if (status == STATUS_READY\nAND currentState.queue non-empty?) then (yes — execute batch)

  :Set status = STATUS_RUNNING_JOB;
  :Capture reference to currentState.queue;
  :Set each op.status = STATUS_RUNNING;

  |Database|
  :db.batch_write(\n  queue.map(op => op.getStatement())\n);
  note right
    Executes all ops in a single batch:
    INSERT INTO fsentries (fields) VALUES (?)
    UPDATE fsentries SET field=? WHERE uuid=? LIMIT 1
    DELETE FROM fsentries WHERE uuid=? LIMIT 1
  end note

  |FSEntryController|
  :Set each op.status = STATUS_DONE\n(resolves each op's TeePromise —\nunblocks all awaitDone() callers);
  :flipState_():\n  currentState ← deferredState\n  reset deferredState to empty\n  resolve queueSizePromise (unblock backpressure waiters);
  :Set status = STATUS_READY;
  :checkShouldExec_()\n(kick off next deferred batch if queued);

else (no — running or queue empty)
endif

' ═══════════════════════════════════════════════════════════
'  CALLER  ─  receives result
' ═══════════════════════════════════════════════════════════
|Caller|
:await op.awaitDone()\n(suspended until op.status = STATUS_DONE);
:Receive completed operation;
stop

@enduml
