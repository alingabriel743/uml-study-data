@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Launch-on-Init Service Flow

|"initgui / launch_services"|

start

:Call launch_services(options)\nat GUI startup;

:Initialize services_l_ array\nand services_m_ map;

:Register all builtin services\n(IPCService, ExecService, DebugService,\nBroadcastService, ..., AntiCSRFService);

:register('__launch-on-init',\nnew LaunchOnInitService())\npush to services_l_ and services_m_;

note right
  All services are registered
  before any lifecycle phase begins
end note

:── CONSTRUCT PHASE ──\nFor each [name, instance] in services_l_:\nawait instance.construct({ gui_params: options });

|"Service (base class)"|

:Service.construct(o)\nCopy o into this.$puter;

:Delegate → call this._construct();

|LaunchOnInitService|

:_construct()\nInitialize this.commands map;

note right
  this.commands = {
    'window-call': ({ fn_name, args })
      => window[fn_name](...args)
  }
end note

:Return to construct loop;

|"initgui / launch_services"|

:── INIT PHASE ──\nFor each [name, instance] in services_l_:\nawait instance.init({ services: globalThis.services });

|"Service (base class)"|

:Service.init(a)\nSet this.services = a.services;

:Delegate → call this._init();

|LaunchOnInitService|

:_init()\nRead launch_options =\nthis.$puter.gui_params.launch_options;

if (launch_options exists?) then (yes)

  if (launch_options.on_initialized\narray exists?) then (yes)

    :Loop: for each command\nin on_initialized array;

    :run_(command)\nSpread command into args\nDelete args.$ (the type key);

    :Look up handler:\nthis.commands[command.$](args);

    if (command.$ === 'window-call'?) then (yes)
      :window[fn_name](...args.args)\nInvoke named function\non global window object;
    else (other handler)
      :Dispatch to\nregistered handler;
    endif

    :Advance to next command;

    note right
      Loop continues until
      all on_initialized
      commands are executed
    end note

  else (no — array absent)
    :Return early\n(no commands to run);
    stop
  endif

else (no — launch_options absent)
  :Return early\n(no launch options provided);
  stop
endif

|"initgui / launch_services"|

:All on_initialized commands executed\nLaunchOnInitService init complete;

stop

@enduml
