@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}

title Locale and Duration Formatting Flow\n<size:11><i>Duration and locale-aware string formatting pipeline in LocaleService</i></size>

|LocaleService|
start

:Receive **seconds** (total duration as number)\n<i>LocaleService.format_duration(seconds: number)</i>;

:Compute time components
**hours** = Math.floor(seconds / 3600)
**minutes** = Math.floor((seconds % 3600) / 60)
**remainingSeconds** = seconds % 60;

:Pad each component to 2 digits with leading zeros
**paddedHours** = hours.toString().padStart(2, '0')
**paddedMinutes** = minutes.toString().padStart(2, '0')
**paddedSeconds** = remainingSeconds.toString().padStart(2, '0');

if (hours === 0 AND minutes === 0?) then (yes — seconds only)

    :Call **i18n('seconds')** for locale-aware label;

    |i18n / window|

    :Read **window.locale** (global browser state);

    if (locale found in translations map?) then (yes)
        :Select language from translations;
    else (no — fallback)
        :Use **'en'** as default language;
    endif

    :Look up **'seconds'** key in language.dictionary;

    if (key found in selected language?) then (yes)
        :Use translated string;
    else (no — fallback)
        :Look up key in **'en'** dictionary;
    endif

    :Run **ReplacePlaceholders()**\nReplace {{link=...}} and {{...}} tokens;

    if (encode_html === true?) then (yes)
        :HTML-encode the string;
        :Replace \\n with **<br />**;
    else (no)
    endif

    :Replace **%%** tokens with positional\nreplacements array values;

    :Return localized label string;

    |LocaleService|

    :Combine result\nReturn **"${paddedSeconds} ${label}"**\n<i>e.g. "05 seconds"</i>;

else (no — has minutes or hours)

    if (hours === 0?) then (yes — minutes only)

        :Return **"${paddedMinutes}:${paddedSeconds}"**\n<i>mm:ss format — no i18n call</i>;

    else (no — has hours)

        :Return **"${paddedHours}:${paddedMinutes}:${paddedSeconds}"**\n<i>hh:mm:ss format — no i18n call</i>;

    endif

endif

:Formatted duration string returned to caller;

stop

@enduml
