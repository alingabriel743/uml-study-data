@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}

title Release Notes Generation Flow\n<size:11><color:#6C757D>tools/gen-release-notes.js — Parsing conventional commits, grouping by scope, producing formatted markdown</color></size>

|#E8F4FD| Initialization |
start
:Parse CLI params\n(from tag, to tag, date);
:Initialize simpleGit() client;
:Fetch git log from **params.from** tag\nvia simpleGit().log();
:Build **retro_prefixes** lookup map\nfrom retro_prefixes_0 array\n(hash → type prefix);
:Initialize **data** accumulator\n{ [scope]: { feat:[], i18n:[], fix:[] } };

|#FFF8E1| Commit Processing |
:Begin iterating over each commit;

repeat
  :Read next commit\n(hash, message);

  if (commit.hash in **message_changes**?) then (yes)
    :Override commit.message\nwith mapped string;
  else (no)
  endif

  if (commit.hash in **retro_prefixes**?) then (yes)
    :Prepend retro prefix\nto commit.message;
  else (no)
  endif

  :Call **parse_conventional_commit**(commit.message)\n→ regex: /^([a-z0-9]+)(\\([a-z0-9]+\\))?:\\s(.*)/;

  if (parse result is **null**?) then (yes)
    :Skip commit (continue);
    note right
      Non-conventional commit
      message — not parseable
    end note
  else (no)
    :Extract **{ type, scope, summary }**\nfrom parse result;

    :Apply **complicated_cases** transformers sequentially;
    note right
      fix_i18n: scope=='i18n' → type='i18n', clear scope
      deps_scope: scope=='deps' → type='chore', clear scope
      puterai_is_ai: scope in ['puterai','puerai','puter-ai'] → scope='ai'
      doc_scopes: scope=='readme' → type='doc', clear scope
    end note

    :Resolve final scope:\n**meta.scope ?? 'puter'**;

    while (scope in **scope_aliases**?) is (yes)
      :Replace scope with alias target\n(e.g. main→puter, ui→gui, parsely→phoenix);
    endwhile (no — scope resolved)

    if (scope NOT in **known scopes registry**?) then (yes)
      #FFB3B3:Throw Error:\n'missing scope: {scope}';
      stop
    else (no)
    endif

    if (**scopes[scope].ignore** == true?) then (yes)
      :Skip commit (continue);
      note right
        e.g. 'tools' scope
        is silently ignored
      end note
    else (no)
      :Call **ensure_scope(scope)**\nInitialize data[scope] with\nempty arrays per type if absent;

      if (**meta.type** is a known type?\n(feat / fix / i18n)) then (yes)
        :Push **{ meta, commit }**\ninto data[scope][meta.type];
      else (no)
        :Discard commit\n(chore / doc types not in output);
        note right
          'chore' and 'doc' are parsed
          but silently dropped —
          not present in types map
        end note
      endif
    endif
  endif

repeat while (more commits?) is (yes)
-> no;

|#EAFAF1| Output Generation |
:Begin building markdown string;

:Append version header:\n**## {to} ({date})**;

repeat
  :Next scope in **data**;
  :Append scope header:\n**### {scope.label}**;

  :Iterate types in order: feat → i18n → fix;
  repeat
    :Next type\n(feat / i18n / fix);
    if (items list **empty**?) then (yes)
      :Skip this type section;
    else (no)
      :Append type header:\n**#### {type.label}**;
      :For each item append:\n**- {summary} ([shorthash](REPO_URL/commit/hash))**;
      note right
        REPO_URL hardcoded to
        github.com/HeyPuter/puter
      end note
    endif
  repeat while (more types?) is (yes)
  -> no;

repeat while (more scopes?) is (yes)
-> no;

:Print final markdown\nto **stdout**;
stop

@enduml
