@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    DiamondFontColor #212529
}
skinparam swimlane {
    BorderColor #ADB5BD
    TitleBackgroundColor #E9ECEF
    TitleBorderColor #6C757D
    TitleFontColor #212529
    TitleFontSize 13
    TitleFontStyle bold
}

title S3 Storage Read and Delete Pipeline\n<size:11><i>File read and deletion flows within S3StorageController</i></size>

|Caller|
start
:Invoke S3StorageController operation;

if (Operation Type?) then (read)

  :Call **read()**\n{ location, range?, version_id? };

  |S3StorageController|
  :Destructure location\n→ { bucket_region, bucket, key };
  note right
    location is passed directly
    by the caller (no async lookup)
  end note

  :Invoke **#get_client**(bucket_region);

  |s3ClientProvider|
  :s3ClientProvider.get(region)\n→ return S3Client;

  |S3StorageController|
  :Initialize GetObjectCommand params\n{ Bucket: bucket, Key: key };

  if (range provided?) then (yes)
    :Append **Range** header\nto command params;
  else (no)
    :Skip Range header;
  endif

  if (version_id provided?) then (yes)
    :Append **VersionId**\nto command params;
  else (no)
    :Skip VersionId;
  endif

  :client.send(**GetObjectCommand**);

  |AWS S3|
  :Retrieve object\nReturn response with Body stream;

  |S3StorageController|
  :Readable.from(response.Body)\n→ wrap Body as Node.js Readable stream;
  note right
    No buffering — raw stream
    returned directly to caller.
    No retry logic in read().
  end note

  |Caller|
  :Receive **Readable stream**;

else (delete)

  :Call **delete()**\n{ node };

  |S3StorageController|
  :await node.get('s3:location')\n→ resolve node_storage\n{ bucket_region, bucket, key };
  note right
    Lazy async metadata lookup —
    bucket info is resolved from
    the node abstraction at runtime.
  end note

  :Invoke **#get_client**(node_storage.bucket_region);

  |s3ClientProvider|
  :s3ClientProvider.get(region)\n→ return S3Client;

  |S3StorageController|
  :Build DeleteObjectCommand params\n{ Bucket: node_storage.bucket,\n  Key: node_storage.key };

  :client.send(**DeleteObjectCommand**);

  |AWS S3|
  :Delete object\nReturn S3 delete response;

  |S3StorageController|
  :Return S3 response to caller;
  note right
    No retry logic in delete().
    Response forwarded as-is.
  end note

  |Caller|
  :Receive **S3 delete response**;

endif

stop

@enduml
