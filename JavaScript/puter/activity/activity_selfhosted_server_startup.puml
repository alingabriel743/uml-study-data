@startuml

skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam ActivityBackgroundColor #F8F9FA
skinparam ActivityBorderColor #495057
skinparam ArrowColor #495057
skinparam ActivityFontColor #212529
skinparam ActivityDiamondBackgroundColor #E9ECEF
skinparam ActivityDiamondBorderColor #495057
skinparam swimlaneBorderColor #6C757D
skinparam swimlaneBorderThickness 2
skinparam swimlaneBackgroundColor #E9ECEF

title Self-Hosted Server Startup Flow\n<i>Bootstrap sequence: from config loading to server ready (run-selfhosted.js)</i>

|Entry Script (run-selfhosted.js)|
start

:Invoke top-level IIFE\n<i>(async () => { await main(); })()</i>;

:Try import('dotenv/config');

if (dotenv available?) then (yes)
  :Load .env file variables\ninto process.env;
else (no — optional dependency)
  :Skip silently\ncontinue without .env;
endif

if (import.meta.filename defined?) then (yes)
else (no — older Node.js)
  :Polyfill import.meta.filename\n<i>Object.defineProperty from import.meta.url</i>;
endif

:Enter main() async function;

:Dynamic import('@heyputer/backend')\nDestructure exported module classes:\nKernel, EssentialModules, DatabaseModule,\nSelfHostedModule, BroadcastModule,\nTestDriversModule, TestConfigModule,\nInternetModule;

|Kernel|

:Instantiate Kernel\n<b>new Kernel({ entry_path: import.meta.filename })</b>;

|Entry Script (run-selfhosted.js)|

:Register EssentialModules\n<i>for each mod of EssentialModules array</i>\n<i>k.add_module(new mod())</i>\n<i>[core platform modules]</i>;

:k.add_module(new DatabaseModule())\n<i>Relational data storage layer</i>;

:k.add_module(new LocalDiskStorageModule())\n<i>Local filesystem storage adapter</i>\n<i>imported from @heyputer/backend/src/LocalDiskStorageModule.js</i>;

:k.add_module(new SelfHostedModule())\n<i>Self-hosted specific config & routes</i>;

:k.add_module(new BroadcastModule())\n<i>Inter-process broadcast messaging</i>;

:k.add_module(new TestDriversModule())\n<i>Test driver support (dev/test builds)</i>;

:k.add_module(new TestConfigModule())\n<i>Test configuration (dev/test builds)</i>;

:k.add_module(new InternetModule())\n<i>Internet connectivity services</i>;

|Kernel|

:k.boot()\nInitialize all registered modules\nin dependency order\nStart HTTP server;

:Server Ready;

stop

@enduml
