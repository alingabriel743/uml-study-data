@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF8DC
    DiamondBorderColor #B8860B
    StartColor #2C3E50
    EndColor #2C3E50
    BarColor #495057
}
skinparam swimlane {
    BorderColor #ADB5BD
    TitleBackgroundColor #DEE2E6
    TitleFontColor #343A40
    TitleFontSize 13
}

title Theme Management Flow

|ThemeService|
|Filesystem (puter.fs)|
|DOM :root|
|BroadcastService|

' ═════════════════════════════════════════════════════════
' INITIALIZATION
' ═════════════════════════════════════════════════════════
|ThemeService|
start

:_init() — Service Startup;
:Resolve BroadcastService\nglobalThis.services.get('broadcast');
:Set default state\n{ sat=41.18, hue=210, lig=93.33,\n  alpha=0.8, light_text=false };
:Cache document.querySelector(':root');
:save_cooldown_ = undefined;

|Filesystem (puter.fs)|
:puter.fs.read("~/.__puter_gui.json")\n[async — non-blocking .then()];

|ThemeService|
if (Read succeeded?) then (yes)
  if (Data is Blob / object?) then (yes)
    :await data.text()  →  convert to string;
  endif
  if (Non-empty string?) then (yes)
    :JSON.parse(data);
    if (Parse successful?) then (yes)
      if (parsed.colors exists?) then (yes)
        :Merge parsed.colors into state;
        |DOM :root|
        :Set --primary-hue = state.hue\n--primary-saturation = state.sat%\n--primary-lightness = state.lig%\n--primary-alpha = state.alpha;
        if (state.light_text == true?) then (yes)
          :--primary-color = "white"\n--primary-color-icon = "invert(1)"\n--primary-color-sidebar-item = "#5a5d61aa";
        else (no)
          :--primary-color = "#373e44"\n--primary-color-icon = "invert(0)"\n--primary-color-sidebar-item = "#fefeff";
        endif
        |BroadcastService|
        :sendBroadcast("themeChanged",\n  { palette: {primaryHue, primarySaturation,\n    primaryLightness, primaryAlpha, primaryColor} },\n  { sendToNewAppInstances: true });
        |ThemeService|
      endif
    else (parse error)
      :UIAlert\ntitle: "Error loading theme data"\nmessage: parse error text;
    endif
  endif
else (read error)
  if (error.code ==\n'subject_does_not_exist'?) then (yes)
    :Silent — no action\n(first-time user, no theme file yet);
  else (no)
    :console.error(error);
  endif
endif

:Initialization complete\n(default or persisted theme now active);

' ═════════════════════════════════════════════════════════
' THEME OPERATIONS
' ═════════════════════════════════════════════════════════
if (Operation invoked?) then (apply)

  ' ─── apply(values) ────────────────────────────────────
  :apply(values)\nstate = { ...state, ...values };

  |DOM :root|
  :Set --primary-hue, --primary-saturation,\n--primary-lightness, --primary-alpha on :root;
  if (state.light_text == true?) then (yes)
    :--primary-color = "white"\n--primary-color-icon = "invert(1)"\n--primary-color-sidebar-item = "#5a5d61aa";
  else (no)
    :--primary-color = "#373e44"\n--primary-color-icon = "invert(0)"\n--primary-color-sidebar-item = "#fefeff";
  endif

  |BroadcastService|
  :sendBroadcast("themeChanged",\n  { palette },\n  { sendToNewAppInstances: true });

  |ThemeService|
  :save_() — schedule persist;
  if (save_cooldown_\ntimer active?) then (yes)
    :clearTimeout(save_cooldown_);
  endif
  :setTimeout(1000 ms)\n→ schedules commit_save_();

  |Filesystem (puter.fs)|
  note right: Debounced 1000 ms cooldown
  :commit_save_() fires after 1000 ms;
  :JSON.stringify({ colors: state });
  :puter.fs.write("~/.__puter_gui.json");

  |ThemeService|

elseif (Operation invoked?) then (get)

  ' ─── get(key) ─────────────────────────────────────────
  :get(key);
  :return this.state[key];

elseif (Operation invoked?) then (reset)

  ' ─── reset() ──────────────────────────────────────────
  :reset()\nstate = default_values\n{ sat=41.18, hue=210, lig=93.33,\n  alpha=0.8, light_text=false };

  |DOM :root|
  :Set --primary-hue, --primary-saturation,\n--primary-lightness, --primary-alpha on :root\n(default values);
  if (state.light_text == true?) then (yes)
    :--primary-color = "white"\n--primary-color-icon = "invert(1)"\n--primary-color-sidebar-item = "#5a5d61aa";
  else (no)
    :--primary-color = "#373e44"\n--primary-color-icon = "invert(0)"\n--primary-color-sidebar-item = "#fefeff";
  endif

  |BroadcastService|
  :sendBroadcast("themeChanged",\n  { palette: defaults },\n  { sendToNewAppInstances: true });

  |Filesystem (puter.fs)|
  :puter.fs.delete("~/.__puter_gui.json")\n[removes persisted theme file];

  |ThemeService|

endif

stop

@enduml
