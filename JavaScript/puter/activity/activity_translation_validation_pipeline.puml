@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Translation Validation Pipeline\n<i>tools/check-translations.js</i>

|Script Runner|
start
:Import translations object\nfrom src/gui/src/i18n/translations/translations.js;
note right: hadError = false (global flag)

|Registration Check|
:await checkTranslationRegistrations();
:Read all files from\n./src/gui/src/i18n/translations/;
repeat
  :Process next file;
  if (File extension is .js?) then (no)
    :Skip file;
  else (yes)
    :Derive translationName\n(strip .js extension);
    if (translationName === 'translations'?) then (yes)
      :Skip index file;
    else (no)
      :Lookup translations[translationName];
      if (Translation registered?) then (no)
        #FFD7D7:reportError("not listed in translations.js");
      else (yes)
        if (translation.name present?) then (no)
          #FFD7D7:reportError("missing a name");
        endif
        if (translation.code present?) then (no)
          #FFD7D7:reportError("missing a code");
        else (yes)
          if (translation.code === translationName?) then (no)
            #FFD7D7:reportError("code mismatch");
          endif
        endif
        if (translation.dictionary is object?) then (no)
          #FFD7D7:reportError("missing translations dictionary");
        endif
      endif
    endif
  endif
repeat while (More files?) is (yes)
-> no;

|Key Check|
:checkTranslationKeys();
:Load enDictionary = translations.en.dictionary\n(ground-truth reference);
repeat
  :Process next translation entry;
  if (translation.code === 'en'?) then (yes)
    :Skip (reference language);
  else (no)
    if (translation.dictionary is object?) then (no)
      :Skip (already reported);
    else (yes)
      repeat
        :Check next [key, value] pair;
        if (key exists in enDictionary?) then (no)
          #FFD7D7:reportError("key does not exist in en");
        else (yes)
          :Key valid;
        endif
      repeat while (More keys?) is (yes)
      -> no;
    endif
  endif
repeat while (More translations?) is (yes)
-> no;

|Usage Check|
:await checkTranslationUsage();
:Load enDictionary = translations.en.dictionary;
:Define source directories:\n./src/gui/src/helpers\n./src/gui/src/UI;
:Define i18nRegex = /i18n\((['"])(.*?)\1\)/g;
repeat
  :Scan next source directory\n(recursive readdir);
  repeat
    :Process next file;
    if (File extension is .js?) then (no)
      :Skip file;
    else (yes)
      :Read file contents;
      :Apply matchAll(i18nRegex)\nto find all i18n() calls;
      repeat
        :Extract key from capture group 2;
        if (key in enDictionary?) then (no)
          #FFD7D7:reportError("Unrecognized i18n key: " + key);
        else (yes)
          :Key recognized;
        endif
      repeat while (More i18n() matches?) is (yes)
      -> no;
    endif
  repeat while (More files?) is (yes)
  -> no;
repeat while (More directories?) is (yes)
-> no;

|Script Runner|
if (hadError === true?) then (yes)
  :Write "Errors were found..." to stdout;
  #FFD7D7:process.exit(1);
else (no)
  :Write "✅ Translations appear valid." to stdout;
  #D4EDDA:process.exit(0);
endif

stop

note bottom
  All three phases run regardless of earlier errors.
  Fail-accumulate strategy — not fail-fast.
  reportError() sets hadError=true and writes ❌ to stderr.
end note

@enduml
