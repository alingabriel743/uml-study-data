@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
    StartColor #212529
    EndColor #212529
}

skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title UI Groups Management Flow

|Window / jQuery Event System|
start

:Fire **ctxmenu-will-open** event\non window;

if (event.detail.options.id\n== 'user-options-menu'?) then (no)
    :Ignore event;
    stop
else (yes)
endif

if (window.experimental_features\nis truthy?) then (no)
    :Ignore event\n(feature not enabled);
    stop
else (yes)
endif

|Extension (groups-manager.js)|

:Build **newMenuItems** array\nwith "Groups Manager" entry\n(id: 'groups-manager');

:Search items array\nfor 'task_manager' entry index;

if (task_manager item found?) then (yes)
    :Calculate insertBeforeIndex\n= foundIndex + 1;
    :Splice newMenuItems **after**\ntask_manager in items list;
else (no)
    :Append newMenuItems\nto **end** of items list;
endif

:Set event.detail.options.items\n= [ ...firstHalf, ...newMenuItems,\n    ...secondHalf ];

|Window / jQuery Event System|

:Render context menu\nwith injected **"Groups Manager"** item;

:User clicks\n"Groups Manager" menu item;

|Extension (groups-manager.js)|

:Instantiate **new UIGroupsManager()**;

|UIElement (Base Class)|

:Call **open_as_window()**\ncreate Placeholder container\nand modal window chrome;

:Invoke **make({ root })**\n(auto-called — LAZY_RENDER not set);

|Extension (groups-manager.js)|

:Append **alpha-warning** div\nto root element;

:Instantiate **new Collector()**\n(antiCSRF, origin, authToken\nfrom window.services & puter);

|Collector / API|

:Call **collector.get('/group/list')**\n→ HTTP GET with Bearer token;

:Receive JSON response\n{ in_groups: [ ... ] };

|Extension (groups-manager.js)|

:Create empty **groups_el** container;

:Iterate **for each group**\nin response.in_groups;

repeat
    if (group.metadata exists?) then (yes)
        :Read **title** = group.metadata.title;
        :Read **color** = group.metadata.color;
    else (no)
        :Fallback title = **group.uid**;
        :Fallback color = **'#FFF'**;
    endif

    :Build group element:\nel('div.group',\n  [ el('div.group-name', { text: title }) ]);

    if (color is defined?) then (yes)
        :Apply\ngroup_el.style.backgroundColor = color;
    else (no)
    endif

    :Append group element\nto groups_el container;
repeat while (more groups?) is (yes) not (no)

:Append **groups_el** container\nto root — UI fully rendered;

|UIElement (Base Class)|

:Display **UIGroupsManager** window\nto user;

stop

@enduml
