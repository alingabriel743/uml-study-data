@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
}
skinparam arrowThickness 1.2

title AI Chat Service

' ─────────────────────────────────────────
'  Base
' ─────────────────────────────────────────
package "Base" {
    abstract class BaseService {
        +services: ServiceLocator
    }
}

' ─────────────────────────────────────────
'  AI Chat Core
' ─────────────────────────────────────────
package "services/ai/chat" {

    class AIChatService {
        +{static} SERVICE_NAME: string = "ai-chat"
        +{static} DEFAULT_PROVIDER: string = "openai-completion"
        +{static} IMPLEMENTS: object
        +{static} MAX_FALLBACKS: number = 4
        --
        -#providers: Record<string, IChatProvider>
        -#modelIdMap: Record<string, IChatModel[]>
        --Getters (Service Locator)--
        +meteringService: MeteringService
        +db: BaseDatabaseAccessService
        +errorService: ErrorService
        +eventService: EventService
        +driverService: DriverService
        --Public Methods--
        +getProvider(name: string): IChatProvider
        +getModel(modelId: string, provider: string): IChatModel
        +models(): IChatModel[]
        +list(): string[]
        +complete(parameters: ICompleteArguments): Promise<TypedValue>
        +moderate(messages): Promise<boolean>
        +getFallbackModel(modelId, triedIds, triedProviders): Promise<object>
        --Private Methods--
        -registerProviders(): Promise<void>
        -#getAiChatConcurrentLimitConfig(): GroupLimitConfig
        -#getAiChatConcurrentLeaseMs(): number
        -#toLimitValue(rawLimit): number | null
    }

    class AIChatRedisCacheSpace <<utility>> {
        +{static} fallbackModelsKey(modelId: string): string
        note: "Redis key → 'aichat:fallbacks:{modelId}'"
    }
}

' ─────────────────────────────────────────
'  Chat Provider Interfaces & Types
' ─────────────────────────────────────────
package "services/ai/chat/providers" {

    interface IChatProvider {
        +models(extra_params?): IChatModel[]
        +list(): string[]
        +getDefaultModel(): string
        +checkModeration(text: string): Promise<ModerationResult>
        +complete(arg: ICompleteArguments): Promise<StreamResult | MessageResult>
    }

    interface IChatModel {
        +id: string
        +provider?: string
        +puterId?: string
        +aliases?: string[]
        +costs_currency: string
        +costs: ModelCost
        +input_cost_key?: string
        +output_cost_key?: string
        +context?: number
        +max_tokens: number
        +subscriberOnly?: boolean
        +minimumCredits?: number
    }

    interface ICompleteArguments {
        +messages: PuterMessage[]
        +provider?: string
        +stream?: boolean
        +model: string
        +tools?: unknown[]
        +tool_choice?: unknown
        +parallel_tool_calls?: boolean
        +max_tokens?: number
        +temperature?: number
        +response?: object
    }

    ' ── Provider Implementations ──────────
    class ClaudeProvider
    class OpenAiChatProvider
    class OpenAiResponsesChatProvider
    class GeminiChatProvider
    class GroqAIProvider
    class DeepSeekProvider
    class MistralAIProvider
    class XAIProvider
    class OpenRouterProvider
    class TogetherAIProvider
    class OllamaChatProvider
    class FakeChatProvider
}

' ─────────────────────────────────────────
'  API & Interface Registration
' ─────────────────────────────────────────
package "services/ai (API Layer)" {

    class ChatAPIService {
        +{static} MODULES: object
        --
        +install_chat_endpoints_(router): void
        note: "GET /puterai/chat/models\nGET /puterai/chat/models/details\nOpenAI-compat & Anthropic routers"
    }

    class AIInterfaceService {
        --
        +__on_driver.register.interfaces(): Promise<void>
        note: "Registers: puter-chat-completion\nputer-image-generation, puter-ocr\nputer-tts, puter-video-generation"
    }
}

' ─────────────────────────────────────────
'  Supporting Services (dependencies)
' ─────────────────────────────────────────
package "Supporting Services" {
    class MeteringService {
        +hasEnoughCredits(actor, cost): Promise<boolean>
        +getRemainingUsage(actor): Promise<object>
    }
    class EventService {
        +emit(event: string, payload): Promise<void>
    }
    class DriverService
    class ErrorService
    class BaseDatabaseAccessService
}

' ═════════════════════════════════════════
'  RELATIONSHIPS
' ═════════════════════════════════════════

' Inheritance
AIChatService     --|> BaseService
ChatAPIService    --|> BaseService
AIInterfaceService --|> BaseService

' Provider implementations
ClaudeProvider                ..|> IChatProvider
OpenAiChatProvider            ..|> IChatProvider
OpenAiResponsesChatProvider   ..|> IChatProvider
GeminiChatProvider            ..|> IChatProvider
GroqAIProvider                ..|> IChatProvider
DeepSeekProvider              ..|> IChatProvider
MistralAIProvider             ..|> IChatProvider
XAIProvider                   ..|> IChatProvider
OpenRouterProvider            ..|> IChatProvider
TogetherAIProvider            ..|> IChatProvider
OllamaChatProvider            ..|> IChatProvider
FakeChatProvider              ..|> IChatProvider

' AIChatService core compositions
AIChatService "1" *-- "0..*" IChatProvider    : "#providers\n(keyed by name)"
AIChatService "1" o-- "0..*" IChatModel       : "#modelIdMap"
AIChatService ..> ICompleteArguments           : accepts

' Redis cache utility
AIChatService ..> AIChatRedisCacheSpace        : uses (fallback key factory)

' Service locator dependencies
AIChatService ..> MeteringService              : depends on
AIChatService ..> EventService                 : depends on
AIChatService ..> DriverService                : depends on
AIChatService ..> ErrorService                 : depends on
AIChatService ..> BaseDatabaseAccessService    : depends on

' API layer dependencies
ChatAPIService ..> AIChatService               : delegates to

@enduml
