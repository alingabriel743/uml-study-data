@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
    FontColor #155724
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #856404
}

title AI Multimodal Services (Image, Video, OCR, TTS)

' ─────────────────────────────────────────────
' Core Base
' ─────────────────────────────────────────────
package "Core" {
    abstract class BaseService {
        #services: ServiceContainer
        #config: object
        #global_config: object
        #log: Logger
    }
}

' ─────────────────────────────────────────────
' Infrastructure / Shared Services
' ─────────────────────────────────────────────
package "Infrastructure" {
    class MeteringService {
        +hasEnoughCreditsFor(params): Promise<boolean>
    }
    class DriverService {
        +implements(iface): object
    }
    class EventService {
        +emit(event): void
    }
    class ErrorService {
        +create(params): APIError
    }
}

' ─────────────────────────────────────────────
' Driver Interfaces (Puter API contracts)
' ─────────────────────────────────────────────
package "Driver Interfaces" {
    interface "puter-image-generation" as puterImageGen {
        +generate(parameters: IGenerateParams): TypedValue
    }
    interface "puter-video-generation" as puterVideoGen {
        +generate(parameters: IGenerateVideoParams): any
    }
    interface "puter-ocr" as puterOCR {
        +recognize(params): object
    }
    interface "puter-tts" as puterTTS {
        +list_voices(options?): Voice[]
        +list_engines(options?): Engine[]
        +synthesize(params): TypedValue
    }
    interface "driver-capabilities" as driverCaps {
        +supports_test_mode(iface, method_name): boolean
    }
}

' ─────────────────────────────────────────────
' Provider Interfaces
' ─────────────────────────────────────────────
package "Provider Interfaces" {
    interface IImageProvider {
        +models(): Promise<IImageModel[]>
        +getDefaultModel(): string
        +generate(params): Promise<string>
    }
    interface IVideoProvider {
        +models(): Promise<IVideoModel[]>
        +getDefaultModel(): string
        +generate(params): Promise<any>
    }
}

' ─────────────────────────────────────────────
' AI Image Generation
' ─────────────────────────────────────────────
package "AI Image Service" {
    class AIImageGenerationService {
        {static} -SERVICE_NAME: string = "ai-image"
        {static} -DEFAULT_PROVIDER: string = "openai-image-generation"
        #providers: Record<string, IImageProvider>
        #modelIdMap: Record<string, IImageModel[]>
        +getProvider(name: string): IImageProvider
        +getModel(params): IImageModel
        +models(): IImageModel[]
        +list(): string[]
        +generate(parameters: IGenerateParams): Promise<TypedValue>
        -registerProviders(): Promise<void>
    }

    class OpenAiImageGenerationProvider {
        +models(): Promise<IImageModel[]>
        +generate(params): Promise<string>
    }
    class GeminiImageGenerationProvider {
        +models(): Promise<IImageModel[]>
        +generate(params): Promise<string>
    }
    class TogetherImageGenerationProvider {
        +models(): Promise<IImageModel[]>
        +generate(params): Promise<string>
    }
    class XAIImageGenerationProvider {
        +models(): Promise<IImageModel[]>
        +generate(params): Promise<string>
    }
    class CloudflareImageGenerationProvider {
        +models(): Promise<IImageModel[]>
        +generate(params): Promise<string>
    }
    class ReplicateImageGenerationProvider {
        +models(): Promise<IImageModel[]>
        +generate(params): Promise<string>
    }
}

' ─────────────────────────────────────────────
' AI Video Generation
' ─────────────────────────────────────────────
package "AI Video Service" {
    class AIVideoGenerationService {
        {static} -SERVICE_NAME: string = "ai-video"
        {static} -DEFAULT_PROVIDER: string = "openai-video-generation"
        #providers: Record<string, IVideoProvider>
        #modelIdMap: Record<string, IVideoModel[]>
        +getProvider(name: string): IVideoProvider
        +getModel(params): IVideoModel
        +models(): IVideoModel[]
        +list(): string[]
        +generate(parameters: IGenerateVideoParams): Promise<any>
        -registerProviders(): Promise<void>
    }

    class OpenAIVideoGenerationProvider {
        +models(): Promise<IVideoModel[]>
        +generate(params): Promise<any>
    }
    class TogetherVideoGenerationProvider {
        +models(): Promise<IVideoModel[]>
        +generate(params): Promise<any>
    }
    class GeminiVideoGenerationProvider {
        +models(): Promise<IVideoModel[]>
        +generate(params): Promise<any>
    }
}

' ─────────────────────────────────────────────
' AI OCR Service
' ─────────────────────────────────────────────
package "AI OCR Service" {
    class MistralOCRService {
        +models: string[]
        -client: Mistral
        -api_base_url: string
        +_init(): Promise<void>
        +recognize(params): Promise<object>
        -_buildDocumentChunkFromSource(fileFacade): Promise<object>
        -_inferMimeFromName(name): string
        -_chunkFromUrl(url, fileName, mimeType): object
        #normalizeOcrResponse(response): object
        #recordOcrUsage(response, model, options): void
    }
    note right of MistralOCRService
        External: @mistralai/mistralai
        Models: mistral-ocr-latest,
        mistral-ocr-2505, mistral-ocr
    end note
}

' ─────────────────────────────────────────────
' AI TTS Services
' ─────────────────────────────────────────────
package "AI TTS Services" {
    class AWSPollyService {
        -clients_: Record<string, PollyClient>
        +describe_voices(): Promise<object>
        +synthesize_speech(text, params): Promise<SynthesizeSpeechOutput>
        +list_voices(options): Promise<Voice[]>
        +list_engines(): Promise<Engine[]>
        +synthesize(params): Promise<TypedValue>
        -_get_client(region): PollyClient
        -_create_aws_credentials(): object
        -maybe_get_language_appropriate_voice_(lang, engine): Promise<string>
    }
    note right of AWSPollyService
        External: AWS Polly SDK + Redis cache
        Engines: standard, neural,
        long-form, generative
    end note

    class ElevenLabsTTSService {
        -apiKey: string
        -baseUrl: string
        -defaultVoiceId: string
        +_init(): Promise<void>
        +listVoices(): Promise<Voice[]>
        +listEngines(): Promise<Engine[]>
        +synthesize(params): Promise<TypedValue>
        -request(path, options): Promise<Response>
    }
    note right of ElevenLabsTTSService
        External: ElevenLabs REST API
        Models: eleven_multilingual_v2,
        eleven_flash_v2_5, eleven_turbo_v2_5,
        eleven_v3
    end note

    class OpenAITTSService {
        -openai: OpenAI
        +_init(): Promise<void>
        +list_voices(params): Voice[]
        +list_engines(params): Engine[]
        +synthesize(params): Promise<TypedValue>
    }
    note right of OpenAITTSService
        External: OpenAI SDK
        Models: gpt-4o-mini-tts,
        tts-1, tts-1-hd
        Voices: alloy, ash, coral, echo...
    end note
}

' ─────────────────────────────────────────────
' Inheritance
' ─────────────────────────────────────────────
AIImageGenerationService  --|> BaseService
AIVideoGenerationService  --|> BaseService
MistralOCRService         --|> BaseService
AWSPollyService           --|> BaseService
ElevenLabsTTSService      --|> BaseService
OpenAITTSService          --|> BaseService

' ─────────────────────────────────────────────
' Driver interface implementations
' ─────────────────────────────────────────────
AIImageGenerationService  ..|> puterImageGen
AIImageGenerationService  ..|> driverCaps
AIVideoGenerationService  ..|> puterVideoGen
AIVideoGenerationService  ..|> driverCaps
MistralOCRService         ..|> puterOCR
MistralOCRService         ..|> driverCaps
AWSPollyService           ..|> puterTTS
AWSPollyService           ..|> driverCaps
ElevenLabsTTSService      ..|> puterTTS
ElevenLabsTTSService      ..|> driverCaps
OpenAITTSService          ..|> puterTTS
OpenAITTSService          ..|> driverCaps

' ─────────────────────────────────────────────
' Image provider implementations
' ─────────────────────────────────────────────
OpenAiImageGenerationProvider    ..|> IImageProvider
GeminiImageGenerationProvider    ..|> IImageProvider
TogetherImageGenerationProvider  ..|> IImageProvider
XAIImageGenerationProvider       ..|> IImageProvider
CloudflareImageGenerationProvider ..|> IImageProvider
ReplicateImageGenerationProvider ..|> IImageProvider

' ─────────────────────────────────────────────
' Video provider implementations
' ─────────────────────────────────────────────
OpenAIVideoGenerationProvider    ..|> IVideoProvider
TogetherVideoGenerationProvider  ..|> IVideoProvider
GeminiVideoGenerationProvider    ..|> IVideoProvider

' ─────────────────────────────────────────────
' Composition: services own their provider maps
' ─────────────────────────────────────────────
AIImageGenerationService *-- IImageProvider : routes to >
AIVideoGenerationService *-- IVideoProvider : routes to >

' ─────────────────────────────────────────────
' Service dependencies (infrastructure)
' ─────────────────────────────────────────────
AIImageGenerationService  ..> MeteringService : uses
AIImageGenerationService  ..> DriverService   : uses
AIImageGenerationService  ..> EventService    : uses
AIImageGenerationService  ..> ErrorService    : uses

AIVideoGenerationService  ..> MeteringService : uses
AIVideoGenerationService  ..> DriverService   : uses
AIVideoGenerationService  ..> EventService    : uses

MistralOCRService         ..> MeteringService : uses
AWSPollyService           ..> MeteringService : uses
ElevenLabsTTSService      ..> MeteringService : uses
OpenAITTSService          ..> MeteringService : uses

@enduml
