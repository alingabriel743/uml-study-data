@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title App Management Services

' ─────────────────────────────────────────
' Base classes
' ─────────────────────────────────────────
abstract class BaseService {
    +_construct()
    +_init()
    +'__on_boot.consolidation'()
}

abstract class AdvancedBase

' ─────────────────────────────────────────
' Shared cache namespace
' ─────────────────────────────────────────
class AppRedisCacheSpace {
    ~app lookup cache
    ~app stats cache
}

' ─────────────────────────────────────────
' modules/data-access
' ─────────────────────────────────────────
package "modules/data-access" {

    class AppRepository {
        ~stub — empty body
    }

    class AppService {
        -{static} PROTECTED_FIELDS
        -{static} READ_ONLY_FIELDS
        -repository: AppRepository
        -db
        --
        +_init()
        +getAppRootDirId(app)
        ..Entity Service Delegates..
        +create({object, options})
        +read({uid, id, params})
        +update({object, id, options})
        +upsert({object, id, options})
        +select(options)
        +delete({uid, id})
        ..Private..
        -select({predicate, params})
        -read({uid, id, params, backend_only_options})
        -create({object, options})
        -update({object, id, options})
        -delete({uid, id})
        -execute_insert(object, uid, owner_user_id, app_owner_id)
        -execute_update(object, old_app)
        -emit_change_events(object, old_app)
        -check_protected_app_access(app, owner_user_id)
        -check_app_owner_permission(old_app, actor)
        -resolveAppId(app)
        -readCanonicalAppUidAlias(oldAppUid)
        -writeCanonicalAppUidAlias({oldAppUid, canonicalAppUid})
        -handle_name_conflict(object, old_app, options)
        -claimAppOwnershipByIdForUser({appId, userId})
    }
}

' ─────────────────────────────────────────
' modules/apps
' ─────────────────────────────────────────
package "modules/apps" {

    class AppIconService {
        -{static} MODULES: {sharp, bmp, ico, uuidv4}
        -{static} ICON_SIZES: [16,32,64,128,256,512]
        -dir_app_icons: FSNodeContext
        -appIconsBaseUrl: string|null
        -pendingIconSizeJobs: Set
        -pendingDataUrlIconWrites: Set
        --
        +getSizes(): number[]
        +iconifyApps({apps, size}): apps[]
        +getAppIconPath({appUid, size}): string|null
        +getAppIconEndpointUrl({appUid}): string|null
        +normalizeAppUid(appUid): string
        +isDataUrl(value): boolean
        +parseAppIconEndpointUrl(iconUrl): {appUid, size}|null
        +isAppIconEndpointUrl(iconUrl): boolean
        +getSizedIconUrl({appUid, size}): string|null
        +getOriginalIconUrl({appUid}): string|null
        +ensureAppIconsDirectory({dirSystem?}): FSNodeContext
        +generateMissingSizeFromOriginal({appUid, size}): void
        +queueMissingSizeFromOriginal({appUid, size}): void
        +queueDataUrlIconWrite({appUid, dataUrl}): void
        +persistConvertedIconUrl({appUid, iconUrl}): void
        +createAppIcons({data}): void
        ..Routes..
        ~GET /app-icon/:app_uid
        ~GET /app-icon/:app_uid/:size
    }

    class AppInformationService {
        -{static} LOG_DEBUG: true
        -tags: {}
        -mysqlDateFormats: {hour,day,week,month,year}
        -clickhouseGroupByFormats: {hour,day,week,month,year}
        --
        +_construct()
        +'__on_boot.consolidation'()
        +invalidateAppCache({appUid, oldName, app}): void
        +get_stats(app_uid, options): object
        +_refresh_app_stats(): void
        +_refresh_app_stat_referrals(): void
        +delete_app(app_uid, app, options): void
        +buildCanonicalAppUidAliasKey_(appUid): string
        +buildCanonicalAppUidAliasReverseKey_(canonicalAppUid): string
        +generateAllPeriods(startDate, endDate, grouping): object[]
        +mergeWithGeneratedPeriods(actualData, allPeriods, stats_grouping): object[]
    }
}

' ─────────────────────────────────────────
' services (registry)
' ─────────────────────────────────────────
package "services" {

    class MapCollection {
        -map_id: uuid
        -map: Map
        --
        +get(key): any
        +exists(key): boolean
        +set(key, value): void
        +del(key): void
        +keys(): string[]
        -_mk_key(key): string
    }

    class RegistryService {
        -collections_: {}
        --
        +_construct()
        +'__on_boot.consolidation'()
        +register_collection(name): MapCollection
        +get(name): MapCollection
    }

    class RegistrantService {
        +_init()
        -_populate_registry()
    }
}

' ─────────────────────────────────────────
' Inheritance
' ─────────────────────────────────────────
AppService       --|> BaseService
AppIconService   --|> BaseService
AppInformationService --|> BaseService
RegistryService  --|> BaseService
RegistrantService --|> BaseService
MapCollection    --|> AdvancedBase

' ─────────────────────────────────────────
' Composition / Aggregation
' ─────────────────────────────────────────
AppService *-- AppRepository : repository

RegistryService *-- MapCollection : creates / owns

' ─────────────────────────────────────────
' Dependencies
' ─────────────────────────────────────────
AppService ..> AppIconService          : uses (icon resolution\n& creation)
AppService ..> AppInformationService   : uses (delete_app on merge)
RegistrantService ..> RegistryService  : registers collections

AppService            ..> AppRedisCacheSpace : cache invalidation
AppIconService        ..> AppRedisCacheSpace : icon cache
AppInformationService ..> AppRedisCacheSpace : stats cache

' ─────────────────────────────────────────
' Event flows (notes)
' ─────────────────────────────────────────
note as EventNote
  <b>Event Bus Wiring</b>
  AppService emits:
    • app.changed → AppInformationService
    • app.rename  → AppInformationService
    • app.new-icon → AppIconService

  AppInformationService emits:
    • apps.invalidate (after cache flush)
    • app.changed (action:deleted)
end note

@enduml
