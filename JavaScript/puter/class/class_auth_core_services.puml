@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Authentication Core Services

' ─────────────────────────────────────
' Base / external stubs
' ─────────────────────────────────────
package "Framework Base" {
    abstract class BaseService {
        +_construct(): void
        +_init(): void
    }
    abstract class AdvancedBase {
    }
}

' ─────────────────────────────────────
' Auth Services
' ─────────────────────────────────────
package "Auth Services" {

    class AuthService {
        -db: DatabaseClient
        -sessionService: SessionService
        -tokenService: TokenService
        -sessions: object
        --
        +_init(): async void
        +authenticate_from_token(token): async Actor
        +create_session_(user, meta): async Session
        +create_session_token(user, meta): async object
        +check_session(cur_token, meta): async Actor
        +remove_session_by_token(token): async void
        +create_access_token(authorizer, permissions, options): async object
        +revoke_access_token(tokenOrUuid): async void
        +list_sessions(actor): async Session[]
        +revoke_session(actor, uuid): async void
        +get_user_app_token_from_origin(origin): async string
        +resolveCanonicalAppUidFromOrigin(origin): async string
        +resolvePrivateBootstrapIdentityFromToken(token, opts): async Actor
        +readCanonicalAppUidFromRedisCache(origin): async string
        +writeCanonicalAppUidToRedisCache(origin, appUid): async void
        +invalidateCanonicalAppUidCacheForOrigins(origins): async void
        +getHostedSubdomainOwnerUserId(subdomain): async number
    }

    class TokenService {
        -secret: string
        -compression: object
        --
        +_construct(): void
        +_init(): void
        +sign(scope, payload, options): string
        +verify(scope, token): object
        -_compress_payload(context, payload): object
        -_decompress_payload(context, payload): object
    }

    class SignupService {
        --
        +create_new_user(params): async OutcomeObject
    }

    class PreAuthService {
        --
        +on_install_middlewares_early(app): async void
    }
}

' ─────────────────────────────────────
' Actor Model
' ─────────────────────────────────────
package "Actor Model" {

    class Actor {
        -type: ActorType
        {static} -system_actor_: Actor
        --
        {static} +get_system_actor(): Actor
        {static} +create(type, params): async Actor
        {static} +adapt(actor): Actor
        +get uid(): string
        +get private_uid(): string
        +toLogFields(): object
        +clone(): Actor
        +get_related_actor(type_class): Actor
    }

    abstract class ActorType {
        --
        +constructor(o): void
    }

    class SystemActorType {
        --
        +get uid(): string
        +get_related_type(type_class): SystemActorType
    }

    class UserActorType {
        +user: UserObject
        +hasHttpOnlyCookie: boolean
        --
        +get uid(): string
        +get_related_type(type_class): UserActorType
    }

    class AppUnderUserActorType {
        +user: UserObject
        +app: AppObject
        --
        +get uid(): string
        +get_related_type(type_class): ActorType
    }

    class AccessTokenActorType {
        +authorizer: Actor
        +authorized: Actor
        +token: string
        --
        +get uid(): string
        +get_related_actor(): void
    }

    class SiteActorType {
        +site: SiteObject
        --
        +get uid(): string
    }
}

' ─────────────────────────────────────
' Value Objects
' ─────────────────────────────────────
package "Value Objects" {
    class CreatedUserOutcome {
        +user_id: number
    }
}

' ─────────────────────────────────────
' Inheritance
' ─────────────────────────────────────
AuthService    --|> BaseService
TokenService   --|> BaseService
SignupService  --|> BaseService
PreAuthService --|> BaseService

Actor --|> AdvancedBase

SystemActorType      --|> ActorType
UserActorType        --|> ActorType
AppUnderUserActorType --|> ActorType
AccessTokenActorType --|> ActorType

' ─────────────────────────────────────
' Composition & Aggregation
' ─────────────────────────────────────
AuthService *-- TokenService       : tokenService
Actor       *-- ActorType          : type

' ─────────────────────────────────────
' Dependencies
' ─────────────────────────────────────
AuthService ..> Actor                 : creates / resolves
AccessTokenActorType ..> Actor        : authorizer / authorized
AppUnderUserActorType ..> UserActorType : get_related_type()
SignupService ..> CreatedUserOutcome  : produces

@enduml
