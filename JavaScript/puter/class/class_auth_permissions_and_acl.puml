@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #856404
}

title Permissions & Access Control

abstract class BaseService {
    +_construct(): void
    +_init(): Promise<void>
}

package "Permission Engine" {

    class PermissionService {
        -{static} CONCERN: string = "permissions"
        -_permission_rewriters: PermissionRewriter[]
        -_permission_implicators: PermissionImplicator[]
        -_permission_exploders: PermissionExploder[]
        -_PERMISSION_SCAN_CACHE_TTL_SECONDS: number
        -db: DatabaseConnection
        -kvService: KVStoreInterface
        --
        +check(actor: Actor, permission_options: string|string[], scan_options?): Promise<boolean>
        +canManagePermission(actor: Actor, permission: string): Promise<boolean>
        +scan(actor: Actor, permission_options: string|string[], ...): Promise<any[]>
        +grant_user_app_permission(actor, app_uid, permission, extra?, meta?): Promise<void>
        +revoke_user_app_permission(actor, app_uid, permission, meta?): Promise<void>
        +grant_user_user_permission(actor, username: string, permission, extra?, meta?): Promise<void>
        +revoke_user_user_permission(actor, username, permission, meta?): Promise<void>
        +grant_user_group_permission(actor, gid, permission, extra?, meta?): Promise<void>
        +revoke_user_group_permission(actor, gid, permission, meta?): Promise<void>
        +get_higher_permissions(permission): Promise<Set>
        +get_parent_permissions(permission): string[]
        +register_rewriter(rewriter: PermissionRewriter): void
        +register_implicator(implicator: PermissionImplicator): void
        +register_exploder(exploder: PermissionExploder): void
        #scan(actor, permission_options, _reserved, state, scan_options): Promise<any[]>
        #flat_grant_user_user_permission(actor, user, permission, extra?): Promise<void>
        #linked_grant_user_user_permission(actor, user, permission, extra?, meta?): Promise<void>
    }

    class PermissionImplicator <<helper>> {
        +{static} create(opts: \{ id, shortcut?, matcher, checker \}): PermissionImplicator
        +matches(permission: string): boolean
        +run(ctx: object): Promise<object>
    }

    class PermissionRewriter <<helper>> {
        +matches(permission: string): boolean
        +rewrite(permission: string): Promise<string>
    }

    class PermissionExploder <<helper>> {
        +matches(permission: string): boolean
        +explode(permission: string): Promise<string[]>
    }

    class PermissionUtil <<utility>> {
        +{static} join(...parts): string
        +{static} split(permission: string): string[]
        +{static} isManage(permission: string): boolean
        +{static} reading_to_options(reading): any[]
    }
}

package "ACL" {

    class ACLService {
        --
        +check(actor: Actor, resource: FSNode|object, mode: string): Promise<boolean>
        +checkResource(actor: Actor, resource: object, mode: string): Promise<boolean>
        +set_user_user(issuer: Actor, holder: Actor|string, resource: FSNode|string, mode: string, options?): Promise<boolean>
        +stat_user_user(issuer: Actor, holder: Actor, resource: FSNode): Promise<object>
        +get_safe_acl_error(actor, resource, mode): Promise<APIError>
        +get_highest_mode(): string
        -_check_fsNode(actor: Actor, fsNode: FSNode, mode: string): Promise<boolean>
        -_higher_modes(mode: string): string[]
    }

    note bottom of ACLService
        Mode hierarchy:
        see < list < read < write (< manage)
        Routes: POST /acl/stat-user-user
                POST /acl/set-user-user
    end note
}

package "Groups" {

    class GroupService {
        -db: DatabaseConnection
        -kvkey: string
        --
        +get(uid: string): Promise<Group|undefined>
        +create(owner_user_id, extra?, metadata?): Promise<string>
        +list_groups_with_owner(owner_user_id): Promise<GroupEntity[]>
        +list_groups_with_member(user_id): Promise<GroupEntity[]>
        +list_public_groups(): Promise<GroupEntity[]>
        +list_members(uid: string): Promise<string[]>
        +add_users(uid: string, users: string[]): Promise<void>
        +remove_users(uid: string, users: string[]): Promise<void>
    }

    class VirtualGroupService {
        -groups_: \{ [id: string]: object \}
        -membership_implicators_: Function[]
        --
        +register_membership_implicator(implicator: Function): void
        +add_group(group: \{ id: string \}): void
        +get_virtual_groups(actor: Actor): object[]
    }

    class GroupEntity <<factory object>> {
        -values: object
        --
        +fetch_members(): Promise<string[]>
        +get_client_value(options?: \{ members?: boolean \}): Promise<object>
    }
}

package "Shortcuts" {

    class PermissionShortcutService {
        --
        +_init(): void
    }

    note bottom of PermissionShortcutService
        Registers a shortcut implicator on
        PermissionService for:
        'service:puter-kvstore:ii:puter-kvstore'
        Rate-limit: max 200 per 10000ms
    end note
}

class Actor <<value object>> {
    +type: ActorType
    +uid: string
    --
    +{static} adapt(actor): Actor
}

enum ActorType {
    SystemActorType
    UserActorType
    AppUnderUserActorType
    AccessTokenActorType
}

' ── Inheritance ──────────────────────────────────────
PermissionService      --|> BaseService
ACLService             --|> BaseService
GroupService           --|> BaseService
VirtualGroupService    --|> BaseService
PermissionShortcutService --|> BaseService

' ── Composition / Aggregation ────────────────────────
PermissionService o-- "0..*" PermissionRewriter   : _permission_rewriters
PermissionService o-- "0..*" PermissionImplicator : _permission_implicators
PermissionService o-- "0..*" PermissionExploder   : _permission_exploders

GroupEntity ..> GroupService : lazy-loads members\nvia list_members()

' ── Service Dependencies ─────────────────────────────
ACLService             ..> PermissionService      : scan() / grant / revoke\npermissions
PermissionShortcutService ..> PermissionService   : register_implicator()
PermissionService      ..> VirtualGroupService    : get_virtual_groups()\nduring scan
PermissionService      ..> GroupService           : group-based\npermission lookups

' ── Actor Usage ──────────────────────────────────────
ACLService         ..> Actor : check(actor, ...)
PermissionService  ..> Actor : check(actor, ...)
Actor              --> ActorType : type

@enduml
