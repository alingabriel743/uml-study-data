@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Backend Kernel & Boot Infrastructure

' ─────────────────────────────────────────────
'  External / Base Abstractions
' ─────────────────────────────────────────────
package "Base Abstractions" {
    abstract class AdvancedBase {
    }

    abstract class BaseService {
        +__on_boot_ready(): Promise<void>
    }

    class EmitterFeature <<mixin>> {
        +emit(event, ...args): void
        +on(event, handler): void
    }

    class TeePromise {
        +resolve(value): void
        +then(...): Promise
    }
}

' ─────────────────────────────────────────────
'  Core Kernel
' ─────────────────────────────────────────────
package "Kernel (src/backend/src)" {

    class Kernel {
        -modules: Array
        -useapi: UseAPI
        -entry_path: string
        -extensionExports: object
        -extensionInfo: object
        -registry: object
        -runtimeModuleRegistry: RuntimeModuleRegistry
        -environment: RuntimeEnvironment
        -services: Container
        --
        +constructor(entry_path: string)
        +add_module(module): void
        +boot(): void
        +_runtime_init(boot_parameters): void
        +_install_modules(): Promise<void>
        +_boot_services(): Promise<void>
        +install_extern_mods_(): Promise<void>
        +install_extern_mod_(mod_install_root_context, mod_dirname, mod_path): Promise<mod_entry>
        +_run_extern_mod(mod_entry): Promise<void>
        +_create_mod_context(parent, options): Context
        +create_mod_package_json(mod_path, name, entry): Promise<object>
        +run_npm_install(path): Promise<void>
    }

    class Extension {
        -service: ExtensionServiceState
        -log: Function
        -LOG: Function
        -terminal_color: number
        -only_one_preinit_fn: Function
        -only_one_init_fn: Function
        -registry: object
        -name: string
        -runtime: RuntimeModule
        --
        +constructor()
        +ensure_service_(): void
        +register(typeKey, keyOrData, data): void
        +reg(...a): void
        +get(path, handler, options): void
        +post(path, handler, options): void
        +put(path, handler, options): void
        +delete(path, handler, options): void
        +use(...args): void
        +import(name): any
        +example(): void
        ..getters..
        +db: DatabaseInstance
        +services: Container
        +errors: ErrorService
        +exports: any
        +preinit: Function
        +init: Function
    }

    class ExtensionModule {
        -extension: Extension
        --
        +install(context): Promise<void>
    }

}

' ─────────────────────────────────────────────
'  Service Container
' ─────────────────────────────────────────────
package "Service Container (src/backend/src/services)" {

    class Container {
        -instances_: object
        -implementors_: object
        -modname_: string
        -modules_: object
        -enforcers: Array<Function>
        +ready: TeePromise
        --
        +constructor()
        +registerEnforcer(func): void
        +registerModule(name, module): void
        +setModuleName(name): void
        +registerService(name, cls, args): void
        +patchService(name, patch, args): void
        +get_implementors(interface_name): Array
        +set(name, instance): void
        +get(name, opts): ServiceInstance
        +_get(name, opts): ServiceInstance
        +has(name): boolean
        +init(): Promise<void>
        +emit(id, ...args): Promise<void>
        ..getters..
        +values: object
    }

    class ProxyContainer {
        -delegate: Container
        -instances_: object
        --
        +constructor(delegate: Container)
        +set(name, instance): void
        +get(name): ServiceInstance
        +has(name): boolean
        ..getters..
        +values: object
    }

    class BootScriptService {
        {static} MODULES: object
        --
        +__on_boot_ready(): Promise<void>
        +run_script(boot_json: Array): Promise<void>
    }

}

' ─────────────────────────────────────────────
'  Boot Utilities
' ─────────────────────────────────────────────
package "Boot Utilities (src/backend/src/util)" {

    class ConsoleLogManager <<Singleton>> {
        {static} -instance_: ConsoleLogManager
        {static} +CONSOLE_METHODS: string[]
        {static} +PROXY_METHOD: Function
        {static} +getInstance(): ConsoleLogManager
        --
        -__original_console: Console
        -__original_methods: object
        -__proxy_methods: object
        -__log_decorators: object
        -__log_hooks_post: object
        --
        +constructor()
        +initialize_proxy_methods(methods?): void
        +decorate(method, dec_fn): void
        +decorate_all(dec_fn): void
        +post_all(post_fn): void
        +log_raw(method, ...args): void
        +get_log_decorators_(method): Array
        +get_post_hooks_(method): Array
    }

}

' ─────────────────────────────────────────────
'  Referenced Runtime Types (lightweight stubs)
' ─────────────────────────────────────────────
package "Runtime Support" {
    class RuntimeModuleRegistry {
        +register(name, module): void
        +get(name): RuntimeModule
    }

    class RuntimeModule {
        +exports: any
        +import(name): any
    }

    class RuntimeEnvironment {
        +parse(boot_parameters): void
    }

    class ExtensionServiceState {
        +name: string
    }
}

' ─────────────────────────────────────────────
'  Inheritance
' ─────────────────────────────────────────────
Kernel          --|> AdvancedBase
Extension       --|> AdvancedBase
ExtensionModule --|> AdvancedBase
BootScriptService --|> BaseService

' ─────────────────────────────────────────────
'  Mixin
' ─────────────────────────────────────────────
Extension       ..|> EmitterFeature : <<mixin>>

' ─────────────────────────────────────────────
'  Composition / Aggregation
' ─────────────────────────────────────────────
Kernel          *-- Container          : services
Kernel          *-- RuntimeModuleRegistry : runtimeModuleRegistry
Kernel          *-- RuntimeEnvironment : environment
Kernel          o-- ConsoleLogManager  : uses (boot)

Kernel          ..> ExtensionModule    : creates
Kernel          ..> Extension          : creates

ExtensionModule *-- Extension          : extension

Extension       *-- ExtensionServiceState : service
Extension       o-- RuntimeModule      : runtime

ProxyContainer  o-- Container          : delegate

Container       *-- TeePromise         : ready

BootScriptService ..> Container        : registered via Kernel._install_modules()

' ─────────────────────────────────────────────
'  Boot Sequence Note
' ─────────────────────────────────────────────
note bottom of Kernel
  Boot sequence:
  1. boot() → _runtime_init() → new Container()
  2. initialize_proxy_methods() on ConsoleLogManager
  3. _install_modules() → registerModule + install(context)
  4. install_extern_mods_() → scan mod_paths →
     install_extern_mod_() → _run_extern_mod()
  5. container.init() → service lifecycle
  6. _boot_services() → emit(boot.consolidation)
     → emit(boot.activation) → emit(boot.ready)
  7. BootScriptService.__on_boot_ready() runs scripts
end note

note right of Container
  Event-driven boot stages:
  boot.consolidation → boot.activation → boot.ready
  BaseService subclasses implement __on_{event}
  to subscribe automatically.
end note

@enduml
