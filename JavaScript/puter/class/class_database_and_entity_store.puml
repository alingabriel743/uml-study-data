@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
}

title Database Access & Entity Store

' ─────────────────────────────────────────
'  External / Base References
' ─────────────────────────────────────────

package "External Dependencies" {
    abstract class BaseService {
        {abstract} +_init(): Promise<void>
    }

    abstract class AdvancedBase {
        ' from @heyputer/putility
    }

    class "better-sqlite3\n«driver»" as BetterSqlite3 {
        +prepare(sql): Statement
        +exec(sql): void
        +transaction(fn): Function
    }
}

' ─────────────────────────────────────────
'  Database Access Layer
' ─────────────────────────────────────────

package "Database Access" {

    abstract class BaseDatabaseAccessService {
        {static} +DB_WRITE: symbol
        {static} +DB_READ: symbol
        --
        +case(choices): any
        +get(): BaseDatabaseAccessService
        +read(query, params): Promise<any[]>
        +tryHardRead(query, params): Promise<any[]>
        +requireRead(query, params): Promise<any[]>
        +pread(query, params): Promise<any[]>
        +write(query, params): Promise<{insertId, anyRowsAffected}>
        +insert(table_name, data): Promise<any>
        +batch_write(statements): Promise<void>
        --
        #_gen_insert_sql(table_name, data): string
        #{abstract} _read(query, params): Promise<any[]>
        #{abstract} _tryHardRead(query, params): Promise<any[]>
        #{abstract} _write(query, params): Promise<any>
        #{abstract} _batch_write(entries): Promise<void>
    }

    class SqliteDatabaseAccessService {
        {static} +ENGINE_NAME: string = "sqlite"
        {static} +MODULES: object
        --
        -db: Database
        -config: { path: string }
        --
        +_init(): Promise<void>
        +__on_boot.consolidation(): Promise<void>
        --
        #_read(query, params): Promise<any[]>
        #_tryHardRead(query, params): Promise<any[]>
        #_write(query, params): Promise<{insertId, anyRowsAffected}>
        #_batch_write(entries): Promise<void>
        --
        -sqlite_transform_query_(query): string
        -sqlite_transform_params_(params): any[]
        -run_js_migration_({ filename, contents }): Promise<void>
    }

    note bottom of SqliteDatabaseAccessService
        Runs 43+ schema migrations on _init.
        Supports both .sql and .js migration files.
        _batch_write uses db.transaction().
    end note
}

' ─────────────────────────────────────────
'  Entity Store Layer
' ─────────────────────────────────────────

interface "«interface»\ncrud-q" as CrudQ {
    +create({ object, options }): Promise<any>
    +update({ object, id, options }): Promise<any>
    +upsert({ object, id, options }): Promise<any>
    +read({ uid, id, params }): Promise<Entity|null>
    +select(options): Promise<Entity[]>
    +delete({ uid, id }): Promise<any>
}

package "Entity Store" {

    class EntityStoreService {
        {static} +IMPLEMENTS: { "crud-q": CrudQ }
        --
        -upstream: object
        -om: object
        --
        +_init(args: { entity, upstream }): Promise<void>
        +create(entity: Entity, options): Promise<any>
        +read(uid: string): Promise<Entity|null>
        +select({ predicate, ...rest }): Promise<Entity[]>
        +update(entity: Entity, id, options): Promise<any>
        +upsert(entity: Entity, id, options): Promise<any>
        +delete(uid: string): Promise<any>
        --
        -fetch_based_on_complex_id_(id): Promise<Entity|null>
        -fetch_based_on_either_id_(uid, id): Promise<Entity|null>
    }

    class Entity {
        -om: object
        -found: boolean | undefined
        -private_meta: object
        -values_: object
        -init_arg_keys_: string[]
        --
        {static} +create(args: { om }, data): Promise<Entity>
        --
        +clone(): Promise<Entity>
        +apply(other: Entity): Promise<Entity>
        +set(key: string, value: any): Promise<void>
        +get(key: string): Promise<any>
        +del(key: string): Promise<void>
        +has(key: string): Promise<boolean>
        +is_set(key: string): Promise<boolean>
        +check(condition: object): Promise<boolean>
        +om_has_property(key: string): boolean
        +get_client_safe(): Promise<object>
    }

    note right of Entity
        ORM-like entity model.
        get() supports: direct value,
        factory fallback, and implicator
        (imply: { given, make }).
        set() adapts via prop.adapt().
    end note

    class "WeakConstructorFeature\n«trait»" as WeakConstructorFeature {
    }
}

' ─────────────────────────────────────────
'  Relationships
' ─────────────────────────────────────────

' Inheritance
BaseDatabaseAccessService --|> BaseService
SqliteDatabaseAccessService --|> BaseDatabaseAccessService
EntityStoreService --|> BaseService
Entity --|> AdvancedBase

' Interface implementation
EntityStoreService ..|> CrudQ : implements

' Composition / Dependency
SqliteDatabaseAccessService *-- BetterSqlite3 : uses db driver

EntityStoreService ..> Entity : creates via\nEntity.create()
EntityStoreService ..> "upstream\n«injected»" as Upstream : delegates\nCRUD ops to
Entity ..> WeakConstructorFeature : mixin

note "upstream provides:\nupsert / read / select /\ndelete / create_predicate\n(dependency injected)" as UpstreamNote
EntityStoreService .. UpstreamNote

@enduml
