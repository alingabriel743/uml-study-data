@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Driver & Capability System

' ─────────────────────────────────────────
' Framework bases (external to driver pkg)
' ─────────────────────────────────────────
package "Framework Bases" {
    abstract class BaseService {
        #services
        #log
        #errors
    }

    abstract class AdvancedBase

    abstract class BasicBase

    abstract class RuntimeEntity
}

' ─────────────────────────────────────────
' Core Driver Services
' ─────────────────────────────────────────
package "Driver Services" {

    class DriverService {
        ~{static} CONCERN : String = "drivers"
        ~{static} MODULES : Object
        ~{static} IMPLEMENTS : Object
        -drivers : Object
        -interface_to_implementation : Object
        -interface_to_test_service : Object
        -service_aliases : Object
        -interface_service_aliases : Object
        --
        +_construct()
        +_init()
        +register_driver(interface_name, implementation)
        +register_test_service(interface_name, service_name)
        +register_service_alias(service_name, alias, options)
        +get_default_implementation(interface_name)
        +call(o) : Promise<Object>
        -_call(driver, iface, method, args) : Promise<Object>
        -_process_args(interface_name, method_name, args) : Promise<Object>
        +call_new_(actor, service, iface, method, args) : Promise<Object>
        +get_service_or_throw_(name, iface) : Service
        +get_policies_for_option_(option) : Promise<Array>
        +select_best_option_(options) : Promise<Object>
        -_driver_response_from_error(e, meta) : Promise<Object>
        +usage() : Promise<Object>
    }

    class DriverUsagePolicyService {
        +get_policies_for_option_(option) : Promise<Array>
        +select_best_option_(options) : Promise<Object>
        +get_effective_policy(actor, service_name, trait_name) : Promise<Object>
    }

    class CoercionService {
        ~{static} MODULES : Object
        -coercions_ : Array
        --
        +_construct()
        +_init()
        +coerce(target : TypeSpec, typed_value : TypedValue) : Promise<TypedValue>
    }
}

' ─────────────────────────────────────────
' Type System (Meta)
' ─────────────────────────────────────────
package "Type System" {

    class TypeSpec {
        -$ : String
        -content_type : String
        --
        +{static} adapt(raw) : TypeSpec
        +hash() : String
        +equals(other : TypeSpec) : Boolean
    }

    class TypedValue {
        +type : TypeSpec
        +value : any
        -calculated_coercions_ : Object
        --
        +constructor(type, value)
    }

    class FileFacade {
        +{static} OUT_TYPES : Object
        +{static} MODULES : Object
        -values : MultiValue
        --
        +constructor()
        +set(k, v)
        +get(k)
    }
}

' ─────────────────────────────────────────
' Error Types
' ─────────────────────────────────────────
package "Error Types" {

    class DriverError {
        +source : any
        +message : String
        --
        +{static} create(source) : DriverError
        +constructor(source, message)
        +serialize() : Object
    }

    class APIError {
        +{static} forbidden()
        +serialize() : Object
    }
}

' ─────────────────────────────────────────
' Utility / Infrastructure
' ─────────────────────────────────────────
package "Utilities" {

    class Invoker {
        +{static} create(decorators, delegate) : Invoker
        +run(args) : Promise<any>
    }

    class PermissionUtil {
        +{static} join(...parts) : String
        +{static} reading_to_options(reading) : Array
    }

    class MultiValue {
        +add_factory(from, to, fn)
        +get(key) : any
        +set(key, value)
    }
}

' ─────────────────────────────────────────
' Inheritance
' ─────────────────────────────────────────
DriverService          --|> BaseService
DriverUsagePolicyService --|> BaseService
CoercionService        --|> BaseService

TypeSpec               --|> BasicBase
TypedValue             --|> RuntimeEntity
RuntimeEntity          --|> BasicBase

FileFacade             --|> AdvancedBase

' ─────────────────────────────────────────
' Dependencies & Associations
' ─────────────────────────────────────────

' DriverService core dependencies
DriverService          ..> CoercionService        : delegates coercion
DriverService          ..> DriverUsagePolicyService : resolves usage policy
DriverService          ..> Invoker                : builds decorator chain
DriverService          ..> PermissionUtil         : scans permissions
DriverService          ..> DriverError            : serializes in error response
DriverService          ..> APIError               : emits on forbidden / arg error
DriverService          ..> TypedValue             : checks instanceof for coercion
DriverService          ..> FileFacade             : accepts as file arg type

' DriverUsagePolicyService
DriverUsagePolicyService ..> PermissionUtil       : scans permissions

' CoercionService
CoercionService        ..> TypeSpec               : adapt / hash / equals
CoercionService        ..> TypedValue             : coerces, caches result

' TypedValue holds a TypeSpec
TypedValue             o-- TypeSpec               : type

' FileFacade uses MultiValue for lazy resolution
FileFacade             *-- MultiValue             : values

@enduml
