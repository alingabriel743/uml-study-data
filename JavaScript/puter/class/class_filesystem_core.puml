@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #FFF3CD
    BorderColor #856404
}

title Filesystem Core Services

' ─── External / Base ────────────────────────────────────────────────────────

package "@heyputer/putility" {
    abstract class AdvancedBase {
    }
    abstract class "concepts.Service" as ConceptsService {
    }
}

' ─── Service Infrastructure ─────────────────────────────────────────────────

package "services" {
    class BaseService {
        +services: ServiceContainer
        +config: object
        +global_config: object
        +context: Context
        +service_name: string
        +args: object
        --
        +constructor(service_resources)
        +async run_as_early_as_possible(): void
        #_construct(): void
        #_init(): void
    }
}

' ─── Filesystem Core ────────────────────────────────────────────────────────

package "modules/puterfs" {

    class PuterFSModule {
        --
        +async install(context): void
    }
    note right of PuterFSModule
      Registers ResourceService,
      SizeService, MountpointService.
      Creates RuntimeModule 'fs'
      exposing capabilities, selectors,
      lock modes & resource constants.
    end note

    class MountpointService {
        -#storage: Map<provider, StorageBackend>
        -#mounters: Map<name, FilesystemType>
        -#mountpoints: Map<path, ProviderEntry>
        --
        +register_mounter(name, mounter): void
        +async get_provider(selector): Provider
        +set_storage(provider, storage): void
        +get_storage(provider): StorageBackend
        -async "__on_boot.consolidation"(): void
    }

    class SizeService {
        +usages: Map<user_id, number>
        +db: DatabaseWriteHandle
        --
        #_construct(): void
        #_init(): void
        +async get_usage(user_id): number
        +async change_usage(user_id, delta): void
        +async add_node_size(fs, node, user, factor): void
        +async get_storage_capacity(user_or_id, opts): number
        +async add_storage(user_or_id, bytes, reason, opts): void
    }

    class ResourceService {
        +uidToEntry: Map<uid, ResourceEntry>
        +uidToPath: Map<uid, string>
        +pathToEntry: Map<path, ResourceEntry>
        ..constants..
        +{static} RESOURCE_STATUS_PENDING_CREATE: symbol
        +{static} RESOURCE_STATUS_PENDING_UPDATE: symbol
        +{static} RS_DIRECTORY_PENDING_CHILD_INSERT: symbol
        --
        +register(entry): ResourceEntry
        +free(uid): void
        +async waitForResourceByPath(path): void
        +async waitForResourceByUID(uid): void
        +async waitForResource(selector): void
        +getResourceInfo(uid): ResourceEntry
    }
    note bottom of ResourceService
      Intra-server write consistency:
      callers await freePromise before
      reading a resource being written.
    end note

    class UserParameter {
        --
        +{static} async adapt(value): UserObject
    }
    note right of UserParameter
      If object → return as-is
      If number → query by id
      If string → query by username
    end note

}

' ─── Filesystem Services ────────────────────────────────────────────────────

package "services/fs" {

    class FSLockService {
        +{static} LOG_DEBUG: boolean = true
        +{static} MODE_READ: Symbol
        +{static} MODE_WRITE: Symbol
        +locks: Map<path, RWLock>
        --
        #async _construct(): void
        #async _init(): void
        +async lock_child(path, name, mode): Promise
        +async lock_path(path, mode): Promise
    }

}

' ─── Utilities ──────────────────────────────────────────────────────────────

package "util" {

    class RWLock {
        +on_empty_: callback
        --
        +rlock(): Promise
        +wlock(): Promise
    }

}

package "extension" {

    class RuntimeModule {
        +name: string
        --
        +constructor(opts)
    }

}

' ─── Key Interfaces ─────────────────────────────────────────────────────────

interface Mounter {
    +mount(path, options): Promise<Provider>
}

interface Provider {
    +quick_check(selector): Promise<boolean>
}

interface ResourceEntry {
    +uid: string
    +path: string
    +status: symbol
    +freePromise: Promise
    +free(): void
    +onFree(): void
}

' ─── Inheritance ─────────────────────────────────────────────────────────────

BaseService       --|> ConceptsService
PuterFSModule     --|> AdvancedBase
MountpointService --|> BaseService
FSLockService     --|> BaseService
SizeService       --|> BaseService
ResourceService   --|> BaseService

' ─── Composition / Aggregation ───────────────────────────────────────────────

FSLockService  "1" *-- "0..*" RWLock        : manages >
ResourceService "1" *-- "0..*" ResourceEntry : tracks >

' ─── Creation / Registration ─────────────────────────────────────────────────

PuterFSModule ..> MountpointService : <<registers>>
PuterFSModule ..> SizeService       : <<registers>>
PuterFSModule ..> ResourceService   : <<registers>>
PuterFSModule ..> RuntimeModule     : <<creates>>

' ─── Dependencies ────────────────────────────────────────────────────────────

SizeService       ..> UserParameter   : <<uses>>
MountpointService ..> Mounter         : <<uses>>
MountpointService ..> Provider        : <<resolves>>

@enduml
