@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title GUI Services (Frontend)

' ─────────────────────────────────────────
' External / putility base classes
' ─────────────────────────────────────────
package "@heyputer/putility" {
    abstract class "concepts.Service" as ConceptsService {
    }
    abstract class AdvancedBase {
    }
}

' ─────────────────────────────────────────
' Definitions — base classes
' ─────────────────────────────────────────
package "definitions.js" {

    class Service {
        +construct(o): void
        +init(...a): void
        +get context(): {services}
    }

    class Process {
        {static} PROPERTIES: {status, ipc_status}
        +uuid: string
        +parent: uuid
        +name: string
        +meta: any
        +references: {iframe: HTMLIFrameElement}
        --
        +chstatus(status): void
        +is_init(): boolean
        +signal(sig): void
        +handle_connection(other_process): void
        +get type(): string
    }

    class InitProcess {
        {static} created_: boolean
        --
        +is_init(): true
        +_construct(): void
        +_signal(sig): void
    }
    note right of InitProcess
      Singleton. _signal fans out to all processes.
      END_HARD triggers window.location.reload().
    end note

    class PortalProcess {
        --
        +_construct(): void
        +_signal(sig): void
        +send(channel, data, context): void
        +handle_connection(connection, args): async any
    }
    note right of PortalProcess
      type='app'. Sends messages to
      iframe via postMessage.
    end note

    class PseudoProcess {
        --
        +_construct(): void
        +_signal(sig): void
    }
    note right of PseudoProcess
      type='ui'. Closes window
      element on end signal.
    end note
}

' ─────────────────────────────────────────
' GUI Services
' ─────────────────────────────────────────
package "services/" {

    class ProcessService {
        {static} INITRC: Array
        +processes: Array<Process>
        +processes_map: Map<uuid, Process>
        +uuid_to_treelist: Map<uuid, Array<Process>>
        --
        +_init(): async void
        +__on_gui_ready(): void
        +get_init(): Process
        +get_by_uuid(uuid): Process
        +get_children_of(uuid): Array<Process>
        +select_by_name(name): Array<Process>
        +register(process): void
        +register_(process): void
        +attach_to_parent_(process): void
        +unregister(uuid): void
    }

    class IPCService {
        {static} description: string
        -connections_: Object<uuid, ConnectionEntry>
        --
        +_init(): async void
        +add_connection({source, target}): {forward, backward}
        +get_connection(uuid): InternalConnection
        +register_ipc_handler(name, spec): void
    }

    class InternalConnection {
        +services: ServiceContainer
        +source: uuid
        +target: uuid
        +uuid: string
        +reverse: uuid
        --
        +send(data): void
    }
    note bottom of InternalConnection
      Resolves target process via
      ProcessService and calls
      process.send(channel, data).
    end note

    class ThemeService {
        -broadcastService: BroadcastService
        +state: {sat, hue, lig, alpha, light_text}
        +root: HTMLElement
        -save_cooldown_: TimeoutID
        --
        +_init(): async void
        +reset(): void
        +apply(values): void
        +get(key): any
        -reload_(): void
        -save_(): void
        -commit_save_(): void
    }
    note right of ThemeService
      Loads theme from ~/.__puter_gui.json.
      Sets CSS custom props on :root.
      Broadcasts 'themeChanged'. 1000ms debounce.
    end note

    class LocaleService {
        --
        +format_duration(seconds): string
    }
    note right of LocaleService
      Formats seconds into HH:MM:SS
      or localized string via i18n().
    end note

    class DebugService {
        +enabled_logs: Array<string>
        --
        +_init(): async void
        +logs(category): void
    }
    note right of DebugService
      Registers param_provider with ExecService.
      Broadcasts log.on to all iframes.
    end note

    class SettingsService {
        -tabs: Array<SettingsTab>
        --
        +_init(): async void
        +get_tabs(): Array<SettingsTab>
        +register_tab(tab): void
    }
    note right of SettingsService
      Registers 7 built-in tabs on init:
      UsageTab, AccountTab, SecurityTab,
      PersonalizationTab, LanguageTag,
      KeyboardShortcutsTab, AboutTab.
    end note

    class LaunchOnInitService {
        +commands: {window-call: Function}
        --
        +_construct(): void
        +_init(): async void
        -run_(command): void
    }
    note right of LaunchOnInitService
      Reads gui_params.launch_options.on_initialized.
      'window-call' invokes window[fn_name](...args).
    end note
}

' ─────────────────────────────────────────
' Referenced external services (stubs)
' ─────────────────────────────────────────
package "Internal Services (referenced)" {
    class ExecService <<service>> {
        +launchApp(name): void
        +register_param_provider(fn): void
    }
    class BroadcastService <<service>> {
        +sendBroadcast(name, data): void
    }
    class SettingsTab <<interface>> {
        +id: string
        +title: string
    }
}

' ─────────────────────────────────────────
' Inheritance
' ─────────────────────────────────────────
Service          --|> ConceptsService     : extends
Process          --|> AdvancedBase        : extends

ProcessService   --|> Service             : extends
IPCService       --|> Service             : extends
ThemeService     --|> Service             : extends
LocaleService    --|> Service             : extends
DebugService     --|> Service             : extends
SettingsService  --|> Service             : extends
LaunchOnInitService --|> Service          : extends

InitProcess      --|> Process             : extends
PortalProcess    --|> Process             : extends
PseudoProcess    --|> Process             : extends

' ─────────────────────────────────────────
' Composition / Aggregation
' ─────────────────────────────────────────
ProcessService   o-- Process              : aggregates >
IPCService       *-- InternalConnection   : creates >
SettingsService  *-- SettingsTab          : composes >

' ─────────────────────────────────────────
' Dependencies
' ─────────────────────────────────────────
InternalConnection ..> ProcessService     : uses (get_by_uuid)
ThemeService       ..> BroadcastService   : uses (themeChanged)
DebugService       ..> ExecService        : uses (param_provider)
ProcessService     ..> ExecService        : uses (launchApp on gui:ready)

@enduml
