@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
}

title KV Store, Captcha & Miscellaneous Services

' ─── Base / Infrastructure ───────────────────────────────────────────────────

abstract class AdvancedBase {
    +install(context): Promise<void>
}

abstract class BaseService {
    +_construct(): Promise<void>
    +_init(): Promise<void>
    +_destroy(): Promise<void>
}

' ─── KV Store Module ─────────────────────────────────────────────────────────

package "modules/kvstore" {

    class KVStoreModule {
        +install(context): Promise<void>
    }

    class KVStoreInterfaceService {
        +__on_driver.register.interfaces(): Promise<void>
    }
}

interface "puter-kvstore" as KVStoreDriverInterface {
    +get(key, optConfig)
    +set(key, value, expireAt, optConfig)
    +batchPut(items, optConfig)
    +del(key, optConfig)
    +list(as, pattern, limit, cursor, optConfig)
    +flush(optConfig)
    +update(key, pathAndValueMap, ttl, optConfig)
    +add(key, pathAndValueMap, optConfig)
    +remove(key, paths, optConfig)
    +incr(key, pathAndAmountMap, optConfig)
    +decr(key, pathAndAmountMap, optConfig)
    +expireAt(key, timestamp, optConfig)
    +expire(key, ttl, optConfig)
}

' ─── Captcha Module ──────────────────────────────────────────────────────────

package "modules/captcha/services" {

    class CaptchaService {
        -crypto: module
        -svgCaptcha: module
        -captchaTokens: Map<string, TokenEntry>
        -serviceId: string
        -requestCounter: number
        -enabled: boolean
        -expirationTime: number
        -difficulty: string
        -testMode: boolean
        -endpointsRegistered: boolean
        -cleanupInterval: Interval
        +_construct(): Promise<void>
        +_init(): Promise<void>
        +_destroy(): Promise<void>
        +__on_install.middlewares.context-aware(_, app): void
        +registerEndpoints(): void
        +generateCaptcha(): TokenResult
        +verifyCaptcha(token: string, userAnswer: string): boolean
        +cleanupExpiredTokens(): void
        -_getCaptchaOptions(): Object
        -_checkServiceHealth(): boolean
        +verifySelfTest(): boolean
        +getDiagnosticInfo(): Object
    }
}

' ─── General Services ────────────────────────────────────────────────────────

package "services" {

    class FeatureFlagService {
        -known_flags: Map<string, spec>
        +_construct(): void
        +_init(): Promise<void>
        +register(name: string, spec: Object|boolean): void
        +check(...a): Promise<boolean>
        +get_summary(actor: Object): Promise<Object>
    }

    class LockService {
        -locks: Record<string, RWLock>
        +_construct(): Promise<void>
        +_init(): Promise<void>
        +lock(name: string|string[], opt_options?, callback: Function): Promise<any>
    }
}

' ─── External / Utility ──────────────────────────────────────────────────────

class RWLock <<utility>> {
    +rlock(): Promise<handle>
    +wlock(): Promise<handle>
}

class checkCaptcha <<middleware>> {
    +handle(req, res, next): void
}

class WebServer <<external>> {
    +use(middleware): void
    +get(path, handler): void
    +post(path, handler): void
}

class WhoamiService <<external>> {
    +add_detail_provider(provider): void
}

class PermissionUtil <<external>> {
    +reading_to_options(options): Object
}

' ─── Inheritance ─────────────────────────────────────────────────────────────

KVStoreModule      --|> AdvancedBase
KVStoreInterfaceService --|> BaseService
CaptchaService     --|> BaseService
FeatureFlagService --|> BaseService
LockService        --|> BaseService

' ─── Composition / Creation ──────────────────────────────────────────────────

KVStoreModule      ..> KVStoreInterfaceService  : <<registers>>
KVStoreInterfaceService ..> KVStoreDriverInterface : <<publishes interface>>
LockService        *-- RWLock                   : manages >

' ─── Dependencies ────────────────────────────────────────────────────────────

CaptchaService     ..> checkCaptcha             : <<uses middleware>>
CaptchaService     ..> WebServer                : <<registers routes>>
FeatureFlagService ..> WhoamiService            : <<registers detail provider>>
FeatureFlagService ..> PermissionUtil           : <<checks permissions>>

' ─── Notes ───────────────────────────────────────────────────────────────────

note bottom of KVStoreInterfaceService
  Registers 'puter-kvstore' driver
  interface spec only — actual KV
  implementation is elsewhere.
end note

note right of CaptchaService
  Tokens stored in-memory Map.
  One-time use: deleted after verify.
  Auto-cleanup via Interval.
  API: GET /api/captcha/generate
       POST /api/captcha/verify
end note

note right of FeatureFlagService
  Three flag types:
  • config-flag (static boolean)
  • function-flag (dynamic fn)
  • permission-flag (feature:<name>)
end note

note right of LockService
  Always acquires write locks (wlock).
  Supports array of lock names for
  sequential acquisition.
  One-time use handles via handle.unlock().
end note

@enduml
