@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #FFF3CD
    BorderColor #856404
}
skinparam note {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
}

title Monitoring, Health & Logging

' ─────────────────────────────────────────
' External / Base
' ─────────────────────────────────────────
package "Foundation" {
    abstract class BaseService {
        +_construct()
        +_init()
    }

    abstract class AdvancedBase {
    }
}

' ─────────────────────────────────────────
' Core Health & Alarm Services
' ─────────────────────────────────────────
package "Health & Alarms" {
    class ServerHealthService {
        -checks_: Array
        -failures_: Array
        -stats_: Object
        -health_started_at_: number
        -last_check_cycle_completed_at_: number
        -web_checks_registered_: boolean
        -isDraining_: boolean
        +{static} CHECK_INTERVAL_MS: 5000
        +{static} CHECK_TIMEOUT_MS: 4000
        +_construct()
        +_init()
        +beginDrain(reason: string): void
        +add_check(name: string, fn: Function): chainable
        +get_stats(): Promise<Object>
        +get_status(): Promise<Object>
        -initDefaultChecks()
        -initServiceCheck()
        -registerWebChecks()
        -getStatusFailures(): string[]
        -getStaleHealthRunnerFailure(): string
        -getServiceIfAvailable(name: string): Service
    }

    class AlarmService {
        +alarms: Object
        +alarm_aliases: Object
        +known_errors: Array
        +isDraining: boolean
        +pager: PagerService
        +_construct()
        +_init()
        +beginDrain(reason: string): void
        +create(id: string, message: string, fields: Object): void
        +clear(id: string): void
        +get_alarm(id: string): alarm
        -adapt_id_(id: string): string
        -apply_known_errors_(alarm: Object): void
        -handle_alarm_on_(alarm: Object): void
        -handle_alarm_repeat_(alarm: Object): void
        -handle_alarm_off_(alarm: Object): void
    }

    class PagerService <<external>> {
        +alert(severity, fields): void
    }
}

' ─────────────────────────────────────────
' Telemetry & Disk Usage
' ─────────────────────────────────────────
package "Telemetry & Metrics" {
    class TelemetryService {
        +{static} TRACER_NAME: string
        -{static} sharedSdk: NodeSDK
        -{static} sharedTracer: Tracer
        -{static} telemetryStarted: boolean
        -tracer: Tracer
        +sdk: NodeSDK
        +constructor(service_resources)
        +_init()
        -{static} normalizeRoute(route): string
        -{static} buildRoute(req, route): string
        -{static} applyRouteToSpan(span, req, route): void
        -{static} buildInstrumentationConfig(): Object
        -{static} resolveExporterConfig(config): Object
        -{static} getConfiguredExporter(config): Exporter
        -{static} getMetricExporter(config): Exporter
        -{static} startTelemetry(config): Object
    }

    class HostDiskUsageService {
        +_init(): Promise<void>
        +get_host_usage(): number
        +get_extra(): Object
        +get_darwin_mountpoint(dir: string): string
        +get_linux_mountpint(dir: string): string
        +get_disk_capacity_darwin(mp: string): number
        +get_disk_capacity_linux(mp: string): number
        +get_disk_use_darwin(mp: string): number
        +get_disk_use_linux(mp: string): number
    }

    class NodeSDK <<OpenTelemetry>> {
    }
}

' ─────────────────────────────────────────
' Log Service & Context
' ─────────────────────────────────────────
package "Logging" {
    class LogService {
        +loggers: Array
        +bufferLogger: BufferLogger
        +log_directory: string
        +output_lvl: number
        +devlogger: DevLogger
        +{static} LOG_LEVEL_ERRO: 0
        +{static} LOG_LEVEL_WARN: 1
        +{static} LOG_LEVEL_INFO: 2
        +{static} LOG_LEVEL_DEBU: 4
        +{static} LOG_LEVEL_TICK: 10
        +_construct()
        +_init()
        +register_log_middleware(callback: Function): void
        +create(prefix: string, fields: Object): LogContext
        +log_(lvl, crumbs, message, fields, objects): void
        +ensure_log_directory_(): void
        +get_log_file(name: string): string
        +get_log_buffer(): Array
    }

    class LogContext {
        +logService: LogService
        +crumbs: string[]
        +fields: Object
        +sub(name: string, fields: Object): LogContext
        +info(message, fields, objects)
        +warn(message, fields, objects)
        +debug(message, fields, objects)
        +error(message, fields, objects)
        +tick(message, fields, objects)
        +noticeme(message, fields, objects)
        +system(message, fields, objects)
        +called(fields: Object)
        +cache(isCacheHit, identifier, fields)
        +log(lvl, message, fields, objects)
        +mkid(): string
        +traceOn(): LogContext
        +get_log_buffer(): Array
    }

    interface ILogger {
        +onLogMessage(lvl, crumbs, message, fields, objects)
    }

    class DevLogger {
        +onLogMessage(lvl, crumbs, message, fields, objects)
    }

    class NullLogger {
        +onLogMessage(lvl, crumbs, message, fields, objects)
    }

    class WinstonLogger {
        +onLogMessage(lvl, crumbs, message, fields, objects)
    }

    class TimestampLogger {
        -delegate: ILogger
        +onLogMessage(lvl, crumbs, message, fields, objects)
    }

    class BufferLogger {
        -buffer: Array
        -size: number
        -delegate: ILogger
        +onLogMessage(lvl, crumbs, message, fields, objects)
    }

    class CustomLogger {
        -callback: Function
        -delegate: ILogger
        +onLogMessage(lvl, crumbs, message, fields, objects)
    }
}

' ─────────────────────────────────────────
' Operation Tracing
' ─────────────────────────────────────────
package "Operation Tracing" {
    class OperationTraceService {
        +log: LogContext
        +ongoing: Object
        +constructor(services: Object)
        +add_frame(label: string): Promise<OperationFrame>
        +add_frame_sync(label: string, x?: any): OperationFrame
        +ckey(key: string): string
    }

    class OperationFrame {
        +{static} FRAME_STATUS_PENDING: string
        +{static} FRAME_STATUS_WORKING: string
        +{static} FRAME_STATUS_STUCK: string
        +{static} FRAME_STATUS_READY: string
        +{static} FRAME_STATUS_DONE: string
        +parent: OperationFrame
        +label: string
        +tags: string[]
        +attributes: Object
        +messages: string[]
        +children: OperationFrame[]
        +id: string
        +log: LogContext
        -error_: Error
        -status_: Object
        -effective_status_: Object
        +set status(status)
        +get status(): Object
        +_calc_effective_status()
        +tag(...tags): this
        +attr(key, value): this
        +get_attr(key): any
        +log(message): this
        +error(err): this
        +push_child(frame: OperationFrame): this
        +get_root_frame(): OperationFrame
        +done(): void
        +describe(show_tree, highlight): string
    }

    class BaseOperation {
        +values: Object
        +frame: OperationFrame
        +log: LogContext
        +run(firstArg, ...rest): Promise<any>
        +checkpoint(name: string): void
        +field(key, value): void
        +_post_run(): Object
        +_run(firstArg, ...rest): Promise<any>
    }
}

' ─────────────────────────────────────────
' Inheritance
' ─────────────────────────────────────────
ServerHealthService  --|> BaseService
AlarmService         --|> BaseService
TelemetryService     --|> BaseService
HostDiskUsageService --|> BaseService
LogService           --|> BaseService
BaseOperation        --|> AdvancedBase

' ─────────────────────────────────────────
' Logger interface implementations
' ─────────────────────────────────────────
DevLogger      ..|> ILogger
NullLogger     ..|> ILogger
WinstonLogger  ..|> ILogger
TimestampLogger ..|> ILogger
BufferLogger   ..|> ILogger
CustomLogger   ..|> ILogger

' ─────────────────────────────────────────
' Compositions & Aggregations
' ─────────────────────────────────────────
LogService "1" *-- "1" BufferLogger        : owns >
LogService "1" *-- "1..*" LogContext       : creates >
LogService "1" o-- "1" DevLogger           : uses >
LogService "1" o-- "1" WinstonLogger       : uses >
LogService "1" o-- "1" NullLogger          : uses >
LogService "1" o-- "0..1" CustomLogger     : middleware >

TimestampLogger "1" o-- "1" ILogger        : delegates to >
BufferLogger    "1" o-- "1" ILogger        : delegates to >
CustomLogger    "1" o-- "1" ILogger        : delegates to >

LogContext "1" o-- "1" LogService          : delegates log_() >

OperationTraceService "1" *-- "0..*" OperationFrame : tracks >
OperationFrame "1" o-- "0..1" OperationFrame : parent >
OperationFrame "1" *-- "0..*" OperationFrame : children >
OperationFrame "1" o-- "1" LogContext       : log >

BaseOperation "1" *-- "1" OperationFrame   : owns frame >
BaseOperation "1" o-- "1" LogContext        : log >

' ─────────────────────────────────────────
' Dependencies
' ─────────────────────────────────────────
ServerHealthService ..> AlarmService        : creates alarms >
AlarmService        "1" o-- "1" PagerService : pages >
AlarmService        ..> LogService           : reads log buffer >
TelemetryService    "1" o-- "1" NodeSDK      : singleton SDK >
BaseOperation       ..> OperationTraceService : registers frames >
OperationTraceService ..> LogService          : log context >

@enduml
