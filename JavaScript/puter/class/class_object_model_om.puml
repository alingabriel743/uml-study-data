@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam abstractClass {
    BackgroundColor #EAF0FB
    BorderColor #3A5DAE
}
skinparam note {
    BackgroundColor #FFF9E3
    BorderColor #C8A400
}

title Object Model (OM) Layer

' ===================================================
' Framework Base (external)
' ===================================================
abstract class AdvancedBase <<framework>> {
}

' ===================================================
' Entity
' ===================================================
package "om/entity" #E9ECEF {

    class Entity {
        -values_: object
        +found: boolean
        -private_meta: object
        +om: Mapping
        --
        +{static} async create(args, data): Entity
        +async clone(): Entity
        +async apply(other: Entity): Entity
        +async set(key: string, value: any): void
        +async get(key: string): any
        +async del(key: string): void
        +async has(key: string): boolean
        +async check(condition: Predicate): boolean
        +async get_client_safe(): object
        +om_has_property(key: string): boolean
        +async is_set(key: string): boolean
    }
}

' ===================================================
' Definitions
' ===================================================
package "om/definitions" #E9ECEF {

    class Mapping {
        +properties: map<string, Property>
        +sql: object
        +primary_identifier: string
        +redundant_identifiers: string[]
        --
        +{static} create(context, data): Mapping
        +async get_client_safe(data: object): object
    }

    class Property {
        +name: string
        +descriptor: object
        +typ: PropType
        --
        +{static} create(context, name, descriptor): Property
        +async adapt(value): any
        +async sql_dereference(value): any
        +async sql_reference(value): any
        +async validate(value): true|Error
        +async factory(): any
        +async is_set(value): boolean
    }

    class PropType {
        +name: string
        +chains: object
        --
        +{static} create(context, data, k): PropType
        +populate_subtype_(chains): void
        +async adapt(value, extra): any
        +async sql_dereference(value, extra): any
        +async sql_reference(value, extra): any
        +async validate(value, extra): true|Error
        +async factory(extra): any
        +async is_set(value): boolean
    }

    note right of PropType
      Built-in types (om/proptypes):
      base, json, string, array, flag,
      uuid, puter-uuid, image-base64,
      url, reference, datetime, puter-node
    end note
}

' ===================================================
' Entity Storage Chain
' ===================================================
package "om/entitystorage" #E9ECEF {

    abstract class BaseES {
        +upstream: BaseES
        +om: Mapping
        +context: Context
        --
        +async provide_context(args): void
        +async read(uid): Entity
        +async upsert(entity, extra): any
        +async delete(uid, extra): any
        +async select(options): Entity[]
        +async read_transform(entity): Entity
        +async retry_predicate_rewrite(opts): Predicate
        #call_on_impl_(method, ...args): any
    }

    class SQLES {
        --
        +async create_predicate(id, args): RawCondition
        +async read(uid): Entity
        +async select(opts): Entity[]
        +async upsert(entity, extra): object
        +async delete(uid): object
        -async sql_row_to_entity_(data): Entity
        -async create_(entity): object
        -async update_(entity, old): object
        -async get_sql_data_(entity): object
        -async om_to_sql_condition_(pred): RawCondition
    }

    class ValidationES {
        --
        +async upsert(entity, extra): object
        -async validate_(entity, diff): void
    }

    class AppES {
        --
        +async create_predicate(id, ...args): Predicate
        +async read(uid): Entity
        +async select(options): Entity[]
        +async upsert(entity, extra): any
        +async delete(uid): void
        +async read_transform(entity): void
        +async retry_predicate_rewrite(opts): Predicate
        -async queueIconMigration(entity): void
    }

    class NotificationES {
        --
        +async create_predicate(id): Predicate
        +async read_transform(entity): void
    }

    class SubdomainES {
        --
        +async create_predicate(id): Eq
        +async upsert(entity, extra): any
        +async select(options): Entity[]
        -async _check_max_subdomains(): void
    }

    class ReadOnlyES {
        --
        +async upsert(): throws APIError
        +async delete(): throws APIError
    }

    class MaxLimitES {
        +max: number
        --
        +async select(options): Entity[]
    }

    class OwnerLimitedES {
        --
        +async select(options): Entity[]
        +async read(uid): Entity
    }

    class AppLimitedES {
        +permission_prefix: string
        +exception: Predicate
        --
        +async select(options): Entity[]
        +async read(uid): Entity
        +async upsert(entity, extra): any
        +async delete(uid, extra): any
        -async _check_edit_allowed(opts): void
    }

    class SetOwnerES {
        --
        +async upsert(entity, extra): any
        +async read(uid): Entity
        +async select(...args): Entity[]
        -async _sanitize_owner(entity): void
    }

    class WriteByOwnerOnlyES {
        --
        +async upsert(entity, extra): any
        +async delete(uid, extra): any
        -async _check_allowed(opts): void
    }

    class ProtectedAppES {
        --
        +async select(options): Entity[]
        +async read(uid): Entity
        -async check_(opts, entity): boolean
    }

    class ESBuilder {
        --
        +{static} create(list: Array): BaseES
    }

    note bottom of ESBuilder
      Builds a decorator chain:
      ESBuilder.create([SetOwnerES, ValidationES,
        AppES, MaxLimitES, SQLES])
    end note
}

' ===================================================
' Query Model
' ===================================================
package "om/query" #E9ECEF {

    abstract class Predicate {
        --
        +and(other: Predicate): And
    }

    class "Null" as NullPredicate {
    }

    class And {
        +children: Predicate[]
    }

    class Or {
        +children: Predicate[]
        --
        +async check(entity): boolean
    }

    class Eq {
        +key: string
        +value: any
        --
        +async check(entity): boolean
    }

    class StartsWith {
        +key: string
        +value: string
        --
        +async check(entity): boolean
    }

    class IsNotNull {
        +key: string
        --
        +async check(entity): boolean
    }

    class Like {
        +key: string
        +value: string
        --
        +async check(entity): boolean
    }

    class PredicateUtil <<utility>> {
        --
        +{static} simplify(predicate: Predicate): Predicate
        +{static} write_human_readable(pred: Predicate): string
    }
}

' ===================================================
' Inheritance — Framework Base
' ===================================================
Entity     --|> AdvancedBase
Mapping    --|> AdvancedBase
Property   --|> AdvancedBase
PropType   --|> AdvancedBase
BaseES     --|> AdvancedBase
Predicate  --|> AdvancedBase

' ===================================================
' Inheritance — Entity Storage
' ===================================================
SQLES              --|> BaseES
ValidationES       --|> BaseES
AppES              --|> BaseES
NotificationES     --|> BaseES
SubdomainES        --|> BaseES
ReadOnlyES         --|> BaseES
MaxLimitES         --|> BaseES
OwnerLimitedES     --|> BaseES
AppLimitedES       --|> BaseES
SetOwnerES         --|> BaseES
WriteByOwnerOnlyES --|> BaseES
ProtectedAppES     --|> BaseES

' ===================================================
' Inheritance — Query Predicates
' ===================================================
NullPredicate --|> Predicate
And           --|> Predicate
Or            --|> Predicate
Eq            --|> Predicate
StartsWith    --|> Predicate
IsNotNull     --|> Predicate
Like          --|> Predicate

' ===================================================
' Composition / Association
' ===================================================
Entity  *--  Mapping    : om (injected) >
Mapping *--  Property   : properties >
Property *-- PropType   : typ >
PropType --> PropType   : from (chain merge) >

BaseES  -->  BaseES     : upstream\n(decorator chain) >

ESBuilder   ..>  BaseES    : creates >
Entity      ..>  Predicate : check(condition) >
SQLES       ..>  Entity    : creates via Entity.create() >
SQLES       ..>  Predicate : translates → SQL >

@enduml
