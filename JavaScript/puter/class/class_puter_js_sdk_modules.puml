@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Puter.js SDK Modules

' ─────────────────────────────────────────
' Base / External
' ─────────────────────────────────────────
package "Base / External" {
    class EventListener {
    }
    class EventTarget <<external>> {
    }
    class Event <<external>> {
    }
}

' ─────────────────────────────────────────
' UI Module
' ─────────────────────────────────────────
package "UI Module" {
    class AppConnection {
        -#puterOrigin: string
        -#isOpen: boolean
        -#usesSDK: boolean
        +messageTarget
        +appInstanceID: string
        +targetAppInstanceID: string
        +response: any
        +{static} from(values, puter, options): AppConnection
        +get usesSDK(): boolean
        +postMessage(message): void
        +close(): void
    }

    class UI {
        -#messageID: number
        -#parentAppConnection: AppConnection
        -#callbackFunctions: Array
        -#lastBroadcastValue: Map
        -#overlayActive: boolean
        +itemWatchCallbackFunctions: Array
        +appInstanceID: string
        +parentInstanceID: string
        +onWindowClose(callback): void
        +onItemsOpened(callback): void
        +alert(message, buttons, options): Promise
        +prompt(message, placeholder, options): Promise
        +notify(options): void
        +showOpenFilePicker(options, callback): Promise
        +showSaveFilePicker(content, name, type): Promise
        +showDirectoryPicker(options, callback): Promise
        +setWindowTitle(title, window_id?): void
        +setWindowSize(width, height, window_id?): void
        +setWindowPosition(x, y, window_id?): void
        +requestPermission(options): Promise
        +launchApp(nameOrOptions, args): Promise
        +connectToInstance(app_name): Promise
        +parentApp(): AppConnection
        +setMenubar(spec): void
        +contextMenu(spec): void
        +authenticateWithPuter(): Promise
        +createWindow(options, callback): Promise
    }
}

' ─────────────────────────────────────────
' Core SDK Modules
' ─────────────────────────────────────────
package "Core SDK Modules" {
    class Auth {
        +puter
        +authToken: string
        +APIOrigin: string
        +appID: string
        +setAuthToken(authToken): void
        +setAPIOrigin(APIOrigin): void
        +signIn(options?): Promise
        +signOut(): void
        +isSignedIn(): boolean
        +whoami(): Promise
        +getUser(): Promise
        +getMonthlyUsage(): Promise
        +getGlobalUsage(): Promise
        +getDetailedAppUsage(appId): Promise
    }

    class AI {
        +puter
        +authToken: string
        +APIOrigin: string
        +setAuthToken(authToken): void
        +setAPIOrigin(APIOrigin): void
        +chat(...args): Promise
        +img2txt(...args): Promise
        +txt2speech(...args): Promise
        +txt2img(...args): Promise
        +txt2vid(...args): Promise
        +speech2txt(...args): Promise
        +speech2speech(...args): Promise
        +listModels(provider?): Promise
        +listModelProviders(): Promise
    }

    class Apps {
        +puter
        +authToken: string
        +APIOrigin: string
        +setAuthToken(authToken): void
        +setAPIOrigin(APIOrigin): void
        +list(...args): Promise
        +create(...args): Promise
        +update(...args): Promise
        +get(...args): Promise
        +delete(...args): Promise
        +checkName(name): Promise
        +getDeveloperProfile(...args): Promise
    }

    class KV {
        +MAX_KEY_SIZE: number
        +MAX_VALUE_SIZE: number
        +puter
        +authToken: string
        +APIOrigin: string
        +setAuthToken(authToken): void
        +setAPIOrigin(APIOrigin): void
        +set(...args): Promise
        +get(...args): Promise
        +del(...args): Promise
        +list(...args): Promise
        +incr(key, amount?): Promise
        +decr(key, amount?): Promise
        +flush(...args): Promise
        +expire(key, ttl): Promise
        +expireAt(key, timestamp): Promise
    }

    class OS {
        +puter
        +authToken: string
        +APIOrigin: string
        +setAuthToken(authToken): void
        +setAPIOrigin(APIOrigin): void
        +user(...args): Promise
        +version(...args): Promise
    }
}

' ─────────────────────────────────────────
' Permissions Module
' ─────────────────────────────────────────
package "Permissions Module" {
    class Perms {
        +puter
        +authToken: string
        +APIOrigin: string
        +setAuthToken(authToken): void
        +setAPIOrigin(APIOrigin): void
        +grantUser(target_username, permission): Promise
        +grantApp(app_uid, permission): Promise
        +grantGroup(group_uid, permission): Promise
        +grantOrigin(origin, permission): Promise
        +revokeUser(target_username, permission): Promise
        +revokeApp(app_uid, permission): Promise
        +request(permission): Promise
        +requestEmail(): Promise
        +requestReadDesktop(): Promise
        +requestWriteDesktop(): Promise
        +requestReadAppRootDir(app_uid): Promise
        +requestWriteAppRootDir(app_uid): Promise
        +createGroup(metadata?): Promise
        +addUsersToGroup(uid, usernames): Promise
        +removeUsersFromGroup(uid, usernames): Promise
        +listGroups(): Promise
    }
}

' ─────────────────────────────────────────
' File System Module
' ─────────────────────────────────────────
package "File System Module" {
    class PuterJSFileSystemModule {
        +puter
        +authToken: string
        +APIOrigin: string
        +socket: Socket
        +Batch: Batch
        +FSItem: FSItem
        +setAuthToken(authToken): void
        +setAPIOrigin(APIOrigin): void
        +initializeSocket(): void
        +mkdir(...args): Promise
        +copy(...args): Promise
        +move(...args): Promise
        +rename(...args): Promise
        +read(...args): Promise
        +write(...args): Promise
        +delete(...args): Promise
        +upload(...args): Promise
        +readdir(...args): Promise
        +stat(...args): Promise
        +symlink(...args): Promise
        +getReadURL(...args): Promise
        +space(...args): Promise
    }

    class FSItem {
        ' File system entry (file or directory)
    }

    note bottom of FSItem : Returned by UI.showOpenFilePicker()\nand FileSystem operations
}

' ─────────────────────────────────────────
' Driver System
' ─────────────────────────────────────────
package "Driver System" {
    class FetchDriverCallBackend {
        +getAPIOrigin: Function
        +getAuthToken: Function
        +{static} response_handlers: object
        +call(driver, method_name, parameters): Promise
    }

    class Driver {
        +iface
        +iface_name: string
        +service_name: string
        +call_backend: FetchDriverCallBackend
        +call(method_name, parameters): Promise
    }

    class Drivers {
        +puter
        +authToken: string
        +APIOrigin: string
        +drivers_: object
        +setAuthToken(authToken): void
        +setAPIOrigin(APIOrigin): void
        +list(): Promise
        +get(iface_name, service_name?): Promise
        +call(...a): Promise
    }
}

' ─────────────────────────────────────────
' Peer Module (WebRTC)
' ─────────────────────────────────────────
package "Peer Module (WebRTC)" {
    class PuterPeerServerConnectionEvent {
        +conn: PuterPeerConnection
        +user: object
    }

    class PuterPeerConnectionMessageEvent {
        +data: any
    }

    class PuterPeerServer {
        -#wsconn: WebSocket
        -#oncreateresolve: Function
        -#peerConfig
        +connections: Map
        +inviteCode: string
        +start(): Promise
        +close(): void
    }

    class PuterPeerConnection {
        -#wsconn: WebSocket
        -#datachannel: RTCDataChannel
        -#bufferedMessages: Array
        +peerconnection: RTCPeerConnection
        +connected: boolean
        +closed: boolean
        +connect(invitecode): Promise
        +close(reason?): void
        +send(message): void
        +createOffer(): Promise
        +createAnswer(): Promise
        +setRemoteDescription(description): Promise
        +addIceCandidate(candidate): Promise
    }

    class Peer {
        -#signallerUrl: string
        -#turnServers
        -#turnFailed: boolean
        +puter
        +authToken: string
        +APIOrigin: string
        +setAuthToken(authToken): void
        +setAPIOrigin(APIOrigin): void
        +ensureTurnRelays(): Promise
        +serve(options?): Promise
        +connect(invitecode, options?): Promise
    }
}

' ─────────────────────────────────────────
' Workers Module
' ─────────────────────────────────────────
package "Workers Module" {
    class WorkersHandler {
        +authToken: string
        +create(workerName, filePath, appName?): Promise
        +exec(...args): Promise
        +list(): Promise
        +get(workerName): Promise
        +delete(workerName): Promise
        +getLoggingHandle(workerName): Promise
    }
}

' ─────────────────────────────────────────
' Inheritance Relationships
' ─────────────────────────────────────────
UI --|> EventListener
AppConnection --|> EventListener
PuterPeerServer --|> EventTarget
PuterPeerConnection --|> EventTarget
PuterPeerServerConnectionEvent --|> Event
PuterPeerConnectionMessageEvent --|> Event

' ─────────────────────────────────────────
' Composition & Creation Relationships
' ─────────────────────────────────────────
UI "1" *-- "0..*" AppConnection : creates >
PuterJSFileSystemModule "1" *-- "1" FSItem : references >
Driver "1" *-- "1" FetchDriverCallBackend : delegates to >
Drivers "1" ..> Driver : creates via get() >
Peer "1" ..> PuterPeerServer : creates via serve() >
Peer "1" ..> PuterPeerConnection : creates via connect() >
PuterPeerServer "1" ..> PuterPeerConnection : creates >

' ─────────────────────────────────────────
' Module-level Dependencies
' ─────────────────────────────────────────
AI ..> Drivers : uses (listModels fallback)
Perms ..> UI : uses (requestPermission IPC)
Perms ..> Auth : uses (whoami)
Perms ..> PuterJSFileSystemModule : uses (stat)
WorkersHandler ..> UI : uses (authenticateWithPuter)
WorkersHandler ..> Apps : uses (get / create / list)
WorkersHandler ..> KV : uses (get / set)
Peer ..> UI : uses (authenticateWithPuter)

@enduml
