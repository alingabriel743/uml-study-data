@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EDF6FF
    BorderColor #3A86C8
}
skinparam enum {
    BackgroundColor #FFF8E1
    BorderColor #E6A817
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #C8A400
}

title Putility Service Framework

' ─────────────────────────────────────────
' BASES
' ─────────────────────────────────────────
package "Bases" {

  class BasicBase {
    +_get_inheritance_chain(): Array<Function>
    +_get_merged_static_array(key: string): Array
    +_get_merged_static_object(key: string): Object
  }
  note right of BasicBase
    Root base. Walks prototype chain
    to merge static FEATURES / IMPLEMENTS /
    PROPERTIES / MODULES / TOPICS / HOOKS
  end note

  class FeatureBase {
    +constructor(parameters, ...a)
    --
    ' Reads merged FEATURES[]
    ' Calls feature.install_in_instance(this, {parameters})
    ' Sets this._ = { features }
  }
  note right of FeatureBase
    Core DI mechanism: iterates FEATURES[]
    and installs each feature into the instance
  end note

}

' ─────────────────────────────────────────
' CORE
' ─────────────────────────────────────────
package "Core" {

  class AdvancedBase {
    {static} FEATURES: Feature[]
  }
  note right of AdvancedBase
    FEATURES = [
      NodeModuleDIFeature,
      PropertiesFeature,
      TraitsFeature,
      TopicsFeature
    ]
    Main base class for all backend services
  end note

  class ServiceManager {
    -context: Object
    -services_l_: Array
    -services_m_: Object
    -service_infos_: Object
    -init_listeners_: Array
    -waiting_: Object
    --
    +constructor(context)
    +async register(name, factory, options)
    +info(name): Object
    +get(name): Service
    +async aget(name): Promise<Service>
    +async wait_for_init(depends: string[]): void
    +get_waiting_for_(depends: string[]): string[]
    -async maybe_init_(name): void
    -async init_service_(name, modifiers): void
  }
  note bottom of ServiceManager
    Orchestrates dependency-ordered init.
    Status lifecycle per service:
    Registering → Pending → Initializing → Running
  end note

  enum StatusEnum {
    Registering
    Pending
    Initializing
    Running
  }

  class Service {
    {static} FEATURES: Feature[]
    {static} IMPLEMENTS: Object
    {static} DEPENDS: string[]
    --
    {static} +create(parameters, context): Service
    +async __on(id: string, args: Array): void
    +__get_event_handler(id: string): Function
    #_init(...a): void
    #_construct(o): void
    +get_depends(): string[]
  }
  note right of Service
    FEATURES = [ServiceFeature]
    IMPLEMENTS = { [TService]: { init(), construct(), get_depends() } }
    Abstract base for all concrete services.
    TService bridges ServiceManager lifecycle
    into subclass hooks (_init, _construct).
  end note

}

' ─────────────────────────────────────────
' FEATURES
' ─────────────────────────────────────────
package "Features" {

  class TraitsFeature <<feature>> {
    +install_in_instance(instance, params): void
    --
    Adds: instance.as(trait): impl
    Adds: instance.list_traits(): string[]
    Adds: instance.mixin(name, impl): void
  }

  class NodeModuleDIFeature <<feature>> {
    +install_in_instance(instance, params): void
    --
    Source: MODULES{}
    Adds: instance.modules{}
    Adds: instance.require(name): module
  }

  class PropertiesFeature <<feature>> {
    +install_in_instance(instance, params): void
    --
    Source: PROPERTIES{}
    Adds: reactive getters/setters
    Adds: instance.onchange(name, cb): void
  }

  class TopicsFeature <<feature>> {
    +install_in_instance(instance, params): void
    --
    Source: TOPICS[]
    Adds: instance._.topics{}
    Mixes in: TTopics (pub, sub)
  }

  class ServiceFeature <<feature>> {
    +install_in_instance(instance, params): void
    --
    Source: HOOKS[]
    Wires cross-service event subscriptions
    via _.init_hooks[] at init time
  }

  class EmitterFeature <<feature>> {
    +install_in_instance(instance, params): void
    --
    Adds: instance.emit(key, data, meta): Promise
    Adds: instance.on(selector, cb): Detachable
    Adds: instance.on_all(cb): void
  }
  note bottom of EmitterFeature
    Opt-in alternative to TopicsFeature.
    Not included in AdvancedBase.FEATURES by default.
  end note

}

' ─────────────────────────────────────────
' TRAITS / SYMBOLS
' ─────────────────────────────────────────
package "Traits / Symbols" {

  interface TService <<trait>> {
    +init(): void
    +construct(o): void
    +get_depends(): string[]
  }

  interface TTopics <<trait>> {
    +pub(k: string, v: any): void
    +sub(k: string, fn: Function): Detachable
  }

  interface TDetachable <<trait>>

  interface TLogger <<trait>>

}

' ─────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────

' Inheritance chain
BasicBase     <|-- FeatureBase
FeatureBase   <|-- AdvancedBase
AdvancedBase  <|-- ServiceManager
AdvancedBase  <|-- Service

' StatusEnum owned by ServiceManager
ServiceManager +-- StatusEnum

' AdvancedBase installs 4 core features
AdvancedBase  *-- TraitsFeature        : installs
AdvancedBase  *-- NodeModuleDIFeature  : installs
AdvancedBase  *-- PropertiesFeature    : installs
AdvancedBase  *-- TopicsFeature        : installs

' Service additionally installs ServiceFeature
Service       *-- ServiceFeature       : installs

' Trait implementation & usage
Service          ..|> TService         : implements via IMPLEMENTS
ServiceManager   ..>  TService         : uses (init / get_depends)
TopicsFeature    ..>  TTopics          : produces mixin on instance
ServiceFeature   ..>  TTopics          : consumes on dependency instances

' TraitsFeature is prerequisite
TraitsFeature    ..>  TopicsFeature    : prerequisite for
TraitsFeature    ..>  ServiceFeature   : prerequisite for

@enduml
