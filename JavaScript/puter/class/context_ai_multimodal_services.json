{
  "scope": "ai_multimodal_services",
  "title": "AI Multimodal Services (Image, Video, OCR, TTS)",
  "diagram_type": "class",
  "base_class": {
    "name": "BaseService",
    "role": "Common base for all services; provides this.services, this.config, this.global_config, this.log"
  },
  "classes": [
    {
      "name": "AIImageGenerationService",
      "extends": "BaseService",
      "service_name": "ai-image",
      "implements_interfaces": ["puter-image-generation", "driver-capabilities"],
      "private_fields": [
        "#providers: Record<string, IImageProvider>",
        "#modelIdMap: Record<string, IImageModel[]>"
      ],
      "getters": [
        "meteringService: MeteringService",
        "db: BaseDatabaseAccessService",
        "errorService: ErrorService",
        "eventService: EventService",
        "driverService: DriverService"
      ],
      "methods": [
        "static SERVICE_NAME = 'ai-image'",
        "static DEFAULT_PROVIDER = 'openai-image-generation'",
        "getProvider(name: string): IImageProvider | undefined",
        "getModel({ modelId, provider }): IImageModel | undefined",
        "private registerProviders(): Promise<void>",
        "__on_boot.consolidation(): Promise<void>",
        "models(): IImageModel[]",
        "list(): string[]",
        "generate(parameters: IGenerateParams): Promise<TypedValue>"
      ],
      "providers_registered": [
        "OpenAiImageGenerationProvider",
        "GeminiImageGenerationProvider",
        "TogetherImageGenerationProvider",
        "XAIImageGenerationProvider",
        "CloudflareImageGenerationProvider",
        "ReplicateImageGenerationProvider"
      ],
      "dependencies": ["MeteringService", "BaseDatabaseAccessService", "ErrorService", "EventService", "DriverService", "APIError", "Context", "TypedValue"]
    },
    {
      "name": "AIVideoGenerationService",
      "extends": "BaseService",
      "service_name": "ai-video",
      "implements_interfaces": ["puter-video-generation", "driver-capabilities"],
      "private_fields": [
        "#providers: Record<string, IVideoProvider>",
        "#modelIdMap: Record<string, IVideoModel[]>"
      ],
      "getters": [
        "meteringService: MeteringService",
        "eventService: EventService",
        "driverService: DriverService"
      ],
      "methods": [
        "static SERVICE_NAME = 'ai-video'",
        "static DEFAULT_PROVIDER = 'openai-video-generation'",
        "getProvider(name: string): IVideoProvider | undefined",
        "getModel({ modelId, provider }): IVideoModel | undefined",
        "private registerProviders(): Promise<void>",
        "__on_boot.consolidation(): Promise<void>",
        "models(): IVideoModel[]",
        "list(): string[]",
        "generate(parameters: IGenerateVideoParams): Promise<any>"
      ],
      "providers_registered": [
        "OpenAIVideoGenerationProvider",
        "TogetherVideoGenerationProvider",
        "GeminiVideoGenerationProvider"
      ],
      "dependencies": ["MeteringService", "EventService", "DriverService", "APIError", "Context"]
    },
    {
      "name": "MistralOCRService",
      "extends": "BaseService",
      "implements_interfaces": ["puter-ocr", "driver-capabilities"],
      "fields": [
        "meteringService: MeteringService",
        "models: array (mistral-ocr-latest, aliases: mistral-ocr-2505, mistral-ocr)",
        "client: Mistral (initialized in _init)",
        "api_base_url: string"
      ],
      "methods": [
        "_init(): Promise<void>",
        "recognize({ source, model, pages, includeImageBase64, imageLimit, imageMinSize, bboxAnnotationFormat, documentAnnotationFormat, test_mode }): Promise<object>",
        "_buildDocumentChunkFromSource(fileFacade): Promise<object>",
        "_safeFileValue(fileFacade, key): Promise<any>",
        "_chunkFromUrl(url, fileName, mimeType): object",
        "_inferMimeFromName(name): string|undefined",
        "_extractMimeFromDataUrl(url): string|undefined",
        "_createDataUrl(buffer, mimeType): string",
        "#normalizeOcrResponse(response): object",
        "#recordOcrUsage(response, model, options): void",
        "#sampleOcrResponse(): object"
      ],
      "external_clients": ["Mistral (@mistralai/mistralai)"],
      "dependencies": ["BaseService", "MeteringService", "Context", "APIError", "mime-types", "path"]
    },
    {
      "name": "AWSPollyService",
      "extends": "BaseService",
      "implements_interfaces": ["puter-tts", "driver-capabilities"],
      "fields": [
        "clients_: Record<string, PollyClient>",
        "meteringService: MeteringService (getter)"
      ],
      "methods": [
        "_construct(): Promise<void>",
        "_create_aws_credentials(): object",
        "_get_client(region): PollyClient",
        "describe_voices(): Promise<object> [Redis-cached, TTL 10min]",
        "synthesize_speech(text, { format, voice_id, language, text_type, engine }): Promise<SynthesizeSpeechOutput>",
        "maybe_get_language_appropriate_voice_(language, engine): Promise<string|null>",
        "get_default_voice_for_engine_(engine): Promise<string>",
        "[IMPLEMENTS] list_voices({ engine }): Promise<Voice[]>",
        "[IMPLEMENTS] list_engines(): Promise<Engine[]>",
        "[IMPLEMENTS] synthesize({ text, voice, ssml, language, engine, test_mode }): Promise<TypedValue>"
      ],
      "engines": ["standard", "neural", "long-form", "generative"],
      "external_clients": ["PollyClient (AWS SDK)", "redisClient"],
      "dependencies": ["BaseService", "MeteringService", "Context", "APIError", "TypedValue", "PollyRedisCacheKeys", "setRedisCacheValue"]
    },
    {
      "name": "ElevenLabsTTSService",
      "extends": "BaseService",
      "implements_interfaces": ["puter-tts", "driver-capabilities"],
      "fields": [
        "apiKey: string",
        "baseUrl: string (default: https://api.elevenlabs.io)",
        "defaultVoiceId: string",
        "meteringService: MeteringService (getter)"
      ],
      "methods": [
        "_init(): Promise<void>",
        "request(path, { method, body, headers }): Promise<Response>",
        "listVoices(): Promise<Voice[]>",
        "listEngines(): Promise<Engine[]>",
        "synthesize({ text, voice, model, response_format, output_format, voice_settings, voiceSettings, test_mode }): Promise<TypedValue>",
        "[IMPLEMENTS] list_voices()",
        "[IMPLEMENTS] list_engines()",
        "[IMPLEMENTS] synthesize(params)"
      ],
      "models": ["eleven_multilingual_v2 (default)", "eleven_flash_v2_5", "eleven_turbo_v2_5", "eleven_v3"],
      "external_clients": ["fetch (native HTTP)"],
      "dependencies": ["BaseService", "MeteringService", "Context", "APIError", "TypedValue", "stream.Readable"]
    },
    {
      "name": "OpenAITTSService",
      "extends": "BaseService",
      "implements_interfaces": ["puter-tts", "driver-capabilities"],
      "fields": [
        "openai: OpenAI (initialized in _init)",
        "meteringService: MeteringService (getter)"
      ],
      "methods": [
        "_init(): Promise<void>",
        "synthesize({ text, voice, model, response_format, instructions, test_mode }): Promise<TypedValue>",
        "[IMPLEMENTS] list_voices({ provider }): Voice[]",
        "[IMPLEMENTS] list_engines({ provider }): Engine[]",
        "[IMPLEMENTS] synthesize(params)"
      ],
      "voices": ["alloy (default)", "ash", "ballad", "coral", "echo", "fable", "nova", "onyx", "sage", "shimmer"],
      "models": ["gpt-4o-mini-tts (default, $15/1M chars)", "tts-1 ($15/1M)", "tts-1-hd ($30/1M)"],
      "external_clients": ["OpenAI SDK (openai.audio.speech.create)"],
      "dependencies": ["BaseService", "MeteringService", "Context", "APIError", "TypedValue", "stream.Readable"]
    }
  ],
  "interfaces": [
    {
      "name": "IImageProvider",
      "methods": ["models(): Promise<IImageModel[]>", "getDefaultModel(): string", "generate(params): Promise<string>"]
    },
    {
      "name": "IVideoProvider",
      "methods": ["models(): Promise<IVideoModel[]>", "getDefaultModel(): string", "generate(params): Promise<any>"]
    },
    {
      "name": "puter-image-generation",
      "driver_interface": true,
      "methods": ["generate(parameters: IGenerateParams): TypedValue"]
    },
    {
      "name": "puter-video-generation",
      "driver_interface": true,
      "methods": ["generate(parameters: IGenerateVideoParams)"]
    },
    {
      "name": "puter-ocr",
      "driver_interface": true,
      "methods": ["recognize(params): object"]
    },
    {
      "name": "puter-tts",
      "driver_interface": true,
      "methods": ["list_voices(options?): Voice[]", "list_engines(options?): Engine[]", "synthesize(params): TypedValue"]
    },
    {
      "name": "driver-capabilities",
      "driver_interface": true,
      "methods": ["supports_test_mode(iface, method_name): boolean"]
    }
  ],
  "key_relationships": [
    "AIImageGenerationService extends BaseService",
    "AIVideoGenerationService extends BaseService",
    "MistralOCRService extends BaseService",
    "AWSPollyService extends BaseService",
    "ElevenLabsTTSService extends BaseService",
    "OpenAITTSService extends BaseService",
    "AIImageGenerationService implements puter-image-generation + driver-capabilities",
    "AIVideoGenerationService implements puter-video-generation + driver-capabilities",
    "MistralOCRService implements puter-ocr + driver-capabilities",
    "AWSPollyService implements puter-tts + driver-capabilities",
    "ElevenLabsTTSService implements puter-tts + driver-capabilities",
    "OpenAITTSService implements puter-tts + driver-capabilities",
    "AIImageGenerationService composes IImageProvider (6 provider impls)",
    "AIVideoGenerationService composes IVideoProvider (3 provider impls)",
    "AIImageGenerationService depends_on MeteringService, DriverService, EventService, ErrorService",
    "AIVideoGenerationService depends_on MeteringService, DriverService, EventService",
    "MistralOCRService depends_on MeteringService, Mistral client",
    "AWSPollyService depends_on MeteringService, PollyClient, redisClient",
    "ElevenLabsTTSService depends_on MeteringService",
    "OpenAITTSService depends_on MeteringService, OpenAI client"
  ],
  "shared_patterns": [
    "All services extend BaseService and use this.services.get() for dependency injection",
    "All implement static IMPLEMENTS object mapping driver interface names to method delegates",
    "All TTS services (AWSPolly, ElevenLabs, OpenAITTS) implement identical puter-tts interface: list_voices, list_engines, synthesize",
    "All synthesize methods return TypedValue (stream or URL) and check credits via meteringService.hasEnoughCreditsFor()",
    "Image/Video services use provider+modelIdMap pattern for multi-provider routing",
    "test_mode: all services return sample/stub responses when test_mode=true"
  ],
  "image_providers": [
    "OpenAiImageGenerationProvider",
    "GeminiImageGenerationProvider",
    "TogetherImageGenerationProvider",
    "XAIImageGenerationProvider",
    "CloudflareImageGenerationProvider",
    "ReplicateImageGenerationProvider"
  ],
  "video_providers": [
    "OpenAIVideoGenerationProvider",
    "TogetherVideoGenerationProvider",
    "GeminiVideoGenerationProvider"
  ],
  "source_files_analyzed": [
    "src/backend/src/services/ai/image/AIImageGenerationService.ts",
    "src/backend/src/services/ai/video/AIVideoGenerationService.ts",
    "src/backend/src/services/ai/ocr/MistralOCRService.js",
    "src/backend/src/services/ai/tts/AWSPollyService.js",
    "src/backend/src/services/ai/tts/ElevenLabsTTSService.js",
    "src/backend/src/services/ai/tts/OpenAITTSService.js"
  ]
}
