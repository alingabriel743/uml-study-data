  "key_relationships": [
    "AppService extends BaseService",
    "AppIconService extends BaseService",
    "AppInformationService extends BaseService",
    "RegistryService extends BaseService",
    "RegistrantService extends BaseService",
    "MapCollection extends AdvancedBase",
    "AppService composes AppRepository (instance field)",
    "RegistryService creates MapCollection (register_collection)",
    "RegistrantService depends_on RegistryService",
    "AppService depends_on AppIconService (icon path resolution, icon creation)",
    "AppService depends_on AppInformationService (delete_app call on app merge)",
    "AppService uses AppRedisCacheSpace (cache invalidation)",
    "AppIconService uses AppRedisCacheSpace (cache invalidation)",
    "AppInformationService uses AppRedisCacheSpace (stats caching)",
    "AppService emits events consumed by AppIconService (app.new-icon)",
    "AppService emits events consumed by AppInformationService (app.rename, app.changed)",
    "AppInformationService emits apps.invalidate after cache invalidation"
  ],
  "shared_dependencies": [
    "AppRedisCacheSpace — shared cache namespace for app lookups and stats",
    "BaseService — common base (lifecycle: _construct, _init, __on_* hooks)",
    "database service — DB_READ / DB_WRITE used by AppService, AppIconService, AppInformationService",
    "event service — pub/sub bus wiring all three app services",
    "su service — system-level sudo operations in AppIconService and AppInformationService"
  ],
  "important_notes": [
    "AppService uses the Entity Service pattern: delegates CRUD to an inner object with create/read/update/delete/select/upsert methods",
    "AppIconService registers HTTP routes for /app-icon/:uid and /app-icon/:uid/:size",
    "AppInformationService supports both MySQL and ClickHouse for statistics queries",
    "RegistrantService populates the RegistryService with om:proptype and om:mapping collections at boot",
    "AppRepository is currently an empty stub class",
    "Icon sizes are fixed: [16, 32, 64, 128, 256, 512]; default is 128",
    "Canonical UID aliases stored in puter-kvstore to track app merges/renames"
  ],
  "source_files_analyzed": [
