{
  "scope": "kvstore_captcha_and_misc_services",
  "title": "KV Store, Captcha & Miscellaneous Services",
  "diagram_type": "class",
  "key_classes": [
    "KVStoreModule",
    "KVStoreInterfaceService",
    "CaptchaService",
    "FeatureFlagService",
    "LockService",
    "BaseService",
    "AdvancedBase"
  ],
  "class_definitions": [
    {
      "name": "KVStoreModule",
      "extends": "AdvancedBase",
      "package": "modules/kvstore",
      "methods": [
        "install(context): Promise<void>"
      ],
      "responsibilities": "Bootstrap module that registers KVStoreInterfaceService under the 'kvstore-interface' service name"
    },
    {
      "name": "KVStoreInterfaceService",
      "extends": "BaseService",
      "package": "modules/kvstore",
      "methods": [
        "__on_driver.register.interfaces(): Promise<void>"
      ],
      "responsibilities": "Registers the 'puter-kvstore' driver interface with the registry, exposing 12 methods: get, set, batchPut, del, list, flush, update, add, remove, incr, decr, expireAt, expire"
    },
    {
      "name": "CaptchaService",
      "extends": "BaseService",
      "package": "modules/captcha/services",
      "fields": [
        "crypto: module",
        "svgCaptcha: module",
        "captchaTokens: Map<string, {text:string, expiresAt:number}>",
        "serviceId: string",
        "requestCounter: number",
        "enabled: boolean",
        "expirationTime: number (default 10min)",
        "difficulty: string (easy|medium|hard)",
        "testMode: boolean",
        "endpointsRegistered: boolean",
        "cleanupInterval: Interval"
      ],
      "methods": [
        "_construct(): Promise<void>",
        "__on_install.middlewares.context-aware(_, {app}): void",
        "_init(): Promise<void>",
        "_destroy(): Promise<void>",
        "registerEndpoints(): void",
        "generateCaptcha(): {token: string, data: string}",
        "verifyCaptcha(token: string, userAnswer: string): boolean",
        "cleanupExpiredTokens(): void",
        "_getCaptchaOptions(): Object",
        "_checkServiceHealth(): boolean",
        "verifySelfTest(): boolean",
        "getDiagnosticInfo(): Object"
      ],
      "api_endpoints": [
        "GET /api/captcha/generate",
        "POST /api/captcha/verify",
        "POST /api/captcha/create-test-token (testMode only)",
        "GET /api/captcha/diagnostic",
        "GET /api/captcha/debug-tokens",
        "GET /api/captcha/config-status",
        "GET /api/captcha/test-lifecycle"
      ],
      "dependencies": ["web-service/web-server", "event (optional)"],
      "middleware": "checkCaptcha (from captcha-middleware)"
    },
    {
      "name": "FeatureFlagService",
      "extends": "BaseService",
      "package": "services",
      "fields": [
        "known_flags: Map<string, spec>"
      ],
      "methods": [
        "_construct(): void",
        "_init(): Promise<void>",
        "register(name: string, spec: Object|boolean): void",
        "check(...a): Promise<boolean>",
        "get_summary(actor: Object): Promise<Object>"
      ],
      "flag_types": [
        "config-flag: static boolean value from config",
        "function-flag: dynamic fn({actor}) => boolean",
        "permission-flag: checks 'feature:<name>' via permission service"
      ],
      "dependencies": ["whoami (detail provider)", "permission (svc_permission.scan)"],
      "notes": "Registers as provider with WhoamiService to inject feature_flags into user details"
    },
    {
      "name": "LockService",
      "extends": "BaseService",
      "package": "services",
      "fields": [
        "locks: Record<string, RWLock>"
      ],
      "methods": [
        "_construct(): Promise<void>",
        "_init(): Promise<void>",
        "lock(name: string|string[], opt_options?: {timeout?: number}, callback: Function): Promise<any>"
      ],
      "notes": "Uses RWLock (from lockutil). Supports array of lock names (sequential acquisition). Supports timeout option that auto-unlocks. Always acquires write locks (wlock). One-time use handles via handle.unlock()."
    }
  ],
  "key_relationships": [
    "KVStoreModule extends AdvancedBase",
    "KVStoreModule creates KVStoreInterfaceService (registers as service)",
    "KVStoreInterfaceService extends BaseService",
    "CaptchaService extends BaseService",
    "FeatureFlagService extends BaseService",
    "LockService extends BaseService",
    "LockService composes RWLock (from lockutil)",
    "CaptchaService uses checkCaptcha middleware",
    "FeatureFlagService depends_on PermissionUtil (reading_to_options)",
    "FeatureFlagService depends_on Context (get actor)",
    "FeatureFlagService registers_with WhoamiService (detail provider)",
    "CaptchaService registers_routes_with WebService/WebServer"
  ],
  "interfaces_defined": [
    {
      "name": "puter-kvstore (driver interface)",
      "methods": ["get(key, optConfig)", "set(key, value, expireAt, optConfig)", "batchPut(items, optConfig)", "del(key, optConfig)", "list(as, pattern, limit, cursor, optConfig)", "flush(optConfig)", "update(key, pathAndValueMap, ttl, optConfig)", "add(key, pathAndValueMap, optConfig)", "remove(key, paths, optConfig)", "incr(key, pathAndAmountMap, optConfig)", "decr(key, pathAndAmountMap, optConfig)", "expireAt(key, timestamp, optConfig)", "expire(key, ttl, optConfig)"]
    }
  ],
  "important_notes": "KVStoreInterfaceService only registers the interface spec (no actual KV implementation here — implementation is elsewhere). CaptchaService uses svg-captcha library with in-memory Map token storage; tokens are one-time use (deleted after verify). FeatureFlagService supports three flag types: config, function, permission-based. LockService wraps RWLock utility but always uses write-locks; supports chained/array locking.",
  "source_files_analyzed": [
    "src/backend/src/modules/kvstore/KVStoreInterfaceService.js",
    "src/backend/src/modules/kvstore/KVStoreModule.js",
    "src/backend/src/modules/captcha/services/CaptchaService.js",
    "src/backend/src/services/FeatureFlagService.js",
    "src/backend/src/services/LockService.js"
  ]
}
