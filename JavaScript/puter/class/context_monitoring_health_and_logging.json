  "compositions": [
    "LogService creates LogContext (via create(prefix, fields))",
    "LogService composes logger chain: WinstonLogger/DevLogger/NullLogger → TimestampLogger → BufferLogger → optional CustomLogger",
    "OperationTraceService creates OperationFrame (via add_frame_sync)",
    "OperationFrame has parent OperationFrame (tree hierarchy)",
    "OperationFrame has children OperationFrame[]",
    "BaseOperation owns OperationFrame (this.frame)"
  ],
  "dependencies": [
    "ServerHealthService depends_on AlarmService (svc_alarm.create())",
    "ServerHealthService depends_on kv (Redis cache for health status)",
    "ServerHealthService depends_on database service (liveness check)",
    "ServerHealthService depends_on web-server service (listening check)",
    "ServerHealthService depends_on socketio service (init check)",
    "AlarmService depends_on PagerService (this.pager.alert())",
    "AlarmService depends_on LogService (this.log.get_log_buffer())",
    "TelemetryService depends_on OpenTelemetry SDK (NodeSDK, OTLPTraceExporter, OTLPMetricExporter)",
    "TelemetryService depends_on ContextService (registers pre_arun hook)",
    "HostDiskUsageService writes_to config.available_device_storage",
    "OperationFrame depends_on LogService (via Context.get('services').get('log-service'))",
    "OperationTraceService depends_on LogService",
    "BaseOperation depends_on OperationTraceService",
    "BaseOperation depends_on LogService"
  ],
