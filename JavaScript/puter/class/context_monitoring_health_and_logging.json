      "DevLogger": "logs to console; optional delegate; supports recto (file append); respects display_log_level",
      "NullLogger": "no-op; optional delegate",
      "WinstonLogger": "delegates to winston.logger.log()",
      "TimestampLogger": "adds timestamp field; delegates",
      "BufferLogger": "maintains circular buffer of last N entries; delegates",
