  "key_relationships": [
    "UI extends EventListener",
    "AppConnection extends EventListener",
    "PuterPeerServer extends EventTarget",
    "PuterPeerConnection extends EventTarget",
    "PuterPeerConnectionMessageEvent extends Event",
    "PuterPeerServerConnectionEvent extends Event",
    "UI creates AppConnection (via launchApp, connectToInstance, parentApp)",
    "UI uses FSItem (showOpenFilePicker returns FSItem[])",
    "Perms depends_on UI (request() → ui.requestPermission())",
    "Perms depends_on Auth (requestEmail(), requestFolder_() → auth.whoami())",
    "Perms depends_on FileSystem (requestFolder_() → fs.stat())",
    "WorkersHandler depends_on UI (authenticateWithPuter)",
    "WorkersHandler depends_on Apps (apps.get, apps.create, apps.list)",
    "WorkersHandler depends_on KV (kv.get, kv.set)",
    "Peer depends_on UI (authenticateWithPuter)",
    "Peer creates PuterPeerServer",
    "Peer creates PuterPeerConnection",
    "PuterPeerServer creates PuterPeerConnection",
    "AI depends_on Drivers (listModels fallback via puter.drivers.call)",
    "Drivers creates Driver (via get())",
    "Driver depends_on FetchDriverCallBackend (delegation)",
    "All modules (Auth, AI, Apps, Perms, KV, Drivers, OS, Peer) composed by PuterSDK (puter reference in constructor)",
    "All modules share interface: setAuthToken(authToken), setAPIOrigin(APIOrigin)",
    "FileSystem imports and composes all operation functions (copy, delete, mkdir, etc.)",
    "FileSystem has-a FSItem (class reference)",
    "FileSystem has-a Batch",
    "FileSystem uses socket.io (WebSocket-based real-time events)"
  ],

  "common_module_interface": {
    "constructor_param": "puter (PuterSDK instance)",
    "shared_fields": ["puter", "authToken", "APIOrigin", "appID"],
    "shared_methods": ["setAuthToken(authToken)", "setAPIOrigin(APIOrigin)"]
  },

  "driver_system": {
    "description": "utils.make_driver_method() creates parameterized driver call functions used by AI, KV, Apps, WorkersHandler",
    "call_chain": "module.method() → utils.make_driver_method(...) → FetchDriverCallBackend.call() → POST /drivers/call",
    "interfaces": ["puter-chat-completion", "puter-ocr", "puter-tts", "puter-image-generation", "puter-video-generation", "puter-kvstore", "puter-apps", "workers", "app-telemetry", "puter-speech2txt", "puter-speech2speech"]
  },

  "important_notes": [
    "AppConnection is not directly constructable by user code — returned only by UI methods",
    "UI.requestPermission() is the IPC permission gateway used by Perms.request()",
    "KV has a GUI boot cache mechanism (gui_cache_keys prewarm) for performance",
    "FileSystem uses socket.io for real-time watch events (initializeSocket)",
    "Peer uses WebRTC (RTCPeerConnection + RTCDataChannel) with WebSocket signalling",
    "All driver calls are routed through POST /drivers/call with auth_token",
    "WorkersHandler is exported as WorkersHandler (not a default export), used via puter.workers"
  ],

