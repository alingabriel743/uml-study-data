@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F0F4FF
    BorderColor #4A6CF7
    FontColor #212529
    ArrowColor #495057
}
skinparam interface {
    BackgroundColor #FFF8E1
    BorderColor #F9A825
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Puter Platform — Component Architecture

' ─────────────────────────────────────────────
' CLIENT LAYER
' ─────────────────────────────────────────────
package "Client Layer" {
    [GUI\n(Web Desktop)] as GUI
    [Puter.js SDK\n(puter-js)] as PuterJS
    [UseAPI\n(useapi)] as UseAPI
}

' ─────────────────────────────────────────────
' API & MIDDLEWARE LAYER
' ─────────────────────────────────────────────
package "API & Middleware Layer" {
    [REST API\n(api/)] as RestAPI
    [Auth Middleware\n(auth, configurable_auth)] as AuthMW
    [CSRF / Abuse\n(anticsrf, abuse)] as CSRF
    [Subdomain Router\n(subdomain)] as SubdomainRouter
    [Request Metrics\n(measure)] as Metrics
}

' ─────────────────────────────────────────────
' CORE / KERNEL LAYER
' ─────────────────────────────────────────────
package "Core / Kernel Layer" {
    [Kernel\n(Bootstrap & IoC)] as Kernel
    [Extension Service\n(ExtensionController)] as ExtSvc
    [Config Loader\n(ConfigLoader)] as ConfigLoader
    [Boot / Runtime Env\n(boot/)] as Boot
    [Runtime Module Registry] as ModRegistry
    [Error Service\n(ErrorService)] as ErrorSvc
    [Alarm Service\n(AlarmService)] as AlarmSvc
    [Context Service\n(ContextService)] as ContextSvc
}

' ─────────────────────────────────────────────
' BACKEND SERVICE MODULES
' ─────────────────────────────────────────────
package "Backend Service Modules" {
    [Apps Module\n(AppService, AppPermissionService)] as AppsMod
    [Data Access Module\n(AppRepository, UserRepo)] as DataAccessMod
    [Broadcast Module\n(BroadcastService)] as BroadcastMod
    [PuterFS Module\n(SizeService, MountpointService)] as PuterFSMod
    [KVStore Module\n(KVStoreInterfaceService)] as KVStoreMod
    [EntityStore Module\n(EntityStoreInterfaceService)] as EntityStoreMod
    [HostOS Module\n(ProcessService)] as HostOSMod
    [Internet Module\n(WispRelayService)] as InternetMod
    [Captcha Module\n(CaptchaService)] as CaptchaMod
    [Selfhosted Module\n(SelfhostedService)] as SelfhostedMod
    [Telemetry / PerfMon\n(TelemetryService)] as PerfMon
    [Server Health\n(ServerHealthService)] as HealthSvc
}

' ─────────────────────────────────────────────
' EXTENSIONS LAYER
' ─────────────────────────────────────────────
package "Extensions Layer" {
    [FSv2 Extension\n(FSEntryService, UploadTracker)] as FSv2
    [Legacy Filesystem\n(PuterFSProvider, FSEntryController)] as LegacyFS
    [Installed Apps\n(InstalledAppsController)] as InstalledApps
    [Metering\n(UsageController)] as Metering
    [Server Info\n(ServerInfoController)] as ServerInfo
    [Thumbnails\n(base64ParseDataUrl)] as Thumbnails
    [WhoAmI\n(whoami_common)] as WhoAmI
}

' ─────────────────────────────────────────────
' DATA / STORAGE CLIENTS
' ─────────────────────────────────────────────
package "Storage & Cache Clients" {
    [S3 Client\n(initializeS3Config)] as S3Client
    [DynamoDB Client\n(DDBClientServiceWrapper)] as DDBClient
    [Redis Client\n(RedisClusterMock)] as RedisClient
    database "S3 / Object Store" as S3Store
    database "DynamoDB" as DynamoDB
    database "Redis Cache" as RedisStore
}

' ─────────────────────────────────────────────
' UTILITIES / TOOLING (peripheral)
' ─────────────────────────────────────────────
package "Developer Utilities" {
    [Putility\n(shared utilities)] as Putility
    [ESLint Plugins\n(custom rules)] as ESLint
    [Build & Release Tools\n(tools/)] as BuildTools
}

' ─────────────────────────────────────────────
' RELATIONSHIPS — Client → API
' ─────────────────────────────────────────────
GUI --> PuterJS : uses SDK
PuterJS --> RestAPI : HTTP requests
UseAPI --> PuterJS : wraps
GUI --> RestAPI : direct calls

' ─────────────────────────────────────────────
' RELATIONSHIPS — API → Middleware → Kernel
' ─────────────────────────────────────────────
RestAPI --> AuthMW : applies
RestAPI --> CSRF : applies
RestAPI --> SubdomainRouter : routes via
RestAPI --> Metrics : tracks
AuthMW --> Kernel : resolves services
SubdomainRouter --> Kernel : delegates

' ─────────────────────────────────────────────
' RELATIONSHIPS — Kernel → Core Services
' ─────────────────────────────────────────────
Kernel --> ConfigLoader : loads config
Kernel --> Boot : initialises runtime
Kernel --> ModRegistry : registers modules
Kernel --> ExtSvc : loads extensions
Kernel --> ErrorSvc : wires error handling
Kernel --> AlarmSvc : wires alarms
Kernel --> ContextSvc : provides context

' ─────────────────────────────────────────────
' RELATIONSHIPS — Kernel → Service Modules
' ─────────────────────────────────────────────
Kernel --> AppsMod : installs
Kernel --> DataAccessMod : installs
Kernel --> BroadcastMod : installs
Kernel --> PuterFSMod : installs
Kernel --> KVStoreMod : installs
Kernel --> EntityStoreMod : installs
Kernel --> HostOSMod : installs
Kernel --> InternetMod : installs
Kernel --> CaptchaMod : installs
Kernel --> SelfhostedMod : installs
Kernel --> PerfMon : installs
Kernel --> HealthSvc : installs

' ─────────────────────────────────────────────
' RELATIONSHIPS — Kernel → Extensions
' ─────────────────────────────────────────────
ExtSvc --> FSv2 : loads
ExtSvc --> LegacyFS : loads
ExtSvc --> InstalledApps : loads
ExtSvc --> Metering : loads
ExtSvc --> ServerInfo : loads
ExtSvc --> Thumbnails : loads
ExtSvc --> WhoAmI : loads

' ─────────────────────────────────────────────
' RELATIONSHIPS — Service Modules interdependencies
' ─────────────────────────────────────────────
AppsMod --> DataAccessMod : reads app data
PuterFSMod --> FSv2 : delegates FS ops
PuterFSMod --> LegacyFS : fallback FS ops
Metering --> DataAccessMod : queries usage
BroadcastMod --> KVStoreMod : pub/sub via KV

' ─────────────────────────────────────────────
' RELATIONSHIPS — Storage Clients
' ─────────────────────────────────────────────
DataAccessMod --> DDBClient : queries
DataAccessMod --> RedisClient : caches
FSv2 --> S3Client : stores files
LegacyFS --> S3Client : stores files
S3Client --> S3Store : object storage
DDBClient --> DynamoDB : NoSQL store
RedisClient --> RedisStore : in-memory cache

' ─────────────────────────────────────────────
' RELATIONSHIPS — Utilities
' ─────────────────────────────────────────────
Kernel ..> Putility : uses utilities
AppsMod ..> Putility : uses utilities
BuildTools ..> ESLint : validates code

@enduml
