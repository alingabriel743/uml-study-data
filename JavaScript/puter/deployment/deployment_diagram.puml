@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam node {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam artifact {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam database {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
    FontColor #0C5460
}
skinparam component {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}
skinparam cloud {
    BackgroundColor #E2D9F3
    BorderColor #6F42C1
    FontColor #212529
}
skinparam storage {
    BackgroundColor #D4EDDA
    BorderColor #155724
    FontColor #155724
}

title Puter — Deployment Diagram

' ─── Client ───────────────────────────────────────────────────────────────────
node "Client Browser" <<Device>> as browser {
    artifact "Puter.js SDK" as puterjs
    artifact "GUI (Web App)" as gui_client
    artifact "Worker (WebWorker)" as worker_client
}

' ─── Docker Host ──────────────────────────────────────────────────────────────
node "Docker Host" <<Server>> {

    node "puter\nghcr.io/heyputer/puter:latest" <<Docker Container>> as puter_container {

        artifact "Puter Backend\n(Node.js / Express)" as backend
        artifact "GUI Static Files\n(built dist/)" as gui_dist
        artifact "Puter.js Bundle\n(webpack)" as puterjs_bundle
        artifact "Worker Bundle\n(webpack, webworker target)" as worker_bundle
    }

    storage "/etc/puter\n(config volume)" as config_vol
    storage "/var/puter\n(data volume)" as data_vol
}

' ─── Embedded Storage (mounted in data volume) ────────────────────────────────
database "SQLite Database\nputer-database.sqlite" as sqlite
database "DynamoDB (Local)\nputer-ddb/" as dynamo

' ─── Optional / Cloud Services ────────────────────────────────────────────────
cloud "Amazon S3\n(optional file storage)" as s3
cloud "OIDC Providers\n(e.g. Google OAuth)" as oidc
cloud "CDN / Internet\nputer-net.b-cdn.net" as cdn

' ─── Connections ──────────────────────────────────────────────────────────────
browser -down-> puter_container : "HTTP :4100\nputer.localhost"

backend -right-> gui_dist    : "serves"
backend -right-> puterjs_bundle : "serves"
backend -right-> worker_bundle  : "serves"

puter_container --> config_vol : "mounts /etc/puter"
puter_container --> data_vol   : "mounts /var/puter"

data_vol --> sqlite : "stores"
data_vol --> dynamo : "stores"

backend ..> s3    : "S3 API (optional)\nfile storage"
backend ..> oidc  : "OIDC / OAuth2\nauthentication"
worker_client ..> cdn : "loads rustls.js\n(runtime)"

gui_client      <-- gui_dist        : "downloaded by browser"
puterjs         <-- puterjs_bundle  : "downloaded by browser"
worker_client   <-- worker_bundle   : "downloaded by browser"

note right of puter_container
  Exposes port **4100**
  Virtual hosts:
  • puter.localhost        → GUI
  • api.puter.localhost    → REST API
  • site.puter.localhost   → Static Hosting
  • app.puter.localhost    → App Hosting
  Health check: GET /test
end note

note bottom of sqlite
  Default engine.
  Swappable with
  external DB (DynamoDB).
end note

@enduml
