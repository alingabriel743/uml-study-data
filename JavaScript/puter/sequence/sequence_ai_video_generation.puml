@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 2
skinparam sequenceParticipant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceBoxBackgroundColor #E9ECEF
skinparam sequenceBoxBorderColor #6C757D
skinparam noteFontSize 11
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F9A825

title AI Video Generation Request Flow

actor "Client" as Client

participant "DriverService" as DriverService
participant "AIVideoGenerationService\n[ai-video]" as AIVideoSvc
participant "PermissionService\n& RateLimiter" as PermSvc
participant "IVideoProvider\n(OpenAI/Together/Gemini)" as Provider
participant "MeteringService" as MeterSvc
participant "EventService" as EventSvc
participant "GoogleGenAI\n(Gemini API)" as GeminiAPI

== Boot: Provider Registration ==

AIVideoSvc -> AIVideoSvc: __on_boot.consolidation()
activate AIVideoSvc

AIVideoSvc -> AIVideoSvc: registerProviders()
note right: Creates OpenAIVideoGenerationProvider,\nTogetherVideoGenerationProvider,\nGeminiVideoGenerationProvider\n(if API keys configured)

AIVideoSvc -> EventSvc: emit('ai.video.registerProviders', extensionProviders)
activate EventSvc
note right: Allows external provider injection
EventSvc --> AIVideoSvc: extensionProviders (injected)
deactivate EventSvc

loop for each provider
    AIVideoSvc -> DriverService: register_service_alias(\n  'ai-video', providerName,\n  { iface: 'puter-video-generation' })
    activate DriverService
    DriverService --> AIVideoSvc: alias registered
    deactivate DriverService

    AIVideoSvc -> Provider: models()
    activate Provider
    Provider --> AIVideoSvc: IVideoModel[] (with aliases)
    deactivate Provider
    AIVideoSvc -> AIVideoSvc: build #modelIdMap\n(id/puterId/alias + cost-based sort)
end

deactivate AIVideoSvc

== List Models Flow ==

Client -> DriverService: call({ iface: 'puter-video-generation',\n  method: 'list', args })
activate DriverService

DriverService -> DriverService: _call() → resolve driver\niface_to_driver['puter-video-generation'] = 'ai-video'
DriverService -> DriverService: get_service_or_throw_('ai-video',\n  'puter-video-generation')\n→ AIVideoGenerationService

DriverService -> AIVideoSvc: list()
activate AIVideoSvc

AIVideoSvc -> AIVideoSvc: models() → iterate #modelIdMap\ndeduplicate by provider:puterId/id\nsort by provider + id
AIVideoSvc --> DriverService: sorted model ID strings[]
deactivate AIVideoSvc

DriverService --> Client: { success: true,\n  result: model_ids[] }
deactivate DriverService

== Generate Video Flow ==

Client -> DriverService: call({ iface: 'puter-video-generation',\n  method: 'generate',\n  args: { model, provider, prompt,\n          duration, size } })
activate DriverService

DriverService -> DriverService: _process_args(\n  'puter-video-generation', 'generate', args)\n[validates via registry interface definition]

DriverService -> DriverService: resolve driver alias\niface_to_driver['puter-video-generation'] = 'ai-video'\nresolve provider alias →\ninterface_service_aliases[...][providerName]

DriverService -> DriverService: emit 'driver.create-call-context'\n(Context sub { client_driver_call, call_details })

DriverService -> DriverService: call_new_({ actor, service:\n  AIVideoGenerationService, iface, method, args })
activate DriverService

DriverService -> PermSvc: scan(actor,\n  'service:ai-video:ii:puter-video-generation')
activate PermSvc
note right: Checks options / policy
PermSvc --> DriverService: permission result
deactivate PermSvc

DriverService -> PermSvc: rate-limit check\nsvc_rateLimit.check_and_increment(policy_holder)
activate PermSvc
PermSvc --> DriverService: rate-limit OK
deactivate PermSvc

DriverService -> AIVideoSvc: service.as('puter-video-generation')\n.generate(parameters)
activate AIVideoSvc

AIVideoSvc -> AIVideoSvc: Context.get('client_driver_call')\n→ extract test_mode, intended_service

AIVideoSvc -> AIVideoSvc: resolve intendedProvider\nparams.provider > legacyProviderName\n> DEFAULT_PROVIDER ('openai-video-generation')

AIVideoSvc -> AIVideoSvc: getModel({ modelId, provider })\n→ lookup #modelIdMap\n(exact id > puterId > short-name > first)

AIVideoSvc -> AIVideoSvc: validate/normalize\nduration (durationSeconds)\ndimensions (size/resolution)

alt test_mode = true
    AIVideoSvc --> DriverService: TypedValue({ $: 'string:url:web',\n  content_type: 'video' },\n  DEFAULT_TEST_VIDEO_URL)\nnote: skips API call & metering
else normal mode
    AIVideoSvc -> Provider: provider.generate({\n  ...parameters,\n  model: model.id,\n  provider: model.provider,\n  test_mode })
    activate Provider

    group Gemini Provider Path
        Provider -> MeterSvc: hasEnoughCredits(actor, costInMicroCents)
        activate MeterSvc
        MeterSvc --> Provider: creditsAvailable: true
        deactivate MeterSvc

        Provider -> GeminiAPI: models.generateVideos(generateParams)
        activate GeminiAPI
        GeminiAPI --> Provider: GenerateVideosOperation
        deactivate GeminiAPI

        loop #pollUntilComplete — every 10s (max 10 min)
            Provider -> GeminiAPI: operations.getVideosOperation(operationName)
            activate GeminiAPI
            GeminiAPI --> Provider: operation status
            deactivate GeminiAPI
        end

        Provider -> MeterSvc: incrementUsage(actor, usageKey,\n  durationSeconds, costInMicroCents)
        activate MeterSvc
        MeterSvc --> Provider: usage recorded
        deactivate MeterSvc

        Provider --> AIVideoSvc: TypedValue({ $: 'string:url:web',\n  content_type: 'video' }, proxyUrl)\nnote: HMAC-signed proxy URL (48h expiry)
    end

    deactivate Provider

    AIVideoSvc --> DriverService: TypedValue result
end

deactivate AIVideoSvc

DriverService -> DriverService: Invoker decorator:\ncoerce result (TypedValue → interface result type\nvia svc_coercion)
deactivate DriverService

DriverService -> DriverService: attach response_metadata
DriverService --> Client: { success: true,\n  service: { name: 'ai-video' },\n  result: { url: '...' } }
deactivate DriverService

@enduml
