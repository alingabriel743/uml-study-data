@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipant underline
skinparam sequenceBoxBackgroundColor #E9ECEF
skinparam sequenceBoxBorderColor #6C757D
skinparam sequenceLifeLineBorderColor #495057
skinparam sequenceGroupBackgroundColor #F1F3F5
skinparam sequenceGroupBorderColor #868E96
skinparam noteFontSize 11
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F9A825

title Context Menu and UI Drag Event Handling

actor User
participant "Caller" as caller
participant "UIContextMenu" as ctxmenu
participant "menuAim" as menuaim
participant "jQuery / DOM" as dom
participant "taphold Plugin" as taphold
participant "set_menu_item_prop" as setprop

' ─────────────────────────────────────────────
box "UIContextMenu Initialization" #EEF2FF
    caller -> ctxmenu : UIContextMenu({ items, id, position,\n  delay, parent_id, is_submenu,\n  css, parent_element, onClose })
    activate ctxmenu

    ctxmenu -> dom : dispatchEvent(\n  CustomEvent('ctxmenu-will-open', { detail: options }))
    ctxmenu -> dom : build HTML string\n  (context-menu div + <li> items / submenus / dividers)
    ctxmenu -> dom : $('body').append(html)
    ctxmenu -> dom : compute x_pos / y_pos\n  from (mouseX/mouseY | touch | options.position)\n  vs window bounds
    ctxmenu -> dom : $(contextMenu).css({ top, left })\n  apply options.css if present

    alt options.delay === false
        ctxmenu -> dom : $(contextMenu).show(0)
    else options.delay is number n
        ctxmenu -> dom : $(contextMenu).fadeIn(n)
    else default (true / 1 / undefined)
        ctxmenu -> dom : $(contextMenu).fadeIn(50)
    end

    ctxmenu -> dom : $('.context-menu')\n  .not(contextMenu).removeClass('context-menu-active')
    ctxmenu -> menuaim : $(contextMenu).menuAim({\n  rowSelector, submenuSelector,\n  submenuDirection, enter,\n  activate, deactivate, exit })
    activate menuaim
end box

' ─────────────────────────────────────────────
box "menuAim Initialization" #E8F5E9
    menuaim -> dom : $menu.mouseleave(mouseleaveMenu)
    menuaim -> dom : $menu.find(rowSelector)\n  .mouseenter(mouseenterRow)\n  .mouseleave(mouseleaveRow)\n  .click(clickRow)
    menuaim -> dom : $(document).mousemove(mousemoveDocument)
end box

' ─────────────────────────────────────────────
box "Menu Item Click" #FFF3E0
    User -> dom : click on #context-menu-{id} > li:not(.disabled)
    dom -> ctxmenu : click handler fires
    activate ctxmenu

    alt item.onClick defined
        ctxmenu -> caller : item.onClick(event)
    else fallback
        ctxmenu -> caller : item.action()
    end

    opt not a submenu item
        ctxmenu -> ctxmenu : fade_remove(this)
    end
    deactivate ctxmenu
end box

' ─────────────────────────────────────────────
box "Mouse Movement & Submenu Activation" #F3E5F5
    User -> dom : mousemove on document
    dom -> menuaim : mousemoveDocument —\n  push {x, y} to mouseLocs (max 3)

    User -> dom : mouseenter on row
    dom -> menuaim : mouseenterRow —\n  clearTimeout(timeoutId), options.enter(row)
    activate menuaim

    menuaim -> menuaim : possiblyActivate(row)
    menuaim -> menuaim : activationDelay() —\n  compute slope from mouseLocs\n  vs submenu corner bounds

    alt delay > 0 (mouse heading toward submenu)
        menuaim -> menuaim : setTimeout(possiblyActivate, 300ms)
    else no delay
        menuaim -> ctxmenu : options.activate(row, event, data)
        activate ctxmenu
        ctxmenu -> dom : $(contextMenu).find('.context-menu-item')\n  .removeClass('context-menu-item-active')
        ctxmenu -> dom : $(item).addClass('context-menu-item-active')
        ctxmenu -> dom : remove other open submenus\n  $('.context-menu[data-parent-id]')
        opt row has submenu
            ctxmenu -> ctxmenu : setTimeout(300ms) →\n  UIContextMenu({ items: subItems,\n  parent_id, is_submenu: true, id, position })
        end
        deactivate ctxmenu
    end
    deactivate menuaim
end box

' ─────────────────────────────────────────────
box "Mouse Leave Row" #FBE9E7
    User -> dom : mouseleave on row
    dom -> menuaim : mouseleaveRow
    activate menuaim

    opt row has no open submenu
        menuaim -> dom : remove 'context-menu-item-active' class
    end

    menuaim -> ctxmenu : options.exit(row)
    opt row was activeRow
        menuaim -> ctxmenu : options.deactivate(row)
        activate ctxmenu
        ctxmenu -> ctxmenu : clearTimeout(submenu_delay_timer)
        opt row had open submenu
            ctxmenu -> dom : remove submenu\n  removeClass('has-open-context-menu-submenu')
        end
        deactivate ctxmenu
    end
    deactivate menuaim
end box

' ─────────────────────────────────────────────
box "Menu Leave" #E0F7FA
    User -> dom : mouseleave on .context-menu
    dom -> ctxmenu : remove 'context-menu-item-active'\n  from all items; clearTimeout(submenu_delay_timer)
    dom -> menuaim : mouseleaveMenu —\n  clearTimeout(timeoutId)
    activate menuaim
    opt options.exitMenu() returns true
        menuaim -> ctxmenu : options.deactivate(activeRow)
    end
    deactivate menuaim
end box

' ─────────────────────────────────────────────
box "Cancel / Close" #FCE4EC
    caller -> ctxmenu : menu.cancel({ fade })
    activate ctxmenu

    alt fade === true
        ctxmenu -> dom : $(contextMenu).fadeOut(200, remove)
    else
        ctxmenu -> dom : $(contextMenu).remove()
    end

    dom --> ctxmenu : 'remove' event fires
    ctxmenu -> ctxmenu : clearTimeout(submenu_delay_timer)
    ctxmenu -> caller : options.onClose(cancel_options)
    ctxmenu -> dom : restore parent scroll / overflow;\n  removeClass('children-have-open-contextmenu')
    deactivate ctxmenu
    deactivate ctxmenu
end box

' ─────────────────────────────────────────────
box "taphold Plugin — Drag Start / Stop / Leave Handlers" #F9FBE7
    caller -> taphold : taphold.setup(data)
    activate taphold
    taphold -> dom : bind touchstart/mousedown → startHandler\n  touchend/mouseup → stopHandler\n  touchmove/mouseleave → leaveHandler
    deactivate taphold

    User -> dom : touchstart / mousedown
    dom -> taphold : startHandler(event)
    activate taphold
    taphold -> dom : store click handler;\n  reset flags (taphold_triggered,\n  taphold_clicked, taphold_cancelled = false)
    taphold -> taphold : taphold_timer = setTimeout(duration)\n  → if not cancelled/clicked:\n    $elem.trigger('taphold'),\n    taphold_triggered = true
    deactivate taphold

    User -> dom : touchend / mouseup
    dom -> taphold : stopHandler(event)
    activate taphold
    alt taphold_cancelled
        taphold --> dom : return (no action)
    else not triggered / not clicked
        taphold -> dom : restore click handler;\n  trigger click;\n  taphold_clicked = true
    end
    taphold -> taphold : clearTimeout(taphold_timer)
    deactivate taphold

    User -> dom : touchmove / touchcancel / mouseleave
    dom -> taphold : leaveHandler(event)
    activate taphold
    taphold -> taphold : taphold_cancelled = true\n  (cancels pending hold)
    deactivate taphold

    caller -> taphold : taphold.teardown()
    activate taphold
    taphold -> dom : unbind startHandler, stopHandler, leaveHandler
    deactivate taphold
end box

' ─────────────────────────────────────────────
box "set_menu_item_prop — Menu Item Property Update" #E8EAF6
    caller -> setprop : window.set_menu_item_prop(\n  items, item_id, prop, val)
    activate setprop
    loop for each item in items
        alt item.id === item_id
            setprop -> setprop : item[prop] = val → break
        else item has nested items
            setprop -> setprop : recurse into item.items
        end
    end
    setprop --> caller : (updated items array)
    deactivate setprop
end box

@enduml
