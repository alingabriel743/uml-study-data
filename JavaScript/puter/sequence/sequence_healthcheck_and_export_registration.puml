@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequence {
    ArrowColor #495057
    ActorBorderColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    ParticipantBorderColor #495057
    ParticipantBackgroundColor #F8F9FA
    ParticipantFontColor #212529
    BoxBorderColor #6C757D
    BoxBackgroundColor #E9ECEF
    NoteBackgroundColor #FFF9C4
    NoteBorderColor #F0AD4E
}

title Healthcheck and Export Registrant Flow

' ─────────────────────────────────────────────
'  Participants
' ─────────────────────────────────────────────
actor       "Client"                    as client
participant "Express Router\n(healthcheck.js)"  as router
participant "ServerHealthService"       as svcHealth
database    "KVCache (Redis)"           as kv
participant "Caller / App Bootstrap"   as caller
participant "ServiceManager"           as svcMgr
participant "Service (TService trait)" as tservice
participant "ExportRegistrantService"  as exportSvc

' ═══════════════════════════════════════════════════════════════════
'  FLOW A – Health Status Endpoint
' ═══════════════════════════════════════════════════════════════════
== Flow A: GET /healthcheck ==

client -> router : GET /healthcheck
activate router

alt isDraining == true
    router --> client : 503 {ok: false, failed: ["draining"]}
else isHostedDomainRequest
    router -> router : next()\n(skip health response)
else normal request
    router -> router : send_health_status(req, res,\n{fail_with_http_error: false})

    router -> svcHealth : req.services.get("server-health")\n→ get_status(req)
    activate svcHealth

    alt isDraining_ flag set
        svcHealth --> router : {ok: false, failed: ["draining"]}
    else check cache
        svcHealth -> kv : kv.get(ServerHealthRedisCacheKeys.status)
        activate kv

        alt cache HIT (TTL = 5 s)
            kv --> svcHealth : cached JSON string
            deactivate kv
            svcHealth -> svcHealth : JSON.parse(cached) → status
        else cache MISS
            kv --> svcHealth : null
            deactivate kv
            svcHealth -> svcHealth : #getStatusFailures()\n  failures_.map(v => v.name)
            svcHealth -> svcHealth : #getStaleHealthRunnerFailure()\n  compare now vs last_check_cycle_completed_at_\n  threshold = 3 × 5 s = 15 s
            svcHealth -> svcHealth : build status =\n  {ok: failures.length === 0,\n   failed?: [...failures]}
            svcHealth -> kv : kv.set(cacheKey,\n  JSON.stringify(status), {EX: 5})
            activate kv
            kv --> svcHealth : OK
            deactivate kv
        end

        svcHealth --> router : status
        deactivate svcHealth

        router -> router : httpStatus =\n  (fail_with_http_error && !status.ok)\n  ? 500 : 200

        router --> client : res.status(httpStatus).json(status)
    end
end

deactivate router

' ═══════════════════════════════════════════════════════════════════
'  FLOW B – Export Registrant Service Startup Registration
' ═══════════════════════════════════════════════════════════════════
== Flow B: ExportRegistrantService Self-Registration at Startup ==

caller -> svcMgr : register("export-registrant",\n  ExportRegistrantService, options)
activate svcMgr

svcMgr -> svcMgr : await setTimeout(0)\n[yield to event loop]

svcMgr -> tservice : Service.create({parameters, context})\n→ new ExportRegistrantService()
activate tservice
tservice -> exportSvc : ins.as(TService).construct(parameters)\n[calls _construct if defined]
activate exportSvc
exportSvc --> tservice : instance ready
deactivate exportSvc
tservice --> svcMgr : ExportRegistrantService instance
deactivate tservice

svcMgr -> svcMgr : push entry\n{name, instance, status: "registering"}\ninto services_l_ / services_m_

svcMgr -> svcMgr : maybe_init_("export-registrant")

svcMgr -> exportSvc : instance.as(TService).get_depends()\n[reads constructor.DEPENDS ?? []]
activate exportSvc
exportSvc --> svcMgr : [] (no dependencies)
deactivate exportSvc

svcMgr -> svcMgr : get_waiting_for_([]) → []\n(all deps satisfied)

svcMgr -> svcMgr : init_service_("export-registrant")\nentry.status = "initializing"

svcMgr -> exportSvc : service_impl.as(TService).init()
activate exportSvc

note over exportSvc
  ExportRegistrantService._init():
  console.log(Spinner)
  [force Spinner import —
   prevents tree-shaking]
end note

exportSvc --> svcMgr : init resolved
deactivate exportSvc

svcMgr -> svcMgr : entry.status = "running"\nentry.statusStartTS = new Date()

svcMgr -> svcMgr : check waiting_["export-registrant"]\n→ notify dependent services via maybe_init_\n(none waiting)

svcMgr -> svcMgr : iterate init_listeners_\n→ call each listener\n[unblocks aget() callers]

svcMgr --> caller : service running
deactivate svcMgr

@enduml
