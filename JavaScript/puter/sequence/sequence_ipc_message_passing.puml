@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    BoxBackgroundColor #F1F3F5
    DividerBorderColor #495057
    GroupBorderColor #868E96
    GroupBackgroundColor #DEE2E6
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title IPC Message Passing Between Processes

actor "CallerApp\n(iframe)" as Caller
participant "ExecService" as Exec
participant "IPCService" as IPC
participant "launch_app\n(helper)" as LaunchHelper
participant "ChildProcess\n(iframe)" as Child
participant "ProcessService" as ProcSvc
participant "BroadcastService\n(GUI)" as Broadcast

== launchApp: Connection Setup & Child Launch ==

Caller -> Exec : IPC call 'launchApp'\n({app_name, args, pseudonym, file_paths, items}, ipc_context)
activate Exec

Exec -> Exec : extract caller process\nfrom ipc_context.caller.process
Exec -> Exec : generate child_instance_id = uuidv4()

Exec -> IPC : add_connection({source: caller.uuid,\ntarget: child_instance_id})
activate IPC
IPC -> IPC : create forward conn (uuid=A)\n+ backward conn (r_uuid=B)\nin connections_ map
IPC --> Exec : return {forward: {uuid:A, reverse:B},\nbackward: {uuid:B, reverse:A}}
deactivate IPC

note right of Exec
  forward: caller → child (uuid=A)
  backward: child → caller (uuid=B)
  child gets parent_pseudo_id = B
  caller gets appInstanceID = A
end note

Exec -> LaunchHelper : launch_app({name, uuid: child_instance_id,\nparent_instance_id, parent_pseudo_id: B,\nargs, file_paths, items})
activate LaunchHelper
LaunchHelper --> Exec : return {launchResult,\nreferences: {iframe, el_win}}
deactivate LaunchHelper

== Child IPC Attachment Detection ==

Child -> Exec : ipc_status changes to\nPROCESS_IPC_ATTACHED\n(onchange listener)
activate Exec

Exec -> Exec : send_child_launched_msg()\n{uses_sdk: true}

Exec -> Caller : postMessage({msg: 'childAppLaunched',\noriginal_msg_id, child_instance_id,\nuses_sdk: true}, '*')

Exec -> Broadcast : sendSavedBroadcastsTo(child_instance_id)
activate Broadcast
loop for each saved broadcast
    Broadcast -> Child : postMessage({msg: 'broadcast',\nname, data}, '*')
end
deactivate Broadcast
deactivate Exec

== Child Window Close ==

Child -> Exec : el_win 'remove' jQuery event
activate Exec

Exec -> Caller : postMessage({msg: 'appClosed',\nappInstanceID: A, statusCode: 0}, '*')

opt not SDK app
    Exec -> Exec : report_app_closed(child_process.uuid)
end
deactivate Exec

== launchApp Return ==

Exec --> Caller : return {appInstanceID: A,\nusesSDK: true, response?}
deactivate Exec

|||

== connectToInstance: Attach to Existing Process ==

Caller -> Exec : IPC call 'connectToInstance'\n({app_name, args}, ipc_context)
activate Exec

Exec -> Exec : verify caller == 'phoenix'\nverify target == 'puter-linux'

Exec -> ProcSvc : select_by_name(app_name)
activate ProcSvc
ProcSvc --> Exec : return existing process
deactivate ProcSvc

Exec -> IPC : add_connection({source: caller.uuid,\ntarget: process.uuid})
activate IPC
IPC --> Exec : return {forward, backward}
deactivate IPC

Exec -> Child : handle_connection(connection.backward, args)
activate Child
Child --> Exec : return response
deactivate Child

Exec --> Caller : return {appInstanceID: forward.uuid,\nusesSDK: true, response}
deactivate Exec

|||

== InternalConnection: Direct Message Dispatch ==

participant "Sender\n(process)" as Sender
participant "InternalConnection" as Conn
participant "TargetProcess\n(process)" as Target

Sender -> Conn : send(data)
activate Conn

Conn -> ProcSvc : get_by_uuid(target_uuid)
activate ProcSvc
ProcSvc --> Conn : return target process
deactivate ProcSvc

Conn -> Target : process.send({returnAddress: reverse_uuid}, data)
deactivate Conn

@enduml
