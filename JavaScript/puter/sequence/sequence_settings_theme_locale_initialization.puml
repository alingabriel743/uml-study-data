@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequenceArrowColor #495057
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #6C757D
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #ADB5BD

title Settings, Theme, and Locale Service Initialization

actor Browser as browser

participant "globals.js" as globals
participant "initgui.js\n(launch_services)" as initgui
participant "Service\n(base class)" as svc_base
participant "BroadcastService" as broadcast
participant "ThemeService" as theme
participant "SettingsService" as settings
participant "LocaleService" as locale
participant "LaunchOnInitService" as launch_init
participant "puter.fs" as fs
participant "DOM (:root)" as dom

== Boot: Global State Setup ==

browser -> globals: page load
activate globals
note over globals
  Parse localStorage('user_preferences')
  → { language: navigator.language || 'en' }
  → window.user_preferences
  window.locale = 'en'  (static default)
end note
globals --> browser: window globals set
deactivate globals

== Service Registration ==

browser -> initgui: launch_services(options)
activate initgui

initgui -> broadcast: new BroadcastService()
activate broadcast
broadcast --> initgui: instance
deactivate broadcast

initgui -> theme: new ThemeService()
activate theme
theme --> initgui: instance
deactivate theme

initgui -> locale: new LocaleService()
activate locale
locale --> initgui: instance
deactivate locale

initgui -> settings: new SettingsService()
activate settings
settings --> initgui: instance
deactivate settings

initgui -> launch_init: new LaunchOnInitService()
activate launch_init
launch_init --> initgui: instance
deactivate launch_init

== Two-Phase Initialization: construct() ==

loop for each registered service instance
    initgui -> svc_base: instance.construct({ gui_params: options })
    activate svc_base
    note right of svc_base
      Sets this.$puter (gui_params)
      Delegates to _construct()
    end note
    svc_base --> initgui: constructed
    deactivate svc_base
end

== Two-Phase Initialization: init() ==

loop for each registered service instance
    initgui -> svc_base: instance.init({ services })
    activate svc_base
    note right of svc_base
      Sets this.services reference
      Delegates to _init()
    end note
    svc_base --> initgui: initialized
    deactivate svc_base
end

== ThemeService._init() ==

initgui -> theme: _init()
activate theme

theme -> broadcast: globalThis.services.get('broadcast')
activate broadcast
broadcast --> theme: broadcastService ref
deactivate broadcast

note over theme
  Set default state:
  hue=210, sat=41.18%
  lig=93.33%, alpha=0.8
  light_text=false
end note

theme -> dom: document.querySelector(':root')
activate dom
dom --> theme: root element ref
deactivate dom

theme -> fs: puter.fs.read('~/.__puter_gui.json') [async .then()]
note right of theme: Non-blocking — init() returns\nwhile file load is in-flight

theme --> initgui: _init() returned (async pending)
deactivate theme

== ThemeService: Async Theme File Callback ==

fs --> theme: [async callback] Blob data
activate theme

theme -> theme: data.text() → JSON.parse(data)
theme -> theme: merge data.colors into this.state

theme -> theme: reload_()
activate theme

theme -> dom: setProperty('--primary-hue', hue)
activate dom
theme -> dom: setProperty('--primary-saturation', sat%)
theme -> dom: setProperty('--primary-lightness', lig%)
theme -> dom: setProperty('--primary-alpha', alpha)
dom --> theme: CSS vars applied
deactivate dom

theme -> broadcast: sendBroadcast('themeChanged',\n  { palette: {...} },\n  { sendToNewAppInstances: true })
activate broadcast
broadcast --> theme: broadcast sent
deactivate broadcast

deactivate theme
deactivate theme

alt puter.fs error: 'subject_does_not_exist'
    fs --> theme: [catch] error
    note over theme: File not found — silently\nignore, use default theme
end

== SettingsService._init() ==

initgui -> settings: _init()
activate settings

note over settings
  Register 7 settings tabs:
  UsageTab, AccountTab,
  SecurityTab, PersonalizationTab,
  LanguageTab, KeyboardShortcutsTab,
  AboutTab
end note

loop for each tab class
    settings -> settings: register_tab(tab)\n→ this.#tabs.push(tab)
end

settings --> initgui: _init() complete
deactivate settings

== LocaleService._init() ==

initgui -> locale: _init()
activate locale
note over locale
  No _init() defined — no-op.
  Actual locale is managed by
  globals.js + helpers.js
end note
locale --> initgui: _init() complete (no-op)
deactivate locale

== LaunchOnInitService._init() ==

initgui -> launch_init: _init()
activate launch_init

launch_init -> launch_init: read this.$puter.gui_params\n.launch_options.on_initialized

loop for each on_initialized command
    launch_init -> launch_init: run_(command)\n[e.g. 'window-call']
end

launch_init --> initgui: _init() complete
deactivate launch_init

== Post-Init: Mark Process as Running ==

initgui -> initgui: svc_process.get_init()\n.chstatus(PROCESS_RUNNING)
deactivate initgui

== Runtime: Locale Update via user preferences ==

browser -> globals: window.update_user_preferences(prefs)
activate globals

note over globals
  helpers.js:
  window.locale = prefs.language ?? 'en'
end note

globals -> broadcast: sendBroadcast('localeChanged',\n  { language },\n  { sendToNewAppInstances: true })
activate broadcast
broadcast --> globals: broadcast sent
deactivate broadcast

globals --> browser: locale updated
deactivate globals

@enduml
