@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    BoxBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    GroupBorderColor #6C757D
    GroupBackgroundColor #DEE2E6
    DividerBackgroundColor #CED4DA
    DividerBorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
    FontColor #212529
}

title User Account Management UI Flows

actor User as user
participant "UIWindowChangeUsername" as changeUser
participant "UIWindowChangePassword" as changePass
participant "UIWindowSaveAccount" as saveAccount
participant "UIWindowEmailConfirmation\nRequired" as emailConfirm
participant "openRevalidatePopup\n(OIDC util)" as oidcPopup
participant "check_password_strength\n(helper)" as pwdStrength
participant "update_username_in_gui\n(helper)" as updateGui
participant "API Server" as api

' ─────────────────────────────────────────────────────────────────
== Flow 1: Change Username ==
' ─────────────────────────────────────────────────────────────────

user -> changeUser : clicks "Change Username"
activate changeUser

changeUser -> changeUser : validate new_username\n(show error if empty)

alt OIDC-only path (oidc_only && !revalidated && !password)
    changeUser -> changeUser : myOpenRevalidatePopup()
    activate changeUser
    changeUser -> changeUser : disable submit button\nshow OIDC hint text
    changeUser -> oidcPopup : openRevalidatePopup(revalidateUrl)
    activate oidcPopup
    oidcPopup -> user : open OIDC provider popup
    user -> oidcPopup : completes OIDC sign-in
    oidcPopup --> changeUser : resolves
    deactivate oidcPopup
    changeUser -> changeUser : hide hint text
    deactivate changeUser
    changeUser -> api : POST /user-protected/change-username\n{new_username} (no password, credentials: include)
else Standard path
    changeUser -> api : POST /user-protected/change-username\n{new_username, password} (credentials: include)
end

activate api
api --> changeUser : HTTP Response
deactivate api

alt res.ok
    changeUser -> updateGui : update_username_in_gui(new_username)
    changeUser -> changeUser : window.user.username = new_username\nshow success msg, clear inputs
else code = "oidc_revalidation_required" (server-triggered)
    changeUser -> changeUser : myOpenRevalidatePopup(data.revalidate_url)
    activate changeUser
    changeUser -> oidcPopup : openRevalidatePopup(revalidateUrl)
    activate oidcPopup
    oidcPopup -> user : OIDC provider popup
    user -> oidcPopup : completes sign-in
    oidcPopup --> changeUser : resolves
    deactivate oidcPopup
    deactivate changeUser
    changeUser -> api : retry POST /user-protected/change-username\n(no password body)
    activate api
    api --> changeUser : HTTP Response
    deactivate api
    alt retry ok
        changeUser -> updateGui : update_username_in_gui(new_username)
        changeUser -> changeUser : show success msg
    else retry fail
        changeUser -> changeUser : onError(d.message)
    end
else other error
    changeUser -> changeUser : onError(data.message)
end

deactivate changeUser

' ─────────────────────────────────────────────────────────────────
== Flow 2: Change Password ==
' ─────────────────────────────────────────────────────────────────

user -> changePass : clicks "Change Password"
activate changePass

changePass -> changePass : validate new_password\n+ confirm_new_password present
changePass -> changePass : validate passwords match\n(show i18n('passwords_do_not_match') on mismatch)
changePass -> pwdStrength : check_password_strength(new_password)
pwdStrength --> changePass : {overallPass: bool}

alt password too weak
    changePass -> changePass : show i18n('password_strength_error')
else strength OK
    alt OIDC-only path (oidc_only && !revalidated && !current_password)
        changePass -> changePass : myOpenRevalidatePopup()
        activate changePass
        changePass -> changePass : disable submit button\nshow OIDC hint text
        changePass -> oidcPopup : openRevalidatePopup(revalidateUrl)
        activate oidcPopup
        oidcPopup -> user : open OIDC provider popup
        user -> oidcPopup : completes OIDC sign-in
        oidcPopup --> changePass : resolves
        deactivate oidcPopup
        changePass -> changePass : hide hint text
        deactivate changePass
        changePass -> api : POST /user-protected/change-password\n{new_pass: new_password} (credentials: include)
    else Standard path
        changePass -> api : POST /user-protected/change-password\n{password: current_password, new_pass: new_password}
    end

    activate api
    api --> changePass : HTTP Response
    deactivate api

    alt res.ok
        changePass -> changePass : show success msg, clear inputs, re-enable button
    else code = "oidc_revalidation_required" (server-triggered)
        changePass -> changePass : myOpenRevalidatePopup(data.revalidate_url)
        activate changePass
        changePass -> oidcPopup : openRevalidatePopup(revalidateUrl)
        activate oidcPopup
        oidcPopup -> user : OIDC provider popup
        user -> oidcPopup : completes sign-in
        oidcPopup --> changePass : resolves
        deactivate oidcPopup
        deactivate changePass
        changePass -> api : retry POST /user-protected/change-password\n(empty body)
        activate api
        api --> changePass : HTTP Response
        deactivate api
        alt retry ok
            changePass -> changePass : show success msg, re-enable
        else retry fail
            changePass -> changePass : onError(d.message)
        end
    else other error
        changePass -> changePass : onError(data.message || res.statusText)
    end
end

deactivate changePass

' ─────────────────────────────────────────────────────────────────
== Flow 3: Save Account (Create Account Dialog) ==
' ─────────────────────────────────────────────────────────────────

note over saveAccount
  Wrapped in a Promise<bool>:
  resolves true on success,
  false on close/cancel,
  is_verified if email confirmation needed
end note

user -> saveAccount : opens Save Account dialog\n(caller opens modal, awaits Promise<bool>)
activate saveAccount

saveAccount -> saveAccount : render UIWindow form\n(username, email, password fields)
user -> saveAccount : fills username, email, password\nclicks "Create Account"
saveAccount -> saveAccount : disable button + inputs\nblur fields

saveAccount -> api : $.ajax POST /save_account\n{username, email, password, referrer,\nsend_confirmation_code}\n(Bearer auth_token)
activate api
api --> saveAccount : success {token, user}
deactivate api

saveAccount -> saveAccount : dispatchEvent('account-saved', {detail: data})\nwindow.update_auth_data(data.token, data.user)

alt email_confirmation_required
    saveAccount -> emailConfirm : open UIWindowEmailConfirmationRequired\n({stay_on_top: true})
    activate emailConfirm
    emailConfirm -> user : show email verification UI
    user -> emailConfirm : verifies email
    emailConfirm --> saveAccount : is_verified
    deactivate emailConfirm
    saveAccount --> user : resolve(is_verified)
else no email confirmation required
    saveAccount --> user : resolve(true)
end

saveAccount -> saveAccount : hide form, show success panel
user -> saveAccount : clicks OK on success panel
saveAccount -> saveAccount : $(el_window).close()

alt API error
    saveAccount -> saveAccount : show err.responseText\nre-enable button + inputs
else window closed / X button
    saveAccount --> user : resolve(false)
end

deactivate saveAccount

@enduml
