@startuml
title Puter — System Context Diagram

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actor {
    BackgroundColor<<Person>> #08427B
    FontColor<<Person>> #FFFFFF
    BorderColor<<Person>> #052E56
}

skinparam package {
    BackgroundColor #F5F5F5
    BorderColor #BDBDBD
    FontColor #424242
    FontStyle bold
}

skinparam arrow {
    Color #424242
    FontSize 10
    FontColor #616161
}

' ── Actors ──────────────────────────────────────────────────────────────────
actor "End User\n[Browser / Web Desktop]" as user <<Person>>
actor "App Developer\n[Puter SDK / REST API]" as developer <<Person>>
actor "System Admin\n[Self-hosted Operator]" as admin <<Person>>

' ── Core System ──────────────────────────────────────────────────────────────
rectangle "**Puter**\n[Node.js / Express.js — Cloud OS]\n\nBrowser-based desktop environment.\nHandles filesystem, auth, permissions,\nchat AI, notifications, apps & extensions." as system <<System>>

' ── Data Stores ──────────────────────────────────────────────────────────────
package "Data Stores" {
    rectangle "**SQLite**\n[Embedded Relational DB]\n\nUser data, filesystem entries,\napp records, permissions,\nrate-limit state" as sqlite <<Database>>

    rectangle "**AWS DynamoDB**\n[Managed NoSQL DB]\n\nScalable key-value store\nfor cloud-hosted deployments;\ncache invalidation events" as dynamo <<Database>>
}

' ── AWS Cloud Infrastructure ─────────────────────────────────────────────────
package "AWS Cloud" {
    rectangle "**AWS S3**\n[Object Storage]\n\nUser file uploads, copies,\ndeletes; media assets;\nbackup archives" as s3 <<Infrastructure>>

    rectangle "**AWS SNS**\n[Notification Service]\n\nPush notifications,\nfan-out events to\nsubscribed endpoints" as sns <<Queue>>

    rectangle "**AWS Secrets Manager**\n[Secrets Store]\n\nAPI keys, credentials,\nencryption secrets for\nproduction deployments" as secrets <<Infrastructure>>
}

' ── AI / LLM Providers ───────────────────────────────────────────────────────
package "AI Providers" {
    rectangle "**Anthropic Claude**\n[LLM API]\n\nText generation,\nchat completions,\nadvanced reasoning" as anthropic <<External>>

    rectangle "**OpenAI**\n[LLM API]\n\nGPT chat completions,\nembeddings, image\ngeneration (via AI SDK)" as openai <<External>>

    rectangle "**Google Gemini**\n[LLM API]\n\nMultimodal AI,\ntext & vision models\n(via @google/genai)" as gemini <<External>>

    rectangle "**OpenRouter**\n[AI Gateway]\n\nUnified proxy to multiple\nLLM providers; model\nlisting & routing" as openrouter <<External>>
}

' ── Communication & Real-time ─────────────────────────────────────────────────
package "Communication" {
    rectangle "**SMTP Server**\n[Email Transport]\n\nTransactional emails:\nverification, password\nreset, notifications" as smtp <<External>>
}

' ── Client & Protocol Layer ───────────────────────────────────────────────────
package "Client Protocols" {
    rectangle "**Socket.IO Server**\n[Real-time Channel]\n\nBi-directional events\nbetween GUI and backend;\nnotification delivery" as socketio <<External>>

    rectangle "**WISP Protocol**\n[WebSocket TCP Proxy]\n\nProxies TCP connections\nfor Puter apps; enables\nin-browser networking" as wisp <<External>>
}

' ── Auth & Identity ───────────────────────────────────────────────────────────
package "Auth & Identity" {
    rectangle "**OIDC Provider**\n[OAuth 2.0 / OIDC]\n\nExternal identity provider\nfor SSO; token issuance\nand validation" as oidc <<External>>
}

' ── Observability ─────────────────────────────────────────────────────────────
package "Observability" {
    rectangle "**OpenTelemetry Collector**\n[Telemetry Backend]\n\nDistributed traces,\nmetrics and logs\nexported via OTLP/gRPC" as otel <<Infrastructure>>
}

' ── Relationships: Actors → System ───────────────────────────────────────────
user --> system : "HTTPS + Socket.IO\n(REST API, GUI app\nrequests, file ops)"
developer --> system : "HTTPS REST\n(Puter SDK API calls,\napp deployment)"
admin --> system : "CLI / HTTPS\n(config, deploy,\nservice management)"

' ── Relationships: System → Data Stores ──────────────────────────────────────
system --> sqlite : "SQLite driver\n(reads/writes: users,\nfiles, permissions)"
system --> dynamo : "AWS SDK / HTTPS\n(put/get/query items;\ncache events)"

' ── Relationships: System → AWS Cloud ────────────────────────────────────────
system --> s3 : "AWS SDK / HTTPS\n(upload, copy,\ndelete objects)"
system --> sns : "AWS SDK / HTTPS\n(publish notifications\n& events)"
system --> secrets : "AWS SDK / HTTPS\n(fetch runtime secrets\n& credentials)"

' ── Relationships: System → AI Providers ────────────────────────────────────
system --> anthropic : "HTTPS REST\n(chat completions,\nstreaming responses)"
system --> openai : "HTTPS REST\n(completions, models\nvia @ai-sdk/openai)"
system --> gemini : "HTTPS REST\n(multimodal completions\nvia @google/genai)"
system --> openrouter : "HTTPS REST\n(model listing,\nrouted completions)"

' ── Relationships: System → Communication ────────────────────────────────────
system --> smtp : "SMTP / Nodemailer\n(send transactional\nemails)"

' ── Relationships: System ↔ Client Protocols ────────────────────────────────
system --> socketio : "WebSocket / HTTP\n(emit: notifications,\nfile-change events)"
socketio --> user : "WebSocket\n(real-time events\nto browser)"
system --> wisp : "WebSocket\n(WISP frames:\nTCP proxy for\nputer-apps)"

' ── Relationships: System → Auth ────────────────────────────────────────────
system --> oidc : "HTTPS / OIDC\n(token validation,\nSSO token exchange)"
oidc --> user : "HTTPS / OAuth 2.0\n(auth redirect,\ntoken issuance)"

' ── Relationships: System → Observability ───────────────────────────────────
system --> otel : "gRPC / OTLP\n(traces, metrics,\nlog records)"

@enduml
