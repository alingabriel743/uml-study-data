{
  "scope": "file_sharing_and_permissions",
  "title": "File Sharing and Permissions",
  "diagram_type": "use_case",
  "actors": [
    {
      "name": "AuthenticatedUser",
      "description": "A logged-in user who owns files/folders and can share or manage permissions"
    },
    {
      "name": "RecipientUser",
      "description": "Another user who receives file/permission grants from the owner"
    },
    {
      "name": "App",
      "description": "A Puter application that can be granted or have permissions checked against it"
    },
    {
      "name": "GroupOwner",
      "description": "An AuthenticatedUser who owns and manages a permission group (extends AuthenticatedUser)"
    },
    {
      "name": "System",
      "description": "Internal system: FSEntryController queue processor and PermissionService"
    }
  ],
  "use_cases": [
    {
      "id": "UC01",
      "name": "Grant Permission to User",
      "actor": "AuthenticatedUser",
      "endpoint": "POST /auth/grant-user-user",
      "params": ["target_username", "permission", "extra?", "meta?"],
      "service_call": "svc_permission.grant_user_user_permission(actor, target_username, permission, extra, meta)",
      "constraint": "Actor must be UserActorType",
      "db_table": "user_to_user_permissions"
    },
    {
      "id": "UC02",
      "name": "Revoke Permission from User",
      "actor": "AuthenticatedUser",
      "endpoint": "POST /auth/revoke-user-user",
      "service_call": "svc_permission.revoke_user_user_permission(...)",
      "constraint": "Actor must be UserActorType"
    },
    {
      "id": "UC03",
      "name": "Grant Permission to Group",
      "actor": "AuthenticatedUser",
      "endpoint": "POST /auth/grant-user-group",
      "params": ["group_uid", "permission", "extra?", "meta?"],
      "service_call": "svc_permission.grant_user_group_permission(actor, group_uid, permission, extra, meta)",
      "constraint": "Actor must be UserActorType"
    },
    {
      "id": "UC04",
      "name": "Revoke Permission from Group",
      "actor": "AuthenticatedUser",
      "endpoint": "POST /auth/revoke-user-group",
      "service_call": "svc_permission.revoke_user_group_permission(...)"
    },
    {
      "id": "UC05",
      "name": "Grant App Permission",
      "actor": "AuthenticatedUser",
      "endpoint": "POST /auth/grant-user-app",
      "db_table": "user_to_app_permissions"
    },
    {
      "id": "UC06",
      "name": "Revoke App Permission",
      "actor": "AuthenticatedUser",
      "endpoint": "POST /auth/revoke-user-app"
    },
    {
      "id": "UC07",
      "name": "Grant Developer App Permission",
      "actor": "AuthenticatedUser",
      "endpoint": "POST /auth/grant-dev-app"
    },
    {
      "id": "UC08",
      "name": "Revoke Developer App Permission",
      "actor": "AuthenticatedUser",
      "endpoint": "POST /auth/revoke-dev-app"
    },
    {
      "id": "UC09",
      "name": "Check Permissions",
      "actor": "AuthenticatedUser",
      "endpoint": "POST /auth/check-permissions",
      "params": ["permissions: string[]"],
      "service_call": "permissionService.check(actor, perm)",
      "returns": "{ permissions: { [perm]: boolean } }"
    },
    {
      "id": "UC10",
      "name": "List Permissions",
      "actor": "AuthenticatedUser",
      "endpoint": "GET /auth/list-permissions",
      "constraint": "UserActorType only",
      "returns": "{ myself_to_app[], myself_to_user[], user_to_myself[] }",
      "db_queries": [
        "SELECT * FROM user_to_app_permissions WHERE user_id=?",
        "SELECT * FROM user_to_user_permissions WHERE issuer_user_id=?",
        "SELECT * FROM user_to_user_permissions WHERE holder_user_id=?"
      ]
    },
    {
      "id": "UC11",
      "name": "Check App ACL",
      "actor": "App",
      "endpoint": "GET /auth/check-app-acl",
      "handler": "check-app-acl.endpoint.js"
    },
    {
      "id": "UC12",
      "name": "Create Permission Group",
      "actor": "GroupOwner",
      "endpoint": "POST /group/create",
      "params": ["extra?", "metadata?"],
      "service_call": "svc_group.create({ owner_user_id, extra, metadata })",
      "returns": "{ uid }"
    },
    {
      "id": "UC13",
      "name": "Add Users to Group",
      "actor": "GroupOwner",
      "endpoint": "POST /group/add-users",
      "params": ["uid", "users: string[]"],
      "service_call": "svc_group.add_users({ uid, users })",
      "constraint": "group.owner_user_id === req.user.id"
    },
    {
      "id": "UC14",
      "name": "Remove Users from Group",
      "actor": "GroupOwner",
      "endpoint": "POST /group/remove-users",
      "params": ["uid", "users: string[]"],
      "service_call": "svc_group.remove_users({ uid, users })",
      "constraint": "group.owner_user_id === req.user.id"
    },
    {
      "id": "UC15",
      "name": "List Groups",
      "actor": "AuthenticatedUser",
      "endpoint": "GET /group/list",
      "service_calls": [
        "svc_group.list_groups_with_owner({ owner_user_id })",
        "svc_group.list_groups_with_member({ user_id })",
        "svc_group.list_public_groups()"
      ],
      "returns": "{ owned_groups[], in_groups[], public_groups[] }"
    },
    {
      "id": "UC16",
      "name": "Get Public Groups",
      "actor": "AuthenticatedUser",
      "endpoint": "GET /group/public-groups",
      "returns": "{ user: default_user_group, temp: default_temp_group }"
    },
    {
      "id": "UC17",
      "name": "Share File/Folder (Filesystem)",
      "actor": "AuthenticatedUser",
      "description": "Uses filesystem routes (write, mkdir, stat, readdir, copy, move, rename) exposed by FilesystemAPIService; permission checks enforced internally via PermissionService",
      "backed_by": "FilesystemAPIService routes + FSEntryController"
    },
    {
      "id": "UC18",
      "name": "Read Shared File",
      "actor": "RecipientUser",
      "endpoint": "GET /file or /filesystem/read or /filesystem/token-read",
      "description": "RecipientUser accesses a file shared with them; backed by FSEntryController.findByUID/findByPath + permission check"
    },
    {
      "id": "UC19",
      "name": "Request App Root Directory",
      "actor": "App",
      "endpoint": "POST /auth/request-app-root-dir",
      "description": "App requests its sandboxed root directory, subject to permission check"
    }
  ],
  "key_relationships": [
    "GroupOwner extends AuthenticatedUser",
    "AuthenticatedUser <<include>> Check Permissions (permission verified on every protected action)",
    "UC03 (Grant to Group) <<extend>> UC12 (Create Group) — group must exist",
    "UC13 <<include>> svc_group.get() to verify group ownership before adding users",
    "UC17 (Share File) <<include>> UC01/UC03 to set access permissions",
    "UC18 (Read Shared File) <<include>> UC09 (Check Permissions)",
    "FilesystemAPIService delegates to FSEntryController for all DB reads/writes",
    "FSEntryController uses batched queue: insert/update/delete → enqueue_ → exec_ → db.batch_write",
    "PermissionAPIService depends_on PermissionService (svc_permission)",
    "PermissionAPIService depends_on GroupService (svc_group)",
    "FilesystemAPIService depends_on FSEntryController (via legacyFileSystem extension)"
  ],
  "system_boundaries": [
    {
      "boundary": "Puter API Server",
      "contains": ["PermissionAPIService", "FilesystemAPIService", "PermissionService", "GroupService"]
    },
    {
      "boundary": "Legacy FileSystem Extension",
      "contains": ["FSEntryController", "Insert", "Update", "Delete", "BaseOperation"]
    },
    {
      "boundary": "Database",
      "contains": ["fsentries table", "user_to_user_permissions table", "user_to_app_permissions table", "groups table"]
    }
  ],
  "important_notes": [
    "All permission endpoints require auth2 middleware (configurable_auth) and are on the 'api' subdomain",
    "Group ownership enforced at API layer: group.owner_user_id must equal req.user.id for mutating ops",
    "FSEntryController uses a two-state queue (currentState / deferredState) with STATUS_READY / STATUS_RUNNING_JOB for batched DB writes",
    "Permissions are scoped: user-to-user, user-to-app, user-to-group, dev-app",
    "list-permissions returns 3 views: permissions I gave to apps, permissions I gave to users, permissions users gave me",
    "FSEntryController defaultProperties include is_public, public_token, file_request_token — these support public file sharing"
  ],
  "source_files_analyzed": [
    "src/backend/src/services/PermissionAPIService.js",
    "src/backend/src/services/FilesystemAPIService.js",
    "extensions/legacyFileSystem/fsentries/FSEntryController.js",
    "src/backend/src/routers/auth/grant-user-user.js",
    "src/backend/src/routers/auth/grant-user-group.js",
    "src/backend/src/routers/auth/check-permissions.js",
    "src/backend/src/routers/auth/list-permissions.js"
  ]
}
