@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}

left to right direction

title AI Model Management

' ── Primary Actors (left) ──────────────────────────────────────
actor "Client\n(API User)" as client

' ── External / Supporting Actors (right) ──────────────────────
actor "OpenRouter\nProvider" as openrouter
actor "AI Image Generation\nService" as imageService
actor "Metering\nService" as metering

' ── System Boundary ────────────────────────────────────────────
rectangle "AI Model Management System" {

    ' Model Discovery
    usecase "List Available Chat Models\n<size:10><i>GET /puterai/chat/models</i></size>" as UC1
    usecase "Get Detailed Chat Model Info\n<size:10><i>GET /puterai/chat/models/details</i></size>" as UC2
    usecase "List Available Image Models\n<size:10><i>GET /puterai/image/models</i></size>" as UC3

    ' Completion Routing
    usecase "Route Chat Completion\nto Provider" as UC5
    usecase "Get Default Model" as UC4

    ' Provider Lifecycle
    usecase "Register AI Providers\n<size:10><i>(bootstrap on service init)</i></size>" as UC6

    ' Client-Side Logging
    usecase "Log API Calls\n<size:10><i>(puter-js client-side)</i></size>" as UC7

    ' Supporting Sub-Use-Cases
    usecase "Record Token Usage\n& Costs" as UC8
    usecase "Cache Model List\n<size:10><i>(KV Store)</i></size>" as UC9
    usecase "Apply Model Config\nOverrides" as UC10
    usecase "Filter Restricted\nModels" as UC11
}

' ── Actor → Use Case Associations ─────────────────────────────
client --> UC1
client --> UC2
client --> UC3
client --> UC5
client --> UC7

openrouter --> UC1
openrouter --> UC2
openrouter --> UC5
openrouter --> UC6

imageService --> UC3

metering --> UC8

' ── Include / Extend Relationships ────────────────────────────
UC5 ..> UC4   : <<include>>
UC5 ..> UC8   : <<include>>
UC1 ..> UC9   : <<extend>>
UC2 ..> UC9   : <<extend>>
UC2 ..> UC10  : <<extend>>
UC1 ..> UC11  : <<include>>
UC2 ..> UC11  : <<include>>

note bottom of UC6
  Auto-discovers Ollama via
  localhost:11434/api/tags.
  Emits 'ai.chat.registerProviders'
  for extension providers.
  Supports: claude, openai, gemini,
  groq, deepseek, mistral, xai,
  openrouter, together-ai, ollama.
end note

note right of UC5
  Concurrent request limit:
  default=3, free=5 (configurable).
  MAX_FALLBACKS=4 (3 retries).
  Strips provider prefix before
  forwarding to OpenAI SDK.
end note

@enduml
