@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7ABD
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057

title API Call Logging and Monitoring

left to right direction

' ── Actors ──────────────────────────────────────────
actor "Developer" as Developer
actor "puter-js SDK\n(API Modules)" as SDK
actor "App (iframe)" as AppIframe

' ── System Boundary: puter-js SDK / APICallLogger ───
rectangle "puter-js SDK  /  APICallLogger" {
    usecase "Enable API Call Logging\n(puter.enableAPILogging)" as UC1
    usecase "Disable API Call Logging\n(puter.disableAPILogging)" as UC2
    usecase "Configure API Logging\n(puter.configureAPILogging)" as UC3
    usecase "Log API Request\n(apiCallLogger.logRequest)" as UC4
    usecase "Get Logging Stats\n(apiCallLogger.getStats)" as UC5
}

' ── System Boundary: GUI / DebugService ─────────────
rectangle "GUI  /  DebugService  &  ServiceManager" {
    usecase "Enable Log Category\n(DebugService.logs)" as UC6
    usecase "Propagate Log Categories\nto App Iframes" as UC7
    usecase "Register & Initialize\nDebugService" as UC8
}

' ── Actor → Use Case relationships ──────────────────
Developer --> UC1
Developer --> UC2
Developer --> UC3
Developer --> UC5
Developer --> UC6

SDK --> UC4

Developer --> UC8

' ── Include / Extend relationships ──────────────────
UC1 ..> UC3 : <<include>>\nupdateConfig(enabled:true)
UC2 ..> UC3 : <<include>>\nupdateConfig(enabled:false)

UC6 ..> UC7 : <<include>>\npostMessage log.on

' ── Use Case → Actor relationships ──────────────────
UC4 --> Developer : console.log / console.error
UC5 --> Developer : {enabled, config}
UC7 --> AppIframe : postMessage\n{cmd: log.on}
UC7 --> SDK      : puter.logger.on(category)
UC8 ..> UC6      : <<include>>\nregister param_provider\nwith ExecService

@enduml
