@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title API Gateway and Error Handling

left to right direction

' ── Actors ──────────────────────────────────────────────────
actor "External Client\n(Browser / App)" as ExternalClient
actor "Web Server\n(Express App)"        as WebServer
actor "Internal Service\n/ Module"       as InternalService
actor "SDK Developer"                    as SDKUser

' ── System Boundary ─────────────────────────────────────────
rectangle "API Gateway and Error Handling" {

    ' ── API Gateway (PuterAPIService) ───────────────────────
    package "API Gateway\n(PuterAPIService)" {
        usecase "Make API Request"       as UC1
        usecase "Register API Routes"    as UC2
    }

    ' ── Error Creation & Registry (APIError / APIErrorService)
    package "Error Management\n(APIError + APIErrorService)" {
        usecase "Create Standardized\nAPI Error"          as UC3
        usecase "Register Custom\nError Codes"            as UC4
        usecase "Create Error via\nService Registry"      as UC5
        usecase "Adapt Arbitrary Error\nto APIError"      as UC9
    }

    ' ── Error Transport ─────────────────────────────────────
    package "Error Transport\n(APIError)" {
        usecase "Send Error\nHTTP Response"               as UC6
        usecase "Serialize Error\nto JSON"                as UC7
        usecase "Convert Error to\nQuery String"          as UC8
    }

    ' ── SDK Logging (APICallLogger) ──────────────────────────
    package "SDK API Call Logging\n(APICallLogger)" {
        usecase "Log API Call"                            as UC10
        usecase "Enable / Disable\nAPI Logging"          as UC11
        usecase "Check Logging\nStatistics"               as UC12
    }
}

' ── Actor → Use-Case Associations ───────────────────────────
ExternalClient  --> UC1
ExternalClient  --> UC6

WebServer       --> UC2

InternalService --> UC3
InternalService --> UC4
InternalService --> UC5
InternalService --> UC7
InternalService --> UC8
InternalService --> UC9

SDKUser         --> UC10
SDKUser         --> UC11
SDKUser         --> UC12

' ── Include / Extend Relationships ──────────────────────────
UC1     .down.> UC6  : <<extend>>\nerror path
UC5     .right.> UC3 : <<include>>\ndelegates to
UC9     .right.> UC3 : <<include>>\nwraps as\ninternal_error
UC4     .down.> UC5  : <<include>>\nenables

@enduml
