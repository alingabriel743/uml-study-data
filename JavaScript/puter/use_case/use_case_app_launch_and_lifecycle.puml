@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BBF
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343A40
}

title Application Launch and Lifecycle

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────
actor "User" as User
actor "GUI System" as GUISystem
actor "Running App\n(PortalProcess /\nPseudoProcess)" as RunningApp
actor "ServiceManager" as SvcMgr

' ── System Boundary ─────────────────────────────────────────────────────
rectangle "Puter Desktop GUI" {

    ' ── Startup / Lifecycle ───────────────────────────────────────────
    usecase "Initialize Services\nat Startup" as UC6
    usecase "Launch App\non System Init" as UC1
    usecase "Run INITRC Apps\non GUI Ready" as UC7

    ' ── App Launch ────────────────────────────────────────────────────
    usecase "Launch Desktop App" as UC2
    usecase "Fetch User-App\nAuth Token" as UC_TOKEN
    usecase "Launch App via IPC\n(App-to-App)" as UC3
    usecase "Connect to\nExisting App Instance" as UC4

    ' ── App Shutdown ──────────────────────────────────────────────────
    usecase "Stop / Close\nApplication" as UC5
    usecase "Reparent Orphaned\nChild Processes" as UC_REPARENT

}

' ── Actor → Use Case associations ────────────────────────────────────────
GUISystem  --> UC6
GUISystem  --> UC1
GUISystem  --> UC7

User       --> UC2
User       --> UC5

RunningApp --> UC3
RunningApp --> UC4

SvcMgr     --> UC6

' ── Include / Extend relationships ───────────────────────────────────────

' ServiceManager orchestrates service init dependency graph
UC6        ..> UC1  : <<enables>>

' INITRC launch path: ProcessService.__on_gui:ready -> svc_exec.launchApp
UC7        ..> UC3  : <<include>>

' IPC launch internally delegates to launch_app()
UC3        ..> UC2  : <<include>>

' launch_app always acquires a per-launch user-app token
UC2        ..> UC_TOKEN : <<include>>

' Closing an app triggers orphan reparenting in ProcessService
UC5        ..> UC_REPARENT : <<include>>

@enduml
