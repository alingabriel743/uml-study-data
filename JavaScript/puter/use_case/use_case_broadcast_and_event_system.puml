@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BorderColor #495057
    FontColor #212529
    BackgroundColor #FFFFFF
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 10

left to right direction

title Broadcast and Event System

' ── Actors ─────────────────────────────────────────────
actor "GUI Client\n(App / Window)" as gui_client
actor "App Launch System" as app_launch
actor "Remote Peer\n(Webhook Consumer)" as remote_peer
actor "EventService\n(outer.* events)" as event_service
actor "Redis Pub/Sub" as redis
actor "Application Bootstrap" as app_bootstrap
actor "Service / Component" as svc_component

' ── System Boundary ────────────────────────────────────
rectangle "Broadcast and Event System" {

    package "GUI Broadcast" #E3EEF7 {
        usecase "Send Broadcast\nto All Open Apps" as UC1
        usecase "Save Broadcast for\nFuture App Instances" as UC2
        usecase "Replay Saved Broadcasts\nto New App" as UC3
    }

    package "Backend Broadcast" #EAF4EA {
        usecase "Receive & Emit\nInbound Webhook Event" as UC4
        usecase "Validate HMAC\nWebhook Signature" as UC4a
        usecase "Forward Outbound Event\nto Peer via Webhook" as UC5
        usecase "Publish Events\nto Redis Pub/Sub" as UC6
        usecase "Consume Redis\nPub/Sub Events" as UC7
    }

    package "Event Infrastructure" #FFF8E1 {
        usecase "Subscribe to Event\n(wildcard selector)" as UC10
        usecase "Emit Event\nto Listeners" as UC11
    }

    package "Service Lifecycle" #F5ECF8 {
        usecase "Install BroadcastService\nvia Module" as UC12
        usecase "Register & Initialize\nService" as UC8
        usecase "Retrieve Running\nService" as UC9
    }
}

' ── Actor → Use Case associations ──────────────────────
gui_client   --> UC1
gui_client   --> UC2
app_launch   --> UC3
remote_peer  --> UC4
event_service --> UC5
redis        --> UC7
app_bootstrap --> UC12
app_bootstrap --> UC8
svc_component --> UC9
svc_component --> UC10
svc_component --> UC11

' ── Include / Extend relationships ─────────────────────
' Saving broadcasts is an optional extension of sending
UC2 <.. UC1  : <<extend>>\nsendToNewAppInstances=true

' Replaying requires previously saved broadcasts
UC3 ..> UC2  : <<include>>

' Inbound webhook must pass HMAC validation
UC4 ..> UC4a : <<include>>

' Both inbound webhook handling and outbound forwarding
' mirror events to Redis for cross-replica distribution
UC4 ..> UC6  : <<include>>
UC5 ..> UC6  : <<include>>

' Consuming a Redis message triggers local event emission
UC7 ..> UC11 : <<include>>

' Installing the module registers the service
UC12 ..> UC8 : <<include>>

@enduml
