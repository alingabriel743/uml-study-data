@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Chat and AI Integration

left to right direction

' ─── Actors ───────────────────────────────────────────────────────────────────

actor "User / API Client" as User
actor "System\n(Internal Services)" as System

actor "OpenAI API" as OpenAI
actor "Claude API" as Claude
actor "Gemini API" as Gemini
actor "Groq API" as Groq
actor "OpenRouter API" as OpenRouter
actor "Other Providers\n(DeepSeek, Mistral,\nxAI, TogetherAI, Ollama)" as OtherProviders

' ─── System boundary ──────────────────────────────────────────────────────────

rectangle "Chat & AI Integration System" {

    ' Model Discovery
    usecase "Browse AI Model Catalog\n(Chat / Image / Video)" as UC_BrowseModels
    usecase "Get Model Details\n(Cost, Capabilities, Limits)" as UC_ModelDetails

    ' Chat Request Entry Points
    usecase "Send OpenAI-Compatible\nChat Completion" as UC_OpenAICompat
    usecase "Send Anthropic-Compatible\nMessage" as UC_AnthropicCompat

    ' Core Processing
    usecase "Complete AI Chat Request\n(Route & Dispatch)" as UC_Complete
    usecase "Stream Chat Response\n(NDJSON / Chunked)" as UC_Stream

    ' Safety & Governance
    usecase "Moderate Chat Content" as UC_Moderate
    usecase "Check & Enforce\nCredit Limits" as UC_Credits
    usecase "Enforce Concurrent\nRequest Limits" as UC_Concurrency

    ' Resilience
    usecase "Fallback to Alternate\nModel / Provider" as UC_Fallback

    ' Provider Lifecycle
    usecase "Register AI Providers\nat Boot" as UC_RegisterProviders

    ' Observability
    usecase "Record Token Usage\n& Metering" as UC_Metering

    ' OpenRouter-specific
    usecase "Fetch OpenRouter\nModel Catalog" as UC_FetchORouterCatalog
    usecase "Complete Chat\nvia OpenRouter" as UC_OpenRouterComplete

}

' ─── User relationships ───────────────────────────────────────────────────────

User --> UC_BrowseModels
User --> UC_ModelDetails
User --> UC_OpenAICompat
User --> UC_AnthropicCompat
User --> UC_Stream

' ─── Include / Extend (use-case to use-case) ─────────────────────────────────

UC_BrowseModels ..> UC_ModelDetails       : <<include>>

UC_OpenAICompat  ..> UC_Complete          : <<include>>
UC_AnthropicCompat ..> UC_Complete        : <<include>>

UC_Complete ..> UC_Moderate               : <<include>>
UC_Complete ..> UC_Credits                : <<include>>
UC_Complete ..> UC_Concurrency            : <<include>>
UC_Complete ..> UC_Metering               : <<include>>

UC_Stream   ..> UC_Complete               : <<extend>>
UC_Fallback ..> UC_Complete               : <<extend>>

UC_OpenRouterComplete ..> UC_FetchORouterCatalog : <<include>>

' ─── System relationships ─────────────────────────────────────────────────────

System --> UC_RegisterProviders
System --> UC_Moderate
System --> UC_Credits
System --> UC_Concurrency
System --> UC_Fallback
System --> UC_Metering

' ─── External provider relationships ─────────────────────────────────────────

UC_Complete --> OpenAI        : dispatches to
UC_Complete --> Claude        : dispatches to
UC_Complete --> Gemini        : dispatches to
UC_Complete --> Groq          : dispatches to
UC_Complete --> OtherProviders : dispatches to

UC_OpenRouterComplete --> OpenRouter : calls via OpenAI SDK
UC_Complete ..> UC_OpenRouterComplete : <<include>>

OpenRouter --> UC_FetchORouterCatalog : provides catalog

@enduml
