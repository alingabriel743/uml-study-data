@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Cloud Storage and S3 Management

left to right direction

' ─── Actors ───────────────────────────────────────────────────────────────────
actor "Client\n(API Consumer)" as Client
actor "Internal Service\n(fsv2)" as InternalService
actor "AWS S3\n(External Storage)" as AWSS3

' ─── System Boundary ──────────────────────────────────────────────────────────
rectangle "Cloud Storage & S3 Management System" {

    ' ── Legacy S3 Object Operations (server-proxied) ──
    package "Legacy S3 Backend (S3StorageController)" {
        usecase "Upload File" as UC1
        usecase "Download / Read File" as UC2
        usecase "Copy File" as UC3
        usecase "Delete File" as UC4
        usecase "Buffer Upload\n(Single PUT)" as UC1a
        usecase "Multipart Upload\n(chunked streaming)" as UC1b
        usecase "Simple Copy\n(CopyObjectCommand)" as UC3a
        usecase "Multipart Copy\n(UploadPartCopyCommand)" as UC3b
    }

    ' ── fsv2 S3 Direct-Upload Operations (S3StorageProvider) ──
    package "fsv2 S3 Backend (S3StorageProvider)" {
        usecase "Create Signed\nUpload URL" as UC10
        usecase "Create Multipart\nPresigned URLs" as UC10b
        usecase "Complete Multipart\nUpload (client-side)" as UC11
        usecase "Server-side Upload\n(fsv2)" as UC12
    }

    ' ── Metadata / Directory Operations (FSEntryController) ──
    package "Metadata Layer (FSEntryController)" {
        usecase "Create Directory" as UC5
        usecase "Stat / Read Metadata" as UC6
        usecase "List Directory" as UC7
        usecase "Move / Rename File" as UC8
        usecase "Search Files" as UC9
    }
}

' ─── Actor → Use Case Associations ───────────────────────────────────────────

' Client drives all primary file & metadata operations
Client --> UC1
Client --> UC2
Client --> UC3
Client --> UC4
Client --> UC5
Client --> UC6
Client --> UC7
Client --> UC8
Client --> UC9
Client --> UC10
Client --> UC11

' Internal service performs server-side fsv2 uploads
InternalService --> UC12

' AWS S3 is the external system that receives/fulfills S3 commands
UC1 --> AWSS3
UC2 --> AWSS3
UC3 --> AWSS3
UC4 --> AWSS3
UC10 --> AWSS3
UC11 --> AWSS3
UC12 --> AWSS3

' ─── Include / Extend Relationships ──────────────────────────────────────────

' Upload File chooses between buffer or multipart strategies
UC1 ..> UC1a : <<include>>
UC1 <.. UC1b : <<extend>>\n(large / streaming files)

' Copy File chooses between simple or multipart based on size threshold (4 GiB)
UC3 ..> UC3a : <<include>>\n(size < 4 GiB)
UC3 <.. UC3b : <<extend>>\n(size ≥ 4 GiB)

' Signed URL creation optionally extends to multipart presigned URLs
UC10 <.. UC10b : <<extend>>\n(multipart mode)

' ─── Notes ───────────────────────────────────────────────────────────────────
note right of UC1b
  5 MB parts, max 4 concurrent
  simple_retry (3 attempts, 200 ms)
  AbortMultipartUpload on error
end note

note right of UC3b
  4 GiB parts per UploadPartCopyCommand
  Progress tracked via progress_tracker
end note

note right of UC10b
  PutObjectCommand presigned URL
  expires 60 s – 3600 s
  UploadPartCommand presigned per part
end note

note bottom of UC5
  Metadata-only: no S3 object created
end note

note bottom of UC8
  Metadata update only; S3 key unchanged
  (copy + delete pattern at upper layer if needed)
end note

@enduml
