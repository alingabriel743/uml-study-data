@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFF8E1
    BorderColor #F9A825
    FontColor #212529
}

title Desktop and GUI Management

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────
actor "User" as User
actor "System\n(initgui)" as System
actor "Extension /\nPlugin" as Extension
actor "BroadcastService" as Broadcast
actor "puter.fs\n(Filesystem API)" as PuterFS

' ── System Boundary ─────────────────────────────────────────────────────
rectangle "Puter GUI Shell (src/gui/src)" {

    ' ── Desktop Lifecycle ────────────────────────────────────────────
    usecase "UC01\nOpen Desktop" as UC01
    usecase "UC09\nRefresh Desktop Background" as UC09
    usecase "UC10\nResize Desktop" as UC10

    ' ── Theme Management ─────────────────────────────────────────────
    usecase "UC02\nApply Theme" as UC02
    usecase "UC03\nLoad Persisted Theme on Init" as UC03
    usecase "UC04\nReset Theme to Defaults" as UC04
    usecase "UC05\nBroadcast Theme Change to Apps" as UC05

    ' ── Settings ─────────────────────────────────────────────────────
    usecase "UC06\nOpen Settings Panel" as UC06
    usecase "UC07\nRegister Custom Settings Tab" as UC07

    ' ── Experimental Features ────────────────────────────────────────
    usecase "UC08\nOpen Groups Manager\n(experimental)" as UC08

}

' ── Actor → Use Case Associations ───────────────────────────────────────
System    --> UC01
System    --> UC03
System    --> UC09

User      --> UC02
User      --> UC04
User      --> UC06
User      --> UC08
User      --> UC10

Extension --> UC07

' ── Use Case → External System Associations ─────────────────────────────
UC05      --> Broadcast : sendBroadcast\n('themeChanged')
UC02      --> PuterFS   : write ~/.__puter_gui.json
UC03      --> PuterFS   : read ~/.__puter_gui.json
UC04      --> PuterFS   : delete ~/.__puter_gui.json

' ── Include / Extend Relationships ──────────────────────────────────────
UC02      ..> UC05 : <<include>>
UC04      ..> UC05 : <<include>>
UC01      ..> UC09 : <<include>>

UC06      <.. UC08 : <<extend>>\n[experimental_features\n== true]

' ── Notes ────────────────────────────────────────────────────────────────
note bottom of UC08
  Requires
  window.experimental_features === true.
  Triggered via ctxmenu-will-open
  (user-options-menu) event.
end note

note right of UC05
  Notifies all running app iframes
  of the updated color palette via
  BroadcastService.sendBroadcast().
  sendToNewAppInstances: true
end note

note bottom of UC02
  ThemeService uses a 1s debounce
  before persisting to
  ~/.__puter_gui.json
end note

@enduml
