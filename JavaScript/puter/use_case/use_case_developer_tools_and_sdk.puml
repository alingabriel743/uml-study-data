@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #F0F4F8
    BorderColor #6C757D
}
skinparam ArrowColor #495057

left to right direction

title Developer Tools and SDK

' ─── Actors ───────────────────────────────────────────────
actor "Developer" as developer
actor "SDK Consumer\n(puter-js client)" as sdkConsumer
actor "Release Engineer" as releaseEngineer
actor "Self-Hosted Operator" as operator
actor "Kernel / ServiceManager" as kernel #EAF4EA

' ─── System Boundary ──────────────────────────────────────
rectangle "Developer Tools & SDK Platform" {

    ' ── Subsystem: puter-js SDK Logging ───────────────────
    package "puter-js SDK Logging" {
        usecase "Call Puter API via SDK" as UC1
        usecase "Enable / Disable API Call Logging" as UC2
        usecase "Get Logger Stats" as UC4
    }

    ' ── Subsystem: Service Management ─────────────────────
    package "Service Management (ServiceManager)" {
        usecase "Register a Service" as UC6
        usecase "Resolve Service Dependencies" as UC7
        usecase "Wait for Service Initialization" as UC8
        usecase "Register API Routes" as UC5
    }

    ' ── Subsystem: Release Engineering Tool ───────────────
    package "Release Engineering Tool" {
        usecase "Generate Release Notes" as UC9
    }

    ' ── Subsystem: Self-Hosted Setup ──────────────────────
    package "Self-Hosted Setup" {
        usecase "Run Self-Hosted Backend" as UC10
        usecase "Configure Self-Hosted Environment" as UC11
    }
}

' ─── Actor → Use Case Associations ───────────────────────

' SDK Consumer
sdkConsumer --> UC1

' Developer
developer --> UC2
developer --> UC4
developer --> UC6
developer --> UC8

' Kernel / ServiceManager
kernel --> UC5
kernel --> UC6
kernel --> UC7

' Release Engineer
releaseEngineer --> UC9

' Self-Hosted Operator
operator --> UC10
operator --> UC11

' ─── Use Case Relationships ───────────────────────────────

' UC7 includes UC6: dependency resolution is part of the registration flow
UC7 ..> UC6 : <<include>>

' UC11 extends UC10: env config is an optional step before Kernel boot
UC10 <.. UC11 : <<extend>>

' UC5 depends on services registered via UC6/UC7
UC5 ..> UC6 : <<include>>

@enduml
