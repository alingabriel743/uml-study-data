@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam arrow {
    Color #495057
    FontColor #495057
    FontSize 11
}

title File Sharing and Permissions

left to right direction

' ─── Actors ───────────────────────────────────────────────────────────────────
actor "Authenticated User" as AuthUser
actor "Recipient User"     as RecipientUser
actor "App"                as App
actor "Group Owner"        as GroupOwner

' GroupOwner is a specialised AuthenticatedUser
GroupOwner --|> AuthUser

' ─── System Boundary ──────────────────────────────────────────────────────────
rectangle "Puter API Server" {

    ' ── Permission Management ─────────────────────────────────────────────────
    package "User Permissions" {
        usecase "Grant Permission\nto User"      as UC01
        usecase "Revoke Permission\nfrom User"   as UC02
        usecase "Check Permissions"              as UC09
        usecase "List Permissions"               as UC10
    }

    ' ── Group-Scoped Permissions ──────────────────────────────────────────────
    package "Group Permissions" {
        usecase "Grant Permission\nto Group"     as UC03
        usecase "Revoke Permission\nfrom Group"  as UC04
    }

    ' ── App Permissions ───────────────────────────────────────────────────────
    package "App Permissions" {
        usecase "Grant App Permission"           as UC05
        usecase "Revoke App Permission"          as UC06
        usecase "Grant Developer App Permission" as UC07
        usecase "Revoke Developer App Permission"as UC08
        usecase "Check App ACL"                  as UC11
        usecase "Request App Root Directory"     as UC19
    }

    ' ── Permission Group Management ───────────────────────────────────────────
    package "Permission Group Management" {
        usecase "Create Permission Group"        as UC12
        usecase "Add Users to Group"             as UC13
        usecase "Remove Users from Group"        as UC14
        usecase "List Groups"                    as UC15
        usecase "Get Public Groups"              as UC16
    }

    ' ── File Sharing ──────────────────────────────────────────────────────────
    package "File Sharing" {
        usecase "Share File / Folder"            as UC17
        usecase "Read Shared File"               as UC18
    }
}

' ─── Actor → Use-Case Associations ───────────────────────────────────────────

' Authenticated User
AuthUser --> UC01
AuthUser --> UC02
AuthUser --> UC03
AuthUser --> UC04
AuthUser --> UC05
AuthUser --> UC06
AuthUser --> UC07
AuthUser --> UC08
AuthUser --> UC09
AuthUser --> UC10
AuthUser --> UC15
AuthUser --> UC16
AuthUser --> UC17

' Recipient User
RecipientUser --> UC18

' App
App --> UC11
App --> UC19

' Group Owner
GroupOwner --> UC12
GroupOwner --> UC13
GroupOwner --> UC14

' ─── Include / Extend Relationships ──────────────────────────────────────────

' Sharing a file includes setting access permissions
UC17 ..> UC01 : <<include>>
UC17 ..> UC03 : <<include>>

' Reading a shared file requires a permission check
UC18 ..> UC09 : <<include>>

' Granting to a group implies the group already exists
UC03 ..> UC12 : <<extend>>

' Adding/removing members verifies group ownership internally
UC13 ..> UC09 : <<include>>
UC14 ..> UC09 : <<include>>

' Every protected action re-uses the core permission check
UC01 ..> UC09 : <<include>>
UC02 ..> UC09 : <<include>>

@enduml
