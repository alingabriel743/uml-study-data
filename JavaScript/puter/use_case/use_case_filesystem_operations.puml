@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Filesystem Operations\n<size:11>(File and folder CRUD: create, read, update, delete, move, copy)</size>

left to right direction

actor "Client" as client
actor "System / Batch" as batch

actor "S3 Storage" as s3 #D9EDF7
actor "Database\n(fsentries)" as db #DFF0D8

rectangle "Filesystem Module\n(FilesystemAPIService + legacyFileSystem)" {

    ' ── Write / Read ──────────────────────────────────────────
    usecase "Write File\n<size:10>POST /write</size>" as UC01
    usecase "Read File\n<size:10>GET /read</size>" as UC02
    usecase "Read File via Token\n<size:10>GET /token-read</size>" as UC03

    ' ── Directory ops ─────────────────────────────────────────
    usecase "Make Directory\n<size:10>POST /mkdir</size>" as UC04
    usecase "List Directory\n<size:10>GET /readdir</size>" as UC08
    usecase "List Directory with Subdomains\n<size:10>GET /readdir-subdomains</size>" as UC09

    ' ── File management ───────────────────────────────────────
    usecase "Delete File or Folder\n<size:10>POST /delete</size>" as UC05
    usecase "Copy File or Folder\n<size:10>POST /copy</size>" as UC10
    usecase "Move File or Folder\n<size:10>POST /move</size>" as UC11
    usecase "Rename\n<size:10>POST /rename</size>" as UC12

    ' ── Metadata / info ───────────────────────────────────────
    usecase "Stat (Get File Info)\n<size:10>GET /stat</size>" as UC06
    usecase "Touch File\n<size:10>POST /touch</size>" as UC07
    usecase "Update File Metadata\n<size:10>POST /update</size>" as UC14
    usecase "Search Files\n<size:10>GET /search</size>" as UC13

    ' ── Utility ───────────────────────────────────────────────
    usecase "Check Disk Usage\n<size:10>GET /df</size>" as UC16
    usecase "Cache Operations\n<size:10>GET /cache</size>" as UC17

    ' ── Batch ─────────────────────────────────────────────────
    usecase "Batch Operations\n<size:10>POST /batch</size>" as UC15
}

' ── Client → Use Cases ────────────────────────────────────────
client --> UC01
client --> UC02
client --> UC03
client --> UC04
client --> UC05
client --> UC06
client --> UC07
client --> UC08
client --> UC09
client --> UC10
client --> UC11
client --> UC12
client --> UC13
client --> UC14
client --> UC16
client --> UC17

' ── System/Batch → Batch Operations ──────────────────────────
batch --> UC15

' ── Extend / Include relationships ───────────────────────────
UC02 <.. UC03 : <<extend>>
UC08 <.. UC09 : <<extend>>
UC15 ..> UC01 : <<include>>
UC15 ..> UC04 : <<include>>
UC15 ..> UC05 : <<include>>

' ── Binary storage (S3) interactions ─────────────────────────
UC01 --> s3 : upload
UC02 --> s3 : stream read
UC05 --> s3 : delete object
UC10 --> s3 : copy object

' ── Metadata storage (Database) interactions ─────────────────
UC01 --> db : insert / update entry
UC02 --> db : find by path / UID
UC04 --> db : insert dir entry
UC05 --> db : delete entry
UC06 --> db : find metadata
UC07 --> db : update timestamps
UC08 --> db : get descendants
UC10 --> db : insert new entry
UC11 --> db : update parent_uid
UC12 --> db : update name
UC13 --> db : search entries
UC14 --> db : update metadata fields
UC16 --> db : get recursive size

note bottom of UC15
  Executes Write File, Make Directory,
  and Delete File or Folder atomically
  in a single HTTP request
end note

note right of UC10
  Simple CopyObject for files < 4 GB
  Multipart UploadPartCopy for files ≥ 4 GB
end note

@enduml
