@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Localization and Internationalization

left to right direction

actor "User" as user
actor "App\n(SDK iframe)" as app_iframe

rectangle "Puter GUI (i18n/l10n Subsystem)" {

    usecase "Switch Language" as UC1
    usecase "Search Languages" as UC7
    usecase "Translate UI Text" as UC2
    usecase "Format Locale Duration" as UC3
    usecase "Persist Language Preference" as UC4
    usecase "Notify Apps of Locale Change" as UC5
    usecase "Receive Locale Change in App" as UC6
    usecase "Register Language Settings Tab" as UC8

}

' Primary actor associations
user --> UC1
user --> UC2
user --> UC3
user --> UC8

' App iframe associations
app_iframe --> UC6

' UC1: Switch Language includes Persist + Notify
UC1 ..> UC4 : <<include>>
UC1 ..> UC5 : <<include>>

' Search Languages extends Switch Language (optional filter step)
UC1 <.. UC7 : <<extend>>

' Notifying apps triggers the app-side receive
UC5 ..> UC6 : <<include>>

' Format Duration uses i18n translation
UC3 ..> UC2 : <<include>>

note bottom of UC4
  Persists via puter.kv (cloud)
  and localStorage (local)
end note

note right of UC5
  BroadcastService posts postMessage
  to all SDK-enabled iframes;
  saved for future app instances
end note

note bottom of UC2
  i18n module looks up
  translations[window.locale];
  falls back to 'en'
end note

@enduml
