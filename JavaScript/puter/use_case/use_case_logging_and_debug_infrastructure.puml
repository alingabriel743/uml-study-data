@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Logging and Debug Infrastructure

left to right direction

actor "Developer" as developer #D0E8FF

actor "ExecService" as execservice #D5F5E3
actor "Iframe Apps" as iframeapps #D5F5E3

rectangle "Logging and Debug Infrastructure" {

    package "Debug Service" {
        usecase "Enable Log Category" as UC1
        usecase "Toggle Category Off" as UC3
        usecase "Toggle Category On (Logger)" as UC2
        usecase "Expose Enabled Logs\nas Query Param" as UC8
        usecase "Propagate Log Toggle\nto Iframes" as UC9
    }

    package "Logger Pipeline" {
        usecase "Filter Log by Category" as UC4
        usecase "Prefix Log Message" as UC5
        usecase "Chain Logger with Fields" as UC10
        usecase "Output Log to Console" as UC6
        usecase "Aggregate Logs in Buffer" as UC7
    }
}

' Developer interactions
developer --> UC1 : calls DebugService.logs(category)
developer --> UC3 : calls logger.off(category)
developer --> UC10 : chains logger.fields(...)

' Enable Log Category includes downstream actions
UC1 ..> UC2 : <<include>>\ncalls puter.logger.on()
UC1 ..> UC9 : <<include>>\nbroadcasts to iframes

' Logging pipeline relationships
UC4 ..> UC6 : <<include>>\nif category enabled
UC4 <.. UC7 : <<extend>>\nbuffered (test mode)
UC5 ..> UC4 : <<include>>\nprepends prefix, delegates
UC10 ..> UC4 : <<include>>\nmerges fields, delegates

' Secondary actor connections
UC8 --> execservice : registers param provider\n(enabled_logs as query string)
UC9 --> iframeapps : postMessage\n{ cmd: 'log.on', category }

@enduml
