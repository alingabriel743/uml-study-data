@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}

title Networking and WISP Protocol

left to right direction

actor "Client Application" as client
actor "WISP Server" as wispServer
actor "Puter Platform" as puter
actor "Worker Service\nBackend" as workerBackend

rectangle "WISP Tunnel Manager\n(PWispHandler)" as wispSystem {
    usecase "Establish WISP Tunnel" as UC01
    usecase "Authenticate INFO\nHandshake" as UC02
    usecase "Register TCP Connection" as UC03
    usecase "Write Data to Stream" as UC04
    usecase "Handle Buffer\nFlow Control" as UC05
    usecase "Receive Stream Data" as UC06
    usecase "Close Stream Channel" as UC07
    usecase "Handle Remote\nStream Close" as UC08
}

rectangle "Worker Lifecycle Manager\n(WorkersHandler)" as workerSystem {
    usecase "Create Worker" as UC09
    usecase "Execute Worker" as UC10
    usecase "List Workers" as UC11
    usecase "Get Worker" as UC12
    usecase "Delete Worker" as UC13
    usecase "Stream Worker Logs" as UC14
}

rectangle "Service Registry & Lifecycle\n(ServiceManager)" as serviceSystem {
    usecase "Register Service" as UC15
    usecase "Initialize Service\nwith Dependencies" as UC16
    usecase "Retrieve Running Service" as UC17
}

' Client Application → WISP Tunnel Manager
client --> UC01
client --> UC03
client --> UC04
client --> UC07

' WISP Server → WISP Tunnel Manager
wispServer --> UC02
wispServer --> UC05
wispServer --> UC06
wispServer --> UC08

' Client Application → Worker Lifecycle Manager
client --> UC09
client --> UC10
client --> UC11
client --> UC12
client --> UC13
client --> UC14

' Puter Platform supports worker operations
puter --> UC09
puter --> UC10
puter --> UC13
puter --> UC14

' Worker Service Backend supports worker operations
workerBackend --> UC09
workerBackend --> UC11
workerBackend --> UC12
workerBackend --> UC13
workerBackend --> UC14

' Client Application → Service Registry
client --> UC15
client --> UC17

' ServiceManager internal dependency init
UC15 ..> UC16 : <<include>>
UC16 <.. UC17 : <<extend>>

@enduml
