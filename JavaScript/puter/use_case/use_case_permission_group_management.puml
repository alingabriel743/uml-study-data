@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FEFEFE
    BorderColor #6C757D
    FontColor #343A40
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Permission Group Management

left to right direction

' ─── Actors ───
actor "Authenticated\nUser" as auth
actor "Group\nOwner" as owner
actor "System\nAdmin" as admin

note right of owner
  Subset of Authenticated User
  who created (owns) the group
end note

' GroupOwner inherits from AuthenticatedUser
auth <|-- owner

' ─── System Boundary ───
rectangle "Permission Group Management System" {

    ' --- Group CRUD ---
    usecase "Create Permission Group\n<size:10>[POST /group/create]</size>" as UC1
    usecase "Add Users to Group\n<size:10>[POST /group/add-users]</size>" as UC2
    usecase "Remove Users from Group\n<size:10>[POST /group/remove-users]</size>" as UC3
    usecase "List Groups\n<size:10>[GET /group/list]</size>" as UC4
    usecase "Get Public Groups\n<size:10>[GET /group/public-groups]</size>" as UC5

    ' --- Permission Grant / Revoke ---
    usecase "Grant Permission to Group\n<size:10>[POST /auth/grant-user-group]</size>" as UC6
    usecase "Revoke Permission from Group\n<size:10>[POST /auth/revoke-user-group]</size>" as UC7

    ' --- ACL Query ---
    usecase "Check App ACL\n<size:10>[GET /auth/check-app-acl]</size>" as UC8

    ' --- Supporting / Shared Use Cases ---
    usecase "Verify Group Ownership" as VOWN
    usecase "Verify User Actor Type\n(UserActorType only)" as VUTYPE
    usecase "Enforce Group Creation\nRate Limit (20/hr)" as VRL
    usecase "Cache Public Groups\n(Redis, 60s TTL)" as VCACHE
}

' ─── Actor → Use Case Associations ───
auth --> UC1
auth --> UC4
auth --> UC5
auth --> UC6
auth --> UC7
auth --> UC8

owner --> UC2
owner --> UC3

admin --> UC5 : configures\npublic groups

' ─── Include / Extend Relationships ───
UC1 ..> VRL     : <<include>>
UC2 ..> VOWN    : <<include>>
UC3 ..> VOWN    : <<include>>
UC6 ..> VUTYPE  : <<include>>
UC7 ..> VUTYPE  : <<include>>
UC5 ..> VCACHE  : <<include>>
UC4 <.. VCACHE  : <<extend>>

@enduml
