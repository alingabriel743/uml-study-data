@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Server Info and Health

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────
actor "Admin" as Admin
actor "GUI User" as GUIUser
actor "OS / Node.js Runtime" as OS

' ── System Boundary ──────────────────────────────────────────────────────
rectangle "Server Info and Health System" {

    ' ── Server Info API (backend) ────────────────────────────────────────
    package "Server Info API\n(ServerInfoController)" {
        usecase "View Server Info\n[GET /serverInfo]" as UC1
        usecase "Retrieve OS Metadata\n(platform, type, release)" as UC2
        usecase "Retrieve CPU Information\n(model, core count)" as UC3
        usecase "Retrieve RAM Statistics\n(total / free GB)" as UC4
        usecase "Retrieve Disk Statistics\n(total / free / used GB)" as UC5
        usecase "Retrieve Uptime\n(days / hours / minutes)" as UC6
        usecase "Retrieve Load Average\n(1 / 5 / 15 min)" as UC7
    }

    ' ── GUI / Browser (frontend) ─────────────────────────────────────────
    package "GUI System\n(Browser)" {
        usecase "View System Info Window\n(UIWindowSystemInfo)" as UC8
        usecase "Enable Debug Logging\n(DebugService)" as UC9
    }

    ' ── Service Management ───────────────────────────────────────────────
    package "Service Management\n(ServiceManager)" {
        usecase "Register Service" as UC10
        usecase "Query Service Status" as UC11
        usecase "Await Service Initialization" as UC12
    }
}

' ── Actor → Use Case Relationships ──────────────────────────────────────
Admin    --> UC1  : requests (allowedUsernames only)
Admin    --> UC10
Admin    --> UC11
Admin    --> UC12

GUIUser  --> UC8
GUIUser  --> UC9

OS       --> UC2
OS       --> UC3
OS       --> UC4
OS       --> UC5
OS       --> UC6
OS       --> UC7

' ── Include Relationships (UC1 delegates to data retrieval) ──────────────
UC1 .> UC2  : <<include>>
UC1 .> UC3  : <<include>>
UC1 .> UC4  : <<include>>
UC1 .> UC5  : <<include>>
UC1 .> UC6  : <<include>>
UC1 .> UC7  : <<include>>

' ── Dependency / Extend Notes ─────────────────────────────────────────
note right of UC1
  Access-controlled:
  config.allowedUsernames guard
  Returns JSON: os, cpu, ram,
  uptime, disk, loadavg, hostname
end note

note right of UC5
  Uses fs.statfs('/');
  graceful fallback to N/A
  on unsupported platforms
end note

note right of UC9
  Broadcasts {cmd:'log.on'}
  to all iframes via postMessage
end note

note right of UC12
  Resolves when all
  dependent services reach
  "running" state
end note

@enduml
