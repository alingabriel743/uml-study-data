@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7ABD
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Service Lifecycle Management

left to right direction

actor "Caller /\nBoot System" as caller
actor "Service\nInstance" as svc_instance

rectangle "ServiceManager (IoC Container)" {
    usecase "Register Service\n<size:10>(register(name, factory, options))</size>" as UC1
    usecase "Resolve Dependencies &\nInitialize Service\n<size:10>(maybe_init_ / init_service_)</size>" as UC2
    usecase "Retrieve Running\nService (Sync)\n<size:10>(get(name))</size>" as UC3
    usecase "Async-Retrieve Service\n(Wait for Init)\n<size:10>(aget(name))</size>" as UC4
    usecase "Wait for Multiple\nServices\n<size:10>(wait_for_init(depends[]))</size>" as UC5
    usecase "Query Service\nInfo / Status\n<size:10>(info(name))</size>" as UC8
    usecase "Subscribe to Service\nEvents via HOOKS\n<size:10>(ServiceFeature.install_in_instance)</size>" as UC6
    usecase "Execute Launch\nCommands on Init\n<size:10>(LaunchOnInitService._init)</size>" as UC7
}

' Primary actor relationships
caller --> UC1
caller --> UC3
caller --> UC4
caller --> UC5
caller --> UC8

' Service Instance relationships
svc_instance --> UC6
svc_instance --> UC7

' Include relationships
UC1 ..> UC2 : <<include>>
UC4 ..> UC5 : <<include>>

' Extend relationships
UC6 <.. UC2 : <<extend>>\nduring init
UC1 <.. UC7 : <<extend>>\non boot

' Internal cascade note
note right of UC2
  <b>Status State Machine</b>
  Registering → Pending (deps unmet)
  Pending → Initializing (deps met)
  Initializing → Running (_init complete)
  Running → cascades to dependents
end note

note bottom of UC6
  HOOKS provide declarative
  cross-service event wiring
  via TTopics pub/sub trait
end note

@enduml
