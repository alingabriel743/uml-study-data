@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Theme and Settings Management

left to right direction

actor "User" as user
actor "System\n(Startup / Plugin)" as system
actor "App Instance\n(SDK iframe)" as appInstance
actor "FileSystem\n(puter.fs)" as filesystem

rectangle "Theme and Settings Management" {

    package "Theme Customization" {
        usecase "Apply Custom\nTheme Colors" as UC1
        usecase "Reset Theme\nto Defaults" as UC2
        usecase "Load Saved Theme\non Startup" as UC3
        usecase "Save Theme\nPreferences" as UC1a
        usecase "Delete Theme\nPreferences" as UC2a
    }

    package "Theme Broadcasting" {
        usecase "Broadcast Theme Change\nto Running Apps" as UC4
        usecase "Send Saved Broadcasts\nto Newly Launched App" as UC5
    }

    package "Settings Management" {
        usecase "Open Settings\nWindow" as UC6
        usecase "Register Settings\nTab" as UC7
        usecase "Format Duration\nfor Display" as UC8
    }

}

' --- User interactions ---
user --> UC1 : adjusts color picker\nin ThemeDialog
user --> UC2 : clicks Reset Colors
user --> UC6 : navigates to Settings

' --- System interactions ---
system --> UC3 : on application boot\n(ThemeService._init)
system --> UC7 : on startup\n(SettingsService._init)
system --> UC5 : on new app launch
system --> UC8 : render time-based UI values

' --- App Instance interactions ---
appInstance <-- UC4 : postMessage\n(themeChanged)
appInstance <-- UC5 : postMessage\n(saved broadcasts)

' --- FileSystem interactions ---
filesystem <-- UC1a : puter.fs.write\n(~/.__puter_gui.json)
filesystem <-- UC2a : puter.fs.delete\n(~/.__puter_gui.json)
filesystem --> UC3 : puter.fs.read\n(~/.__puter_gui.json)

' --- Include relationships ---
UC1 ..> UC4 : <<include>>
UC1 ..> UC1a : <<include>>
UC2 ..> UC4 : <<include>>
UC2 ..> UC2a : <<include>>

' --- Notes ---
note right of UC1
  ThemeService.apply() merges hue, sat,
  lig, alpha, light_text into state,
  sets CSS custom properties on :root,
  then debounces (1000ms) before save
end note

note right of UC7
  Tabs registered: Usage, Account,
  Security, Personalization, Language,
  KeyboardShortcuts, About
end note

@enduml
