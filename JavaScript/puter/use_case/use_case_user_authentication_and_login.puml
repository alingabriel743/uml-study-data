@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}

title User Authentication and Login

left to right direction

' ── External Actors ──────────────────────────────────────────────────────────
actor "Authenticated\nUser" as AuthUser
actor "API Client\n(Bearer / Access Token)" as APIClient
actor "OIDC Provider\n(e.g. Google)" as OIDCProvider
actor "System\n(AuthService / SessionService\n/ TokenService)" as System

' ── System Boundary ───────────────────────────────────────────────────────────
rectangle "Puter Authentication System" {

    ' Token-based authentication
    usecase "Authenticate via Token\n(session / app-under-user /\naccess-token)" as UC01
    usecase "Validate Session Token\n(JWT decode → session lookup\n→ user fetch)" as UC02

    ' CSRF protection
    usecase "Request CSRF Token\n(Frontend GUI)" as UC05
    usecase "Get CSRF Token\nGET /get-anticsrf-token" as UC03
    usecase "Consume / Validate\nCSRF Token" as UC04

    ' User-protected endpoint access
    usecase "Access User-Protected\nEndpoint\nPOST /user-protected/{action}" as UC06
    usecase "Revalidate Identity\nvia OIDC Provider" as UC12

    ' Protected sub-operations
    usecase "Change Password" as UC07
    usecase "Change Email" as UC08
    usecase "Change Username" as UC09
    usecase "Disable 2FA" as UC10
    usecase "Delete Own Account" as UC11

    ' Error handling
    usecase "Handle Auth\nError Response" as UC13
}

' ── Actor → Use Case associations ─────────────────────────────────────────────
AuthUser  --> UC01
APIClient --> UC01

AuthUser  --> UC05
AuthUser  --> UC06

AuthUser  --> UC07
AuthUser  --> UC08
AuthUser  --> UC09
AuthUser  --> UC10
AuthUser  --> UC11

AuthUser    --> UC12
OIDCProvider --> UC12

System --> UC02
System --> UC04
System --> UC13

' ── Include relationships ──────────────────────────────────────────────────────
UC01 ..> UC02 : <<include>>
UC03 ..> UC01 : <<include>>
UC04 ..> UC03 : <<include>>
UC05 ..> UC03 : <<include>>
UC06 ..> UC01 : <<include>>
UC06 ..> UC12 : <<include>>

' ── Extend relationships ───────────────────────────────────────────────────────
UC07 ..> UC06 : <<extend>>
UC08 ..> UC06 : <<extend>>
UC09 ..> UC06 : <<extend>>
UC10 ..> UC06 : <<extend>>
UC11 ..> UC06 : <<extend>>

' ── Notes ─────────────────────────────────────────────────────────────────────
note right of UC01
  Token extracted in order:
  1. body.auth_token
  2. Authorization: Bearer
  3. HttpOnly cookie
  Errors: 401 (missing/expired/invalid),
  403 (suspended)
end note

note right of UC03
  Requires authenticated session.
  Blocked on api. subdomain.
  Stores last 10 tokens per session
  via CircularQueue (oldest evicted).
end note

note right of UC06
  Full middleware chain:
  - Edge rate-limit (429)
  - configurable_auth (no cache)
  - HttpOnly cookie required (403)
  - Temp-account blocked (403)
  - bcrypt or OIDC revalidation
end note

note bottom of UC12
  OIDC-only accounts (no password):
  Redirects to /auth/oidc/{provider}/start
  Sets puter_revalidation JWT cookie
end note

@enduml
