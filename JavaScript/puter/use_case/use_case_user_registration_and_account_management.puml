@startuml use_case_user_registration_and_account_management

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title User Registration and Account Management

left to right direction

' ── Actors ──────────────────────────────────────────────
actor "Guest" as Guest
actor "Temporary User" as TempUser
actor "Registered User" as RegUser

actor "Email Service" as EmailSvc #D5F5E3
actor "OIDC Provider" as OIDCProvider #FFF3CD
actor "Rate Limit Service" as RateLimitSvc #FCE4D6

' ── System Boundary ──────────────────────────────────────
rectangle "User Registration & Account Management" {

    ' ── Registration ────────────────────────────────────
    package "Registration" {
        usecase "Sign Up\n(POST /signup)" as UC1
        usecase "Save Account\n(Upgrade Temp User)\n(POST /save_account)" as UC2
        usecase "Confirm Email\n(/confirmEmail)" as UC8
        usecase "Send Email Confirmation\n(/sendConfirmEmail)" as UC9
    }

    ' ── Password Recovery ───────────────────────────────
    package "Password Recovery" {
        usecase "Send Password\nRecovery Email" as UC10a
        usecase "Verify Recovery\nToken" as UC10b
        usecase "Set New Password\nUsing Token" as UC10c
    }

    ' ── Account Modification (Protected) ────────────────
    package "Account Modification\n(/user-protected)" {
        usecase "Change Password\n(POST /change-password)" as UC3
        usecase "Change Email\n(POST /change-email)" as UC4
        usecase "Change Username\n(POST /change-username)" as UC5
        usecase "Configure 2FA\n(/configure-2fa)" as UC11
        usecase "Disable 2FA\n(POST /disable-2fa)" as UC6
        usecase "Delete Own Account\n(POST /delete-own-user)" as UC7
    }

    ' ── Supporting Use Cases ─────────────────────────────
    package "Security & Auth" {
        usecase "Revalidate Identity\n(Password / OIDC)" as UC_REVAL
        usecase "Check Rate Limit" as UC_RATE
        usecase "Invalidate Session" as UC_SESSION
    }
}

' ── Actor → Use Case Associations ────────────────────────

' Guest
Guest --> UC1
Guest --> UC10a
Guest --> UC10b
Guest --> UC10c

' Temporary User
TempUser --> UC2
TempUser --> UC7

' Registered User
RegUser --> UC3
RegUser --> UC4
RegUser --> UC5
RegUser --> UC6
RegUser --> UC7
RegUser --> UC8
RegUser --> UC9
RegUser --> UC11

' External services
EmailSvc --> UC8   : delivers verification link
UC1      --> EmailSvc : <<include>> send verification
UC2      --> EmailSvc : <<include>> send verification
UC3      --> EmailSvc : <<include>> password change notification
UC4      --> EmailSvc : <<include>> email change notifications
UC6      --> EmailSvc : <<include>> 2FA disabled notification

OIDCProvider --> UC_REVAL : provides revalidation token

RateLimitSvc --> UC1      : enforces signup rate limit
RateLimitSvc --> UC5      : enforces username change limit
RateLimitSvc --> UC_RATE  : edge rate limit

' ── Include / Extend Relationships ───────────────────────

' All /user-protected use cases include identity revalidation
UC3  ..> UC_REVAL     : <<include>>
UC4  ..> UC_REVAL     : <<include>>
UC5  ..> UC_REVAL     : <<include>>
UC6  ..> UC_REVAL     : <<include>>
UC_REVAL <.. UC7      : <<extend>>\nnote: waived for temp users

' All /user-protected use cases include rate limit check
UC3  ..> UC_RATE      : <<include>>
UC4  ..> UC_RATE      : <<include>>
UC5  ..> UC_RATE      : <<include>>
UC6  ..> UC_RATE      : <<include>>
UC7  ..> UC_RATE      : <<include>>

' Password change also invalidates all sessions
UC3  ..> UC_SESSION   : <<include>>

' Password recovery flow is sequential
UC10a ..> UC10b : <<include>>
UC10b ..> UC10c : <<include>>

' Sign Up can be followed by email confirmation
UC8 <.. UC1          : <<extend>>
UC8 <.. UC2          : <<extend>>

@enduml
