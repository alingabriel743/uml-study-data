@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Worker Management

left to right direction

' ─── Actors ───────────────────────────────────────────────
actor "Authenticated User\n(puter.js SDK)" as AuthUser
actor "Puter App\n(App Context)" as PuterApp
actor "File System\n(fs.write.file)" as FileSystem
actor "Cloudflare Workers\n(Compute Platform)" as CF
actor "Service Manager\n(putility)" as SvcMgr

' ─── System Boundary ──────────────────────────────────────
rectangle "Worker Management System" {

    ' Core lifecycle
    usecase "Create Worker" as UC1
    usecase "Execute Worker" as UC2
    usecase "List Workers" as UC3
    usecase "Get Worker Info" as UC4
    usecase "Delete Worker" as UC5

    ' Observability & automation
    usecase "Stream Worker Logs" as UC6
    usecase "Auto-Redeploy Worker\non File Change" as UC7

    ' Infrastructure
    usecase "Register & Initialize\nWorkerService" as UC8

    ' Sub-steps surfaced as included use cases
    usecase "Authenticate User\n(puter.ui.authenticateWithPuter)" as UC_AUTH
    usecase "Validate Worker Name\n& Check Limits" as UC_VALIDATE
    usecase "Resolve / Create\nSandbox App" as UC_SANDBOX
    usecase "Read Worker Script\nfrom Puter FS (≤10 MB)" as UC_FSREAD
    usecase "Register Subdomain\n(workers.puter.*)" as UC_SUBDOMAIN
    usecase "Deploy to Cloudflare\n(createWorker API)" as UC_CF_DEPLOY
    usecase "Remove from Cloudflare\n(deleteWorker API)" as UC_CF_DELETE
    usecase "Notify User of\nDeploy Result" as UC_NOTIFY
}

' ─── AuthenticatedUser associations ──────────────────────
AuthUser --> UC1
AuthUser --> UC2
AuthUser --> UC3
AuthUser --> UC4
AuthUser --> UC5
AuthUser --> UC6

' ─── PuterApp association ─────────────────────────────────
PuterApp --> UC1 : provides appName\n(optional)

' ─── FileSystem trigger ───────────────────────────────────
FileSystem --> UC7

' ─── Cloudflare external boundary ────────────────────────
UC_CF_DEPLOY --> CF
UC_CF_DELETE --> CF

' ─── ServiceManager ──────────────────────────────────────
SvcMgr --> UC8

' ─── <<include>> relationships ────────────────────────────
UC1 ..> UC_AUTH       : <<include>>
UC1 ..> UC_VALIDATE   : <<include>>
UC1 ..> UC_SANDBOX    : <<include>>
UC1 ..> UC_FSREAD     : <<include>>
UC1 ..> UC_SUBDOMAIN  : <<include>>
UC1 ..> UC_CF_DEPLOY  : <<include>>

UC2 ..> UC_AUTH       : <<include>>

UC3 ..> UC_AUTH       : <<include>>

UC4 ..> UC_AUTH       : <<include>>

UC5 ..> UC_AUTH       : <<include>>
UC5 ..> UC_CF_DELETE  : <<include>>

UC7 ..> UC_FSREAD     : <<include>>
UC7 ..> UC_CF_DEPLOY  : <<include>>
UC7 ..> UC_NOTIFY     : <<include>>

' ─── <<extend>> relationships ─────────────────────────────
UC2 <.. UC6 : <<extend>>\n(observability)

@enduml
