@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
    StartColor #212529
    EndColor #212529
    BarColor #495057
}

skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Datadog PHP Extension Uninstall\n<size:11>(datadog-setup.php — uninstall flow)</size>

|#E8F4F8|Script Entry (main)|
start
:Script invoked via CLI;
if (DD_TEST_EXECUTION env var truthy?) then (yes)
    #FFE0B2:Exit early\n<i>test mode — no-op</i>;
    stop
else (no)
endif

|#EAF4EA|CLI Parser (parse_validate_user_options)|
:parse_cli_arguments($argv)\n— strip script name, tokenise long/short flags\n— map DD_ env-vars to INI keys via map_env_to_ini();
if (Parse failed OR --help flag?) then (yes)
    :print_help();
    #C8E6C9:Exit 0\n<i>help printed</i>;
    stop
else (no)
endif
:Normalise options:\nOPT_UNINSTALL · OPT_PHP_BIN · OPT_PHP_INI\nOPT_INSTALL_DIR · OPT_EXTENSION_DIR\nOPT_ENABLE_APPSEC · OPT_ENABLE_PROFILING · OPT_INI_SETTING;
if (--php-bin provided with no value?) then (yes)
    #FFCDD2:print_error_and_exit()\n+ print_help()\n<i>exit(1)</i>;
    stop
else (no)
endif

|Script Entry (main)|
if (OPT_UNINSTALL flag set?) then (yes)
    :Call uninstall($options);
else (no)
    :Call install($options)\n<i>(out of scope)</i>;
    stop
endif

|#F3E5F5|Binary Resolver (require_binaries_or_exit)|
if (OPT_PHP_BIN empty?) then (yes)
    :pick_binaries_interactive()\n<i>reads STDIN; recursive on bad input</i>;
elseif (OPT_PHP_BIN = 'all'?) then (yes)
    :search_php_binaries()\n— enumerate standard PATH locations\n— filter out shebang scripts;
else (no)
    :For each --php-bin value:\nresolve_command_full_path();
    if (Binary not found on PATH?) then (yes)
        #FFCDD2:print_error_and_exit()\n<i>exit(1)</i>;
        stop
    else (no)
    endif
endif
if (Resolved binary list is empty?) then (yes)
    #FFCDD2:print_error_and_exit(\n'At least one binary must be specified')\n<i>exit(1)</i>;
    stop
else (no)
endif

|#FFF8E1|Uninstall Engine (uninstall — per-binary loop)|
:FOR EACH resolved PHP binary;
split
    :ini_values($binary)\n— runs 'php -i'\n— extracts: EXTENSION_DIR, INI_SCANDIR, INI_MAIN;
split again
    :Determine extensionDir:\nuse OPT_EXTENSION_DIR if set,\nelse PHP's EXTENSION_DIR;
    :Build extensionDestinations list:\n• ddtrace<suffix>.so\n• datadog-profiling<suffix>.so\n• ddappsec<suffix>.so;
end split

if (INI_SCANDIR present?) then (yes)
    :Primary INI path =\nINI_SCANDIR/98-ddtrace.ini;
    if (Path contains '/cli/conf.d'?\n<i>(Debian multi-SAPI)</i>) then (yes)
        :Also add paths if dirs exist:\n• apache2/conf.d/98-ddtrace.ini\n• fpm/conf.d/98-ddtrace.ini;
    else (no)
    endif
elseif (INI_MAIN absent AND INI_SCANDIR absent?) then (yes)
    #FFCDD2:print_error_and_exit(\n'no scan directory and no\nconfiguration file loaded')\n<i>exit(1)</i>;
    stop
else (INI_MAIN present)
    :iniFilePaths = [INI_MAIN];
endif

note right
  INI files are **never deleted** —\nonly extension= lines are\ncommented out, preserving\ncustom settings.
end note

:FOR EACH iniFilePath;
if (Path is a symlink?) then (yes)
    :Resolve real path via readlink();
else (no)
endif
if (INI file exists?) then (yes)
    if (Filename is 98-ddtrace.ini?) then (yes)
        :modify_ini_file()\n— regex comment ALL\n(zend_)?extension= lines;
    else (no)
        :modify_ini_file()\n— regex comment only lines matching:\nddtrace | datadog-profiling | ddappsec;
    endif
    :Echo: "Disabled all [Datadog]\nmodules in INI file ...";
else (no)
endif

:FOR EACH extensionDestination\n(ddtrace.so, datadog-profiling.so, ddappsec.so);
if (.so file exists AND unlink() fails?) then (yes)
    :print_warning()\n<i>non-fatal; does NOT exit</i>;
    :Set \$errors = true;
else (no)
endif

|Script Entry (main)|
if (\$errors flag set?) then (yes)
    #FFE0B2:Echo: "Uninstall completed\nwith warnings"\n<i>exit(0)</i>;
else (no)
    #C8E6C9:Echo: "Uninstall successful"\n<i>exit(0)</i>;
endif

stop

@enduml
