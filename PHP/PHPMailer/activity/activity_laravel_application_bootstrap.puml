@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}

title Laravel Application Bootstrap & Service Registration\n<size:11><i>Datadog PHP Tracing SDK — Laravel Test Fixtures (v10.x / v11.x)</i></size>

|Laravel Kernel|
start

:HTTP Request or Artisan Command received;

note right
  Datadog PHP tracing SDK instruments
  this bootstrap sequence via hooks/
  extensions to trace provider
  registration timing.
end note

' ─── PHASE 1: Load Provider List ───
partition "**PHASE 1** — Load Provider List" {
    if (Laravel Version?) then (10.x / below)
        :Read **config/app.php** 'providers' array;
        :Resolve provider list:\n  AppServiceProvider\n  AuthServiceProvider\n  BroadcastServiceProvider*\n  EventServiceProvider\n  RouteServiceProvider;
        note right
          * BroadcastServiceProvider is
          **commented out** by default
          in config/app.php (10.x)
        end note
    else (11.x)
        :Read **bootstrap/providers.php**;
        :Resolve provider list:\n  AppServiceProvider only\n  (Auth/Broadcast/Event\n  merged into framework core);
    endif
}

' ─── PHASE 2: Instantiate Providers ───
partition "**PHASE 2** — Instantiate Providers" {
    :Kernel instantiates each ServiceProvider\nwith the IoC Container (app instance);
    fork
        :new AppServiceProvider($app);
    fork again
        :new AuthServiceProvider($app);
    fork again
        :new BroadcastServiceProvider($app);
    fork again
        :new EventServiceProvider($app);
    end fork
}

' ─── PHASE 3: Register Pass ───
|Laravel Kernel|
partition "**PHASE 3** — register() Pass\n<size:10>Bind services into IoC Container before any boot()</size>" {
    |AppServiceProvider|
    :AppServiceProvider::register()\n<size:10>→ no-op (empty, no IoC bindings in test fixture)</size>;

    |AuthServiceProvider|
    :AuthServiceProvider::register()\n<size:10>→ inherited; auto-registers policies from $policies[]</size>;
    note right
      $policies = [] (empty in test fixture)
      Gate::define() calls would be
      added here for authorization rules
    end note

    |BroadcastServiceProvider|
    :BroadcastServiceProvider\n<size:10>→ no register() override</size>;

    |EventServiceProvider|
    :EventServiceProvider::register()\n<size:10>→ inherited; auto-registers $listen[] event-listener mappings</size>;
    note right
      $listen = [
        Registered::class =>
          [SendEmailVerificationNotification::class]
      ]
    end note
}

' ─── PHASE 4: Boot Pass ───
|Laravel Kernel|
partition "**PHASE 4** — boot() Pass\n<size:10>Executed in registration order, after all register() complete</size>" {

    |AppServiceProvider|
    :AppServiceProvider::boot();
    if (Laravel 10.x?) then (yes)
        :Schema::defaultStringLength(191);
        note right
          Sets DB varchar default to 191
          for **utf8mb4** compatibility
        end note
    else (11.x)
        :no-op (empty boot in 11.x);
    endif

    |AuthServiceProvider|
    :AuthServiceProvider::boot();
    :no-op\n<size:10>(empty boot; no Gate::define() calls in test fixture)</size>;

    |BroadcastServiceProvider|
    if (BroadcastServiceProvider enabled?\n<size:10>i.e. uncommented in config/app.php</size>) then (yes)
        :BroadcastServiceProvider::boot();
        :Broadcast::routes();
        :require base_path('routes/channels.php');
        note right
          Registers broadcasting
          channel authentication routes
        end note
    else (no — disabled by default)
        :Skip BroadcastServiceProvider boot;
    endif

    |EventServiceProvider|
    :EventServiceProvider::boot();
    :no-op (empty boot override);

    :shouldDiscoverEvents() → returns **false**;
    if (shouldDiscoverEvents() == true?) then (yes)
        :Auto-discover event listeners\nin Listeners/ directory;
    else (no — discovery disabled)
        :Use only manually declared\n$listen[] mappings;
        :Register:\nRegistered → SendEmailVerificationNotification;
    endif
}

|Laravel Kernel|
:All providers registered and booted\nApplication ready to handle requests;

note right
  Datadog tracer captures timing
  spans for each provider's
  register() and boot() lifecycle.
end note

stop

@enduml
