@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
    StartColor #212529
    EndColor #212529
}

skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

skinparam noteBackgroundColor #FFF3CD
skinparam noteBorderColor #FFC107

title Laravel Route Registration & Request Dispatch\n<size:11><color:#6C757D>Laravel 5.7 — Datadog PHP Tracing Test Fixture</color></size>

|Laravel Service Container|
start
:Application boots\n(public/index.php);

note right
  Laravel 5.7 overhead
  test fixture for Datadog
  PHP tracing benchmarks
end note

:Service Container resolves\nand boots all Service Providers;

|RouteServiceProvider|
:RouteServiceProvider::boot() called;
:Calls parent::boot()\n[Illuminate\\Foundation\\Support\\Providers\\\nRouteServiceProvider];
:parent::boot() triggers map();

fork
  :mapApiRoutes();
  note right
    Route::prefix('api')
    ->middleware('api')
    ->namespace('App\\Http\\Controllers')
    ->group('routes/api.php')
  end note
  if (routes/api.php\nhas routes?) then (no — file is empty)
    :No API routes registered\n(branch terminates);
  else (yes)
    :Register API routes;
  endif

fork again
  :mapWebRoutes();
  note right
    Route::middleware('web')
    ->namespace('App\\Http\\Controllers')
    ->group('routes/web.php')
  end note
  :Load routes/web.php;
  :Register route:\nGET '/' → ExampleController@example\n(named 'example_route');
  note right
    'web' middleware group provides:
    session state, CSRF protection,
    cookies
  end note

end fork

:Route registration complete\n— application ready to handle requests;

|Laravel HTTP Kernel / Router|
:HTTP Request arrives\nat Laravel HTTP Kernel;

:Run global middleware pipeline;

if (Incoming URI matches\na registered route?) then (yes — URI: '/')
  :Route '/' matched\n(named: 'example_route')\nvia 'web' middleware group;
  :Dispatch to\nExampleController@example;

  |ExampleController|
  :ExampleController::example() executes;
  :error_log(\n  'This is the example action'\n);
  :Return string:\n"Hi from Laravel 5.7 app!\\n";

  |Laravel HTTP Kernel / Router|
  :Laravel wraps return value\nas HTTP Response (200 OK);

else (no match)
  :Return 404 Not Found Response\n(implicit Laravel default);
endif

:HTTP Response sent to client;

stop

@enduml
