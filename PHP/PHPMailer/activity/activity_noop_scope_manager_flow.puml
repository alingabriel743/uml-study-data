@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}

title No-Op Scope Manager Flow\n<size:11><i>DDTrace — Disabled / No-Op Tracing Path</i></size>

|Caller / NoopTracer|
start
note right
  **No-op path is active when:**
  DDTrace is disabled, or
  NoopTracer::limited() returns true
end note
:NoopTracer detects tracing is disabled;
:Call NoopScopeManager::create()\n→ returns new NoopScopeManager instance;

|NoopScopeManager|
note right
  **Ported from opentracing/opentracing-php**
  reference implementation.
  Not a singleton — a fresh instance each time.
end note
:NoopScopeManager instance created\n(implements DDTrace\\Contracts\\ScopeManager);

|Caller / NoopTracer|
:Caller invokes ScopeManager operation;

switch (Which ScopeManager operation?)

case (activate(SpanInterface $span,\n$finishSpanOnClose = DEFAULT_FINISH_SPAN_ON_CLOSE))
    |NoopScopeManager|
    note right
      **DEFAULT_FINISH_SPAN_ON_CLOSE = true**
      is defined on the interface but has
      no effect in the no-op implementation.
      $span argument is silently ignored.
    end note
    :activate() called — span & flag are ignored;
    :Delegate to NoopScope::create();

    |NoopScope|
    :NoopScope::create()\n→ returns new NoopScope instance\n(implements DDTrace\\Contracts\\Scope);

    |Caller / NoopTracer|
    :Receive NoopScope stub (no-op);

case (getActive())
    |NoopScopeManager|
    note right
      Always returns a fresh NoopScope —
      never returns null, unlike real ScopeManager.
    end note
    :getActive() called;
    :Delegate to NoopScope::create();

    |NoopScope|
    :NoopScope::create()\n→ returns new NoopScope instance\n(no stored state);

    |Caller / NoopTracer|
    :Receive NoopScope stub (no-op);

case (close())
    |NoopScopeManager|
    :close() called — empty method body;
    note right
      Pure no-op. Returns void.
      No state to clean up.
    end note

    |Caller / NoopTracer|
    :Operation completes (void, no-op);

endswitch

|Caller / NoopTracer|
if (Caller uses the returned NoopScope?) then (yes)

    switch (Which Scope operation?)

    case (NoopScope::close())
        |NoopScope|
        :close() called — empty method body;
        note right
          Pure no-op. Returns void.
        end note
        |Caller / NoopTracer|
        :Scope closed (void, no-op);

    case (NoopScope::getSpan())
        |NoopScope|
        :getSpan() called;
        :Delegate to NoopSpan::create();

        |NoopSpan|
        :NoopSpan::create()\n→ returns new NoopSpan instance\n(no stored state);

        |Caller / NoopTracer|
        :Receive NoopSpan stub (no-op);
        note right
          NoopSpan is a no-op stub.
          All span operations on it
          are silent no-ops.
        end note

    endswitch

else (no)
endif

|Caller / NoopTracer|
:Flow complete — no tracing data recorded;
stop

@enduml
