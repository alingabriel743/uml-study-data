@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}
skinparam note {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
    FontColor #0C5460
}

title WordPress Customizer Manager Setup\n<size:11><i>WP_Customize_Manager: Initialization, Changeset Establishment, Preview Lifecycle</i></size>

|#E8F4F8|WordPress Hook System|
|#F0F8E8|WP_Customize_Manager|
|#FFF8E8|Security & Auth|
|#F8E8F8|Theme System|

|WP_Customize_Manager|
start

:new WP_Customize_Manager($args);
note right
  Args: changeset_uuid, theme,
  messenger_channel, settings_previewed,
  autosaved, branching
end note

' ── Resolve constructor arguments ──────────────────────────────────
if (changeset_uuid in $args?) then (yes)
    :Use provided changeset_uuid;
else (no)
    :Generate UUID via\nwp_generate_uuid4();
endif

if (theme in $args?) then (yes)
    :Use provided theme slug;
else (no)
    :Read theme from\n$_REQUEST['customize_theme']\nor $_REQUEST['theme'];
endif

if (messenger_channel in $args?) then (yes)
    :Use provided messenger_channel;
else (no)
    :Read from\n$_REQUEST['customize_messenger_channel'];
endif

' ── Load components ────────────────────────────────────────────────
:Load component class files\n(setting, panel, section, control\nand all specializations);

:Apply filter 'customize_loaded_components'\nto determine active components;

note right
  Changeset = a Custom Post Type (CPT)
  storing pending customization data
  with post_name = UUID
end note

:Instantiate WP_Customize_Selective_Refresh;

if ('widgets' in active components?) then (yes)
    :Instantiate WP_Customize_Widgets;
endif

if ('nav_menus' in active components?) then (yes)
    :Instantiate WP_Customize_Nav_Menus;
endif

' ── Register hooks and AJAX handlers ───────────────────────────────
:Register action hooks:\nsetup_theme → setup_theme()\nwp_loaded → wp_loaded();

:Remove cron and\nupdate-check actions;

:Register AJAX handlers:\ncustomize_save, customize_trash,\ncustomize_refresh_nonces,\ncustomize_load_themes, etc.;

:Register customize_register →\nregister_controls() &\nregister_dynamic_settings();

' ══════════════════════════════════════════════════════════════════
' setup_theme() fires on 'setup_theme' action
' ══════════════════════════════════════════════════════════════════
|WordPress Hook System|
:Fire WordPress 'setup_theme' action;

|WP_Customize_Manager|
:setup_theme() invoked;

' ── Permission check ──────────────────────────────────────────────
|Security & Auth|
if (pagenow == 'customize.php'\nAND user cannot 'customize'?) then (yes)
    :auth_redirect() or\nwp_die(403 Forbidden);
    stop
else (no)
endif

' ── UUID validation ───────────────────────────────────────────────
if (changeset_uuid set but\ninvalid UUID format?) then (yes)
    :wp_die(-1, 'Invalid changeset UUID');
    stop
else (no)
endif

' ── CSRF nonce check ──────────────────────────────────────────────
:Check CSRF nonce\n(preview-customize_, save-customize_,\ncustomize_preview_nonce);

if (Nonce valid?) then (yes)
else (no)
    :Clear POST/REQUEST\ncustomized data;
    note right
      Strips pending changes but
      does not abort the request
    end note
endif

if (User cannot 'customize'\nAND no changeset_post_id?) then (yes)
    if (messenger_channel set?) then (yes)
        :wp_die(0) — messenger mode;
    else (no)
        :wp_die(-1);
    endif
    stop
else (no)
endif

' ── Theme path decision ───────────────────────────────────────────
|WP_Customize_Manager|
:Read branching flag\nvia branching() getter;
note right
  branching() applies filter
  'customize_changeset_branching'
  (default: false = linear mode)
end note

|Theme System|
if (is_theme_active()?) then (yes)
    :Register after_setup_theme hook\n→ after_setup_theme();
else (no)
    |Security & Auth|
    if (User has 'switch_themes' cap?) then (no)
        :wp_die('Insufficient capabilities');
        stop
    else (yes)
    endif

    |Theme System|
    if (Theme has errors?) then (yes)
        :wp_die('Theme has errors');
        stop
    else (no)
    endif

    if (Multisite: theme allowed\nfor this site?) then (no)
        :wp_die('Theme not allowed');
        stop
    else (yes)
    endif
endif

' ── Fresh site starter content ────────────────────────────────────
|WP_Customize_Manager|
if (fresh_site flag set\nAND pagenow == customize.php?) then (yes)
    :Schedule import_theme_starter_content()\nat after_setup_theme priority 100;
    note right
      Imports starter content on
      first Customizer load for new sites
    end note
endif

:Register after_setup_theme:5\n→ establish_loaded_changeset();

' ══════════════════════════════════════════════════════════════════
' establish_loaded_changeset() fires on after_setup_theme:5
' ══════════════════════════════════════════════════════════════════
|WordPress Hook System|
:Fire 'after_setup_theme' action\n(priority 5);

|WP_Customize_Manager|
:establish_loaded_changeset() invoked;

if (_changeset_uuid already set?) then (yes)
    :Skip UUID resolution\n(use existing UUID);
else (no)
    if (branching() == false\nAND is_theme_active()?) then (yes)
        :Query most recent unpublished\nchangeset post via get_changeset_posts()\n(exclude auto-draft, publish, trash,\ninherit, private statuses);

        if (Valid existing changeset found?) then (yes)
            :Reuse existing changeset UUID;
            note right
                Branching=false (default) means
                all users share one draft changeset
            end note
        else (no)
            :Generate new UUID via\nwp_generate_uuid4();
        endif
    else (branching=true)
        :Always generate new UUID\n(independent session changeset);
        note right
            Branching=true gives each
            user/session an independent changeset
        end note
    endif
endif

if (is_admin()\nAND pagenow == customize.php?) then (yes)
    :set_changeset_lock(changeset_post_id())\nto prevent concurrent edits;
endif

' ══════════════════════════════════════════════════════════════════
' after_setup_theme() — active theme validation
' ══════════════════════════════════════════════════════════════════
|WordPress Hook System|
:Fire 'after_setup_theme' action\n(default priority);

|WP_Customize_Manager|
:after_setup_theme() invoked\n(active theme path only);

if (NOT doing AJAX\nAND no customized POST data\nAND validate_current_theme() fails?) then (yes)
    |Theme System|
    :wp_redirect('themes.php?broken=true');
    :exit();
    stop
else (no)
endif

' ══════════════════════════════════════════════════════════════════
' start_previewing_theme() — called at end of setup_theme()
' ══════════════════════════════════════════════════════════════════
|WP_Customize_Manager|
:start_previewing_theme() called\n(terminal call of setup_theme());

if (is_preview() already true?) then (yes)
    :Bail — no-op\n(already previewing);
else (no)
    :Set $this->previewing = true;

    |Theme System|
    if (Theme is NOT currently active?) then (yes)
        :Add filters: template, stylesheet,\npre_option_current_theme,\npre_option_stylesheet,\npre_option_template,\npre_option_stylesheet_root,\npre_option_template_root;
    else (no — active theme)
        :No additional theme filters needed;
    endif

    |WordPress Hook System|
    :Fire action 'start_previewing_theme'\ndo_action('start_previewing_theme', $this);
endif

' ══════════════════════════════════════════════════════════════════
' Settings preview check
' ══════════════════════════════════════════════════════════════════
|WP_Customize_Manager|
:settings_previewed() getter called\nduring preview lifecycle;
note right
  Returns $this->settings_previewed (bool)
  If true: WP_Customize_Setting::preview()
  is applied to show pending values
  in the preview iframe (default: true)
end note

fork
    ' autosaved() path
    :autosaved() getter called;
    note right
      Returns bool — if true, loads from
      autosave revision of changeset post
      rather than published post content
    end note
fork again
    ' branching() path
    :branching() getter called;
    :Apply filter 'customize_changeset_branching'\nand return result;
end fork

' ══════════════════════════════════════════════════════════════════
' Preview active — eventual stop
' ══════════════════════════════════════════════════════════════════
:Theme preview active;
:Customizer UI operational;

note right
  Changeset data stored as CPT post
  (post_name = UUID)
  - Pending settings not yet published
  - Register/save operations via AJAX
end note

' ── Stop preview ──────────────────────────────────────────────────
:stop_previewing_theme() called\n(externally, to end preview session);

if (is_preview() == false?) then (yes)
    :Bail — no-op\n(not currently previewing);
else (no)
    :Set $this->previewing = false;

    |Theme System|
    if (Theme was NOT active?) then (yes)
        :Remove all template/stylesheet\nfilters added by start_previewing_theme();
    endif

    |WordPress Hook System|
    :Fire action 'stop_previewing_theme'\ndo_action('stop_previewing_theme', $this);
endif

|WP_Customize_Manager|
:Customizer session complete;

stop

@enduml
