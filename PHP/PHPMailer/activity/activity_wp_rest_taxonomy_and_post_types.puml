@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleFontColor #212529
    TitleBackgroundColor #E9ECEF
}
skinparam note {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
    FontColor #0C5460
}

title WordPress REST Taxonomy & Post Type Discovery\n(wp/v2 — WP_REST_Post_Types_Controller & WP_REST_Taxonomies_Controller)

|REST Client|
|WP_REST_Post_Types_Controller|
|WP_REST_Taxonomies_Controller|
|WordPress Core|

' ══════════════════════════════════════════════════════
'  SECTION 1 — POST TYPES: Collection (GET /wp/v2/types)
' ══════════════════════════════════════════════════════

|REST Client|
start
:Send **GET /wp/v2/types**\nor **GET /wp/v2/types/{type}**\nor **GET /wp/v2/taxonomies**\nor **GET /wp/v2/taxonomies/{taxonomy}**;

note right
  Namespace: wp/v2
  Since WordPress 4.7.0
  show_in_rest flag must be
  truthy on all registered types
end note

' ─── POST TYPES: List ───────────────────────────────
|WP_REST_Post_Types_Controller|
:Route dispatched to\n**get_items_permissions_check()**;

|WordPress Core|
if (context == 'edit'?) then (yes)
  :get_post_types(show_in_rest=true);
  :Iterate all REST-visible post types;
  if (current_user_can(edit_posts)\nfor any post type?) then (yes)
    :Permission GRANTED;
  else (no)
    #FFB3B3:Return **WP_Error**\n'rest_cannot_view' (403);
    stop
  endif
else (no — view/embed)
  :Return true immediately\n(no auth required);
endif

|WP_REST_Post_Types_Controller|
:**get_items()** — fetch collection;

|WordPress Core|
:get_post_types(show_in_rest=true, 'objects')\n→ array of WP_Post_Type objects;

|WP_REST_Post_Types_Controller|
:Iterate each **$post_type** object;

repeat
  if (context == 'edit' AND\n!current_user_can(edit_posts)?) then (skip)
    :Skip this post type;
  else (include)
    :prepare_item_for_response(post_type, request);
    |WordPress Core|
    :get_object_taxonomies(post_type, 'objects')\nwp_list_filter(show_in_rest=true)\nwp_list_pluck() → $taxonomies;
    :get_all_post_type_supports(name)\n→ $supports;
    |WP_REST_Post_Types_Controller|
    :get_fields_for_response(request)\n→ determine context-gated fields;
    note right
      view/embed: name, slug, rest_base
      view+edit:  description, hierarchical, taxonomies
      edit only:  capabilities, viewable, labels, supports
    end note
    :add_additional_fields_to_object();
    :filter_response_by_context();
    :rest_ensure_response()\n→ add_links(collection href, items href);
    |WordPress Core|
    :apply_filters('rest_prepare_post_type',\nresponse, post_type, request);
    |WP_REST_Post_Types_Controller|
    :prepare_response_for_collection(post_type);
    :Add to **$data** keyed by post type name;
  endif
repeat while (more post types?) is (yes)
->no;

|REST Client|
:Receive JSON object\nof post type descriptors;

' ─── POST TYPES: Single Item ────────────────────────
|WP_REST_Post_Types_Controller|
:Route dispatched to **get_item()**\n(permission checks are INLINE);

|WordPress Core|
:get_post_type_object($request['type'])\n→ $obj;

if ($obj empty?) then (yes)
  #FFB3B3:Return **WP_Error**\n'rest_type_invalid' (404);
  stop
endif

if ($obj->show_in_rest empty?) then (yes)
  #FFB3B3:Return **WP_Error**\n'rest_cannot_read_type' (403);
  stop
endif

if (context == 'edit' AND\n!current_user_can(edit_posts)?) then (yes)
  #FFB3B3:Return **WP_Error**\n'rest_forbidden_context' (403);
  stop
else (no)
endif

|WP_REST_Post_Types_Controller|
:prepare_item_for_response($obj, $request)\n[same field-gated pipeline as collection];
:rest_ensure_response() → return post type descriptor;

|REST Client|
:Receive single post type descriptor;

' ══════════════════════════════════════════════════════
'  SECTION 2 — TAXONOMIES: Collection (GET /wp/v2/taxonomies)
' ══════════════════════════════════════════════════════

|WP_REST_Taxonomies_Controller|
:Route dispatched to\n**get_items_permissions_check()**;

|WordPress Core|
if (context == 'edit'?) then (yes)
  if ($request['type'] set?) then (yes)
    :get_object_taxonomies(type, 'objects');
  else (no)
    :get_taxonomies('', 'objects');
  endif
  :Iterate taxonomies;
  if (show_in_rest AND\ncurrent_user_can(assign_terms)\nfor any taxonomy?) then (yes)
    :Permission GRANTED;
  else (no)
    #FFB3B3:Return **WP_Error**\n'rest_cannot_view' (403);
    stop
  endif
else (no — view/embed)
  :Return true immediately;
endif

|WP_REST_Taxonomies_Controller|
:**get_items()** — read collection params;
:Check registered param 'type' (filter by post type);

|WordPress Core|
if ($request['type'] set?) then (yes)
  :get_object_taxonomies(type, 'objects');
else (no)
  :get_taxonomies('', 'objects');
endif

|WP_REST_Taxonomies_Controller|
:Iterate each **$taxonomy** object;

repeat
  if (empty(show_in_rest)?) then (skip)
    :Skip — not REST-exposed;
  elseif (context == 'edit' AND\n!current_user_can(assign_terms)?) then (skip)
    :Skip — insufficient capability;
  else (include)
    :prepare_item_for_response(taxonomy, request);
    note right
      rest_base = taxonomy->rest_base ?? taxonomy->name
    end note
    :get_fields_for_response(request)\n→ context-gated field population;
    note right
      view/embed: name(label), slug, rest_base
      view+edit:  description, hierarchical, types
      edit only:  capabilities, labels, show_cloud, visibility
                  (public, publicly_queryable, show_admin_column,
                   show_in_nav_menus, show_in_quick_edit, show_ui)
    end note
    :add_additional_fields_to_object();
    :filter_response_by_context();
    :rest_ensure_response()\n→ add_links(collection href,\nitems href: wp/v2/{base});
    |WordPress Core|
    :apply_filters('rest_prepare_taxonomy',\nresponse, taxonomy, request);
    |WP_REST_Taxonomies_Controller|
    :prepare_response_for_collection(tax);
    :Add to **$data** keyed by taxonomy type;
  endif
repeat while (more taxonomies?) is (yes)
->no;

if ($data empty?) then (yes)
  :Cast to object\n(ensure {} not [] in JSON);
  note right
    Business rule: empty taxonomy
    collection returns JSON object {}
    not array [] per REST convention
  end note
else (no)
endif

:rest_ensure_response($data);

|REST Client|
:Receive JSON object\nof taxonomy descriptors;

' ─── TAXONOMIES: Single Item ────────────────────────
|WP_REST_Taxonomies_Controller|
:Route dispatched to\n**get_item_permissions_check()**;

|WordPress Core|
:get_taxonomy($request['taxonomy'])\n→ $tax_obj;

if ($tax_obj exists?) then (yes)
  if (empty(show_in_rest)?) then (yes)
    #FFB3B3:Return false → 403;
    stop
  endif
  if (context == 'edit' AND\n!current_user_can(assign_terms)?) then (yes)
    #FFB3B3:Return **WP_Error**\n'rest_forbidden_context' (403);
    stop
  else (no)
  endif
else (no — non-existent)
  :Return true\n(404 deferred to get_item);
  note right
    Business rule: non-existent taxonomy
    passes permissions check; 404 is
    raised in get_item, not here
  end note
endif

|WP_REST_Taxonomies_Controller|
:Route dispatched to **get_item()**;

|WordPress Core|
:get_taxonomy($request['taxonomy'])\n→ $tax_obj;

if (empty($tax_obj)?) then (yes)
  #FFB3B3:Return **WP_Error**\n'rest_taxonomy_invalid' (404);
  stop
else (no)
endif

|WP_REST_Taxonomies_Controller|
:prepare_item_for_response($tax_obj, $request)\n[same field-gated pipeline as collection];
:rest_ensure_response() → return taxonomy descriptor;

|REST Client|
:Receive single taxonomy descriptor;
stop

@enduml
