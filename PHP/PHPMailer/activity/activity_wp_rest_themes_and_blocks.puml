@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title WordPress REST Themes & Reusable Blocks Flow\n(WP 6.1 — WP_REST_Themes_Controller & WP_REST_Blocks_Controller)

|REST Router|
start
:Incoming HTTP Request;

if (Route match?) then (GET /wp/v2/themes)
    |WP_REST_Themes_Controller|
    :get_items_permissions_check(request);

    if (has switch_themes OR manage_network_themes cap?) then (yes)
        :Permission granted;
    else (no)
        if (status filter == ["active"] only?) then (yes)
            :check_read_active_theme_permission();
            if (has edit_posts cap?) then (yes)
                :Permission granted;
            else (no)
                :Loop REST-exposed post types;
                if (any matching capability found?) then (yes)
                    :Permission granted;
                else (no)
                    #FFC0CB:Return WP_Error\nrest_cannot_view_active_theme (403);
                    stop
                endif
            endif
        else (no)
            #FFC0CB:Return WP_Error\nrest_cannot_view_themes (403);
            stop
        endif
    endif

    :get_items(request);
    |WordPress Core|
    :wp_get_themes() → all installed themes;
    :wp_get_theme() → current active theme;
    |WP_REST_Themes_Controller|
    :foreach theme: is_same_theme()\nDerive status: "active" | "inactive";

    note right
      is_same_theme() compares
      get_stylesheet() strings
    end note

    :Apply status filter\n(skip non-matching themes);

    repeat
        :prepare_item_for_response(theme, request);
        |WordPress Core|
        :get_fields_for_response(request) → field list;
        |WP_REST_Themes_Controller|
        fork
            :Plain fields:\nstylesheet, template, requires_php,\nrequires_wp, textdomain, version, screenshot;
        fork again
            :Rich fields (author, description, name, etc.):\n.raw  → theme->display(header, false, true)\n.rendered → theme->display(header);
        fork again
            :status: is_same_theme()\n→ "active" | "inactive";
        fork again
            if (Active theme?) then (yes)
                :theme_supports block:\nget_registered_theme_features() loop\ncurrent_theme_supports(feature)?\nrest_sanitize_value_from_schema();
                note right
                  theme_supports only populated
                  for the ACTIVE theme
                end note
            else (no)
                :Skip theme_supports;
            endif
        end fork
        :add_additional_fields_to_object(data, request);
        :rest_ensure_response(data);
        :prepare_links(theme):\nself + collection +\noptional global-styles link;
        :apply_filters("rest_prepare_theme",\nresponse, theme, request);
        :prepare_response_for_collection(prepared);
    repeat while (more themes?) is (yes)
    -> no;

    :rest_ensure_response(themes[]);
    :Set X-WP-Total header;
    :Set X-WP-TotalPages = 1;
    |REST Router|
    :Return WP_REST_Response (200);

else (GET /wp/v2/themes/<stylesheet>)
    |WP_REST_Themes_Controller|
    :_sanitize_stylesheet_callback(stylesheet)\n→ urldecode(stylesheet);

    :get_item_permissions_check(request);
    |WordPress Core|
    :wp_get_theme(stylesheet) + wp_get_theme() (current);
    |WP_REST_Themes_Controller|
    if (has switch_themes OR manage_network_themes cap?) then (yes)
        :Permission granted;
    else (no)
        if (is_same_theme()?) then (yes — it's active)
            :check_read_active_theme_permission();
        else (no)
            #FFC0CB:Return WP_Error\nrest_cannot_view_themes (403);
            stop
        endif
    endif

    :get_item(request);
    |WordPress Core|
    :wp_get_theme(stylesheet);
    |WP_REST_Themes_Controller|
    if (theme->exists()?) then (no)
        #FFC0CB:Return WP_Error\nrest_theme_not_found (404);
        stop
    else (yes)
        :prepare_item_for_response(theme, request);
        note right
          Same response-building flow
          as the collection path above
        end note
        :rest_ensure_response(data);
        |REST Router|
        :Return WP_REST_Response (200);
    endif

endif

|REST Router|
:Incoming HTTP Request\n(Reusable Block read);

|WP_REST_Blocks_Controller|
:check_read_permission(post);
if (current_user_can("read_post", post->ID)?) then (no)
    :Return false (deny);
    |REST Router|
    #FFC0CB:Return 403 Forbidden;
    stop
else (yes)
    :parent::check_read_permission(post)\n(WP_REST_Posts_Controller);
    :Return bool;
endif

:filter_response_by_context(data, context);
:parent::filter_response_by_context(data, context)\n(WP_REST_Posts_Controller);
:unset data["title"]["rendered"];
:unset data["content"]["rendered"];

note right
  Rendered fields stripped because
  rendering a block requires it to
  be inside a post/page context.
  Clients use .raw to parse/edit.
end note

:Return filtered data[];

:get_item_schema();
:schema = parent::get_item_schema()\n(WP_REST_Posts_Controller);
:Override context for title.raw\n& content.raw → ["view", "edit"];
:unset schema["title"]["rendered"];
:unset schema["content"]["rendered"];

note right
  Schema NOT cached — rendered
  variants deliberately removed
  so API clients always receive
  raw markup for reusable blocks
end note

:Return modified schema;

|REST Router|
:Return WP_REST_Response (200);
stop

@enduml
