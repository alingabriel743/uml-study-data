@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #DEE2E6
    TitleFontColor #212529
    TitleFontSize 13
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #FFF3CD
skinparam NoteBorderColor #FFC107

title WordPress REST Users CRUD Flow\n(WP_REST_Users_Controller — namespace: wp/v2, base: /users)

|#E3F2FD|REST Client|
|#F3E5F5|WP REST Infrastructure|
|#E8F5E9|WP_REST_Users_Controller|
|#FFF8E1|WordPress Core|

|REST Client|
start
:Send HTTP Request\n**GET / POST / PUT / DELETE**\n/wp/v2/users[/{id} | /me];

|WP REST Infrastructure|
:Match registered route\nvia register_routes();

if (Route found?) then (no)
  #FFCDD2:Return **404** Not Found;
  stop
else (yes)
endif

if (Which endpoint?) then (GET /wp/v2/users)
  note right
    List Users
    Collection endpoint
  end note

  |WP_REST_Users_Controller|
  :get_items_permissions_check();

  if (roles/capabilities param present\nAND NOT list_users cap?) then (yes)
    #FFCDD2:Return **403** rest_user_cannot_view;
    stop
  else (no)
  endif

  if (context=edit\nAND NOT list_users?) then (yes)
    #FFCDD2:Return **403** rest_forbidden_context;
    stop
  else (no)
  endif

  if (orderby=email or registered_date\nAND NOT list_users?) then (yes)
    #FFCDD2:Return **403** rest_forbidden_orderby;
    stop
  else (no)
  endif

  if (who=authors?) then (yes)
    if (Has edit_posts on any\nREST-visible post type?) then (no)
      #FFCDD2:Return **403** rest_forbidden_who;
      stop
    else (yes)
    endif
  else (no)
  endif

  :Permission granted → true;

  :get_items()\nMap API params → WP_User_Query args\n(exclude, include, order, per_page,\nroles, capabilities, slug);

  if (who=authors?) then (yes)
    :Set prepared_args['who'] = 'authors';
  else (no)
    if (NOT list_users cap?) then (yes)
      :Restrict to has_published_posts;
    else (no)
    endif
  endif

  :apply_filters('rest_user_query',\nprepared_args, request);

  |WordPress Core|
  :new WP_User_Query(prepared_args);
  :Fetch matching users from DB;

  |WP_REST_Users_Controller|
  :For each user:\nprepare_item_for_response()\n+ prepare_response_for_collection();
  :Set X-WP-Total\nX-WP-TotalPages headers;
  :Add prev/next Link headers\n(if multi-page);
  #C8E6C9:Return **200** WP_REST_Response\n(user collection);
  stop

else (GET /wp/v2/users/{id})
  note right
    Single User
    by numeric ID
  end note

  |WP_REST_Users_Controller|
  :get_item_permissions_check();
  :get_user(id) — validate & fetch;

  if (User not found or\nnot blog member?) then (yes)
    #FFCDD2:Return **404** rest_user_invalid_id;
    stop
  else (no)
  endif

  if (Current user IS\nrequested user?) then (yes)
    :Permission granted → true;
  else (no)
    if (context=edit\nAND NOT list_users?) then (yes)
      #FFCDD2:Return **403** rest_forbidden_context;
      stop
    else (no)
    endif
    if (No published posts\nAND NOT edit_user\nAND NOT list_users?) then (yes)
      #FFCDD2:Return **403** rest_cannot_edit;
      stop
    else (no)
      :Permission granted → true;
    endif
  endif

  :get_item()\nget_user(request['id']);
  :prepare_item_for_response(user, request);
  :rest_ensure_response();
  #C8E6C9:Return **200** WP_REST_Response\n(single user data);
  stop

else (GET /wp/v2/users/me)
  note right
    Current User
    No permission callback
    (handler enforces auth)
  end note

  |WP_REST_Users_Controller|
  :get_current_item();
  :get_current_user_id();

  if (User ID is empty\n(not logged in)?) then (yes)
    #FFCDD2:Return **401** rest_not_logged_in;
    stop
  else (no)
  endif

  :wp_get_current_user();
  :prepare_item_for_response(user, request);
  #C8E6C9:Return **200** WP_REST_Response\n(current user data);
  stop

else (POST /wp/v2/users)
  note right
    Create User
  end note

  |WP_REST_Users_Controller|
  :create_item_permissions_check();

  if (NOT create_users cap?) then (yes)
    #FFCDD2:Return **403** rest_cannot_create_user;
    stop
  else (no)
    :Permission granted → true;
  endif

  :create_item();

  if (request['id'] already set?) then (yes)
    #FFCDD2:Return **400** rest_user_exists;
    stop
  else (no)
  endif

  if (roles in request?) then (yes)
    :check_role_update(id, roles)\nValidate each role exists\nCheck promote_user cap\nCheck editable roles;
    if (Role validation fails?) then (yes)
      #FFCDD2:Return **400/403**\nrest_user_invalid_role\nor rest_cannot_edit_roles;
      stop
    else (no)
    endif
  else (no)
  endif

  :prepare_item_for_database(request)\nBuild stdClass user object;

  |WordPress Core|
  if (Multisite installation?) then (yes)
    :wpmu_validate_user_signup();
    if (Validation errors?) then (yes)
      #FFCDD2:Return **400** signup errors;
      stop
    else (no)
    endif
    :wpmu_create_user();
    :wp_update_user();
    :add_user_to_blog();
  else (no)
    :wp_insert_user(wp_slash(user));
  endif

  if (WP_Error returned?) then (yes)
    #FFCDD2:Return WP_Error response;
    stop
  else (no)
  endif

  |WP_REST_Users_Controller|
  :do_action('rest_insert_user',\nuser, request, true);

  if (roles supplied?) then (yes)
    :user->add_role() for each role;
  else (no)
  endif

  if (meta supplied?) then (yes)
    :meta->update_value(meta, user_id);
  else (no)
  endif

  :update_additional_fields_for_object();
  :do_action('rest_after_insert_user',\nuser, request, true);
  :prepare_item_for_response()\nset_status(201)\nSet Location header;
  #C8E6C9:Return **201** WP_REST_Response\n(created user data);
  stop

else (PUT /wp/v2/users/{id}\nor PUT /wp/v2/users/me)
  note right
    Update User
    /me injects current user id
    then delegates to update_item
  end note

  |WP_REST_Users_Controller|
  if (Endpoint is /me?) then (yes)
    :update_current_item_permissions_check()\nInject request['id'] = get_current_user_id();
  else (no)
  endif

  :update_item_permissions_check();
  :get_user(id);

  if (User not found?) then (yes)
    #FFCDD2:Return **404** rest_user_invalid_id;
    stop
  else (no)
  endif

  if (roles in request\nAND NOT promote_user?) then (yes)
    #FFCDD2:Return **403** rest_cannot_edit_roles;
    stop
  else (no)
  endif

  if (Only {id, roles} params\n(promote_user sufficient)?) then (yes)
    :Permission granted → true;
  else (no)
    if (NOT edit_user cap\nfor this user?) then (yes)
      #FFCDD2:Return **403** rest_cannot_edit;
      stop
    else (no)
      :Permission granted → true;
    endif
  endif

  :update_item();

  if (Email in use by\ndifferent user?) then (yes)
    #FFCDD2:Return **400** rest_user_invalid_email;
    stop
  else (no)
  endif

  if (Username change\nattempted?) then (yes)
    #FFCDD2:Return **400** rest_user_invalid_argument;
    stop
  else (no)
  endif

  if (Slug conflict?) then (yes)
    #FFCDD2:Return **400** rest_user_invalid_slug;
    stop
  else (no)
  endif

  if (roles in request?) then (yes)
    :check_role_update(id, roles);
    if (Role validation fails?) then (yes)
      #FFCDD2:Return **400/403** role error;
      stop
    else (no)
    endif
  else (no)
  endif

  :prepare_item_for_database(request);

  |WordPress Core|
  :wp_update_user(wp_slash(user));

  |WP_REST_Users_Controller|
  :do_action('rest_insert_user',\nuser, request, false);

  if (roles supplied?) then (yes)
    :add_role() for each role;
  else (no)
  endif

  if (meta supplied?) then (yes)
    :meta->update_value();
  else (no)
  endif

  :update_additional_fields_for_object();
  :do_action('rest_after_insert_user',\nuser, request, false);
  :prepare_item_for_response();
  #C8E6C9:Return **200** WP_REST_Response\n(updated user data);
  stop

else (DELETE /wp/v2/users/{id}\nor DELETE /wp/v2/users/me)
  note right
    Delete User
    Trashing NOT supported
    Multisite NOT supported
  end note

  |WP_REST_Users_Controller|
  if (Endpoint is /me?) then (yes)
    :delete_current_item_permissions_check()\nInject request['id'] = get_current_user_id();
  else (no)
  endif

  :delete_item_permissions_check();
  :get_user(id);

  if (User not found?) then (yes)
    #FFCDD2:Return **404** rest_user_invalid_id;
    stop
  else (no)
  endif

  if (NOT delete_user cap\nfor this user?) then (yes)
    #FFCDD2:Return **403** rest_user_cannot_delete;
    stop
  else (no)
    :Permission granted → true;
  endif

  :delete_item();

  if (Multisite installation?) then (yes)
    #FFCDD2:Return **501** rest_cannot_delete\n(not supported on multisite);
    stop
  else (no)
  endif

  if (force = false?) then (yes)
    #FFCDD2:Return **501** rest_trash_not_supported\n(trashing not supported);
    stop
  else (force = true)
  endif

  :check_reassign(value, request, param)\nParse reassign param;

  if (reassign param invalid\n(non-numeric)?) then (yes)
    #FFCDD2:Return **400** rest_user_invalid_reassign;
    stop
  else (no)
  endif

  if (reassign == same user id\nor reassign user not found?) then (yes)
    #FFCDD2:Return **400** rest_user_invalid_reassign;
    stop
  else (no)
  endif

  :prepare_item_for_response()\nSnapshot user data as 'previous';
  :require wp-admin/includes/user.php;

  |WordPress Core|
  :wp_delete_user(id, reassign)\nReassign content if param set;

  |WP_REST_Users_Controller|
  if (Delete failed?) then (yes)
    #FFCDD2:Return **500** rest_cannot_delete;
    stop
  else (no)
  endif

  :do_action('rest_delete_user',\nuser, response, request);
  #C8E6C9:Return **200**\n{ deleted: true, previous: <data> };
  stop

endif

@enduml
