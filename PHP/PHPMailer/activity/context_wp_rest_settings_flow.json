{
  "scope": "wp_rest_settings_flow",
  "title": "WordPress REST Settings Read/Write Flow",
  "diagram_type": "activity",
  "source_files_analyzed": [
    "tests/Frameworks/WordPress/Version_6_1/wp-includes/rest-api/endpoints/class-wp-rest-settings-controller.php"
  ],
  "key_participants": [
    "WP_REST_Server",
    "WP_REST_Settings_Controller",
    "WP_REST_Request",
    "WordPress Options API",
    "WordPress Settings API",
    "JSON Schema Validator"
  ],
  "class_info": {
    "name": "WP_REST_Settings_Controller",
    "extends": "WP_REST_Controller",
    "namespace": "wp/v2",
    "rest_base": "settings",
    "since": "4.7.0",
    "methods": [
      "__construct()",
      "register_routes()",
      "get_item_permissions_check($request): bool",
      "get_item($request): array|WP_Error",
      "prepare_value($value, $schema): mixed",
      "update_item($request): array|WP_Error",
      "get_registered_options(): array",
      "get_item_schema(): array",
      "sanitize_callback($value, $request, $param): mixed|WP_Error",
      "set_additional_properties_to_false($schema): array [deprecated 6.1.0]"
    ]
  },
  "routes": [
    "GET    /wp/v2/settings  → get_item()    [permission: get_item_permissions_check]",
    "PATCH  /wp/v2/settings  → update_item() [permission: get_item_permissions_check]",
    "PUT    /wp/v2/settings  → update_item() [permission: get_item_permissions_check]",
    "SCHEMA /wp/v2/settings  → get_public_item_schema()"
  ],
  "activity_flows": {
    "permission_check": [
      "START: incoming request",
      "call current_user_can('manage_options')",
      "[NO] → return 403 Forbidden",
      "[YES] → proceed to handler"
    ],
    "get_item_flow": [
      "START: GET /wp/v2/settings",
      "permission_check → must have 'manage_options' capability",
      "call get_registered_options() → returns filtered options array",
      "FOR EACH option in registered options:",
      "  apply_filters('rest_pre_get_setting', null, $name, $args)",
      "  [filter returned non-null?] → use filter value directly",
      "  [filter returned null] → call get_option($args['option_name'], $args['schema']['default'])",
      "  call prepare_value($value, $schema):",
      "    rest_validate_value_from_schema($value, $schema)",
      "    [validation WP_Error?] → set value to null (non-destructive)",
      "    [valid] → call rest_sanitize_value_from_schema($value, $schema) → return sanitized",
      "  store result in response[$name]",
      "END LOOP",
      "return response array"
    ],
    "update_item_flow": [
      "START: PATCH/PUT /wp/v2/settings",
      "permission_check → must have 'manage_options' capability",
      "call get_registered_options()",
      "call $request->get_params() to get submitted params",
      "FOR EACH option in registered options:",
      "  [option key NOT in request params?] → skip (continue)",
      "  apply_filters('rest_pre_update_setting', false, $name, $request[$name], $args)",
      "  [filter returned true (externally handled)?] → skip (continue)",
      "  [request value is null?]:",
      "    rest_validate_value_from_schema(get_option($args['option_name'], false), $args['schema'])",
      "    [stored value is invalid (WP_Error)?] → return WP_Error('rest_invalid_stored_value', 500)",
      "    [stored value valid] → call delete_option($args['option_name'])",
      "  [request value NOT null] → call update_option($args['option_name'], $request[$name])",
      "END LOOP",
      "call get_item($request) → return refreshed settings"
    ],
    "get_registered_options_flow": [
      "START: get_registered_options()",
      "call get_registered_settings() → all WP registered options",
      "FOR EACH setting:",
      "  [empty($args['show_in_rest'])?] → skip",
      "  build rest_args: name (override or original), schema (from show_in_rest if array)",
      "  build default_schema: type, description, default from $args",
      "  merge default_schema with rest_args['schema']",
      "  set rest_args['option_name'] = $name",
      "  [schema type empty?] → skip",
      "  [type NOT in (number, integer, string, boolean, array, object)?] → skip",
      "  call rest_default_additional_properties_to_false($rest_args['schema'])",
      "  add to $rest_options[$rest_args['name']]",
      "END LOOP",
      "return $rest_options"
    ],
    "get_item_schema_flow": [
      "START: get_item_schema()",
      "[$this->schema already cached?] → return add_additional_fields_schema($this->schema)",
      "call get_registered_options()",
      "build JSON Schema: $schema = { '$schema': json-schema draft-04, title: 'settings', type: 'object', properties: {} }",
      "FOR EACH option:",
      "  $schema['properties'][$option_name] = $option['schema']",
      "  attach arg_options['sanitize_callback'] = $this->sanitize_callback",
      "END LOOP",
      "cache $this->schema = $schema",
      "return add_additional_fields_schema($this->schema)"
    ],
    "sanitize_callback_flow": [
      "START: sanitize_callback($value, $request, $param)",
      "[value is null?] → return null (allow null bypass schema type check)",
      "[value not null] → call rest_parse_request_arg($value, $request, $param)",
      "return result or WP_Error"
    ]
  },
  "key_conditions": [
    "Options only exposed if registered with 'show_in_rest' => true (or array)",
    "Schema type must be defined and one of: number, integer, string, boolean, array, object",
    "Null request value triggers delete_option() only if stored value passes schema validation",
    "Invalid stored value blocks null update → returns HTTP 500 with 'rest_invalid_stored_value'",
    "Filter 'rest_pre_get_setting' can short-circuit option reading",
    "Filter 'rest_pre_update_setting' can short-circuit option writing",
    "prepare_value returns null (not error) when validation fails — safe, non-destructive"
  ],
  "wp_api_dependencies": [
    "get_registered_settings() — returns all WP Settings API registered options",
    "get_option($name, $default) — reads option from wp_options table",
    "update_option($name, $value) — persists option to wp_options table",
    "delete_option($name) — removes option from wp_options table",
    "rest_validate_value_from_schema($value, $schema) — JSON Schema validation",
    "rest_sanitize_value_from_schema($value, $schema) — JSON Schema sanitization",
    "rest_default_additional_properties_to_false($schema) — hardens schema (since 6.1.0)",
    "rest_parse_request_arg($value, $request, $param) — full arg parse+sanitize",
    "current_user_can('manage_options') — capability check",
    "apply_filters('rest_pre_get_setting', ...) — extensibility hook for reads",
    "apply_filters('rest_pre_update_setting', ...) — extensibility hook for writes"
  ],
  "important_notes": "Controller lives at GET/PATCH/PUT wp/v2/settings. Single resource (no collection paging). update_item always returns a fresh get_item call so response reflects actual stored state. Schema is lazily built and cached in $this->schema. set_additional_properties_to_false() deprecated in 6.1.0, replaced by global rest_default_additional_properties_to_false(). Null values in responses signal invalid/non-scalar stored data, not deletions.",
  "error_states": [
    "403: current_user_can('manage_options') returns false",
    "500 rest_invalid_stored_value: null update attempted on option with invalid stored value"
  ]
}
