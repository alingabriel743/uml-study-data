@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title CI/CD Pipeline Generation\nGitLab CI YAML generators for Datadog PHP Tracer

' ─────────────────────────────────────────────
' SHARED FOUNDATION
' ─────────────────────────────────────────────
package ".gitlab/ — Pipeline Generators" {

    class "generate-common.php" <<module>> as CommonModule {
        -- PHP Version Matrix (shared globals) --
        +$arch_targets: string[]
        +$php_versions_to_abi: map<string,string>
        +$all_minor_major_targets: string[]
        +$asan_minor_major_targets: string[]
        +$windows_minor_major_targets: string[]
        +$profiler_minor_major_targets: string[]
        +$no_asan_minor_major_targets: string[]
        +$service_bind_address: string
        -- YAML Snippet Emitters --
        +unset_dd_runner_env_vars(): void
        +dockerhub_login(): void
        +windows_git_setup(): void
        +windows_git_setup_with_packages(): void
    }

    ' ─────────────────────────────────────────
    ' PIPELINE GENERATORS
    ' ─────────────────────────────────────────

    class "generate-package.php" <<pipeline>> as PackageGen {
        -- Build Platform Matrices --
        +$build_platforms: array[4]
        +$asan_build_platforms: array[2]
        +$windows_build_platforms: array[1]
        -- Generated Jobs --
        +"prepare code"(): void
        +"cache cargo deps: [arch, triplet]"(): void
        +"package loader: [arch]"(): void
        +"validate_supported_configurations_v2"(): void
        +"configure_system_tests"(): void
        +"package-oci"(): void
        +"requirements_json_test"(): void
    }

    class "generate-appsec.php" <<pipeline>> as AppsecGen {
        -- Variables --
        +$ecrLoginSnippet: string
        -- Generated Jobs --
        +"test appsec extension"(): void
        +"appsec integration tests"(): void
        +"helper-rust build and test"(): void
        +"helper-rust code coverage"(): void
        +"appsec code coverage"(): void
        +"push appsec images"(): void
        +"appsec lint"(): void
        +"check libxml2 version"(): void
    }

    class "generate-shared.php" <<pipeline>> as SharedGen {
        -- Variables --
        +$switch_php_versions: string[]
        -- Generated Jobs --
        +"C components ASAN"(): void
        +"C components UBSAN"(): void
        +"Build & Test Tea"(): void
        +"Zend Abstract Interface Tests"(): void
        +"ZAI Shared Tests"(): void
        +"Extension Tea Tests"(): void
        +"Configuration Consistency"(): void
    }

    class "generate-profiler.php" <<pipeline>> as ProfilerGen {
        -- Generated Jobs --
        +"profiling tests"(): void
        +"clippy NTS"(): void
        +"Cargo test"(): void
    }

    class "generate-tracer.php" <<pipeline>> as TracerGen {
        -- Variables --
        +$services: array
        +$jobs: array
        +$xdebug_test_matrix: array
        -- YAML Snippet Emitters --
        +after_script($execute_dir, $has_test_agent): void
        +sidecar_logs(): void
        +before_script_steps($with_docker_auth): void
        +agent_httpbin_service(): void
    }
}

' ─────────────────────────────────────────────
' YAML JOB TEMPLATES (GitLab CI anchors)
' ─────────────────────────────────────────────
package "GitLab CI Job Templates" {

    class ".appsec_test" <<yaml-template>> as AppsecTestTpl {
        +tags: arch:${ARCH}
        +interruptible: true
        +before_script: unset_dd_runner_env_vars()
        +cache: boost-cache
        +matrix: PHP_MAJOR_MINOR x ARCH x build-type
    }

    class ".docker_push_job" <<yaml-template>> as DockerPushTpl {
        +stage: docker-build
        +image: docker:29.4.0-noble
        +before_script: ECR login + dockerhub_login()
        +before_script: apt install openjdk-17
    }

    class ".appsec_integration_tests" <<yaml-template>> as AppsecIntTpl {
        +stage: test
        +runner: docker-in-docker:amd64
        +tool: Gradle
        +artifacts: JUnit XML
    }

    class ".tea_test" <<yaml-template>> as TeaTestTpl {
        +tags: arch:amd64
        +interruptible: true
        +after_script: copy LastTest.log
        +after_script: silent-upload-junit-to-datadog.sh
        +artifacts: JUnit XML
    }
}

' ─────────────────────────────────────────────
' EXTERNAL YAML INCLUDES
' ─────────────────────────────────────────────
package "External YAML" {
    class "one-pipeline.locked.yml" <<yaml>> as OnePipelineYml
    class "benchmarks.yml" <<yaml>> as BenchmarksYml
}

' ─────────────────────────────────────────────
' RELATIONSHIPS — include (all generators use common)
' ─────────────────────────────────────────────
PackageGen  ..>  CommonModule : <<include>>
AppsecGen   ..>  CommonModule : <<include>>
SharedGen   ..>  CommonModule : <<include>>
ProfilerGen ..>  CommonModule : <<include>>
TracerGen   ..>  CommonModule : <<include>>

' Internal call within common module
CommonModule ..> CommonModule : windows_git_setup_with_packages()\ncalls windows_git_setup()

' Template definitions
AppsecGen ..> AppsecTestTpl      : defines
AppsecGen ..> DockerPushTpl      : defines
AppsecGen ..> AppsecIntTpl       : defines
SharedGen ..> TeaTestTpl         : defines

' Concrete jobs extend templates
AppsecGen  ..>  AppsecTestTpl  : extends via concrete jobs
AppsecGen  ..>  DockerPushTpl  : extends via concrete jobs
AppsecGen  ..>  AppsecIntTpl   : extends via concrete jobs
SharedGen  ..>  TeaTestTpl     : extends via concrete jobs

' External YAML includes
PackageGen ..> OnePipelineYml : <<includes yaml>>
PackageGen ..> BenchmarksYml  : <<includes yaml>>

' ─────────────────────────────────────────────
' NOTES
' ─────────────────────────────────────────────
note bottom of CommonModule
  Emits YAML anchors reused across all pipelines:
  • &all_minor_major_targets (PHP 7.0–8.5)
  • &asan_minor_major_targets (PHP >= 7.4)
  • &arch_targets (amd64, arm64)
  • default: retry block (max: 2)
  • .services: test-agent, mysql, redis,
    elasticsearch, kafka, mongodb, amqp…
  ABI timestamp map: 7.0=20151012 → 8.5=20250925
end note

note right of PackageGen
  Largest generator (~1000+ lines).
  Covers the full release pipeline:
  stages: prepare → profiler → appsec →
  tracing → packaging → benchmarks →
  gate → notify → verify →
  shared-pipeline → pre-release → release
  Integrates OCI packaging + Windows builds.
end note

note right of ProfilerGen
  Uses $profiler_minor_major_targets
  (PHP >= 7.1) from generate-common.php.
  CARGO_TARGET_DIR=/mnt/ramdisk/cargo.
  JUnit upload skipped on centos-7
  (old glibc/OpenSSL incompatible).
end note

note bottom of AppsecGen
  AWS ECR login via STS assume-role.
  Secrets (codecov, Datadog API key)
  sourced from HashiCorp Vault.
  ASAN-capable jobs require PHP >= 7.4.
end note

note right of TracerGen
  Services parsed dynamically via regex.
  Jobs array accumulated programmatically.
  Xdebug tests use a dedicated matrix.
end note

@enduml
