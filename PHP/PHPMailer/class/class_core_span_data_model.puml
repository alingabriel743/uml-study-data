@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Core Span Data Model\n<size:11><i>DDTrace C-extension stubs (ext/ddtrace.stub.php)</i></size>

package "DDTrace" {

    class SpanData {
        +$name: string|null = ""
        +$resource: string|null = ""
        +$service: string|null = ""
        +$env: string = ""
        +$version: string = ""
        +$type: string|null = ""
        +$meta: string[] = []
        +$metrics: float[] = []
        +$meta_struct: string[] = []
        +$exception: Throwable|null = null
        +$links: SpanLink[] = []
        +$events: SpanEvent[] = []
        +$peerServiceSources: string[] = []
        +$onClose: Closure[] = []
        +$baggage: array = []
        .. readonly (set by C runtime) ..
        +{readonly} $id: string
        +{readonly} $parent: SpanData|null
        +{readonly} $stack: SpanStack
        --
        +getDuration(): int
        +getStartTime(): int
        +getLink(): SpanLink
        +hexId(): string
    }

    class RootSpanData {
        +$origin: string
        +$propagatedTags: array = []
        +$samplingPriority: int
        +$propagatedSamplingPriority: int
        +$tracestate: string
        +$tracestateTags: array = []
        +$parentId: string
        +$traceId: string = ""
        +$gitMetadata: GitMetadata|null = null
        +$inferredSpan: InferredSpanData|null = null
    }

    class InferredSpanData {
        .. marker class ..
        __(no additional attributes)__
    }

    class SpanStack {
        +{readonly} $parent: SpanStack|null
        +$active: SpanData|null = null
        +$spanCreationObservers: Closure[] = []
    }

    class GitMetadata {
        +$commitSha: string = ""
        +$repositoryUrl: string = ""
    }

    class SpanLink {
        +$traceId: string
        +$spanId: string
        +$traceState: string
        +$attributes: array
        +$droppedAttributesCount: int
        --
        +jsonSerialize(): mixed
        +{static} fromHeaders(array|callable $headersOrCallback): SpanLink
    }

    class SpanEvent {
        +$name: string
        +$attributes: string[]
        +$timestamp: int
        --
        +__construct(string $name, array $attributes, ?int $timestamp)
        +jsonSerialize(): mixed
    }

    class ExceptionSpanEvent {
        +$exception: Throwable
        --
        +__construct(Throwable $exception, array $attributes)
    }

    interface JsonSerializable <<PHP>> {
        +jsonSerialize(): mixed
    }

}

' ── Inheritance ──────────────────────────────────────────
RootSpanData      --|>  SpanData         : extends
InferredSpanData  --|>  SpanData         : extends
ExceptionSpanEvent --|> SpanEvent        : extends

' ── Interface implementations ────────────────────────────
SpanLink  ..|>  JsonSerializable
SpanEvent ..|>  JsonSerializable

' ── Composition / Aggregation ────────────────────────────
SpanData *--  SpanStack          : $stack\n(readonly, context carrier)
SpanData *--  "0..*" SpanLink    : $links
SpanData *--  "0..*" SpanEvent   : $events
SpanData o--  SpanData           : $parent\n(self-ref, readonly)

RootSpanData o--  GitMetadata        : $gitMetadata\n(optional)
RootSpanData o--  InferredSpanData   : $inferredSpan\n(optional)

SpanStack o--  SpanData   : $active\n(currently active span)
SpanStack o--  SpanStack  : $parent\n(self-ref, linked-list)

' ── Notes ────────────────────────────────────────────────
note bottom of SpanData
  <b>$id</b>, <b>$parent</b>, and <b>$stack</b> are <b>readonly</b> — assigned by the C runtime.
  <b>$type</b> values: web, db, cache, or custom.
  <b>$meta_struct</b> is double-msgpack-encoded on agent submission.
  <b>$baggage</b> follows OTel baggage semantics (propagated with context).
  <b>$onClose</b> handlers fire on normal close only — NOT on drop.
end note

note right of RootSpanData
  Represents the <b>first span in a trace</b>.
  Carries trace-level metadata:
  traceId, samplingPriority, origin,
  propagated tags, tracestate, and gitMetadata.
  Default samplingPriority =
  DD_TRACE_PRIORITY_SAMPLING_UNKNOWN.
end note

note right of InferredSpanData
  <b>Marker subclass</b> — no extra fields.
  Tags synthetic / inferred spans.
  Referenced via RootSpanData.$inferredSpan.
end note

note right of SpanStack
  Context carrier between spans.
  Stacks form a <b>linked list</b>.
  <b>create_stack()</b> forks a new stack;
  <b>switch_stack()</b> swaps the active span.
  New spans always go on top of the active stack.
  $spanCreationObservers are inherited by child stacks.
end note

note bottom of GitMetadata
  Simple value object for CI/CD
  and source tracking.
  Attached to <b>RootSpanData only</b>.
end note

@enduml
