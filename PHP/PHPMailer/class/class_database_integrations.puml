@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Database Integrations\n<size:11>(Datadog PHP Tracer — DDTrace\\Integrations)</size>

' ─────────────────────────────────────────────
' DDTrace core (external references)
' ─────────────────────────────────────────────
package "DDTrace (Core)" <<Frame>> {
    interface Integration as CoreIntegration <<interface>> {
        +init(): int
    }

    class SpanData {
        +$name: string
        +$resource: string
        +$service: string
        +$type: string
        +$meta: array
        +$metrics: array
        +$peerServiceSources: array
    }

    class ObjectKVStore <<utility>> {
        +{static} put(object $obj, string $key, $value): void
        +{static} get(object $obj, string $key): mixed
    }
}

' ─────────────────────────────────────────────
' Base Integration
' ─────────────────────────────────────────────
package "DDTrace\\Integrations" <<Frame>> {

    abstract class Integration as BaseIntegration <<abstract>> {
        +{static} LOADED: int
        +{static} NOT_AVAILABLE: int
        +{abstract} {static} getName(): string
        +{abstract} {static} init(): int
        +{static} shouldLoad(string $name): bool
        +{static} addTraceAnalyticsIfEnabled(SpanData $span): void
        +{static} requiresExplicitTraceAnalyticsEnabling(): bool
        +{static} handleInternalSpanServiceName(SpanData $span, string $fallbackName, bool $skipFlattening): void
        +{static} handleOrphan(SpanData $span): void
        +{static} toString($value): string
    }

    class DatabaseIntegrationHelper <<utility>> {
        +{static} PEER_SERVICE_SOURCES: array
        +{static} injectDatabaseIntegrationData($hook, $driver, $argIndex, $forcedMode): void
    }

    note right of DatabaseIntegrationHelper
      Shared by PDO, MongoDB,
      PHPRedis, and Memcached.
      Handles DBM propagation
      and peer.service tag sources.
    end note
}

' ─────────────────────────────────────────────
' PDO Integration
' ─────────────────────────────────────────────
package "DDTrace\\Integrations\\PDO" <<Frame>> {
    class PDOIntegration {
        +{static} NAME: string = 'pdo'
        +{static} CONNECTION_TAGS_KEY: string
        +{static} DB_DRIVER_TO_SYSTEM: array
        --
        +{static} init(): int
        +{static} detectError($pdoOrStatement, SpanData $span): void
        +{static} extractConnectionMetadata(array $constructorArgs): array
        +{static} setCommonSpanInfo($source, SpanData $span): void
        +{static} handleRasp(PDO $source, SpanData $span): void
        +{static} injectDBIntegration($pdo, $hook, $forcedMode): void
        +{static} useQuestionMarkPlaceholders(string $query): string
        -{static} parseDsn(string $dsn): array
    }

    note bottom of PDOIntegration
      Span type: SQL
      Traces: PDO::__construct, ::exec, ::query,
      ::prepare, ::commit, PDOStatement::execute
      Tags: db.system, db.name, out.host, out.port,
      db.user, db.row_count, span.kind=client
      Env: DD_APPSEC_RASP_ENABLED (SQLi detection)
      DD_TRACE_DB_CLIENT_SPLIT_BY_INSTANCE
    end note
}

' ─────────────────────────────────────────────
' MongoDB Integration
' ─────────────────────────────────────────────
package "DDTrace\\Integrations\\MongoDB" <<Frame>> {
    class MongoDBIntegration {
        +{static} NAME: string = 'mongodb'
        +{static} SYSTEM: string = 'mongodb'
        --
        +{static} init(): int
        +{static} traceCollectionMethodWithFilter(string $method): void
        +{static} traceCollectionMethodNoArgs(string $method): void
        +{static} traceExecuteQuery(string $class, string $method): void
        +{static} traceExecuteBulkWrite(string $class, string $method): void
        +{static} traceExecuteCommand(string $class, string $method, array $knownCommands): void
        +{static} setMetadata(SpanData $span, $name, $method, $database, $collection, $host, $port, $command, $rawQuery): void
        +{static} serializeQuery($anythingQueryLike, bool $normalize): ?string
        +{static} normalizeQuery($rawQuery): mixed
        +{static} parseNamespace(string $namespace): array
    }

    note bottom of MongoDBIntegration
      Span type: MONGO
      Traces: Manager, Server, Collection (20+ ops),
      Query, Command, BulkWrite
      Tags: mongodb.database, mongodb.collection,
      mongodb.query, out.host, out.port
      Env: DD_TRACE_MONGODB_OBFUSCATION
    end note
}

' ─────────────────────────────────────────────
' PHPRedis Integration
' ─────────────────────────────────────────────
package "DDTrace\\Integrations\\PHPRedis" <<Frame>> {
    class PHPRedisIntegration {
        +{static} NAME: string = 'phpredis'
        +{static} SYSTEM: string = 'redis'
        +{static} DEFAULT_HOST: string = '127.0.0.1'
        +{static} DEFAULT_PORT: int = 6379
        +{static} CMD_MAX_LEN: int = 1000
        +{static} VALUE_MAX_LEN: int = 100
        --
        +{static} init(): int
        +{static} enrichSpan(SpanData $span, $instance, string $prefix): void
    }

    note bottom of PHPRedisIntegration
      Span type: REDIS
      Traces: Redis::connect/pconnect/open/popen,
      RedisCluster::__construct
      Tags: out.host, out.port,
      _dd.cluster.name, _dd.first.configured.host
      Supports Unix Domain Sockets
    end note
}

' ─────────────────────────────────────────────
' Memcached Integration
' ─────────────────────────────────────────────
package "DDTrace\\Integrations\\Memcached" <<Frame>> {
    class MemcachedIntegration {
        +{static} NAME: string = 'memcached'
        --
        +{static} init(): int
        +{static} traceCommand(string $command): void
        +{static} traceCommandByKey(string $command): void
        +{static} traceMulti(string $command): void
        +{static} traceMultiByKey(string $command): void
        +{static} setCommonData(SpanData $span, string $command): void
        +{static} setServerTags(SpanData $span, Memcached $memcached): void
        +{static} markForTraceAnalytics(SpanData $span, string $command): void
        +{static} obfuscateIfNeeded($params, string $glue): string
    }

    note bottom of MemcachedIntegration
      Span type: MEMCACHED
      Traces: add, get, set, delete, increment,
      decrement, cas, flush, prepend, replace (+ ByKey variants)
      Tags: memcached.command, memcached.query,
      db.system=memcached, db.row_count
      Env: DD_TRACE_MEMCACHED_OBFUSCATION
    end note
}

' ─────────────────────────────────────────────
' Elasticsearch Integrations
' ─────────────────────────────────────────────
package "DDTrace\\Integrations\\ElasticSearch" <<Frame>> {

    class ElasticSearchCommon <<utility>> {
        +{static} buildResourceName(string $methodName, array $params): string
    }

    note right of ElasticSearchCommon
      Builds resource name from
      method + relevant params
      (index, type). Shared
      between V1 and V8.
    end note

    package "V1" <<Frame>> {
        class ElasticSearchIntegrationV1 <<ElasticSearchIntegration>> {
            +{static} NAME: string = 'elasticsearch'
            -{static} $constructorCalled: bool
            --
            +{static} init(): int
            +{static} traceClientMethod(string $name, bool $isTraceAnalyticsCandidate): void
            +{static} traceSimpleMethod(string $class, string $name): void
            +{static} traceNamespaceMethod(string $namespace, string $name): void
        }

        note bottom of ElasticSearchIntegrationV1
          Span type: ELASTICSEARCH
          Traces: Elasticsearch\\Client (30+ methods),
          Serializers, AbstractEndpoint, Connection
          Tags: elasticsearch.url, elasticsearch.method,
          elasticsearch.params, elasticsearch.body
          Dynamically hooks namespace classes at __construct
        end note
    }

    package "V8" <<Frame>> {
        class ElasticSearchIntegrationV8 <<ElasticSearchIntegration>> {
            +{static} NAME: string = 'elasticsearch'
            -{static} $constructorCalled: bool
            -{static} $logNextBody: bool
            --
            +{static} init(): int
            +{static} traceClientMethod(string $name, bool $isTraceAnalyticsCandidate): void
            +{static} traceSimpleMethod(string $class, string $name): void
            +{static} traceNamespaceMethod(string $class, string $name): void
        }

        note bottom of ElasticSearchIntegrationV8
          Span type: ELASTICSEARCH
          Traces: Elastic\\Elasticsearch\\Client,
          Transport Serializers (PSR-7), Namespace traits
          Uses PSR-7 RequestInterface (not raw args)
          Lazily hooks NamespaceTrait methods on first access
        end note
    }
}

' ─────────────────────────────────────────────
' Inheritance
' ─────────────────────────────────────────────
BaseIntegration ..|> CoreIntegration : implements

PDOIntegration --|> BaseIntegration : extends
MongoDBIntegration --|> BaseIntegration : extends
PHPRedisIntegration --|> BaseIntegration : extends
MemcachedIntegration --|> BaseIntegration : extends
ElasticSearchIntegrationV1 --|> BaseIntegration : extends
ElasticSearchIntegrationV8 --|> BaseIntegration : extends

' ─────────────────────────────────────────────
' Dependencies — DatabaseIntegrationHelper
' ─────────────────────────────────────────────
PDOIntegration ..> DatabaseIntegrationHelper : uses
MongoDBIntegration ..> DatabaseIntegrationHelper : uses
PHPRedisIntegration ..> DatabaseIntegrationHelper : uses
MemcachedIntegration ..> DatabaseIntegrationHelper : uses

' ─────────────────────────────────────────────
' Dependencies — ObjectKVStore
' ─────────────────────────────────────────────
PDOIntegration ..> ObjectKVStore : uses
MongoDBIntegration ..> ObjectKVStore : uses
PHPRedisIntegration ..> ObjectKVStore : uses

' ─────────────────────────────────────────────
' Dependencies — ElasticSearchCommon
' ─────────────────────────────────────────────
ElasticSearchIntegrationV1 ..> ElasticSearchCommon : uses
ElasticSearchIntegrationV8 ..> ElasticSearchCommon : uses

' ─────────────────────────────────────────────
' SpanData usage (all integrations populate spans)
' ─────────────────────────────────────────────
PDOIntegration ..> SpanData : populates
MongoDBIntegration ..> SpanData : populates
PHPRedisIntegration ..> SpanData : populates
MemcachedIntegration ..> SpanData : populates
ElasticSearchIntegrationV1 ..> SpanData : populates
ElasticSearchIntegrationV8 ..> SpanData : populates

@enduml
