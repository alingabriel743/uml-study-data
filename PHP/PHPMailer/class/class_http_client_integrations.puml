@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title HTTP Client Integrations\nDatadog PHP Tracing (dd-trace-php)

' ─────────────────────────────────────────────
' DDTrace core
' ─────────────────────────────────────────────
package "DDTrace (core)" {
    interface Integration <<interface>> {
        +init(): int
    }

    class SpanData {
        +$name: string
        +$resource: string
        +$service: string
        +$type: string
        +$meta: array
        +$metrics: array
        +$exception: Throwable
        +$peerServiceSources: array
        +getDuration(): int
        +getStartTime(): int
    }
}

' ─────────────────────────────────────────────
' DDTrace\Integrations base
' ─────────────────────────────────────────────
package "DDTrace\\Integrations" {
    abstract class Integration <<abstract>> {
        +{static} getName(): string
        +{static} shouldLoad(name: string): bool
        +{static} addTraceAnalyticsIfEnabled(span: SpanData): void
        +{static} requiresExplicitTraceAnalyticsEnabling(): bool
        +{static} handleInternalSpanServiceName(span: SpanData, fallbackName: string, skipFlattening: bool): void
        +{static} handleOrphan(span: SpanData): void
        +{static} toString(value): string
    }

    class HttpClientIntegrationHelper {
        +{static} PEER_SERVICE_SOURCES: array
        --
        +{static} isClientError(statusCode: int): bool
        +{static} setClientError(span: SpanData, statusCode: int, reasonPhrase: ?string): bool
    }

    note right of HttpClientIntegrationHelper
      Reads DD_TRACE_HTTP_CLIENT_ERROR_STATUSES
      env var. Supports single codes and
      ranges (e.g. "400-499").
    end note
}

' ─────────────────────────────────────────────
' cURL Integration
' ─────────────────────────────────────────────
package "DDTrace\\Integrations\\Curl" {
    class CurlIntegration <<final>> {
        +{static} NAME: string = "curl"
        --
        +{static} init(): int
        -{static} setup_curl_span(span: SpanData): void
        -{static} set_curl_attributes(span: SpanData, info: array): array
    }

    note bottom of CurlIntegration
      Hooks: curl_exec (posthook),
      curl_multi_exec (pre+posthook),
      curl_multi_info_read (posthook).
      Distributed tracing handled natively
      at the PHP extension level.
    end note

    class CurlSpanInfo {
        +$span: SpanData
        +$spans: array
        --
        +__destruct(): void
    }

    note right of CurlSpanInfo
      Stored in ObjectKVStore keyed
      by curl_multi handle.
      Destructor finalises multi-exec
      spans via set_curl_attributes().
    end note
}

' ─────────────────────────────────────────────
' Guzzle Integration
' ─────────────────────────────────────────────
package "DDTrace\\Integrations\\Guzzle" {
    class GuzzleIntegration {
        +{static} NAME: string = "guzzle"
        --
        +{static} init(): int
        +{static} addRequestInfo(span: SpanData, request): void
        +{static} handlePromiseResponse(response, span: SpanData): void
    }

    note bottom of GuzzleIntegration
      Hooks: GuzzleHttp\\Client::transfer (pre+post),
      GuzzleHttp\\Client::send (posthook).
      Injects distributed tracing headers via
      generate_distributed_tracing_headers() into
      PSR-7 request. Always calls overrideArguments()
      (JIT safety). Supports Guzzle 5, 6 & 7.
    end note
}

' ─────────────────────────────────────────────
' PSR-18 Integration
' ─────────────────────────────────────────────
package "DDTrace\\Integrations\\Psr18" {
    class Psr18Integration {
        +{static} NAME: string = "psr18"
        --
        +{static} init(): int
        +{static} addRequestInfo(span: SpanData, request): void
    }

    note bottom of Psr18Integration
      Post-hook only on
      Psr\\Http\\Client\\ClientInterface::sendRequest.
      No header injection — relies on curl
      integration below it. Tested via
      GuzzleIntegration test suite.
    end note
}

' ─────────────────────────────────────────────
' External / PSR interfaces (abbreviated)
' ─────────────────────────────────────────────
package "PSR Interfaces" {
    interface RequestInterface <<PSR-7>> {
        +getUri(): UriInterface
        +getMethod(): string
        +withHeader(name: string, value): RequestInterface
    }

    interface ResponseInterface <<PSR-7>> {
        +getStatusCode(): int
        +getReasonPhrase(): string
    }

    interface ClientInterface <<PSR-18>> {
        +sendRequest(request: RequestInterface): ResponseInterface
    }
}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' Inheritance hierarchy
Integration ..|> Integration : implements
CurlIntegration --|> Integration
GuzzleIntegration --|> Integration
Psr18Integration --|> Integration

' Composition
CurlIntegration *-- CurlSpanInfo : creates / stores\nvia ObjectKVStore

' Dependencies on helper
CurlIntegration ..> HttpClientIntegrationHelper : uses setClientError()\nPEER_SERVICE_SOURCES
GuzzleIntegration ..> HttpClientIntegrationHelper : uses setClientError()\nPEER_SERVICE_SOURCES
Psr18Integration ..> HttpClientIntegrationHelper : uses setClientError()

' Span data usage
CurlIntegration ..> SpanData : decorates
GuzzleIntegration ..> SpanData : decorates
Psr18Integration ..> SpanData : decorates
CurlSpanInfo o-- SpanData : holds

' PSR interface usage
GuzzleIntegration ..> RequestInterface : reads / injects headers
GuzzleIntegration ..> ResponseInterface : inspects status
Psr18Integration ..> RequestInterface : reads
Psr18Integration ..> ResponseInterface : inspects status
Psr18Integration ..> ClientInterface : hooks sendRequest

@enduml
