@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Integration Interface and Base Classes

' ─────────────────────────────────────────────
' DDTrace core namespace (C extension stubs)
' ─────────────────────────────────────────────
package "DDTrace (ext stub)" {

    interface Integration <<interface>> {
        {static} +NOT_LOADED : int
        {static} +LOADED : int
        {static} +NOT_AVAILABLE : int
        --
        {static} +init() : int
    }

    class SpanData {
        +name : string|null
        +resource : string|null
        +service : string|null
        +type : string|null
        +env : string
        +version : string
        +meta : array
        +metrics : array
        +exception : ?Throwable
        +id : readonly string
        +links : array
        +events : array
        +peerServiceSources : array
        +parent : readonly SpanData|null
        +stack : readonly SpanStack
        +onClose : array
        +baggage : array
        +meta_struct : array
        --
        +getDuration() : int
        +getStartTime() : int
        +getLink() : SpanLink
        +hexId() : string
    }

    class RootSpanData {
        +origin : string
        +propagatedTags : array
        +samplingPriority : int
        +propagatedSamplingPriority : int
        +tracestate : string
        +tracestateTags : array
        +parentId : string
        +traceId : string
        +gitMetadata : ?GitMetadata
        +inferredSpan : ?InferredSpanData
    }

    class InferredSpanData {
        ' Marker subclass — no additional members
    }

    class HookData {
        +data : mixed
        +id : int
        +args : array
        +returned : mixed
        +exception : ?Throwable
        +instance : object
        --
        +span(?parent) : SpanData
        +unlimitedSpan(?parent) : SpanData
        +overrideArguments(array $arguments) : bool
        +overrideReturnValue(mixed $value) : bool
        +overrideException(?Throwable $exception) : bool
        +suppressCall() : bool
        +disableJitInlining() : bool
        +allowNestedHook() : bool
        +getSourceFile() : string
    }

    class SpanStack {
        +parent : SpanStack
        +active : SpanData
        +spanCreationObservers : array
    }

}

' ─────────────────────────────────────────────
' DDTrace\Integrations namespace (PHP layer)
' ─────────────────────────────────────────────
package "DDTrace\\Integrations" {

    abstract class IntegrationBase <<abstract>> {
        {static} +NAME : string
        --
        {static} +getName() : string
        {static} +shouldLoad(string $name) : bool
        {static} +addTraceAnalyticsIfEnabled(SpanData $span) : void
        {static} +requiresExplicitTraceAnalyticsEnabling() : bool
        {static} +toString($value) : string
        {static} +handleInternalSpanServiceName(SpanData $span, string $fallbackName, bool $skipFlattening) : void
        {static} +handleOrphan(SpanData $span) : void
    }

    class HttpClientIntegrationHelper <<utility>> {
        {static} +PEER_SERVICE_SOURCES : array
        --
        {static} +isClientError(int $statusCode) : bool
        {static} +setClientError(SpanData $span, int $statusCode, ?string $reasonPhrase) : bool
    }

    class DatabaseIntegrationHelper <<utility>> {
        {static} +PEER_SERVICE_SOURCES : array
        --
        {static} +injectDatabaseIntegrationData(HookData $hook, string $backend, int $argNum, bool $preventFullMode) : void
        {static} +propagateViaSqlComments($query, $databaseService, $mode, $targetHost, $dbName, $peerService) : string
        {static} +injectSqlComment($query, array $tags) : string
    }

}

' ─────────────────────────────────────────────
' Representative concrete integrations
' ─────────────────────────────────────────────
package "Concrete Integrations (examples)" {

    class PDOIntegration {
        {static} +NAME = "pdo"
        --
        {static} +init() : int
    }

    class GuzzleIntegration {
        {static} +NAME = "guzzle"
        --
        {static} +init() : int
    }

    class SymfonyIntegration {
        {static} +NAME = "symfony"
        --
        {static} +init() : int
        {static} +requiresExplicitTraceAnalyticsEnabling() : bool
    }

    class AMQPIntegration {
        {static} +NAME = "amqp"
        --
        {static} +init() : int
    }

}

' ─────────────────────────────────────────────
' Inheritance & implementation relationships
' ─────────────────────────────────────────────

' Abstract base implements the core interface
IntegrationBase ..|> Integration : implements

' Concrete integrations extend the abstract base
PDOIntegration --|> IntegrationBase : extends
GuzzleIntegration --|> IntegrationBase : extends
SymfonyIntegration --|> IntegrationBase : extends
AMQPIntegration --|> IntegrationBase : extends

' SpanData hierarchy
RootSpanData --|> SpanData : extends
InferredSpanData --|> SpanData : extends

' SpanData <-> SpanStack composition
SpanData *-- SpanStack : stack

' Abstract base uses SpanData
IntegrationBase ..> SpanData : uses
IntegrationBase ..> RootSpanData : uses (handleOrphan)

' Utility helper dependencies
HttpClientIntegrationHelper ..> SpanData : setClientError(span)
DatabaseIntegrationHelper ..> HookData : injectDatabaseIntegrationData(hook)
DatabaseIntegrationHelper ..> SpanData : via hook.span()

' Concrete HTTP integrations use HTTP helper
GuzzleIntegration ..> HttpClientIntegrationHelper : uses

' Concrete DB integrations use DB helper
PDOIntegration ..> DatabaseIntegrationHelper : uses

' ─────────────────────────────────────────────
' Notes
' ─────────────────────────────────────────────
note top of Integration
  Root contract defined in the
  DDTrace C extension stub.
  Status constants drive the
  integration lifecycle.
end note

note right of IntegrationBase
  **Integration Lifecycle**
  1. shouldLoad(NAME) — checks ddtrace ext + config
  2. init() — registers install_hook / trace_method hooks
  3. Returns LOADED, NOT_AVAILABLE, or NOT_LOADED
  4. Hooked calls create SpanData via HookData::span()
  5. Helpers (DB / HTTP) applied as needed
  6. handleOrphan() rejects orphan spans when enabled
end note

note bottom of DatabaseIntegrationHelper
  DBM = Database Monitoring propagation.
  Modes: **disabled** / **service** / **full**.
  Full propagation for mysql/pgsql only.
  SQL comment tag order: dddb, dddbs, dde,
  ddh, ddprs, ddps, ddpv, traceparent.
end note

note bottom of HttpClientIntegrationHelper
  Shared by Guzzle, Curl, and PSR-18
  integrations for HTTP error tagging.
  Reads DD_TRACE_HTTP_CLIENT_ERROR_STATUSES
  (supports ranges like "400-499").
end note

note right of SymfonyIntegration
  Web frameworks override
  requiresExplicitTraceAnalyticsEnabling()
  to return **false**, enabling automatic
  trace analytics inclusion.
end note

@enduml
