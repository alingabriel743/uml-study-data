@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Logging and Diagnostics — DDTrace\\Log

' ─────────────────────────────────────────────────────────────
' External PSR-3 reference (out-of-scope stub)
' ─────────────────────────────────────────────────────────────
package "PSR-3 (External)" #FFFFFF {
    interface "Psr\\Log\\LoggerInterface" as PsrLoggerInterface {
        +log(level, message, context): void
        +debug(message, context): void
        +warning(message, context): void
        +error(message, context): void
    }
}

' ─────────────────────────────────────────────────────────────
' Core DDTrace Log package
' ─────────────────────────────────────────────────────────────
package "DDTrace\\Log" {

    interface LoggerInterface {
        +debug(string $message, array $context): void
        +warning(string $message, array $context): void
        +error(string $message, array $context): void
        +isLevelActive(string $level): bool
    }

    abstract class AbstractLogger {
        -array $enabledLevels
        +__construct(string $level): void
        +isLevelActive(string $level): bool
    }

    class LogLevel <<final>> {
        +{static} EMERGENCY: string
        +{static} ALERT: string
        +{static} CRITICAL: string
        +{static} ERROR: string
        +{static} WARNING: string
        +{static} NOTICE: string
        +{static} INFO: string
        +{static} DEBUG: string
        +{static} all(): string[]
    }

    class Logger <<final>> {
        -{static} LoggerInterface $logger
        +{static} set(LoggerInterface $logger): void
        +{static} get(): LoggerInterface
        +{static} reset(): void
    }

    note right of Logger
        Singleton/Registry pattern.
        Auto-creates ErrorLogLogger when
        DD_TRACE_DEBUG=true, otherwise
        NullLogger(EMERGENCY).
    end note

    class NullLogger <<final>> {
        +debug(string $message, array $context): void
        +warning(string $message, array $context): void
        +error(string $message, array $context): void
        +isLevelActive(string $level): bool
    }

    note right of NullLogger
        All methods are no-ops.
        isLevelActive always returns false.
    end note

    class ErrorLogLogger {
        +debug(string $message, array $context): void
        +warning(string $message, array $context): void
        +error(string $message, array $context): void
        -emit(string $level, string $message, array $context): void
    }

    note bottom of ErrorLogLogger
        Writes to PHP error_log() as:
        "[date] [ddtrace] [level] - msg"
        Uses InterpolateTrait for {placeholder} substitution.
    end note

    class PsrLogger <<final>> {
        -Psr\\Log\\LoggerInterface $psrLogger
        +__construct(LoggerInterface $psrLogger, string $level): void
        +debug(string $message, array $context): void
        +warning(string $message, array $context): void
        +error(string $message, array $context): void
    }

    class DatadogLogger <<final>> {
        #resource|null $stream
        -string|null $errorMessage
        -bool|null $dirCreated
        +{static} DEFAULT_JSON_FLAGS: int
        +__construct($stream, string $mode): void
        +log(string $level, $message, array $context): void
        -{static} format(string $level, $message, array $context): string
        -{static} handleLogInjection(): array
        -emit(string $message): void
    }

    note bottom of DatadogLogger
        @internal — JSON stream logger.
        Does NOT extend AbstractLogger.
        Injects dd.trace_id + dd.span_id when
        DD_LOGS_INJECTION=true (log correlation).
        Inspired by Monolog StreamHandler.
    end note

    ' Traits
    class LoggingTrait <<trait>> {
        #{static} logDebug(string $message, array $context): void
        #{static} logWarning(string $message, array $context): void
        #{static} logError(string $message, array $context): void
        #{static} isLogDebugActive(): bool
    }

    note right of LoggingTrait
        Used by Tracer, Span, and TextMap
        to emit log messages via the
        global Logger registry.
    end note

    class InterpolateTrait <<trait>> {
        +{static} interpolate(string $message, array $context): string
    }

    note right of InterpolateTrait
        PSR-3 {placeholder} substitution.
        Replaces {key} tokens in message
        using values from $context array.
    end note
}

' ─────────────────────────────────────────────────────────────
' Test utilities
' ─────────────────────────────────────────────────────────────
package "DDTrace\\Tests" {

    class DebugLogger {
        -array $records
        +__construct(): void
        +debug(string $message, array $context): void
        +warning(string $message, array $context): void
        +error(string $message, array $context): void
        +has(string $level, string $message): bool
        +hasOnly(string $level, string $message): bool
        +all(): array
    }

    note bottom of DebugLogger
        Test-only in-memory logger.
        Stores [level, interpolated_message] pairs
        for asserting log output in unit tests.
    end note
}

' ─────────────────────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────────────────────

' Inheritance / Interface implementation
AbstractLogger ..|> LoggerInterface : implements
NullLogger --|> AbstractLogger : extends
ErrorLogLogger --|> AbstractLogger : extends
PsrLogger --|> AbstractLogger : extends
DebugLogger --|> AbstractLogger : extends

' Trait usage
ErrorLogLogger ..> InterpolateTrait : <<uses>>
DatadogLogger ..> InterpolateTrait : <<uses>>
DebugLogger ..> InterpolateTrait : <<uses>>

' Composition / Association
Logger "1" o-- "1" LoggerInterface : holds (singleton)
Logger ..> ErrorLogLogger : creates (DD_TRACE_DEBUG=true)
Logger ..> NullLogger : creates (default)
PsrLogger *-- PsrLoggerInterface : delegates to

' LoggingTrait dependencies
LoggingTrait ..> Logger : calls Logger::get()
LoggingTrait ..> LogLevel : uses LogLevel::DEBUG

' AbstractLogger uses LogLevel for level gating
AbstractLogger ..> LogLevel : builds enabledLevels from LogLevel::all()

' DatadogLogger implements PSR-3 indirectly (full PSR-3 API surface)
DatadogLogger ..> PsrLoggerInterface : conforms to (PSR-3 API)

@enduml
