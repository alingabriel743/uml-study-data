@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Messaging and Queue Integrations\nDatadog PHP Tracing (ddtrace) — Auto-instrumentation for AMQP, Kafka, and Symfony Messenger

' ─────────────────────────────────────────────
' DDTrace Core — Interface & Abstract Base
' ─────────────────────────────────────────────
package "DDTrace (Core)" {

    interface "DDTrace\\Integration" as DDTraceIntegration {
        +{static} LOADED : int
        +{static} NOT_LOADED : int
        --
        +init() : int
    }

    class SpanData {
        +$name : string
        +$resource : string
        +$service : string
        +$type : string
        +$meta : array
        +$metrics : array
        +$links : array
        +$exception : Throwable
        --
        +getDuration() : int
        +getStartTime() : int
        +getLink() : SpanLink
        +hexId() : string
    }

    class SpanLink {
        +$traceId : string
        +$spanId : string
        +$traceState : string
        +$attributes : array
        --
        +{static} fromHeaders($headersOrCallback) : SpanLink
        +jsonSerialize() : array
    }

    interface "DDTrace\\Propagator" as Propagator {
        +inject($spanContext, $carrier) : void
        +extract($carrier) : SpanContext
    }

    class "DDTrace\\Tag" as Tag {
        +{static} MQ_SYSTEM : string
        +{static} MQ_PROTOCOL : string
        +{static} MQ_PROTOCOL_VERSION : string
        +{static} MQ_OPERATION : string
        +{static} MQ_DESTINATION : string
        +{static} MQ_DESTINATION_KIND : string
        +{static} MQ_MESSAGE_ID : string
        +{static} MQ_MESSAGE_PAYLOAD_SIZE : string
        +{static} MQ_CONSUMER_ID : string
        +{static} SPAN_KIND : string
        +{static} COMPONENT : string
        +{static} KAFKA_HOST_LIST : string
        +{static} KAFKA_GROUP_ID : string
        +{static} KAFKA_CLIENT_ID : string
        +{static} KAFKA_PARTITION : string
        +{static} KAFKA_MESSAGE_OFFSET : string
        +{static} RABBITMQ_EXCHANGE : string
        +{static} RABBITMQ_ROUTING_KEY : string
    }

    class HookData {
        +$span : SpanData
        +$args : array
        +$returned : mixed
    }

    class "DDTrace\\Util\\ObjectKVStore" as ObjectKVStore {
        +{static} put(object $obj, string $key, $value) : void
        +{static} get(object $obj, string $key) : mixed
    }

}

' ─────────────────────────────────────────────
' DDTrace Integration Base
' ─────────────────────────────────────────────
package "DDTrace\\Integrations" {

    abstract class Integration {
        +{static} getName() : string
        +{static} shouldLoad(string $name) : bool
        +{static} addTraceAnalyticsIfEnabled(SpanData $span) : void
        +{static} requiresExplicitTraceAnalyticsEnabling() : bool
        +{static} toString($value) : string
        +{static} handleInternalSpanServiceName(SpanData $span, string $fallbackName, bool $skipFlattening) : void
        +{static} handleOrphan(SpanData $span) : void
    }

}

' ─────────────────────────────────────────────
' AMQP / RabbitMQ Integration
' ─────────────────────────────────────────────
package "DDTrace\\Integrations\\AMQP" {

    class AMQPIntegration {
        +{static} NAME : string = "amqp"
        +{static} SYSTEM : string = "rabbitmq"
        --
        -{static} $protocolVersion : string
        --
        +{static} init() : int
        +{static} setGenericTags(SpanData $span, string $name, string $spanKind, $resourceDetail, $exception) : void
        +{static} setOptionalMessageTags(SpanData $span, AMQPMessage $message) : void
        +{static} injectContext(AMQPMessage $message) : void
        +{static} extractContext(AMQPMessage $message) : void
        +{static} hasDistributedHeaders(AMQPMessage $message) : bool
        +{static} formatQueueName($queue) : string
        +{static} formatExchangeName($exchange) : string
        +{static} formatRoutingKey($routingKey) : string
        +{static} largeBaseConvert(string $numString, int $fromBase, int $toBase) : string
    }

}

' ─────────────────────────────────────────────
' Kafka Integration
' ─────────────────────────────────────────────
package "DDTrace\\Integrations\\Kafka" {

    class KafkaIntegration {
        +{static} NAME : string = "kafka"
        +{static} METADATA_MAPPING : array
        --
        +{static} init() : int
        +{static} setupKafkaProduceSpan(HookData $hook, ProducerTopic $producerTopic) : void
        +{static} addProducerSpanMetadata($span, $conf, $args) : void
        +{static} setupKafkaConsumeSpan(HookData $hook, $consumer) : void
        +{static} setupCommonSpanMetadata($span, string $name, string $spanKind, string $operation) : void
        -{static} installProducerTopicHooks() : void
        -{static} installConsumerHooks() : void
        -{static} installConfigurationHooks() : void
        -{static} installConfigurationHook(string $class, string $method) : void
        -{static} addMetadataToSpan($span, $conf) : void
        -{static} injectHeadersIntoArgs(array $args, array $headers) : array
    }

}

' ─────────────────────────────────────────────
' Symfony Messenger Integration (incl. SQS)
' ─────────────────────────────────────────────
package "DDTrace\\Integrations\\SymfonyMessenger" {

    class SymfonyMessengerIntegration {
        +{static} NAME : string = "symfonymessenger"
        --
        +{static} init() : int
        +{static} setSpanAttributes(SpanData $span, string $name, $resource, $envelopeOrMessage, $transportName, $operation, bool $addStampsInformation) : void
        +{static} resolveMetadataFromEnvelope(SpanData $span, Envelope $envelope, $resource, $transportName, $operation, bool $addStampsInformation) : void
        +{static} tryResolveMetadataFromMessage(SpanData $span, $message, $resource, $transportName, $operation) : void
        +{static} messageHasAlreadyBeenHandled(Envelope $envelope, HandlerDescriptor $handlerDescriptor) : bool
        +{static} determineSpanKind($operation) : ?string
    }

}

' ─────────────────────────────────────────────
' External Libraries (PhpAmqpLib)
' ─────────────────────────────────────────────
package "PhpAmqpLib (External)" #EDE7F6 {

    class "AMQPChannel" as AMQPChannel {
        +basic_publish(AMQPMessage $msg, ...) : void
        +basic_deliver(string $consumerTag, ...) : void
        +batch_basic_publish(AMQPMessage $msg) : void
        +publish_batch() : void
        +basic_consume(...) : string
        +basic_get(string $queue, ...) : AMQPMessage
        +basic_ack(int $deliveryTag, ...) : void
        +basic_nack(...) : void
        +exchange_declare(...) : void
        +queue_declare(...) : array
        +queue_bind(...) : void
    }

    class "AMQPMessage" as AMQPMessage {
        +$body : string
        +$application_headers : AMQPTable
        +get_properties() : array
    }

    class "AbstractConnection" as AMQPAbstractConnection {
        +connect() : void
        +reconnect() : void
    }

}

' ─────────────────────────────────────────────
' External Libraries (RdKafka)
' ─────────────────────────────────────────────
package "RdKafka (External)" #E8F5E9 {

    class "ProducerTopic" as RdKafkaProducerTopic {
        +producev(int $partition, int $msgflags, ...) : void
    }

    class "KafkaConsumer" as RdKafkaKafkaConsumer {
        +consume(int $timeoutMs) : Message
    }

    class "Queue" as RdKafkaQueue {
        +consume(int $timeoutMs) : Message
    }

    class "Producer" as RdKafkaProducer {
        +newTopic(string $topicName, ...) : ProducerTopic
    }

    class "Conf" as RdKafkaConf {
        +set(string $name, string $value) : void
        +get(string $name) : string
    }

}

' ─────────────────────────────────────────────
' External Libraries (Symfony Messenger)
' ─────────────────────────────────────────────
package "Symfony\\Component\\Messenger (External)" #FFF3E0 {

    interface "MessageBusInterface" as MessageBusInterface {
        +dispatch($message, array $stamps) : Envelope
    }

    interface "SenderInterface" as SenderInterface {
        +send(Envelope $envelope) : Envelope
    }

    interface "TransportInterface" as TransportInterface {
        +send(Envelope $envelope) : Envelope
    }

    class "Worker" as MessengerWorker {
        +handleMessage(Envelope $envelope, ...) : void
    }

    class "Envelope" as MessengerEnvelope {
        +all(?string $stampFqcn) : array
        +last(string $stampFqcn) : ?StampInterface
        +getMessage() : object
    }

    class "AmazonSqsReceivedStamp" as AmazonSqsReceivedStamp {
        ' SQS bridge — carried on Envelope when\nmessage originates from Amazon SQS
    }

}

' ─────────────────────────────────────────────
' Inheritance Hierarchy
' ─────────────────────────────────────────────
Integration          ..|> DDTraceIntegration   : implements
AMQPIntegration      --|> Integration          : extends
KafkaIntegration     --|> Integration          : extends
SymfonyMessengerIntegration --|> Integration   : extends

' ─────────────────────────────────────────────
' DDTrace Core Dependencies
' ─────────────────────────────────────────────
AMQPIntegration      ..> SpanData             : creates/tags
AMQPIntegration      ..> SpanLink             : creates (distributed tracing)
AMQPIntegration      ..> Propagator           : uses (inject/extract context)
AMQPIntegration      ..> Tag                  : uses (mq.*, rabbitmq.*)
AMQPIntegration      ..> AMQPMessage          : reads/writes headers
AMQPIntegration      ..> AMQPChannel          : instruments (hooks)
AMQPIntegration      ..> AMQPAbstractConnection : instruments (connect/reconnect)

KafkaIntegration     ..> SpanData             : creates/tags
KafkaIntegration     ..> SpanLink             : creates (distributed tracing)
KafkaIntegration     ..> HookData             : uses
KafkaIntegration     ..> Tag                  : uses (mq.*, kafka.*)
KafkaIntegration     ..> ObjectKVStore        : stores Conf across hooks
KafkaIntegration     ..> RdKafkaProducerTopic : instruments (producev)
KafkaIntegration     ..> RdKafkaKafkaConsumer : instruments (consume)
KafkaIntegration     ..> RdKafkaQueue         : instruments (consume)
KafkaIntegration     ..> RdKafkaProducer      : instruments (__construct, newTopic)
KafkaIntegration     ..> RdKafkaConf          : reads metadata (broker.list, group.id)

SymfonyMessengerIntegration ..> SpanData              : creates/tags
SymfonyMessengerIntegration ..> HookData              : uses
SymfonyMessengerIntegration ..> Tag                   : uses (mq.*, symfony.*)
SymfonyMessengerIntegration ..> ObjectKVStore         : stores handler locator
SymfonyMessengerIntegration ..> MessengerEnvelope     : reads stamps & metadata
SymfonyMessengerIntegration ..> AmazonSqsReceivedStamp : detects SQS source
SymfonyMessengerIntegration ..> MessageBusInterface   : instruments (dispatch)
SymfonyMessengerIntegration ..> SenderInterface       : instruments (send, inject headers)
SymfonyMessengerIntegration ..> TransportInterface    : instruments (send)
SymfonyMessengerIntegration ..> MessengerWorker       : instruments (handleMessage)

' ─────────────────────────────────────────────
' Span relationship
' ─────────────────────────────────────────────
SpanData o-- SpanLink : contains >

' ─────────────────────────────────────────────
' Notes
' ─────────────────────────────────────────────
note top of AMQPIntegration
  Instruments PhpAmqpLib (RabbitMQ).
  Supports distributed tracing via
  AMQPMessage application_headers.
  Env flag: DD_TRACE_AMQP_ENABLED
end note

note top of KafkaIntegration
  Instruments rdkafka extension (>= v6).
  Distributed tracing via producev() headers.
  Env flag: DD_TRACE_KAFKA_DISTRIBUTED_TRACING
end note

note top of SymfonyMessengerIntegration
  Instruments Symfony Messenger 4.4+.
  SQS support via AmazonSqsReceivedStamp bridge.
  Env flag: DD_TRACE_SYMFONY_MESSENGER_DISTRIBUTED_TRACING
  Note: ResqueIntegration not present in codebase.
end note

note bottom of ObjectKVStore
  Thread-safe key-value store keyed
  by object identity — used to propagate
  Kafka Conf and Messenger handler locator
  across separate method hooks.
end note

@enduml
