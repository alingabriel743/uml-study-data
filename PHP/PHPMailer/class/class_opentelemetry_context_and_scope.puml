@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
    FontColor #1A5276
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title OpenTelemetry Context and Scope

' ─────────────────────────────────────────
' External OpenTelemetry Interfaces
' ─────────────────────────────────────────
package "OpenTelemetry\\Context (External)" {

    interface ContextInterface <<OTel spec>> {
        +activate(): ScopeInterface
        +withContextValue(value: ImplicitContextKeyedInterface): ContextInterface
        +with(key: ContextKeyInterface, value: mixed): self
        +get(key: ContextKeyInterface): mixed
    }

    interface ScopeInterface {
        +detach(): int
    }

    interface ContextKeyInterface {
        +getName(): string
    }

    interface ContextStorageInterface {
        +current(): ContextInterface
        +attach(context: ContextInterface): ScopeInterface
    }

    interface ImplicitContextKeyedInterface {
        +storeInContext(context: ContextInterface): ContextInterface
    }

    interface ExecutionContextAwareInterface {
    }
}

' ─────────────────────────────────────────
' OpenTelemetry Context Implementation
' ─────────────────────────────────────────
package "OpenTelemetry\\Context" {

    class Context <<final>> {
        +{static} createKey(key: string): ContextKeyInterface
        +{static} setStorage(storage: ContextStorageInterface): void
        +{static} storage(): ContextStorageInterface
        +{static} resolve(context, contextStorage: ?ContextStorageInterface): ContextInterface
        +{static} getRoot(): ContextInterface
        +{static} getCurrent(): ContextInterface
        +activate(): ScopeInterface
        +withContextValue(value: ImplicitContextKeyedInterface): ContextInterface
        +with(key: ContextKeyInterface, value: mixed): self
        +get(key: ContextKeyInterface): mixed
    }

    note right of Context
        Immutable: with() and withContextValue()
        return new Context instances.
        OTel spec: opentelemetry-specification/
        blob/main/specification/context/README.md
    end note
}

' ─────────────────────────────────────────
' DDTrace Contracts (OpenTracing-ported)
' ─────────────────────────────────────────
package "DDTrace\\Contracts" {

    interface Scope <<interface>> {
        +close(): void
        +getSpan(): Span
    }

    note right of Scope
        Ported from opentracing/opentracing-php.
        Formalises activation/deactivation of a
        Span from the CPU scheduling standpoint.
    end note

    interface ScopeManager <<interface>> {
        +{static} DEFAULT_FINISH_SPAN_ON_CLOSE: bool = true
        +activate(span: Span, finishSpanOnClose: bool = true): Scope
        +getActive(): ?Scope
        +close(): void
    }

    note right of ScopeManager
        Keeps track of the current active Span.
        Ported from opentracing/opentracing-php.
    end note

    interface Span <<interface>> {
        +getOperationName(): string
        +getContext(): SpanContext
        +finish(finishTime): void
        +setTag(key, value, setIfFinished): void
        +getTag(key): mixed
    }
}

' ─────────────────────────────────────────
' DDTrace Implementations
' ─────────────────────────────────────────
package "DDTrace" {

    class Scope <<final>> {
        -scopeManager: ScopeManager
        -span: Contracts\\Span
        -finishSpanOnClose: bool
        +__construct(scopeManager: ScopeManager, span: Contracts\\Span, finishSpanOnClose: bool)
        +close(): void
        +getSpan(): SpanInterface
    }

    note bottom of Scope
        close() optionally finishes the wrapped
        Span depending on finishSpanOnClose flag.
    end note

    class ScopeManager <<final>> {
        -scopeStack: array
        -rootContext: mixed
        +__construct(rootContext = null)
        +activate(span: Contracts\\Span, finishSpanOnClose: bool = true): Scope
        +getActive(): ?Scope
        +deactivate(scope: Scope): void
        +close(): void
        ~getPrimaryRoot(): mixed
        ~getTopScope(): mixed
    }

    note bottom of ScopeManager
        Maintains a stack of active Scopes.
        deactivate() restores the previous
        active Scope on the stack.
    end note
}

' ─────────────────────────────────────────
' DDTrace Logging Support
' ─────────────────────────────────────────
package "DDTrace\\Log" {

    class LoggingTrait <<trait>> {
        #{static} logDebug(message: string, context: array): void
        #{static} logWarning(message: string, context: array): void
        #{static} logError(message: string, context: array): void
        #{static} isLogDebugActive(): bool
    }
}

' ─────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────

' OpenTelemetry Context implements its interface
Context ..|> ContextInterface : implements

' Context produces ScopeInterface on activation
Context ..> ScopeInterface : activate() returns >

' Context depends on supporting OTel interfaces
Context ..> ContextStorageInterface : uses >
Context ..> ContextKeyInterface : uses >
Context ..> ImplicitContextKeyedInterface : uses >

' ContextInterface hierarchy
ContextStorageInterface ..> ScopeInterface : attach() returns >

' DDTrace implementation hierarchy
Scope ..|> "DDTrace\\Contracts"::Scope : implements
ScopeManager ..|> "DDTrace\\Contracts"::ScopeManager : implements

' DDTrace Scope depends on ScopeManager and Span
Scope o-- ScopeManager : injected via constructor
Scope o-- "DDTrace\\Contracts"::Span : wraps >

' ScopeManager creates and manages Scopes
ScopeManager ..> Scope : creates / deactivates >

' Logging trait used by DDTrace classes
ScopeManager ..|> LoggingTrait : uses trait

@enduml
