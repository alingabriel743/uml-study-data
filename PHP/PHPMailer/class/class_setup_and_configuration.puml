@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9E6
    BorderColor #CCA300
}

title Setup and Configuration\n(datadog-setup.php — Datadog PHP Tracer Installer)

package "datadog-setup.php" {

    class IniRecord {
        + $setting: string
        + $currentValue: string
        + $defaultValue: string
        + $iniFile: string
        + $binary: string
        --
        + println(): void
    }
    note right of IniRecord
        Value object — one datadog.* INI entry
        found in an active INI file for a given
        PHP binary. Populated by config_list().
        Only formal class in the installer.
    end note

    class Installer <<procedural>> {
        + main(): void
        + install(array $options): void
        + uninstall(array $options): void
        + download(string $url, string $dest,\n  bool $retry = false): bool
        + safe_copy_extension(string $src,\n  string $dest): void
        + get_architecture(): string
        + is_alpine(): bool
        + check_library_prerequisite_or_exit(\n  string $lib): void
        + check_php_ext_prerequisite_or_exit(\n  string $binary, string $ext): void
    }
    note bottom of Installer
        Entry point — dispatches to:
        install | uninstall | cmd_config_get
        cmd_config_set | cmd_config_list
        Cross-platform: IS_WINDOWS flag drives
        path separators & archive extraction.
    end note

    class OptionsParser <<procedural>> {
        + parse_validate_user_options(): array
        + parse_cli_arguments(array $argv): array|false
        + map_env_to_ini(string $env): string|null
        + print_help(): void
        + print_error_and_exit(string $msg,\n  bool $printHelp = false): never
        + print_warning(string $msg): void
    }
    note right of OptionsParser
        map_env_to_ini() lets DD_TRACE_ENABLED
        style env vars be used as INI setting
        names in "config set" commands.
    end note

    class BinaryFinder <<procedural>> {
        + require_binaries_or_exit(\n  array $options): array
        + search_php_binaries(\n  string $prefix = ''): array
        + pick_binaries_interactive(\n  array $options,\n  array $binaries): array
        + resolve_command_full_path(\n  mixed $cmd): string|false
        + build_known_command_names_matrix(): array
        + get_supported_php_versions(): array
    }
    note right of BinaryFinder
        Searches $PATH + known paths incl.
        Remi Safe, Plesk. Supports: php, php8,
        php82, php-fpm8.2, … variants.
    end note

    class IniFileManager <<procedural>> {
        + ini_values(string $binary): array
        + find_all_ini_files(\n  array $phpProps): array
        + find_main_ini_files(\n  array $phpProps): array
        + filter_ssi_ini_paths(\n  array $paths): array
        + add_missing_ini_settings(\n  string $file,\n  array $settings,\n  array $replacements): void
        + modify_ini_file(\n  string $file,\n  callable $cb): void
        + update_ini_setting(\n  array $setting,\n  string $file,\n  bool $promoteComment): false|int
        + parse_ini_setting(string $raw): false|array
        + get_ini_settings(\n  string $srcDir,\n  string $appsecHelper,\n  string $appsecRules): array
    }
    note bottom of IniFileManager
        Default INI file: 98-ddtrace.ini.
        Debian: INI dirs split by SAPI
        (cli / apache2 / fpm) — all handled.
        3-step INI cascade: update active →
        promote commented → append new.
    end note

    class ConfigCommands <<procedural>> {
        + config_list(\n  array $options): array
        + cmd_config_list(\n  array $options): void
        + cmd_config_get(\n  array $options): void
        + cmd_config_set(\n  array $options): void
    }
    note right of ConfigCommands
        config_list() returns
        array<setting_name, IniRecord>.
        cmd_config_get groups results
        by setting across multiple files.
    end note

}

' --- Relationships ---

' ConfigCommands creates IniRecord objects
ConfigCommands ..> IniRecord : <<creates>>\nconfig_list()

' ConfigCommands depends on IniFileManager
ConfigCommands ..> IniFileManager : <<uses>>\nfind_all_ini_files()\nget_ini_settings()

' ConfigCommands depends on BinaryFinder
ConfigCommands ..> BinaryFinder : <<uses>>\nrequire_binaries_or_exit()

' Installer depends on IniFileManager
Installer ..> IniFileManager : <<uses>>\nini_values()\nfind_main_ini_files()\nadd_missing_ini_settings()\nget_ini_settings()

' Installer depends on BinaryFinder
Installer ..> BinaryFinder : <<uses>>\nrequire_binaries_or_exit()

' Installer uses OptionsParser (main() calls parse_validate_user_options first)
Installer ..> OptionsParser : <<uses>>\nparse_validate_user_options()

' ConfigCommands threads options from OptionsParser
ConfigCommands ..> OptionsParser : <<uses>>\noptions array

@enduml
