@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #E8F4FD
    BorderColor #2196F3
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Span Events and Links

package "DDTrace" {

    class SpanEvent {
        +name: string
        +attributes: array
        +timestamp: int
        --
        +__construct(name: string, attributes: array = [], timestamp: ?int = null)
        +jsonSerialize(): mixed
    }

    class ExceptionSpanEvent {
        +exception: Throwable
        --
        +__construct(exception: Throwable, attributes: array = [])
    }

    class SpanLink {
        +traceId: string
        +spanId: string
        +traceState: string
        +attributes: array
        +droppedAttributesCount: int
        --
        +jsonSerialize(): mixed
        +{static} fromHeaders(headersOrCallback: array|callable): SpanLink
    }

    class SpanData {
        +links: SpanLink[]
        +events: SpanEvent[]
        + ...
        --
        +getLink(): SpanLink
    }

}

interface "\\JsonSerializable" as JsonSerializable <<PHP Built-in>> {
    +jsonSerialize(): mixed
}

interface "\\Throwable" as Throwable <<PHP Built-in>> {
}

note right of SpanEvent
  <b>Timestamped span annotation</b>
  - timestamp in nanoseconds
    (defaults to current Unix time)
  - attributes: arbitrary key/value metadata
  - Modelled after OpenTelemetry span events
end note

note right of SpanLink
  <b>Cross-trace reference</b>
  - traceId: 32-char hex (128-bit W3C)
  - spanId: 16-char hex (64-bit)
  - Always populate via SpanData::getLink()
    — never assign SpanData::$id directly
    (64-bit → 128-bit mismatch)
  - fromHeaders() supports W3C Trace Context
    and Datadog distributed tracing formats
end note

note bottom of ExceptionSpanEvent
  <b>Convenience subclass for PHP exceptions</b>
  Auto-populates name, attributes, and timestamp
  from the Throwable — captures exception type,
  message, and stack trace as a structured event.
end note

note right of SpanData
  <b>Span owner / container</b>
  Append SpanEvent / ExceptionSpanEvent to $events.
  Append SpanLink to $links.
  Use getLink() as a factory to obtain a
  pre-populated SpanLink (correct 128-bit traceId).
end note

' Inheritance
ExceptionSpanEvent --|> SpanEvent : extends

' Interface implementations
SpanEvent ..|> JsonSerializable : implements
SpanLink ..|> JsonSerializable : implements

' ExceptionSpanEvent depends on Throwable
ExceptionSpanEvent ..> Throwable : <<constructor param>>

' SpanData composition
SpanData *-- "0..*" SpanEvent : events >
SpanData *-- "0..*" SpanLink : links >

' SpanData factory method produces SpanLink
SpanData ..> SpanLink : <<creates>>\ngetLink()

@enduml
