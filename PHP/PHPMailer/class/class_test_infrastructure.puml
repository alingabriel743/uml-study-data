@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2E86C1
}
skinparam abstract {
    BackgroundColor #FEF9E7
    BorderColor #D4AC0D
}

title Test Infrastructure

' ─────────────────────────────────────────────────────────
' External DDTrace interfaces and base types
' ─────────────────────────────────────────────────────────

package "DDTrace (library)" {

    interface Transport <<interface>> {
        +send(tracer: Tracer): void
    }

    namespace DDTrace.Contracts {
        interface Tracer <<interface>> {
        }
    }

    namespace DDTrace.Log {
        abstract class AbstractLogger <<abstract>> {
            #__construct(level: string)
        }
        class InterpolateTrait <<trait>> {
        }
        class LogLevel <<class>> {
            +DEBUG: string
            +WARNING: string
            +ERROR: string
        }
    }
}

' ─────────────────────────────────────────────────────────
' SAPI abstraction layer (DDTrace\Tests\Sapi)
' ─────────────────────────────────────────────────────────

package "DDTrace\\Tests\\Sapi" {

    interface Sapi <<interface>> {
        +isFastCgi(): bool
        +start(): void
        +stop(): void
    }

    class CliServer {
    }
    class PhpCgi {
    }
    class PhpFpm {
    }
    class PhpApache {
    }
    class RoadrunnerServer {
    }
    class OctaneServer {
    }
    class FrankenphpServer {
    }
    class SwooleServer {
    }

    CliServer        ..|> Sapi
    PhpCgi           ..|> Sapi
    PhpFpm           ..|> Sapi
    PhpApache        ..|> Sapi
    RoadrunnerServer ..|> Sapi
    OctaneServer     ..|> Sapi
    FrankenphpServer ..|> Sapi
    SwooleServer     ..|> Sapi
}

' ─────────────────────────────────────────────────────────
' Nginx reverse-proxy helper
' ─────────────────────────────────────────────────────────

package "DDTrace\\Tests\\Nginx" {
    class NginxServer {
        +start(): void
        +stop(): void
    }
}

' ─────────────────────────────────────────────────────────
' Core test infrastructure — DDTrace\Tests namespace
' ─────────────────────────────────────────────────────────

package "DDTrace\\Tests" {

    ' ── WebServer ────────────────────────────────────────
    class WebServer <<final>> {
        ' Constants
        +{static} FCGI_HOST: string = '0.0.0.0'
        +{static} FCGI_PORT: int
        +{static} ERROR_LOG_NAME: string
        ' Properties
        -sapi: Sapi
        -server: NginxServer
        -host: string
        -port: int
        -ddprofServiceName: string|null
        -indexFile: string
        -envs: array
        -defaultEnvs: array
        -inis: array
        -defaultInis: array
        -errorLogSize: int
        -isOctane: bool
        -isFrankenphp: bool
        -isSwoole: bool
        -roadrunnerVersion: string|null
        -phpFpmMaxChildren: int
        -phpFpmUser: string|null
        -phpFpmGroup: string|null
        -phpFpmSudo: bool
        -phpFpmMasterInis: array
        -forceSapi: string|null
        -{static} apache: PhpApache|null
        ' Methods
        +__construct(indexFile: string, host: string, port: int, ddprofServiceName: mixed)
        +setRoadrunner(version: mixed): void
        +setOctane(): void
        +setSwoole(): void
        +setFrankenphp(): void
        +setPhpFpmMaxChildren(maxChildren: mixed): void
        +setPhpFpmUser(user: mixed, group: mixed): void
        +setPhpFpmSudo(sudo: bool): void
        +setPhpFpmMasterIni(inis: array): void
        +setForceSapi(sapi: mixed): void
        +start(): void
        +reload(): void
        +stop(): void
        +mergeEnvs(envs: array): WebServer
        +mergeInis(inis: array): WebServer
        +checkErrors(): string|null
    }

    note right of WebServer
        SAPI selection priority (start()):
        roadrunner > octane > swoole >
        frankenphp > forceSapi/env-var >
        cgi-fcgi > fpm-fcgi >
        apache2handler > CliServer (default)

        FastCGI SAPIs also spin up NginxServer.
        PhpApache is a static singleton
        persisted across the test suite.
        stop() waits DD_TRACE_AGENT_FLUSH_INTERVAL×2
        for background trace flushing.
    end note

    ' ── DebugTransport ───────────────────────────────────
    class DebugTransport {
        -traces: array
        -headers: array
        +send(tracer: Tracer): void
        +setHeader(key: string, value: string): void
        +getHeaders(): array
        +getTraces(): array
    }

    note bottom of DebugTransport
        Accumulates traces in-memory.
        Used in unit tests to assert
        spans without a real DD agent.
    end note

    ' ── DebugLogger ──────────────────────────────────────
    class DebugLogger {
        -records: array
        +__construct()
        +debug(message: string, context: array): void
        +warning(message: string, context: array): void
        +error(message: string, context: array): void
        +has(level: string, message: string): bool
        +hasOnly(level: string, message: string): bool
        +all(): array
    }

    note bottom of DebugLogger
        Captures log records by level+message.
        has() / hasOnly() enable precise
        log assertions in test cases.
    end note
}

' ─────────────────────────────────────────────────────────
' PackageUpdater — global namespace (standalone CLI)
' ─────────────────────────────────────────────────────────

package "tests/ (global)" {

    class PackageUpdater {
        ' Constants
        +{static} INTEGRATIONS_DIR: string
        +{static} PACKAGIST_API_URL: string
        ' Properties
        -updates: array
        -errors: array
        ' Methods
        +run(): void
        -findTestFiles(): array
        -processFile(file: string): void
        -findLibrary(className: string, file: string): string|null
        -findComposerFile(className: string, file: string): string|null
        -updatePackageVersion(library: string, composerFile: string): void
        -getLatestVersion(library: string): string|null
        -displaySummary(): void
    }

    note right of PackageUpdater
        Standalone CLI tool (no namespace).
        Scans tests/Integrations/**/*Latest/*Test.php,
        queries Packagist API for latest stable version,
        and patches composer.json files in place.
        Exits with code 1 if any errors are found.
    end note
}

' ─────────────────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────────────────

' DebugTransport implements DDTrace\Transport
DebugTransport ..|> Transport

' DebugLogger extends AbstractLogger and uses InterpolateTrait
DebugLogger --|> DDTrace.Log.AbstractLogger
DebugLogger ..> DDTrace.Log.InterpolateTrait : <<uses trait>>

' DebugTransport depends on Tracer (via send() parameter)
DebugTransport ..> DDTrace.Contracts.Tracer : <<uses>>

' WebServer composes Sapi (strategy pattern)
WebServer *-- Sapi : strategy\n(chosen at start())

' WebServer composes NginxServer (FastCGI only)
WebServer *-- NginxServer : reverse proxy\n(FastCGI SAPIs only)

' WebServer holds static PhpApache singleton
WebServer o-- PhpApache : static singleton\n(apache2handler)

@enduml
