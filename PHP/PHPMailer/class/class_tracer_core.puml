@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Tracer Core\nMain Tracer class, GlobalTracer factory, and core tracing orchestration components

' ─────────────────────────────────────────────
' DDTrace Contracts (API contract layer)
' ─────────────────────────────────────────────
package "DDTrace\\Contracts" {

    interface Tracer <<interface>> {
        +limited(): bool
        +getScopeManager(): ScopeManager
        +getActiveSpan(): Span|null
        +startSpan(string $operationName, $options): Span
        +startActiveSpan(string $operationName, $options): Scope
        +startRootSpan(string $operationName, $options): Scope
        +getRootScope(): Scope|null
        +getSafeRootSpan(): Span|null
        +inject(SpanContext $ctx, string $format, &$carrier): void
        +extract(string $format, $carrier): SpanContext|null
        +flush(): void
        +setPrioritySampling($priority): void
        +getPrioritySampling(): int|null
        +getTracesAsArray(): array
        +getTracesCount(): int
    }

}

' ─────────────────────────────────────────────
' DDTrace Core (main implementation)
' ─────────────────────────────────────────────
package "DDTrace" {

    class Tracer <<final>> {
        -$traces: Span[][]
        -$transport: Transport
        -$propagators: Propagator[]
        -$config: array
        -$scopeManager: ScopeManager
        -$serviceVersion: string
        -$environment: string
        -$rootContext: SpanContext|null
        --
        +__construct($transport, $propagators, array $config)
        +limited(): bool
        +reset(): void
        +{static} noop(): self
        +{static} version(): string
        +startSpan(string $operationName, $options): Span
        +startActiveSpan(string $operationName, $options): Scope
        +startRootSpan(string $operationName, $options): Scope
        +inject(SpanContext $ctx, string $format, &$carrier): void
        +extract(string $format, $carrier): SpanContext|null
        +flush(): void
        +getScopeManager(): ScopeManager
        +getActiveSpan(): Span|null
        +getSafeRootSpan(): Span|null
        +setPrioritySampling($priority): void
        +getPrioritySampling(): int|null
        +getTracesAsArray(): array
        +getTracesCount(): int
        +addUrlAsResourceNameToSpan(Span $span): void
        -findParent(Reference[] $refs): Reference|null
        -setPrioritySamplingFromSpan(Span $span): void
    }

    class GlobalTracer <<final>> {
        -{static} $instance: TracerInterface
        --
        +{static} set(TracerInterface $tracer): void
        +{static} get(): TracerInterface
    }

    class NoopTracer <<final>> {
        --
        +{static} create(): self
        +limited(): bool
        +getActiveSpan(): NoopSpan
        +getScopeManager(): NoopScopeManager
        +startSpan(...): NoopSpan
        +startActiveSpan(...): NoopScope
        +startRootSpan(...): NoopScope
        +getRootScope(): NoopScope
        +getSafeRootSpan(): NoopSpan
        +inject(...): void
        +extract(...): NoopSpanContext
        +flush(): void
        +getTracesAsArray(): array
        +getTracesCount(): int
    }

    ' ─── Supporting types used by Tracer ───
    interface Transport <<interface>> {
        +send($tracer): void
    }

    interface Propagator <<interface>> {
        +inject(SpanContext $ctx, $carrier): void
        +extract($carrier): SpanContext|null
    }

    class ScopeManager {
        +__construct($rootContext)
        +activate(Span $span, bool $finishOnClose): Scope
        +getActive(): Scope|null
        +getPrimaryRoot(): Scope|null
        +getTopScope(): Scope|null
        +close(): void
    }

    class SpanContext {
        +$traceId
        +$spanId
        +$parentId
        +$propagatedPrioritySampling
        +$origin
        +$baggageItems
        --
        +{static} createAsRoot($baggageItems): self
        +{static} createAsChild(SpanContext $parent): self
        +getTraceId(): string
        +getSpanId(): string
        +isDistributedTracingActivationContext(): bool
    }

    trait LoggingTrait {
        #logDebug(string $msg, array $ctx): void
        #logWarning(string $msg, array $ctx): void
        #logError(string $msg, array $ctx): void
        #isLogDebugActive(): bool
    }

}

' ─────────────────────────────────────────────
' DDTrace OpenTracing adapter
' ─────────────────────────────────────────────
package "DDTrace\\OpenTracer" {

    class OTTracerAdapter as "Tracer" <<final>> {
        -$tracer: DDTrace\\Contracts\\Tracer
        -$scopeManager: OTScopeManager
        --
        +__construct($tracer)
        +{static} make($transport, $propagators, $config): self
        +startSpan(string $operationName, $options): OT\\Span
        +startActiveSpan(string $operationName, $options): OT\\Scope
        +inject(OT\\SpanContext $ctx, string $format, &$carrier): void
        +extract(string $format, $carrier): OT\\SpanContext
        +flush(): void
        +getScopeManager(): OT\\ScopeManager
        +getActiveSpan(): OT\\Span|null
        +unwrapped(): DDTrace\\Contracts\\Tracer
    }

}

' ─────────────────────────────────────────────
' OpenTracing (external v0 API)
' ─────────────────────────────────────────────
package "OpenTracing" <<external>> {

    interface OTTracer as "Tracer" <<interface>> {
        +startSpan(string $operationName, $options): Span
        +startActiveSpan(string $operationName, $options): Scope
        +inject(SpanContext $ctx, string $format, &$carrier): void
        +extract(string $format, $carrier): SpanContext
        +flush(): void
        +getScopeManager(): ScopeManager
        +getActiveSpan(): Span|null
    }

}

' ─────────────────────────────────────────────
' OpenTelemetry SDK stubs
' ─────────────────────────────────────────────
package "OpenTelemetry" <<external>> {

    interface OTelTracerInterface as "API\\Trace\\TracerInterface" <<interface>> {
        +spanBuilder(string $spanName): SpanBuilderInterface
        +isEnabled(): bool
        +getInstrumentationScope(): InstrumentationScopeInterface
    }

    interface OTelSpanBuilderInterface as "API\\Trace\\SpanBuilderInterface" <<interface>> {
        +setParent($context): SpanBuilderInterface
        +addLink(SpanContextInterface $ctx, $attributes): SpanBuilderInterface
        +setAttribute(string $key, $value): SpanBuilderInterface
        +setAttributes(iterable $attributes): SpanBuilderInterface
        +setStartTimestamp(int $tsNanos): SpanBuilderInterface
        +setSpanKind(int $spanKind): SpanBuilderInterface
        +startSpan(): SpanInterface
    }

    class OTelSpanBuilder as "SDK\\Trace\\SpanBuilder" <<final>> {
        -spanName: string
        -instrumentationScope: InstrumentationScopeInterface
        -tracerSharedState: TracerSharedState
        --
        +__construct(string $spanName, InstrumentationScopeInterface $scope, TracerSharedState $state)
        +setParent($context): SpanBuilderInterface
        +addLink(SpanContextInterface $ctx, $attributes): SpanBuilderInterface
        +setAttribute(string $key, $value): SpanBuilderInterface
        +setAttributes(iterable $attributes): SpanBuilderInterface
        +setStartTimestamp(int $tsNanos): SpanBuilderInterface
        +setSpanKind(int $spanKind): SpanBuilderInterface
        +startSpan(): SpanInterface
    }

    interface OTelInstrumentationScope as "SDK\\Common\\Instrumentation\\InstrumentationScopeInterface" <<interface>> {
        ' Identifies an instrumentation library (name + version)
    }

    class OTelTracerSharedState as "SDK\\Trace\\TracerSharedState" {
        ' Holds SpanProcessor, Resource, Sampler
        ' Shared across Tracer instances
    }

}

' ─────────────────────────────────────────────
' DDTrace OpenTelemetry hook wrapper
' ─────────────────────────────────────────────
package "DDTrace\\OpenTelemetry" {

    class CachedInstrumentationHook as "CachedInstrumentation (hook)" <<anonymous>> {
        ' DDTrace installs hooks on CachedInstrumentation::__construct\n and ::tracer() at runtime
        --
        +spanBuilder(string $spanName): SpanBuilderInterface
        +isEnabled(): bool
        +getInstrumentationScope(): InstrumentationScopeInterface
        +updateConfig(Configurator $cfg): void
    }

}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' Core implementation ──▷ Contract
Tracer ..|> "DDTrace\\Contracts".Tracer : implements
NoopTracer ..|> "DDTrace\\Contracts".Tracer : implements

' GlobalTracer factory
GlobalTracer ..> "DDTrace\\Contracts".Tracer : holds singleton
GlobalTracer ..> Tracer : <<creates>>\n[if ddtrace ext loaded]
GlobalTracer ..> NoopTracer : <<creates>>\n[fallback]

' Tracer composes supporting types
Tracer *-- ScopeManager : -$scopeManager\ncomposes
Tracer *-- Transport : -$transport\ncomposes
Tracer *-- Propagator : -$propagators[]\ncomposes
Tracer o-- SpanContext : -$rootContext\n(distributed tracing)
Tracer ..> LoggingTrait : <<uses trait>>

' OpenTracing adapter
OTTracerAdapter ..|> OTTracer : implements
OTTracerAdapter o-- "DDTrace\\Contracts".Tracer : -$tracer\nwraps
OTTracerAdapter ..> Tracer : ::make() creates

' OTel SpanBuilder
OTelSpanBuilder ..|> OTelSpanBuilderInterface : implements
OTelSpanBuilder ..> OTelInstrumentationScope : uses
OTelSpanBuilder ..> OTelTracerSharedState : uses

' CachedInstrumentation hook
CachedInstrumentationHook ..|> OTelTracerInterface : implements (hook)
CachedInstrumentationHook ..> OTelInstrumentationScope : delegates

' ─────────────────────────────────────────────
' Notes
' ─────────────────────────────────────────────

note right of Tracer
  Core C-extension-backed implementation.
  Uses internal functions: dd_trace_*, active_span(),
  root_span(), set_priority_sampling() etc.
  flush() sends spans to Datadog Agent via Transport.
  Reads DD_VERSION / DD_ENV env vars on construction.
end note

note right of GlobalTracer
  Singleton entry-point for the legacy DDTrace API.
  Returns DDTrace\\Tracer when the ddtrace PHP
  extension is loaded; falls back to NoopTracer.
end note

note bottom of NoopTracer
  All operations silently dropped.
  limited() always returns true.
  Fallback when ddtrace ext is not loaded.
end note

note right of OTTracerAdapter
  OpenTracing v0 adapter.
  make() is the designated factory method.
  unwrapped() exposes the inner DDTrace\\Contracts\\Tracer.
  Prefixes scope names with "otel." via CachedInstrumentation hook.
end note

note bottom of OTelSpanBuilder
  OTel SDK stub provided via ddtrace stubs.
  Connects Tracer to SpanProcessor and Sampler
  through TracerSharedState.
end note

@enduml
