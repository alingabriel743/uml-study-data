@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Transport Layer

package "DDTrace" {

    interface Transport <<interface>> {
        +send(TracerInterface $tracer): void
        +setHeader(string $key, string $value): void
    }

    note right of Transport
        Canonical definition: src/api/Transport.php
        Mirrored in ddtrace_php_api.stubs.php for IDE support.
        Contract for all trace-sending implementations.
    end note

    package "DDTrace\\Transport" {

        class Internal <<final>> {
            +send(TracerInterface $tracer): void
            +setHeader(string $key, string $value): void
        }

        note bottom of Internal
            Default production transport.
            Delegates to C-extension DDTrace\\flush().
            send() is skipped if DD_TRACE_GENERATE_ROOT_SPAN=true.
            setHeader() is a no-op — background sender ignores headers.
        end note

        class Noop <<final>> {
            +send(Tracer $tracer): void
            +setHeader(string $key, string $value): void
        }

        note bottom of Noop
            Null-object pattern.
            Used when tracing is disabled.
            Both methods are intentional no-ops.
        end note
    }

    class Tracer {
        -$transport: Transport
        +__construct($transport = null, $propagators = null, array $config = [])
        +flush(): void
    }

    note right of Tracer
        Uses Internal transport by default.
        Switches to Noop when tracing is disabled.
        Calls $transport->send($this) on flush/shutdown.
    end note
}

package "DDTrace\\Tests" {

    class DebugTransport {
        -$traces: array
        -$headers: array
        +send(Tracer $tracer): void
        +setHeader(string $key, string $value): void
        +getTraces(): array
        +getHeaders(): array
    }

    note bottom of DebugTransport
        Test-only implementation.
        Accumulates traces via getTracesAsArray()
        and headers in memory for test assertions.
        Not for production use.
    end note
}

' Implementations
Internal ..|> Transport : implements
Noop ..|> Transport : implements
DebugTransport ..|> Transport : implements

' Tracer composition
Tracer *-- Transport : -$transport

' Tracer default wiring
Tracer ..> Internal : instantiates by default
Tracer ..> Noop : uses when disabled

@enduml
