@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Web Framework Integrations\n<size:11>Datadog PHP Tracing (DDTrace) — Auto-Instrumentation for PHP Web Frameworks</size>

' ──────────────────────────────────────────────
' DDTrace Core (ext stub)
' ──────────────────────────────────────────────
package "DDTrace (Core Extension)" #D4EDDA {
    interface "Integration" as DDTraceIntegration {
        +init(): int
    }

    class SpanData {
        +$name: string
        +$resource: string
        +$service: string
        +$type: string
        +$meta: array
        +$metrics: array
        +$exception: Throwable
        +$parent: SpanData
        +getDuration(): int
        +getStartTime(): int
    }
}

' ──────────────────────────────────────────────
' Base Integration (DDTrace\Integrations)
' ──────────────────────────────────────────────
package "DDTrace\\Integrations" #E9ECEF {
    abstract class Integration {
        {static} +getName(): string
        {static} +addTraceAnalyticsIfEnabled(SpanData $span): void
        {static} +requiresExplicitTraceAnalyticsEnabling(): bool
        {static} +shouldLoad(string $name): bool
        {static} +toString($value): string
        {static} +handleInternalSpanServiceName(SpanData $span,\n  string $fallbackName, bool $skipFlattening): void
        {static} +handleOrphan(SpanData $span): void
    }
    note right of Integration
        All framework integrations call
        DDTrace extension functions:
        trace_method(), hook_method(),
        install_hook()
    end note
}

' ──────────────────────────────────────────────
' Laravel
' ──────────────────────────────────────────────
package "DDTrace\\Integrations\\Laravel" #EEF2FB {
    class LaravelIntegration {
        {static} +NAME: string = "laravel"
        {static} +UNNAMED_ROUTE: string = "unnamed_route"
        {static} -$serviceName: string
        ..
        {static} +requiresExplicitTraceAnalyticsEnabling(): bool
        {static} +init(): int
        {static} +isArtisanQueueCommand(): bool
        {static} +getServiceName(): string
        {static} +getLoginFromArgs($args): ?string
        {static} +getAuthIdentifier($user): string
        {static} +isLumen(SpanData $rootSpan): bool
        {static} +normalizeRouteName($routeName): string
    }
    note bottom of LaravelIntegration
        Spans: laravel.request, laravel.action,
        laravel.view.render, laravel.artisan, …
        Hooks: Illuminate\\Foundation\\Application::handle,
        Illuminate\\Routing\\Router::findRoute,
        Laravel\\Octane\\Worker::handle
        Auth: SessionGuard::attempt, Events\\Login
    end note

    class LaravelIntegrationException {
        ' Replaces blocked-request exceptions
        ' in Laravel's error handler
    }
    note right of LaravelIntegrationException
        Helper exception used to replace
        blocked-request exceptions in
        the Laravel error handler
    end note
}

' ──────────────────────────────────────────────
' Symfony
' ──────────────────────────────────────────────
package "DDTrace\\Integrations\\Symfony" #FBF3EE {
    class SymfonyIntegration {
        {static} +NAME: string = "symfony"
        {static} -$frameworkPrefix: string
        {static} -$kernel: HttpKernel
        ..
        {static} +requiresExplicitTraceAnalyticsEnabling(): bool
        {static} +init(): int
        {static} +loadSymfony(): void
        {static} +injectActionInfo($event, string $eventName,\n  SpanData $requestSpan): bool
    }
    note bottom of SymfonyIntegration
        Spans: symfony.request, symfony.controller,
        symfony.httpkernel.kernel.handle,
        symfony.console.command.run, …
        $frameworkPrefix switches "symfony" → "drupal"
        when DrupalIntegration::NAME is detected.
        Also covers Twig + 4 Symfony template engines.
    end note
}

' ──────────────────────────────────────────────
' WordPress
' ──────────────────────────────────────────────
package "DDTrace\\Integrations\\WordPress" #EEFBF3 {
    class WordPressIntegration {
        {static} +NAME: string = "wordpress"
        ..
        {static} +requiresExplicitTraceAnalyticsEnabling(): bool
        {static} +init(): int
    }
    note right of WordPressIntegration
        Two-phase load:
        1. init() hooks wp_check_php_mysql_versions
           to detect WP version >= 4
        2. Delegates to WordPressIntegrationLoader::load()
        Auth: wp_authenticate, register_new_user,
              wp_validate_auth_cookie
    end note

    class WordPressIntegrationLoader {
        {static} +extractPluginNameFromFile(string $file,\n  bool $muPlugins): string
        {static} +extractThemeNameFromFile(string $file): string
        {static} +load(): void
    }
    note right of WordPressIntegrationLoader
        Handles deferred loading of WP
        tracing hooks once version is
        confirmed. Provides plugin/theme
        name extraction from file paths.
    end note
}

' ──────────────────────────────────────────────
' Drupal
' ──────────────────────────────────────────────
package "DDTrace\\Integrations\\Drupal" #FBF0FB {
    class DrupalIntegration {
        {static} +NAME: string = "drupal"
        ..
        {static} +requiresExplicitTraceAnalyticsEnabling(): bool
        {static} +init(): int
    }
    note bottom of DrupalIntegration
        Spans: drupal.request, drupal.kernel.handle,
        drupal.kernel.boot, drupal.theme.render,
        drupal.hook.{hook}, symfony.response.send
        Hooks: DrupalKernel::handle/boot,
               ThemeManager::render,
               AccountProxy::setAccount
        Increases spans_limit to max(1500, current).
        Uses ObjectKVStore for shared hook state.
        Calls DDTrace\\set_user() for account tracking.
    end note
}

' ──────────────────────────────────────────────
' Slim
' ──────────────────────────────────────────────
package "DDTrace\\Integrations\\Slim" #FFFBEE {
    class SlimIntegration {
        {static} +NAME: string = "slim"
        ..
        {static} +init(): int
    }
    note bottom of SlimIntegration
        Spans: slim.request, slim.middleware,
        slim.route (v4), slim.route.controller (v3),
        slim.view
        Hooks: Slim\\App::__construct (version detect),
               Slim\\Router::lookupRoute (v3),
               Slim\\Routing\\RouteCollector::lookupRoute (v4),
               Slim\\Views\\Twig::render
        NOTE: Does NOT override
        requiresExplicitTraceAnalyticsEnabling()
        → requires explicit opt-in (default: true).
    end note
}

' ──────────────────────────────────────────────
' Relationships
' ──────────────────────────────────────────────

' Integration implements the DDTrace core interface
Integration ..|> DDTraceIntegration : implements

' All framework integrations extend the base
LaravelIntegration --|> Integration
SymfonyIntegration --|> Integration
WordPressIntegration --|> Integration
DrupalIntegration --|> Integration
SlimIntegration --|> Integration

' WordPress two-phase composition
WordPressIntegration ..> WordPressIntegrationLoader : delegates\nloading to

' Symfony ↔ Drupal coupling
SymfonyIntegration ..> DrupalIntegration : reads NAME constant\nto detect Drupal context

' All integrations produce/annotate SpanData
Integration ..> SpanData : uses

' LaravelIntegration exception helper
LaravelIntegration *-- LaravelIntegrationException : creates

' ──────────────────────────────────────────────
' Global note
' ──────────────────────────────────────────────
note as GlobalNote
    <b>Common Patterns across all integrations</b>
    • static init(): int → returns Integration::LOADED
    • Laravel, Symfony, WordPress, Drupal override
      requiresExplicitTraceAnalyticsEnabling() = false
      (trace analytics auto-enabled)
    • Slim inherits default = true (requires explicit enabling)
    • Route extraction sets HTTP_ROUTE, HTTP_URL, HTTP_METHOD
      tags on the root span
    • DD_HTTP_SERVER_ROUTE_BASED_NAMING env var controls
      resource naming in Laravel, Symfony, and Slim
    • Auth events tracked via Datadog AppSec API:
      track_user_login_success/failure/signup/authenticated_event_automated()
end note

@enduml
