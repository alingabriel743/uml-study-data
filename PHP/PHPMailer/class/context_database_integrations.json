      "file": "src/DDTrace/Integrations/PHPRedis/PHPRedisIntegration.php"
    },
    {
      "name": "MemcachedIntegration",
      "namespace": "DDTrace\\Integrations\\Memcached",
      "extends": "Integration",
      "constants": ["NAME='memcached'"],
      "key_methods": [
        "static init(): int",
        "static traceCommand(string $command): void",
        "static traceCommandByKey(string $command): void",
        "static traceMulti(string $command): void",
        "static traceMultiByKey(string $command): void",
        "static setCommonData(SpanData $span, string $command): void",
        "static setServerTags(SpanData $span, \\Memcached $memcached): void",
        "static markForTraceAnalytics(SpanData $span, string $command): void",
        "static obfuscateIfNeeded($params, string $glue=' '): string"
      ],
      "traced_methods": ["Memcached: add, addByKey, append, appendByKey, decrement, decrementByKey, delete, deleteMulti, deleteByKey, deleteMultiByKey, get, getMulti, getByKey, getMultiByKey, set, setMulti, setByKey, setMultiByKey, increment, incrementByKey, prepend, prependByKey, replace, replaceByKey, touch, touchByKey, flush, cas, casByKey"],
      "span_type": "Type::MEMCACHED",
      "dependencies": ["DatabaseIntegrationHelper", "Obfuscation", "SpanData", "Tag", "Type"],
      "tags_set": ["memcached.command", "memcached.query", "memcached.server_key", "memcached.cas_token", "out.host", "out.port", "db.system=memcached", "span.kind=client", "component=memcached", "db.row_count"],
      "notes": "Obfuscation controlled by DD_TRACE_MEMCACHED_OBFUSCATION. Uses Memcached::getServerList() (not getServerByKey) to avoid mutating result code. Analytics enabled for add/delete/get/set variants.",
      "file": "src/DDTrace/Integrations/Memcached/MemcachedIntegration.php"
    },
    {
      "name": "ElasticSearchIntegration (V1)",
      "namespace": "DDTrace\\Integrations\\ElasticSearch\\V1",
      "extends": "Integration",
      "constants": ["NAME='elasticsearch'"],
      "static_properties": ["$constructorCalled: bool"],
      "key_methods": [
        "static init(): int",
        "static traceClientMethod(string $name, bool $isTraceAnalyticsCandidate=false): void",
        "static traceSimpleMethod(string $class, string $name): void",
        "static traceNamespaceMethod(string $namespace, string $name): void"
      ],
      "traced_classes": [
        "Elasticsearch\\Client (__construct, bulk, clearScroll, count, create, delete, deleteByQuery, exists, explain, get, index, mget, msearch, ping, reindex, scroll, search, update, updateByQuery, ...30+ methods)",
        "Elasticsearch\\Serializers\\ArrayToJSONSerializer (serialize, deserialize)",
        "Elasticsearch\\Serializers\\EverythingToJSONSerializer (serialize, deserialize)",
        "Elasticsearch\\Serializers\\SmartSerializer (serialize, deserialize)",
        "Elasticsearch\\Endpoints\\AbstractEndpoint (performRequest)",
        "Elasticsearch\\Connections\\Connection (performRequest)"
      ],
      "dependencies": ["ElasticSearchCommon", "SpanData", "Tag", "Type"],
      "span_type": "Type::ELASTICSEARCH",
      "tags_set": ["elasticsearch.url", "elasticsearch.method", "elasticsearch.params", "elasticsearch.body", "component=elasticsearch", "span.kind=client"],
      "notes": "Dynamically discovers namespace classes from Client properties at __construct time. Uses prehook to capture $params before extractArgument() mutates them.",
      "file": "src/DDTrace/Integrations/ElasticSearch/V1/ElasticSearchIntegration.php"
    },
    {
      "name": "ElasticSearchIntegration (V8)",
      "namespace": "DDTrace\\Integrations\\ElasticSearch\\V8",
      "extends": "Integration",
      "constants": ["NAME='elasticsearch'"],
      "static_properties": ["$constructorCalled: bool", "$logNextBody: bool"],
      "key_methods": [
        "static init(): int",
        "static traceClientMethod(string $name, bool $isTraceAnalyticsCandidate=false): void",
        "static traceSimpleMethod(string $class, string $name): void",
        "static traceNamespaceMethod(string $class, string $name): void"
      ],
      "traced_classes": [
        "Elastic\\Elasticsearch\\Client (__construct, sendRequest, all ClientEndpointsTrait methods)",
        "Elastic\\Transport\\Serializer\\* (CsvSerializer, JsonSerializer, NDJsonSerializer, TextSerializer, XmlSerializer — serialize/unserialize)",
        "Elastic\\Elasticsearch\\Namespaces\\* (all namespace trait methods dynamically)"
      ],
      "dependencies": ["ElasticSearchCommon", "HookData", "SpanData", "Tag", "Type"],
      "span_type": "Type::ELASTICSEARCH",
      "tags_set": ["elasticsearch.url", "elasticsearch.method", "elasticsearch.params", "elasticsearch.body", "component=elasticsearch", "span.kind=client"],
      "notes": "V8 uses PSR-7 RequestInterface instead of raw args. Dynamically hooks NamespaceTrait methods lazily (on first access). $logNextBody flag enables body capture for search methods.",
      "file": "src/DDTrace/Integrations/ElasticSearch/V8/ElasticSearchIntegration.php"
    },
    {
      "name": "ElasticSearchCommon",
      "namespace": "DDTrace\\Integrations\\ElasticSearch",
      "type": "utility_class",
      "key_methods": [
        "static buildResourceName(string $methodName, array $params): string"
      ],
      "notes": "Builds resource name from method + relevant params (index, type). Shared between V1 and V8 integrations.",
      "file": "src/DDTrace/Integrations/ElasticSearch/ElasticSearchCommon.php"
    },
    {
      "name": "DatabaseIntegrationHelper",
      "namespace": "DDTrace\\Integrations",
      "type": "utility_class",
      "constants": ["PEER_SERVICE_SOURCES"],
