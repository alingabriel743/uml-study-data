{
  "scope": "database_integrations",
  "title": "Database Integrations",
  "diagram_type": "class",
  "project": "Datadog PHP Tracer (ddtrace)",
  "namespace_root": "DDTrace\\Integrations",

  "classes": [
    {
      "name": "Integration",
      "namespace": "DDTrace\\Integrations",
      "type": "abstract_class",
      "implements": ["\\DDTrace\\Integration"],
      "constants": ["LOADED", "NOT_AVAILABLE"],
      "key_methods": [
        "static getName(): string",
        "static init(): int",
        "static shouldLoad(string $name): bool",
        "static addTraceAnalyticsIfEnabled(SpanData $span): void",
        "static requiresExplicitTraceAnalyticsEnabling(): bool",
        "static handleInternalSpanServiceName(SpanData $span, string $fallbackName, bool $skipFlattening): void",
        "static handleOrphan(SpanData $span): void",
        "static toString($value): string"
      ],
      "file": "src/DDTrace/Integrations/Integration.php"
    },
    {
      "name": "PDOIntegration",
      "namespace": "DDTrace\\Integrations\\PDO",
      "extends": "Integration",
      "constants": ["NAME='pdo'", "CONNECTION_TAGS_KEY='connection_tags'", "DB_DRIVER_TO_SYSTEM (map: mysql, pgsql, sqlite, mssql, oracle, etc.)"],
      "key_methods": [
        "static init(): int",
        "static detectError($pdoOrStatement, SpanData $span): void",
        "static extractConnectionMetadata(array $constructorArgs): array",
        "static setCommonSpanInfo($source, SpanData $span): void",
        "static handleRasp(\\PDO $source, SpanData $span): void",
        "static injectDBIntegration($pdo, $hook, $forcedMode=null): void",
        "static useQuestionMarkPlaceholders(string $query): string",
        "private static parseDsn(string $dsn): array"
      ],
      "traced_methods": ["PDO::__construct", "PDO::connect (PHP 8.4+)", "PDO::exec", "PDO::query", "PDO::prepare", "PDO::commit", "PDOStatement::execute"],
      "span_type": "Type::SQL",
      "dependencies": ["DatabaseIntegrationHelper", "ObjectKVStore", "SpanData", "Tag", "Type", "HookData"],
      "tags_set": ["db.system", "db.type", "db.name", "db.charset", "out.host", "out.port", "db.user", "db.row_count", "span.kind=client", "component=pdo"],
      "notes": "Parses DSN regex to extract db engine/host/port/name. Supports RASP SQLi detection (DD_APPSEC_RASP_ENABLED). Supports DB client split by instance (DD_TRACE_DB_CLIENT_SPLIT_BY_INSTANCE). Named params replaced with '?' placeholders.",
      "file": "src/DDTrace/Integrations/PDO/PDOIntegration.php"
    },
    {
      "name": "MongoDBIntegration",
      "namespace": "DDTrace\\Integrations\\MongoDB",
      "extends": "Integration",
      "constants": ["NAME='mongodb'", "SYSTEM='mongodb'"],
      "key_methods": [
        "static init(): int",
        "static traceCollectionMethodWithFilter(string $method): void",
        "static traceCollectionMethodNoArgs(string $method): void",
        "static traceExecuteQuery(string $class, string $method): void",
        "static traceExecuteBulkWrite(string $class, string $method): void",
        "static traceExecuteCommand(string $class, string $method, array $knownCommands): void",
        "static setMetadata(SpanData $span, $name, $method, $database, $collection, $host, $port, $command, $rawQuery): void",
        "static serializeQuery($anythingQueryLike, bool $normalize=true): ?string",
        "static normalizeQuery($rawQuery): mixed",
        "static parseNamespace(string $namespace): array"
      ],
      "traced_classes": [
        "MongoDB\\Driver\\Manager (executeQuery, executeBulkWrite, executeCommand, executeWriteCommand, executeReadCommand, executeReadWriteCommand, selectServer)",
        "MongoDB\\Driver\\Server (executeQuery, executeBulkWrite, executeCommand variants)",
        "MongoDB\\Collection (aggregate, count, countDocuments, deleteMany, deleteOne, find, findOne, findOneAndDelete, findOneAndReplace, findOneAndUpdate, replaceOne, updateMany, updateOne, bulkWrite, drop, dropIndexes, estimatedDocumentCount, insertMany, insertOne, listIndexes, mapReduce)",
        "MongoDB\\Driver\\Query (__construct - stores filter)",
        "MongoDB\\Driver\\Command (__construct - stores cmd)",
        "MongoDB\\Driver\\BulkWrite (delete, update, insert - aggregates for span metadata)"
      ],
      "span_type": "Type::MONGO",
      "dependencies": ["DatabaseIntegrationHelper", "ObjectKVStore", "SpanData", "Tag", "Type"],
      "tags_set": ["mongodb.database", "mongodb.collection", "mongodb.query", "out.host", "out.port", "db.system=mongodb", "span.kind=client", "component=mongodb"],
      "notes": "Registers a DatadogSubscriberLoader subscriber. Normalizes/obfuscates queries (DD_TRACE_MONGODB_OBFUSCATION). Supports 100+ known MongoDB commands. Parses 'db.collection' namespace strings.",
      "file": "src/DDTrace/Integrations/MongoDB/MongoDBIntegration.php"
    },
    {
      "name": "PHPRedisIntegration",
      "namespace": "DDTrace\\Integrations\\PHPRedis",
      "extends": "Integration",
