  "distributed_tracing": {
    "AMQP": "injectContext() adds DDTrace headers into AMQPMessage application_headers; extractContext() consumes them; hasDistributedHeaders() checks presence; SpanLink created in basic_get/basic_deliver for cross-trace linking",
    "Kafka": "Producer injects DDTrace headers into producev() args[4]; Consumer checks message.headers, creates SpanLink or starts new trace span based on DD_TRACE_KAFKA_DISTRIBUTED_TRACING env flag",
    "SymfonyMessenger": "Sender injects headers via SerializerStamp context['datadog']; Consumer reads them in handleMessage prehook; respects DD_TRACE_SYMFONY_MESSENGER_DISTRIBUTED_TRACING flag"
  },

