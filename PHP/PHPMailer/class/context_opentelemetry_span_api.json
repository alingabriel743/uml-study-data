  "startSpan_flow": [
    "SpanBuilder::startSpan() → applySpanKind() sets Tag::SPAN_KIND attribute",
    "SpanBuilder::startSpan() → Context::resolve(parentContext) → ContextInterface",
    "SpanBuilder::startSpan() → Span::fromContext(parentContext) → parentSpan",
    "SpanBuilder::startSpan() → parentSpan.getContext() → parentSpanContext",
    "SpanBuilder::startSpan() → TracerSharedState::getSampler()::shouldSample(...) → SamplingResult",
    "SpanBuilder::startSpan() → DDTrace\\start_trace_span() → DDTrace\\SpanData",
    "SpanBuilder::startSpan() → DDTraceAPI\\SpanContext::createFromLocalSpan(span, sampled) → SpanContextInterface",
    "SpanBuilder::startSpan() → Span::startSpan(span, spanContext, scope, kind, parentSpan, ...) → Span",
    "SpanBuilder::startSpan() [if not sampled] → Span::wrap(spanContext) → no-op Span"
  ],

  "convention_logic": {
    "input": "DDTrace\\SpanData $span (reads $span->meta)",
    "output": "string operation name",
    "rules": [
      "http.request.method + SERVER → 'http.server.request'",
      "http.request.method + CLIENT → 'http.client.request'",
      "db.system + CLIENT → '{db.system}.query'",
      "messaging.system + messaging.operation + consumer/producer/server/client → '{messaging.system}.{messaging.operation}'",
      "rpc.system = aws-api + CLIENT → 'aws.{rpc.service}.request' or 'aws.client.request'",
      "rpc.system + CLIENT → '{rpc.system}.client.request'",
      "rpc.system + SERVER → '{rpc.system}.server.request'",
      "faas.trigger + SERVER → '{faas.trigger}.invoke'",
      "faas.invoked_provider + faas.invoked_name + CLIENT → '{provider}.{name}.invoke'",
      "graphql.operation.type → 'graphql.server.request'",
      "generic SERVER/CLIENT → '{network.protocol.name}.{kind}.request' or '{kind}.request'",
      "fallback → ''"
    ]
  },

  "important_notes": [
    "This is a DDTrace PHP bridge: OTel-compatible API stubs wrap the internal DDTrace tracing engine.",
    "SpanBuilder.startSpan() calls DDTrace\\start_trace_span() and consumes distributed tracing headers for W3C traceparent propagation.",
    "SpanContext.createFromLocalSpan() is a DDTrace-specific factory not in the OTel spec.",
    "TraceAnalyticsProcessor is a standalone utility—not a SpanProcessor in the OTel sense.",
    "Convention is used to derive Datadog operation names from OTel semantic convention attributes.",
    "Span.getDDSpan() exposes the internal DDTrace\\SpanData bridge for interoperability.",
    "SpanKind constants: KIND_INTERNAL(0), KIND_SERVER(1), KIND_CLIENT(2), KIND_PRODUCER(3), KIND_CONSUMER(4)."
  ],

