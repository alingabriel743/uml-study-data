  "key_relationships": [
    "client_handler composes client (unique_ptr ownership)",
    "client_handler composes service_config (shared_ptr)",
    "client holds vector<shared_ptr<listener_base>> (polymorphic listeners)",
    "client indexes listeners_per_product_: product → [listener_base*]",
    "engine_listener extends listener_base",
    "asm_features_listener extends listener_base",
    "engine_listener composes config_aggregator_base (one per product: ASM/ASM_DD/ASM_DATA)",
    "asm_features_listener composes config_aggregator_base::unique_ptr",
    "asm_aggregator extends config_aggregator_base",
    "asm_features_aggregator extends config_aggregator_base",
    "config produces parsed_config_key (via config_key())",
    "config produces mapped_memory (via read())",
    "parsed_config_key references product",
    "RemoteConfigState composes RemoteConfigManager",
    "RemoteConfigState composes LiveDebuggerState",
    "RemoteConfigState composes DynamicConfig",
    "DynamicConfig composes ActiveDynamicConfig (map by config_id)",
    "RemoteConfigManager fetches RemoteConfigUpdate (Add/Remove/None)",
    "LiveDebuggerCallbacks used by RemoteConfigState for probe lifecycle"
  ],

  "exported_c_functions": [
    "ddog_init_remote_config(live_debugging_enabled, appsec_activation, appsec_config): void — populates global DDTRACE_REMOTE_CONFIG_PRODUCTS/CAPABILITIES",
    "ddog_init_remote_config_state(endpoint, di_enabled): Box<RemoteConfigState>",
    "ddog_process_remote_configs(state: &mut RemoteConfigState): bool — main polling loop, dispatches Add/Remove updates",
    "ddog_remote_configs_service_env_change(state, service, env, version, tags, process_tags): bool",
    "ddog_setup_remote_config(update_config: DynamicConfigUpdate, setup: &LiveDebuggerSetup): void",
    "ddog_set_dynamic_instrumentation_enabled(state, enabled): void",
    "ddog_remote_config_alter_dynamic_config(state, config, new_value): bool",
    "ddog_remote_config_get_path(state): *const c_char",
    "ddog_rshutdown_remote_config(state): void — clears spans_map, old_config_values, unloads products",
    "ddog_shutdown_remote_config(_: Box<RemoteConfigState>): void — drops Box",
    "ddog_type_can_be_instrumented(state, typename): bool — checks allow/deny DFA"
  ],

  "polling_flow": [
    "client_handler::poll() → client::poll()",
    "client::poll() calls FFI ddog_remote_config_read(reader_) via shmem",
    "Parses newline-delimited config lines into set<config>",
    "If changed: client::process_response(new_configs)",
    "process_response: for each listener → init()",
    "process_response: for removed configs → listener->on_unapply(cfg)",
    "process_response: for new configs → listener->on_update(cfg)",
    "process_response: for each listener → commit()",
    "Rust: ddog_process_remote_configs loops manager.fetch_update()",
    "Rust Add LiveDebugger → apply_config() → callbacks.set_probe()",
    "Rust Add DynamicConfig → compute_merged_configs() → insert_new_configs() → DYNAMIC_CONFIG_UPDATE callback",
    "Rust Remove LiveDebugger → remove_config() → callbacks.remove_probe()",
    "Rust Remove ApmTracing → recompute merged or remove_old_configs()"
  ],

  "important_notes": [
    "C++ RC uses shared-memory (shmem) as transport, not HTTP polling — ddog_RemoteConfigReader reads from shmem_path",
    "Rust RC uses RemoteConfigManager from datadog_sidecar crate, also shmem-based",
    "Config key format: (datadog/<org_id> | employee)/<PRODUCT>/<config_id>/<name>",
    "DynamicConfig merges multiple active configs by priority (higher priority wins on discriminant collision)",
    "use_rc_config() logic: DI/ExceptionReplay/CodeOrigin configs only override if user has them enabled; all others always use RC value",
    "LiveDebugger probes stored in active even when di_enabled=false; installed on enable",
    "DDTRACE_REMOTE_CONFIG_PRODUCTS and DDTRACE_REMOTE_CONFIG_CAPABILITIES are global static mutable Vecs initialized once",
    "PHP tracer uses DynamicConfigUpdate function pointer as callback into PHP engine for config updates"
  ],

