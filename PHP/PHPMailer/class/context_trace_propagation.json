  "key_relationships": [
    "DDTrace\\Propagators\\TextMap implements DDTrace\\Propagator",
    "DDTrace\\SpanContext extends DDTrace\\Data\\SpanContext",
    "DDTrace\\Data\\SpanContext implements DDTrace\\Contracts\\SpanContext",
    "DDTrace\\Contracts\\SpanContext extends IteratorAggregate",
    "DDTrace\\OpenTelemetry\\API\\Trace\\SpanContext implements OpenTelemetry\\API\\Trace\\SpanContextInterface",
    "DDTrace\\Tracer implements DDTrace\\Contracts\\Tracer",
    "DDTrace\\Tracer depends_on DDTrace\\Propagator[] (aggregation by format key)",
    "DDTrace\\Propagators\\TextMap depends_on DDTrace\\Contracts\\Tracer (constructor injection)",
    "DDTrace\\Propagators\\TextMap depends_on DDTrace\\Contracts\\SpanContext (inject/extract parameter)",
    "DDTrace\\Tracer uses DDTrace\\Format (routes inject/extract to Propagator by format constant)"
  ],

  "propagation_flow": [
    "Tracer::inject(spanContext, Format::HTTP_HEADERS, &$carrier) → looks up Propagator by format → TextMap::inject(spanContext, &$carrier)",
    "TextMap::inject writes x-datadog-trace-id, x-datadog-parent-id, x-datadog-sampling-priority, x-datadog-origin, ot-baggage-* headers into $carrier",
    "Tracer::extract(Format::HTTP_HEADERS, $carrier) → looks up Propagator by format → TextMap::extract($carrier)",
    "TextMap::extract reads headers from $carrier → creates DDTrace\\SpanContext with isDistributedTracingActivationContext=true",
    "SpanContext::createAsChild(parentContext) used to link extracted remote context to local span"
  ],

  "important_notes": [
    "DDTrace\\Propagator defines Datadog-specific HTTP header constants for distributed tracing",
    "TextMap handles both TEXT_MAP (unrestricted) and HTTP_HEADERS (RFC 7230) formats via same class",
    "SpanContext is immutable; withBaggageItem returns a new instance",
    "isDistributedTracingActivationContext=true marks a remotely-extracted context (cross-service)",
    "DDTrace\\Time bridges PHP microtime to Datadog nanosecond timestamps",
    "OTel SpanContext (DDTrace\\OpenTelemetry\\API\\Trace\\SpanContext) is a separate bridge class implementing OTel SpanContextInterface",
    "GlobalTracer singleton pattern: GlobalTracer::set()/get() manage the global DDTrace\\Tracer instance"
  ],

  "source_files_analyzed": [
    "src/ddtrace_php_api.stubs.php"
  ]
