{
  "scope": "web_framework_integrations",
  "title": "Web Framework Integrations",
  "diagram_type": "class",
  "project": "Datadog PHP Tracing (DDTrace)",
  "namespace_root": "DDTrace\\Integrations",

  "classes": [
    {
      "name": "Integration",
      "type": "abstract_class",
      "namespace": "DDTrace\\Integrations",
      "implements": ["\\DDTrace\\Integration"],
      "constants": ["LOADED (from interface)"],
      "static_methods": [
        "getName(): string",
        "addTraceAnalyticsIfEnabled(SpanData $span): void",
        "requiresExplicitTraceAnalyticsEnabling(): bool (returns true)",
        "shouldLoad(string $name): bool",
        "toString($value): string",
        "handleInternalSpanServiceName(SpanData $span, string $fallbackName, bool $skipFlattening=false): void",
        "handleOrphan(SpanData $span): void"
      ],
      "dependencies": ["SpanData", "RootSpanData", "Tag"]
    },
    {
      "name": "LaravelIntegration",
      "type": "class",
      "namespace": "DDTrace\\Integrations\\Laravel",
      "extends": "Integration",
      "constants": ["NAME = 'laravel'", "UNNAMED_ROUTE = 'unnamed_route'"],
      "static_properties": ["$serviceName: string"],
      "static_methods": [
        "requiresExplicitTraceAnalyticsEnabling(): bool (returns false)",
        "isArtisanQueueCommand(): bool",
        "init(): int",
        "getServiceName(): string",
        "getLoginFromArgs($args): ?string",
        "getAuthIdentifier($user): string",
        "isLumen(SpanData $rootSpan): bool",
        "normalizeRouteName($routeName): string"
      ],
      "span_names_produced": [
        "laravel.request", "laravel.application.handle", "laravel.action",
        "laravel.event.handle", "laravel.view.render", "laravel.view",
        "lumen.view", "laravel.provider.load", "laravel.artisan"
      ],
      "hooked_targets": [
        "Illuminate\\Foundation\\Application::handle",
        "Illuminate\\Routing\\Router::findRoute",
        "Illuminate\\Routing\\Route::run",
        "Illuminate\\Http\\Response::send",
        "Illuminate\\Events\\Dispatcher::fire (Laravel < 5.8)",
        "Illuminate\\Events\\Dispatcher::dispatch (Laravel >= 5.8)",
        "Illuminate\\View\\View::render",
        "Illuminate\\View\\Engines\\CompilerEngine::get",
        "Illuminate\\Foundation\\ProviderRepository::load",
        "Illuminate\\Console\\Application::__construct",
        "Illuminate\\Auth\\SessionGuard::attempt",
        "Illuminate\\Auth\\Events\\Login::__construct",
        "Illuminate\\Auth\\Guard::login/attempt/user",
        "Illuminate\\Auth\\Events\\Authenticated::__construct",
        "Illuminate\\Auth\\Events\\Registered::__construct",
        "Laravel\\Octane\\Worker::handle"
      ],
      "dependencies": ["SpanData", "HookData", "Tag", "Type", "LumenIntegration", "LaravelIntegrationException"]
    },
    {
      "name": "LaravelIntegrationException",
      "type": "class",
      "namespace": "DDTrace\\Integrations\\Laravel",
      "note": "Helper exception used to replace blocked-request exceptions in Laravel error handler"
    },
    {
      "name": "SymfonyIntegration",
      "type": "class",
      "namespace": "DDTrace\\Integrations\\Symfony",
      "extends": "Integration",
      "constants": ["NAME = 'symfony'"],
      "static_properties": [
        "$frameworkPrefix: string (default: 'symfony', can switch to 'drupal')",
        "$kernel (stores HttpKernel instance)"
      ],
      "static_methods": [
        "requiresExplicitTraceAnalyticsEnabling(): bool (returns false)",
        "init(): int",
        "loadSymfony(): void",
        "injectActionInfo($event, string $eventName, SpanData $requestSpan): bool"
      ],
      "span_names_produced": [
        "symfony.request", "symfony.httpkernel.kernel.handle", "symfony.httpkernel.kernel.boot",
        "symfony.kernel.handle", "symfony.kernel.handleException", "symfony.console.command.run",
        "symfony.controller", "symfony.{eventName}", "symfony.templating.render"
      ],
      "hooked_targets": [
        "Symfony\\Component\\HttpKernel\\Kernel::handle/boot",
        "Symfony\\Component\\HttpKernel\\HttpKernel::handle/handleException/handleThrowable/__construct",
        "Symfony\\Component\\EventDispatcher\\EventDispatcher::dispatch",
        "Drupal\\Component\\EventDispatcher\\ContainerAwareEventDispatcher::dispatch",
        "Symfony\\Component\\Console\\Command\\Command::run",
        "Symfony\\Component\\Console\\Application::renderException/renderThrowable",
        "Doctrine\\ORM\\UnitOfWork::executeInserts",
        "Symfony\\Component\\Security\\Guard\\* (login hooks Symfony < 5)",
        "Symfony\\Component\\Security\\Http\\Firewall\\AbstractAuthenticationListener::onSuccess/onFailure (Symfony 5-6)",
        "Symfony\\Component\\Security\\Http\\Authenticator\\FormLoginAuthenticator (Symfony >= 6)",
        "Symfony\\Component\\Security\\Core\\Authorization\\AccessDecisionManagerInterface::decide",
        "Twig\\Environment::render + 4 Symfony templating engines"
      ],
      "cross_integration_coupling": "References DrupalIntegration::NAME to detect Drupal-flavored Symfony requests; sets $frameworkPrefix = 'drupal'",
      "dependencies": ["SpanData", "HookData", "Tag", "Type", "Normalizer", "DrupalIntegration", "EndpointCatalog"]
    },
    {
      "name": "WordPressIntegration",
      "type": "class",
      "namespace": "DDTrace\\Integrations\\WordPress",
      "extends": "Integration",
      "constants": ["NAME = 'wordpress'"],
      "static_methods": [
        "requiresExplicitTraceAnalyticsEnabling(): bool (returns false)",
        "init(): int"
      ],
      "init_logic": "Hooks wp_check_php_mysql_versions to detect WP version >= 4, then delegates to WordPressIntegrationLoader::load(). Also hooks WP::main (path params), wp_authenticate (login tracking), register_new_user (signup), wp_validate_auth_cookie (session auth).",
      "dependencies": ["Integration", "WordPressIntegrationLoader"]
    },
    {
      "name": "WordPressIntegrationLoader",
      "type": "class",
      "namespace": "DDTrace\\Integrations\\WordPress",
      "extends": "none (standalone utility)",
      "static_methods": [
        "extractPluginNameFromFile(string $file, bool $muPlugins = false): string",
        "extractThemeNameFromFile(string $file): string",
        "load(): void (inferred — called by WordPressIntegration::init)"
      ],
      "note": "Handles deferred loading of WordPress-specific tracing hooks once WP version is confirmed. Provides plugin/theme name extraction from file paths.",
      "dependencies": ["Integration", "SpanData", "HookData", "Tag", "Type", "Normalizer"]
    },
    {
      "name": "DrupalIntegration",
      "type": "class",
      "namespace": "DDTrace\\Integrations\\Drupal",
      "extends": "Integration",
      "constants": ["NAME = 'drupal'"],
      "static_methods": [
        "requiresExplicitTraceAnalyticsEnabling(): bool (returns false)",
        "init(): int"
      ],
      "span_names_produced": [
        "drupal.request", "drupal.kernel.handle", "drupal.kernel.boot",
        "drupal.httpkernel.handle", "drupal.theme.render", "drupal.hook.{hook}",
        "symfony.response.send"
      ],
      "hooked_targets": [
        "Drupal\\Core\\DrupalKernel::handle/boot",
        "Stack\\StackedHttpKernel::handle (Drupal 9-)",
        "Drupal\\Core\\StackMiddleware\\StackedHttpKernel::handle (Drupal 10+)",
        "Drupal\\Core\\Theme\\ThemeManager::render/setThemeRegistry",
        "Drupal\\Core\\Theme\\Registry::__construct",
        "Drupal\\Core\\EventSubscriber\\MainContentViewSubscriber::__construct/onViewRenderArray",
        "Drupal\\Core\\Extension\\ModuleHandler::invokeAllWith (cron hooks)",
        "Symfony\\Component\\HttpFoundation\\Response::send",
        "Drupal\\Core\\Session\\AccountProxy::setAccount"
      ],
      "special_behaviors": [
        "Increases spans_limit to max(1500, current) on init",
        "Uses ObjectKVStore to share protected object state across hooks",
        "Calls DDTrace\\set_user() for Drupal account tracking",
        "Detects Drupal 9 vs 10 StackedHttpKernel class name difference"
      ],
      "dependencies": ["SpanData", "HookData", "Tag", "Type", "ObjectKVStore"]
    },
    {
      "name": "SlimIntegration",
      "type": "class",
      "namespace": "DDTrace\\Integrations\\Slim",
      "extends": "Integration",
      "constants": ["NAME = 'slim'"],
      "static_methods": ["init(): int"],
      "note": "No requiresExplicitTraceAnalyticsEnabling() override (inherits default: true)",
      "init_logic": "Hooks Slim\\App::__construct; detects version (3 or 4) and sets up version-specific routing hooks. v3: hooks Slim\\Router::lookupRoute. v4: hooks Slim\\Routing\\RouteCollector::lookupRoute + MiddlewareDispatcher::addMiddleware. Common: traces RequestResponse/__invoke strategies and Slim\\Views\\Twig::render.",
      "span_names_produced": [
        "slim.request", "slim.middleware", "slim.route (v4)",
        "slim.route.controller (v3)", "slim.view"
      ],
      "hooked_targets": [
        "Slim\\App::__construct",
        "Slim\\Router::lookupRoute (v3)",
        "Slim\\Routing\\RouteCollector::lookupRoute (v4)",
        "Slim\\MiddlewareDispatcher::addMiddleware (v4)",
        "Slim\\Handlers\\Strategies\\RequestResponse::__invoke",
        "Slim\\Handlers\\Strategies\\RequestResponseArgs::__invoke",
        "Slim\\Views\\Twig::render"
      ],
      "dependencies": ["SpanData", "Tag", "Type", "ServerRequestInterface", "RouteContext"]
    }
  ],

  "key_relationships": [
    "LaravelIntegration extends Integration",
    "SymfonyIntegration extends Integration",
    "WordPressIntegration extends Integration",
    "DrupalIntegration extends Integration",
    "SlimIntegration extends Integration",
    "Integration implements \\DDTrace\\Integration (interface)",
    "WordPressIntegration delegates_to WordPressIntegrationLoader (composition via static call)",
    "SymfonyIntegration references DrupalIntegration (uses DrupalIntegration::NAME constant to detect Drupal context)",
    "LaravelIntegration references LumenIntegration (uses LumenIntegration::NAME for view span naming)",
    "DrupalIntegration is traced by SymfonyIntegration (Symfony kernel hooks also cover Drupal's DrupalKernel)"
  ],

  "common_patterns": [
    "All integrations: static init(): int returns Integration::LOADED",
    "All framework integrations override requiresExplicitTraceAnalyticsEnabling() to return false (auto-enable analytics)",
    "SlimIntegration does NOT override requiresExplicitTraceAnalyticsEnabling() — requires explicit enabling",
    "All use DDTrace extension functions: trace_method(), hook_method(), install_hook()",
    "Auth tracking via \\datadog\\appsec\\track_user_login_success/failure/signup/authenticated_event_automated()",
    "Route extraction sets HTTP_ROUTE, HTTP_URL, HTTP_METHOD tags on root span",
    "DD_HTTP_SERVER_ROUTE_BASED_NAMING env var controls resource naming across Laravel, Symfony, Slim"
  ],

  "source_files_analyzed": [
    "src/DDTrace/Integrations/Integration.php",
    "src/DDTrace/Integrations/Laravel/LaravelIntegration.php",
    "src/DDTrace/Integrations/Symfony/SymfonyIntegration.php",
    "src/DDTrace/Integrations/WordPress/WordPressIntegration.php",
    "src/DDTrace/Integrations/WordPress/WordPressIntegrationLoader.php",
    "src/DDTrace/Integrations/Drupal/DrupalIntegration.php",
    "src/DDTrace/Integrations/Slim/SlimIntegration.php"
  ],

  "important_notes": "This is the Datadog PHP APM tracer. Each integration auto-instruments a PHP web framework by hooking into framework internals using DDTrace extension primitives (trace_method, hook_method, install_hook). SymfonyIntegration is shared between pure Symfony apps and Drupal (which runs on Symfony's HttpKernel); $frameworkPrefix switches between 'symfony' and 'drupal' at runtime. WordPressIntegration uses a two-phase load: init() detects WP version, then delegates to WordPressIntegrationLoader::load() for the actual hooks. DrupalIntegration sets a higher spans_limit (1500) due to Drupal's complex render pipeline."
}
