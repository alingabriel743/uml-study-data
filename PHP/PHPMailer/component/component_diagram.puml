@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Datadog PHP Tracer — Component Architecture

' ─────────────────────────────────────────────
' External PHP Application
' ─────────────────────────────────────────────
package "PHP Application" #D6EAF8 {
    [User PHP App] as phpapp
}

' ─────────────────────────────────────────────
' Instrumentation & Setup Layer
' ─────────────────────────────────────────────
package "Instrumentation & Setup" #EAF4FB {
    [Datadog Installer\n(datadog-setup.php)] as installer
    note right of installer
      Manages PHP INI settings,
      extension installation,
      and config get/set/list
    end note

    [PHP C Extension\n(ddtrace ext)] as cext
}

' ─────────────────────────────────────────────
' Core DDTrace Tracing Layer
' ─────────────────────────────────────────────
package "Core Tracing (DDTrace)" #EBF5EB {
    [Tracer] as tracer
    [Span & SpanContext] as span
    [Scope & ScopeManager] as scope
    [Propagator\n(TextMap / Noop)] as propagator
    [Transport\n(Internal / Noop)] as transport
    [Logging] as logging
}

' ─────────────────────────────────────────────
' OpenTelemetry Bridge Layer
' ─────────────────────────────────────────────
package "OpenTelemetry Bridge" #FEF9E7 {
    [OTel Span & SpanContext] as otelspan
    [OTel SpanBuilder] as otelbuilder
    [OTel Context & Convention] as otelctx
    [OTel Configuration] as otelconfig
    package "Resource Detectors" #FDF2E9 {
        [Environment Detector] as detenv
        [Host Detector] as dethost
        [Service Detector] as detservice
    }
}

' ─────────────────────────────────────────────
' API Bridge Layer
' ─────────────────────────────────────────────
package "API Bridge (src/bridge)" #F5EEF8 {
    [DDTrace PHP API Stubs] as apistubs
    [Tracer Bridge] as tracerbridge
    [OpenTelemetry File Bridge] as otelbridge
}

' ─────────────────────────────────────────────
' Application Security (AppSec) Module
' ─────────────────────────────────────────────
package "Application Security (AppSec)" #FDEDEC {
    [AppSec Extension Module] as appsec
    [XML / JSON Format Converters] as converters
    note right of appsec
      Runtime Application
      Self-Protection (RASP)
      integrated via PHP extension
    end note
}

' ─────────────────────────────────────────────
' Integration Test Web Applications
' ─────────────────────────────────────────────
package "Integration Test Apps" #EAECEE {
    [Laravel 8.x App] as laravel
    [Symfony 6.2 App] as symfony
    [RoadRunner App] as roadrunner
    [FrankenPHP App] as frankenphp
    [LLM / Payment Endpoints] as llm
}

' ─────────────────────────────────────────────
' CI/CD Pipeline
' ─────────────────────────────────────────────
package "CI/CD Pipeline (.gitlab)" #EBEDEF {
    [Pipeline Generator\n(Common / Shared)] as ci_common
    [Tracer Pipeline Generator] as ci_tracer
    [AppSec Pipeline Generator] as ci_appsec
    [Profiler Pipeline Generator] as ci_profiler
    [Package Pipeline Generator] as ci_package
}

' ─────────────────────────────────────────────
' External Datadog Backend
' ─────────────────────────────────────────────
package "Datadog Backend (External)" #D5F5E3 {
    [Datadog Agent] as ddagent
    [Datadog APM / Tracing UI] as ddui
}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' PHP App → Instrumentation
phpapp --> installer : installs / configures
phpapp --> cext : hooked at runtime

' Installer → Extension
installer --> cext : activates via php.ini

' Extension → Core Tracer
cext --> tracer : bootstraps tracing

' Core Tracer internals
tracer --> span : creates / manages
tracer --> scope : manages active scope
tracer --> propagator : inject / extract context
tracer --> transport : flushes trace data
tracer --> logging : emits log output

' API Bridge → Core Tracer
apistubs --> tracer : provides public PHP API
tracerbridge --> tracer : delegates calls
otelbridge --> otelspan : routes OTel spans

' OpenTelemetry Bridge → Core
otelspan --> tracer : wraps DDTrace Tracer
otelbuilder --> otelspan : builds OTel spans
otelctx --> otelspan : attaches context
otelconfig --> tracer : configures via DDTrace
detenv --> otelconfig : detects env resources
dethost --> otelconfig : detects host resources
detservice --> otelconfig : detects service resources

' AppSec → Extension
appsec --> cext : hooks via PHP extension
appsec --> converters : parses payloads

' Transport → Datadog Backend
transport --> ddagent : sends trace data (HTTP)
ddagent --> ddui : forwards to APM

' Integration Test Apps → AppSec / Tracer
laravel --> apistubs : traced via DDTrace
symfony --> apistubs : traced via DDTrace
roadrunner --> apistubs : traced via DDTrace
frankenphp --> apistubs : traced via DDTrace
llm --> apistubs : traced via DDTrace

' CI/CD → components
ci_common --> ci_tracer : composes pipelines
ci_common --> ci_appsec : composes pipelines
ci_common --> ci_profiler : composes pipelines
ci_common --> ci_package : composes pipelines

@enduml
