{
  "scope": "noop_tracer_flow",
  "title": "No-op Tracer and Span Flow",
  "diagram_type": "sequence",
  "key_participants": [
    "Application",
    "GlobalTracer",
    "NoopTracer",
    "NoopScope",
    "NoopSpan",
    "NoopSpanContext",
    "NoopScopeManager",
    "DDTrace\\Tracer (real)",
    "dd_trace_disable_in_request (C ext)",
    "ddtrace_config_trace_enabled (C ext)"
  ],
  "trigger_conditions": [
    "ddtrace PHP extension NOT loaded → GlobalTracer::get() returns NoopTracer::create()",
    "GlobalTracer::set() never called (bootstrap) → GlobalTracer::get() falls back to NoopTracer",
    "Tracer.php: !config['enabled'] OR !ddtrace_config_trace_enabled() → startSpan() returns NoopSpan::create()",
    "dd_trace_disable_in_request() called at runtime → disables all instrumentation hooks for remainder of request"
  ],
  "interaction_flow": [
    "Application → GlobalTracer: get()",
    "GlobalTracer → GlobalTracer: check self::$instance (null?)",
    "GlobalTracer → GlobalTracer: extension_loaded('ddtrace') && class_exists(Tracer)?",
    "alt [ddtrace extension missing OR Tracer class missing]: GlobalTracer → NoopTracer: create() → new NoopTracer()",
    "GlobalTracer → Application: return NoopTracer instance",

    "Application → NoopTracer: startSpan(operationName, options=[])",
    "NoopTracer → NoopSpan: create() → new NoopSpan()",
    "NoopTracer → Application: return NoopSpan (getOperationName='noop_span')",

    "Application → NoopTracer: startActiveSpan(operationName, options=[])",
    "NoopTracer → NoopScope: create() → new NoopScope()",
    "NoopTracer → Application: return NoopScope",

    "Application → NoopScope: getSpan()",
    "NoopScope → NoopSpan: create() → new NoopSpan()",
    "NoopScope → Application: return NoopSpan",

    "Application → NoopSpan: setTag(key, value) → [no-op, void]",
    "Application → NoopSpan: log(fields, timestamp) → [no-op, void]",
    "Application → NoopSpan: finish(finishTime) → [no-op, void]",
    "Application → NoopSpan: getContext()",
    "NoopSpan → NoopSpanContext: create() → new NoopSpanContext()",
    "NoopSpan → Application: return NoopSpanContext",

    "Application → NoopTracer: getScopeManager()",
    "NoopTracer → NoopScopeManager: new NoopScopeManager()",
    "NoopTracer → Application: return NoopScopeManager",

    "Application → NoopScopeManager: activate(span, finishSpanOnClose)",
    "NoopScopeManager → NoopScope: create()",
    "NoopScopeManager → Application: return NoopScope",

    "Application → NoopScopeManager: getActive()",
    "NoopScopeManager → NoopScope: create()",
    "NoopScopeManager → Application: return NoopScope",

    "Application → NoopTracer: inject(spanContext, format, &carrier) → [no-op, void]",
    "Application → NoopTracer: extract(format, carrier)",
    "NoopTracer → NoopSpanContext: create()",
    "NoopTracer → Application: return NoopSpanContext",

    "Application → NoopTracer: flush() → [no-op, void]",
    "Application → NoopTracer: getPrioritySampling() → null",
    "Application → NoopTracer: getTracesAsArray() → []",
    "Application → NoopTracer: getTracesCount() → 0",
    "Application → NoopTracer: limited() → true",

    "--- Runtime disable path (real Tracer, not NoopTracer) ---",
    "Application → dd_trace_disable_in_request(): bool (C ext function)",
    "dd_trace_disable_in_request → DDTrace\\Tracer: hooks removed for rest of request",
    "Application → DDTrace\\Tracer: startSpan(operationName)",
    "DDTrace\\Tracer → ddtrace_config_trace_enabled(): check DD_TRACE_ENABLED",
    "alt [!config['enabled'] OR !ddtrace_config_trace_enabled()]: DDTrace\\Tracer → NoopSpan: create()",
    "DDTrace\\Tracer → Application: return NoopSpan"
  ],
  "key_relationships": [
    "NoopTracer implements DDTrace\\Contracts\\Tracer (TracerInterface)",
    "NoopSpan implements DDTrace\\Contracts\\Span (SpanInterface)",
    "NoopScope implements DDTrace\\Contracts\\Scope (ScopeInterface)",
    "NoopScopeManager implements DDTrace\\Contracts\\ScopeManager (ScopeManagerInterface)",
    "NoopSpanContext implements DDTrace\\Contracts\\SpanContext (SpanContextInterface)",
    "GlobalTracer holds static singleton TracerInterface; falls back to NoopTracer::create() if extension absent",
    "NoopTracer creates NoopSpan, NoopScope, NoopScopeManager, NoopSpanContext (all via static ::create())",
    "NoopScope creates NoopSpan via getSpan()",
    "NoopSpan creates NoopSpanContext via getContext()",
    "NoopScopeManager creates NoopScope via activate() and getActive()",
    "DDTrace\\Tracer (real) falls back to NoopSpan::create() when tracing disabled",
    "NoopSpanContext returns EmptyIterator from getIterator(); all baggage operations are no-ops"
  ],
  "noop_return_values": {
    "NoopTracer.limited()": "true",
    "NoopTracer.getPrioritySampling()": "null",
    "NoopTracer.getTracesAsArray()": "[]",
    "NoopTracer.getTracesCount()": "0",
    "NoopSpan.getOperationName()": "'noop_span'",
    "NoopSpan.getTraceId()": "''",
    "NoopSpan.getSpanId()": "''",
    "NoopSpan.getParentId()": "null",
    "NoopSpan.hasError()": "false",
    "NoopSpan.isFinished()": "false",
    "NoopSpan.getStartTime()": "0",
    "NoopSpan.getDuration()": "0",
    "NoopSpan.getAllTags()": "[]",
    "NoopSpan.getAllBaggageItems()": "[]",
    "NoopSpan.getMetrics()": "[]",
    "NoopSpanContext.getTraceId()": "''",
    "NoopSpanContext.isHostRoot()": "false",
    "NoopSpanContext.isDistributedTracingActivationContext()": "false",
    "NoopSpanContext.getPropagatedPrioritySampling()": "0"
  },
  "ext_functions": {
    "dd_trace_disable_in_request()": "C extension function; disables all tracing hooks for the current HTTP request; returns bool",
    "ddtrace_config_trace_enabled()": "C extension function; checks DD_TRACE_ENABLED ini/env config; returns bool"
  },
  "important_notes": [
    "All Noop classes are final and ported from opentracing/opentracing-php reference implementation",
    "NoopTracer.limited() always returns true — signals to callers that tracer is in degraded/disabled mode",
    "GlobalTracer::get() sets instance on first call; bootstrap docs say 'Prior to GlobalTracer::set, all spans are noops'",
    "dd_trace_disable_in_request() affects hook execution (C level); the PHP Tracer.startSpan() also guards with ddtrace_config_trace_enabled()",
    "NoopScope.close() is a no-op — no span is finished; NoopScopeManager.close() is also a no-op",
    "NoopSpanContext.withBaggageItem() returns a new NoopSpanContext instance (immutable pattern but still no-op)",
    "inject() is a true void no-op — carrier is never modified under NoopTracer"
  ],
  "source_files_analyzed": [
    "src/api/NoopTracer.php",
    "src/api/NoopSpan.php",
    "src/api/NoopScope.php",
    "src/api/NoopSpanContext.php",
    "src/api/NoopScopeManager.php",
    "src/api/GlobalTracer.php",
    "src/DDTrace/Tracer.php (relevant sections)",
    "ext/ddtrace.stub.php (dd_trace_disable_in_request, ddtrace_config_trace_enabled)",
    "tests/ext/sandbox-regression/disable_tracing_disables_tracing.phpt"
  ]
}
