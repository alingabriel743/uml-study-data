{
  "scope": "php_binary_discovery",
  "title": "PHP Binary Discovery and Prerequisite Checking",
  "diagram_type": "sequence",
  "key_participants": [
    "install()",
    "require_binaries_or_exit()",
    "search_php_binaries()",
    "build_known_command_names_matrix()",
    "resolve_command_full_path()",
    "check_library_prerequisite_or_exit()",
    "check_php_ext_prerequisite_or_exit()",
    "search_for_working_ldconfig()",
    "OS/Shell"
  ],
  "interaction_flow": [
    "install($options) → check_library_prerequisite_or_exit('libcurl')",
    "install($options) → check_library_prerequisite_or_exit('libgcc_s')",
    "install($options) [if profiling && !alpine] → check_library_prerequisite_or_exit('libdl.so')",
    "install($options) [if profiling && !alpine] → check_library_prerequisite_or_exit('libpthread')",
    "install($options) [if profiling && !alpine] → check_library_prerequisite_or_exit('librt')",
    "check_library_prerequisite_or_exit() [Windows] → return (no-op)",
    "check_library_prerequisite_or_exit() [Alpine] → execute_or_exit: find /usr/local/lib /usr/lib -name '*{lib}*.so*'",
    "check_library_prerequisite_or_exit() [Linux] → search_for_working_ldconfig()",
    "search_for_working_ldconfig() → OS/Shell: find {/sbin,/usr/sbin,...} -name ldconfig (cached static)",
    "search_for_working_ldconfig() [fallback] → iterate $PATH entries",
    "search_for_working_ldconfig() [not found] → return bare 'ldconfig' string",
    "check_library_prerequisite_or_exit() [Linux] → execute_or_exit: ldconfig -p | grep {lib}",
    "check_library_prerequisite_or_exit() [empty result] → print_error_and_exit()",
    "install($options) → require_binaries_or_exit($options)",
    "require_binaries_or_exit() [no --php-bin] → search_php_binaries()",
    "require_binaries_or_exit() [--php-bin=all] → search_php_binaries()",
    "require_binaries_or_exit() [--php-bin=<cmd>] → resolve_command_full_path($command)",
    "require_binaries_or_exit() [not found] → print_error_and_exit()",
    "require_binaries_or_exit() [no --php-bin] → pick_binaries_interactive($options, results)",
    "search_php_binaries($prefix='') → build_known_command_names_matrix()",
    "build_known_command_names_matrix() → get_supported_php_versions()",
    "build_known_command_names_matrix() → return unique array: [php, php-fpm, php{M}, php{M}{m}, php{M}.{m}, php{M}-fpm, ... (+ .exe on Windows)]",
    "search_php_binaries() → resolve_command_full_path($command) [for each in matrix, PATH lookup]",
    "resolve_command_full_path() [Linux] → OS/Shell: command -v {command}",
    "resolve_command_full_path() [Windows] → OS/Shell: where {command}",
    "resolve_command_full_path() → realpath($path) [resolve symlinks]",
    "search_php_binaries() [Linux] → build Remi Safe paths: /opt/remi/php{M}{m}/root/usr/sbin",
    "search_php_binaries() [Linux] → build Plesk paths: /opt/plesk/php/{version}/bin",
    "search_php_binaries() [Linux] → OS/Shell: find -L {std+remi+plesk paths} -type f \\( -name php -o ... \\)",
    "search_php_binaries() [Windows] → scandir boot disk + Chocolatey dir for php* dirs",
    "search_php_binaries() → deduplicate via realpath()",
    "search_php_binaries() → file_get_contents($path, 0, 2) === '#!' [shebang check per binary]",
    "search_php_binaries() → return [command => {shebang: bool, path: string}]",
    "install() → foreach selectedBinaries: check_php_ext_prerequisite_or_exit($fullPath, 'json')",
    "check_php_ext_prerequisite_or_exit($binary, $extName) → OS/Shell: {binary} -m",
    "check_php_ext_prerequisite_or_exit() [null/no [PHP Modules]] → echo WARNING",
    "check_php_ext_prerequisite_or_exit() [ext missing] → print_error_and_exit()"
  ],
  "key_relationships": [
    "install() orchestrates all prereq checks and binary discovery",
    "require_binaries_or_exit() delegates search to search_php_binaries()",
    "search_php_binaries() depends_on build_known_command_names_matrix() and resolve_command_full_path()",
    "build_known_command_names_matrix() depends_on get_supported_php_versions()",
    "check_library_prerequisite_or_exit() depends_on search_for_working_ldconfig() (non-Alpine Linux only)",
    "search_for_working_ldconfig() uses static cache (singleton pattern)"
  ],
  "branching_conditions": {
    "IS_WINDOWS": "Skips library checks; uses 'where' for path lookup; adds .exe suffix; scans boot disk + Chocolatey",
    "is_alpine()": "Uses 'find' instead of ldconfig to locate shared libraries",
    "OPT_ENABLE_PROFILING": "Additional library prereqs: libdl.so, libpthread, librt (non-Alpine only)",
    "OPT_PHP_BIN empty": "Falls back to interactive binary selection via pick_binaries_interactive()",
    "OPT_PHP_BIN == 'all'": "Calls search_php_binaries() and filters out shebang (script wrapper) binaries",
    "shebang check": "Filters out script wrappers from results when 'all' is used"
  },
  "important_notes": "search_for_working_ldconfig() is cached with static $path. Command name matrix covers all versioned variants (php7, php74, php7.4, php7-fpm, etc.) for all supported versions. Binary search covers standard paths + Remi Safe (/opt/remi) + Plesk (/opt/plesk/php) on Linux. Deduplication via realpath(). check_php_ext_prerequisite_or_exit() is called per binary (not globally) for 'json' extension. Library prereqs are global (called once in install()).",
  "source_files_analyzed": ["datadog-setup.php"],
  "key_function_signatures": {
    "search_php_binaries": "function search_php_binaries($prefix = ''): array",
    "resolve_command_full_path": "function resolve_command_full_path($command): string|false",
    "build_known_command_names_matrix": "function build_known_command_names_matrix(): array",
    "check_library_prerequisite_or_exit": "function check_library_prerequisite_or_exit($requiredLibrary): void",
    "check_php_ext_prerequisite_or_exit": "function check_php_ext_prerequisite_or_exit($binary, $extName): void",
    "search_for_working_ldconfig": "function search_for_working_ldconfig(): string",
    "require_binaries_or_exit": "function require_binaries_or_exit($options): array",
    "install": "function install($options): void"
  }
}
