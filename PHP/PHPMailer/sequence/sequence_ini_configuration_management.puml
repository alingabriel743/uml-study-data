@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    ParticipantBackgroundColor #F8F9FA
    ParticipantBorderColor #495057
    ActorBackgroundColor #F8F9FA
    ActorBorderColor #495057
    BoxBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    NoteBackgroundColor #FFF9C4
    NoteBorderColor #F9A825
    GroupBorderColor #6C757D
    GroupHeaderFontColor #212529
}

title INI Configuration Management Flow

actor "User (CLI)" as User
participant "main()" as Main
participant "parse_validate_user_options()" as ParseOpts
participant "cmd_config_list()" as CmdList
participant "cmd_config_get()" as CmdGet
participant "cmd_config_set()" as CmdSet
participant "config_list()" as ConfigList
participant "require_binaries_or_exit()" as RequireBin
participant "ini_values()" as IniValues
participant "find_all_ini_files()" as FindAllIni
participant "find_main_ini_files()" as FindMainIni
participant "parse_ini_setting()" as ParseIniSetting
participant "update_ini_setting()" as UpdateIni
participant "IniRecord" as IniRecord
database "INI File\n(filesystem)" as IniFile

== CLI Invocation & Argument Parsing ==

User -> Main: php datadog-setup.php config [list|get|set]\n--php-bin <bin> -d <setting>[=<value>]
activate Main

Main -> ParseOpts: parse_validate_user_options()
activate ParseOpts
note right of ParseOpts
  Parses and normalises argv:
  resolves CMD_CONFIG_LIST /
  CMD_CONFIG_GET / CMD_CONFIG_SET
  and options['d'], options[OPT_PHP_BIN]
end note
ParseOpts --> Main: {cmd: CMD_CONFIG_*, opts: normalizedOptions}
deactivate ParseOpts

== Config List Flow ==

alt CMD_CONFIG_LIST
    Main -> CmdList: cmd_config_list(options)
    activate CmdList

    CmdList -> ConfigList: config_list(options)
    activate ConfigList

    ConfigList -> ConfigList: get_ini_settings('','','')\n→ known Datadog settings array
    ConfigList -> RequireBin: require_binaries_or_exit(options)
    activate RequireBin
    RequireBin --> ConfigList: {command => fullPath} map
    deactivate RequireBin

    loop for each PHP binary
        ConfigList -> IniValues: ini_values(fullPath)
        activate IniValues
        note right of IniValues
          Executes: php -i
          Parses: INI_MAIN, INI_SCANDIR,
          EXTENSION_DIR, PHP_VER, etc.
        end note
        IniValues --> ConfigList: phpProps {INI_MAIN, INI_SCANDIR, EXTENSION_DIR, …}
        deactivate IniValues

        ConfigList -> FindAllIni: find_all_ini_files(phpProps)
        activate FindAllIni
        note right of FindAllIni
          Scans conf.d dirs;
          prioritises 98-ddtrace.ini.
          Handles Debian split SAPI dirs
          (cli/apache2/fpm).
        end note
        FindAllIni --> ConfigList: iniFilePaths[]
        deactivate FindAllIni

        loop for each INI file path
            ConfigList -> IniFile: parse_ini_file(iniFilePath)
            IniFile --> ConfigList: parsed key/value pairs
        end

        ConfigList -> IniRecord: new IniRecord(setting, currentValue,\ndefaultValue, iniFile, binary)
        activate IniRecord
        IniRecord --> ConfigList: IniRecord instance
        deactivate IniRecord
    end

    ConfigList --> CmdList: IniRecord[]
    deactivate ConfigList

    loop for each IniRecord
        CmdList -> IniRecord: println()
        activate IniRecord
        IniRecord --> User: "setting = value;\n  default: X, binary: Y, INI file: Z"
        deactivate IniRecord
    end

    deactivate CmdList

== Config Get Flow ==

else CMD_CONFIG_GET
    Main -> CmdGet: cmd_config_get(options)
    activate CmdGet

    alt options['d'] missing
        CmdGet --> User: print_help() and exit
    else options['d'] provided
        CmdGet -> ConfigList: config_list(options)
        activate ConfigList
        ConfigList --> CmdGet: IniRecord[] (indexed by setting name)
        deactivate ConfigList

        loop for each requested -d setting
            alt setting found in IniRecord index
                CmdGet -> IniRecord: println()
                activate IniRecord
                IniRecord --> User: "setting = value;\n  default: X, binary: Y, INI file: Z"
                deactivate IniRecord
            else setting not found
                CmdGet --> User: "; setting = undefined;\n  is missing in INI files"
            end
        end
    end

    deactivate CmdGet

== Config Set Flow ==

else CMD_CONFIG_SET
    Main -> CmdSet: cmd_config_set(options)
    activate CmdSet

    alt options['d'] missing
        CmdSet --> User: print_help() and exit
    else options['d'] provided

        CmdSet -> RequireBin: require_binaries_or_exit(options)
        activate RequireBin
        RequireBin --> CmdSet: {command => fullPath} map
        deactivate RequireBin

        loop for each PHP binary
            CmdSet -> IniValues: ini_values(fullPath)
            activate IniValues
            IniValues --> CmdSet: phpProps {INI_MAIN, INI_SCANDIR, …}
            deactivate IniValues

            loop for each -d cliIniSetting
                CmdSet -> ParseIniSetting: parse_ini_setting(cliIniSetting)
                activate ParseIniSetting
                note right of ParseIniSetting
                  Splits on '=', validates via
                  parse_ini_string().
                  Returns [key, value] or false.
                end note
                ParseIniSetting --> CmdSet: [key, value] | false
                deactivate ParseIniSetting

                CmdSet -> FindAllIni: find_all_ini_files(phpProps)
                activate FindAllIni
                FindAllIni --> CmdSet: iniFilePaths[]
                deactivate FindAllIni

                group Pass 1 — Update Active (Uncommented) Entries
                    loop for each INI file
                        CmdSet -> UpdateIni: update_ini_setting(setting, iniFile,\npromoteComment=false)
                        activate UpdateIni
                        UpdateIni -> IniFile: file_get_contents(iniFile)
                        IniFile --> UpdateIni: content
                        UpdateIni -> UpdateIni: preg_replace(regex, 'key = value')
                        UpdateIni -> IniFile: file_put_contents(iniFile, updatedContent)
                        UpdateIni --> CmdSet: matchCount (0=not found,\n>0=updated, false=error)
                        deactivate UpdateIni

                        alt matchCount >= 2
                            CmdSet --> User: warn — duplicate entries found
                        end
                    end
                end

                alt matchCount >= 1 (Pass 1 succeeded)
                    CmdSet --> User: setting updated (active entry)
                else

                    group Pass 2 — Promote Commented Entries
                        loop for each INI file
                            CmdSet -> UpdateIni: update_ini_setting(setting, iniFile,\npromoteComment=true)
                            activate UpdateIni
                            note right of UpdateIni
                              Regex includes leading ';' chars.
                              Replaces first match only.
                            end note
                            UpdateIni -> IniFile: file_get_contents(iniFile)
                            IniFile --> UpdateIni: content
                            UpdateIni -> UpdateIni: preg_replace(regex_with_semicolon,\n'key = value', limit=1)
                            UpdateIni -> IniFile: file_put_contents(iniFile, updatedContent)
                            UpdateIni --> CmdSet: matchCount
                            deactivate UpdateIni
                        end
                    end

                    alt matchCount >= 1 (Pass 2 succeeded)
                        CmdSet --> User: setting promoted from comment
                    else

                        group Pass 3 — Append to Main INI File
                            CmdSet -> FindMainIni: find_main_ini_files(phpProps)
                            activate FindMainIni
                            note right of FindMainIni
                              Locates 98-ddtrace.ini or
                              the INI file containing
                              'extension = ddtrace'.
                            end note
                            FindMainIni --> CmdSet: mainIniFilePaths[]
                            deactivate FindMainIni

                            loop for each main INI file
                                alt file missing
                                    CmdSet -> IniFile: file_put_contents(iniFile, '') — create
                                end
                                CmdSet -> IniFile: file_get_contents(iniFile)
                                IniFile --> CmdSet: content
                                CmdSet -> IniFile: file_put_contents(iniFile,\ncontent + 'key = value')
                            end

                            alt unable to set in any file
                                CmdSet --> User: exit(1) — failed to write setting
                            else
                                CmdSet --> User: setting appended to main INI file
                            end
                        end

                    end
                end
            end
        end
    end

    deactivate CmdSet
end

deactivate Main

note over User, IniFile
  **Datadog-specific INI settings only** (datadog.* namespace).
  Canonical default file: **98-ddtrace.ini** (prioritised in all scans).
  DD_TRACE_* → datadog.trace.* | DD_PROFILING_* → datadog.profiling.*
  DD_APPSEC_* → datadog.appsec.* | DD_ENV → datadog.env
end note

@enduml
