@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam sequence {
    ArrowColor #495057
    ActorBorderColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    ParticipantBorderColor #495057
    ParticipantBackgroundColor #F8F9FA
    ParticipantFontColor #212529
    BoxBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    GroupBackgroundColor #DEE2E6
    GroupBorderColor #868E96
    NoteBackgroundColor #FFF9C4
    NoteBorderColor #F0AD4E
    DividerBackgroundColor #E9ECEF
}

title No-op Tracer and Span Flow\n<size:11>//Fallback no-op tracer, no-op span and scope behaviour when tracing is disabled//</size>

actor Application as app

participant "GlobalTracer" as gt #D4EDDA
participant "NoopTracer\n(DDTrace\\NoopTracer)" as nt #FFF3CD
participant "NoopScope\n(DDTrace\\NoopScope)" as ns #FFF3CD
participant "NoopSpan\n(DDTrace\\NoopSpan)" as nsp #FFF3CD
participant "NoopSpanContext\n(DDTrace\\NoopSpanContext)" as nsc #FFF3CD
participant "NoopScopeManager\n(DDTrace\\NoopScopeManager)" as nsm #FFF3CD
participant "DDTrace\\Tracer\n(real tracer)" as rt #D0E8FF
participant "C Extension\n(ddtrace)" as cext #F5E6FF

note over gt
  **Bootstrap rule:**
  Prior to GlobalTracer::set(),
  all spans are no-ops.
  $instance is null by default.
end note

== Path 1: ddtrace extension NOT loaded (full no-op fallback) ==

app -> gt: get()
activate gt
gt -> gt: check self::$instance (null?)
gt -> gt: extension_loaded('ddtrace')\n&& class_exists(Tracer::class)?

alt ddtrace extension missing OR Tracer class not found
    gt -> nt: create() — new NoopTracer()
    activate nt
    nt --> gt: NoopTracer instance
    deactivate nt
    gt -> gt: self::$instance = NoopTracer
end

gt --> app: NoopTracer (limited() == true)
deactivate gt

note right of app
  **NoopTracer.limited() = true**
  Signals to callers that the
  tracer is in degraded/disabled mode.
end note

== Path 2: Span operations on NoopTracer ==

app -> nt: startSpan(operationName, options=[])
activate nt
nt -> nsp: create() — new NoopSpan()
activate nsp
nsp --> nt: NoopSpan
deactivate nsp
nt --> app: NoopSpan\n[getOperationName() = 'noop_span']
deactivate nt

app -> nt: startActiveSpan(operationName, options=[])
activate nt
nt -> ns: create() — new NoopScope()
activate ns
ns --> nt: NoopScope
deactivate ns
nt --> app: NoopScope
deactivate nt

== Path 3: NoopScope and NoopSpan operations ==

app -> ns: getSpan()
activate ns
ns -> nsp: create() — new NoopSpan()
activate nsp
nsp --> ns: NoopSpan
deactivate nsp
ns --> app: NoopSpan
deactivate ns

app -> nsp: setTag(key, value)
activate nsp
note right of nsp: no-op — void, tag discarded
nsp --> app: (void)
deactivate nsp

app -> nsp: log(fields, timestamp)
activate nsp
note right of nsp: no-op — void, log discarded
nsp --> app: (void)
deactivate nsp

app -> nsp: getContext()
activate nsp
nsp -> nsc: create() — new NoopSpanContext()
activate nsc
nsc --> nsp: NoopSpanContext
deactivate nsc
nsp --> app: NoopSpanContext\n[getTraceId()='', getSpanId()='']
deactivate nsp

app -> nsp: finish(finishTime)
activate nsp
note right of nsp: no-op — void, nothing recorded
nsp --> app: (void)
deactivate nsp

app -> ns: close()
activate ns
note right of ns: no-op — no span finished on close
ns --> app: (void)
deactivate ns

== Path 4: ScopeManager operations ==

app -> nt: getScopeManager()
activate nt
nt -> nsm: new NoopScopeManager()
activate nsm
nsm --> nt: NoopScopeManager
deactivate nsm
nt --> app: NoopScopeManager
deactivate nt

app -> nsm: activate(span, finishSpanOnClose)
activate nsm
nsm -> ns: create() — new NoopScope()
activate ns
ns --> nsm: NoopScope
deactivate ns
nsm --> app: NoopScope
deactivate nsm

app -> nsm: getActive()
activate nsm
nsm -> ns: create() — new NoopScope()
activate ns
ns --> nsm: NoopScope
deactivate ns
nsm --> app: NoopScope
deactivate nsm

== Path 5: Propagation operations on NoopTracer ==

app -> nt: inject(spanContext, format, &carrier)
activate nt
note right of nt: true void no-op\ncarrier is NEVER modified
nt --> app: (void)
deactivate nt

app -> nt: extract(format, carrier)
activate nt
nt -> nsc: create() — new NoopSpanContext()
activate nsc
nsc --> nt: NoopSpanContext
deactivate nsc
nt --> app: NoopSpanContext
deactivate nt

== Path 6: Diagnostic methods on NoopTracer ==

app -> nt: flush()
activate nt
note right of nt: no-op — nothing to flush
nt --> app: (void)
deactivate nt

app -> nt: getPrioritySampling()
activate nt
nt --> app: null
deactivate nt

app -> nt: getTracesAsArray()
activate nt
nt --> app: [] (empty array)
deactivate nt

app -> nt: getTracesCount()
activate nt
nt --> app: 0
deactivate nt

app -> nt: limited()
activate nt
nt --> app: true
deactivate nt

== Path 7: Runtime disable via dd_trace_disable_in_request() ==

note over app, cext
  **Runtime disable path** — uses real DDTrace\\Tracer,
  but tracing is disabled mid-request via C extension function.
end note

app -> cext: dd_trace_disable_in_request()
activate cext
note right of cext
  C extension function.
  Removes all instrumentation hooks
  for the remainder of the current
  HTTP request at the C level.
end note
cext --> rt: hooks removed for rest of request
cext --> app: true (bool)
deactivate cext

app -> rt: startSpan(operationName)
activate rt
rt -> cext: ddtrace_config_trace_enabled()
activate cext
note right of cext
  Checks DD_TRACE_ENABLED
  ini/env config setting.
end note
cext --> rt: false (tracing disabled)
deactivate cext

alt !config['enabled'] OR !ddtrace_config_trace_enabled()
    rt -> nsp: create() — new NoopSpan()
    activate nsp
    nsp --> rt: NoopSpan
    deactivate nsp
    rt --> app: NoopSpan (fallback, tracing disabled)
end

deactivate rt

note over app, nsc
  **Summary of no-op return values:**
  • NoopSpan.getOperationName() = 'noop_span'
  • NoopSpan.getTraceId() / getSpanId() = ''
  • NoopSpan.hasError() = false  |  isFinished() = false
  • NoopSpan.getStartTime() / getDuration() = 0
  • NoopSpanContext.isHostRoot() = false
  • NoopSpanContext.getPropagatedPrioritySampling() = 0
  • NoopSpanContext.getIterator() = EmptyIterator
end note

@enduml
