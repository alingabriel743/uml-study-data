@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequence {
    ArrowColor #495057
    ActorBorderColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    ParticipantBorderColor #495057
    ParticipantBackgroundColor #F8F9FA
    ParticipantFontColor #212529
    BoxBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    NoteBackgroundColor #FFF3CD
    NoteBorderColor #FFC107
}

title Trace Flush and Export Flow

actor "Application" as App
participant "DDTrace\\Tracer" as Tracer
participant "ScopeManager" as ScopeMgr

box "Transport Layer" #EEF2FF
    participant "Transport\\Internal\n(default)" as Internal
    participant "DebugTransport\n(test only)" as Debug
end box

box "C Extension" #F0FFF0
    participant "DDTrace C Ext\n(DDTrace\\flush)" as CExt
end box

participant "Background\nWriter Thread" as BGWriter
participant "Datadog Agent\n/v0.4/traces" as Agent

== Flush Triggered (request end or manually) ==

App -> Tracer : flush()
activate Tracer

alt config['enabled'] = false
    Tracer --> App : return (no-op)
else tracing enabled
    opt Web SAPI && DD_TRACE_URL_AS_RESOURCE_NAMES_ENABLED
        Tracer -> Tracer : addUrlAsResourceNameToSpan(rootSpan)
        note right : Normalizes URL path as span resource name\n(e.g. "GET /users/:id")
    end

    opt Debug logging active
        Tracer -> CExt : dd_trace_closed_spans_count(): int
        CExt --> Tracer : spanCount
        Tracer -> Tracer : logDebug('Flushing {count} traces, {spanCount} spans')
    end

    == Transport::send() Delegation ==

    alt Internal Transport (default background writer path)

        Tracer -> Internal : send($tracer)
        activate Internal

        alt DD_TRACE_GENERATE_ROOT_SPAN = false
            note over Internal : Only flushes when root span is not\nauto-generated by the C extension
            Internal -> CExt : DDTrace\\flush()
            activate CExt
            note right of CExt : C ext closes all open spans\nand submits finished traces

            CExt -> CExt : dd_trace_buffer_span(traceArray): bool
            note right : Serializes spans as msgpack array\nand buffers for background writer

            CExt -> BGWriter : dd_trace_coms_trigger_writer_flush(): int
            activate BGWriter
            note right : Signals background thread\nto begin flush cycle

            deactivate CExt

            == Background Writer Thread (async) ==

            BGWriter -> BGWriter : Serialize buffered spans\nto msgpack payload
            note over BGWriter : Encoding: application/msgpack\n(SpanData.meta_struct = double-encoded msgpack)

            BGWriter -> Agent : dd_trace_send_traces_via_thread(\n  numTraces, curlHeaders, payload): bool
            activate Agent
            note right of BGWriter : HTTP POST /v0.4/traces\nContent-Type: application/msgpack\n(Exactly 1 trace per call)

            Agent --> BGWriter : 200 OK
            deactivate Agent
            deactivate BGWriter

        else DD_TRACE_GENERATE_ROOT_SPAN = true
            note over Internal : Root span is owned by C extension;\nskip explicit flush — C ext handles it automatically
        end

        Internal --> Tracer : (void)
        deactivate Internal

    else DebugTransport (test/assertion path)

        Tracer -> Debug : send($tracer)
        activate Debug

        Debug -> Tracer : getTracesAsArray()
        activate Tracer
        Tracer -> CExt : dd_trace_serialize_closed_spans(): array
        note right of CExt : Auto-closes any remaining open spans;\ndestroys the open span stack — call only\nat end of trace lifecycle
        CExt --> Tracer : serialized spans array
        Tracer --> Debug : tracesArray
        deactivate Tracer

        Debug -> Debug : array_merge($this->traces, tracesArray)
        note over Debug : Stores traces in-memory for\ntest assertions via getTraces()

        Debug --> Tracer : (void)
        deactivate Debug

    else Noop Transport (tracing disabled)
        note over Tracer : Transport::Noop::send() — silent no-op;\nno spans are collected or transmitted
    end

    == Scope Cleanup ==

    Tracer -> ScopeMgr : close()
    activate ScopeMgr
    ScopeMgr --> Tracer : (void)
    deactivate ScopeMgr

end

deactivate Tracer

== Alternative: Synchronous Flush (blocking) ==

App -> CExt : dd_trace_synchronous_flush(timeout = 100): void
note right : Blocks up to $timeout ms waiting\nfor all buffered spans to be sent to agent
CExt --> App : (void, all spans delivered or timeout)

== Alternative: Force-Close All Spans & Flush ==

App -> CExt : dd_trace_close_all_spans_and_flush(): void
note right : Behavior depends on DD_AUTOFINISH_SPANS:\n  true  → close all open spans, then flush\n  false → drop open spans, then flush
CExt --> App : (void)

@enduml
