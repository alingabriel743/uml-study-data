@startuml
title Datadog PHP Tracer (dd-trace-php) — System Context

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actor {
    BackgroundColor<<Person>> #08427B
    FontColor<<Person>> #FFFFFF
    BorderColor<<Person>> #052E56
}

skinparam package {
    BackgroundColor #F5F5F5
    BorderColor #BDBDBD
    FontColor #424242
    FontStyle bold
}

skinparam arrow {
    Color #424242
    FontSize 10
    FontColor #616161
}

' ── Actors ───────────────────────────────────────────────────────────────────
actor "PHP Developer
[Application Owner]" as dev <<Person>>
actor "DevOps / SRE
[Datadog Dashboard]" as devops <<Person>>
actor "CI/CD Pipeline
[GitLab CI]" as cicd <<Person>>

' ── Core System ──────────────────────────────────────────────────────────────
rectangle "**Datadog PHP Tracer**
**(dd-trace-php)**
[PHP Extension + Library]

Auto-instruments PHP apps
for distributed tracing, APM,
profiling & AppSec monitoring" as system <<System>>

' ── Datadog Infrastructure ───────────────────────────────────────────────────
package "Datadog Observability Platform" {
    rectangle "**Datadog Agent**
[Local Daemon]

Receives trace data from
the PHP tracer, batches
and forwards to backend" as dd_agent <<Infrastructure>>

    rectangle "**Datadog APM / Backend**
[SaaS Platform]

Distributed trace storage,
service maps, alerting,
dashboards & analytics" as dd_backend <<Infrastructure>>
}

' ── Web Frameworks & PHP Applications ────────────────────────────────────────
package "PHP Web Frameworks (Instrumented)" {
    rectangle "**Laravel / Laravel Queue**
[PHP Framework]

Request lifecycle tracing,
queue job instrumentation
via LaravelQueueIntegration" as laravel <<External>>

    rectangle "**Symfony / Messenger**
[PHP Framework]

HTTP kernel tracing,
Symfony Messenger transport
via SymfonyMessengerIntegration" as symfony <<External>>

    rectangle "**WordPress / Drupal**
[CMS Platforms]

Hook/event tracing,
HTTP API tracing via
WordPressIntegration & DrupalIntegration" as cms <<External>>

    rectangle "**Magento / CakePHP
Zend / Laminas / Yii / Nette**
[PHP Frameworks]

Full request-response tracing
for each framework lifecycle
via dedicated integrations" as other_fw <<External>>
}

' ── Data Stores ──────────────────────────────────────────────────────────────
package "Data Stores" {
    rectangle "**MySQL / MySQLi / PDO**
[Relational Database]

SQL query tracing,
slow query detection,
sanitized query capture" as mysql <<Database>>

    rectangle "**MongoDB**
[Document Database]

Command monitoring via
DatadogSubscriber, operation
and collection-level spans" as mongodb <<Database>>

    rectangle "**Elasticsearch**
[Search Engine]

Index, search & query
tracing via V1/V8
ElasticSearch integrations" as elasticsearch <<Database>>

    rectangle "**Google Cloud Spanner**
[Managed RDBMS]

Read/write operation
tracing via
GoogleSpannerIntegration" as spanner <<Database>>

    rectangle "**SQL Server (SQLSRV)**
[Relational Database]

T-SQL query tracing
and error detection
via SQLSRVIntegration" as sqlsrv <<Database>>
}

' ── Cache ────────────────────────────────────────────────────────────────────
package "Cache Layer" {
    rectangle "**Redis (PHPRedis)**
[In-Memory Cache]

Command-level tracing,
key/value operation spans
via PHPRedisIntegration" as phpredis <<Cache>>

    rectangle "**Redis (Predis)**
[In-Memory Cache]

Command-level tracing,
pipeline & transaction spans
via PredisIntegration" as predis <<Cache>>
}

' ── Message Brokers ──────────────────────────────────────────────────────────
package "Messaging & Queues" {
    rectangle "**Apache Kafka**
[Distributed Streaming]

Producer topic hooks,
span metadata injection,
header context propagation" as kafka <<Queue>>

    rectangle "**RabbitMQ (AMQP)**
[Message Broker]

Publish/consume span tracing,
W3C trace context propagation
via AMQPIntegration" as amqp <<Queue>>
}

' ── HTTP Clients ─────────────────────────────────────────────────────────────
package "HTTP Clients (Auto-Instrumented)" {
    rectangle "**Guzzle HTTP Client**
[HTTP Client Library]

Outbound request tracing,
distributed trace header
injection via GuzzleIntegration" as guzzle <<External>>

    rectangle "**cURL / PSR-18**
[HTTP Transport Layer]

Low-level cURL span capture,
PSR-18 compliant client
tracing for HTTP calls" as curl <<External>>

    rectangle "**Ratchet**
[WebSocket Server]

WebSocket connection &
message handling tracing
via RatchetIntegration" as ratchet <<External>>
}

' ── Third-Party External APIs ─────────────────────────────────────────────────
package "Third-Party APIs (Traced)" {
    rectangle "**OpenAI API**
[AI / LLM Service]

LLM call tracing, token
usage capture & response
span via OpenAIIntegration" as openai <<External>>

    rectangle "**Stripe API**
[Payment Gateway]

Payment intent tracing,
charge & refund span
capture via StripeIntegration" as stripe <<External>>

    rectangle "**Akismet API**
[Spam Detection]

REST API call tracing,
spam-check request spans
via Akismet_REST_API" as akismet <<External>>
}

' ── OpenTracing / OpenTelemetry ───────────────────────────────────────────────
package "Tracing Standards" {
    rectangle "**OpenTracing API**
[Vendor-Neutral Standard]

Compatible tracer interface,
Span/SpanContext/Propagator
abstractions for portability" as opentracing <<External>>
}

' ── Relationships: Actors → System ───────────────────────────────────────────
dev --> system : "Installs & configures\n(Composer / PHP ext)"
devops --> dd_backend : "HTTPS\n(Views traces, dashboards)"
cicd --> system : "GitLab CI\n(Build, test, release)"

' ── Core System → Datadog Infrastructure ─────────────────────────────────────
system --> dd_agent : "HTTP / Unix Socket\n(sends trace spans & metrics)"
dd_agent --> dd_backend : "HTTPS\n(forwards batched trace data)"

' ── Frameworks → System ──────────────────────────────────────────────────────
laravel --> system : "PHP hooks / DDTrace\n(auto-instrumented spans)"
symfony --> system : "PHP hooks / DDTrace\n(auto-instrumented spans)"
cms --> system : "PHP hooks / DDTrace\n(auto-instrumented spans)"
other_fw --> system : "PHP hooks / DDTrace\n(auto-instrumented spans)"

' ── System → Data Stores ─────────────────────────────────────────────────────
system --> mysql : "PDO / MySQLi hooks\n(SQL query spans)"
system --> mongodb : "MongoDB driver hooks\n(command-level spans)"
system --> elasticsearch : "Elasticsearch client hooks\n(search/index spans)"
system --> spanner : "Google Spanner client hooks\n(read/write spans)"
system --> sqlsrv : "SQLSRV extension hooks\n(query spans)"

' ── System → Cache ───────────────────────────────────────────────────────────
system --> phpredis : "PHPRedis extension hooks\n(command spans)"
system --> predis : "Predis client hooks\n(command spans)"

' ── System → Message Brokers ─────────────────────────────────────────────────
system --> kafka : "rdkafka hooks\n(producer topic spans + header inject)"
system --> amqp : "AMQP extension hooks\n(publish/consume spans)"

' ── System → HTTP Clients ────────────────────────────────────────────────────
system --> guzzle : "Guzzle middleware hooks\n(outbound HTTP spans)"
system --> curl : "cURL / PSR-18 hooks\n(outbound HTTP spans)"
system --> ratchet : "WebSocket hooks\n(connection/message spans)"

' ── System → Third-Party APIs ────────────────────────────────────────────────
system --> openai : "HTTP instrumentation\n(LLM request/response spans)"
system --> stripe : "HTTP instrumentation\n(payment operation spans)"
system --> akismet : "REST hooks\n(spam-check request spans)"

' ── System ↔ OpenTracing ─────────────────────────────────────────────────────
system --> opentracing : "Implements OpenTracing API\n(Tracer / Span / Propagator)"

@enduml
