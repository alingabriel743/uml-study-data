{
  "scope": "distributed_tracing_core",
  "title": "Distributed Tracing — Core Instrumentation",
  "diagram_type": "use_case",
  "description": "Developer creates, annotates, and finishes spans to instrument PHP application code using the DDTrace core primitives.",

  "actors": [
    "Developer (PHP Application Code)",
    "Auto-Instrumentation (DDTrace Extension)",
    "OpenTelemetry SDK User",
    "OpenTracing SDK User"
  ],

  "use_cases": [
    "Start a new span (start_span / start_trace_span)",
    "Start a root/trace span",
    "Set span name / operation name",
    "Set span resource",
    "Set span service",
    "Set span type",
    "Annotate span with tags (setTag)",
    "Annotate span with metrics (setMetric)",
    "Annotate span with baggage (addBaggageItem)",
    "Mark span as error (setError / setRawError)",
    "Log structured fields on span (log)",
    "Add span event (SpanEvent / ExceptionSpanEvent)",
    "Add span link (SpanLink)",
    "Finish / close span (finish / close_span)",
    "Close spans until a target span (close_spans_until)",
    "Retrieve active span (active_span)",
    "Retrieve root span (root_span)",
    "Override operation name (overwriteOperationName)",
    "Get span context (traceId, spanId, parentId)",
    "Create a new span stack (create_stack)",
    "Switch active stack (switch_stack)",
    "Build span via SpanBuilder (OTel) — setParent, setAttribute, setSpanKind, setStartTimestamp, startSpan",
    "Propagate distributed tracing headers (consume_distributed_tracing_headers)",
    "Control sampling priority (MANUAL_KEEP / MANUAL_DROP / set_priority_sampling)"
  ],

  "key_classes": [
    {
      "name": "SpanData",
      "namespace": "DDTrace",
      "type": "class (C extension stub)",
      "key_properties": ["name", "resource", "service", "env", "version", "type", "meta[]", "metrics[]", "baggage[]", "links[]", "events[]", "exception", "id (readonly)", "parent (readonly SpanData|null)", "stack (readonly SpanStack)", "onClose[]", "peerServiceSources[]", "meta_struct[]"],
      "key_methods": ["getDuration(): int", "getStartTime(): int", "getLink(): SpanLink", "hexId(): string"]
    },
    {
      "name": "RootSpanData",
      "namespace": "DDTrace",
      "type": "class extends SpanData",
      "additional_properties": ["origin", "propagatedTags[]", "samplingPriority", "propagatedSamplingPriority", "tracestate", "tracestateTags[]", "parentId", "traceId", "gitMetadata", "inferredSpan"],
      "notes": "Returned by root_span() and start_trace_span(). Holds distributed tracing propagation state."
    },
    {
      "name": "InferredSpanData",
      "namespace": "DDTrace",
      "type": "class extends SpanData",
      "notes": "Empty subclass used for inferred spans."
    },
    {
      "name": "SpanStack",
      "namespace": "DDTrace",
      "type": "class (C extension stub)",
      "key_properties": ["parent (readonly SpanStack|null)", "active (SpanData|null)", "spanCreationObservers[]"],
      "notes": "Manages the active span stack. New spans push to top; create_stack/switch_stack manage concurrent contexts (e.g., fibers, async)."
    },
    {
      "name": "Span",
      "namespace": "DDTrace",
      "type": "class extends DDTrace\\Data\\Span",
      "implements": "SpanInterface (OpenTracing-compatible)",
      "key_methods": [
        "__construct(SpanData $internalSpan, SpanContext $context)",
        "setTag($key, $value, $setIfFinished = false)",
        "getTag($key): mixed",
        "getAllTags(): array",
        "setMetric($key, $value)",
        "getMetrics(): array",
        "setResource($resource)",
        "setError($error: Throwable|bool|null)",
        "setRawError($message, $type)",
        "hasError(): bool",
        "finish($finishTime = null)",
        "isFinished(): bool",
        "overwriteOperationName($operationName)",
        "getOperationName(): string",
        "getTraceId(): string",
        "getSpanId(): string",
        "getParentId(): string",
        "getContext(): SpanContext",
        "getStartTime(): int (microseconds)",
        "getDuration(): int (microseconds)",
        "log(array $fields, $timestamp = null)",
        "addBaggageItem($key, $value)",
        "getBaggageItem($key): mixed",
        "getAllBaggageItems(): array",
        "removeBaggageItem($key)",
        "removeAllBaggageItems()"
      ],
      "notes": "Wraps a SpanData (C-level) + SpanContext. finish() calls close_span(); handles out-of-order close via close_spans_until()."
    },
    {
      "name": "SpanBuilder",
      "namespace": "OpenTelemetry\\SDK\\Trace",
      "type": "class implements SpanBuilderInterface",
      "key_methods": [
        "setParent($context): self",
        "setAttribute(string $key, $value): self",
        "setAttributes(iterable $attributes): self",
        "setSpanKind(int $spanKind): self",
        "setStartTimestamp(int $timestampNanos): self",
        "addLink(SpanContextInterface $context, iterable $attributes): self",
        "addEvent(string $name, iterable $attributes, ?int $timestamp): self",
        "recordException(Throwable $exception, iterable $attributes): self",
        "startSpan(): SpanInterface"
      ],
      "notes": "OTel fluent builder. startSpan() calls start_trace_span() or start_span(), resolves parent context, applies sampling, sets traceparent header."
    }
  ],

  "global_functions": [
    "start_span(float $startTime = 0): SpanData|false  — creates child span on active stack",
    "start_trace_span(float $startTime = 0): RootSpanData  — creates root/trace span",
    "close_span(float $finishTime = 0): false|null  — closes active span",
    "close_spans_until(?SpanData $span): false|int  — closes spans down to target",
    "active_span(): null|SpanData  — returns current top-of-stack span",
    "root_span(): null|RootSpanData  — returns root span of current trace",
    "create_stack(): SpanStack  — creates isolated concurrent stack",
    "switch_stack(SpanData|SpanStack|null $newStack): null|false|SpanStack  — switches active stack",
    "set_priority_sampling(int $priority)  — controls sampling decision",
    "consume_distributed_tracing_headers(array $headers)  — injects upstream traceparent/tracestate"
  ],

  "key_relationships": [
    "RootSpanData extends SpanData",
    "InferredSpanData extends SpanData",
    "DDTrace\\Span extends DDTrace\\Data\\Span (abstract), which implements DDTrace\\Contracts\\Span",
    "DDTrace\\Span composes SpanData (internalSpan) and SpanContext",
    "SpanData has parent SpanData (nullable, readonly)",
    "SpanData has stack SpanStack (readonly)",
    "SpanStack has parent SpanStack (nullable, readonly) — linked stack chain",
    "SpanStack holds active SpanData",
    "OpenTelemetry SpanBuilder depends_on DDTrace global functions (start_span, start_trace_span, root_span)",
    "OpenTelemetry Span wraps SpanData internally",
    "DDTrace\\Span.finish() calls close_span() / close_spans_until()"
  ],

  "special_tag_behaviors": [
    "Tag::ERROR → calls setError()",
    "Tag::ERROR_MSG → sets meta[error.msg] + marks hasError=true",
    "Tag::SERVICE_NAME → sets internalSpan->service",
    "Tag::RESOURCE_NAME → sets internalSpan->resource",
    "Tag::SPAN_TYPE → sets internalSpan->type",
    "Tag::HTTP_URL → sanitized via Urls::sanitize()",
    "Tag::HTTP_STATUS_CODE >= 500 → marks hasError=true",
    "Tag::MANUAL_KEEP → set_priority_sampling(USER_KEEP)",
    "Tag::MANUAL_DROP → set_priority_sampling(USER_REJECT)",
    "Tag::SERVICE_VERSION → also sets Tag::VERSION",
    "Tag::ANALYTICS_KEY → routed to setMetric() via TraceAnalyticsProcessor"
  ],

  "domain_notes": [
    "DDTrace is the Datadog PHP tracing extension; SpanData is a C-level struct exposed to PHP.",
    "Times are stored internally in nanoseconds; Span (OT layer) exposes microseconds.",
    "SpanStack enables concurrent/fiber-safe tracing — each fiber can have its own stack.",
    "Distributed tracing propagated via W3C traceparent/tracestate headers.",
    "Sampling decisions: AUTO_KEEP, AUTO_REJECT, USER_KEEP, USER_REJECT.",
    "OpenTracing and OpenTelemetry APIs are both bridged on top of the same SpanData primitives.",
    "onClose handlers on SpanData are called when span is closed (not dropped).",
    "RootSpanData.inferredSpan supports inferred service spans (e.g., inferred from network calls)."
  ],

  "source_files_analyzed": [
    "src/DDTrace/Span.php",
    "src/api/Data/Span.php",
    "ext/ddtrace.stub.php",
    "src/DDTrace/OpenTelemetry/SpanBuilder.php",
    "src/ddtrace_php_api.stubs.php"
  ]
}
