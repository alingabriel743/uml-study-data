{
  "scope": "laravel_service_providers",
  "title": "Laravel Service Provider Integration",
  "diagram_type": "use_case",
  "description": "Bootstrapping Datadog tracing within a Laravel application via service providers. DDTrace hooks are installed at PHP extension level intercepting Illuminate framework calls during the service provider loading lifecycle.",

  "actors": [
    "Laravel Application (bootstrap orchestrator)",
    "DDTrace PHP Extension (auto-instrumentation layer)",
    "Developer (configures providers in config/app.php)",
    "AppSec Module (security event tracking)"
  ],

  "use_cases": [
    "Register Application Service Providers",
    "Bootstrap Application Services (boot())",
    "Register Application Bindings (register())",
    "Load Service Provider Repository",
    "Register Authentication Policies",
    "Register Event Listeners",
    "Map Web and API Routes",
    "Register Broadcast Routes",
    "Trace Application Handle (laravel.request span)",
    "Trace Provider Load (laravel.provider.load span)",
    "Trace Route Action (laravel.action span)",
    "Trace Event Dispatch (laravel.event.handle span)",
    "Trace View Render (laravel.view.render span)",
    "Resolve Service Name from config/app.php or .env",
    "Track User Login Success / Failure (AppSec)",
    "Track User Registration / Signup (AppSec)",
    "Track Authenticated User (AppSec)",
    "Handle Artisan Console Commands (laravel.artisan span)",
    "Report / Suppress Exceptions in Root Span"
  ],

  "service_providers": [
    {
      "class": "App\\Providers\\AppServiceProvider",
      "extends": "Illuminate\\Support\\ServiceProvider",
      "methods": ["boot(): void", "register(): void"],
      "responsibility": "General app bootstrapping – empty stub in test app",
      "source": "tests/overhead/Laravel57/app/Providers/AppServiceProvider.php"
    },
    {
      "class": "App\\Providers\\AuthServiceProvider",
      "extends": "Illuminate\\Foundation\\Support\\Providers\\AuthServiceProvider",
      "properties": ["$policies = ['App\\Model' => 'App\\Policies\\ModelPolicy']"],
      "methods": ["boot(): void → calls registerPolicies()"],
      "responsibility": "Registers model-to-policy mappings for authorization",
      "source": "tests/overhead/Laravel57/app/Providers/AuthServiceProvider.php"
    },
    {
      "class": "App\\Providers\\EventServiceProvider",
      "extends": "Illuminate\\Foundation\\Support\\Providers\\EventServiceProvider",
      "properties": ["$listen = [Registered::class => [SendEmailVerificationNotification::class]]"],
      "methods": ["boot(): void → calls parent::boot()"],
      "responsibility": "Maps auth events to notification listeners",
      "source": "tests/overhead/Laravel57/app/Providers/EventServiceProvider.php"
    },
    {
      "class": "App\\Providers\\RouteServiceProvider",
      "extends": "Illuminate\\Foundation\\Support\\Providers\\RouteServiceProvider",
      "properties": ["$namespace = 'App\\Http\\Controllers'"],
      "methods": [
        "boot(): void → calls parent::boot()",
        "map(): void → mapApiRoutes() + mapWebRoutes()",
        "mapWebRoutes(): void → Route::middleware('web')->namespace()->group('routes/web.php')",
        "mapApiRoutes(): void → Route::prefix('api')->middleware('api')->namespace()->group('routes/api.php')"
      ],
      "responsibility": "Binds web and API route files to middleware groups",
      "source": "tests/overhead/Laravel57/app/Providers/RouteServiceProvider.php"
    },
    {
      "class": "App\\Providers\\BroadcastServiceProvider",
      "extends": "Illuminate\\Support\\ServiceProvider",
      "methods": ["boot(): void → Broadcast::routes() + require routes/channels.php"],
      "responsibility": "Registers WebSocket broadcast routes (commented out in config/app.php)",
      "source": "tests/overhead/Laravel57/app/Providers/BroadcastServiceProvider.php"
    }
  ],

  "ddtrace_hooks": [
    {
      "target": "Illuminate\\Foundation\\Application::handle",
      "type": "trace_method",
      "span_name": "laravel.application.handle",
      "sets_root_span": "laravel.request",
      "tags": ["http.status_code", "span.kind=server", "component=laravel"]
    },
    {
      "target": "Illuminate\\Foundation\\ProviderRepository::load",
      "type": "trace_method",
      "span_name": "laravel.provider.load",
      "note": "Sets root span name to laravel.request and service name"
    },
    {
      "target": "Illuminate\\Contracts\\Foundation\\Application::bootstrapWith",
      "type": "hook_method",
      "note": "Reads service name from ddtrace_config_app_name(), .env, or config/app.php['name']"
    },
    {
      "target": "Illuminate\\Routing\\Router::findRoute",
      "type": "hook_method",
      "sets": ["laravel.route.name", "laravel.route.action", "http.url", "http.route", "http.method"],
      "note": "Collects and flushes all route endpoints if not yet done"
    },
    {
      "target": "Illuminate\\Routing\\Route::run",
      "type": "trace_method",
      "span_name": "laravel.action"
    },
    {
      "target": "Illuminate\\Events\\Dispatcher::dispatch (>= 5.8) / fire (< 5.8)",
      "type": "trace_method",
      "span_name": "laravel.event.handle",
      "note": "Also triggers AppSec user-signup tracking on 'eloquent.created: User'"
    },
    {
      "target": "Illuminate\\View\\View::render",
      "type": "trace_method",
      "span_name": "laravel.view.render"
    },
    {
      "target": "Illuminate\\View\\Engines\\CompilerEngine::get",
      "type": "trace_method",
      "span_name": "laravel.view or lumen.view"
    },
    {
      "target": "Illuminate\\Console\\Application::__construct",
      "type": "hook_method",
      "sets_root_span": "laravel.artisan"
    },
    {
      "target": "Illuminate\\Auth\\Events\\Login::__construct",
      "type": "hook_method",
      "calls": "datadog\\appsec\\track_user_login_success_event_automated"
    },
    {
      "target": "Illuminate\\Auth\\SessionGuard::attempt",
      "type": "hook_method",
      "calls": "datadog\\appsec\\track_user_login_failure_event_automated"
    },
    {
      "target": "Illuminate\\Auth\\Events\\Registered::__construct",
      "type": "hook_method",
      "calls": "datadog\\appsec\\track_user_signup_event_automated"
    },
    {
      "target": "Illuminate\\Auth\\Events\\Authenticated::__construct",
      "type": "hook_method",
      "calls": "datadog\\appsec\\track_authenticated_user_event_automated"
    },
    {
      "target": "Illuminate\\Contracts\\Debug\\ExceptionHandler::report",
      "type": "hook_method",
      "note": "Sets root span exception and error.ignored flag"
    }
  ],

  "provider_registration_order": [
    "Laravel framework providers (Auth, Broadcast, Bus, Cache, ...)",
    "App\\Providers\\AppServiceProvider",
    "App\\Providers\\AuthServiceProvider",
    "App\\Providers\\EventServiceProvider",
    "App\\Providers\\RouteServiceProvider",
    "(App\\Providers\\BroadcastServiceProvider — commented out)"
  ],

  "key_relationships": [
    "AppServiceProvider extends Illuminate\\Support\\ServiceProvider",
    "AuthServiceProvider extends Illuminate\\Foundation\\Support\\Providers\\AuthServiceProvider",
    "EventServiceProvider extends Illuminate\\Foundation\\Support\\Providers\\EventServiceProvider",
    "RouteServiceProvider extends Illuminate\\Foundation\\Support\\Providers\\RouteServiceProvider",
    "BroadcastServiceProvider extends Illuminate\\Support\\ServiceProvider",
    "LaravelIntegration extends DDTrace\\Integrations\\Integration",
    "LaravelIntegration hooks into Illuminate classes via DDTrace PHP extension (not via service providers)",
    "DDTrace intercepts ProviderRepository::load to bootstrap root span before providers run"
  ],

  "bootstrap_flow": [
    "1. PHP request arrives → DDTrace ext auto-loads LaravelIntegration::init()",
    "2. LaravelIntegration installs trace_method / hook_method hooks on Illuminate classes",
    "3. Laravel kernel calls Application::handle() → DDTrace creates laravel.request root span",
    "4. Application::bootstrapWith() → DDTrace reads service name",
    "5. ProviderRepository::load() → DDTrace creates laravel.provider.load span",
    "6. AppServiceProvider::register() + boot() run",
    "7. AuthServiceProvider::boot() → registerPolicies()",
    "8. EventServiceProvider::boot() → parent::boot() registers event→listener mappings",
    "9. RouteServiceProvider::boot() + map() → registers web and API routes",
    "10. Router::findRoute() → DDTrace enriches root span with route metadata",
    "11. Route::run() → DDTrace creates laravel.action span",
    "12. View::render() / CompilerEngine::get() → DDTrace creates view spans",
    "13. Response::send() → DDTrace captures HTTP status / exceptions"
  ],

  "important_notes": [
    "DDTrace integration does NOT use a Laravel service provider — it hooks at PHP ext level via trace_method/hook_method",
    "Service name resolved in priority: DD_SERVICE env var → ddtrace_config_app_name() → config/app.php['name'] → APP_NAME env → 'laravel'",
    "DD_TRACE_REMOVE_ROOT_SPAN_LARAVEL_QUEUE + isArtisanQueueCommand() controls root span removal for queue workers",
    "DD_HTTP_SERVER_ROUTE_BASED_NAMING env var controls whether resource name uses route name or URI",
    "AppSec event tracking (track_user_login_success, track_user_signup, etc.) is conditional on datadog\\appsec functions existing",
    "BroadcastServiceProvider is present but commented out in config/app.php providers array",
    "LaravelIntegration also handles Lumen (checks rootSpan->name === 'lumen.request') and Laravel Octane (Laravel\\Octane\\Worker::handle hook)"
  ],

  "source_files_analyzed": [
    "tests/overhead/Laravel57/app/Providers/AppServiceProvider.php",
    "tests/overhead/Laravel57/app/Providers/AuthServiceProvider.php",
    "tests/overhead/Laravel57/app/Providers/EventServiceProvider.php",
    "tests/overhead/Laravel57/app/Providers/RouteServiceProvider.php",
    "tests/overhead/Laravel57/app/Providers/BroadcastServiceProvider.php",
    "tests/overhead/Laravel57/config/app.php",
    "src/DDTrace/Integrations/Laravel/LaravelIntegration.php",
    "src/api/GlobalTracer.php",
    "docs/getting_started.md",
    "docs/open_tracing.md",
    "docs/changelog.md"
  ]
}
