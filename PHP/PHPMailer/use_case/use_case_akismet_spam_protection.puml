@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Akismet Spam Protection Plugin

left to right direction

actor "Admin\n(manage_options)" as Admin
actor "Akismet.com\n(Remote Service)" as AkismetCom

rectangle "Akismet Spam Protection Plugin\n(namespace: akismet/v1)" {

    package "API Key Management" {
        usecase "Get API Key\nGET /akismet/v1/key" as UC1
        usecase "Set API Key\nPOST/PUT /akismet/v1/key" as UC2
        usecase "Delete API Key\nDELETE /akismet/v1/key" as UC3
    }

    package "Spam Settings" {
        usecase "Get Spam Settings\nGET /akismet/v1/settings/" as UC4
        usecase "Update Spam Settings\nPOST/PUT /akismet/v1/settings/" as UC5
    }

    package "Spam Statistics" {
        usecase "Get Spam Stats\nGET /akismet/v1/stats[/{interval}]" as UC6
    }

    package "Alert Lifecycle" {
        usecase "Get Alert\nGET /akismet/v1/alert" as UC7
        usecase "Set / Refresh Alert\nPOST/PUT /akismet/v1/alert" as UC8
        usecase "Delete / Clear Alert\nDELETE /akismet/v1/alert" as UC9
    }

    usecase "Validate API Key\n(verify-key via Akismet.com)" as UC_VALIDATE
    usecase "Fetch Spam Stats\n(get-stats via Akismet.com)" as UC_STATS_REMOTE
}

' Admin interactions
Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5
Admin --> UC6

' Akismet.com interactions
AkismetCom --> UC7
AkismetCom --> UC8
AkismetCom --> UC9

' Include relationships
UC2 ..> UC_VALIDATE : <<include>>
UC6 ..> UC_STATS_REMOTE : <<include>>
UC8 ..> UC_VALIDATE : <<include>>

' UC_VALIDATE and UC_STATS_REMOTE communicate back with Akismet.com
UC_VALIDATE --> AkismetCom
UC_STATS_REMOTE --> AkismetCom

note bottom of UC2
  Business Rule: Blocked with HTTP 409
  if WPCOM_API_KEY constant is defined.
  Key must pass verify-key check before saving.
end note

note bottom of UC6
  Intervals: 60-days | 6-months | all
  Invalid values default to "all".
end note

note right of UC7
  Auth: API key passed as request
  param (server-to-server calls only).
  Not WordPress session-based.
end note

@enduml
