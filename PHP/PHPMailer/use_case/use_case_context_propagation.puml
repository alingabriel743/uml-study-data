@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Distributed Context Propagation\n<size:11>(DDTrace PHP — Injecting and Extracting Trace Context across Service Boundaries)</size>

left to right direction

' ── Actors ──────────────────────────────────────────────
actor "HTTP Client Service" as httpClient
actor "HTTP Server Service" as httpServer
actor "AMQP Producer"       as amqpProducer
actor "AMQP Consumer"       as amqpConsumer
actor "Kafka Producer"      as kafkaProducer
actor "OpenTracing Client"  as otClient
actor "OpenTelemetry Client" as otelClient
actor "DDTrace Tracer"      as ddTracer

' ── System Boundary ──────────────────────────────────────
rectangle "Distributed Context Propagation System\n(DDTrace PHP Tracer)" {

    ' ─── HTTP Header Propagation ─────────────────────────
    package "HTTP Header Propagation" {
        usecase "Inject Trace Context\ninto HTTP Headers" as UC1
        usecase "Extract Trace Context\nfrom HTTP Headers" as UC2
        usecase "Create Child Span\nfrom Propagated Context" as UC3
    }

    ' ─── Messaging Propagation ───────────────────────────
    package "Messaging Propagation" {
        usecase "Inject Context\ninto AMQP Message" as UC4
        usecase "Extract Context\nfrom AMQP Message" as UC5
        usecase "Inject Context\ninto Kafka Message" as UC6
    }

    ' ─── OpenTelemetry Bridge ────────────────────────────
    package "OpenTelemetry Bridge" {
        usecase "Get Current\nOTel Context" as UC7
        usecase "Determine Operation Name\nby Convention" as UC9
    }

    ' ─── Cross-Cutting Concerns ──────────────────────────
    package "Cross-Cutting Concerns" {
        usecase "Propagate\nBaggage Items" as UC8
        usecase "Normalize Trace\nAnalytics Sampling Rate" as UC10
    }
}

' ── Actor → Use Case associations ────────────────────────
httpClient    --> UC1
httpServer    --> UC2
httpServer    --> UC3
amqpProducer  --> UC4
amqpConsumer  --> UC5
kafkaProducer --> UC6
otelClient    --> UC7
otelClient    --> UC9
otClient      --> UC8
ddTracer      --> UC10
ddTracer      --> UC1
ddTracer      --> UC2

' ── Include / Extend relationships ───────────────────────
UC2 ..> UC3  : <<include>>
UC8 <.. UC1  : <<extend>>
UC8 <.. UC2  : <<extend>>
UC9 <.. UC7  : <<extend>>

' ── Notes ────────────────────────────────────────────────
note right of UC1
  Serialises SpanContext into carrier map:
  • x-datadog-trace-id
  • x-datadog-parent-id
  • x-datadog-sampling-priority
  • x-datadog-origin
  • ot-baggage-{key} (baggage)
  W3C: traceparent / tracestate
end note

note right of UC2
  isDistributedTracingActivationContext=true
  flags an incoming remote context
  (distinct from local child spans)
end note

note right of UC5
  AMQPIntegration creates **span links**
  between producer and consumer traces
  (not a parent-child relationship)
end note

note bottom of UC8
  SpanContext is immutable;
  withBaggageItem() returns a new instance
end note

@enduml
