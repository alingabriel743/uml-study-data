@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #343A40
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Distributed Tracing — Core Instrumentation

left to right direction

actor "Developer\n(PHP Application)" as dev
actor "Auto-Instrumentation\n(DDTrace Extension)" as auto
actor "OpenTelemetry\nSDK User" as otel
actor "OpenTracing\nSDK User" as ot

rectangle "DDTrace Core Instrumentation" {

  package "Span Lifecycle" {
    usecase "Start Child Span\n(start_span)" as UC1
    usecase "Start Root / Trace Span\n(start_trace_span)" as UC2
    usecase "Finish Span\n(finish / close_span)" as UC3
    usecase "Close Spans Until Target\n(close_spans_until)" as UC4
  }

  package "Span Identity & Metadata" {
    usecase "Set Operation Name\n(overwriteOperationName)" as UC5
    usecase "Set Span Resource\n(setResource)" as UC6
    usecase "Set Span Service" as UC7
    usecase "Set Span Type" as UC8
  }

  package "Span Annotation" {
    usecase "Annotate with Tags\n(setTag)" as UC9
    usecase "Annotate with Metrics\n(setMetric)" as UC10
    usecase "Annotate with Baggage\n(addBaggageItem)" as UC11
    usecase "Mark Span as Error\n(setError / setRawError)" as UC12
    usecase "Log Structured Fields\n(log)" as UC13
    usecase "Add Span Event\n(SpanEvent / ExceptionSpanEvent)" as UC14
    usecase "Add Span Link\n(SpanLink)" as UC15
  }

  package "Context & Lookup" {
    usecase "Retrieve Active Span\n(active_span)" as UC16
    usecase "Retrieve Root Span\n(root_span)" as UC17
    usecase "Get Span Context\n(traceId / spanId / parentId)" as UC18
  }

  package "Stack Management" {
    usecase "Create Isolated Span Stack\n(create_stack)" as UC19
    usecase "Switch Active Stack\n(switch_stack)" as UC20
  }

  package "Distributed Tracing Propagation" {
    usecase "Propagate Upstream Headers\n(consume_distributed_tracing_headers)" as UC21
    usecase "Control Sampling Priority\n(set_priority_sampling)" as UC22
  }
}

' ── Developer connections ──────────────────────────────────────
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4
dev --> UC5
dev --> UC6
dev --> UC7
dev --> UC8
dev --> UC9
dev --> UC10
dev --> UC11
dev --> UC12
dev --> UC13
dev --> UC14
dev --> UC15
dev --> UC16
dev --> UC17
dev --> UC18
dev --> UC19
dev --> UC20
dev --> UC21
dev --> UC22

' ── Auto-Instrumentation connections ──────────────────────────
auto --> UC1
auto --> UC2
auto --> UC3
auto --> UC16
auto --> UC22

' ── OpenTelemetry SDK User connections ────────────────────────
otel --> UC1
otel --> UC2
otel --> UC5
otel --> UC9
otel --> UC14
otel --> UC15
otel --> UC21
otel --> UC22

' ── OpenTracing SDK User connections ──────────────────────────
ot --> UC1
ot --> UC5
ot --> UC9
ot --> UC11
ot --> UC12
ot --> UC13
ot --> UC18

' ── Include / Extend relationships ────────────────────────────
UC3 ..> UC16 : <<include>>
UC12 <.. UC9 : <<extend>>\n(error-tagged keys)

' ── Domain notes ──────────────────────────────────────────────
note right of UC21
  Propagation uses W3C traceparent / tracestate headers.
  RootSpanData carries: propagatedTags, tracestate,
  samplingPriority, propagatedSamplingPriority, parentId.
end note

note right of UC22
  Sampling priorities:
  AUTO_KEEP / AUTO_REJECT  (agent-decided)
  USER_KEEP  ← Tag::MANUAL_KEEP
  USER_REJECT ← Tag::MANUAL_DROP
end note

note bottom of UC9
  Special tag routing:
  Tag::ERROR            → setError()
  Tag::ERROR_MSG        → meta[error.msg] + hasError = true
  Tag::HTTP_STATUS >= 500 → hasError = true
  Tag::SERVICE_NAME     → internalSpan->service
  Tag::RESOURCE_NAME    → internalSpan->resource
  Tag::ANALYTICS_KEY    → routed to setMetric()
end note

note bottom of UC19
  SpanStack enables fiber-safe / async tracing.
  Each fiber can own an isolated stack;
  switch_stack() changes the active context.
end note

@enduml
