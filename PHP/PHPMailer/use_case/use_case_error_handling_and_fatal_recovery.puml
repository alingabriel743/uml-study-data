@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Error Handling & Fatal Error Recovery\n<size:11>(Datadog PHP Tracer — Instrumented Application Error Pipeline)</size>

left to right direction

' ─── Actors ─────────────────────────────────────────────────────────────────
actor "PHP Application\n(Instrumented Runtime)" as phpApp
actor "Laravel Developer"                        as laravelDev
actor "WordPress Admin"                          as wpAdmin
actor "PHP Runtime\n(Shutdown Trigger)"          as phpRuntime
actor "Datadog Tracer\n(Span / Error Capture)"   as ddTracer
actor "WordPress Drop-in\n(Custom Override)"     as wpDropin

' ─── System 1: Laravel / Lumen Exception Handler ────────────────────────────
rectangle "Laravel / Lumen Exception Handler\n(App\\Exceptions\\Handler → Illuminate ExceptionHandler)" as laravelSystem {

    usecase "Catch & Report Exception\n(Handler::report())"                          as UC1
    usecase "Render Exception as\nHTTP Response\n(Handler::render())"                as UC2
    usecase "Register Custom Exception\nReporting Callbacks\n(Handler::register())"  as UC3
    usecase "Suppress Specific Exception\nTypes from Reporting\n(\$dontReport)"      as UC4
    usecase "Suppress Sensitive Input\nfrom Session Flash\n(\$dontFlash)"            as UC5
}

' ─── System 2: WordPress Fatal Error Handler ────────────────────────────────
rectangle "WordPress Fatal Error Handler\n(WP_Fatal_Error_Handler — since WordPress 5.2.0)" as wpSystem {

    usecase "Detect PHP Fatal Error\non Shutdown\n(handle() → detect_error())"                        as UC6
    usecase "Filter Handleable\nPHP Error Types\n(should_handle_error())"                             as UC7
    usecase "Skip Fatal Handling in\nSandbox / Maintenance Mode\n(WP_SANDBOX_SCRAPING guard)"         as UC12
    usecase "Recover via WordPress\nRecovery Mode\n(wp_recovery_mode()->handle_error())"              as UC8
    usecase "Display Custom PHP\nError Template\n(php-error.php drop-in)"                             as UC9
    usecase "Display Default Fatal\nError Page\n(display_default_error_template() → wp_die())"        as UC10
    usecase "Override Fatal Error\nHandler via Drop-in\n(fatal-error-handler.php)"                    as UC11
}

' ─── Actor → Use Case associations ──────────────────────────────────────────

' Laravel / Lumen side
phpApp      --> UC1
phpApp      --> UC2
laravelDev  --> UC3
laravelDev  --> UC4
laravelDev  --> UC5
ddTracer    --> UC3 : registers reportable()\ncallbacks via register()
ddTracer    --> UC1 : captures ExceptionSpanEvent

' WordPress side
phpRuntime  --> UC6
phpRuntime  --> UC12
wpAdmin     --> UC8
wpDropin    --> UC9
wpDropin    --> UC11

' ─── Use Case relationships ──────────────────────────────────────────────────

' Laravel: report always checks dontReport list
UC1 ..> UC4  : <<include>>

' WordPress: handle() always filters error types
UC6 ..> UC7  : <<include>>

' WordPress: sandbox/maintenance check can short-circuit handle()
UC6 <.. UC12 : <<extend>>\n(guard — early exit)

' WordPress: recovery mode is attempted when available (non-multisite)
UC6 <.. UC8  : <<extend>>\n(optional recovery)

' WordPress: custom drop-in template is attempted first
UC6 <.. UC9  : <<extend>>\n(if drop-in present)

' WordPress: default wp_die() page when no drop-in available
UC9  <.. UC10 : <<extend>>\n(fallback when drop-in absent)

' WordPress: drop-in can replace the entire handler
UC6 <.. UC11 : <<extend>>\n(full handler override)

' ─── Notes ───────────────────────────────────────────────────────────────────

note bottom of UC7
  Handles: E_ERROR, E_PARSE,
  E_USER_ERROR, E_COMPILE_ERROR,
  E_RECOVERABLE_ERROR.
  Extensible via wp_should_handle_php_error filter.
end note

note bottom of UC10
  HTTP 500 response via wp_die(WP_Error).
  Message customised by:
  • wp_php_error_message filter
  • wp_php_error_args filter
  Variants: recovery-mode active,
  admin protected endpoint, or generic.
end note

note top of UC1
  Parent Illuminate ExceptionHandler::report()
  is always delegated to.
  $dontReport skips IgnoredException (v10+).
end note

note right of ddTracer
  Datadog PHP tracer auto-instruments
  both pipelines, recording exceptions
  as ExceptionSpanEvent on active spans
  without disrupting host error handling.
end note

@enduml
