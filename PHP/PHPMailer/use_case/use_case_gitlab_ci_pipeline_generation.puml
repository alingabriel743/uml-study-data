@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title GitLab CI Pipeline Configuration Generation

left to right direction

' ── Actors ──────────────────────────────────────────────
actor "CI Engineer\n(Pipeline Maintainer)" as engineer
actor "GitLab CI Runner"                   as runner
actor "PHP Version Matrix\n(7.0 – 8.5)"   as phpMatrix
actor "Architecture Matrix\n(amd64, arm64)" as archMatrix

' ── System boundary ─────────────────────────────────────
rectangle "GitLab CI Pipeline Generation System\n(.gitlab/generate-*.php)" {

    ' ── Shared foundation ────────────────────────────────
    package "Shared Foundation (generate-common.php)" {
        usecase "Define PHP Version Matrices\n& ABI Map"       as UC7
        usecase "Define Shared Test\nService Containers"       as UC6
        usecase "Emit Default Retry Policy\n& YAML Anchors"    as UC_anchors
    }

    ' ── Component pipelines ──────────────────────────────
    package "Component Pipeline Generators" {
        usecase "Generate Tracer\nCI Pipeline"                 as UC1
        usecase "Generate Profiler\nCI Pipeline"               as UC2
        usecase "Generate AppSec\nCI Pipeline"                 as UC3
        usecase "Generate Shared Components\nCI Pipeline"      as UC5
    }

    ' ── Tracer sub-features ──────────────────────────────
    package "Tracer Pipeline Capabilities" {
        usecase "Compile PHP Extension\n(debug / ASAN / ZTS)"  as UC_compile
        usecase "Run Unit & C Extension\nTests"                as UC_unit
        usecase "Dynamic Integration\nTest Job Generation"     as UC9
        usecase "Windows Build & Test\n(PowerShell / NTS)"     as UC8
        usecase "Aggregate Tested\nVersions & Raise PR"        as UC10
    }

    ' ── Release pipeline ─────────────────────────────────
    package "Release & Packaging Pipeline (generate-package.php)" {
        usecase "Generate Package /\nRelease Pipeline"         as UC4
        usecase "Cross-Platform Packaging\n(APK / RPM / DEB / tar.gz)" as UC_pkg
        usecase "One-Pipeline & Benchmarks\nIntegration"       as UC_onepipe
        usecase "Configure System Tests\n(onboarding / profiling / appsec / SSI)" as UC_systest
    }
}

' ── Actor → Use-case associations ────────────────────────
engineer    --> UC1
engineer    --> UC2
engineer    --> UC3
engineer    --> UC4
engineer    --> UC5
engineer    --> UC7

phpMatrix   --> UC7
archMatrix  --> UC_compile

runner      --> UC_compile
runner      --> UC_unit
runner      --> UC8
runner      --> UC9
runner      --> UC10
runner      --> UC_pkg

' ── <<include>> relationships ────────────────────────────
UC1 ..> UC7         : <<include>>
UC1 ..> UC6         : <<include>>
UC1 ..> UC_anchors  : <<include>>

UC2 ..> UC7         : <<include>>
UC2 ..> UC6         : <<include>>
UC2 ..> UC_anchors  : <<include>>

UC3 ..> UC7         : <<include>>
UC3 ..> UC6         : <<include>>
UC3 ..> UC_anchors  : <<include>>

UC4 ..> UC7         : <<include>>
UC4 ..> UC_anchors  : <<include>>

UC5 ..> UC7         : <<include>>
UC5 ..> UC_anchors  : <<include>>

' ── <<extend>> / sub-feature relationships ───────────────
UC1 ..> UC_compile  : <<extend>>
UC1 ..> UC_unit     : <<extend>>
UC1 ..> UC9         : <<extend>>
UC1 ..> UC8         : <<extend>>
UC1 ..> UC10        : <<extend>>

UC4 ..> UC_pkg      : <<extend>>
UC4 ..> UC_onepipe  : <<extend>>
UC4 ..> UC_systest  : <<extend>>

UC9 ..> UC6         : <<include>>

' ── Notes ───────────────────────────────────────────────
note bottom of UC7
  PHP version filters:
  • all: 7.0 – 8.5
  • asan: 7.4+
  • profiler: 7.1+
  • windows: 7.2+
end note

note bottom of UC9
  Parses Makefile TEST_INTEGRATIONS_* /
  TEST_WEB_* targets; auto-injects
  services by target-name substring
  (e.g. "kafka" → Zookeeper + Kafka)
end note

note right of UC_pkg
  Package formats per platform:
  Alpine → APK
  GNU Linux → RPM + DEB + tar.gz
  Windows → dbgsym.tar.gz
end note

note right of UC3
  AppSec uses AWS ECR
  (role: ddbuild-dd-trace-php-ci)
  Coverage via Codecov + Datadog CI
end note

@enduml
