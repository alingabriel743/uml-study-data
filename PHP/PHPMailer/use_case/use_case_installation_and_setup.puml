@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #B8A800
    FontColor #333333
}

title Datadog PHP Agent Installation & Setup

left to right direction

' ── Actors ──────────────────────────────────────────────────────────
actor "DevOps Engineer" as devops

actor "GitHub Releases" as github #E8F5E9
actor "Packagist API" as packagist #E8F5E9
actor "Web Server\n(Apache / nginx / PHP-FPM)" as webserver #FFF3E0

' ── System boundary ──────────────────────────────────────────────────
rectangle "Datadog PHP Tracer Installer  (datadog-setup.php)" {

    ' Installation & Removal
    usecase "Install Datadog\nPHP Tracer" as UC1
    usecase "Uninstall Datadog\nPHP Tracer" as UC2

    ' INI / Configuration management
    usecase "Configure\nINI Setting" as UC3
    usecase "View\nINI Setting" as UC4
    usecase "List All Datadog\nINI Settings" as UC5

    ' Shared sub-flow
    usecase "Select PHP Binary\nInteractively" as UC7

    ' Manual post-install step
    usecase "Restart\nWeb Server" as UC8

    ' Dev/test utility (scoped separately)
    usecase "Update Integration\nPackage Versions\n«dev utility»" as UC6
}

' ── DevOps → Use Cases ───────────────────────────────────────────────
devops --> UC1 : php datadog-setup.php\n--install
devops --> UC2 : php datadog-setup.php\n--uninstall
devops --> UC3 : php datadog-setup.php\nconfig set -d key=value
devops --> UC4 : php datadog-setup.php\nconfig get -d key
devops --> UC5 : php datadog-setup.php\nconfig list
devops --> UC6 : php PackageUpdater.php
devops --> UC8 : manually restart\nafter install/uninstall

' ── Include relationships (shared sub-flow) ──────────────────────────
UC1 .> UC7 : <<include>>\n(when --php-bin absent)
UC2 .> UC7 : <<include>>\n(when --php-bin absent)
UC3 .> UC7 : <<include>>
UC4 .> UC7 : <<include>>
UC5 .> UC7 : <<include>>

' ── External system interactions ─────────────────────────────────────
UC1 --> github  : download dd-library-php\n<version>.tar.gz
UC6 --> packagist : GET /p2/<library>.json\n(latest stable version)
UC8 --> webserver : reload INI changes\ninto runtime

' ── Notes ────────────────────────────────────────────────────────────
note right of UC1
  Optional extensions installed
  on demand via CLI flags:
  • ddtrace.so (always)
  • datadog-profiling.so (--enable-profiling)
  • ddappsec.so (--enable-appsec)
  INI written to: 98-ddtrace.ini
  Default install dir: /opt/datadog
end note

note right of UC2
  Comments out extension= lines
  and removes .so files from
  extension_dir.
  Custom INI settings are preserved.
end note

note bottom of UC7
  Scans PATH + known paths
  (Remi Safe, Plesk, /usr/bin/php*).
  Skipped when --php-bin all|<path>
  is provided (non-interactive mode).
end note

note bottom of UC8
  Web server restart is NOT
  automated by the installer.
  DevOps must manually restart
  Apache / nginx / php-fpm for
  INI changes to take effect.
end note

note right of UC6
  Dev/test utility only.
  Not part of the production
  installer flow.
end note

@enduml
