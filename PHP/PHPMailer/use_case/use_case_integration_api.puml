@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 10

title Framework & Library Integration API\n(Datadog PHP Distributed Tracing — ddtrace)

left to right direction

' ── Actors ──────────────────────────────────────────────────
actor "Framework / Library\n(Laravel, Symfony, Guzzle,\nCurl, Kafka, PDO …)" as FrameworkLib
actor "Tracer Extension\n(ddtrace C ext)" as TracerExt
actor "Developer / Operator" as DevOps
actor "Monitoring System\n(Datadog Agent)" as DatadogAgent

' ── System boundary ─────────────────────────────────────────
rectangle "Framework & Library Integration API" {

    ' Integration lifecycle
    usecase "Register Integration\n(Integration::init(): int)" as UC_Register
    usecase "Check Integration\nEligibility" as UC_Check
    usecase "Instrument\nFramework Method" as UC_Instrument

    ' Span management
    usecase "Resolve Span\nService Name" as UC_ServiceName
    usecase "Configure\nTrace Analytics" as UC_Analytics
    usecase "Handle Orphan\nSpan" as UC_Orphan
    usecase "Capture Inferred\nSpan" as UC_Inferred

    ' Logging
    usecase "Emit Debug /\nWarning / Error Log" as UC_Log
    usecase "Configure\nGlobal Logger" as UC_ConfigLogger

    ' Include / extend relationships
    UC_Register ..> UC_Check        : <<include>>
    UC_Register ..> UC_Instrument   : <<include>>
    UC_Instrument ..> UC_ServiceName : <<include>>
    UC_Instrument ..> UC_Analytics   : <<extend>>
    UC_Log ..> UC_ConfigLogger       : <<extend>>
}

' ── Actor → Use-case associations ────────────────────────────
TracerExt    --> UC_Register
TracerExt    --> UC_Orphan
TracerExt    --> UC_Inferred

FrameworkLib --> UC_Instrument
FrameworkLib --> UC_Log

DevOps       --> UC_Check
DevOps       --> UC_Analytics
DevOps       --> UC_ConfigLogger

DatadogAgent --> UC_Inferred

' ── Notes ────────────────────────────────────────────────────
note bottom of UC_Register
  Returns NOT_LOADED (0), LOADED (1),
  or NOT_AVAILABLE (2).
  Requires ddtrace PHP extension loaded.
end note

note right of UC_Instrument
  Calls \\DDTrace\\trace_method(),
  \\DDTrace\\hook_method(), or
  \\DDTrace\\install_hook() to attach
  span-creation closures.
end note

note bottom of UC_Orphan
  Rejects sampling when
  DD_TRACE_REMOVE_AUTOINSTRUMENTATION_ORPHANS=true
  and span is a parentless RootSpanData.
end note

note bottom of UC_Analytics
  Reads DD_TRACE_ANALYTICS_ENABLED and
  per-integration rate config.
  Top-level (framework) integrations
  are enabled by default.
end note

note right of UC_ConfigLogger
  Logger singleton auto-selects:
  • ErrorLogLogger (DD_TRACE_DEBUG=true)
  • NullLogger (default / production)
  • DebugLogger (test-only, in-memory)
end note

@enduml
