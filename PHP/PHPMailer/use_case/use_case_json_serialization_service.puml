@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D8E8F8
    BorderColor #3A6EA5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title JSON Serialization Service\n<size:10><i>Services_JSON (wp-includes/class-json.php) — Deprecated since WP 5.3.0</i></size>

left to right direction

' ─────────────────── Actors ───────────────────
actor "WordPress Core\n(wp-includes)" as wpcore
actor "Plugin Developer" as plugin
actor "REST API Layer" as restapi
actor "PEAR Error System" as pear
actor "compat.php\n(Legacy Polyfill)" as compat

' ─────────────────── System Boundary ───────────────────
rectangle "JSON Serialization Service  (Services_JSON)" {

    ' Public encode/decode operations
    usecase "Encode PHP Value\nto JSON String" as UC1
    usecase "Encode PHP Value\nto JSON (Unsafe,\nNo HTTP Header)" as UC2
    usecase "Decode JSON String\nto PHP Value" as UC3

    ' Extended / specialised encode flows
    usecase "Serialize Object\nwith Custom toJSON()" as UC4
    usecase "Polyfill Global\njson_encode / json_decode\n(Legacy PHP Compat)" as UC9

    ' Error handling
    usecase "Check If Return Value\nIs an Error" as UC5

    ' Internal operations (shown for completeness)
    usecase "Convert UTF-8 Characters\nDuring Encoding" as UC6
    usecase "Build JSON\nName-Value Pair" as UC7
    usecase "Strip JSON Comments\nand Whitespace" as UC8
}

' ─────────────────── Actor → Use-Case associations ───────────────────
wpcore  --> UC1
wpcore  --> UC3
wpcore  --> UC5
wpcore  --> UC9

plugin  --> UC1
plugin  --> UC2
plugin  --> UC3
plugin  --> UC4
plugin  --> UC5

restapi --> UC2
restapi --> UC3

compat  --> UC9

pear    --> UC5

' ─────────────────── Include / Extend relationships ───────────────────
UC1 ..> UC2  : <<include>>
UC2 ..> UC6  : <<include>>
UC2 ..> UC7  : <<include>>
UC3 ..> UC8  : <<include>>
UC4 ..> UC2  : <<extend>>\nwhen SERVICES_JSON_USE_TO_JSON flag set

' ─────────────────── Notes ───────────────────
note bottom of UC1
  Sets <b>Content-Type: application/json</b> header
  before delegating to encodeUnsafe().
  Returns JSON string or Services_JSON_Error.
end note

note bottom of UC2
  <b>XSS risk</b> — no Content-Type header, no
  HTML escaping. Sets LC_NUMERIC locale to 'C'
  for decimal formatting consistency.
end note

note right of UC4
  Guards against infinite recursion.
  Returns Services_JSON_Error if
  toJSON() returns another toJSON-capable object.
end note

note right of UC9
  <b>Deprecated path.</b>
  compat.php wraps Services_JSON via global
  $wp_json. PHP native extension now required.
end note

note right of UC5
  Falls back to PEAR::isError()
  when PEAR library is present.
end note

@enduml
