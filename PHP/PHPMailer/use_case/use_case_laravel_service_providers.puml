@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Laravel Service Provider Integration\n<size:11>//Bootstrapping Datadog Tracing via Laravel Service Providers//</size>

left to right direction

' ─────────────────────────────────────────────
' Actors
' ─────────────────────────────────────────────
actor "Developer" as dev #D0E8FF
actor "Laravel Application\n(Kernel / Bootstrap)" as laravel #D5F5D5
actor "DDTrace PHP Extension\n(Auto-Instrumentation)" as ddtrace #FFE0B2
actor "AppSec Module\n(Security Tracking)" as appsec #F8D7DA

' ─────────────────────────────────────────────
' System Boundary
' ─────────────────────────────────────────────
rectangle "Laravel Application with Datadog Tracing" {

    ' ── Service Provider Bootstrap ──
    package "Service Provider Bootstrap" {
        usecase "Register Service Providers\n(config/app.php)" as UC_RegProviders
        usecase "Load Provider Repository\n(ProviderRepository::load)" as UC_LoadRepo
        usecase "Register Application Bindings\n(register())" as UC_Register
        usecase "Bootstrap Application Services\n(boot())" as UC_Boot
        usecase "Register Authentication Policies\n(AuthServiceProvider::boot)" as UC_AuthPolicies
        usecase "Register Event → Listener Mappings\n(EventServiceProvider::boot)" as UC_EventListeners
        usecase "Map Web & API Routes\n(RouteServiceProvider::map)" as UC_Routes
    }

    ' ── DDTrace Instrumentation ──
    package "DDTrace Instrumentation" {
        usecase "Initialise Tracing Integration\n(LaravelIntegration::init)" as UC_Init
        usecase "Create Root Request Span\n(laravel.request)" as UC_RootSpan
        usecase "Resolve Service Name\n(DD_SERVICE / app.php / .env)" as UC_ServiceName
        usecase "Trace Provider Load\n(laravel.provider.load span)" as UC_ProviderSpan
        usecase "Trace Route Action\n(laravel.action span)" as UC_ActionSpan
        usecase "Enrich Span with Route Metadata\n(route.name, http.url, http.method)" as UC_RouteEnrich
        usecase "Trace Event Dispatch\n(laravel.event.handle span)" as UC_EventSpan
        usecase "Trace View Render\n(laravel.view.render span)" as UC_ViewSpan
        usecase "Handle Artisan Console Span\n(laravel.artisan)" as UC_ArtisanSpan
        usecase "Report / Suppress Exceptions\n(root span error flags)" as UC_Exceptions
    }

    ' ── AppSec Security Tracking ──
    package "AppSec Security Event Tracking" {
        usecase "Track User Login Success\n(track_user_login_success_event_automated)" as UC_LoginOK
        usecase "Track User Login Failure\n(track_user_login_failure_event_automated)" as UC_LoginFail
        usecase "Track User Registration\n(track_user_signup_event_automated)" as UC_Signup
        usecase "Track Authenticated User\n(track_authenticated_user_event_automated)" as UC_AuthUser
    }
}

' ─────────────────────────────────────────────
' Developer relationships
' ─────────────────────────────────────────────
dev --> UC_RegProviders : configures providers\nin config/app.php
dev --> UC_ServiceName  : sets DD_SERVICE\nor APP_NAME

' ─────────────────────────────────────────────
' Laravel Application relationships
' ─────────────────────────────────────────────
laravel --> UC_LoadRepo
laravel --> UC_Register
laravel --> UC_Boot
laravel --> UC_Routes
laravel --> UC_AuthPolicies
laravel --> UC_EventListeners

UC_RegProviders ..> UC_LoadRepo   : <<include>>
UC_LoadRepo     ..> UC_Register   : <<include>>
UC_LoadRepo     ..> UC_Boot       : <<include>>
UC_Boot         ..> UC_AuthPolicies    : <<include>>
UC_Boot         ..> UC_EventListeners  : <<include>>
UC_Boot         ..> UC_Routes         : <<include>>

' ─────────────────────────────────────────────
' DDTrace PHP Extension relationships
' ─────────────────────────────────────────────
ddtrace --> UC_Init
ddtrace --> UC_RootSpan
ddtrace --> UC_ServiceName
ddtrace --> UC_ProviderSpan
ddtrace --> UC_ActionSpan
ddtrace --> UC_RouteEnrich
ddtrace --> UC_EventSpan
ddtrace --> UC_ViewSpan
ddtrace --> UC_ArtisanSpan
ddtrace --> UC_Exceptions

UC_Init       ..> UC_RootSpan      : <<include>>
UC_Init       ..> UC_ServiceName   : <<include>>
UC_RootSpan   ..> UC_ProviderSpan  : <<include>>
UC_ProviderSpan ..> UC_ActionSpan  : <<include>>
UC_ActionSpan ..> UC_RouteEnrich   : <<include>>
UC_ActionSpan ..> UC_ViewSpan      : <<extend>>
UC_EventSpan  ..> UC_Signup        : <<extend>>\n(eloquent.created:User)

' ─────────────────────────────────────────────
' AppSec Module relationships
' ─────────────────────────────────────────────
appsec --> UC_LoginOK
appsec --> UC_LoginFail
appsec --> UC_Signup
appsec --> UC_AuthUser

' ─────────────────────────────────────────────
' Notes
' ─────────────────────────────────────────────
note bottom of UC_Init
  DDTrace hooks at PHP extension level
  via trace_method / hook_method —
  **not** via a Laravel ServiceProvider
end note

note right of UC_ServiceName
  Priority: DD_SERVICE env →
  ddtrace_config_app_name() →
  config/app.php['name'] →
  APP_NAME env → 'laravel'
end note

note bottom of UC_ArtisanSpan
  DD_TRACE_REMOVE_ROOT_SPAN_LARAVEL_QUEUE
  controls span removal for queue workers
end note

@enduml
