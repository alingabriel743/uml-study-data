@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #EEF2F7
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontColor #5D4037
}

title OpenTracing API Compatibility\n<size:11><i>Using the OpenTracing standard API to start, propagate, and finish traces via DDTrace adapters</i></size>

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────────
actor "Application Developer" as Dev
actor "GlobalTracer\n(OT Registry)" as GT
actor "DDTrace Core\n(DDTracer)" as DDCore

' ── System Boundary ──────────────────────────────────────────────────────────
rectangle "OpenTracing API Compatibility  (DDTrace\\OpenTracer / DDTrace\\OpenTracer1)" {

    ' ── Initialization ────────────────────────────────────────────────────────
    package "Adapter Initialization" {
        usecase "Initialize OpenTracing Adapter\n<size:10>new Tracer(\\$ddTracer) or Tracer::make(...)</size>" as UC11
    }

    ' ── Span Lifecycle ────────────────────────────────────────────────────────
    package "Span Lifecycle" {
        usecase "Start a Span\n<size:10>startSpan(operationName, options)</size>" as UC1
        usecase "Start an Active Span\n<size:10>startActiveSpan(operationName, options)</size>" as UC2
        usecase "Get Active Span\n<size:10>getActiveSpan(): ?OTSpan</size>" as UC8
        usecase "Flush Completed Traces\n<size:10>flush()</size>" as UC9
    }

    ' ── Scope Management ──────────────────────────────────────────────────────
    package "Scope Management" {
        usecase "Get Scope Manager\n<size:10>getScopeManager(): OTScopeManager</size>" as UC7
        usecase "Activate an Existing Span\n<size:10>ScopeManager::activate(OTSpan, finishOnClose)</size>" as UC3
        usecase "Get Active Scope\n<size:10>ScopeManager::getActive(): ?OTScope</size>" as UC4
        usecase "Close All Root Scopes\n<size:10>ScopeManager::close()</size>" as UC10
    }

    ' ── Context Propagation ───────────────────────────────────────────────────
    package "Context Propagation" {
        usecase "Inject Span Context\n<size:10>inject(OTSpanContext, format, &carrier)</size>" as UC5
        usecase "Extract Span Context\n<size:10>extract(format, carrier): ?OTSpanContext</size>" as UC6
    }

    ' ── Internal include relationships ────────────────────────────────────────
    UC11 ..> UC1  : <<enable>>
    UC11 ..> UC2  : <<enable>>
    UC7  ..> UC3  : <<include>>
    UC7  ..> UC4  : <<include>>
    UC7  ..> UC10 : <<include>>
    UC3 <.. UC1  : <<extend>>\nactivate manually
    UC6 <.. UC5  : <<extend>>\npropagation pair
}

' ── Actor → Use Case Associations ────────────────────────────────────────────
Dev --> UC11
Dev --> UC1
Dev --> UC2
Dev --> UC3
Dev --> UC4
Dev --> UC5
Dev --> UC6
Dev --> UC7
Dev --> UC8
Dev --> UC9
Dev --> UC10

GT  --> UC11 : fallback when\nno tracer provided

DDCore --> UC1  : creates DDSpan\n+ sets SPAN_FLAG_OPENTRACING
DDCore --> UC2  : creates DDScope\n+ sets SPAN_FLAG_OPENTRACING
DDCore --> UC3  : delegates activate()
DDCore --> UC4  : reconcileInternalAndUserland()
DDCore --> UC5  : Propagator::inject()\n(DD headers)
DDCore --> UC6  : Propagator::extract()\n(DD headers)
DDCore --> UC8  : getActiveSpan()
DDCore --> UC9  : flush() buffered spans
DDCore --> UC10 : close hostRootScopes

' ── Notes ────────────────────────────────────────────────────────────────────
note bottom of UC5
  Propagation headers:
  x-datadog-trace-id
  x-datadog-parent-id
  x-datadog-sampling-priority
  x-datadog-origin
  ot-baggage-{key}
end note

note right of UC11
  Two adapter variants:
  • OpenTracer  — legacy, permissive types
  • OpenTracer1 — OT 1.x, strict PHP types
  Both implement OpenTracing\\ITracer
end note

note right of UC3
  Span::unwrapped() or
  Span::toDDSpan() converts
  OT Span → DDSpan before
  delegating to DDTrace core
end note

@enduml
