@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Scope & Active Span Management\n(DDTrace PHP Tracer — OpenTracing Compatible)

left to right direction

' ── Primary Actors (left) ───────────────────────────────
actor "Application\nDeveloper" as AppDev
actor "OpenTracing\nClient" as OTClient

' ── System Actors (right) ───────────────────────────────
actor "DDTrace\nTracer" as DDTracer
actor "C Extension\n(root_span / active_span)" as CExt

' ── System Boundary ─────────────────────────────────────
rectangle "DDTrace Scope Management System" {

    usecase "Activate Span\n(make span active via Scope)" as UC1
    usecase "Query Active Scope\n(get current active Span)" as UC2
    usecase "Close Scope\n(end scope, optionally finish Span)" as UC3
    usecase "Close All Root Scopes\n(end-of-request cleanup)" as UC4
    usecase "Reconcile Internal &\nUserland Spans\n(sync C-ext spans → PHP stack)" as UC5
    usecase "Deactivate Scope\n(remove from scope stack)" as UC6
    usecase "Get Primary Root Scope\n(outermost request scope)" as UC7
    usecase "Unwrap to Native\nScopeManager\n(OT adapter interop)" as UC8

}

' ── Actor → Use Case Associations ───────────────────────
AppDev  --> UC1
AppDev  --> UC2
AppDev  --> UC3

OTClient --> UC1
OTClient --> UC2
OTClient --> UC3
OTClient --> UC8

DDTracer --> UC4
DDTracer --> UC6
DDTracer --> UC7

CExt --> UC5

' ── Include Relationships ────────────────────────────────
UC2 .right.> UC5 : <<include>>
UC7 .right.> UC5 : <<include>>
UC3 .down.>  UC6 : <<include>>
UC4 .up.>    UC3 : <<include>>

' ── Notes ────────────────────────────────────────────────
note bottom of UC1
  Implementations:
  • DDTrace\\ScopeManager — pushes onto $scopes stack;
    tracks hostRootScopes for distributed-tracing entry points
  • DDTrace\\NoopScopeManager — returns NoopScope (tracing disabled)
  • OpenTracer/OpenTracer1 adapters — unwrap OT span,
    delegate to inner ScopeManager, re-wrap result as OT Scope
end note

note bottom of UC3
  DEFAULT_FINISH_SPAN_ON_CLOSE = true
  Closing a Scope finishes its wrapped Span by default.
  Set finishSpanOnClose=false to keep Span alive after close.
end note

note bottom of UC5
  Bridges C-extension internal spans
  (root_span() / active_span()) into
  the PHP userland scope stack.
  Critical for correct parent-child
  relationship resolution.
end note

note right of UC8
  OpenTracer & OpenTracer1 adapters
  expose unwrapped() to access the
  underlying DDTrace ScopeManager
  directly for interoperability.
end note

@enduml
