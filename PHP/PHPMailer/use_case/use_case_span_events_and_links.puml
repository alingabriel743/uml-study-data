@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Span Events, Links & Git Metadata\n<i>DDTrace PHP Library — Attaching structured events, causal links, and source-code Git metadata to spans</i>

left to right direction

' ── Actors ──────────────────────────────────────────────────
actor "Developer\n(Instrumentor)" as Dev
actor "OpenTelemetry\nBridge (OTel Span)" as OTel
actor "DDTrace Runtime\n(C Extension)" as Runtime

' ── System Boundary ─────────────────────────────────────────
rectangle "DDTrace PHP — Span Events, Links & Git Metadata" {

    ' ── Span Events ─────────────────────────────────────────
    package "Span Events" {
        usecase "Attach Named Event\nto Span" as UC1
        usecase "Record Exception\non Span" as UC2
        usecase "Bridge OTel addEvent\nto DDTrace SpanEvent" as UC7
    }

    ' ── Span Links ──────────────────────────────────────────
    package "Span Links" {
        usecase "Link Span to\nAnother Span / Trace" as UC3
        usecase "Get Pre-populated SpanLink\nfrom Current Span" as UC4
        usecase "Build SpanLink from\nDistributed Tracing Headers" as UC5
        usecase "Bridge OTel addLink\nto DDTrace SpanLink" as UC8
    }

    ' ── Git Metadata ────────────────────────────────────────
    package "Git Metadata" {
        usecase "Attach Git Metadata\nto Root Span" as UC6
    }

    ' ── Serialization ───────────────────────────────────────
    package "Export & Serialization" {
        usecase "Serialize Events / Links\nto JSON" as UC9
    }

    ' ── Include / Extend relationships ──────────────────────
    UC2 ..> UC1 : <<extend>>\nexception wraps event
    UC4 ..> UC3 : <<include>>\npre-populates traceId/spanId
    UC5 ..> UC3 : <<include>>\nfactory from headers
    UC7 ..> UC1 : <<include>>\ndelegates to SpanData
    UC8 ..> UC3 : <<include>>\ndelegates to SpanData
    UC1 ..> UC9 : <<include>>\nJsonSerializable
    UC3 ..> UC9 : <<include>>\nJsonSerializable
}

' ── Actor → Use Case associations ───────────────────────────
Dev --> UC1
Dev --> UC2
Dev --> UC3
Dev --> UC4
Dev --> UC5

OTel --> UC7
OTel --> UC8

Runtime --> UC6
Runtime --> UC9

' ── Notes ────────────────────────────────────────────────────
note bottom of UC4
  <b>Encoding warning:</b> SpanLink::$traceId must NOT
  be assigned directly from SpanData::$id —
  use SpanData::getLink() (different hex encoding)
end note

note bottom of UC6
  Git commit SHA & repo URL are auto-populated
  by the C extension from the filesystem
  (refs/heads/master, remote URL).
  Not set manually by developers.
end note

note bottom of UC9
  Both SpanEvent and SpanLink implement
  JsonSerializable for export to the
  Datadog Agent (defined in ddtrace.stub.php)
end note

@enduml
