@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #FFF9E6
skinparam NoteBorderColor #CCA300

left to right direction

title Symfony Framework Auto-Instrumentation

' ── Actors ──────────────────────────────────────────────────────────
actor "Developer / Operator" as DevOps
actor "Symfony HttpKernel" as HttpKernel
actor "Symfony EventDispatcher" as EventDispatcher
actor "Symfony Router /\nContainer" as Router
actor "AppSec Module" as AppSec
actor "Doctrine ORM" as Doctrine

' ── System Boundary ─────────────────────────────────────────────────
rectangle "DDTrace Symfony Integration  (DDTrace\\Integrations\\Symfony)" {

    package "HTTP Lifecycle Tracing" {
        usecase "Instrument HTTP Request\n(symfony.request span)" as UC1
        usecase "Instrument Kernel Boot\n(symfony.httpkernel.kernel.boot)" as UC2
        usecase "Set HTTP Route Tag\non Root Span" as UC3
        usecase "Inject Controller /\nAction Metadata" as UC4
    }

    package "Endpoint Discovery" {
        usecase "Discover & Catalog\nHTTP Endpoints" as UC5
        usecase "Read Router Cache Files\n(url_generating_routes.php)" as UC6
        usecase "Resolve Route\nPath Template" as UC7
        usecase "Extract HTTP Methods\nby Route" as UC8
    }

    package "Event & Component Tracing" {
        usecase "Trace EventDispatcher\nEvents" as UC9
        usecase "Handle & Annotate\nExceptions" as UC12
    }

    package "AppSec Security Tracking" {
        usecase "Track User\nLogin Success / Failure" as UC13
        usecase "Track User\nSignup" as UC14
        usecase "Track Authenticated\nUser Access Decision" as UC15
    }

    usecase "Configure via\nEnvironment Flags" as UC16
}

' ── Actor → Use Case associations ───────────────────────────────────
DevOps          --> UC16

HttpKernel      --> UC1
HttpKernel      --> UC2
HttpKernel      --> UC12

EventDispatcher --> UC9
EventDispatcher --> UC5

Router          --> UC5
Router          --> UC7

AppSec          --> UC13
AppSec          --> UC15

Doctrine        --> UC14

' ── Include / Extend relationships ──────────────────────────────────
UC1  ..> UC3  : <<include>>
UC1  ..> UC4  : <<include>>
UC5  ..> UC6  : <<include>>
UC5  ..> UC7  : <<include>>
UC5  ..> UC8  : <<include>>
UC6 <.. UC7  : <<extend>>

' ── Notes ───────────────────────────────────────────────────────────
note bottom of UC5
  Triggered lazily at first EventDispatcher::dispatch call
  (ensures Symfony container & router are fully initialised).
  Prefers compiled cache files for performance;
  falls back to live RouteCollection if cache unavailable.
  Calls DDTrace\\add_endpoint() + DDTrace\\flush_endpoints().
end note

note right of UC3
  Controlled by DD_TRACE_SYMFONY_HTTP_ROUTE flag.
  Sets meta[http.route] = /path/{param} template.
  Route resource naming driven by
  DD_HTTP_SERVER_ROUTE_BASED_NAMING.
end note

note bottom of UC16
  Key environment flags:
  • DD_TRACE_SYMFONY_HTTP_ROUTE
  • DD_HTTP_SERVER_ROUTE_BASED_NAMING
  • DD_TRACE_REMOVE_ROOT_SPAN_SYMFONY_MESSENGER
end note

@enduml
