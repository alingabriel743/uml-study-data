@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Transport & Datadog Agent Communication

left to right direction

' ── Actors ──────────────────────────────────────────────
actor "PHP Application" as phpApp
actor "Test Suite\n(PHPUnit)" as testSuite

actor "Datadog Agent\n(local sidecar)" as ddAgent
actor "C Extension /\nBackground Sender" as cext

' ── System boundary ─────────────────────────────────────
rectangle "ddtrace PHP Tracer — Transport Layer" {

    ' Production path
    usecase "Flush Traces\nto Agent" as UC1
    usecase "Send via Internal\n(Production) Transport" as UC2
    usecase "Set Transport\nHeader" as UC6

    ' C extension / BGS path
    usecase "Serialize & Deliver\nTrace Payload\n(msgpack → HTTP / UDS)" as UC3

    ' Test path
    usecase "Capture Traces\nin Memory (Test Mode)" as UC4
    usecase "Inspect Captured\nTraces" as UC5

    ' Web-server integration test path
    usecase "Start Web Server\nSAPI for Integration\nTesting" as UC7
    usecase "Stop Web Server &\nAwait BGS Flush" as UC8
    usecase "Log Debug / Warning /\nError Messages" as UC9
    usecase "Check Server\nErrors" as UC10
}

' ── Actor → Use-case associations ───────────────────────
phpApp  --> UC1
phpApp  --> UC2
phpApp  --> UC6

cext    --> UC3

testSuite --> UC4
testSuite --> UC5
testSuite --> UC7
testSuite --> UC8
testSuite --> UC9
testSuite --> UC10

UC3 --> ddAgent

' ── Include / Extend relationships ──────────────────────
UC1 ..> UC2 : <<include>>
UC2 ..> UC3 : <<include>>

UC1 ..> UC4 : <<extend>>\n[test mode]

UC7 ..> UC9 : <<extend>>
UC8 ..> UC9 : <<extend>>
UC10 ..> UC9 : <<include>>

' ── Notes ───────────────────────────────────────────────
note right of UC3
  C extension (BGS) handles:
  • msgpack serialization
  • HTTP POST to /v0.4/traces
    (DD_AGENT_HOST:DD_TRACE_AGENT_PORT)
  • Unix Domain Socket
    (DD_TRACE_AGENT_URL=unix://…)
  • Async background delivery
end note

note right of UC4
  DebugTransport stores spans
  in-memory; no network call.
  Used exclusively in test code
  (tests/DebugTransport.php).
end note

note bottom of UC8
  WebServer::stop() sleeps
  2 × DD_TRACE_AGENT_FLUSH_INTERVAL
  to ensure BGS delivers all
  traces before process exits.
end note

note top of UC2
  Internal transport is the default
  when no transport is injected into
  Tracer constructor.
  setHeader() is a no-op for Internal
  and Noop transports.
end note

@enduml
