@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title WordPress REST API — Block Renderer\n<size:11>(WP_REST_Block_Renderer_Controller · wp/v2/block-renderer)</size>

left to right direction

' ── Actors ──────────────────────────────────────────────
actor "API Consumer\n(Editor / Plugin / Theme)" as Consumer
actor "WordPress\nAuth System" as AuthSystem
actor "WP_Block_Type_Registry\n(Singleton)" as BlockRegistry

' ── System Boundary ─────────────────────────────────────
rectangle "WordPress REST API  (wp/v2)" {

    usecase "Render Block\nvia REST API\n<size:10>GET|POST /wp/v2/block-renderer/{name}</size>" as UC1
    usecase "Check Block\nRender Permission\n<size:10>get_item_permissions_check()</size>" as UC2
    usecase "Validate Block\nAttributes\n<size:10>rest_validate / rest_sanitize\n_value_from_schema()</size>" as UC3
    usecase "Execute Block\nRender\n<size:10>get_item() → render_block()</size>" as UC4
    usecase "Retrieve Block\nOutput Schema\n<size:10>get_item_schema()</size>" as UC5
    usecase "Register Block\nRenderer Route\n<size:10>register_routes() on REST init</size>" as UC6

}

' ── Actor → Use Case associations ───────────────────────
Consumer  --> UC1
Consumer  --> UC5
AuthSystem --> UC6

' ── Include relationships ────────────────────────────────
UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>

' ── Secondary actor interactions ────────────────────────
UC2 --> AuthSystem   : current_user_can()\nedit_posts | edit_post
UC4 --> BlockRegistry : get_instance()\n→ get_registered(name)

' ── Notes (business rules) ───────────────────────────────
note bottom of UC2
  **Permission branching:**
  • post_id > 0  → current_user_can('edit_post', post_id)
  • post_id == 0 → current_user_can('edit_posts')
  • Failure returns 401 / 403  (block_cannot_read)
end note

note right of UC4
  **Dynamic-block guard:**
  Only blocks with a render_callback
  are served — non-dynamic blocks
  return 404 (block_invalid).
  render_block() is called (not the
  callback directly) so all WP
  filters are applied.
end note

note right of UC3
  **Attribute validation:**
  Schema sourced from
  WP_Block_Type::get_attributes().
  Attributes are both validated AND
  sanitized before rendering.
end note

note bottom of UC5
  Response schema title: "rendered-block"
  Field: rendered (string, context: edit only)
  — not exposed in public context
end note

@enduml
