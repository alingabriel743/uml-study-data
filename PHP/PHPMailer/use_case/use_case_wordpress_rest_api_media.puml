@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BorderColor #495057
    FontColor #212529
    BackgroundColor #DEE2E6
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #333333
}

left to right direction

title WordPress REST API — Media & Attachments

' ── Primary Actors (left side) ──────────────────────────────────────────────
actor "API Consumer" as consumer
actor "Authenticated\nEditor" as editor

' ── Secondary / External Actors (right side) ────────────────────────────────
actor "WordPress\nFile System" as filesystem
actor "getID3\nLibrary" as getid3
actor "External oEmbed\nProvider" as oembed_provider
actor "WordPress\nTransient Cache" as cache

' ════════════════════════════════════════════════════════════════════════════
rectangle "WordPress REST API — Media & Attachments" {

    ' ── Media Attachments group ─────────────────────────────────────────────
    package "Media Attachments  /wp/v2/media" as PKG_MEDIA {
        usecase "List Media Attachments\nGET /wp/v2/media" as UC2
        usecase "Retrieve Single Attachment\nGET /wp/v2/media/{id}" as UC3
        usecase "Upload Media Attachment\nPOST /wp/v2/media" as UC1
        usecase "Update Attachment Metadata\nPUT|PATCH /wp/v2/media/{id}" as UC4
        usecase "Delete Attachment\nDELETE /wp/v2/media/{id}" as UC8
        usecase "Post-Process Attachment\nPOST /wp/v2/media/{id}/post-process" as UC5
    }

    ' ── Upload sub-functions group ──────────────────────────────────────────
    package "Upload Processing Sub-Functions" as PKG_UPLOAD {
        usecase "Validate Upload Permissions\n(upload_files + edit_post on parent)" as SUB1
        usecase "Check Upload Size\n(multisite quota enforcement)" as SUB2
        usecase "Parse Content-Disposition Header\n(RFC 6266 filename extraction)" as SUB3
        usecase "Extract Image EXIF/IPTC Metadata\n(wp_read_image_metadata)" as SUB4
        usecase "Generate Attachment Metadata\n(wp_generate_attachment_metadata)" as SUB5
        usecase "Create Image Sub-sizes" as SUB6
        usecase "Validate Update Permissions\n(edit_post on attachment)" as SUB7
    }

    ' ── oEmbed group ────────────────────────────────────────────────────────
    package "oEmbed  /oembed/1.0" as PKG_OEMBED {
        usecase "Get oEmbed Data for WP Post\nGET /oembed/1.0/embed" as UC6
        usecase "Proxy External oEmbed Request\nGET /oembed/1.0/proxy" as UC7
        usecase "Validate oEmbed Proxy Permissions\n(edit_posts capability)" as SUB8
        usecase "Cache oEmbed Response\n(transient, default TTL 24 h)" as SUB9
    }
}

' ════════════════════════════════════════════════════════════════════════════
' Actor → Use Case associations
' ════════════════════════════════════════════════════════════════════════════

' API Consumer (unauthenticated read operations)
consumer --> UC2
consumer --> UC3
consumer --> UC6

' Authenticated Editor (write / privileged operations)
editor --> UC1
editor --> UC4
editor --> UC5
editor --> UC8
editor --> UC7

' Secondary actor connections
filesystem --> UC1  : wp_handle_upload\n/ wp_handle_sideload
getid3    --> SUB5  : format-specific\nmetadata extraction
oembed_provider --> UC7 : fetch embed data
cache --> SUB9      : get/set_transient

' ════════════════════════════════════════════════════════════════════════════
' <<include>> relationships (mandatory sub-flows)
' ════════════════════════════════════════════════════════════════════════════
UC1 .> SUB1 : <<include>>
UC1 .> SUB2 : <<include>>
UC1 .> SUB3 : <<include>>
UC1 .> SUB4 : <<include>>
UC1 .> SUB5 : <<include>>
SUB5 .> SUB6 : <<include>>

UC5 .> SUB7 : <<include>>
UC7 .> SUB8 : <<include>>
UC7 .> SUB9 : <<include>>

' ════════════════════════════════════════════════════════════════════════════
' <<extend>> relationships (conditional / optional flows)
' ════════════════════════════════════════════════════════════════════════════
UC5 .> UC1 : <<extend>>\nretry sub-size generation\nafter PHP fatal
UC7 .> UC6 : <<extend>>\nproxy handles external URLs;\nUC6 handles internal WP URLs

' ════════════════════════════════════════════════════════════════════════════
' Business-rule notes
' ════════════════════════════════════════════════════════════════════════════
note bottom of UC1
  Two upload paths:
  • Multipart $_FILES → wp_handle_upload
  • Raw POST body → wp_handle_sideload
  Content-MD5 header validates integrity (412 on mismatch).
  X-WP-Upload-Attachment-ID header enables client retry via UC5.
end note

note bottom of UC7
  oEmbed proxy requires "edit_posts" cap
  to prevent SSRF abuse by anonymous users.
  discover=true enables autodiscovery for
  non-whitelisted providers.
end note

note right of SUB2
  Multisite enforces
  per-site upload space
  quota and per-user quota.
end note

@enduml
