@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #1A1A2E
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #EEF2F7
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontColor #4A3800
}

title WordPress REST API — Posts & Content\n<size:11><color:#6C757D>WP_REST_Posts_Controller · WP_REST_Revisions_Controller · WP_REST_Blocks_Controller</color></size>

left to right direction

' ──────────────────────────────
'  Actors
' ──────────────────────────────
actor "API Consumer" as consumer #D0E8FF
note right of consumer
  Any external client:
  headless app, plugin,
  editor UI
end note

actor "Authenticated Editor" as editor #C8E6C9
note right of editor
  Requires: create_posts,
  edit_post, delete_post
  capabilities
end note

actor "Administrator" as admin #FFE0B2
note right of admin
  Requires: edit_others_posts,
  publish_posts,
  delete_post on parent
  & revision
end note

actor "WordPress Core" as wpcore #E8EAF6
note right of wpcore
  WP_Query, wp_insert_post,
  wp_update_post,
  wp_delete_post,
  wp_trash_post,
  revision engine
end note

' ──────────────────────────────
'  System Boundary
' ──────────────────────────────
rectangle "WordPress REST API  (namespace: wp/v2)" {

    ' ── Posts sub-boundary ──
    package "Posts  [ /wp/v2/{post_type} ]" {
        usecase "List Posts\nGET /wp/v2/{post_type}" as UC_P1
        usecase "Get Single Post\nGET /wp/v2/{post_type}/{id}" as UC_P2
        usecase "Create Post\nPOST /wp/v2/{post_type}" as UC_P3
        usecase "Update Post\nPUT|PATCH /wp/v2/{post_type}/{id}" as UC_P4
        usecase "Delete Post\nDELETE /wp/v2/{post_type}/{id}" as UC_P5
    }

    ' ── Shared sub-use-cases ──
    package "Shared Post Operations" {
        usecase "Authenticate Request\n& Check Capabilities" as UC_AUTH
        usecase "Handle Featured Media\n& Taxonomy Terms" as UC_META
        usecase "Trash Post\n(soft delete)" as UC_TRASH
        usecase "Permanently Delete\n(?force=true)" as UC_FORCE
        usecase "Access Password-\nProtected Content" as UC_PASS
    }

    ' ── Revisions sub-boundary ──
    package "Revisions  [ /wp/v2/{parent_base}/{parent}/revisions ]" {
        usecase "List Revisions\nGET …/revisions" as UC_R1
        usecase "Get Single Revision\nGET …/revisions/{id}" as UC_R2
        usecase "Delete Revision\nDELETE …/revisions/{id}?force=true" as UC_R3
        usecase "Inherit Revision Schema\nfrom Parent Post Type" as UC_RSCHEMA
    }

    ' ── Blocks sub-boundary ──
    package "Reusable Blocks  [ /wp/v2/blocks ]" {
        usecase "List Reusable Blocks\nGET /wp/v2/blocks" as UC_B1
        usecase "Get Single Block\nGET /wp/v2/blocks/{id}" as UC_B2
        usecase "Create Reusable Block\nPOST /wp/v2/blocks" as UC_B3
        usecase "Update Reusable Block\nPUT /wp/v2/blocks/{id}" as UC_B4
        usecase "Delete Reusable Block\nDELETE /wp/v2/blocks/{id}" as UC_B5
    }

}

' ──────────────────────────────
'  Actor → Use Case associations
' ──────────────────────────────

' API Consumer (public read)
consumer --> UC_P1
consumer --> UC_P2

' Authenticated Editor — posts
editor --> UC_P3
editor --> UC_P4
editor --> UC_P5
editor --> UC_R1
editor --> UC_R2
editor --> UC_B1
editor --> UC_B2
editor --> UC_B3
editor --> UC_B4
editor --> UC_B5

' Administrator — elevated operations
admin --> UC_P3 : assign author /\nset sticky
admin --> UC_P4 : edit others' posts
admin --> UC_R3

' WordPress Core — internal processing
wpcore --> UC_META
wpcore --> UC_TRASH
wpcore --> UC_FORCE

' ──────────────────────────────
'  Include / Extend relationships
' ──────────────────────────────

' Permissions are checked on every mutating call
UC_P3 ..> UC_AUTH : <<include>>
UC_P4 ..> UC_AUTH : <<include>>
UC_P5 ..> UC_AUTH : <<include>>
UC_R1 ..> UC_AUTH : <<include>>
UC_R3 ..> UC_AUTH : <<include>>
UC_B3 ..> UC_AUTH : <<include>>
UC_B4 ..> UC_AUTH : <<include>>
UC_B5 ..> UC_AUTH : <<include>>

' Create / Update trigger media & term handling
UC_P3 ..> UC_META : <<include>>
UC_P4 ..> UC_META : <<include>>

' Delete extensions
UC_P5 ..> UC_TRASH  : <<extend>>\n[EMPTY_TRASH_DAYS > 0]
UC_P5 ..> UC_FORCE  : <<extend>>\n[force=true]
UC_B5 ..> UC_FORCE  : <<include>>\n[no trash support]
UC_R3 ..> UC_FORCE  : <<include>>\n[mandatory]

' Password-protected access
UC_P2 ..> UC_PASS : <<extend>>\n[password-protected post]

' Revision schema inheritance
UC_R1 ..> UC_RSCHEMA : <<include>>
UC_R2 ..> UC_RSCHEMA : <<include>>

' ──────────────────────────────
'  Business Rule Notes
' ──────────────────────────────
note bottom of UC_P5
  Soft delete (trash) when EMPTY_TRASH_DAYS > 0.
  Hard delete requires ?force=true.
end note

note bottom of UC_R3
  Revisions do NOT support trash.
  ?force=true is ALWAYS required.
end note

note bottom of UC_B3
  wp_block post type.
  Only raw title/content exposed —
  rendered fields intentionally omitted.
end note

note bottom of UC_P3
  Returns HTTP 201 Created + Location header.
  Fires: rest_insert_{post_type},
         rest_after_insert_{post_type}.
  Batch operations supported (v1).
end note

@enduml
