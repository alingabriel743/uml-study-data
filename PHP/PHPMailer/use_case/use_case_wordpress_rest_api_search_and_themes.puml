@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7FC1
    FontColor #1B3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontColor #333333
}

title WordPress REST API — Search, Themes & Settings\n<size:11><color:#6C757D>Namespace: wp/v2 — Search, Themes & Settings Controllers</color></size>

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────────
actor "API Consumer\n(Anonymous)" as anon
actor "API Consumer\n(Authenticated / Editor)" as editor
actor "API Consumer\n(Admin)" as admin
actor "WordPress Core" as wpcore

' ── System boundary ─────────────────────────────────────────────────────────
rectangle "WordPress REST API  [wp/v2]" {

    ' ── Search ────────────────────────────────────────────────────────────
    package "Search  (WP_REST_Search_Controller)" {
        usecase "Search Site Content\nGET /wp/v2/search" as UC1
        usecase "Search Posts\n(type=post)" as UC2
        usecase "Search Terms\n(type=term)" as UC3
        usecase "Search Post Formats\n(type=post-format)" as UC4
    }

    ' ── Themes ────────────────────────────────────────────────────────────
    package "Themes  (WP_REST_Themes_Controller)" {
        usecase "List All Themes\nGET /wp/v2/themes" as UC5
        usecase "List Active Theme Only\nGET /wp/v2/themes?status[]=active" as UC6
        usecase "Get Single Theme\nGET /wp/v2/themes/{stylesheet}" as UC7
    }

    ' ── Settings ──────────────────────────────────────────────────────────
    package "Settings  (WP_REST_Settings_Controller)" {
        usecase "Read Site Settings\nGET /wp/v2/settings" as UC8
        usecase "Update Site Settings\nPOST|PUT|PATCH /wp/v2/settings" as UC9
    }
}

' ── Actor → Use-Case associations ───────────────────────────────────────────

' Anonymous can search freely (public endpoint)
anon --> UC1

' Editor can list the active theme and retrieve a single active theme
editor --> UC6
editor --> UC7

' Admin has full theme access + settings read/write
admin --> UC5
admin --> UC7
admin --> UC8
admin --> UC9

' WordPress Core is invoked internally by all controllers
UC1 ..> wpcore : <<uses>>\nWP_Query
UC5 ..> wpcore : <<uses>>\nwp_get_themes()
UC6 ..> wpcore : <<uses>>\nwp_get_theme()
UC7 ..> wpcore : <<uses>>\nwp_get_theme()
UC8 ..> wpcore : <<uses>>\nget_option()\nget_registered_settings()
UC9 ..> wpcore : <<uses>>\nupdate_option()\ndelete_option()

' ── Search handler include relationships ────────────────────────────────────
UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>

' ── UC6 extends UC5 (lower-privilege subset) ────────────────────────────────
UC6 ..> UC5 : <<extend>>\nstatus[]=active only

' ── UC9 includes read to return updated state ────────────────────────────────
UC9 ..> UC8 : <<include>>\nreturns updated settings

' ── Notes ────────────────────────────────────────────────────────────────────
note right of UC1
  <b>Public endpoint — no auth required</b>
  Supports pagination via page / per_page.
  Returns: id, title, url, type, subtype.
  Added in WordPress 5.0.
end note

note right of UC5
  <b>Requires:</b> switch_themes
  <b>OR</b> manage_network_themes capability.
  Always returns X-WP-TotalPages = 1.
  <i>rest_prepare_theme</i> filter applied
  to each theme response.
end note

note right of UC6
  <b>Lower-privilege path:</b>
  edit_posts or REST post-type edit cap.
  Only the active theme is returned;
  theme_supports field is populated.
end note

note bottom of UC8
  <b>Requires:</b> manage_options capability.
  Returns all show_in_rest=true options.
  Filters: rest_pre_get_setting
end note

note bottom of UC9
  <b>Requires:</b> manage_options capability.
  null value → delete_option().
  Null rejected if stored value already
  invalid (prevents accidental wipe).
  Filters: rest_pre_update_setting
end note

@enduml
