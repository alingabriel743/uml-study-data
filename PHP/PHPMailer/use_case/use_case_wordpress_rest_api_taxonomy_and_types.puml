@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #FFFFFF
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9E3
    BorderColor #C9A700
    FontColor #212529
}

title WordPress REST API — Taxonomies & Post Types

left to right direction

actor "API Consumer" as consumer
actor "Authenticated\nEditor" as editor
actor "WordPress Core" as wpcore

rectangle "WordPress REST API  (wp/v2)  —  Read-Only Metadata Endpoints" {

    package "Taxonomies  (/wp/v2/taxonomies)" {
        usecase "List Taxonomies\nGET /taxonomies" as UC1
        usecase "Retrieve Single Taxonomy\nGET /taxonomies/{taxonomy}" as UC2
        usecase "Filter Taxonomies\nby Post Type  (?type=...)" as UC3
    }

    package "Post Types  (/wp/v2/types)" {
        usecase "List Post Types\nGET /types" as UC4
        usecase "Retrieve Single Post Type\nGET /types/{type}" as UC5
    }

    package "Post Statuses  (/wp/v2/statuses)" {
        usecase "List Post Statuses\nGET /statuses" as UC6
        usecase "Retrieve Single Post Status\nGET /statuses/{status}" as UC7
    }

    usecase "Apply Context Parameter\n(view | edit | embed)" as UC_CTX
    usecase "Check Read Permission" as UC_PERM

}

' ── API Consumer (public / unauthenticated) ────────────────────────────────
consumer --> UC1
consumer --> UC2
consumer --> UC4
consumer --> UC5
consumer --> UC6
consumer --> UC7

' ── Authenticated Editor (unlocks edit context & non-public resources) ─────
editor --> UC1
editor --> UC2
editor --> UC4
editor --> UC5
editor --> UC6
editor --> UC7

' ── WordPress Core provides registry data ──────────────────────────────────
wpcore --> UC1 : get_taxonomies()
wpcore --> UC4 : get_post_types()
wpcore --> UC6 : get_post_stati()

' ── Extend: optional ?type= filter specialises List Taxonomies ─────────────
UC3 .> UC1 : <<extend>>

' ── Include: Context Parameter is shared by every endpoint ─────────────────
UC1 .> UC_CTX : <<include>>
UC2 .> UC_CTX : <<include>>
UC4 .> UC_CTX : <<include>>
UC5 .> UC_CTX : <<include>>
UC6 .> UC_CTX : <<include>>
UC7 .> UC_CTX : <<include>>

' ── Include: Read-permission check used by both status use-cases ───────────
UC6 .> UC_PERM : <<include>>
UC7 .> UC_PERM : <<include>>

' ── Notes ──────────────────────────────────────────────────────────────────
note bottom of UC2
  Returns 404 if taxonomy not found
  or show_in_rest = false (403).
  Response includes HAL _links
  (collection + items endpoint).
end note

note bottom of UC5
  Permission callback is __return_true;
  visibility enforced inside get_item().
  show_in_rest must be true.
  Response embeds associated taxonomy slugs
  via get_object_taxonomies().
end note

note bottom of UC_CTX
  'edit' context returns extra fields:
  capabilities, labels, visibility, supports.
  Requires assign_terms (taxonomies)
  or edit_posts (post types / statuses).
  Enforced via filter_response_by_context().
end note

note bottom of UC_PERM
  Public statuses: always allowed.
  Non-public or 'trash': requires
  edit_posts on at least one
  REST-enabled post type.
  Implemented in check_read_permission().
end note

@enduml
