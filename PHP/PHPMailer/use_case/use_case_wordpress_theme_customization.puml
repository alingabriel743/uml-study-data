@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}

title WordPress Theme Customization\n<size:11><i>Admin previews, adjusts settings, and publishes theme customizations via WP_Customize_Manager</i></size>

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────────
actor "Admin\n(customize)" as Admin
actor "Admin\n(switch_themes)" as ThemeAdmin
actor "Admin\n(install_themes)" as ThemeInstaller
actor "WordPress System\n(hooks / actions)" as WPSystem
actor "Preview iframe\n(frontend)" as PreviewFrame

' ── System Boundary ─────────────────────────────────────────────────────────
rectangle "WordPress Customizer  (WP_Customize_Manager)" {

    package "Customizer Setup" #E3F2FD {
        usecase "Open Customizer" as UC_Open
        usecase "Preview Theme in iframe" as UC_Preview
        usecase "Set Live Preview URL" as UC_SetURL
    }

    package "Settings & UI Structure" #E8F5E9 {
        usecase "Register Setting" as UC_RegSetting
        usecase "Adjust Setting Value" as UC_Adjust
        usecase "Validate Setting Values" as UC_Validate
        usecase "Add Panel" as UC_Panel
        usecase "Add Section" as UC_Section
        usecase "Add Control" as UC_Control
    }

    package "Theme Management" #FFF8E1 {
        usecase "Browse Installed Themes" as UC_BrowseThemes
        usecase "Load WordPress.org Themes" as UC_LoadThemes
        usecase "Switch Theme Preview" as UC_SwitchTheme
        usecase "Import Starter Content" as UC_Starter
    }

    package "Changeset Lifecycle" #FCE4EC {
        usecase "Autosave Changeset" as UC_Autosave
        usecase "Save Changeset as Draft" as UC_Draft
        usecase "Save Changeset as Pending Review" as UC_Pending
        usecase "Publish Changeset" as UC_Publish
        usecase "Schedule Changeset" as UC_Schedule
        usecase "Trash Changeset" as UC_Trash
    }

    package "Collaboration & Security" #F3E5F5 {
        usecase "Override Changeset Lock" as UC_Override
        usecase "Dismiss Autosave or Lock" as UC_Dismiss
        usecase "Manage Lock via Heartbeat" as UC_Heartbeat
        usecase "Refresh Security Nonces" as UC_Nonces
    }
}

' ── Actor → Use Case Associations ───────────────────────────────────────────

' Admin (customize)
Admin --> UC_Open
Admin --> UC_SetURL
Admin --> UC_RegSetting
Admin --> UC_Adjust
Admin --> UC_Panel
Admin --> UC_Section
Admin --> UC_Control
Admin --> UC_BrowseThemes
Admin --> UC_Autosave
Admin --> UC_Draft
Admin --> UC_Pending
Admin --> UC_Publish
Admin --> UC_Schedule
Admin --> UC_Trash
Admin --> UC_Override
Admin --> UC_Dismiss
Admin --> UC_Nonces

' Admin (switch_themes) — extends base Admin for theme switching
ThemeAdmin --> UC_SwitchTheme

' Admin (install_themes) — extends base Admin for remote themes
ThemeInstaller --> UC_LoadThemes

' WordPress System initiates background & hook-driven actions
WPSystem --> UC_Starter
WPSystem --> UC_Heartbeat

' Preview iframe interacts with the live preview use case
PreviewFrame --> UC_Preview

' ── Include / Extend Relationships ──────────────────────────────────────────
UC_Open       ..> UC_Preview    : <<include>>
UC_Adjust     ..> UC_Validate   : <<include>>
UC_Draft      ..> UC_Autosave   : <<extend>>
UC_Publish    ..> UC_RegSetting : <<include>>

' ── Notes ───────────────────────────────────────────────────────────────────
note right of UC_Open
  **Guards:**
  • Requires 'customize' capability
  • CSRF nonce: preview-customize_{stylesheet}
  • UUID validated via wp_is_uuid()
  • setup_theme() → start_previewing_theme()
end note

note right of UC_Publish
  **Changeset CPT: customize_changeset**
  post_name = UUID  |  post_content = JSON
  Status flow:
  auto-draft → draft / pending
             → publish / future / trash
  Publishes via _publish_changeset_values()
  triggered by transition_post_status hook
end note

note right of UC_Starter
  Auto-imported on fresh WordPress installs.
  import_theme_starter_content()
  → _save_starter_content_changeset()
end note

note bottom of UC_Override
  **Changeset Lock:**
  Prevents concurrent edits.
  Heartbeat API refreshes lock every 15 s.
  Locked session forces autosave mode.
end note

@enduml
