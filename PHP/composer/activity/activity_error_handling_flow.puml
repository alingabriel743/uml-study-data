@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activityBackgroundColor #F8F9FA
skinparam activityBorderColor #495057
skinparam activityArrowColor #495057
skinparam activityFontColor #212529
skinparam activityDiamondBackgroundColor #E8F4FD
skinparam activityDiamondBorderColor #495057
skinparam activityDiamondFontColor #212529
skinparam swimlaneBorderColor #6C757D
skinparam swimlaneTitleFontColor #212529
skinparam swimlaneBackgroundColor #E9ECEF

title Error Handler Registration & Dispatch

|Application|
start
:Call ErrorHandler::register(?IOInterface $io);

|ErrorHandler|
:set_error_handler(['ErrorHandler', 'handle']);
:error_reporting(E_ALL);
:Store static $io = $io;
note right
  Registration complete.
  PHP runtime will now invoke
  handle() on every triggered error.
end note

|Application|
:PHP runtime triggers\nerror / notice / warning;

|ErrorHandler|
:handle(\n  int $level, string $message,\n  string $file, int $line);

if (level is E_DEPRECATED\nor E_USER_DEPRECATED?) then (yes — deprecation)

  if (static $io is null?) then (yes)
    :return true;
    note right: No IO registered —\nsilently ignore deprecation.
    stop
  else (no — IO available)

    if ($hasShownDeprecationNotice > 0\nAND NOT $io->isVerbose()?) then (yes — already shown, non-verbose)

      if ($hasShownDeprecationNotice === 1?) then (yes — first suppression)
        |IO Layer|
        :$io->writeError(\n"<warning>More deprecation notices\nwere hidden...</warning>");
        |ErrorHandler|
        :$hasShownDeprecationNotice = 2;
      else (no — already at 2, stay silent)
      endif
      :return true;
      stop

    else (no — first notice or verbose mode)
      :$hasShownDeprecationNotice = 1;
      :outputWarning(\n"Deprecation Notice: $message\nin $file:$line");
      |IO Layer|
      :$io->writeError(\n"<warning>Deprecation Notice:\n$message in $file:$line</warning>");
      |ErrorHandler|
      if ($io->isVerbose()?) then (yes)
        |IO Layer|
        :$io->writeError("<warning>Stack trace:</warning>");
        :$io->writeError filtered\nbacktrace frames [file:line pairs];
        |ErrorHandler|
      else (no)
      endif
      :return true;
      stop

    endif

  endif

else (no — non-deprecation error)

  if ((error_reporting() & $level) === 0?\n@ operator in effect) then (yes)
    :return true;
    note right: Error suppressed by\n@ operator — silent exit.
    stop
  else (no — not suppressed)

    if (xdebug.scream ini = true?) then (yes)
      :Append "xdebug.scream" advisory\nnote to $message;
    else (no)
    endif

    if (level is E_WARNING / E_USER_WARNING\nAND message matches\n"should either be used or\nintentionally ignored..." pattern?) then (yes)

      :outputWarning(\n"Ignored new PHP warning...",\noutputEvenWithoutIO=true);

      if (static $io !== null?) then (yes)
        |IO Layer|
        :$io->writeError(\n"<warning>Ignored new\nPHP warning...</warning>");
        |ErrorHandler|
        if ($io->isVerbose()?) then (yes)
          |IO Layer|
          :$io->writeError("<warning>Stack trace:</warning>");
          :$io->writeError filtered\nbacktrace frames [file:line pairs];
          |ErrorHandler|
        else (no)
        endif
      else (no IO — outputEvenWithoutIO=true)
        if (STDERR constant defined\nand is a resource?) then (yes)
          |IO Layer|
          :fwrite(STDERR,\n"Warning: $message" . PHP_EOL);
          |ErrorHandler|
        else (no)
          |IO Layer|
          :echo "Warning: $message" . PHP_EOL;
          |ErrorHandler|
        endif
      endif
      :return true;
      stop

    else (no — unhandled non-suppressed error)
      :throw new \\ErrorException(\n$message, 0, $level, $file, $line);
      stop
    endif

  endif

endif

@enduml
