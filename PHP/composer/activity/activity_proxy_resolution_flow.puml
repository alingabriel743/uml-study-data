@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
}

skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #DEE2E6
    TitleFontColor #212529
    TitleFontSize 13
}

skinparam ArrowColor #495057
skinparam NoteBackgroundColor #FFF3CD
skinparam NoteBorderColor #FFC107

title HTTP Proxy Resolution Flow

|Caller|
start
:Call ProxyManager::getInstance();

|Singleton Initialisation|
if (self::$instance === null?) then (yes — first call)
  :new ProxyManager()\n<i>private constructor</i>;

  |Proxy Environment Reading|
  :Begin getProxyData();
  note right
    Reads env vars once at
    construction; result is
    cached in instance fields.
  end note

  if (PHP_SAPI === 'cli'\nor 'phpdbg'?) then (yes — CLI mode)
    :Search $_SERVER for\nhttp_proxy / HTTP_PROXY;
    if (Non-empty value found?) then (yes)
      :$httpProxy = new ProxyItem(value, varName);
    else (no)
    endif
  else (no — CGI / web mode)
    note right
      Security guard: HTTP_PROXY header
      is NOT read in CGI mode to prevent
      header injection attacks.
    end note
  endif

  if ($httpProxy still null?) then (yes)
    :Search $_SERVER for\ncgi_http_proxy / CGI_HTTP_PROXY;
    if (Non-empty value found?) then (yes)
      :$httpProxy = new ProxyItem(value, varName);
    else (no)
    endif
  else (no — already set)
  endif

  :Search $_SERVER for\nhttps_proxy / HTTPS_PROXY;
  if (Non-empty value found?) then (yes)
    :$httpsProxy = new ProxyItem(value, varName);
  else (no)
  endif

  :Search $_SERVER for\nno_proxy / NO_PROXY;
  if (Non-empty value found?) then (yes)
    :$noProxyHandler = new NoProxyPattern(value);
  else (no)
  endif

  if (RuntimeException thrown?) then (yes)
    :Store error message\nin $this->error;
    note right: Deferred — thrown lazily\non getProxyForRequest()
  else (no)
  endif

  |Singleton Initialisation|
  :self::$instance = constructed instance;

else (no — already initialised)
  :Return existing self::$instance;
endif

:Return ProxyManager singleton;

|Caller|
:Call getProxyForRequest(requestUrl);

|Request Resolution|
if ($this->error !== null?) then (yes — bad proxy config)
  #FFCCCC:Throw TransportException\n<i>(proxy URL was invalid)</i>;
  kill
else (no — healthy instance)
endif

:parse_url(requestUrl)\n→ extract URL scheme;

:getProxyForScheme(scheme);

if (scheme === 'https'?) then (yes)
  :$proxy = $httpsProxy;
elseif (scheme === 'http'?) then (yes)
  :$proxy = $httpProxy;
else (other scheme)
  :$proxy = null;
endif

if ($proxy === null?) then (yes — no proxy for scheme)
  :outcome = RequestProxy::none();
else (no — proxy found)
  :noProxy(requestUrl);
  if ($noProxyHandler === null?) then (yes)
    :noProxyResult = false;
  else (not null)
    :noProxyResult =\nNoProxyPattern::test(requestUrl);
  endif

  if (noProxyResult === true?) then (yes — URL excluded)
    :outcome = RequestProxy::noProxy();
  else (no — proxy applies)
    :outcome = $proxy->toRequestProxy(scheme);
  endif
endif

|Caller|
:Receive RequestProxy outcome;
note right
  Possible outcomes:
  • **none()** — no proxy for scheme
  • **noProxy()** — URL on no-proxy list
  • **toRequestProxy()** — active proxy
end note
:Use RequestProxy for outbound HTTP request;
stop

@enduml
