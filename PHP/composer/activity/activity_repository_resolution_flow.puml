@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #E7F3FF
skinparam NoteBorderColor #5B9BD5

title Repository Resolution Flow

|Caller|
start
:Instantiate RepositoryManager\n(IOInterface, Config, HttpDownloader,\n?EventDispatcher, ?ProcessExecutor);

|RepositoryManager|
:Store io, config, httpDownloader, eventDispatcher;\nCreate ProcessExecutor if null;

|Caller|
:Register repo types via\nsetRepositoryClass(type, class);

|RepositoryManager|
:Store repositoryClasses[type] = class;

|Caller|
fork
    :Call createRepository\n(type, config, ?name);

    |RepositoryManager|
    if (type registered in repositoryClasses?) then (NO)
        #FFB3B3:throw InvalidArgumentException\n'Repository type not registered: {type}';
        stop
    else (YES)
    endif

    if (config has 'packagist' key = false?) then (YES)
        :io->writeError(\n  <warning> misplaced packagist key\n);
    else (NO)
    endif

    :Resolve class = repositoryClasses[type];

    if (config has 'only' OR 'exclude'\nOR 'canonical' keys?) then (YES)
        :Save filterConfig;\nStrip those keys from config;
    else (NO)
    endif

    :Instantiate $repository = new $class(\n  config, io, config, httpDownloader,\n  eventDispatcher, processExecutor\n);

    if (filterConfig was set?) then (YES)
        |FilterRepository|
        :Validate filterConfig:\n- 'only' and 'exclude' are arrays\n- 'only' and 'exclude' are mutually exclusive\n- 'canonical' is bool;
        :Wrap: FilterRepository($repository, filterConfig);

        |RepositoryManager|
    else (NO)
        :Use raw repository instance;
    endif

    :Return RepositoryInterface;

    |Caller|
    if (Inject at head (plugin override)?) then (YES)
        :prependRepository(repo)\n→ array_unshift to $repositories\n  (highest priority, overrides Packagist);

        |RepositoryManager|
        :Insert repo at index 0 of\n$repositories list;
    else (NO)
        :addRepository(repo)\n→ append to $repositories list\n  (tail / lower priority);

        |RepositoryManager|
        :Append repo to\n$repositories list;
    endif

fork again
    |Caller|
    :setLocalRepository(\n  InstalledRepositoryInterface\n);

    |RepositoryManager|
    :Store as $localRepository\n(separate from $repositories list);
    note right
      localRepository is NOT
      searched via findPackage /
      findPackages; accessed
      via getLocalRepository()
    end note
end fork

|Caller|
fork
    :findPackage(name, constraint)\n→ get first match;

    |RepositoryManager|
    :Initialize: no result yet;
    :Call getRepositories()\n→ ordered list;

    repeat
        :Call repository->findPackage(name, constraint);
        if (Package found?) then (YES)
            #D4EDDA:Return PackageInterface\n(first match wins — stop scanning);
            |Caller|
            :Receive PackageInterface;
            stop
        else (NO)
            :Advance to next repository;
        endif
    repeat while (More repositories?) is (YES)
    -> NO;

    #FFE0B2:Return null\n(no match across all repositories);
    |Caller|
    :Receive null;

fork again
    :findPackages(name, constraint)\n→ get ALL matches;

    |RepositoryManager|
    :Initialize $packages = [];
    :Call getRepositories()\n→ ordered list;

    repeat
        :Call repository->findPackages(name, constraint);
        :Merge results:\n$packages = array_merge($packages, results);
        :Advance to next repository;
    repeat while (More repositories?) is (YES)
    -> NO;

    #D4EDDA:Return PackageInterface[]\n(all matches across all repositories);
    |Caller|
    :Receive aggregated\nPackageInterface[];
end fork

stop

@enduml
