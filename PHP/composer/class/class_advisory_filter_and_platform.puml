@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
    FontColor #212529
}

title Security Advisory, Platform & Filters

' ─────────────────────────────────────────────
' External / referenced interfaces
' ─────────────────────────────────────────────
interface JsonSerializable <<PHP>> {
    +jsonSerialize(): mixed
}

' ─────────────────────────────────────────────
' Composer\Advisory
' ─────────────────────────────────────────────
package "Composer\\Advisory" {

    class PartialSecurityAdvisory {
        +readonly advisoryId: string
        +readonly packageName: string
        +readonly affectedVersions: ConstraintInterface
        --
        +{static} create(packageName: string, data: array, parser: VersionParser): self
        +__construct(packageName: string, advisoryId: string, affectedVersions: ConstraintInterface)
        +jsonSerialize(): mixed
    }

    class SecurityAdvisory {
        +readonly title: string
        +readonly cve: string|null
        +readonly link: string|null
        +readonly reportedAt: DateTimeImmutable
        +readonly sources: non-empty-array
        +readonly severity: string|null
        --
        +__construct(packageName: string, advisoryId: string, affectedVersions: ConstraintInterface, title: string, sources: array, reportedAt: DateTimeImmutable, cve: ?string, link: ?string, severity: ?string)
        +toIgnoredAdvisory(ignoreReason: ?string): IgnoredSecurityAdvisory
        +jsonSerialize(): mixed
    }

    class IgnoredSecurityAdvisory {
        +readonly ignoreReason: string|null
        --
        +__construct(..., ignoreReason: ?string, severity: ?string)
        +jsonSerialize(): mixed
    }

    class Auditor <<internal>> {
        +{static} FORMAT_TABLE: string = "table"
        +{static} FORMAT_PLAIN: string = "plain"
        +{static} FORMAT_JSON: string = "json"
        +{static} FORMAT_SUMMARY: string = "summary"
        +{static} ABANDONED_IGNORE: string = "ignore"
        +{static} ABANDONED_FAIL: string = "fail"
        +{static} STATUS_OK: int = 0
        +{static} STATUS_VULNERABLE: int = 1
        +{static} STATUS_ABANDONED: int = 2
        +{static} STATUS_FILTERED: int = 4
        --
        +audit(io: IOInterface, repoSet: RepositorySet, packages: array, format: string, warningOnly: bool, ignoreList: array, abandoned: string, ignoredSeverities: array, ignoreUnreachable: bool, ignoreAbandoned: array, filtered: string, filterListProviderSet: ?FilterListProviderSet, filterListConfig: ?FilterListConfig): int
        +needsCompleteAdvisoryLoad(advisories: array, ignoreList: array): bool
        +filterAbandonedPackages(packages: array, ignoreAbandoned: array): array
        +processAdvisories(allAdvisories: array, ignoreList: array, ignoredSeverities: array): array
        -countAdvisories(advisories: array): array
        -outputAdvisories(io: IOInterface, advisories: array, format: string): void
        -calculateBitmask(hasVulnerable: bool, hasAbandoned: bool, hasFiltered: bool): int
        -getSeverity(advisory: SecurityAdvisory): string
    }

}

' ─────────────────────────────────────────────
' Composer\Filter\PlatformRequirementFilter
' ─────────────────────────────────────────────
package "Composer\\Filter\\PlatformRequirementFilter" {

    interface PlatformRequirementFilterInterface {
        +isIgnored(req: string): bool
        +isUpperBoundIgnored(req: string): bool
    }

    class PlatformRequirementFilterFactory <<final>> {
        +{static} fromBoolOrList(boolOrList: mixed): PlatformRequirementFilterInterface
        +{static} ignoreAll(): PlatformRequirementFilterInterface
        +{static} ignoreNothing(): PlatformRequirementFilterInterface
    }

    class IgnoreAllPlatformRequirementFilter <<final>> {
        +isIgnored(req: string): bool
        +isUpperBoundIgnored(req: string): bool
    }

    class IgnoreNothingPlatformRequirementFilter <<final>> {
        +isIgnored(req: string): bool
        +isUpperBoundIgnored(req: string): bool
    }

    class IgnoreListPlatformRequirementFilter <<final>> {
        -ignoreRegex: non-empty-string
        -ignoreUpperBoundRegex: non-empty-string
        --
        +__construct(reqList: array)
        +isIgnored(req: string): bool
        +isUpperBoundIgnored(req: string): bool
        +filterConstraint(req: string, constraint: ConstraintInterface, allowUpperBoundOverride: bool): ConstraintInterface
    }

}

' ─────────────────────────────────────────────
' Composer\FilterList
' ─────────────────────────────────────────────
package "Composer\\FilterList" {

    class FilterListAuditor <<internal, final, readonly>> {
        +collectFilterLists(packages: array, providerSet: FilterListProviderSet, operation: string, ignoreUnreachable: bool): array
        +getMatchingEntries(package: PackageInterface, filterListMap: array, filterListConfig: FilterListConfig, operation: string): list<FilterListEntry>
    }

    class FilterListConfig <<readonly, internal, final>> {
        +unfilteredPackages: list<UnfilteredPackage>
        +sources: list<UrlSource>
        +ignoreUnreachable: bool
        --
        +__construct(unfilteredPackages: array, sources: array, ignoreUnreachable: bool)
        +{static} fromConfig(config: Config, versionParser: VersionParser): ?self
        +getOperationConfig(operation: string): self
    }

    class FilterListEntry <<readonly>> {
        +packageName: string
        +listName: string
        +constraint: ConstraintInterface
        +url: string|null
        +reason: string|null
        +id: string|null
        --
        +__construct(packageName: string, constraint: ConstraintInterface, listName: string, url: ?string, reason: ?string, id: ?string)
        +{static} create(listName: string, data: array, parser: VersionParser): self
    }

    class UnfilteredPackage <<readonly, internal, final>> {
        +packageName: string
        +constraint: ConstraintInterface
        +reason: string|null
        +apply: "all"|"block"|"audit"
        +packageNameRegex: non-empty-string
        --
        -{static} __construct(packageName: string, constraint: ConstraintInterface, reason: ?string, apply: string)
        +{static} fromConfig(config: array|string|UnfilteredPackage, parser: VersionParser): self
    }

}

' ─────────────────────────────────────────────
' Composer\Platform
' ─────────────────────────────────────────────
package "Composer\\Platform" {

    class Runtime {
        +hasConstant(constant: string, class: ?string): bool
        +getConstant(constant: string, class: ?string): mixed
        +hasFunction(fn: string): bool
        +invoke(callable: callable, arguments: array): mixed
        +hasClass(class: string): bool
        +construct(class: string, arguments: array): object
        +getExtensions(): string[]
        +getExtensionVersion(extension: string): string
        +getExtensionInfo(extension: string): string
        +{static} parseHtmlExtensionInfo(html: string): string
    }

    class HhvmDetector {
        -{static} hhvmVersion: string|false|null
        -executableFinder: ?ExecutableFinder
        -processExecutor: ?ProcessExecutor
        --
        +__construct(executableFinder: ?ExecutableFinder, processExecutor: ?ProcessExecutor)
        +reset(): void
        +getVersion(): ?string
    }

}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' Advisory hierarchy
PartialSecurityAdvisory ..|> JsonSerializable
SecurityAdvisory --|> PartialSecurityAdvisory
IgnoredSecurityAdvisory --|> SecurityAdvisory

' Advisory creation
SecurityAdvisory ..> IgnoredSecurityAdvisory : creates via\ntoIgnoredAdvisory()

' Auditor dependencies
Auditor ..> SecurityAdvisory : processes
Auditor ..> IgnoredSecurityAdvisory : outputs
Auditor ..> FilterListAuditor : instantiates
Auditor ..> FilterListConfig : uses
Auditor ..> FilterListEntry : renders

' Platform filter strategy pattern
IgnoreAllPlatformRequirementFilter ..|> PlatformRequirementFilterInterface
IgnoreNothingPlatformRequirementFilter ..|> PlatformRequirementFilterInterface
IgnoreListPlatformRequirementFilter ..|> PlatformRequirementFilterInterface

PlatformRequirementFilterFactory ..> PlatformRequirementFilterInterface : creates

' FilterList composition & dependencies
FilterListConfig *-- UnfilteredPackage : composes

FilterListAuditor ..> FilterListConfig : uses
FilterListAuditor ..> FilterListEntry : returns

@enduml
