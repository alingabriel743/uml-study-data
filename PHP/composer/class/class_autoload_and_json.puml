@startuml class_autoload_and_json

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Autoload Generator & JSON Utilities

package "Composer\\Autoload" {

    class AutoloadGenerator {
        -eventDispatcher: EventDispatcher
        -io: IOInterface
        -devMode: ?bool
        -classMapAuthoritative: bool
        -apcu: bool
        -apcuPrefix: ?string
        -dryRun: bool
        -runScripts: bool
        -platformRequirementFilter: PlatformRequirementFilterInterface
        --
        +__construct(eventDispatcher: EventDispatcher, io: ?IOInterface)
        +setDevMode(devMode: bool): void
        +setClassMapAuthoritative(classMapAuthoritative: bool): void
        +setApcu(apcu: bool, apcuPrefix: ?string): void
        +setRunScripts(runScripts: bool): void
        +setDryRun(dryRun: bool): void
        +setPlatformRequirementFilter(filter): void
        +dump(config, localRepo, rootPackage, ...): ClassMap
        +buildPackageMap(installationManager, rootPackage, packages): array
        +parseAutoloads(packageMap, rootPackage, filteredDevPackages): array
        +createLoader(autoloads: array, vendorDir: ?string): ClassLoader
    }

    class ClassLoader {
        -{static} $includeFile: Closure
        -vendorDir: ?string
        -prefixLengthsPsr4: array<string, array<string,int>>
        -prefixDirsPsr4: array<string, list<string>>
        -fallbackDirsPsr4: list<string>
        -prefixesPsr0: array<string, array<string, list<string>>>
        -fallbackDirsPsr0: list<string>
        -useIncludePath: bool
        -classMap: array<string, string>
        -classMapAuthoritative: bool
        -missingClasses: array<string, bool>
        -apcuPrefix: ?string
        -{static} $registeredLoaders: array<string, self>
        --
        +__construct(vendorDir: ?string)
        +getPrefixes(): array
        +getPrefixesPsr4(): array
        +getFallbackDirs(): list<string>
        +getFallbackDirsPsr4(): list<string>
        +getClassMap(): array<string, string>
        +addClassMap(classMap: array): void
        +add(prefix: string, paths, prepend: bool): void
        +addPsr4(prefix: string, paths, prepend: bool): void
        +set(prefix: string, paths): void
        +setPsr4(prefix: string, paths): void
        +setUseIncludePath(useIncludePath: bool): void
        +getUseIncludePath(): bool
        +setClassMapAuthoritative(classMapAuthoritative: bool): void
        +isClassMapAuthoritative(): bool
        +setApcuPrefix(apcuPrefix: ?string): void
        +getApcuPrefix(): ?string
        +register(prepend: bool): void
        +unregister(): void
        +loadClass(class: string): true|null
        +findFile(class: string): string|false
        +{static} getRegisteredLoaders(): array<string, self>
        -findFileWithExtension(class: string, ext: string): string|false
        -{static} initializeIncludeClosure(): void
    }

    class ClassMapGenerator << (D,#FFD700) deprecated >> {
        .. deprecated since Composer 2.4.0 ..
        .. delegates to composer/class-map-generator ..
        --
        +{static} dump(dirs: iterable, file: string): void
        +{static} createMap(path, excluded: ?string, io: ?IOInterface, namespace: ?string, autoloadType: ?string, &scannedFiles: array): array
    }

}

package "Composer\\Json" {

    class JsonFile {
        +{static} LAX_SCHEMA: int = 1
        +{static} STRICT_SCHEMA: int = 2
        +{static} AUTH_SCHEMA: int = 3
        +{static} LOCK_SCHEMA: int = 4
        +{static} COMPOSER_SCHEMA_PATH: string
        +{static} LOCK_SCHEMA_PATH: string
        +{static} INDENT_DEFAULT: string = '    '
        --
        -path: string
        -httpDownloader: ?HttpDownloader
        -io: ?IOInterface
        -indent: string
        --
        +__construct(path: string, httpDownloader: ?HttpDownloader, io: ?IOInterface)
        +getPath(): string
        +exists(): bool
        +read(): mixed
        +write(hash: array, options: int): void
        +validateSchema(schema: int, schemaFile: ?string): bool
        +{static} validateJsonSchema(source, data, schema, schemaFile): bool
        +{static} encode(data: mixed, options: int, indent: string): string
        +{static} parseJson(json: ?string, file: ?string): mixed
        +{static} detectIndenting(json: ?string): string
        #validateSyntax(json: string, file: ?string): bool
        -filePutContentsIfModified(path: string, content: string): int|false
        -{static} throwEncodeError(code: int): never
    }

    class JsonManipulator {
        -contents: string
        -newline: string
        -indent: string
        -DEFINES: string <<const>>
        --
        +__construct(contents: string)
        +getContents(): string
        +addLink(type, package, constraint, sortPackages: bool): bool
        +addRepository(name: string, config: array|false, append: bool): bool
        +setRepositoryUrl(name: string, url: string): bool
        +removeRepository(name: string): bool
        +addConfigSetting(name: string, value: mixed): bool
        +removeConfigSetting(name: string): bool
        +addProperty(name: string, value: mixed): bool
        +removeProperty(name: string): bool
        +addSubNode(mainNode, name, value, append: bool): bool
        +removeSubNode(mainNode: string, name: string): bool
        +addListItem(mainNode, value, append: bool): bool
        +insertListItem(mainNode, value, index: int): bool
        +removeListItem(mainNode, nodeIndex: int): bool
        +addMainKey(key: string, content: mixed): bool
        +removeMainKey(key: string): bool
        +removeMainKeyIfEmpty(key: string): bool
        +format(data: mixed, depth: int, wasObject: bool): string
        #detectIndenting(): void
    }

    class JsonFormatter << (D,#FFD700) deprecated >> {
        .. deprecated — use JsonFile::encode() in 3.0 ..
        --
        +{static} format(json: string, unescapeUnicode: bool, unescapeSlashes: bool): string
    }

    class JsonValidationException {
        #errors: string[]
        --
        +__construct(message: string, errors: string[], previous: ?Exception)
        +getErrors(): string[]
    }

}

' External / out-of-scope references
class Exception <<external>>
class EventDispatcher <<external>>
interface IOInterface <<external>>
class HttpDownloader <<external>>

' ─── Inheritance ───────────────────────────────────────────────
JsonValidationException --|> Exception

' ─── Composition (AutoloadGenerator fields) ────────────────────
AutoloadGenerator *--> EventDispatcher : -eventDispatcher
AutoloadGenerator *--> IOInterface     : -io

' ─── Creation ──────────────────────────────────────────────────
AutoloadGenerator ..> ClassLoader      : <<creates>>\ncreateLoader()

' ─── Dependencies (Autoload) ───────────────────────────────────
AutoloadGenerator ..> ClassMapGenerator : <<uses>>\nbuildPackageMap()
AutoloadGenerator ..> JsonFile          : <<uses>>\nreads installed.json

' ─── Dependencies (JSON) ───────────────────────────────────────
JsonManipulator ..> JsonFile            : <<uses>>\nparseJson() / encode()\ndetectIndenting()
JsonFile        ..> JsonValidationException : <<throws>>
JsonFile        *--> HttpDownloader     : -httpDownloader

@enduml
