@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam stereotypeCBackgroundColor #ADD8E6
skinparam stereotypeIBackgroundColor #C8E6C9

title CLI Command System

' ─────────────────────────────────────────────
' External: Symfony Console
' ─────────────────────────────────────────────
package "Symfony\\Component\\Console\\Command" #DDEEFF {
    abstract class Command {
        +configure(): void
        +execute(InputInterface, OutputInterface): int
        +run(InputInterface, OutputInterface): int
        +complete(CompletionInput, CompletionSuggestions): void
    }
}

' ─────────────────────────────────────────────
' Core external dependencies (simplified)
' ─────────────────────────────────────────────
package "Composer Core" #EAF4EA {
    class Composer << (D,#C8E6C9) domain >> {
        +getConfig(): Config
        +getRepositoryManager(): RepositoryManager
    }
    interface IOInterface << interface >> {
        +write(string): void
        +isInteractive(): bool
    }
    class Installer << (S,#FFE082) service >> {
        +{static} create(IOInterface, Composer): Installer
        +run(): int
        +setUpdate(bool): Installer
        +setDevMode(bool): Installer
    }
    class JsonFile {
        +read(): array
        +write(array): void
    }
    class Config {
        +get(string): mixed
        +set(string, mixed): void
    }
    class JsonConfigSource {
        +addLink(string, string, string): void
        +removeLink(string, string): void
    }
}

' ─────────────────────────────────────────────
' Composer Command Namespace
' ─────────────────────────────────────────────
package "Composer\\Command" {

    ' ── Traits ──────────────────────────────
    class CompletionTrait << (T,orchid) trait >> {
        +suggestPreferInstall(): array
        +suggestAvailablePackage(): Closure
        +suggestAvailablePackageInclPlatform(): Closure
        +suggestInstalledPackage(bool): Closure
        +suggestRootRequirement(): Closure
    }

    class PackageDiscoveryTrait << (T,orchid) trait >> {
        #repos: CompositeRepository
        #determineRequirements(InputInterface, OutputInterface, array, ...): array
        #getRepos(): CompositeRepository
    }

    ' ── Abstract Base Classes ────────────────
    abstract class BaseCommand {
        -composer: ?Composer
        -io: IOInterface
        +requireComposer(?bool $disablePlugins, ?bool $disableScripts): Composer
        +tryComposer(?bool $disablePlugins, ?bool $disableScripts): ?Composer
        +setComposer(Composer $composer): void
        +resetComposer(): void
        +getIO(): IOInterface
        +setIO(IOInterface $io): void
        +isProxyCommand(): bool
        +complete(CompletionInput, CompletionSuggestions): void
        #initialize(InputInterface, OutputInterface): void
        #createComposerInstance(InputInterface, IOInterface, ...): Composer
        #getPreferredInstallOptions(Config, InputInterface, bool): array
        #getPlatformRequirementFilter(InputInterface): PlatformRequirementFilterInterface
        #formatRequirements(array): array
        #normalizeRequirements(array): array
        #renderTable(array, OutputInterface): void
        #getTerminalWidth(): int
        #getAuditFormat(InputInterface, string): string
        #createAuditConfig(Config, InputInterface): AuditConfig
    }

    abstract class BaseConfigCommand {
        #config: Config
        #configFile: JsonFile
        #configSource: JsonConfigSource
        #initialize(InputInterface, OutputInterface): void
    }

    ' ── Concrete Commands ────────────────────
    class InstallCommand {
        {field} command: "install" | alias: "i"
        #configure(): void
        #execute(InputInterface, OutputInterface): int
    }

    class UpdateCommand {
        {field} command: "update" | alias: "u", "upgrade"
        #configure(): void
        #execute(InputInterface, OutputInterface): int
        -getPackagesInteractively(IOInterface, InputInterface, ...): array
        -createVersionSelector(Composer): VersionSelector
    }

    class RequireCommand {
        {field} command: "require" | alias: "r"
        -newlyCreated: bool
        -firstRequire: bool
        -json: JsonFile
        -file: string
        -composerBackup: string
        -lock: string
        -lockBackup: ?string
        -dependencyResolutionCompleted: bool
        #configure(): void
        #execute(InputInterface, OutputInterface): int
        #interact(InputInterface, OutputInterface): void
        -doUpdate(InputInterface, OutputInterface, IOInterface, array, string, string): int
        -updateRequirementsAfterResolution(array, string, string, bool, bool, bool): int
        -updateFile(JsonFile, array, string, string, bool): void
        -revertComposerFile(): void
    }

    class RemoveCommand {
        {field} command: "remove" | alias: "rm", "uninstall"
        #configure(): void
        #execute(InputInterface, OutputInterface): int
    }

    class ShowCommand {
        {field} command: "show" | alias: "info"
        #configure(): void
        #execute(InputInterface, OutputInterface): int
        #complete(CompletionInput, CompletionSuggestions): void
    }

    class ConfigCommand {
        {field} command: "config"
        #{static} CONFIGURABLE_PACKAGE_PROPERTIES: string[]
        #authConfigFile: JsonFile
        #configure(): void
        #execute(InputInterface, OutputInterface): int
        #interact(InputInterface, OutputInterface): void
        #complete(CompletionInput, CompletionSuggestions): void
    }

    class InitCommand {
        {field} command: "init"
        -gitConfig: array
        #configure(): void
        #execute(InputInterface, OutputInterface): int
        #initialize(InputInterface, OutputInterface): void
        #interact(InputInterface, OutputInterface): void
        +namespaceFromPackageName(string): ?string
        #formatAuthors(string): array
        #getGitConfig(): array
        -parseAuthorString(string): array
        -updateDependencies(OutputInterface): void
        -runDumpAutoloadCommand(OutputInterface): void
    }

    class CreateProjectCommand {
        {field} command: "create-project"
        #suggestedPackagesReporter: SuggestedPackagesReporter
        #configure(): void
        #execute(InputInterface, OutputInterface): int
    }

    class SelfUpdateCommand {
        {field} command: "self-update" | alias: "selfupdate"
        +{static} HOMEPAGE: string
        +{static} OLD_INSTALL_EXT: string
        #configure(): void
        #execute(InputInterface, OutputInterface): int
    }

}

' ─────────────────────────────────────────────
' Inheritance Hierarchy
' ─────────────────────────────────────────────
Command          <|-- BaseCommand
BaseCommand      <|-- BaseConfigCommand
BaseConfigCommand <|-- ConfigCommand

BaseCommand <|-- InstallCommand
BaseCommand <|-- UpdateCommand
BaseCommand <|-- RequireCommand
BaseCommand <|-- RemoveCommand
BaseCommand <|-- ShowCommand
BaseCommand <|-- InitCommand
BaseCommand <|-- CreateProjectCommand
BaseCommand <|-- SelfUpdateCommand

' ─────────────────────────────────────────────
' Trait Usage
' ─────────────────────────────────────────────
CompletionTrait    <.. InstallCommand       : <<uses>>
CompletionTrait    <.. UpdateCommand        : <<uses>>
CompletionTrait    <.. RequireCommand       : <<uses>>
CompletionTrait    <.. RemoveCommand        : <<uses>>
CompletionTrait    <.. ShowCommand          : <<uses>>
CompletionTrait    <.. InitCommand          : <<uses>>
CompletionTrait    <.. CreateProjectCommand : <<uses>>

PackageDiscoveryTrait <.. RequireCommand : <<uses>>
PackageDiscoveryTrait <.. InitCommand   : <<uses>>

' ─────────────────────────────────────────────
' Key Dependencies
' ─────────────────────────────────────────────
BaseCommand ..> Composer      : depends on
BaseCommand ..> IOInterface   : uses

BaseConfigCommand *-- Config         : owns
BaseConfigCommand *-- JsonFile       : owns
BaseConfigCommand *-- JsonConfigSource : owns

InstallCommand      ..> Installer : Installer::create()
UpdateCommand       ..> Installer : Installer::create()
RequireCommand      ..> Installer : Installer::create()
RequireCommand      *-- JsonFile  : owns
RemoveCommand       ..> Installer : Installer::create()
RemoveCommand       ..> JsonConfigSource : removeLink()

@enduml
