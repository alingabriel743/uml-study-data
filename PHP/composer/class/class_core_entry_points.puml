@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Core Entry Points & Bootstrap

package "Composer" {

    class PartialComposer {
        -global: bool
        -package: RootPackageInterface
        -loop: Loop
        -repositoryManager: RepositoryManager
        -installationManager: InstallationManager
        -config: Config
        -eventDispatcher: EventDispatcher
        ==
        +setPackage(package: RootPackageInterface): void
        +getPackage(): RootPackageInterface
        +setConfig(config: Config): void
        +getConfig(): Config
        +setLoop(loop: Loop): void
        +getLoop(): Loop
        +setRepositoryManager(manager: RepositoryManager): void
        +getRepositoryManager(): RepositoryManager
        +setInstallationManager(manager: InstallationManager): void
        +getInstallationManager(): InstallationManager
        +setEventDispatcher(dispatcher: EventDispatcher): void
        +getEventDispatcher(): EventDispatcher
        +isGlobal(): bool
        +setGlobal(): void
    }

    class Composer {
        +{static} VERSION: string
        +{static} BRANCH_ALIAS_VERSION: string
        +{static} RELEASE_DATE: string
        +{static} SOURCE_VERSION: string
        +{static} RUNTIME_API_VERSION: string
        ==
        -locker: Locker
        -downloadManager: DownloadManager
        -pluginManager: PluginManager
        -autoloadGenerator: AutoloadGenerator
        -archiveManager: ArchiveManager
        ==
        +{static} getVersion(): string
        +setLocker(locker: Locker): void
        +getLocker(): Locker
        +setDownloadManager(manager: DownloadManager): void
        +getDownloadManager(): DownloadManager
        +setArchiveManager(manager: ArchiveManager): void
        +getArchiveManager(): ArchiveManager
        +setPluginManager(manager: PluginManager): void
        +getPluginManager(): PluginManager
        +setAutoloadGenerator(generator: AutoloadGenerator): void
        +getAutoloadGenerator(): AutoloadGenerator
    }

    class Factory {
        +{static} create(io: IOInterface, config, disablePlugins, disableScripts): Composer
        +{static} createGlobal(io: IOInterface, disablePlugins, disableScripts): Composer
        +{static} createConfig(io: IOInterface, cwd: string): Config
        +{static} getComposerFile(): string
        +{static} getLockFile(composerFile: string): string
        +{static} createHttpDownloader(io: IOInterface, config: Config, options): HttpDownloader
        +{static} createOutput(): ConsoleOutput
        +createComposer(io: IOInterface, localConfig, disablePlugins, cwd, fullLoad, disableScripts): Composer|PartialComposer
        +createDownloadManager(io, config, httpDownloader, process, eventDispatcher): DownloadManager
        +createArchiveManager(config: Config, dm: DownloadManager, loop: Loop): ArchiveManager
        +createInstallationManager(loop: Loop, io: IOInterface, eventDispatcher): InstallationManager
        #createGlobalComposer(io, config, disablePlugins, disableScripts, fullLoad): PartialComposer
        #createPluginManager(io, composer, globalComposer, disablePlugins): PluginManager
        #createDefaultInstallers(im, composer, io, process): void
        #loadRootPackage(rm, config, parser, guesser, io): RootPackageLoader
        #{static} getHomeDir(): string
        #{static} getCacheDir(home: string): string
        #{static} getDataDir(home: string): string
    }

    class Installer {
        #io: IOInterface
        #config: Config
        #package: RootPackageInterface
        #fixedRootPackage: RootPackageInterface
        #downloadManager: DownloadManager
        #repositoryManager: RepositoryManager
        #locker: Locker
        #installationManager: InstallationManager
        #eventDispatcher: EventDispatcher
        #autoloadGenerator: AutoloadGenerator
        #updateAllowList: array
        #lockTransaction: LockTransaction
        -auditConfig: AuditConfig
        -filterListConfig: FilterListConfig
        ==
        +__construct(io, config, package, downloadManager, repositoryManager, locker, installationManager, eventDispatcher, autoloadGenerator)
        +{static} create(io: IOInterface, composer: Composer): self
        +run(): int
        +isDryRun(): bool
        +isVerbose(): bool
        +getLockTransaction(): LockTransaction
        +setDryRun(dryRun: bool): self
        +setUpdate(update: bool): self
        +setInstall(install: bool): self
        +setDevMode(devMode: bool): self
        +setPreferSource(preferSource: bool): self
        +setPreferDist(preferDist: bool): self
        +setRunScripts(runScripts: bool): self
        +setDumpAutoloader(dumpAutoloader: bool): self
        +setAudit(audit: bool): self
        +setAuditConfig(config: AuditConfig): self
        +setPlatformRequirementFilter(filter: PlatformRequirementFilterInterface): self
        +disablePlugins(): self
        #doUpdate(localRepo: InstalledRepositoryInterface, doInstall: bool): int
        #doInstall(localRepo: InstalledRepositoryInterface, alreadySolved: bool): int
        #createPlatformRepo(forUpdate: bool): PlatformRepository
    }

    class InstalledVersions <<final>> {
        -{static} selfDir: string
        -{static} installed: array
        -{static} installedIsLocalDir: bool
        -{static} canGetVendors: bool
        -{static} installedByVendor: array
        ==
        +{static} getInstalledPackages(): string[]
        +{static} getInstalledPackagesByType(type: string): string[]
        +{static} isInstalled(packageName: string, includeDevRequirements: bool): bool
        +{static} satisfies(parser: VersionParser, packageName: string, constraint: string): bool
        +{static} getVersionRanges(packageName: string): string
        +{static} getVersion(packageName: string): string
        +{static} getPrettyVersion(packageName: string): string
        +{static} getReference(packageName: string): string
        +{static} getInstallPath(packageName: string): string
        +{static} getRootPackage(): array
        +{static} getAllRawData(): array[]
        +{static} reload(data: array): void
        -{static} getInstalled(): array[]
        -{static} getSelfDir(): string
    }

    class Compiler {
        -version: string
        -branchAliasVersion: string
        -versionDate: DateTime
        ==
        +compile(pharFile: string): void
        -addFile(phar: Phar, file: SplFileInfo, strip: bool): void
        -addComposerBin(phar: Phar): void
        -stripWhitespace(source: string): string
        -getStub(): string
        -getRelativeFilePath(file: SplFileInfo): string
    }

}

' ── Inheritance ──────────────────────────────────────────────
Composer --|> PartialComposer : extends

' ── Factory bootstrap relationships ─────────────────────────
Factory ..> Composer : <<creates>> (fullLoad=true)
Factory ..> PartialComposer : <<creates>> (fullLoad=false)

' ── Installer depends on Composer ───────────────────────────
Installer ..> Composer : <<uses>> (create / constructor services)

' ── Notes ────────────────────────────────────────────────────
note bottom of Factory
  <b>createComposer()</b> is the central bootstrap:
  loads Config, builds all services, and wires
  them into Composer or PartialComposer based
  on the <i>$fullLoad</i> flag.
  <b>Factory::create()</b> is the static shorthand
  (always fullLoad=true).
end note

note bottom of Installer
  Fluent builder pattern — all setters
  return <b>self</b>. Use <b>Installer::create()</b>
  to extract services from a Composer instance,
  then call <b>run()</b> to execute installation.
end note

note right of InstalledVersions
  <b>@final</b> · all-static runtime API.
  Copied into every installed project.
  Uses ClassLoader::getRegisteredLoaders()
  to discover multiple vendor dirs.
  No runtime dependency on other
  Composer classes.
end note

note right of Compiler
  <b>Build-time only.</b>
  Compiles <i>composer.phar</i> via
  Symfony Finder + PHP Phar.
  Patches VERSION / BRANCH_ALIAS_VERSION /
  RELEASE_DATE constants in Composer.php.
  No runtime dependency on other
  Composer classes.
end note

@enduml
