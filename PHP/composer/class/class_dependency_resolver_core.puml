@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EDF4FB
    BorderColor #3A7BD5
}

title Dependency Resolver — Core Solver\n<size:11>(Composer\\DependencyResolver)</size>

' ─────────────────────────────────────────────
' Policy
' ─────────────────────────────────────────────
interface PolicyInterface {
    + versionCompare(a: PackageInterface, b: PackageInterface, operator: string): bool
    + selectPreferredPackages(pool: Pool, literals: array, requiredPackage: ?string): array
}

class DefaultPolicy {
    - preferStable: bool
    - preferLowest: bool
    - preferDevOverPrerelease: bool
    - preferredVersions: ?array
    - preferredPackageResultCachePerPool: array
    - sortingCachePerPool: array
    --
    + __construct(preferStable: bool, preferLowest: bool, preferredVersions: ?array)
    + versionCompare(a: PackageInterface, b: PackageInterface, operator: string): bool
    + selectPreferredPackages(pool: Pool, literals: array, requiredPackage: ?string): array
    + compareByPriority(pool: Pool, a: BasePackage, b: BasePackage, ...): int
    # groupLiteralsByName(pool: Pool, literals: array): array
    # pruneToBestVersion(pool: Pool, literals: array): array
}

DefaultPolicy ..|> PolicyInterface

' ─────────────────────────────────────────────
' Pool & Builder & Optimizer
' ─────────────────────────────────────────────
class Pool <<Countable>> {
    # packages: BasePackage[]
    # packageByName: array
    # versionParser: VersionParser
    # providerCache: array
    # unacceptableFixedOrLockedPackages: BasePackage[]
    # removedVersions: array
    # removedVersionsByPackage: array
    - securityRemovedVersions: array
    - abandonedRemovedVersions: array
    - filterListRemovedVersions: array
    --
    + whatProvides(name: string, constraint: ?ConstraintInterface): BasePackage[]
    + packageById(id: int): BasePackage
    + literalToPackage(literal: int): BasePackage
    + literalToPrettyString(literal: int, installedMap: array): string
    + match(candidate: BasePackage, name: string, constraint: ?ConstraintInterface): bool
    + getPackages(): BasePackage[]
    + count(): int
    + getRemovedVersions(name: string, constraint: ConstraintInterface): array
    + isUnacceptableFixedOrLockedPackage(package: BasePackage): bool
    + isSecurityRemovedPackageVersion(packageName: string, ...): bool
}

class PoolBuilder {
    - acceptableStabilities: int[]
    - stabilityFlags: int[]
    - rootAliases: array
    - rootReferences: string[]
    - temporaryConstraints: array
    - eventDispatcher: ?EventDispatcher
    - poolOptimizer: ?PoolOptimizer
    - io: IOInterface
    - packages: BasePackage[]
    - packagesToLoad: ConstraintInterface[]
    - loadedPackages: ConstraintInterface[]
    - unacceptableFixedOrLockedPackages: BasePackage[]
    - updateAllowList: string[]
    - securityAdvisoryPoolFilter: ?SecurityAdvisoryPoolFilter
    - filterListPoolFilter: ?FilterListPoolFilter
    --
    + __construct(acceptableStabilities: array, ..., poolOptimizer: ?PoolOptimizer, ...)
    + buildPool(repositories: array, request: Request): Pool
    + setIgnoredTypes(types: array): void
    + setAllowedTypes(types: ?array): void
    - loadPackage(request: Request, ...): void
    - loadPackagesMarkedForLoading(request: Request, ...): void
    - markPackageNameForLoading(request: Request, name: string, ...): void
    - runOptimizer(request: Request, pool: Pool): Pool
    - runSecurityAdvisoryFilter(pool: Pool, ...): Pool
}

class PoolOptimizer {
    - policy: PolicyInterface
    - irremovablePackages: array
    - requireConstraintsPerPackage: array
    - conflictConstraintsPerPackage: array
    - packagesToRemove: array
    - aliasesPerPackage: array
    - removedVersionsByPackage: array
    --
    + __construct(policy: PolicyInterface)
    + optimize(request: Request, pool: Pool): Pool
    - prepare(request: Request, pool: Pool): void
    - optimizeByIdenticalDependencies(request: Request, pool: Pool): void
    - optimizeImpossiblePackagesAway(request: Request, pool: Pool): void
    - applyRemovalsToPool(pool: Pool): Pool
}

PoolBuilder ..> Pool : <<creates>>\nbuildPool()
PoolBuilder o-- PoolOptimizer : optional
PoolOptimizer o-- PolicyInterface : uses

' ─────────────────────────────────────────────
' Request
' ─────────────────────────────────────────────
class Request {
    {static} UPDATE_ONLY_LISTED = 0
    {static} UPDATE_LISTED_WITH_TRANSITIVE_DEPS_NO_ROOT_REQUIRE = 1
    {static} UPDATE_LISTED_WITH_TRANSITIVE_DEPS = 2
    --
    # lockedRepository: ?LockArrayRepository
    # requires: array
    # fixedPackages: array
    # lockedPackages: array
    # fixedLockedPackages: array
    # updateAllowList: string[]
    # updateAllowTransitiveDependencies: false|int
    - restrictedPackages: ?list
    --
    + requireName(packageName: string, constraint: ?ConstraintInterface): void
    + fixPackage(package: BasePackage): void
    + lockPackage(package: BasePackage): void
    + unlockPackage(package: BasePackage): void
    + setUpdateAllowList(updateAllowList: array, transitiveMode): void
    + getRequires(): array
    + getFixedPackages(): array
    + getLockedPackages(): array
    + getFixedOrLockedPackages(): array
    + getPresentMap(packageIds: bool): array
    + isFixedPackage(package: BasePackage): bool
    + isLockedPackage(package: PackageInterface): bool
    + restrictPackages(names: array): void
}

' ─────────────────────────────────────────────
' Decisions
' ─────────────────────────────────────────────
class Decisions <<Iterator, Countable>> {
    {static} DECISION_LITERAL = 0
    {static} DECISION_REASON = 1
    --
    # pool: Pool
    # decisionMap: array
    # decisionQueue: array
    --
    + __construct(pool: Pool)
    + decide(literal: int, level: int, why: Rule): void
    + satisfy(literal: int): bool
    + conflict(literal: int): bool
    + decided(literalOrPackageId: int): bool
    + undecided(literalOrPackageId: int): bool
    + decidedInstall(literalOrPackageId: int): bool
    + decisionLevel(literalOrPackageId: int): int
    + decisionRule(literalOrPackageId: int): Rule
    + lastReason(): Rule
    + lastLiteral(): int
    + reset(): void
    + resetToOffset(offset: int): void
    + revertLast(): void
    + count(): int
    + isEmpty(): bool
    # addDecision(literal: int, level: int): void
}

Decisions *-- Pool : reads literals

' ─────────────────────────────────────────────
' Problem
' ─────────────────────────────────────────────
class Problem {
    # reasonSeen: array
    # reasons: array
    # section: int
    --
    + addRule(rule: Rule): void
    + getReasons(): array
    + getPrettyString(repositorySet, request, pool, ...): string
    + isCausedByLock(repositorySet, request, pool): bool
    + nextSection(): void
    + {static} getMissingPackageReason(repositorySet, request, pool, ...): array
    + {static} formatDeduplicatedRules(rules, indent, ...): string
    + {static} getPackageList(packages, isVerbose, pool, ...): string
    # addReason(id: string, reason: Rule): void
    - getRulePriority(rule: Rule): int
}

' ─────────────────────────────────────────────
' Transaction hierarchy
' ─────────────────────────────────────────────
class Transaction {
    # operations: OperationInterface[]
    # presentPackages: PackageInterface[]
    # resultPackageMap: array
    # resultPackagesByName: array
    --
    + __construct(presentPackages: array, resultPackages: array)
    + getOperations(): OperationInterface[]
    # calculateOperations(): OperationInterface[]
    # getRootPackages(): array
    # getProvidersInResult(link: Link): PackageInterface[]
    - setResultPackageMaps(resultPackages: array): void
    - movePluginsToFront(operations: array): OperationInterface[]
    - moveUninstallsToFront(operations: array): OperationInterface[]
}

class LockTransaction {
    # presentMap: array
    # unlockableMap: array
    # resultPackages: array
    --
    + __construct(pool: Pool, presentMap: array, unlockableMap: array, decisions: Decisions)
    + setResultPackages(pool: Pool, decisions: Decisions): void
    + setNonDevPackages(extractionResult: LockTransaction): void
    + getNewLockPackages(devMode: bool, updateMirrors: bool): BasePackage[]
    + getAliases(aliases: array): array
    - updateMirrorAndUrls(package: BasePackage): BasePackage
}

LockTransaction --|> Transaction
LockTransaction *-- Pool : resolves via
LockTransaction *-- Decisions : reads

' ─────────────────────────────────────────────
' Solver — central orchestrator
' ─────────────────────────────────────────────
class Solver {
    # policy: PolicyInterface
    # pool: Pool
    # rules: RuleSet
    # watchGraph: RuleWatchGraph
    # decisions: Decisions
    # fixedMap: BasePackage[]
    # propagateIndex: int
    # branches: array
    # problems: Problem[]
    # learnedPool: array
    # learnedWhy: array
    # io: IOInterface
    --
    + __construct(policy: PolicyInterface, pool: Pool, io: IOInterface)
    + solve(request: Request, filter: ?PlatformRequirementFilterInterface): LockTransaction
    + getRuleSetSize(): int
    + getPool(): Pool
    # propagate(level: int): ?Rule
    # analyze(level: int, rule: Rule): array
    # setupFixedMap(request: Request): void
    # checkForRootRequireProblems(request: Request, filter: ...): void
    - runSat(): void
    - revert(level: int): void
    - selectAndInstall(level: int, decisionQueue: array, rule: Rule): int
    - setPropagateLearn(level: int, literal: int, rule: Rule): int
    - makeAssertionRuleDecisions(): void
    - analyzeUnsolvable(conflictRule: Rule): void
    - analyzeUnsolvableRule(problem: Problem, conflictRule: Rule, ...): void
}

Solver *-- PolicyInterface       : policy
Solver *-- Pool                  : pool
Solver *-- Decisions             : decisions
Solver o-- Problem               : problems[]
Solver ..> Request               : solve(request)
Solver ..> LockTransaction       : <<creates>>\nsolve() returns

@enduml
