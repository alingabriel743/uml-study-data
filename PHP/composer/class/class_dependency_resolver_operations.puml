@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Dependency Resolver — Operations & Transactions

' ─────────────────────────────────────────────
' External / supporting types (stubs)
' ─────────────────────────────────────────────
package "Composer\\Package" #EEF2FF {
    interface PackageInterface <<external>>
    class AliasPackage <<external>>
    class BasePackage <<external>>
}

package "Composer\\Repository" #EEF2FF {
    interface RepositoryInterface <<external>>
    interface InstalledRepositoryInterface <<external>>
}

package "Composer\\DependencyResolver (support)" #EEF2FF {
    class Pool <<external>>
    class Decisions <<external>>
}

' ─────────────────────────────────────────────
' Operation hierarchy
' ─────────────────────────────────────────────
package "Composer\\DependencyResolver\\Operation" {

    interface OperationInterface {
        +getOperationType(): string
        +show(lock: bool): string
        +__toString(): string
    }

    abstract class SolverOperation {
        {static} #TYPE: string
        +getOperationType(): string
        +__toString(): string
    }

    class InstallOperation {
        {static} #TYPE = "install"
        #package: PackageInterface
        +__construct(package: PackageInterface)
        +getPackage(): PackageInterface
        +show(lock: bool): string
        {static} +format(package: PackageInterface, lock: bool): string
    }

    class UpdateOperation {
        {static} #TYPE = "update"
        #initialPackage: PackageInterface
        #targetPackage: PackageInterface
        +__construct(initial: PackageInterface, target: PackageInterface)
        +getInitialPackage(): PackageInterface
        +getTargetPackage(): PackageInterface
        +show(lock: bool): string
        {static} +format(initial: PackageInterface, target: PackageInterface, lock: bool): string
    }

    class UninstallOperation {
        {static} #TYPE = "uninstall"
        #package: PackageInterface
        +__construct(package: PackageInterface)
        +getPackage(): PackageInterface
        +show(lock: bool): string
        {static} +format(package: PackageInterface, lock: bool): string
    }

    class MarkAliasInstalledOperation {
        {static} #TYPE = "markAliasInstalled"
        #package: AliasPackage
        +__construct(package: AliasPackage)
        +getPackage(): AliasPackage
        +show(lock: bool): string
    }
}

' ─────────────────────────────────────────────
' Transaction hierarchy
' ─────────────────────────────────────────────
package "Composer\\DependencyResolver" {

    class Transaction <<internal>> {
        #operations: OperationInterface[]
        #presentPackages: PackageInterface[]
        #resultPackageMap: array<string, PackageInterface>
        #resultPackagesByName: array<string, PackageInterface[]>
        +__construct(presentPackages: array, resultPackages: array)
        +getOperations(): OperationInterface[]
        #calculateOperations(): OperationInterface[]
        #getRootPackages(): array
        #getProvidersInResult(link: Link): PackageInterface[]
        -setResultPackageMaps(resultPackages: array): void
        -movePluginsToFront(ops: OperationInterface[]): OperationInterface[]
        -moveUninstallsToFront(ops: OperationInterface[]): OperationInterface[]
    }

    class LocalRepoTransaction <<internal>> {
        +__construct(lockedRepository: RepositoryInterface, localRepository: InstalledRepositoryInterface)
    }

    class LockTransaction <<internal>> {
        #presentMap: array<string, BasePackage>
        #unlockableMap: array<int, BasePackage>
        #resultPackages: array{dev: BasePackage[], non-dev: BasePackage[], all: BasePackage[]}
        +__construct(pool: Pool, presentMap: array, unlockableMap: array, decisions: Decisions)
        +setResultPackages(pool: Pool, decisions: Decisions): void
        +setNonDevPackages(extractionResult: LockTransaction): void
        +getNewLockPackages(devMode: bool, updateMirrors: bool): BasePackage[]
        +getAliases(aliases: array): array
        -updateMirrorAndUrls(package: BasePackage): BasePackage
    }
}

' ─────────────────────────────────────────────
' Inheritance & implementation
' ─────────────────────────────────────────────
SolverOperation    ..|>  OperationInterface
InstallOperation   --|>  SolverOperation
UpdateOperation    --|>  SolverOperation
UninstallOperation --|>  SolverOperation
MarkAliasInstalledOperation --|> SolverOperation

LocalRepoTransaction --|> Transaction
LockTransaction      --|> Transaction

' ─────────────────────────────────────────────
' Associations — Transaction ↔ operations
' ─────────────────────────────────────────────
Transaction o-- OperationInterface : "aggregates\noperations[]"

Transaction ..> InstallOperation            : <<creates>>
Transaction ..> UpdateOperation             : <<creates>>
Transaction ..> UninstallOperation          : <<creates>>
Transaction ..> MarkAliasInstalledOperation : <<creates>>

' ─────────────────────────────────────────────
' Operation ↔ package types
' ─────────────────────────────────────────────
InstallOperation    *-- PackageInterface        : package
UninstallOperation  *-- PackageInterface        : package
UpdateOperation     *-- PackageInterface        : initialPackage
UpdateOperation     *-- PackageInterface        : targetPackage
MarkAliasInstalledOperation *-- AliasPackage   : package

' ─────────────────────────────────────────────
' LocalRepoTransaction & LockTransaction deps
' ─────────────────────────────────────────────
LocalRepoTransaction ..> RepositoryInterface          : lockedRepository
LocalRepoTransaction ..> InstalledRepositoryInterface : localRepository

LockTransaction ..> Pool      : pool
LockTransaction ..> Decisions : decisions
LockTransaction *-- BasePackage : resultPackages

' AliasPackage extends BasePackage (and implements PackageInterface) — stub relation
AliasPackage --|> BasePackage

@enduml
