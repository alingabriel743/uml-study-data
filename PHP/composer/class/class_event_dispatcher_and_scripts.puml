@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Event Dispatcher & Script Execution

' ─────────────────────────────────────────
' External / stdlib stubs
' ─────────────────────────────────────────
package "PHP stdlib" <<Rectangle>> {
    class RuntimeException <<external>> {
    }
}

package "Composer (external refs)" <<Rectangle>> {
    class PartialComposer <<external>> {
    }
    class Composer <<external>> {
    }
    interface IOInterface <<external>> {
    }
    class ProcessExecutor <<external>> {
    }
    class ClassLoader <<external>> {
    }
}

' ─────────────────────────────────────────
' Composer\EventDispatcher
' ─────────────────────────────────────────
package "Composer\\EventDispatcher" {

    class Event {
        # name: string
        # args: string[]
        # flags: mixed[]
        - propagationStopped: bool = false
        --
        + __construct(name: string, args: array, flags: array): void
        + getName(): string
        + getArguments(): array
        + getFlags(): array
        + isPropagationStopped(): bool
        + stopPropagation(): void
    }

    interface EventSubscriberInterface {
        + {static} getSubscribedEvents(): array
    }

    class ScriptExecutionException {
    }

    class EventDispatcher {
        # composer: PartialComposer
        # io: IOInterface
        # loader: ClassLoader?
        # process: ProcessExecutor
        # listeners: array<string, array<int, array<callable|string>>>
        # runScripts: bool = true
        - eventStack: list<string>
        - skipScripts: list<string>
        - previousHash: string|null
        - previousListeners: array<string, true>
        --
        + __construct(composer: PartialComposer, io: IOInterface, process: ProcessExecutor?): void
        + setRunScripts(runScripts: bool): self
        + dispatch(eventName: string?, event: Event?): int
        + dispatchScript(eventName: string, devMode: bool, additionalArgs: array, flags: array): int
        + dispatchPackageEvent(eventName: string, devMode: bool, localRepo: RepositoryInterface, operations: OperationInterface[], operation: OperationInterface): int
        + dispatchInstallerEvent(eventName: string, devMode: bool, executeOperations: bool, transaction: Transaction): int
        + addListener(eventName: string, listener: callable|string, priority: int): void
        + removeListener(listener: callable|object): void
        + addSubscriber(subscriber: EventSubscriberInterface): void
        + hasEventListeners(event: Event): bool
        # doDispatch(event: Event): int
        # executeTty(exec: string): int
        # getPhpExecCommand(): string
        # executeEventPhpScript(className: string, methodName: string, event: Event): mixed
        # getListeners(event: Event): array
        # getScriptListeners(event: Event): string[]
        # isPhpScript(callable: string): bool
        # isCommandClass(callable: string): bool
        # isComposerScript(callable: string): bool
        # pushEvent(event: Event): int
        # popEvent(): string?
        - ensureBinDirIsInPath(): void
        - getCallbackIdentifier(cb: callable): string
        - makeAutoloader(event: Event, callable: mixed): void
    }
}

' ─────────────────────────────────────────
' Composer\Script
' ─────────────────────────────────────────
package "Composer\\Script" {

    class ScriptEvent as "Event" {
        - composer: Composer
        - io: IOInterface
        - devMode: bool
        - originatingEvent: BaseEvent|null
        --
        + __construct(name: string, composer: Composer, io: IOInterface, devMode: bool, args: array, flags: array): void
        + getComposer(): Composer
        + getIO(): IOInterface
        + isDevMode(): bool
        + getOriginatingEvent(): BaseEvent?
        + setOriginatingEvent(event: BaseEvent): self
        - calculateOriginatingEvent(event: BaseEvent): BaseEvent
    }

    class ScriptEvents <<constants>> {
        {static} PRE_INSTALL_CMD = 'pre-install-cmd'
        {static} POST_INSTALL_CMD = 'post-install-cmd'
        {static} PRE_UPDATE_CMD = 'pre-update-cmd'
        {static} POST_UPDATE_CMD = 'post-update-cmd'
        {static} PRE_STATUS_CMD = 'pre-status-cmd'
        {static} POST_STATUS_CMD = 'post-status-cmd'
        {static} PRE_AUTOLOAD_DUMP = 'pre-autoload-dump'
        {static} POST_AUTOLOAD_DUMP = 'post-autoload-dump'
        {static} POST_ROOT_PACKAGE_INSTALL = 'post-root-package-install'
        {static} POST_CREATE_PROJECT_CMD = 'post-create-project-cmd'
        {static} PRE_ARCHIVE_CMD = 'pre-archive-cmd'
        {static} POST_ARCHIVE_CMD = 'post-archive-cmd'
    }
}

' ─────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────

' Inheritance
ScriptEvent         --|>  Event                      : extends
ScriptExecutionException --|> RuntimeException       : extends

' EventDispatcher composition / associations
EventDispatcher  *--  PartialComposer                : composer
EventDispatcher  *--  IOInterface                    : io
EventDispatcher  o--  ProcessExecutor                : process
EventDispatcher  o--  ClassLoader                    : loader (nullable)

' Script\Event associations
ScriptEvent      *--  Composer                       : composer
ScriptEvent      *--  IOInterface                    : io

' EventDispatcher → core dependencies
EventDispatcher  ..>  EventSubscriberInterface       : addSubscriber()
EventDispatcher  ..>  Event                          : dispatch / doDispatch
EventDispatcher  ..>  ScriptEvent                    : dispatchScript creates
EventDispatcher  ..>  ScriptExecutionException       : throws on non-zero exit
EventDispatcher  ..>  ScriptEvents                   : uses event name constants

' ─────────────────────────────────────────
' Dispatch-flow note
' ─────────────────────────────────────────
note bottom of EventDispatcher
  **Dispatch flow:**
  dispatch(name, event?) → doDispatch(event)
  dispatchScript(name, ...) → new Script\\Event → doDispatch
  doDispatch: getListeners → pushEvent → forEach listener:
    callable        → makeAutoloader → $callable($event)
    PHP Class::m    → executeEventPhpScript(class, method, event)
    @composerScript → new ScriptEvent + dispatch(name) [recursive]
    shellScript     → executeTty(cmd) — throws ScriptExecutionException
  Circular events detected via eventStack stack.
end note

note right of EventSubscriberInterface
  Return format:
  array<eventName,
    methodName |
    array{methodName, priority} |
    array<array{methodName, priority}>>
end note

note right of ScriptEvents
  Pure constants registry —
  string event-name keys for
  script lifecycle hooks.
  No methods or logic.
end note

@enduml
