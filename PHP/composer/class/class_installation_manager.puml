@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}

title Installation Manager & Installer Implementations

' ─────────────────────────────────────────────
' External stubs (referenced but not in scope)
' ─────────────────────────────────────────────
package "External References" <<Rectangle>> {
    class Event <<(E,#FFD700) Event>> {
    }
    class EventDispatcher {
        +dispatchPackageEvent(...): void
    }
    class Loop {
    }
    class IOInterface <<interface>> {
    }
    class DownloadManager {
        +download(...): ?PromiseInterface
        +prepare(...): ?PromiseInterface
        +cleanup(...): ?PromiseInterface
    }
    class Filesystem {
    }
    class PluginManager {
        +isPluginAllowed(...): bool
        +registerPackage(...): void
        +deactivatePackage(...): void
        +uninstallPackage(...): void
        +disablePlugins(): void
    }
    class PartialComposer {
    }
}

' ─────────────────────────────────────────────
' Core Installer namespace
' ─────────────────────────────────────────────
package "Composer\\Installer" {

    interface InstallerInterface {
        +supports(packageType: string): bool
        +isInstalled(repo: InstalledRepositoryInterface, package: PackageInterface): bool
        +download(package: PackageInterface, prevPackage: ?PackageInterface): ?PromiseInterface
        +prepare(type: string, package: PackageInterface, prevPackage: ?PackageInterface): ?PromiseInterface
        +install(repo: InstalledRepositoryInterface, package: PackageInterface): ?PromiseInterface
        +update(repo: InstalledRepositoryInterface, initial: PackageInterface, target: PackageInterface): ?PromiseInterface
        +uninstall(repo: InstalledRepositoryInterface, package: PackageInterface): ?PromiseInterface
        +cleanup(type: string, package: PackageInterface, prevPackage: ?PackageInterface): ?PromiseInterface
        +getInstallPath(package: PackageInterface): ?string
    }

    interface BinaryPresenceInterface {
        +ensureBinariesPresence(package: PackageInterface): void
    }

    ' ─── InstallationManager ────────────────
    class InstallationManager {
        -installers: list<InstallerInterface>
        -cache: array<string, InstallerInterface>
        -notifiablePackages: array<string, array<PackageInterface>>
        -loop: Loop
        -io: IOInterface
        -eventDispatcher: ?EventDispatcher
        -outputProgress: bool
        --
        +__construct(loop: Loop, io: IOInterface, eventDispatcher: ?EventDispatcher)
        +reset(): void
        +addInstaller(installer: InstallerInterface): void
        +removeInstaller(installer: InstallerInterface): void
        +disablePlugins(): void
        +getInstaller(type: string): InstallerInterface
        +isPackageInstalled(repo: InstalledRepositoryInterface, package: PackageInterface): bool
        +ensureBinariesPresence(package: PackageInterface): void
        +execute(repo: InstalledRepositoryInterface, operations: array, devMode: bool, runScripts: bool, downloadOnly: bool): void
        +install(repo: InstalledRepositoryInterface, operation: InstallOperation): ?PromiseInterface
        +update(repo: InstalledRepositoryInterface, operation: UpdateOperation): ?PromiseInterface
        +uninstall(repo: InstalledRepositoryInterface, operation: UninstallOperation): ?PromiseInterface
        +getInstallPath(package: PackageInterface): ?string
        +setOutputProgress(outputProgress: bool): void
        +notifyInstalls(io: IOInterface): void
        -downloadAndExecuteBatch(...): void
        -executeBatch(...): void
        -waitOnPromises(promises: array): void
        -runCleanup(cleanupPromises: array): void
    }

    ' ─── LibraryInstaller ───────────────────
    class LibraryInstaller {
        #composer: PartialComposer
        #vendorDir: string
        #downloadManager: ?DownloadManager
        #io: IOInterface
        #type: string
        #filesystem: Filesystem
        #binaryInstaller: BinaryInstaller
        --
        +__construct(io: IOInterface, composer: PartialComposer, type: ?string, filesystem: ?Filesystem, binaryInstaller: ?BinaryInstaller)
        +supports(packageType: string): bool
        +isInstalled(repo: InstalledRepositoryInterface, package: PackageInterface): bool
        +download(...): ?PromiseInterface
        +prepare(...): ?PromiseInterface
        +cleanup(...): ?PromiseInterface
        +install(repo: InstalledRepositoryInterface, package: PackageInterface): ?PromiseInterface
        +update(repo: InstalledRepositoryInterface, initial: PackageInterface, target: PackageInterface): ?PromiseInterface
        +uninstall(repo: InstalledRepositoryInterface, package: PackageInterface): ?PromiseInterface
        +getInstallPath(package: PackageInterface): string
        +ensureBinariesPresence(package: PackageInterface): void
        #getPackageBasePath(package: PackageInterface): string
        #installCode(package: PackageInterface): ?PromiseInterface
        #updateCode(initial: PackageInterface, target: PackageInterface): ?PromiseInterface
        #removeCode(package: PackageInterface): ?PromiseInterface
        #initializeVendorDir(): void
        #getDownloadManager(): DownloadManager
    }

    ' ─── PluginInstaller ────────────────────
    class PluginInstaller {
        --
        +__construct(io: IOInterface, composer: PartialComposer, fs: ?Filesystem, binaryInstaller: ?BinaryInstaller)
        +supports(packageType: string): bool
        +disablePlugins(): void
        +prepare(...): ?PromiseInterface
        +download(...): ?PromiseInterface
        +install(repo: InstalledRepositoryInterface, package: PackageInterface): ?PromiseInterface
        +update(repo: InstalledRepositoryInterface, initial: PackageInterface, target: PackageInterface): ?PromiseInterface
        +uninstall(repo: InstalledRepositoryInterface, package: PackageInterface): ?PromiseInterface
        #getPluginManager(): PluginManager
        -rollbackInstall(...): void
    }

    ' ─── MetapackageInstaller ───────────────
    class MetapackageInstaller {
        -io: IOInterface
        --
        +__construct(io: IOInterface)
        +supports(packageType: string): bool
        +isInstalled(repo: InstalledRepositoryInterface, package: PackageInterface): bool
        +download(...): ?PromiseInterface
        +prepare(...): void
        +cleanup(...): void
        +install(repo: InstalledRepositoryInterface, package: PackageInterface): ?PromiseInterface
        +update(repo: InstalledRepositoryInterface, initial: PackageInterface, target: PackageInterface): ?PromiseInterface
        +uninstall(repo: InstalledRepositoryInterface, package: PackageInterface): ?PromiseInterface
        +getInstallPath(package: PackageInterface): null
    }

    ' ─── ProjectInstaller ───────────────────
    class ProjectInstaller {
        -installPath: string
        -downloadManager: DownloadManager
        -filesystem: Filesystem
        --
        +__construct(installPath: string, dm: DownloadManager, fs: Filesystem)
        +supports(packageType: string): bool
        +isInstalled(...): bool
        +download(...): ?PromiseInterface
        +prepare(...): ?PromiseInterface
        +cleanup(...): ?PromiseInterface
        +install(repo: InstalledRepositoryInterface, package: PackageInterface): ?PromiseInterface
        +update(...): void
        +uninstall(...): void
        +getInstallPath(package: PackageInterface): string
    }

    ' ─── BinaryInstaller ────────────────────
    class BinaryInstaller {
        #binDir: string
        #binCompat: string
        #io: IOInterface
        #filesystem: Filesystem
        -vendorDir: ?string
        --
        +__construct(io: IOInterface, binDir: string, binCompat: string, filesystem: ?Filesystem, vendorDir: ?string)
        +installBinaries(package: PackageInterface, installPath: string, warnOnOverwrite: bool): void
        +removeBinaries(package: PackageInterface): void
        +{static} determineBinaryCaller(bin: string): string
        #getBinaries(package: PackageInterface): string[]
        #installFullBinaries(...): void
        #installUnixyProxyBinaries(...): void
        #initializeBinDir(): void
        #generateWindowsProxyCode(...): string
        #generateUnixyProxyCode(...): string
    }

    ' ─── PackageEvents constants ─────────────
    class PackageEvents <<(C,#ADD8E6) Constants>> {
        +{static} PRE_PACKAGE_INSTALL: string
        +{static} POST_PACKAGE_INSTALL: string
        +{static} PRE_PACKAGE_UPDATE: string
        +{static} POST_PACKAGE_UPDATE: string
        +{static} PRE_PACKAGE_UNINSTALL: string
        +{static} POST_PACKAGE_UNINSTALL: string
    }

    ' ─── Events ─────────────────────────────
    class InstallerEvent {
        -composer: Composer
        -io: IOInterface
        -devMode: bool
        -executeOperations: bool
        -transaction: Transaction
        --
        +__construct(eventName: string, composer: Composer, io: IOInterface, devMode: bool, executeOperations: bool, transaction: Transaction)
        +getComposer(): Composer
        +getIO(): IOInterface
        +isDevMode(): bool
        +isExecutingOperations(): bool
        +getTransaction(): ?Transaction
    }

    class PackageEvent {
        -composer: Composer
        -io: IOInterface
        -devMode: bool
        -localRepo: RepositoryInterface
        -operations: OperationInterface[]
        -operation: OperationInterface
        --
        +__construct(eventName: string, composer: Composer, io: IOInterface, devMode: bool, localRepo: RepositoryInterface, operations: array, operation: OperationInterface)
        +getComposer(): Composer
        +getIO(): IOInterface
        +isDevMode(): bool
        +getLocalRepo(): RepositoryInterface
        +getOperations(): OperationInterface[]
        +getOperation(): OperationInterface
    }
}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' Interface implementations
LibraryInstaller ..|> InstallerInterface : implements
LibraryInstaller ..|> BinaryPresenceInterface : implements
MetapackageInstaller ..|> InstallerInterface : implements
ProjectInstaller ..|> InstallerInterface : implements

' Inheritance
PluginInstaller --|> LibraryInstaller : extends

' Event hierarchy
InstallerEvent --|> Event : extends
PackageEvent --|> Event : extends

' InstallationManager aggregates installers
InstallationManager o-- InstallerInterface : manages 1..*

' InstallationManager dependencies
InstallationManager ..> EventDispatcher : dispatches\nPackageEvent
InstallationManager ..> Loop : async execution
InstallationManager ..> PackageEvents : uses constants
InstallationManager ..> BinaryPresenceInterface : instanceof check

' LibraryInstaller compositions
LibraryInstaller *-- BinaryInstaller : composes
LibraryInstaller ..> DownloadManager : delegates to
LibraryInstaller ..> Filesystem : uses
LibraryInstaller ..> PartialComposer : configured by

' PluginInstaller dependencies
PluginInstaller ..> PluginManager : delegates plugin\nlifecycle

' ProjectInstaller compositions
ProjectInstaller *-- DownloadManager : composes
ProjectInstaller *-- Filesystem : composes

@enduml
