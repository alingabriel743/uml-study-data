@startuml class_io_console_and_config

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title IO, Console & Configuration

' ─────────────────────────────────────────────
' External stubs
' ─────────────────────────────────────────────
package "Psr\\Log" #EEF2FF {
    interface LoggerInterface {
        +emergency($message, array $context): void
        +alert($message, array $context): void
        +critical($message, array $context): void
        +error($message, array $context): void
        +warning($message, array $context): void
        +notice($message, array $context): void
        +info($message, array $context): void
        +debug($message, array $context): void
        +log($level, $message, array $context): void
    }
}

package "Symfony\\Component\\Console" #EEF2FF {
    class SymfonyApplication << (C,#EEF2FF) Symfony >> {
        +run(?InputInterface $input, ?OutputInterface $output): int
        +doRun(InputInterface $input, OutputInterface $output): int
    }
    interface InputInterface << Symfony >>
    interface OutputInterface << Symfony >>
    class HelperSet << Symfony >>
}

' ─────────────────────────────────────────────
' Composer IO Package
' ─────────────────────────────────────────────
package "Composer\\IO" {

    interface IOInterface {
        {static} +QUIET: int = 1
        {static} +NORMAL: int = 2
        {static} +VERBOSE: int = 4
        {static} +VERY_VERBOSE: int = 8
        {static} +DEBUG: int = 16
        ..
        +isInteractive(): bool
        +isVerbose(): bool
        +isVeryVerbose(): bool
        +isDebug(): bool
        +isDecorated(): bool
        +write($messages, bool $newline, int $verbosity): void
        +writeError($messages, bool $newline, int $verbosity): void
        +overwrite($messages, bool $newline, ?int $size, int $verbosity): void
        +overwriteError($messages, bool $newline, ?int $size, int $verbosity): void
        +ask(string $question, $default): mixed
        +askConfirmation(string $question, bool $default): bool
        +askAndValidate(string $question, callable $validator, ?int $attempts, $default): mixed
        +askAndHideAnswer(string $question): ?string
        +select(string $question, array $choices, $default, $attempts, string $errorMessage, bool $multiselect): mixed
        +getAuthentications(): array
        +hasAuthentication(string $repositoryName): bool
        +getAuthentication(string $repositoryName): array
        +setAuthentication(string $repositoryName, string $username, ?string $password): void
        +loadConfiguration(Config $config): void
    }

    abstract class BaseIO {
        #$authentications: array
        ..
        +getAuthentications(): array
        +resetAuthentications(): void
        +hasAuthentication(string $repositoryName): bool
        +getAuthentication(string $repositoryName): array
        +setAuthentication(string $repositoryName, string $username, ?string $password): void
        +writeRaw($messages, bool $newline, int $verbosity): void
        +writeErrorRaw($messages, bool $newline, int $verbosity): void
        +loadConfiguration(Config $config): void
        #checkAndSetAuthentication(string $repositoryName, string $username, ?string $password): void
        ' PSR-3 log delegation methods
        +emergency($message, array $context): void
        +alert($message, array $context): void
        +log($level, $message, array $context): void
    }

    class ConsoleIO {
        #$input: InputInterface
        #$output: OutputInterface
        #$helperSet: HelperSet
        #$lastMessage: string
        #$lastMessageErr: string
        -$startTime: float
        -$verbosityMap: array
        ..
        +__construct(InputInterface $input, OutputInterface $output, HelperSet $helperSet)
        +enableDebugging(float $startTime): void
        +isInteractive(): bool
        +isDecorated(): bool
        +isVerbose(): bool
        +isVeryVerbose(): bool
        +isDebug(): bool
        +write($messages, bool $newline, int $verbosity): void
        +writeError($messages, bool $newline, int $verbosity): void
        +overwrite($messages, bool $newline, ?int $size, int $verbosity): void
        +overwriteError($messages, bool $newline, ?int $size, int $verbosity): void
        +ask($question, $default): mixed
        +askConfirmation($question, $default): bool
        +askAndValidate($question, $validator, $attempts, $default): mixed
        +askAndHideAnswer($question): ?string
        +select($question, $choices, $default, $attempts, $errorMessage, $multiselect): mixed
        +getProgressBar(int $max): ProgressBar
        +getTable(): Table
        {static} +sanitize($messages, bool $allowNewlines): string|array
    }

    note right of ConsoleIO
        Maps IOInterface verbosity
        constants to Symfony
        OutputInterface constants.
        Prepends [MiB/time] prefix
        when --profile is active.
    end note

    class BufferIO {
        ..
        +__construct(string $input, int $verbosity, ?OutputFormatterInterface $formatter)
        +getOutput(): string
        +setUserInputs(array $inputs): void
        -createStream(array $inputs)
    }

    note right of BufferIO
        Test-only. Wraps
        ArrayInput + StreamOutput
        in memory. getOutput()
        resolves overwrite sequences.
    end note

    class NullIO {
        ..
        +isInteractive(): bool
        +isVerbose(): bool
        +isVeryVerbose(): bool
        +isDebug(): bool
        +isDecorated(): bool
        +write($messages, bool $newline, int $verbosity): void
        +writeError($messages, bool $newline, int $verbosity): void
        +overwrite($messages, bool $newline, ?int $size, int $verbosity): void
        +overwriteError($messages, bool $newline, ?int $size, int $verbosity): void
        +ask($question, $default): mixed
        +askConfirmation($question, $default): bool
        +askAndValidate($question, $validator, $attempts, $default): mixed
        +askAndHideAnswer($question): ?string
        +select($question, $choices, $default, $attempts, $errorMessage, $multiselect): mixed
    }

    note right of NullIO
        Null Object pattern.
        All methods are no-ops.
        Used in silent/completion
        contexts.
    end note
}

' ─────────────────────────────────────────────
' Composer Console Package
' ─────────────────────────────────────────────
package "Composer\\Console" {

    class Application {
        #$composer: ?Composer
        #$io: IOInterface
        -{static} $logo: string
        -$hasPluginCommands: bool
        -$disablePluginsByDefault: bool
        -$disableScriptsByDefault: bool
        -$initialWorkingDirectory: string|false
        ..
        +__construct(string $name, string $version)
        +run(?InputInterface $input, ?OutputInterface $output): int
        +doRun(InputInterface $input, OutputInterface $output): int
        +getComposer(bool $required, ?bool $disablePlugins, ?bool $disableScripts): ?Composer
        +resetComposer(): void
        +getIO(): IOInterface
        +getHelp(): string
        +getDefaultCommands(): array
        +getLongVersion(): string
        +getInitialWorkingDirectory(): string|false
        +getDisablePluginsByDefault(): bool
        +getDisableScriptsByDefault(): bool
        -getPluginCommands(): array
        -isRunningAsRoot(): bool
        -getUseParentDirConfigValue(): string|bool
    }

    note right of Application
        Initialises with NullIO.
        Replaces with ConsoleIO
        in doRun(). Handles
        --working-dir, root-user
        checks, script aliases.
    end note
}

' ─────────────────────────────────────────────
' Composer Config Package
' ─────────────────────────────────────────────
package "Composer\\Config" {

    interface ConfigSourceInterface {
        +addRepository(string $name, $config, bool $append): void
        +insertRepository(string $name, $config, string $referenceName, int $offset): void
        +setRepositoryUrl(string $name, string $url): void
        +removeRepository(string $name): void
        +addConfigSetting(string $name, $value): void
        +removeConfigSetting(string $name): void
        +addProperty(string $name, $value): void
        +removeProperty(string $name): void
        +addLink(string $type, string $name, string $value): void
        +removeLink(string $type, string $name): void
        +getName(): string
    }

    class JsonConfigSource {
        -$file: JsonFile
        -$authConfig: bool
        ..
        +__construct(JsonFile $file, bool $authConfig)
        +getName(): string
        +addRepository(string $name, $config, bool $append): void
        +insertRepository(string $name, $config, string $referenceName, int $offset): void
        +setRepositoryUrl(string $name, string $url): void
        +removeRepository(string $name): void
        +addConfigSetting(string $name, $value): void
        +removeConfigSetting(string $name): void
        +addProperty(string $name, $value): void
        +removeProperty(string $name): void
        +addLink(string $type, string $name, string $value): void
        +removeLink(string $type, string $name): void
        -manipulateJson(string $method, callable $fallback, ...$args): void
        -arrayUnshiftRef(array &$array, &$value): int
    }

    note right of JsonConfigSource
        All mutations via
        manipulateJson(): tries
        JsonManipulator first,
        falls back to full rewrite.
        Validates schema after
        each write. chmod 0600
        on new files.
    end note
}

' ─────────────────────────────────────────────
' Composer (root namespace)
' ─────────────────────────────────────────────
package "Composer" {

    class Config {
        {static} +$defaultConfig: array
        {static} +$defaultRepositories: array
        {static} +SOURCE_DEFAULT: string
        {static} +SOURCE_COMMAND: string
        {static} +SOURCE_UNKNOWN: string
        {static} +RELATIVE_PATHS: int = 1
        -$config: array
        -$baseDir: ?string
        -$repositories: array
        -$configSource: ConfigSourceInterface
        -$authConfigSource: ConfigSourceInterface
        -$localAuthConfigSource: ?ConfigSourceInterface
        -$useEnvironment: bool
        -$warnedHosts: array
        -$sourceOfConfigValue: array
        ..
        +__construct(bool $useEnvironment, ?string $baseDir)
        +setBaseDir(?string $baseDir): void
        +setConfigSource(ConfigSourceInterface $source): void
        +getConfigSource(): ConfigSourceInterface
        +setAuthConfigSource(ConfigSourceInterface $source): void
        +getAuthConfigSource(): ConfigSourceInterface
        +setLocalAuthConfigSource(ConfigSourceInterface $source): void
        +getLocalAuthConfigSource(): ?ConfigSourceInterface
        +merge(array $config, string $source): void
        +get(string $key, int $flags): mixed
        +all(int $flags): array
        +raw(): array
        +has(string $key): bool
        +getSourceOfValue(string $key): string
        +prohibitUrlByConfig(string $url, ?IOInterface $io, array $repoOptions): void
        {static} +disableProcessTimeout(): void
        -process($value, int $flags): mixed
        -getComposerEnv(string $var): string|false
    }

    note right of Config
        get() resolves {$refs}
        recursively and supports
        env var overrides.
        Holds 3 ConfigSource refs:
        main, auth, localAuth.
    end note
}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' PSR-3 inheritance
IOInterface --|> LoggerInterface

' IO hierarchy
BaseIO ..|> IOInterface
ConsoleIO --|> BaseIO
BufferIO --|> ConsoleIO
NullIO --|> BaseIO

' ConsoleIO uses Symfony Console types
ConsoleIO o-- InputInterface  : uses >
ConsoleIO o-- OutputInterface : uses >
ConsoleIO o-- HelperSet       : uses >

' Console Application
Application --|> SymfonyApplication
Application o-- IOInterface  : $io (NullIO→ConsoleIO) >
Application ..> ConsoleIO    : creates in doRun() >
Application ..> "Composer\\Config.Config" : uses via Factory >

' Config aggregates ConfigSourceInterface (three slots)
Config *-- ConfigSourceInterface : $configSource\n$authConfigSource\n$localAuthConfigSource >
Config ..> IOInterface : prohibitUrlByConfig() >

' BaseIO depends on Config for loadConfiguration
BaseIO ..> Config : loadConfiguration() >

' JsonConfigSource implements ConfigSourceInterface
JsonConfigSource ..|> ConfigSourceInterface

@enduml
