@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Package Archiver & Archive Management\n<size:11>Composer\\Package\\Archiver</size>

' ─────────────────────────────────────────────
' External / PHP built-ins (lightweight stubs)
' ─────────────────────────────────────────────
package "PHP / Symfony (External)" <<Frame>> {
    abstract class FilterIterator <<PHP built-in>> {
        +accept(): bool
    }

    class Finder <<Symfony>> {
    }

    class DownloadManager <<Composer\\Downloader>> {
    }

    class Loop <<Composer\\Util>> {
    }

    interface CompletePackageInterface <<Composer\\Package>> {
        +getArchiveName(): ?string
        +getArchiveExcludes(): array
    }
}

' ─────────────────────────────────────────────
' Composer Package Archiver namespace
' ─────────────────────────────────────────────
package "Composer\\Package\\Archiver" {

    ' ── Interface ──────────────────────────────
    interface ArchiverInterface {
        +archive(sources: string, target: string, format: string,\n  excludes: array, ignoreFilters: bool): string
        +supports(format: string, sourceType: ?string): bool
    }

    ' ── Archive Manager ────────────────────────
    class ArchiveManager {
        #downloadManager: DownloadManager
        #loop: Loop
        #archivers: ArchiverInterface[]
        #overwriteFiles: bool = true
        --
        +__construct(downloadManager: DownloadManager, loop: Loop)
        +addArchiver(archiver: ArchiverInterface): void
        +setOverwriteFiles(overwriteFiles: bool): self
        +getPackageFilenameParts(package: CompletePackageInterface): array
        +getPackageFilenameFromParts(parts: array): string
        +getPackageFilename(package: CompletePackageInterface): string
        +archive(package: CompletePackageInterface, format: string,\n  targetDir: string, fileName: ?string, ignoreFilters: bool): string
        -buildExcludePatterns(parts: array, formats: array): array
        -getSupportedFormats(): array
    }

    ' ── Archiver Implementations ───────────────
    class PharArchiver {
        #{static} formats: array<string,int>
        #{static} compressFormats: array<string,int>
        --
        +archive(sources: string, target: string, format: string,\n  excludes: array, ignoreFilters: bool): string
        +supports(format: string, sourceType: ?string): bool
    }

    class ZipArchiver {
        #{static} formats: array<string,bool>
        --
        +archive(sources: string, target: string, format: string,\n  excludes: array, ignoreFilters: bool): string
        +supports(format: string, sourceType: ?string): bool
        -compressionAvailable(): bool
    }

    ' ── File Finders / Filters ─────────────────
    class ArchivableFilesFinder {
        #finder: Finder
        --
        +__construct(sources: string, excludes: array,\n  ignoreFilters: bool)
        +accept(): bool
    }

    class ArchivableFilesFilter {
        -dirs: string[]
        --
        +accept(): bool
        +addEmptyDir(phar: PharData, sources: string): void
    }

    ' ── Exclude Filters ────────────────────────
    abstract class BaseExcludeFilter {
        #sourcePath: string
        #excludePatterns: array
        --
        +__construct(sourcePath: string)
        +filter(relativePath: string, exclude: bool): bool
        #parseLines(lines: array, lineParser: callable): array
        #generatePatterns(rules: array): array
        #generatePattern(rule: string): array
    }

    class ComposerExcludeFilter {
        --
        +__construct(sourcePath: string, excludeRules: array)
    }

    class GitExcludeFilter {
        --
        +__construct(sourcePath: string)
        +parseGitAttributesLine(line: string): ?array
    }

}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' Implementations
PharArchiver    ..|> ArchiverInterface
ZipArchiver     ..|> ArchiverInterface

' Inheritance within namespace
ArchivableFilesFinder   --|> FilterIterator
ArchivableFilesFilter   --|> FilterIterator
ComposerExcludeFilter   --|> BaseExcludeFilter
GitExcludeFilter        --|> BaseExcludeFilter

' ArchiveManager composition & dependencies
ArchiveManager "1" o-- "*" ArchiverInterface          : archivers
ArchiveManager          ..>  DownloadManager           : downloads sources
ArchiveManager          ..>  Loop                      : async await
ArchiveManager          ..>  CompletePackageInterface  : archives package

' PharArchiver creates finders/filters
PharArchiver    ..>  ArchivableFilesFinder  : <<creates>>
PharArchiver    ..>  ArchivableFilesFilter  : <<creates>>

' ZipArchiver creates finder
ZipArchiver     ..>  ArchivableFilesFinder  : <<creates>>

' ArchivableFilesFilter wraps ArchivableFilesFinder
ArchivableFilesFilter   o--  ArchivableFilesFinder    : wraps

' ArchivableFilesFinder creates exclude filters
ArchivableFilesFinder   ..>  GitExcludeFilter          : <<creates>>
ArchivableFilesFinder   ..>  ComposerExcludeFilter     : <<creates>>
ArchivableFilesFinder   *--  Finder                    : uses

@enduml
