@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
}

title Package Loading, Dumping & Locking

' ─────────────────────────────────────────────
' External / support types (lightweight stubs)
' ─────────────────────────────────────────────
package "Composer\\Package (interfaces)" <<Frame>> {
    interface PackageInterface {
        +getName(): string
        +getVersion(): string
    }
    abstract class BasePackage {
    }
}

package "Composer\\Util & Config" <<Frame>> {
    class VersionParser {
        +normalize(string $version): string
        +parseConstraints(string $constraints): ConstraintInterface
    }
    class VersionGuesser {
        +guessVersion(array $packageConfig, string $path): ?array
    }
    class JsonFile {
        +read(): array
        +write(array $hash): void
        +getPath(): string
    }
    class ProcessExecutor {
    }
}

package "Composer\\Repository" <<Frame>> {
    class RepositoryManager {
    }
    class InstallationManager {
        +getInstallPath(PackageInterface $package): string
    }
}

' ─────────────────────────────────────────────
' Loader namespace
' ─────────────────────────────────────────────
package "Composer\\Package\\Loader" {

    interface LoaderInterface {
        +load(array $config, string $class): BasePackage
    }

    class ArrayLoader {
        #versionParser: VersionParser
        #loadOptions: bool
        --
        +__construct(?VersionParser $parser, bool $loadOptions)
        +load(array $config, string $class): BasePackage
        +loadPackages(array $versions): array
        +parseLinks(string $source, string $sourceVersion,\n  string $description, array $links): Link[]
        +getBranchAlias(array $config): ?string
        -createObject(array $config, string $class): CompletePackage
        -configureObject(PackageInterface $package, array $config): BasePackage
        -configureCachedLinks(array &$linkCache, PackageInterface $package,\n  array $config): void
        -createLink(string $source, string $sourceVersion,\n  string $description, string $target, string $prettyConstraint): Link
    }

    class RootPackageLoader {
        -manager: RepositoryManager
        -config: Config
        -versionGuesser: VersionGuesser
        -io: ?IOInterface
        --
        +__construct(RepositoryManager $manager, Config $config,\n  ?VersionParser $parser, ?VersionGuesser $versionGuesser, ?IOInterface $io)
        +load(array $config, string $class, ?string $cwd): BasePackage
        -extractAliases(array $requires, array $aliases): array
        +{static} extractStabilityFlags(array $requires,\n  string $minimumStability, array $stabilityFlags): array
        +{static} extractReferences(array $requires, array $references): array
    }

    class ValidatingArrayLoader {
        -loader: LoaderInterface
        -versionParser: VersionParser
        -errors: list<string>
        -warnings: list<string>
        -config: array
        -flags: int
        --
        +CHECK_ALL = 3
        +CHECK_UNBOUND_CONSTRAINTS = 1
        +CHECK_STRICT_CONSTRAINTS = 2
        --
        +__construct(LoaderInterface $loader, bool $strictName,\n  ?VersionParser $parser, int $flags)
        +load(array $config, string $class): BasePackage
        +getWarnings(): list<string>
        +getErrors(): list<string>
        +{static} hasPackageNamingError(string $name, bool $isLink): ?string
        -validateRegex(string $property, string $regex, bool $mandatory): bool
        -validateString(string $property, bool $mandatory): bool
        -validateUrl(string $property, bool $mandatory): bool
        -filterUrl(mixed $value, array $schemes): bool
    }

    class JsonLoader {
        -loader: LoaderInterface
        --
        +__construct(LoaderInterface $loader)
        +load(string|JsonFile $json): BasePackage
    }
}

' ─────────────────────────────────────────────
' Dumper namespace
' ─────────────────────────────────────────────
package "Composer\\Package\\Dumper" {

    class ArrayDumper {
        +dump(PackageInterface $package): array<string, mixed>
        -dumpValues(PackageInterface $package, array $keys, array $data): array<string, mixed>
    }
}

' ─────────────────────────────────────────────
' Locker (Composer\\Package)
' ─────────────────────────────────────────────
package "Composer\\Package" {

    class Locker {
        -lockFile: JsonFile
        -installationManager: InstallationManager
        -hash: string
        -contentHash: string
        -loader: ArrayLoader
        -dumper: ArrayDumper
        -process: ProcessExecutor
        -lockDataCache: ?array
        -virtualFileWritten: bool
        --
        +__construct(IOInterface $io, JsonFile $lockFile,\n  InstallationManager $installationManager,\n  string $composerFileContents, ?ProcessExecutor $process)
        +getJsonFile(): JsonFile
        +{static} getContentHash(string $composerFileContents): string
        +isLocked(): bool
        +isFresh(): bool
        +getLockedRepository(bool $withDevReqs): LockArrayRepository
        +getDevPackageNames(): array
        +getPlatformRequirements(bool $withDevReqs): Link[]
        +getMinimumStability(): string
        +getStabilityFlags(): array
        +getPreferStable(): ?bool
        +getPreferLowest(): ?bool
        +getLockData(): array<string, mixed>
        +setLockData(array $packages, ?array $devPackages, ...): bool
        +updateHash(JsonFile $composerJson, ?callable $dataProcessor): void
        +getMissingRequirementInfo(RootPackageInterface $package, bool $includeDev): array
        -fixupJsonDataType(array $lockData): array
        -lockPackages(array $packages): array
        -getPackageTime(PackageInterface $package): ?string
    }

    class Comparer {
        -source: string
        -update: string
        -changed: array
        --
        +setSource(string $source): void
        +setUpdate(string $update): void
        +getChanged(bool $explicated): array|false
        +getChangedAsString(bool $toString, bool $explicated): string
        +doCompare(): void
        -doTree(string $dir, array &$array): array|false
    }
}

' ─────────────────────────────────────────────
' Inheritance & Implementation
' ─────────────────────────────────────────────
ArrayLoader      ..|> LoaderInterface      : implements
ValidatingArrayLoader ..|> LoaderInterface : implements
RootPackageLoader --|> ArrayLoader          : extends

' ─────────────────────────────────────────────
' Decorator / Adapter patterns
' ─────────────────────────────────────────────
ValidatingArrayLoader o--> LoaderInterface  : wraps\n(decorator)
JsonLoader            o--> LoaderInterface  : delegates to\n(adapter)

' ─────────────────────────────────────────────
' Locker composition
' ─────────────────────────────────────────────
Locker *--> ArrayLoader         : owns
Locker *--> ArrayDumper         : owns
Locker o--> JsonFile            : lockFile
Locker o--> InstallationManager

' ─────────────────────────────────────────────
' Loader / Dumper external dependencies
' ─────────────────────────────────────────────
ArrayLoader       o--> VersionParser        : uses
RootPackageLoader o--> VersionGuesser       : uses
RootPackageLoader o--> RepositoryManager    : uses
ArrayDumper       ..>  PackageInterface     : reads

' ─────────────────────────────────────────────
' Package hierarchy (context)
' ─────────────────────────────────────────────
ArrayLoader ..> BasePackage : creates
BasePackage --|> PackageInterface

' ─────────────────────────────────────────────
' Notes
' ─────────────────────────────────────────────
note right of ValidatingArrayLoader
  <b>Decorator Pattern</b>
  Validates all config fields,
  collects errors/warnings,
  throws InvalidPackageException
  on errors, then delegates to
  inner $loader->load()
end note

note right of JsonLoader
  <b>Adapter Pattern</b>
  Parses JSON from filename /
  string / JsonFile, then
  delegates to inner LoaderInterface.
  Does <b>NOT</b> implement LoaderInterface.
end note

note bottom of Locker
  <b>Composition</b>
  Owns both ArrayLoader and ArrayDumper.
  lockPackages() → dumper->dump() per package.
  getLockedRepository() → loader->load() per entry.
  Caches parsed lock JSON in $lockDataCache.
end note

note bottom of Comparer
  Standalone dir-diff utility.
  Not coupled to the loading/dumping pipeline.
  Uses xxh3 (PHP 8.1+) or sha1 for hashing.
end note

@enduml
