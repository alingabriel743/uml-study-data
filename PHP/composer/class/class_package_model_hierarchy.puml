@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontColor #0D47A1
}
skinparam abstract {
    BackgroundColor #FFF8E1
    BorderColor #F57F17
}

title Package Model & Class Hierarchy\n<size:11><i>Composer\\Package — Core domain model for dependency resolution</i></size>

' ─────────────────────────────────────────────
' Interfaces
' ─────────────────────────────────────────────
package "Interfaces" {

    interface PackageInterface {
        +{static} DISPLAY_SOURCE_REF_IF_DEV: int
        +{static} DISPLAY_SOURCE_REF: int
        +{static} DISPLAY_DIST_REF: int
        ..
        +getName(): string
        +getPrettyName(): string
        +getNames(provides: bool): array
        +getId(): int
        +setId(id: int): void
        +isDev(): bool
        +getType(): string
        +getVersion(): string
        +getPrettyVersion(): string
        +getFullPrettyVersion(truncate, displayMode): string
        +getStability(): string
        +getRequires(): array
        +getConflicts(): array
        +getProvides(): array
        +getReplaces(): array
        +getDevRequires(): array
        +getSourceType(): ?string
        +getSourceUrl(): ?string
        +getSourceReference(): ?string
        +getDistType(): ?string
        +getDistUrl(): ?string
        +getDistReference(): ?string
        +getAutoload(): array
        +getRepository(): ?RepositoryInterface
        +setRepository(repo: RepositoryInterface): void
        +getUniqueName(): string
        +__toString(): string
    }

    interface CompletePackageInterface {
        +getScripts(): array
        +getLicense(): array
        +getKeywords(): array
        +getDescription(): ?string
        +getHomepage(): ?string
        +getAuthors(): array
        +getSupport(): array
        +getFunding(): array
        +isAbandoned(): bool
        +getReplacementPackage(): ?string
        +getRepositories(): array
        +getArchiveName(): ?string
        +getArchiveExcludes(): array
    }

    interface RootPackageInterface {
        +getAliases(): array
        +getMinimumStability(): string
        +getStabilityFlags(): array
        +getPreferStable(): bool
        +getConfig(): array
        +getReferences(): array
        +setRequires(array): void
        +setDevRequires(array): void
        +setMinimumStability(string): void
        +setPreferStable(bool): void
        +setConfig(array): void
        +setAliases(array): void
    }

}

' ─────────────────────────────────────────────
' Concrete Hierarchy
' ─────────────────────────────────────────────
package "Concrete Package Hierarchy" {

    abstract class BasePackage {
        +{static} $supportedLinkTypes: array
        +{static} STABILITY_STABLE: int = 0
        +{static} STABILITY_RC: int = 5
        +{static} STABILITY_BETA: int = 10
        +{static} STABILITY_ALPHA: int = 15
        +{static} STABILITY_DEV: int = 20
        +{static} STABILITIES: array
        ..
        +$id: int
        #$name: string
        #$prettyName: string
        #$repository: ?RepositoryInterface
        ..
        +__construct(name: string)
        +getName(): string
        +getPrettyName(): string
        +getNames(provides: bool): array
        +getId(): int
        +setId(id: int): void
        +setRepository(repo: RepositoryInterface): void
        +getRepository(): ?RepositoryInterface
        +isPlatform(): bool
        +getUniqueName(): string
        +equals(package: PackageInterface): bool
        +getStabilityPriority(): int
        +__clone(): void
        +{static} packageNameToRegexp(name, wrap): string
        +{static} packageNamesToRegexp(names, wrap): string
    }

    class Package {
        #$type: string
        #$version: string
        #$prettyVersion: string
        #$stability: string
        #$dev: bool
        #$installationSource: string|null
        #$sourceType: ?string
        #$sourceUrl: ?string
        #$sourceReference: ?string
        #$sourceMirrors: ?array
        #$distType: ?string
        #$distUrl: ?string
        #$distReference: ?string
        #$distSha1Checksum: ?string
        #$distMirrors: ?array
        #$releaseDate: ?DateTimeInterface
        #$extra: array
        #$binaries: array
        #$requires: array
        #$conflicts: array
        #$provides: array
        #$replaces: array
        #$devRequires: array
        #$suggests: array
        #$autoload: array
        #$devAutoload: array
        #$includePaths: array
        #$notificationUrl: ?string
        #$isDefaultBranch: bool
        #$transportOptions: array
        #$phpExt: array|null
        ..
        +__construct(name, version, prettyVersion)
        +replaceVersion(version, prettyVersion): void
        +getSourceUrls(): array
        +getDistUrls(): array
        +setSourceDistReferences(reference: string): void
    }

    class CompletePackage {
        #$repositories: array
        #$license: array
        #$keywords: array
        #$authors: array
        #$description: ?string
        #$homepage: ?string
        #$scripts: array
        #$support: array
        #$funding: array
        #$abandoned: bool|string
        #$archiveName: ?string
        #$archiveExcludes: array
        ..
        +isAbandoned(): bool
        +getReplacementPackage(): ?string
    }

    class RootPackage {
        +{static} DEFAULT_PRETTY_VERSION: string
        ..
        #$minimumStability: string
        #$preferStable: bool
        #$stabilityFlags: array
        #$config: array
        #$references: array
        #$aliases: array
        ..
        +getAliases(): array
        +getMinimumStability(): string
        +getConfig(): array
        +getPreferStable(): bool
        +getStabilityFlags(): array
    }

}

' ─────────────────────────────────────────────
' Alias Hierarchy
' ─────────────────────────────────────────────
package "Alias Package Hierarchy (Decorator/Proxy)" {

    class AliasPackage {
        #$version: string
        #$prettyVersion: string
        #$stability: string
        #$dev: bool
        #$rootPackageAlias: bool
        #$hasSelfVersionRequires: bool
        #$aliasOf: BasePackage
        #$requires: array
        #$devRequires: array
        #$conflicts: array
        #$provides: array
        #$replaces: array
        ..
        +__construct(aliasOf: BasePackage, version, prettyVersion)
        +getAliasOf(): BasePackage
        +setRootPackageAlias(bool): void
        +isRootPackageAlias(): bool
        +hasSelfVersionRequires(): bool
        +replaceSelfVersionDependencies(links, linkType): array
        +__toString(): string
        ' Delegates: getType, getExtra, getSourceType, getSourceUrl,\n' getDistType, getDistUrl, getAutoload, getBinaries, etc. → aliasOf
    }

    class CompleteAliasPackage {
        #$aliasOf: CompletePackage
        ..
        +__construct(aliasOf: CompletePackage, version, prettyVersion)
        ' All CompletePackageInterface methods delegate to aliasOf
    }

    class RootAliasPackage {
        #$aliasOf: RootPackage
        ..
        +__construct(aliasOf: RootPackage, version, prettyVersion)
        +getAliasOf(): RootPackage
        +getAliases(): array
        +getMinimumStability(): string
        +getConfig(): array
        +getPreferStable(): bool
        ' setRequires/setDevRequires/setConflicts:\n' update OWN links AND propagate to aliasOf
        +__clone(): void
    }

}

' ─────────────────────────────────────────────
' External types (abbreviated)
' ─────────────────────────────────────────────
package "External Dependencies" {
    interface RepositoryInterface <<external>>
    class Link <<external>> {
        +getSource(): string
        +getTarget(): string
        +getConstraint(): ConstraintInterface
        +getDescription(): string
    }
}

' ─────────────────────────────────────────────
' Interface Inheritance
' ─────────────────────────────────────────────
CompletePackageInterface --|> PackageInterface
RootPackageInterface --|> CompletePackageInterface

' ─────────────────────────────────────────────
' Concrete Hierarchy — extends / implements
' ─────────────────────────────────────────────
BasePackage ..|> PackageInterface
Package --|> BasePackage
CompletePackage --|> Package
CompletePackage ..|> CompletePackageInterface
RootPackage --|> CompletePackage
RootPackage ..|> RootPackageInterface

' ─────────────────────────────────────────────
' Alias Hierarchy — extends / implements
' ─────────────────────────────────────────────
AliasPackage --|> BasePackage
CompleteAliasPackage --|> AliasPackage
CompleteAliasPackage ..|> CompletePackageInterface
RootAliasPackage --|> CompleteAliasPackage
RootAliasPackage ..|> RootPackageInterface

' ─────────────────────────────────────────────
' Composition / delegation (aliasOf references)
' ─────────────────────────────────────────────
AliasPackage o--> BasePackage : aliasOf\n(delegates getters)
CompleteAliasPackage o--> CompletePackage : aliasOf\n(delegates complete getters)
RootAliasPackage o--> RootPackage : aliasOf\n(delegates + propagates setters)

' ─────────────────────────────────────────────
' Key associations
' ─────────────────────────────────────────────
BasePackage o--> RepositoryInterface : repository
Package ..> Link : uses (requires/\nconflicts/provides/\nreplaces/devRequires)
AliasPackage ..> Link : uses (self.version\nsubstitution)

legend right
  |= Symbol |= Meaning |
  | <&chevron-right> --|> | extends (class/interface) |
  | <&chevron-right> ..|> | implements interface |
  | o--> | composition / delegation (aliasOf) |
  | ..> | dependency (uses) |
  |  o--> | association (optional ref) |
  <b>Design Patterns:</b>
  Decorator/Proxy — AliasPackage wraps a concrete package,
  overriding only version/stability/links.
  Parallel hierarchies mirror each other at every level,
  both terminating at RootPackageInterface.
endlegend

@enduml
