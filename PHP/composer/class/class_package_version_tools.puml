@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Package Version & Stability Tools

' ─────────────────────────────────────────
' External / Semver dependencies
' ─────────────────────────────────────────
package "Composer\\Semver" #EAF0FB {
    class SemverVersionParser <<(E,#AAAAFF) external>> {
        +normalizeBranch(branch: string): string
        +normalize(version: string): string
        +parseConstraints(constraints: string): ConstraintInterface
    }

    interface ConstraintInterface <<(I,#88BBFF) interface>> {
        +matches(provider: ConstraintInterface): bool
        +getPrettyString(): string
    }

    class Intervals <<(E,#AAAAFF) external>> {
        +{static} isSubsetOf(a: ConstraintInterface, b: ConstraintInterface): bool
        +{static} get(constraint: ConstraintInterface): array
    }

    class Semver <<(E,#AAAAFF) external>> {
        +{static} sort(versions: string[]): string[]
    }
}

' ─────────────────────────────────────────
' External support classes
' ─────────────────────────────────────────
package "Composer\\Package" #F0F4EC {
    interface PackageInterface <<(I,#88BBFF) interface>> {
        +getName(): string
        +getVersion(): string
        +getPrettyVersion(): string
        +isDev(): bool
        +getStability(): string
    }

    class BasePackage <<(E,#AAAAFF) external>> {
        +{static} STABILITIES: array
    }
}

package "Composer\\Repository" #F4EDEC {
    class RepositorySet <<(E,#AAAAFF) external>> {
        +findPackages(name: string, constraint: ConstraintInterface): PackageInterface[]
    }

    class PlatformRepository <<(E,#AAAAFF) external>> {
        +getPackages(): PackageInterface[]
    }
}

package "Composer\\Util" #F4F0EC {
    class ProcessExecutor <<(E,#AAAAFF) external>> {
        +execute(command: string, output): int
    }

    class Config <<(E,#AAAAFF) external>> {
    }
}

' ─────────────────────────────────────────
' Core: Composer\Package\Version namespace
' ─────────────────────────────────────────
package "Composer\\Package\\Version" #DDEEFF {

    class VersionParser {
        +{static} DEFAULT_BRANCH_ALIAS: string = "9999999-dev"
        -{static} $constraints: array<string, ConstraintInterface>
        --
        +parseConstraints(constraints: string): ConstraintInterface
        +parseNameVersionPairs(pairs: array): list<array>
        +{static} isUpgrade(normalizedFrom: string, normalizedTo: string): bool
    }

    class VersionSelector {
        -$repositorySet: RepositorySet
        -$platformConstraints: array<string, ConstraintInterface[]>
        -$parser: VersionParser
        --
        +__construct(repositorySet: RepositorySet, platformRepo: PlatformRepository = null)
        +findBestCandidate(packageName: string, targetVersion: string, preferredStability: string, platformFilter, repoSetFlags: int, io: IOInterface, showWarnings): PackageInterface|false
        +findRecommendedRequireVersion(package: PackageInterface): string
        -transformVersion(version: string, prettyVersion: string, stability: string): string
        -getParser(): VersionParser
    }

    class VersionGuesser {
        -$config: Config
        -$process: ProcessExecutor
        -$versionParser: SemverVersionParser
        -$io: IOInterface
        --
        +__construct(config: Config, process: ProcessExecutor, versionParser: SemverVersionParser, io: IOInterface = null)
        +guessVersion(packageConfig: array, path: string): array|null
        +getRootVersionFromEnv(): string
        -guessGitVersion(packageConfig: array, path: string): array
        -guessHgVersion(packageConfig: array, path: string): array|null
        -guessFossilVersion(path: string): array
        -guessSvnVersion(packageConfig: array, path: string): array|null
        -guessFeatureVersion(packageConfig: array, version: string, branches: array, scmCmdline: array, path: string): array
        -versionFromGitTags(path: string): array|null
        -isFeatureBranch(packageConfig: array, branchName: string): bool
        -postprocess(versionData: array): array
    }

    class VersionBumper <<internal>> {
        +bumpRequirement(constraint: ConstraintInterface, package: PackageInterface): string
    }

    class StabilityFilter {
        +{static} isPackageAcceptable(acceptableStabilities: array, stabilityFlags: array, names: array, stability: string): bool
    }
}

' ─────────────────────────────────────────
' Composer\Package\Link
' ─────────────────────────────────────────
package "Composer\\Package" #F0F4EC {
    class Link {
        +{static} TYPE_REQUIRE: string = "requires"
        +{static} TYPE_DEV_REQUIRE: string = "devRequires"
        +{static} TYPE_PROVIDE: string = "provides"
        +{static} TYPE_CONFLICT: string = "conflicts"
        +{static} TYPE_REPLACE: string = "replaces"
        +{static} TYPE_DOES_NOT_REQUIRE: string = "does not require"
        +{static} $TYPES: string[]
        --
        #$source: string
        #$target: string
        #$constraint: ConstraintInterface
        #$description: string
        #$prettyConstraint: string
        --
        +__construct(source: string, target: string, constraint: ConstraintInterface, description: string, prettyConstraint: string = null)
        +getSource(): string
        +getTarget(): string
        +getConstraint(): ConstraintInterface
        +getDescription(): string
        +getPrettyConstraint(): string
        +__toString(): string
        +getPrettyString(sourcePackage: PackageInterface): string
    }
}

' ─────────────────────────────────────────
' Inheritance
' ─────────────────────────────────────────
VersionParser --|> SemverVersionParser : extends

' ─────────────────────────────────────────
' Dependencies
' ─────────────────────────────────────────
VersionSelector ..> VersionParser         : uses (lazy init)
VersionSelector ..> RepositorySet         : findPackages()
VersionSelector ..> PlatformRepository    : reads platform packages
VersionSelector ..> Link                  : reads constraint / description
VersionSelector ..> PackageInterface      : returns / filters

VersionGuesser ..> SemverVersionParser    : normalizeBranch / normalize
VersionGuesser ..> ProcessExecutor        : runs VCS subprocesses
VersionGuesser ..> Config                 : passed to HgDriver

VersionBumper ..> VersionParser           : parseConstraints()
VersionBumper ..> PackageInterface        : getVersion() / isDev()
VersionBumper ..> Intervals               : isSubsetOf() / get()
VersionBumper ..> ConstraintInterface     : manipulates bounds

StabilityFilter ..> BasePackage           : STABILITIES constant

Link *-- ConstraintInterface              : holds

VersionParser ..> Semver                  : Semver::sort() in isUpgrade()
VersionParser ..> ConstraintInterface     : caches & returns

@enduml
