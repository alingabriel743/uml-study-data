@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Plugin System

' ─────────────────────────────────────────────
' External base (out of scope, shown as stub)
' ─────────────────────────────────────────────
package "Composer\\EventDispatcher" #F0F0F0 {
    abstract class Event {
        +getName(): string
        +getArguments(): array
        +getFlags(): array
        +isPropagationStopped(): bool
        +stopPropagation(): void
    }

    interface EventSubscriberInterface {
        +{static} getSubscribedEvents(): array
    }
}

' ─────────────────────────────────────────────
' Capability sub-package
' ─────────────────────────────────────────────
package "Composer\\Plugin\\Capability" {
    interface Capability {
        ' Marker interface
    }

    interface CommandProvider {
        +getCommands(): BaseCommand[]
    }
}

' ─────────────────────────────────────────────
' Core Plugin package
' ─────────────────────────────────────────────
package "Composer\\Plugin" {

    interface PluginInterface {
        +{static} PLUGIN_API_VERSION: string = '2.9.0'
        --
        +activate(Composer $composer, IOInterface $io): void
        +deactivate(Composer $composer, IOInterface $io): void
        +uninstall(Composer $composer, IOInterface $io): void
    }

    interface Capable {
        +getCapabilities(): string[]
    }

    class PluginEvents {
        +{static} INIT: string = 'init'
        +{static} COMMAND: string = 'command'
        +{static} PRE_FILE_DOWNLOAD: string = 'pre-file-download'
        +{static} POST_FILE_DOWNLOAD: string = 'post-file-download'
        +{static} PRE_COMMAND_RUN: string = 'pre-command-run'
        +{static} PRE_POOL_CREATE: string = 'pre-pool-create'
    }

    class PluginManager {
        #Composer $composer
        #IOInterface $io
        #PartialComposer|null $globalComposer
        #VersionParser $versionParser
        #bool $disablePlugins
        #PluginInterface[] $plugins
        #array $registeredPlugins
        -array|null $allowPluginRules
        -array|null $allowGlobalPluginRules
        -bool $runningInGlobalDir
        -array $autoloadedPackages
        -{static} int $classCounter
        --
        +__construct(IOInterface $io, Composer $composer, ?PartialComposer $globalComposer, $disablePlugins)
        +setRunningInGlobalDir(bool): void
        +loadInstalledPlugins(): void
        +deactivateInstalledPlugins(): void
        +getPlugins(): PluginInterface[]
        +getRegisteredPlugins(): string[]
        +getGlobalComposer(): ?PartialComposer
        +registerPackage(PackageInterface, bool, bool): void
        +deactivatePackage(PackageInterface): void
        +uninstallPackage(PackageInterface): void
        +addPlugin(PluginInterface, bool, ?PackageInterface): void
        +removePlugin(PluginInterface): void
        +uninstallPlugin(PluginInterface): void
        +getPluginCapability(PluginInterface, string, array): ?Capability
        +getPluginCapabilities(string, array): Capability[]
        +arePluginsDisabled(string): bool
        +disablePlugins(): void
        +isPluginAllowed(string, bool, bool, bool): bool
        #getPluginApiVersion(): string
        #getCapabilityImplementationClassName(PluginInterface, string): ?string
    }

    ' ── Plugin Events ──

    class PreFileDownloadEvent {
        -HttpDownloader $httpDownloader
        -string $processedUrl
        -string|null $customCacheKey
        -string $type
        -mixed $context
        -array $transportOptions
        --
        +__construct(string $name, HttpDownloader, string $processedUrl, string $type, mixed $context)
        +getHttpDownloader(): HttpDownloader
        +getProcessedUrl(): string
        +setProcessedUrl(string): void
        +getCustomCacheKey(): ?string
        +setCustomCacheKey(?string): void
        +getType(): string
        +getContext(): mixed
        +getTransportOptions(): array
        +setTransportOptions(array): void
    }

    class PostFileDownloadEvent {
        -string|null $fileName
        -string|null $checksum
        -string $url
        -mixed $context
        -string $type
        --
        +__construct(string $name, ?string $fileName, ?string $checksum, string $url, string $type, mixed $context)
        +getFileName(): ?string
        +getChecksum(): ?string
        +getUrl(): string
        +getContext(): mixed
        +getType(): string
        +getPackage(): ?PackageInterface
    }

    class PrePoolCreateEvent {
        -RepositoryInterface[] $repositories
        -Request $request
        -array $acceptableStabilities
        -array $stabilityFlags
        -array $rootAliases
        -array $rootReferences
        -BasePackage[] $packages
        -BasePackage[] $unacceptableFixedPackages
        --
        +__construct(string $name, array $repos, Request, array $stabilities, array $flags, array $aliases, array $refs, array $packages, array $unacceptable)
        +getRepositories(): RepositoryInterface[]
        +getRequest(): Request
        +getAcceptableStabilities(): array
        +getPackages(): BasePackage[]
        +setPackages(BasePackage[]): void
        +getUnacceptableFixedPackages(): BasePackage[]
        +setUnacceptableFixedPackages(BasePackage[]): void
    }

    class CommandEvent {
        -string $commandName
        -InputInterface $input
        -OutputInterface $output
        --
        +__construct(string $name, string $commandName, InputInterface, OutputInterface, array $args, array $flags)
        +getInput(): InputInterface
        +getOutput(): OutputInterface
        +getCommandName(): string
    }

    class PreCommandRunEvent {
        -InputInterface $input
        -string $command
        --
        +__construct(string $name, InputInterface, string $command)
        +getInput(): InputInterface
        +getCommand(): string
    }
}

' ─────────────────────────────────────────────
' Inheritance & Implementation Relationships
' ─────────────────────────────────────────────

' Capability hierarchy
Capability <|-- CommandProvider

' Plugin event inheritance
Event <|-- PreFileDownloadEvent
Event <|-- PostFileDownloadEvent
Event <|-- PrePoolCreateEvent
Event <|-- CommandEvent
Event <|-- PreCommandRunEvent

' ─────────────────────────────────────────────
' PluginManager dependencies
' ─────────────────────────────────────────────

PluginManager "1" o-- "0..*" PluginInterface : manages >
PluginManager ..> Capable : checks instanceof
PluginManager ..> Capability : resolves capabilities
PluginManager ..> EventSubscriberInterface : subscribes/removes listener

' Capable is optionally implemented by PluginInterface implementors
PluginInterface <.. Capable : optionally implemented with

' ─────────────────────────────────────────────
' Notes
' ─────────────────────────────────────────────

note top of PluginInterface
  PLUGIN_API_VERSION = '2.9.0'
  Plugins must require composer-plugin-api
  at this version.
end note

note right of Capable
  Plugins implementing Capable
  advertise capability class names
  keyed by capability interface FQCN
  (e.g. CommandProvider::class).
end note

note bottom of PluginManager
  Plugin lifecycle:
  loadInstalledPlugins() → addPlugin() → plugin.activate()
  removePlugin() → plugin.deactivate()
  uninstallPlugin() → plugin.uninstall()
  allow-plugins config gates all loading.
end note

note right of PluginEvents
  Constants-only event name registry.
  Maps event names to their event classes.
end note

note bottom of PostFileDownloadEvent
  getPackage() deprecated since Composer 2.1.
  Use getContext() instead.
end note

@enduml
