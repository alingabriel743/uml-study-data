@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
}

title ComposerRepository, VcsRepository & Specialised Repos\n<size:11>Composer\\Repository</size>

' ─────────────────────────────────────────────
' INTERFACES
' ─────────────────────────────────────────────
package "Interfaces" {

    interface RepositoryInterface {
        + getRepoName(): string
        + findPackage(string $name, $constraint): ?BasePackage
        + findPackages(string $name, $constraint): array
        + loadPackages(array $packageNameMap, ...): array
        + search(string $query, int $mode, ?string $type): array
        + hasPackage(PackageInterface $package): bool
        + getPackages(): array
        + getProviders(string $packageName): array
        + count(): int
    }

    interface ConfigurableRepositoryInterface {
        + getRepoConfig(): array
    }

    interface AdvisoryProviderInterface {
        + hasSecurityAdvisories(): bool
        + getSecurityAdvisories(array $packageConstraintMap, bool $allowPartialAdvisories): array
    }

    interface FilterListProviderInterface {
        + hasFilter(): bool
        + getFilter(array $packageConstraintMap): array
    }

}

' ─────────────────────────────────────────────
' BASE CLASS
' ─────────────────────────────────────────────
package "Base" {

    class ArrayRepository {
        # packages: ?array<BasePackage>
        # packageMap: ?array<BasePackage>
        --
        + __construct(array $packages = [])
        + getRepoName(): string
        + addPackage(PackageInterface $package): void
        + removePackage(PackageInterface $package): void
        + getPackages(): array
        + findPackage(string $name, $constraint): ?BasePackage
        + findPackages(string $name, $constraint): array
        + loadPackages(array $packageNameMap, ...): array
        + search(string $query, int $mode, ?string $type): array
        + hasPackage(PackageInterface $package): bool
        + getProviders(string $packageName): array
        + count(): int
        # initialize(): void
        # createAliasPackage(BasePackage $package, ...): AliasPackage
    }

    class LockArrayRepository {
        + getRepoName(): string
    }

    note bottom of LockArrayRepository
      Uses CanonicalPackagesTrait.
      Semantically marks lock-file source.
    end note

}

' ─────────────────────────────────────────────
' CONCRETE REPOSITORIES
' ─────────────────────────────────────────────
package "Composer\\Repository" {

    class ComposerRepository {
        - repoConfig: array
        - options: array
        - url: string
        - baseUrl: string
        - io: IOInterface
        - httpDownloader: HttpDownloader
        - loop: Loop
        # cache: Cache
        # notifyUrl: ?string
        # searchUrl: ?string
        # providersApiUrl: ?string
        # hasProviders: bool
        # providersUrl: ?string
        # lazyProvidersUrl: ?string
        # listUrl: ?string
        # loader: ArrayLoader
        - eventDispatcher: ?EventDispatcher
        - allowSslDowngrade: bool
        - degradedMode: bool
        - hasPartialPackages: bool
        - versionParser: VersionParser
        - securityAdvisoryConfig: ?array
        - filterConfig: ?array
        --
        + __construct(array $repoConfig, IOInterface $io, Config $config, HttpDownloader $httpDownloader, ?EventDispatcher $eventDispatcher)
        + getRepoName(): string
        + getRepoConfig(): array
        + findPackage(string $name, $constraint): ?BasePackage
        + findPackages(string $name, $constraint): array
        + getPackages(): array
        + getPackageNames(?string $packageFilter): array
        + loadPackages(array $packageNameMap, ...): array
        + search(string $query, int $mode, ?string $type): array
        + hasSecurityAdvisories(): bool
        + getSecurityAdvisories(array $packageConstraintMap, bool $allowPartialAdvisories): array
        + hasFilter(): bool
        + getFilter(array $packageConstraintMap): array
        + getProviders(string $packageName): array
        + addPackage(PackageInterface $package): void
        # initialize(): void
        # loadRootServerFile(?int $rootMaxAge): array
        # configurePackageTransportOptions(PackageInterface $package): void
        - whatProvides(string $name, ?array $acceptableStabilities, ...): array
        - loadAsyncPackages(array $packageNames, ...): array
        - fetchFile(string $filename, ?string $cacheKey, ...): array
        - createPackages(array $packages, ?string $source): array
        - loadDataFromServer(): array
        - loadProviderListings(array $data): void
        - initializePartialPackages(): void
    }

    class VcsRepository {
        # url: string
        # packageName: ?string
        # io: IOInterface
        # config: Config
        # versionParser: VersionParser
        # type: string
        # loader: ?LoaderInterface
        # repoConfig: array
        # httpDownloader: HttpDownloader
        # processExecutor: ProcessExecutor
        # isVerbose: bool
        # isVeryVerbose: bool
        # branchErrorOccurred: bool
        - drivers: array<string, class-string<VcsDriverInterface>>
        - driver: ?VcsDriverInterface
        - versionCache: ?VersionCacheInterface
        - emptyReferences: list<string>
        - versionTransportExceptions: array
        --
        + __construct(array $repoConfig, IOInterface $io, Config $config, HttpDownloader $httpDownloader, ?EventDispatcher $dispatcher, ?ProcessExecutor $process, ?array $drivers, ?VersionCacheInterface $versionCache)
        + getRepoName(): string
        + getRepoConfig(): array
        + setLoader(LoaderInterface $loader): void
        + getDriver(): ?VcsDriverInterface
        + hadInvalidBranches(): bool
        + getEmptyReferences(): array
        + getVersionTransportExceptions(): array
        # initialize(): void
        # preProcess(VcsDriverInterface $driver, array $data, string $identifier): array
        - validateBranch(string $branch): string|false
        - validateTag(string $version): string|false
        - shouldRethrowTransportException(TransportException $e): bool
    }

    class ArtifactRepository {
        # loader: LoaderInterface
        # lookup: string
        # repoConfig: array
        - io: IOInterface
        --
        + __construct(array $repoConfig, IOInterface $io)
        + getRepoName(): string
        + getRepoConfig(): array
        # initialize(): void
        - scanDirectory(string $path): void
        - getComposerInformation(\\SplFileInfo $file): ?BasePackage
    }

    class PathRepository {
        - loader: ArrayLoader
        - versionGuesser: VersionGuesser
        - url: string
        - repoConfig: array
        - process: ProcessExecutor
        - options: array
        --
        + __construct(array $repoConfig, IOInterface $io, Config $config, ?HttpDownloader $httpDownloader, ?EventDispatcher $dispatcher, ?ProcessExecutor $process)
        + getRepoName(): string
        + getRepoConfig(): array
        # initialize(): void
        - getUrlMatches(): array
    }

    class FilterRepository {
        - only: ?string
        - exclude: ?non-empty-string
        - canonical: bool
        - repo: RepositoryInterface
        --
        + __construct(RepositoryInterface $repo, array $options)
        + getRepoName(): string
        + getRepository(): RepositoryInterface
        + hasPackage(PackageInterface $package): bool
        + findPackage($name, $constraint): ?BasePackage
        + findPackages($name, $constraint): array
        + loadPackages(array $packageNameMap, ...): array
        + search(string $query, int $mode, ?string $type): array
        + getPackages(): array
        + getProviders(string $packageName): array
        + count(): int
        + hasSecurityAdvisories(): bool
        + getSecurityAdvisories(array $packageConstraintMap, bool $allowPartialAdvisories): array
        - isAllowed(string $name): bool
    }

}

' ─────────────────────────────────────────────
' FACTORY & UTILITIES
' ─────────────────────────────────────────────
package "Factory & Utils" {

    class RepositoryFactory {
        + {static} configFromString(IOInterface $io, Config $config, string $repository, bool $allowFilesystem): array
        + {static} fromString(IOInterface $io, Config $config, string $repository, bool $allowFilesystem, ?RepositoryManager $rm): RepositoryInterface
        + {static} createRepo(IOInterface $io, Config $config, array $repoConfig, ?RepositoryManager $rm): RepositoryInterface
        + {static} defaultRepos(?IOInterface $io, ?Config $config, ?RepositoryManager $rm): RepositoryInterface[]
        + {static} manager(IOInterface $io, Config $config, ?HttpDownloader $httpDownloader, ?EventDispatcher $eventDispatcher, ?ProcessExecutor $process): RepositoryManager
        + {static} generateRepositoryName($index, array $repo, array $existingRepos): string
        - {static} createRepos(RepositoryManager $rm, array $repoConfigs): RepositoryInterface[]
    }

    class RepositoryUtils {
        + {static} filterRequiredPackages(array $packages, PackageInterface $requirer, bool $includeRequireDev, array $bucket): array
        + {static} flattenRepositories(RepositoryInterface $repo, bool $unwrapFilterRepos): RepositoryInterface[]
    }

}

' ─────────────────────────────────────────────
' EXTERNAL COLLABORATORS (simplified)
' ─────────────────────────────────────────────
package "External Collaborators" {
    interface VcsDriverInterface {
        + initialize(): void
        + getRootIdentifier(): string
        + getBranches(): array
        + getTags(): array
        + getComposerInformation(string $identifier): ?array
    }

    class HttpDownloader <<external>>
    class Cache <<external>>
    class VersionGuesser <<external>>
    class ProcessExecutor <<external>>
    class EventDispatcher <<external>>
}

' ─────────────────────────────────────────────
' INHERITANCE
' ─────────────────────────────────────────────
ArrayRepository      ..|> RepositoryInterface

ComposerRepository   --|> ArrayRepository
VcsRepository        --|> ArrayRepository
ArtifactRepository   --|> ArrayRepository
PathRepository       --|> ArrayRepository
LockArrayRepository  --|> ArrayRepository

' ─────────────────────────────────────────────
' INTERFACE IMPLEMENTATIONS
' ─────────────────────────────────────────────
ComposerRepository   ..|> ConfigurableRepositoryInterface
ComposerRepository   ..|> AdvisoryProviderInterface
ComposerRepository   ..|> FilterListProviderInterface

VcsRepository        ..|> ConfigurableRepositoryInterface
ArtifactRepository   ..|> ConfigurableRepositoryInterface
PathRepository       ..|> ConfigurableRepositoryInterface

FilterRepository     ..|> RepositoryInterface
FilterRepository     ..|> AdvisoryProviderInterface

' ─────────────────────────────────────────────
' COMPOSITION / DEPENDENCIES
' ─────────────────────────────────────────────
' FilterRepository decorates RepositoryInterface
FilterRepository     o-- RepositoryInterface : wraps (Decorator)

' VcsRepository uses VcsDriverInterface (Strategy)
VcsRepository        o-- VcsDriverInterface  : driver (Strategy)

' ComposerRepository key dependencies
ComposerRepository   *-- HttpDownloader      : httpDownloader
ComposerRepository   *-- Cache               : cache
ComposerRepository   *-- EventDispatcher     : eventDispatcher

' PathRepository key dependencies
PathRepository       *-- VersionGuesser      : versionGuesser
PathRepository       *-- ProcessExecutor     : process

' VcsRepository key dependencies
VcsRepository        *-- ProcessExecutor     : processExecutor
VcsRepository        *-- HttpDownloader      : httpDownloader

' Factory creates repos
RepositoryFactory    ..> ComposerRepository  : creates
RepositoryFactory    ..> VcsRepository       : creates
RepositoryFactory    ..> ArtifactRepository  : creates
RepositoryFactory    ..> PathRepository      : creates

' RepositoryUtils uses FilterRepository
RepositoryUtils      ..> FilterRepository    : unwraps

' ─────────────────────────────────────────────
' NOTES
' ─────────────────────────────────────────────
note right of ComposerRepository
  Supports Packagist v1 (providers)
  and v2 (lazy-providers / metadata-url).
  whatProvides() is the core lazy-loader
  used by the dependency solver.
end note

note right of VcsRepository
  Strategy pattern: selects VcsDriverInterface
  implementation at runtime.
  Drivers: GitHub, GitLab, Bitbucket,
  Git, Hg, Svn, Perforce, Fossil, Forgejo.
end note

note right of FilterRepository
  Decorator pattern. Delegates all calls
  to inner $repo after filtering by
  'only' or 'exclude' regexp.
  canonical=false hides packages
  from solver as canonical source.
end note

note right of PathRepository
  Supports glob URL patterns.
  Sets dist.type='path' for symlink/copy installs.
  Detects COMPOSER_ROOT_VERSION.
end note

note right of ArtifactRepository
  Scans local directory recursively for
  .zip / .tar / .gz / .tgz archives and
  extracts composer.json metadata.
end note

@enduml
