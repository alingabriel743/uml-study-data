@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Repository Core & Implementations

package "PHP SPL" {
    interface Countable {
        +count(): int
    }
}

package "Composer\\Repository" {

    interface RepositoryInterface {
        +{static} SEARCH_FULLTEXT: int = 0
        +{static} SEARCH_NAME: int = 1
        +{static} SEARCH_VENDOR: int = 2
        --
        +hasPackage(PackageInterface): bool
        +findPackage(string $name, $constraint): BasePackage
        +findPackages(string $name, $constraint=null): BasePackage[]
        +getPackages(): BasePackage[]
        +loadPackages(array, array, array, array): array
        +search(string $query, int $mode=0, ?string $type=null): array
        +getProviders(string $packageName): array
        +getRepoName(): string
        +count(): int
    }

    interface WritableRepositoryInterface {
        +write(bool $devMode, InstallationManager): void
        +addPackage(PackageInterface): void
        +removePackage(PackageInterface): void
        +getCanonicalPackages(): PackageInterface[]
        +reload(): void
        +setDevPackageNames(array): void
        +getDevPackageNames(): string[]
    }

    interface InstalledRepositoryInterface {
        +getDevMode(): bool|null
        +isFresh(): bool
    }

    class ArrayRepository {
        #$packages: BasePackage[]
        #$packageMap: BasePackage[]
        --
        +__construct(array $packages=[])
        +addPackage(PackageInterface): void
        +removePackage(PackageInterface): void
        +getPackages(): BasePackage[]
        +loadPackages(array, array, array, array): array
        +findPackage(string, $constraint): BasePackage
        +findPackages(string, $constraint=null): BasePackage[]
        +search(string, int, ?string): array
        +hasPackage(PackageInterface): bool
        +getProviders(string): array
        +createAliasPackage(BasePackage, string, string): AliasPackage
        #initialize(): void
        +count(): int
        +getRepoName(): string
    }

    class WritableArrayRepository {
        #$devPackageNames: string[]
        --
        +getDevMode(): bool|null
        +setDevPackageNames(array): void
        +getDevPackageNames(): string[]
        +write(bool, InstallationManager): void
        +reload(): void
    }

    class PlatformRepository {
        -{static} $lastSeenPlatformPhp: ?string
        -$versionParser: VersionParser
        -$overrides: array
        -$disabledPackages: array
        -$runtime: Runtime
        -$hhvmDetector: HhvmDetector
        --
        +__construct(array $packages=[], array $overrides=[], ?Runtime, ?HhvmDetector)
        #initialize(): void
        +addPackage(PackageInterface): void
        +isPlatformPackageDisabled(string): bool
        +getDisabledPackages(): array
        +{static} isPlatformPackage(string): bool
        +{static} getPlatformPhpVersion(): ?string
        +search(string, int, ?string): array
        -addExtension(string, string): void
        -addLibrary(array&, string, ?string, ...): void
    }

    class CompositeRepository {
        -$repositories: RepositoryInterface[]
        --
        +__construct(RepositoryInterface[] $repositories)
        +addRepository(RepositoryInterface): void
        +getRepositories(): RepositoryInterface[]
        +hasPackage(PackageInterface): bool
        +findPackage($name, $constraint): BasePackage
        +findPackages($name, $constraint=null): array
        +loadPackages(array, array, array, array): array
        +search(string, int, ?string): array
        +getPackages(): array
        +getProviders(string): array
        +removePackage(PackageInterface): void
        +count(): int
        +getRepoName(): string
    }

    class InstalledRepository {
        --
        +findPackagesWithReplacersAndProviders(string $name, $constraint=null): BasePackage[]
        +getDependents($needle, ?ConstraintInterface, bool $invert=false, bool $recurse=true): array
        +getRepoName(): string
        +addRepository(RepositoryInterface): void
    }

    class FilesystemRepository {
        #$file: JsonFile
        -$dumpVersions: bool
        -$rootPackage: ?RootPackageInterface
        -$filesystem: Filesystem
        -$devMode: bool|null
        --
        +__construct(JsonFile, bool $dumpVersions=false, ?RootPackageInterface, ?Filesystem)
        #initialize(): void
        +reload(): void
        +write(bool $devMode, InstallationManager): void
        +getDevMode(): bool|null
        +{static} safelyLoadInstalledVersions(string $path): bool
        -generateInstalledVersions(InstallationManager, ...): array
        -dumpToPhpCode(array, int): string
    }

    class RepositoryManager {
        -$localRepository: InstalledRepositoryInterface
        -$repositories: RepositoryInterface[]
        -$repositoryClasses: array
        -$io: IOInterface
        -$config: Config
        -$httpDownloader: HttpDownloader
        -$eventDispatcher: ?EventDispatcher
        -$process: ProcessExecutor
        --
        +__construct(IOInterface, Config, HttpDownloader, ?EventDispatcher, ?ProcessExecutor)
        +findPackage(string $name, $constraint): PackageInterface
        +findPackages(string $name, $constraint): PackageInterface[]
        +addRepository(RepositoryInterface): void
        +prependRepository(RepositoryInterface): void
        +createRepository(string $type, array $config, ?string $name=null): RepositoryInterface
        +setRepositoryClass(string $type, string $class): void
        +getRepositories(): RepositoryInterface[]
        +setLocalRepository(InstalledRepositoryInterface): void
        +getLocalRepository(): InstalledRepositoryInterface
        +getHttpDownloader(): HttpDownloader
    }

    class RepositorySet {
        +{static} ALLOW_UNACCEPTABLE_STABILITIES: int = 1
        +{static} ALLOW_SHADOWED_REPOSITORIES: int = 2
        --
        -$rootAliases: array
        -$rootReferences: array
        -$repositories: RepositoryInterface[]
        -$acceptableStabilities: array
        -$stabilityFlags: array
        -$rootRequires: array
        -$temporaryConstraints: array
        -$locked: bool
        -$allowInstalledRepositories: bool
        --
        +__construct(string $minimumStability='stable', array $stabilityFlags=[], ...)
        +addRepository(RepositoryInterface): void
        +allowInstalledRepositories(bool): void
        +getRootRequires(): array
        +findPackages(string $name, ?ConstraintInterface, int $flags=0): BasePackage[]
        +getProviders(string $packageName): array
        +isPackageAcceptable(array $names, string $stability): bool
        +createPool(Request, IOInterface, ...): Pool
        +createPoolWithAllPackages(): Pool
        +createPoolForPackage(string, ?LockArrayRepository): Pool
    }

}

' ── Interface hierarchy ──────────────────────────────────────────
RepositoryInterface ..|> Countable
WritableRepositoryInterface --|> RepositoryInterface
InstalledRepositoryInterface --|> WritableRepositoryInterface

' ── Class → Interface implementations ───────────────────────────
ArrayRepository ..|> RepositoryInterface
WritableArrayRepository ..|> WritableRepositoryInterface
CompositeRepository ..|> RepositoryInterface

' ── Inheritance chain ────────────────────────────────────────────
WritableArrayRepository --|> ArrayRepository
PlatformRepository --|> ArrayRepository
FilesystemRepository --|> WritableArrayRepository
InstalledRepository --|> CompositeRepository

' ── Aggregations ─────────────────────────────────────────────────
CompositeRepository o-- RepositoryInterface : "delegates to\n  repositories[]"
RepositoryManager o-- RepositoryInterface : "manages\n  repositories[]"
RepositoryManager o-- InstalledRepositoryInterface : "localRepository"
RepositorySet o-- RepositoryInterface : "resolves\n  repositories[]"

' ── Key dependencies ─────────────────────────────────────────────
FilesystemRepository ..> JsonFile : uses
PlatformRepository ..> Runtime : uses
PlatformRepository ..> HhvmDetector : uses
RepositorySet ..> Pool : creates

@enduml
