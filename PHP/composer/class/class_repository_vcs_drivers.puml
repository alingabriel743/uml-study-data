@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}
skinparam abstract {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
}

title VCS Drivers — Composer\\Repository\\Vcs

' ─────────────────────────────────────────────
' Interface
' ─────────────────────────────────────────────
interface VcsDriverInterface {
    +initialize(): void
    +getComposerInformation(identifier: string): ?array
    +getFileContent(file: string, identifier: string): ?string
    +getChangeDate(identifier: string): ?DateTimeImmutable
    +getRootIdentifier(): string
    +getBranches(): array
    +getTags(): array
    +getDist(identifier: string): ?array
    +getSource(identifier: string): array
    +getUrl(): string
    +hasComposerFile(identifier: string): bool
    +cleanup(): void
    +{static} supports(io, config, url, deep): bool
}

' ─────────────────────────────────────────────
' Abstract base driver
' ─────────────────────────────────────────────
abstract class VcsDriver {
    #url: string
    #originUrl: string
    #repoConfig: array
    #io: IOInterface
    #config: Config
    #process: ProcessExecutor
    #httpDownloader: HttpDownloader
    #infoCache: array
    #cache: ?Cache
    --
    +{final} __construct(repoConfig, io, config, httpDownloader, process)
    +getComposerInformation(identifier: string): ?array
    +hasComposerFile(identifier: string): bool
    +cleanup(): void
    #shouldCache(identifier: string): bool
    #getBaseComposerInformation(identifier: string): ?array
    #getScheme(): string
    #getContents(url: string): Response
}

' ─────────────────────────────────────────────
' Git-based Drivers package
' ─────────────────────────────────────────────
package "Git-Based Drivers" {

    class GitDriver {
        #tags: array
        #branches: array
        #rootIdentifier: string
        #repoDir: string
        --
        +initialize(): void
        +getRootIdentifier(): string
        +getUrl(): string
        +getSource(identifier: string): array
        +getDist(identifier: string): ?array
        +getFileContent(file, identifier): ?string
        +getChangeDate(identifier): ?DateTimeImmutable
        +getTags(): array
        +getBranches(): array
        +{static} supports(io, config, url, deep): bool
    }

    class GitHubDriver {
        #owner: string
        #repository: string
        #rootIdentifier: string
        #repoData: array
        #hasIssues: bool
        #isPrivate: bool
        -isArchived: bool
        -fundingInfo: array|false|null
        -allowGitFallback: bool
        #gitDriver: ?GitDriver
        --
        +initialize(): void
        +getRootIdentifier(): string
        +getUrl(): string
        +getSource(identifier: string): array
        +getDist(identifier: string): ?array
        +getComposerInformation(identifier): ?array
        +getTags(): array
        +getBranches(): array
        #fetchRootIdentifier(): void
        #attemptCloneFallback(?e): bool
        #setupGitDriver(url: string): void
        #generateSshUrl(): string
        +{static} supports(io, config, url, deep): bool
    }

    class GitLabDriver {
        -scheme: string
        -namespace: string
        -repository: string
        -project: array
        -commits: array
        -tags: array
        -branches: array
        #gitDriver: ?GitDriver
        -isPrivate: bool
        -hasNonstandardOrigin: bool
        --
        +initialize(): void
        +getComposerInformation(identifier): ?array
        +getRootIdentifier(): string
        +getUrl(): string
        +getDist(identifier): ?array
        +getSource(identifier): array
        +getTags(): array
        +getBranches(): array
        +getApiUrl(): string
        #fetchProject(): void
        #attemptCloneFallback(): bool
        #setupGitDriver(url: string): void
        +{static} supports(io, config, url, deep): bool
    }

    class GitBitbucketDriver {
        #owner: string
        #repository: string
        -hasIssues: bool
        -rootIdentifier: string
        -tags: array
        -branches: array
        -repoData: array
        #fallbackDriver: ?VcsDriverInterface
        -vcsType: string
        --
        +initialize(): void
        +getUrl(): string
        +getComposerInformation(identifier): ?array
        +getSource(identifier): array
        +getDist(identifier): ?array
        +getTags(): array
        +getBranches(): array
        +getRootIdentifier(): string
        #getRepoData(): bool
        #attemptCloneFallback(): bool
        #setupFallbackDriver(url: string): void
        +{static} supports(io, config, url, deep): bool
    }

    class ForgejoDriver {
        -forgejoUrl: string
        -repositoryData: array
        #gitDriver: ?GitDriver
        -tags: array
        -branches: array
        --
        +initialize(): void
        +getFileContent(file, identifier): ?string
        +getChangeDate(identifier): ?DateTimeImmutable
        +getRootIdentifier(): string
        +getBranches(): array
        +getTags(): array
        +getDist(identifier): ?array
        +getComposerInformation(identifier): ?array
        +getSource(identifier): array
        +getUrl(): string
        #setupGitDriver(url: string): void
        -fetchRepositoryData(): void
        #attemptCloneFallback(): bool
        +{static} supports(io, config, url, deep): bool
    }

}

' ─────────────────────────────────────────────
' Non-Git Drivers package
' ─────────────────────────────────────────────
package "Non-Git Drivers" {

    class SvnDriver {
        #baseUrl: string
        #tags: array
        #branches: array
        #rootIdentifier: ?string
        #trunkPath: string|false
        #branchesPath: string
        #tagsPath: string
        #packagePath: string
        #cacheCredentials: bool
        -util: SvnUtil
        --
        +initialize(): void
        +getRootIdentifier(): string
        +getUrl(): string
        +getSource(identifier): array
        +getDist(identifier): ?array
        +getComposerInformation(identifier): ?array
        +getFileContent(file, identifier): ?string
        +getChangeDate(identifier): ?DateTimeImmutable
        +getTags(): array
        +getBranches(): array
        #shouldCache(identifier): bool
        #execute(command, url): string
        +{static} supports(io, config, url, deep): bool
    }

    class HgDriver {
        #tags: array
        #branches: array
        #rootIdentifier: string
        #repoDir: string
        --
        +initialize(): void
        +getRootIdentifier(): string
        +getUrl(): string
        +getSource(identifier): array
        +getDist(identifier): ?array
        +getFileContent(file, identifier): ?string
        +getChangeDate(identifier): ?DateTimeImmutable
        +getTags(): array
        +getBranches(): array
        +{static} supports(io, config, url, deep): bool
    }

    class FossilDriver {
        #tags: array
        #branches: array
        #rootIdentifier: ?string
        #repoFile: ?string
        #checkoutDir: string
        --
        +initialize(): void
        +getRootIdentifier(): string
        +getUrl(): string
        +getSource(identifier): array
        +getDist(identifier): ?array
        +getFileContent(file, identifier): ?string
        +getChangeDate(identifier): ?DateTimeImmutable
        +getTags(): array
        +getBranches(): array
        #checkFossil(): void
        #updateLocalRepo(): void
        +{static} supports(io, config, url, deep): bool
    }

    class PerforceDriver {
        #depot: string
        #branch: string
        #perforce: ?Perforce
        --
        +initialize(): void
        -initPerforce(repoConfig: array): void
        +getFileContent(file, identifier): ?string
        +getChangeDate(identifier): ?DateTimeImmutable
        +getRootIdentifier(): string
        +getBranches(): array
        +getTags(): array
        +getDist(identifier): ?array
        +getSource(identifier): array
        +getUrl(): string
        +hasComposerFile(identifier): bool
        +getContents(url): Response
        +cleanup(): void
        +getDepot(): string
        +getBranch(): string
        +{static} supports(io, config, url, deep): bool
    }

}

' ─────────────────────────────────────────────
' External Utilities (simplified)
' ─────────────────────────────────────────────
package "Composer\\Util (External)" {
    class HttpDownloader <<utility>>
    class ProcessExecutor <<utility>>
    class Cache <<utility>>
    class GitUtil <<utility>>
    class GitHub <<utility>>
    class GitLab <<utility>>
    class SvnUtil <<utility>>
    class Perforce <<utility>>
    class Forgejo <<utility>>
}

' ─────────────────────────────────────────────
' Inheritance hierarchy
' ─────────────────────────────────────────────
VcsDriver          ..|> VcsDriverInterface
GitDriver          --|> VcsDriver
GitHubDriver       --|> VcsDriver
GitLabDriver       --|> VcsDriver
GitBitbucketDriver --|> VcsDriver
ForgejoDriver      --|> VcsDriver
SvnDriver          --|> VcsDriver
HgDriver           --|> VcsDriver
FossilDriver       --|> VcsDriver
PerforceDriver     --|> VcsDriver

' ─────────────────────────────────────────────
' Git fallback compositions
' ─────────────────────────────────────────────
GitHubDriver       *-- GitDriver       : gitDriver\n(fallback)
GitLabDriver       *-- GitDriver       : gitDriver\n(fallback)
GitBitbucketDriver *-- GitDriver       : fallbackDriver\n(fallback)
ForgejoDriver      *-- GitDriver       : gitDriver\n(fallback)

' ─────────────────────────────────────────────
' VcsDriver base utility dependencies
' ─────────────────────────────────────────────
VcsDriver ..> HttpDownloader  : uses
VcsDriver ..> ProcessExecutor : uses
VcsDriver ..> Cache           : uses

' ─────────────────────────────────────────────
' Driver-specific utility dependencies
' ─────────────────────────────────────────────
GitDriver    ..> GitUtil    : uses
GitHubDriver ..> GitHub     : uses
GitLabDriver ..> GitLab     : uses
SvnDriver    ..> SvnUtil    : uses
PerforceDriver ..> Perforce : uses
ForgejoDriver  ..> Forgejo  : uses

@enduml
