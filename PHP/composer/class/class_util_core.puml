@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Utility — Core Utilities (Composer\\Util)

' ─────────────── External dependencies ───────────────
interface IOInterface <<Composer\\IO>> {
    +isInteractive(): bool
    +write(string $text): void
    +ask(string $question, mixed $default): mixed
}

class Config <<Composer\\Config>> {
    +get(string $key): mixed
    +has(string $key): bool
}

class CurlDownloader <<Composer\\Util\\Http>> {
    +get(string $url, array $options): Response
    +add(string $url, array $options): PromiseInterface
}

class RemoteFilesystem <<Composer\\Util>> {
    +getContents(string $originUrl, string $fileUrl, ...): string
}

' ─────────────── Core Utility classes ───────────────
package "Composer\\Util" {

    class Filesystem {
        -processExecutor: ?ProcessExecutor
        --
        +__construct(?ProcessExecutor $executor = null)
        +remove(string $file): bool
        +removeDirectory(string $directory): bool
        +removeDirectoryAsync(string $directory): PromiseInterface
        +removeDirectoryPhp(string $directory): bool
        +ensureDirectoryExists(string $directory): void
        +copyThenRemove(string $source, string $target): void
        +copy(string $source, string $target): bool
        +rename(string $source, string $target): void
        +relativeSymlink(string $target, string $link): bool
        +normalizePath(string $path): string
        +isAbsolutePath(string $path): bool
        +size(string $path): int
        +isJunction(string $junction): bool
        +junction(string $target, string $junction): void
        +{static} trimTrailingSlash(string $path): string
        +{static} isLocalPath(string $path): bool
        +{static} isReadable(string $path): bool
        #directorySize(string $directory): int
        #getProcess(): ProcessExecutor
    }

    class ProcessExecutor {
        #{static} timeout: int = 300
        #captureOutput: bool
        #errorOutput: string
        #io: ?IOInterface
        -jobs: array
        -maxJobs: int = 10
        -runningJobs: int
        -allowAsync: bool
        ..Status Constants..
        STATUS_QUEUED = 1
        STATUS_STARTED = 2
        STATUS_COMPLETED = 3
        STATUS_FAILED = 4
        STATUS_ABORTED = 5
        --
        +__construct(?IOInterface $io = null)
        +execute(command, mixed &$output, ?string $cwd): int
        +executeTty(command, ?string $cwd): int
        +executeAsync(command, ?string $cwd): PromiseInterface
        +wait(?int $index): void
        +countActiveJobs(?int $index): int
        +enableAsync(): void
        +setMaxJobs(int $maxJobs): void
        +getErrorOutput(): string
        +splitLines(?string $output): string[]
        +requiresGitDirEnv(array|string $command): bool
        +{static} getTimeout(): int
        +{static} setTimeout(int $timeout): void
        +{static} escape(string|false|null $argument): string
    }

    class HttpDownloader {
        -io: IOInterface
        -config: Config
        -jobs: array
        -maxJobs: int = 12
        -runningJobs: int
        -curl: ?CurlDownloader
        -rfs: ?RemoteFilesystem
        -allowAsync: bool
        ..Status Constants..
        STATUS_QUEUED = 1
        STATUS_STARTED = 2
        STATUS_COMPLETED = 3
        STATUS_FAILED = 4
        STATUS_ABORTED = 5
        --
        +__construct(IOInterface $io, Config $config, array $options, bool $disableTls)
        +get(string $url, array $options): Response
        +add(string $url, array $options): PromiseInterface
        +copy(string $url, string $to, array $options): Response
        +addCopy(string $url, string $to, array $options): PromiseInterface
        +getOptions(): array
        +setOptions(array $options): void
        +wait(?int $index): void
        +countActiveJobs(?int $index): int
        +enableAsync(): void
        +{static} isCurlEnabled(): bool
        +{static} outputWarnings(IOInterface $io, string $url, array $data): void
        +{static} getExceptionHints(Throwable $e): ?array
    }

    class AuthHelper {
        #io: IOInterface
        #config: Config
        -displayedOriginAuthentications: array
        -bitbucketRetry: array
        --
        +__construct(IOInterface $io, Config $config)
        +storeAuth(string $origin, string|bool $storeAuth): void
        +promptAuthIfNeeded(string $url, string $origin, int $statusCode,\n  ?string $reason, array $headers, int $retryCount,\n  ?string $responseBody): array
        +addAuthenticationOptions(array $options, string $origin, string $url): array
        +isPublicBitBucketDownload(string $urlToBitBucketFile): bool
    }

    class Git {
        -{static} version: string|false|null
        #io: IOInterface
        #config: Config
        #process: ProcessExecutor
        #filesystem: Filesystem
        #httpDownloader: HttpDownloader
        --
        +__construct(IOInterface $io, Config $config,\n  ProcessExecutor $process, Filesystem $fs)
        +setHttpDownloader(HttpDownloader $httpDownloader): void
        +runCommands(array $commands, string $url,\n  ?string $cwd, bool $initialClone, ...): void
        +syncMirror(string $url, string $dir): bool
        +fetchRefOrSyncMirror(string $url, string $dir,\n  string $ref, ?string $prettyVersion): bool
        +getMirrorDefaultBranch(string $url, string $dir, ...): ?string
        +{static} cleanEnv(?ProcessExecutor $process): void
        +{static} getVersion(ProcessExecutor $process): ?string
        +{static} getGitHubDomainsRegex(Config $config): string
        +{static} getGitLabDomainsRegex(Config $config): string
        +{static} checkForRepoOwnershipError(string $output, ...): void
        +{static} buildRevListCommand(ProcessExecutor $process, array $arguments): array
    }

    class GitHub {
        #io: IOInterface
        #config: Config
        #process: ProcessExecutor
        #httpDownloader: HttpDownloader
        ..Constants..
        GITHUB_TOKEN_REGEX
        --
        +__construct(IOInterface $io, Config $config,\n  ?ProcessExecutor $process, ?HttpDownloader $httpDownloader)
        +authorizeOAuth(string $originUrl): bool
        +authorizeOAuthInteractively(string $originUrl, ?string $message): bool
        +getRateLimit(array $headers): array
        +isRateLimited(array $headers): bool
        +requiresSso(array $headers): bool
        +getSsoUrl(array $headers): ?string
    }

    class GitLab {
        #io: IOInterface
        #config: Config
        #process: ProcessExecutor
        #httpDownloader: HttpDownloader
        --
        +__construct(IOInterface $io, Config $config,\n  ?ProcessExecutor $process, ?HttpDownloader $httpDownloader)
        +authorizeOAuth(string $originUrl): bool
        +authorizeOAuthInteractively(string $scheme, string $originUrl, ...): bool
        +authorizeOAuthRefresh(string $scheme, string $originUrl): bool
        +isOAuthExpired(string $originUrl): bool
        -createToken(string $scheme, string $originUrl): array
        -refreshToken(string $scheme, string $originUrl): array
    }

    class Bitbucket {
        -io: IOInterface
        -config: Config
        -process: ProcessExecutor
        -httpDownloader: HttpDownloader
        -token: ?array
        -time: ?int
        ..Constants..
        OAUTH2_ACCESS_TOKEN_URL
        --
        +__construct(IOInterface $io, Config $config,\n  ?ProcessExecutor $process, ?HttpDownloader $httpDownloader, ?int $time)
        +getToken(): string
        +authorizeOAuth(string $originUrl): bool
        +authorizeOAuthInteractively(string $originUrl, ?string $message): bool
        +requestToken(string $originUrl, string $consumerKey,\n  string $consumerSecret): string
        -requestAccessToken(): bool
        -getTokenFromConfig(string $originUrl): bool
    }

    class Svn {
        #credentials: ?array
        #hasAuth: bool
        #io: IOInterface
        #url: string
        #process: ProcessExecutor
        #config: Config
        #qtyAuthTries: int = 0
        ..Constants..
        MAX_QTY_AUTH_TRIES = 5
        --
        +__construct(string $url, IOInterface $io, Config $config,\n  ?ProcessExecutor $process)
        +execute(array $command, string $url, ?string $cwd,\n  ?string $path, bool $verbose): string
        +executeLocal(array $command, string $path, ?string $cwd,\n  bool $verbose): string
        +{static} cleanEnv(): void
    }

    class Url <<static utility>> {
        --
        +{static} updateDistReference(Config $config, string $url, string $ref): string
        +{static} getOrigin(Config $config, string $url): string
        +{static} sanitize(string $url): string
    }

}

' ─────────────── Relationships ───────────────

' Filesystem — aggregates ProcessExecutor (optional, lazy-init)
Filesystem "1" o-- "0..1" ProcessExecutor : uses (lazy init) >

' Git — composes its core collaborators
Git "1" *-- "1" ProcessExecutor : process >
Git "1" *-- "1" Filesystem : filesystem >
Git "1" *-- "0..1" HttpDownloader : httpDownloader >

' Git — creates provider helpers on demand
Git ..> GitHub : creates on demand >
Git ..> GitLab : creates on demand >
Git ..> Bitbucket : creates on demand >
Git ..> AuthHelper : creates on demand >

' AuthHelper — routes auth prompts to provider helpers
AuthHelper ..> GitHub : routes OAuth >
AuthHelper ..> GitLab : routes OAuth >
AuthHelper ..> Bitbucket : routes OAuth >

' OAuth provider helpers — share ProcessExecutor & HttpDownloader
GitHub "1" *-- "1" ProcessExecutor : process >
GitHub "1" *-- "0..1" HttpDownloader : httpDownloader >

GitLab "1" *-- "1" ProcessExecutor : process >
GitLab "1" *-- "0..1" HttpDownloader : httpDownloader >

Bitbucket "1" *-- "1" ProcessExecutor : process >
Bitbucket "1" *-- "0..1" HttpDownloader : httpDownloader >

' HttpDownloader — selects backend at runtime
HttpDownloader "1" o-- "0..1" CurlDownloader : curl (preferred) >
HttpDownloader "1" o-- "0..1" RemoteFilesystem : rfs (fallback) >

' HttpDownloader & Git use Url static helpers
HttpDownloader ..> Url : uses static helpers >
Git ..> Url : uses static helpers >

' ProcessExecutor references GitHub constant for token masking
ProcessExecutor ..> GitHub : GITHUB_TOKEN_REGEX (masking) >

' Svn — standalone SVN client
Svn "1" *-- "1" ProcessExecutor : process >

' External interface dependencies (selected key wiring)
ProcessExecutor ..> IOInterface : io >
HttpDownloader ..> IOInterface : io >
HttpDownloader ..> Config : config >
AuthHelper ..> IOInterface : io >
AuthHelper ..> Config : config >
Git ..> IOInterface : io >
Git ..> Config : config >
GitHub ..> IOInterface : io >
GitHub ..> Config : config >
GitLab ..> IOInterface : io >
GitLab ..> Config : config >
Bitbucket ..> IOInterface : io >
Bitbucket ..> Config : config >
Svn ..> IOInterface : io >
Svn ..> Config : config >

@enduml
