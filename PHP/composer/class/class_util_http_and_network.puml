@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Utility — HTTP & Network Layer

' ─────────────────────────────────────────
'  External / support stubs
' ─────────────────────────────────────────
interface IOInterface <<external>> {
}

class Config <<external>> {
}

class AuthHelper <<external>> {
}

class NoProxyPattern <<external>> {
}

class Loop <<external>> {
}

interface DownloaderInterface <<external>> {
}

' ─────────────────────────────────────────
'  Composer\Util\Http
' ─────────────────────────────────────────
package "Composer\\Util\\Http" {

    class Response {
        -request: array
        -code: int
        -headers: list<string>
        -body: ?string
        --
        +__construct(request: array, code: ?int, headers: array, body: ?string)
        +getStatusCode(): int
        +getStatusMessage(): ?string
        +getHeaders(): string[]
        +getHeader(name: string): ?string
        +getBody(): ?string
        +decodeJson(): mixed
        +collect(): void
        +{static} findHeaderValue(headers: string[], name: string): ?string
    }

    class CurlResponse {
        -curlInfo: array
        --
        +__construct(request: array, code: ?int, headers: array, body: ?string, curlInfo: array)
        +getCurlInfo(): array
    }

    class RequestProxy {
        -contextOptions: ?array
        -status: ?string
        -url: ?string
        -auth: ?string
        --
        +{static} none(): RequestProxy
        +{static} noProxy(): RequestProxy
        +getContextOptions(): ?array
        +getCurlOptions(sslOptions: array): array
        +getStatus(format: ?string): string
        +isExcludedByNoProxy(): bool
        +isSecure(): bool
        +supportsSecureProxy(): bool
    }

    class ProxyItem {
        -url: non-empty-string
        -safeUrl: non-empty-string
        -curlAuth: ?string
        -optionsProxy: string
        -optionsAuth: ?string
        --
        +__construct(proxyUrl: string, envName: string)
        +toRequestProxy(scheme: string): RequestProxy
    }

    class ProxyManager <<singleton>> {
        -{static} instance: ?self
        -error: ?string
        -httpProxy: ?ProxyItem
        -httpsProxy: ?ProxyItem
        -noProxyHandler: ?NoProxyPattern
        --
        -{static} __construct()
        +{static} getInstance(): ProxyManager
        +{static} reset(): void
        +hasProxy(): bool
        +getProxyForRequest(requestUrl: string): RequestProxy
        -getProxyForScheme(scheme: string): ?ProxyItem
        -getProxyData(): void
        -noProxy(requestUrl: string): bool
    }

    class CurlDownloader <<internal>> {
        -multiHandle: CurlMultiHandle
        -shareHandle: CurlShareHandle
        -jobs: Job[]
        -io: IOInterface
        -config: Config
        -authHelper: AuthHelper
        -selectTimeout: float = 5.0
        -maxRedirects: int = 20
        -maxRetries: int = 3
        --
        +__construct(io: IOInterface, config: Config, options: array, disableTls: bool)
        +download(resolve: callable, reject: callable, origin: string, url: string, options: array, copyTo: ?string): int
        +abortRequest(id: int): void
        +tick(): void
        -initDownload(...): int
        -handleRedirect(job: Job, response: Response): string
        -isAuthenticatedRetryNeeded(job: Job, response: Response): array
        -restartJob(job: Job, url: string, attributes: array): void
        -rejectJob(job: Job, e: Exception): void
    }
}

' ─────────────────────────────────────────
'  Composer\Util
' ─────────────────────────────────────────
package "Composer\\Util" {

    class StreamContextFactory <<final>> {
        --
        +{static} getContext(url: string, defaultOptions: array, defaultParams: array): resource
        +{static} initOptions(url: string, options: array, forCurl: bool = false): array
        +{static} getTlsDefaults(options: array, logger: ?LoggerInterface): array
        -{static} fixHttpHeaderField(header: string|string[]): string[]
    }

    class TlsHelper <<final>> <<deprecated>> {
        --
        ' @deprecated Use composer/ca-bundle; removed in Composer 3.0
        +{static} checkCertificateHost(certificate: mixed, hostname: string, cn: ?string): bool
        +{static} getCertificateNames(certificate: mixed): ?array
        +{static} getCertificateFingerprint(certificate: string): string
        +{static} isOpensslParseSafe(): bool
        -{static} certNameMatcher(certName: string): ?callable
    }

    class RemoteFilesystem <<internal>> {
        -io: IOInterface
        -config: Config
        -authHelper: AuthHelper
        -bytesMax: int
        -options: mixed[]
        -disableTls: bool = false
        -retry: bool = false
        -progress: bool
        -degradedMode: bool = false
        -maxRedirects: int = 20
        --
        +__construct(io: IOInterface, config: Config, options: array, disableTls: bool, authHelper: ?AuthHelper)
        +copy(originUrl: string, fileUrl: string, fileName: string, progress: bool, options: array): bool
        +getContents(originUrl: string, fileUrl: string, progress: bool, options: array): bool|string
        +getOptions(): array
        +setOptions(options: array): void
        +isTlsDisabled(): bool
        +getLastHeaders(): list<string>
        +{static} findStatusCode(headers: string[]): ?int
        #get(originUrl: string, fileUrl: string, additionalOptions: array, fileName: ?string, progress: bool): bool|string
        #getRemoteContents(...): string|false
        #callbackGet(...): void
        #promptAuthAndRetry(httpStatus: int, reason: ?string, headers: array): void
        -handleRedirect(responseHeaders: array, additionalOptions: array, result: string|false): bool|string
    }

    class SyncHelper {
        --
        +{static} downloadAndInstallPackageSync(loop: Loop, downloader: DownloaderInterface, path: string, package: PackageInterface, prevPackage: ?PackageInterface): void
        +{static} await(loop: Loop, promise: ?PromiseInterface): void
    }
}

' ─────────────────────────────────────────
'  Relationships
' ─────────────────────────────────────────

' Inheritance
CurlResponse --|> Response : extends

' Composition / Aggregation
ProxyManager *-- ProxyItem : httpProxy\nhttpsProxy
ProxyManager o-- NoProxyPattern : noProxyHandler

' Creation / Factory
ProxyItem ..> RequestProxy : creates via\ntoRequestProxy()
ProxyManager ..> RequestProxy : creates via\ngetProxyForRequest()
CurlDownloader ..> CurlResponse : creates

' Dependencies — CurlDownloader
CurlDownloader ..> ProxyManager : uses (singleton)
CurlDownloader ..> StreamContextFactory : uses\ninitOptions()
CurlDownloader o-- AuthHelper
CurlDownloader o-- IOInterface
CurlDownloader o-- Config
CurlDownloader ..> Response : uses (handleRedirect,\nauthRetry params)

' Dependencies — RemoteFilesystem
RemoteFilesystem ..> StreamContextFactory : uses\ngetContext()\ngetTlsDefaults()
RemoteFilesystem ..> ProxyManager : uses (singleton)
RemoteFilesystem o-- AuthHelper
RemoteFilesystem o-- IOInterface
RemoteFilesystem ..> Response : uses\nfindHeaderValue()

' Dependencies — StreamContextFactory
StreamContextFactory ..> ProxyManager : getProxyForRequest()
StreamContextFactory ..> RequestProxy : uses\ngetContextOptions()

' Dependencies — SyncHelper
SyncHelper ..> Loop : drives event loop
SyncHelper ..> DownloaderInterface : delegates to

@enduml
