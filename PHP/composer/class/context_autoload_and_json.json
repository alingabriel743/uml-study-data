  "relationships": [
    "AutoloadGenerator depends_on JsonFile (reads installed.json in dump())",
    "AutoloadGenerator depends_on ClassMapGenerator (builds class maps via ClassMapGenerator\\ClassMapGenerator)",
    "AutoloadGenerator creates ClassLoader (createLoader() returns ClassLoader instance)",
    "AutoloadGenerator depends_on EventDispatcher (composition, injected)",
    "AutoloadGenerator depends_on IOInterface (composition, injected)",
    "ClassMapGenerator (deprecated) delegates_to \\Composer\\ClassMapGenerator\\ClassMapGenerator (external package)",
    "JsonManipulator depends_on JsonFile (calls JsonFile::parseJson, JsonFile::encode, JsonFile::detectIndenting)",
    "JsonFile throws JsonValidationException (from validateSchema and validateJsonSchema)",
    "JsonValidationException extends Exception",
    "JsonFormatter is_standalone_utility (no dependencies on other classes in scope)"
  ],
  "key_notes": [
    "ClassMapGenerator in Composer\\Autoload is a deprecated shim since 2.4.0; real logic in composer/class-map-generator package",
    "AutoloadGenerator.dump() uses JsonFile to read vendor/composer/installed.json for devMode detection",
    "ClassLoader supports PSR-0, PSR-4, and classmap strategies; APCu caching optional",
    "JsonFile handles HTTP downloads via HttpDownloader; validates against JSON Schema (LAX/STRICT/AUTH/LOCK schemas)",
    "JsonManipulator does regex-based in-place JSON editing (preserves formatting/whitespace)",
    "JsonFormatter is deprecated; JsonFile::encode() is the modern replacement",
    "JsonFile::detectIndenting() is used by both JsonFile (read) and JsonManipulator (detectIndenting())",
    "AutoloadGenerator.createLoader() wires ClassLoader with PSR-0/PSR-4/classmap entries"
  ],
