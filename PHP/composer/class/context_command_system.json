{
  "scope": "command_system",
  "title": "CLI Command System",
  "diagram_type": "class",
  "namespace": "Composer\\Command",

  "classes": [
    {
      "name": "BaseCommand",
      "type": "abstract class",
      "extends": "Symfony\\Component\\Console\\Command\\Command",
      "properties": [
        "-composer: ?Composer",
        "-io: IOInterface"
      ],
      "methods": [
        "+getApplication(): Application",
        "+requireComposer(?bool $disablePlugins, ?bool $disableScripts): Composer",
        "+tryComposer(?bool $disablePlugins, ?bool $disableScripts): ?Composer",
        "+getComposer(bool $required, ?bool $disablePlugins, ?bool $disableScripts): ?Composer [deprecated]",
        "+setComposer(Composer $composer): void",
        "+resetComposer(): void",
        "+getIO(): IOInterface",
        "+setIO(IOInterface $io): void",
        "+isProxyCommand(): bool",
        "+complete(CompletionInput, CompletionSuggestions): void",
        "#initialize(InputInterface, OutputInterface): void",
        "#createComposerInstance(InputInterface, IOInterface, $config, ?bool, ?bool): Composer",
        "#getPreferredInstallOptions(Config, InputInterface, bool): array",
        "#getPlatformRequirementFilter(InputInterface): PlatformRequirementFilterInterface",
        "#formatRequirements(array): array",
        "#normalizeRequirements(array): array",
        "#renderTable(array, OutputInterface): void",
        "#getTerminalWidth(): int",
        "#getAuditFormat(InputInterface, string): string",
        "#createAuditConfig(Config, InputInterface): AuditConfig"
      ]
    },
    {
      "name": "BaseConfigCommand",
      "type": "abstract class",
      "extends": "BaseCommand",
      "properties": [
        "#config: Config",
        "#configFile: JsonFile",
        "#configSource: JsonConfigSource"
      ],
      "methods": [
        "#initialize(InputInterface, OutputInterface): void",
        "#getComposerConfigFile(InputInterface, Config): string [implied]"
      ]
    },
    {
      "name": "InstallCommand",
      "type": "class",
      "extends": "BaseCommand",
      "traits": ["CompletionTrait"],
      "command_name": "install",
      "aliases": ["i"],
      "methods": [
        "#configure(): void",
        "#execute(InputInterface, OutputInterface): int"
      ],
      "execute_flow": "requireComposer() → Installer::create($io, $composer) → configure install options → install->run()"
    },
    {
      "name": "UpdateCommand",
      "type": "class",
      "extends": "BaseCommand",
      "traits": ["CompletionTrait"],
      "command_name": "update",
      "aliases": ["u", "upgrade"],
      "methods": [
        "#configure(): void",
        "#execute(InputInterface, OutputInterface): int",
        "-getPackagesInteractively(IOInterface, InputInterface, OutputInterface, Composer, array): array",
        "-createVersionSelector(Composer): VersionSelector"
      ],
      "execute_flow": "requireComposer() → Installer::create() → install->run() → optionally BumpCommand::doBump()"
    },
    {
      "name": "RequireCommand",
      "type": "class",
      "extends": "BaseCommand",
      "traits": ["CompletionTrait", "PackageDiscoveryTrait"],
      "command_name": "require",
      "aliases": ["r"],
      "properties": [
        "-newlyCreated: bool",
        "-firstRequire: bool",
        "-json: JsonFile",
        "-file: string",
        "-composerBackup: string",
        "-lock: string",
        "-lockBackup: ?string",
        "-dependencyResolutionCompleted: bool"
      ],
      "methods": [
        "#configure(): void",
        "#execute(InputInterface, OutputInterface): int",
        "#interact(InputInterface, OutputInterface): void",
        "-doUpdate(InputInterface, OutputInterface, IOInterface, array, string, string): int",
        "-updateRequirementsAfterResolution(array, string, string, bool, bool, bool): int",
        "-updateFile(JsonFile, array, string, string, bool): void",
        "-updateFileCleanly(JsonFile, array, string, string, bool): bool",
        "-getInconsistentRequireKeys(array, string): array",
        "-getPackagesByRequireKey(): array",
        "-revertComposerFile(): void"
      ],
      "execute_flow": "Factory::getComposerFile() → determineRequirements() → formatRequirements() → updateFile() → doUpdate() → Installer::create() → install->run()"
    },
    {
      "name": "RemoveCommand",
      "type": "class",
      "extends": "BaseCommand",
      "traits": ["CompletionTrait"],
      "command_name": "remove",
      "aliases": ["rm", "uninstall"],
      "methods": [
        "#configure(): void",
        "#execute(InputInterface, OutputInterface): int"
      ],
      "execute_flow": "read JSON → JsonConfigSource::removeLink() → resetComposer() → requireComposer() → Installer::create() → install->run()"
    },
    {
      "name": "ShowCommand",
      "type": "class",
      "extends": "BaseCommand",
      "traits": ["CompletionTrait"],
      "command_name": "show",
      "aliases": ["info"],
      "methods": [
        "#configure(): void",
        "#execute(InputInterface, OutputInterface): int",
        "#complete(CompletionInput, CompletionSuggestions): void"
      ],
      "notes": "Large command; displays package info, installed packages, platform, available packages. Uses RepositoryInterface, IOInterface for output formatting."
    },
    {
      "name": "ConfigCommand",
      "type": "class",
      "extends": "BaseConfigCommand",
      "command_name": "config",
      "properties": [
        "#CONFIGURABLE_PACKAGE_PROPERTIES: string[] [const]",
        "#authConfigFile: JsonFile"
      ],
      "methods": [
        "#configure(): void",
        "#execute(InputInterface, OutputInterface): int",
        "#interact(InputInterface, OutputInterface): void",
        "#complete(CompletionInput, CompletionSuggestions): void"
      ],
      "notes": "Reads/writes composer.json config keys. Extends BaseConfigCommand which provides $configFile, $configSource, $config."
    },
    {
      "name": "InitCommand",
      "type": "class",
      "extends": "BaseCommand",
      "traits": ["CompletionTrait", "PackageDiscoveryTrait"],
      "command_name": "init",
      "properties": [
        "-gitConfig: array<string,string>"
      ],
      "methods": [
        "#configure(): void",
        "#execute(InputInterface, OutputInterface): int",
        "#initialize(InputInterface, OutputInterface): void",
        "#interact(InputInterface, OutputInterface): void",
        "+namespaceFromPackageName(string): ?string",
        "#formatAuthors(string): array",
        "#getGitConfig(): array",
        "#hasVendorIgnore(string, string): bool",
        "#addVendorIgnore(string, string): void",
        "#isValidEmail(string): bool",
        "-parseAuthorString(string): array",
        "-updateDependencies(OutputInterface): void",
        "-runDumpAutoloadCommand(OutputInterface): void",
        "-hasDependencies(array): bool",
        "-getDefaultPackageName(): string",
        "-getDefaultAuthor(): ?string",
        "-sanitizePackageNameComponent(string): string"
      ],
      "execute_flow": "collect options → write JsonFile → optionally runDumpAutoloadCommand() or updateDependencies()"
    },
    {
      "name": "CreateProjectCommand",
      "type": "class",
      "extends": "BaseCommand",
      "traits": ["CompletionTrait"],
      "command_name": "create-project",
      "properties": [
        "#suggestedPackagesReporter: SuggestedPackagesReporter"
      ],
      "methods": [
        "#configure(): void",
        "#execute(InputInterface, OutputInterface): int"
      ],
      "notes": "Uses ProjectInstaller, RepositoryFactory, VersionSelector. Installs a package as a new project into a directory."
    },
    {
      "name": "SelfUpdateCommand",
      "type": "class",
      "extends": "BaseCommand",
      "command_name": "self-update",
      "aliases": ["selfupdate"],
      "constants": [
        "HOMEPAGE = 'getcomposer.org'",
        "OLD_INSTALL_EXT = '-old.phar'"
      ],
      "methods": [
        "#configure(): void",
        "#execute(InputInterface, OutputInterface): int"
      ],
      "notes": "Updates composer.phar itself. Uses Composer\\SelfUpdate\\Keys, Composer\\SelfUpdate\\Versions. Disables plugins/scripts in BaseCommand::initialize()."
    },
    {
      "name": "CompletionTrait",
      "type": "trait",
      "methods": [
        "+suggestPreferInstall(): array",
        "+suggestAvailablePackage(): Closure",
        "+suggestAvailablePackageInclPlatform(): Closure",
        "+suggestInstalledPackage(bool): Closure",
        "+suggestRootRequirement(): Closure"
      ]
    },
    {
      "name": "PackageDiscoveryTrait",
      "type": "trait",
      "properties": [
        "#repos: CompositeRepository"
      ],
      "methods": [
        "#determineRequirements(InputInterface, OutputInterface, array, ?PlatformRepository, string, bool, bool): array",
        "#getRepos(): CompositeRepository"
      ]
    }
  ],

  "inheritance_hierarchy": [
    "Symfony\\Command → BaseCommand (abstract)",
    "BaseCommand → BaseConfigCommand (abstract)",
    "BaseConfigCommand → ConfigCommand",
    "BaseCommand → InstallCommand",
    "BaseCommand → UpdateCommand",
    "BaseCommand → RequireCommand",
    "BaseCommand → RemoveCommand",
    "BaseCommand → ShowCommand",
    "BaseCommand → InitCommand",
    "BaseCommand → CreateProjectCommand",
    "BaseCommand → SelfUpdateCommand"
  ],

  "trait_usage": [
    "CompletionTrait used by: InstallCommand, UpdateCommand, RequireCommand, RemoveCommand, ShowCommand, InitCommand, CreateProjectCommand",
    "PackageDiscoveryTrait used by: RequireCommand, InitCommand"
  ],

  "key_dependencies": [
    "BaseCommand depends_on Composer (domain object, fetched via Application)",
    "BaseCommand depends_on IOInterface (fetched via Application)",
    "BaseCommand depends_on Factory (static calls: create, createGlobal, createConfig)",
    "BaseCommand depends_on PlatformRequirementFilterFactory",
    "BaseCommand depends_on AuditConfig / Auditor",
    "InstallCommand depends_on Installer (creates via Installer::create)",
    "UpdateCommand depends_on Installer, BumpCommand (invoked inline)",
    "RequireCommand depends_on JsonFile, JsonManipulator, Installer, VersionParser",
    "RemoveCommand depends_on JsonFile, JsonConfigSource, Installer",
    "ConfigCommand depends_on Config, JsonFile, JsonConfigSource (via BaseConfigCommand)",
    "InitCommand depends_on JsonFile, RepositoryFactory, ProcessExecutor",
    "CreateProjectCommand depends_on ProjectInstaller, SuggestedPackagesReporter, VersionSelector",
    "SelfUpdateCommand depends_on SelfUpdate\\Keys, SelfUpdate\\Versions, Phar"
  ],

  "other_commands_in_namespace": [
    "AboutCommand", "ArchiveCommand", "AuditCommand", "BaseDependencyCommand",
    "BumpCommand", "CheckPlatformReqsCommand", "ClearCacheCommand",
    "DependsCommand", "DiagnoseCommand", "DumpAutoloadCommand", "ExecCommand",
    "FundCommand", "GlobalCommand", "HomeCommand", "LicensesCommand",
    "OutdatedCommand", "ProhibitsCommand", "ReinstallCommand", "RepositoryCommand",
    "RunScriptCommand", "ScriptAliasCommand", "SearchCommand", "StatusCommand",
    "SuggestsCommand", "ValidateCommand"
  ],

  "important_notes": [
    "BaseCommand::initialize() reads env vars (COMPOSER_NO_DEV, COMPOSER_PREFER_STABLE, etc.) and sets input options accordingly",
    "SelfUpdateCommand is special-cased in BaseCommand::initialize() to always disable plugins/scripts",
    "RequireCommand and RemoveCommand use backup/revert pattern for composer.json on failure",
    "UpdateCommand can trigger BumpCommand::doBump() post-update via bump-after-update config",
    "ConfigCommand extends BaseConfigCommand (not BaseCommand directly) — adds $config, $configFile, $configSource properties",
    "ShowCommand has the same parent (BaseCommand) as others but is a large 'info display' command using repositories",
    "All install/update/require/remove commands create Installer via Installer::create($io, $composer) and chain options as a fluent builder"
  ],

  "source_files_analyzed": [
    "src/Composer/Command/BaseCommand.php",
    "src/Composer/Command/BaseConfigCommand.php",
    "src/Composer/Command/InstallCommand.php",
    "src/Composer/Command/UpdateCommand.php",
    "src/Composer/Command/RequireCommand.php",
    "src/Composer/Command/RemoveCommand.php",
    "src/Composer/Command/ConfigCommand.php",
    "src/Composer/Command/InitCommand.php",
    "src/Composer/Command/CreateProjectCommand.php",
    "src/Composer/Command/SelfUpdateCommand.php"
  ]
}
