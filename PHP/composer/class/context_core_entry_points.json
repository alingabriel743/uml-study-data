    "Installer": ["IOInterface", "Config", "RootPackageInterface", "DownloadManager", "RepositoryManager", "Locker", "InstallationManager", "EventDispatcher", "AutoloadGenerator", "Solver", "Pool", "Request", "LockTransaction", "AuditConfig", "PlatformRequirementFilterInterface"],
    "InstalledVersions": ["ClassLoader (Composer\\Autoload)", "VersionParser (Composer\\Semver)"],
