  "event_constants": {
    "class": "PackageEvents",
    "constants": [
      "PRE_PACKAGE_INSTALL", "POST_PACKAGE_INSTALL",
      "PRE_PACKAGE_UPDATE", "POST_PACKAGE_UPDATE",
      "PRE_PACKAGE_UNINSTALL", "POST_PACKAGE_UNINSTALL"
    ],
    "dispatched_by": "InstallationManager::executeBatch() via EventDispatcher::dispatchPackageEvent()"
  },

  "important_notes": [
    "InstallationManager.execute() batches operations: plugin-modifies-downloads packages are isolated in their own batch first.",
    "executeBatch() pipeline: dispatcher.PRE_EVENT → installer.prepare() → installer.install/update/uninstall() → cleanup() → repo.write() → dispatcher.POST_EVENT",
    "PluginInstaller.supports() covers both 'composer-plugin' and 'composer-installer' types.",
    "MetapackageInstaller.getInstallPath() returns null — no disk presence.",
    "ProjectInstaller.supports() returns true for all types — it is single-package, not registered globally.",
    "BinaryInstaller generates both Unix shell/PHP proxy files and Windows .bat proxy files depending on binCompat setting.",
    "InstallerEvent carries a Transaction (full resolver plan); PackageEvent carries a single OperationInterface being executed.",
    "InstallationManager.getInstaller() uses a type-keyed cache for performance."
  ],

