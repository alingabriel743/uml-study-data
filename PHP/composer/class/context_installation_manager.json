      "name": "BinaryInstaller",
      "type": "class",
      "implements": [],
      "properties": [
        "binDir: string [protected]",
        "binCompat: string [protected]",
        "io: IOInterface [protected]",
        "filesystem: Filesystem [protected]",
        "vendorDir: ?string [private]"
      ],
      "constructor": "__construct(IOInterface $io, string $binDir, string $binCompat, ?Filesystem $filesystem = null, ?string $vendorDir = null)",
      "methods": [
        "installBinaries(PackageInterface $package, string $installPath, bool $warnOnOverwrite = true): void — iterates bins, delegates to installFullBinaries() or installUnixyProxyBinaries()",
        "removeBinaries(PackageInterface $package): void",
        "determineBinaryCaller(string $bin): string [static] — reads shebang, returns 'call'|'php'|interpreter",
        "getBinaries(PackageInterface $package): string[] [protected]",
        "installFullBinaries(...): void [protected] — unixy proxy + Windows .bat",
        "installUnixyProxyBinaries(...): void [protected] — shell/PHP proxy file",
        "initializeBinDir(): void [protected]",
        "generateWindowsProxyCode(...): string [protected]",
        "generateUnixyProxyCode(...): string [protected]"
      ],
