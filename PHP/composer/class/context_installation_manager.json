    },
    {
      "name": "LibraryInstaller",
      "type": "class",
      "implements": ["InstallerInterface", "BinaryPresenceInterface"],
      "properties": [
        "composer: PartialComposer [protected]",
        "vendorDir: string [protected]",
        "downloadManager: ?DownloadManager [protected]",
        "io: IOInterface [protected]",
        "type: string [protected]",
        "filesystem: Filesystem [protected]",
        "binaryInstaller: BinaryInstaller [protected]"
      ],
      "constructor": "__construct(IOInterface $io, PartialComposer $composer, ?string $type = 'library', ?Filesystem $filesystem = null, ?BinaryInstaller $binaryInstaller = null)",
      "methods": [
        "supports(string $packageType): bool — matches $this->type or null",
        "isInstalled(InstalledRepositoryInterface $repo, PackageInterface $package): bool — checks repo + path readability/junction/link",
        "download(...): delegates to DownloadManager::download()",
        "prepare(...): delegates to DownloadManager::prepare()",
        "cleanup(...): delegates to DownloadManager::cleanup()",
        "install(...): installCode() + binaryInstaller->installBinaries() + repo->addPackage()",
        "update(...): binaryInstaller->removeBinaries() + updateCode() + binaryInstaller->installBinaries() + repo swap",
        "uninstall(...): removeCode() + binaryInstaller->removeBinaries() + repo->removePackage()",
        "getInstallPath(PackageInterface $package): string — vendorDir/prettyName[/targetDir]",
        "ensureBinariesPresence(PackageInterface $package): void",
        "getPackageBasePath(PackageInterface $package): string [protected]",
        "installCode(PackageInterface $package): ?PromiseInterface [protected]",
        "updateCode(PackageInterface $initial, PackageInterface $target): ?PromiseInterface [protected]",
        "removeCode(PackageInterface $package): ?PromiseInterface [protected]",
        "initializeVendorDir(): void [protected]",
        "getDownloadManager(): DownloadManager [protected]"
      ],
      "composition": ["BinaryInstaller", "DownloadManager", "Filesystem"],
      "dependencies": ["PartialComposer", "IOInterface", "InstalledRepositoryInterface", "PackageInterface"]
    },
    {
      "name": "PluginInstaller",
      "type": "class",
      "extends": "LibraryInstaller",
      "implements": ["InstallerInterface", "BinaryPresenceInterface"],
      "constructor": "__construct(IOInterface $io, PartialComposer $composer, ?Filesystem $fs = null, ?BinaryInstaller $binaryInstaller = null) — calls parent with type='composer-plugin'",
      "methods": [
        "supports(string $packageType): bool — 'composer-plugin' || 'composer-installer'",
        "disablePlugins(): void — delegates to PluginManager::disablePlugins()",
        "prepare(...): checks plugin allowance via PluginManager::isPluginAllowed(), then parent::prepare()",
        "download(...): validates extra['class'] exists, then parent::download()",
        "install(...): parent::install() + PluginManager::registerPackage($package, true)",
        "update(...): parent::update() + PluginManager::deactivatePackage($initial) + registerPackage($target, true)",
        "uninstall(...): PluginManager::uninstallPackage($package) + parent::uninstall()",
        "rollbackInstall(...): [private] calls parent::uninstall on failure",
        "getPluginManager(): PluginManager [protected]"
      ],
      "dependencies": ["PluginManager", "Composer"]
    },
    {
      "name": "MetapackageInstaller",
      "type": "class",
      "implements": ["InstallerInterface"],
      "properties": ["io: IOInterface [private]"],
      "constructor": "__construct(IOInterface $io)",
      "methods": [
        "supports(string $packageType): bool — 'metapackage' only",
        "isInstalled(...): repo->hasPackage($package)",
        "download(...): noop, returns resolved promise",
        "prepare(...): noop",
        "cleanup(...): noop",
        "install(...): io->writeError + repo->addPackage(clone $package)",
        "update(...): repo swap initial->target",
        "uninstall(...): repo->removePackage($package)",
        "getInstallPath(...): returns null (no disk presence)"
      ],
      "note": "No-op downloader; purely registry-based. No filesystem operations."
    },
    {
      "name": "ProjectInstaller",
      "type": "class",
      "implements": ["InstallerInterface"],
      "properties": [
        "installPath: string [private]",
        "downloadManager: DownloadManager [private]",
        "filesystem: Filesystem [private]"
      ],
      "constructor": "__construct(string $installPath, DownloadManager $dm, Filesystem $fs)",
      "methods": [
        "supports(string $packageType): bool — always true",
        "isInstalled(...): always false",
        "download(...): validates dir empty, delegates to downloadManager->download()",
        "prepare(...): downloadManager->prepare()",
        "cleanup(...): downloadManager->cleanup()",
        "install(...): downloadManager->install()",
        "update(...): throws InvalidArgumentException (not supported)",
        "uninstall(...): throws InvalidArgumentException (not supported)",
        "getInstallPath(...): returns $this->installPath"
      ],
      "note": "Single-use installer for `composer create-project`. No update/uninstall support."
    },
