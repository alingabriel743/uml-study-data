  "relationships": [
    "IOInterface extends LoggerInterface (Psr\\Log)",
    "BaseIO implements IOInterface",
    "ConsoleIO extends BaseIO",
    "BufferIO extends ConsoleIO",
    "NullIO extends BaseIO",
    "JsonConfigSource implements ConfigSourceInterface",
    "Application extends Symfony\\Component\\Console\\Application",
    "Application depends_on IOInterface (holds $io, starts as NullIO, becomes ConsoleIO in doRun)",
    "Application depends_on Composer (holds $composer, created via Factory::create)",
    "Application creates ConsoleIO in doRun()",
    "Application uses Config via Factory::createConfig() in getUseParentDirConfigValue()",
    "Config aggregates ConfigSourceInterface x3 ($configSource, $authConfigSource, $localAuthConfigSource)",
    "Config depends_on IOInterface in prohibitUrlByConfig() for warnings",
    "BaseIO depends_on Config in loadConfiguration()",
    "JsonConfigSource composes JsonFile (reads/writes JSON)",
    "JsonConfigSource uses JsonManipulator for surgical edits"
  ],
  "key_patterns": [
    "Template Method: BaseIO provides auth management + PSR-3 log methods; subclasses implement write/ask",
    "Strategy: ConfigSourceInterface decouples Config from storage (JsonConfigSource is the main impl)",
    "Null Object: NullIO discards all IO — used in completion mode and as Application default",
    "Facade: Application wires IOInterface + Config + Composer together; consumers use getIO()/getComposer()"
  ],
  "important_notes": "ConsoleIO.doWrite() prepends [MiB/time] prefix when startTime is set (--profile). BufferIO is test-only, wraps ArrayInput+StreamOutput. Config.get() resolves {$refs} recursively via process(). JsonConfigSource.manipulateJson() validates JSON schema after every write and reverts on failure.",
