  "abstract_classes": [
    {
      "name": "BasePackage",
      "implements": ["PackageInterface"],
      "modifiers": "abstract",
      "static_properties": [
        "public static $supportedLinkTypes: array (require/conflict/provide/replace/require-dev => Link::TYPE_*)",
        "public static $stabilities: array (deprecated alias of STABILITIES)"
      ],
      "constants": [
        "STABILITY_STABLE=0", "STABILITY_RC=5", "STABILITY_BETA=10", "STABILITY_ALPHA=15", "STABILITY_DEV=20",
        "STABILITIES: array<string, int>"
      ],
      "properties": [
        "public $id: int (READ-ONLY, set by solver)",
        "protected $name: string (lowercased)",
        "protected $prettyName: string",
        "protected $repository: ?RepositoryInterface"
      ],
      "constructor": "__construct(string $name): sets prettyName, name=strtolower(name), id=-1",
      "key_methods": [
        "getName(): string",
        "getPrettyName(): string",
        "getNames(bool $provides=true): array (includes provides+replaces targets)",
        "setId(int): void",
        "getId(): int",
        "setRepository(RepositoryInterface): void (throws LogicException if already set to different repo)",
        "getRepository(): ?RepositoryInterface",
        "isPlatform(): bool (checks instanceof PlatformRepository)",
        "getUniqueName(): string (name-version)",
        "equals(PackageInterface): bool (unwraps AliasPackage via getAliasOf() before ===)",
        "__toString(): string",
        "getPrettyString(): string",
        "getFullPrettyVersion(bool $truncate=true, int $displayMode): string",
        "getStabilityPriority(): int",
        "__clone(): resets repository=null, id=-1",
        "static packageNameToRegexp(string, string $wrap): string",
        "static packageNamesToRegexp(array, string $wrap): string"
      ]
    }
  ],

  "concrete_classes": [
    {
      "name": "Package",
      "extends": "BasePackage",
      "implements": [],
      "note": "Core solver/installer package — all data for dependency resolution",
      "properties": [
        "protected $type: string",
        "protected $targetDir: ?string",
        "protected $installationSource: 'source'|'dist'|null",
        "protected $sourceType: ?string",
        "protected $sourceUrl: ?string",
        "protected $sourceReference: ?string",
        "protected $sourceMirrors: ?array",
        "protected $distType: ?string",
        "protected $distUrl: ?string",
        "protected $distReference: ?string",
        "protected $distSha1Checksum: ?string",
        "protected $distMirrors: ?array",
        "protected $version: string",
        "protected $prettyVersion: string",
        "protected $releaseDate: ?DateTimeInterface",
        "protected $extra: array",
        "protected $binaries: string[]",
        "protected $dev: bool",
        "protected $stability: 'stable'|'RC'|'beta'|'alpha'|'dev'",
        "protected $notificationUrl: ?string",
        "protected $requires: array<string,Link>",
        "protected $conflicts: array<string,Link>",
        "protected $provides: array<string,Link>",
        "protected $replaces: array<string,Link>",
        "protected $devRequires: array<string,Link>",
        "protected $suggests: array<string,string>",
        "protected $autoload: AutoloadRules",
        "protected $devAutoload: DevAutoloadRules",
        "protected $includePaths: string[]",
        "protected $isDefaultBranch: bool",
        "protected $transportOptions: array",
        "protected $phpExt: PhpExtConfig|null"
      ],
      "constructor": "__construct(string $name, string $version, string $prettyVersion): calls parent(name), sets version/prettyVersion, stability=VersionParser::parseStability(version), dev=(stability==='dev')",
      "notable_methods": [
        "replaceVersion(string $version, string $prettyVersion): void (updates version+stability+dev)",
        "setSourceDistReferences(string $reference): void (updates source ref; also updates distUrl for github/gitlab/bitbucket)",
        "getSourceUrls(): delegates to getUrls() with source params",
        "getDistUrls(): delegates to getUrls() with dist params",
        "getUrls(?string $url, ?array $mirrors, ?string $ref, ?string $type, string $urlType): array (processes mirror URLs via ComposerMirror)",
        "convertLinksToMap(array $links, string $source): array (private, deprecated indexed-array compat)"
      ]
    },
    {
      "name": "CompletePackage",
      "extends": "Package",
      "implements": ["CompletePackageInterface"],
      "note": "Adds metadata not needed by solver — used for display/install info",
      "added_properties": [
        "protected $repositories: array",
        "protected $license: string[]",
        "protected $keywords: string[]",
        "protected $authors: array<{name?,homepage?,email?,role?}>",
        "protected $description: ?string",
        "protected $homepage: ?string",
        "protected $scripts: array<string, string[]>",
        "protected $support: array{issues?,forum?,wiki?,source?,email?,irc?,docs?,rss?,chat?,security?}",
        "protected $funding: array<{url?,type?}>",
        "protected $abandoned: bool|string",
        "protected $archiveName: ?string",
        "protected $archiveExcludes: string[]"
      ],
      "notable_methods": [
        "isAbandoned(): bool (casts $abandoned to bool)",
        "getReplacementPackage(): ?string (returns $abandoned if string, else null)"
      ]
    },
    {
      "name": "RootPackage",
      "extends": "CompletePackage",
      "implements": ["RootPackageInterface"],
      "note": "Represents project's composer.json — the root of dependency graph",
      "constants": ["DEFAULT_PRETTY_VERSION = '1.0.0+no-version-set'"],
      "added_properties": [
        "protected $minimumStability: string (default 'stable')",
        "protected $preferStable: bool (default false)",
        "protected $stabilityFlags: array<string, STABILITY_*>",
        "protected $config: array",
        "protected $references: array<string, string> (package => commit hash)",
        "protected $aliases: list<{package, version, alias, alias_normalized}>"
      ]
    },
    {
      "name": "AliasPackage",
      "extends": "BasePackage",
      "implements": [],
      "note": "Wraps a BasePackage under a different version alias; delegates most getters to aliasOf",
      "properties": [
        "protected $version: string",
        "protected $prettyVersion: string",
        "protected $dev: bool",
        "protected $stability: string",
        "protected $rootPackageAlias: bool",
        "protected $hasSelfVersionRequires: bool",
        "protected $aliasOf: BasePackage",
        "protected $requires: Link[]",
        "protected $devRequires: Link[]",
        "protected $conflicts: Link[]",
        "protected $provides: Link[]",
        "protected $replaces: Link[]"
      ],
      "constructor": "__construct(BasePackage $aliasOf, string $version, string $prettyVersion): copies name from aliasOf, sets own version/stability, calls replaceSelfVersionDependencies for all link types",
      "key_methods": [
        "getAliasOf(): BasePackage",
        "setRootPackageAlias(bool): void",
        "isRootPackageAlias(): bool",
        "hasSelfVersionRequires(): bool",
        "replaceSelfVersionDependencies(Link[], linkType): Link[] (replaces 'self.version' constraints with actual alias version)",
        "__toString(): appends '(root alias of X)' or '(alias of X)'"
      ],
      "delegation_pattern": "Most PackageInterface getters (getType, getTargetDir, getExtra, getSourceType, getSourceUrl, getSourceReference, getDistType, getDistUrl, getDistReference, getAutoload, getDevAutoload, getIncludePaths, getPhpExt, getReleaseDate, getBinaries, getSuggests, getNotificationUrl, isDefaultBranch, getTransportOptions) → $this->aliasOf->*",
      "own_state": "version, prettyVersion, stability, dev, rootPackageAlias, hasSelfVersionRequires, requires/conflicts/provides/replaces/devRequires (with self.version substituted)"
    },
    {
      "name": "CompleteAliasPackage",
      "extends": "AliasPackage",
      "implements": ["CompletePackageInterface"],
      "note": "Alias wrapper for CompletePackage — narrows aliasOf type to CompletePackage",
      "properties": ["protected $aliasOf: CompletePackage (narrowed)"],
      "constructor": "__construct(CompletePackage $aliasOf, string $version, string $prettyVersion)",
      "delegation_pattern": "All CompletePackageInterface methods (getScripts, getRepositories, getLicense, getKeywords, getDescription, getHomepage, getAuthors, getSupport, getFunding, isAbandoned, getReplacementPackage, setAbandoned, getArchiveName, getArchiveExcludes, and all setters) → $this->aliasOf->*"
    },
    {
      "name": "RootAliasPackage",
      "extends": "CompleteAliasPackage",
      "implements": ["RootPackageInterface"],
      "note": "Alias wrapper for RootPackage — used when root package has an alias; mutating setters propagate to both local link state and aliasOf",
      "properties": ["protected $aliasOf: RootPackage (narrowed)"],
      "constructor": "__construct(RootPackage $aliasOf, string $version, string $prettyVersion)",
      "key_methods": [
        "getAliasOf(): RootPackage",
        "getAliases(): delegates to aliasOf",
        "getMinimumStability(): delegates to aliasOf",
        "getStabilityFlags(): delegates to aliasOf",
        "getReferences(): delegates to aliasOf",
        "getPreferStable(): delegates to aliasOf",
        "getConfig(): delegates to aliasOf"
      ],
      "mutation_pattern": "setRequires/setDevRequires/setConflicts/setProvides/setReplaces: updates OWN link array (via replaceSelfVersionDependencies) AND calls aliasOf->set*()",
      "pure_delegation_setters": "setAutoload, setDevAutoload, setStabilityFlags, setMinimumStability, setPreferStable, setConfig, setReferences, setAliases, setSuggests, setExtra → aliasOf->*()",
      "__clone": "calls parent::__clone() then clones aliasOf"
    }
  ],

  "inheritance_chain": [
    "PackageInterface",
    "  ← CompletePackageInterface",
    "    ← RootPackageInterface",
    "BasePackage implements PackageInterface",
    "  ← Package",
    "    ← CompletePackage implements CompletePackageInterface",
    "      ← RootPackage implements RootPackageInterface",
    "  ← AliasPackage",
    "    ← CompleteAliasPackage implements CompletePackageInterface",
    "      ← RootAliasPackage implements RootPackageInterface"
  ],

  "key_relationships": [
    "PackageInterface ←extends— CompletePackageInterface ←extends— RootPackageInterface",
    "BasePackage —implements→ PackageInterface",
    "Package —extends→ BasePackage",
    "CompletePackage —extends→ Package, —implements→ CompletePackageInterface",
    "RootPackage —extends→ CompletePackage, —implements→ RootPackageInterface",
    "AliasPackage —extends→ BasePackage, —composes→ BasePackage (aliasOf)",
    "CompleteAliasPackage —extends→ AliasPackage, —implements→ CompletePackageInterface, —composes→ CompletePackage (aliasOf)",
    "RootAliasPackage —extends→ CompleteAliasPackage, —implements→ RootPackageInterface, —composes→ RootPackage (aliasOf)",
    "BasePackage —depends_on→ RepositoryInterface (association)",
    "BasePackage —depends_on→ Link (static supportedLinkTypes)",
    "AliasPackage —depends_on→ Link, Constraint (replaceSelfVersionDependencies)",
    "Package —depends_on→ VersionParser, ComposerMirror"
  ],

  "design_patterns": [
    "Decorator/Proxy: AliasPackage/CompleteAliasPackage/RootAliasPackage wrap concrete packages, delegating unchanged getters while overriding version/stability/links",
    "Template Method: BasePackage provides concrete implementations of shared PackageInterface methods; subclasses extend",
    "Parallel hierarchies: concrete (Package→CompletePackage→RootPackage) mirrors alias (AliasPackage→CompleteAliasPackage→RootAliasPackage), both terminating at RootPackageInterface"
  ],

  "important_notes": [
    "AliasPackage owns its own link arrays (requires/conflicts/provides/replaces/devRequires) with 'self.version' replaced by the alias version — NOT delegated",
    "RootAliasPackage.set*Links() methods update BOTH own state and aliasOf — unlike CompleteAliasPackage which purely delegates",
    "BasePackage.equals() unwraps AliasPackage before identity comparison",
    "Package.setRequires/setConflicts/etc. accept indexed arrays (deprecated) and convert via convertLinksToMap",
    "RootPackage.DEFAULT_PRETTY_VERSION = '1.0.0+no-version-set'",
    "All interfaces are marked internal — not recommended for extension by users"
  ],

  "source_files_analyzed": [
