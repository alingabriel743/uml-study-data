  "key_relationships": [
    "PluginManager depends_on PluginInterface (manages lifecycle: add/remove/uninstall)",
    "PluginManager depends_on Capable (checks instanceof to discover capabilities)",
    "PluginManager depends_on Capability (getPluginCapability/getPluginCapabilities return Capability)",
    "PluginManager depends_on Composer, IOInterface, VersionParser, PartialComposer",
    "PluginInterface <<interface>> — implemented by concrete plugins",
    "Capable <<interface>> — optionally implemented by PluginInterface implementors",
    "CommandProvider extends Capability (sub-interface, returns BaseCommand[])",
    "PreFileDownloadEvent extends Event",
    "PostFileDownloadEvent extends Event",
    "PrePoolCreateEvent extends Event",
    "CommandEvent extends Event",
    "PreCommandRunEvent extends Event",
    "PluginManager calls plugin.activate(Composer, IOInterface) in addPlugin()",
    "PluginManager calls plugin.deactivate(Composer, IOInterface) in removePlugin()",
    "PluginManager calls plugin.uninstall(Composer, IOInterface) in uninstallPlugin()",
    "PluginManager calls EventDispatcher.addSubscriber(plugin) if plugin instanceof EventSubscriberInterface",
    "PluginManager calls EventDispatcher.removeListener(plugin) in removePlugin()"
  ],

  "lifecycle_flow": [
    "loadInstalledPlugins() → loadRepository(localRepo) → registerPackage(pkg) → addPlugin(plugin)",
    "addPlugin() → plugin.activate(composer, io) → [if EventSubscriberInterface] eventDispatcher.addSubscriber(plugin)",
    "removePlugin() → plugin.deactivate(composer, io) → eventDispatcher.removeListener(plugin)",
    "uninstallPlugin() → plugin.uninstall(composer, io)",
    "getPluginCapability(plugin, capabilityClass) → plugin.getCapabilities() [via Capable] → instantiate capabilityClass",
    "getPluginCapabilities(capabilityClass) → iterates all plugins, calls getPluginCapability per plugin"
  ],

  "event_constants_map": {
    "INIT": "Composer\\EventDispatcher\\Event",
    "COMMAND": "CommandEvent",
    "PRE_FILE_DOWNLOAD": "PreFileDownloadEvent",
    "POST_FILE_DOWNLOAD": "PostFileDownloadEvent",
    "PRE_COMMAND_RUN": "PreCommandRunEvent",
    "PRE_POOL_CREATE": "PrePoolCreateEvent"
  },

  "external_dependencies": [
    "Composer\\EventDispatcher\\Event (base for all plugin events)",
    "Composer\\EventDispatcher\\EventSubscriberInterface (optional plugin interface)",
    "Composer\\Installer\\InstallerInterface (legacy composer-installer BC)",
    "Composer\\Composer, Composer\\PartialComposer",
    "Composer\\IO\\IOInterface",
    "Composer\\Package\\PackageInterface, CompletePackage, BasePackage",
    "Composer\\Repository\\RepositoryInterface, InstalledRepository",
    "Composer\\Util\\HttpDownloader (PreFileDownloadEvent)",
    "Symfony\\Component\\Console\\Input\\InputInterface (CommandEvent, PreCommandRunEvent)",
    "Symfony\\Component\\Console\\Output\\OutputInterface (CommandEvent)"
  ],

  "important_notes": [
    "PLUGIN_API_VERSION = '2.9.0' — plugins must require this via composer-plugin-api",
    "allow-plugins config gates all plugin loading; interactive prompt if not configured",
    "PluginBlockedException thrown when plugin blocked by allow-plugins config",
    "Class aliasing via eval() used when same plugin class loaded multiple times (classCounter suffix)",
    "Capability objects receive ctor array with 'plugin', 'composer', 'io' keys",
    "PrePoolCreateEvent allows filtering packages before dependency solver Pool creation",
    "PostFileDownloadEvent.getPackage() is deprecated since Composer 2.1 — use getContext()"
  ],

  "source_files_analyzed": [
    "src/Composer/Plugin/PluginInterface.php",
    "src/Composer/Plugin/PluginManager.php",
    "src/Composer/Plugin/Capable.php",
    "src/Composer/Plugin/Capability/Capability.php",
    "src/Composer/Plugin/Capability/CommandProvider.php",
    "src/Composer/Plugin/PluginEvents.php",
    "src/Composer/Plugin/PreFileDownloadEvent.php",
    "src/Composer/Plugin/PostFileDownloadEvent.php",
    "src/Composer/Plugin/PrePoolCreateEvent.php",
    "src/Composer/Plugin/CommandEvent.php",
    "src/Composer/Plugin/PreCommandRunEvent.php"
  ]
}
