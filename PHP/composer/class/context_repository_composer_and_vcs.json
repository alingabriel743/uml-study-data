  "key_relationships": [
    "ArrayRepository implements RepositoryInterface",
    "ComposerRepository extends ArrayRepository",
    "ComposerRepository implements ConfigurableRepositoryInterface",
    "ComposerRepository implements AdvisoryProviderInterface",
    "ComposerRepository implements FilterListProviderInterface",
    "VcsRepository extends ArrayRepository",
    "VcsRepository implements ConfigurableRepositoryInterface",
    "ArtifactRepository extends ArrayRepository",
    "ArtifactRepository implements ConfigurableRepositoryInterface",
    "PathRepository extends ArrayRepository",
    "PathRepository implements ConfigurableRepositoryInterface",
    "FilterRepository implements RepositoryInterface",
    "FilterRepository implements AdvisoryProviderInterface",
    "FilterRepository wraps/composes RepositoryInterface (decorator pattern)",
    "LockArrayRepository extends ArrayRepository",
    "LockArrayRepository uses CanonicalPackagesTrait",
    "RepositoryFactory creates RepositoryManager (composes all repo types)",
    "RepositoryFactory depends_on ComposerRepository, VcsRepository, ArtifactRepository, PathRepository",
    "VcsRepository depends_on VcsDriverInterface (strategy pattern for git/svn/hg/etc.)",
    "ComposerRepository depends_on HttpDownloader, Cache, Loop, EventDispatcher",
    "PathRepository depends_on VersionGuesser, ProcessExecutor",
    "ArtifactRepository depends_on Tar, Zip utilities",
    "RepositoryUtils uses FilterRepository (unwraps it in flattenRepositories)"
  ],

  "design_patterns": [
    "Decorator: FilterRepository wraps any RepositoryInterface and filters package visibility",
    "Strategy: VcsRepository selects VcsDriverInterface implementation at runtime (github/git/svn/hg/etc.)",
    "Template Method: ArrayRepository.initialize() overridden by all subclasses for lazy loading",
    "Factory: RepositoryFactory.manager() registers all type→class mappings in RepositoryManager"
  ],

  "important_notes": [
    "ComposerRepository supports both v1 (providers) and v2 (lazy-providers/metadata-url) Packagist API formats",
    "ComposerRepository.whatProvides() is the core lazy-loading method used by the dependency solver",
    "VcsRepository.initialize() iterates all tags+branches via VcsDriverInterface, validates versions, loads packages",
    "FilterRepository.canonical=false means packages are found but NOT marked as canonical (solver can look elsewhere)",
    "PathRepository supports glob patterns in URL and sets dist.type='path' for symlink/copy installs",
    "ArtifactRepository requires PHP zip extension; scans recursively for .zip/.tar/.gz/.tgz",
    "LockArrayRepository is functionally identical to ArrayRepository but semantically marks lock-file source",
    "RepositoryUtils.flattenRepositories() unwraps FilterRepository to expose inner repo for tooling"
  ],

