  "interfaces": [
    {
      "name": "RepositoryInterface",
      "extends": ["\\Countable"],
      "constants": ["SEARCH_FULLTEXT=0", "SEARCH_NAME=1", "SEARCH_VENDOR=2"],
      "methods": [
        "hasPackage(PackageInterface): bool",
        "findPackage(string $name, $constraint): ?BasePackage",
        "findPackages(string $name, $constraint=null): BasePackage[]",
        "getPackages(): BasePackage[]",
        "loadPackages(array $packageNameMap, array $acceptableStabilities, array $stabilityFlags, array $alreadyLoaded=[]): array{namesFound, packages}",
        "search(string $query, int $mode=0, ?string $type=null): array",
        "getProviders(string $packageName): array",
        "getRepoName(): string"
      ]
    },
    {
      "name": "WritableRepositoryInterface",
      "extends": ["RepositoryInterface"],
      "methods": [
        "write(bool $devMode, InstallationManager $installationManager): void",
        "addPackage(PackageInterface $package): void",
        "removePackage(PackageInterface $package): void",
        "getCanonicalPackages(): PackageInterface[]",
        "reload(): void",
        "setDevPackageNames(array $devPackageNames): void",
        "getDevPackageNames(): string[]"
      ]
    },
    {
      "name": "InstalledRepositoryInterface",
      "extends": ["WritableRepositoryInterface"],
      "methods": [
        "getDevMode(): bool|null",
        "isFresh(): bool"
      ]
    }
  ],

  "classes": [
