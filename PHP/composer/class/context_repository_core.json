    {
      "name": "InstalledRepository",
      "extends": "CompositeRepository",
      "methods": [
        "findPackagesWithReplacersAndProviders(string $name, $constraint=null): BasePackage[]",
        "getDependents($needle, ?ConstraintInterface, bool $invert=false, bool $recurse=true, ?array $packagesFound=null): array",
        "getRepoName(): string",
        "addRepository(RepositoryInterface): void"
      ],
      "notes": "addRepository enforces only: LockArrayRepository | InstalledRepositoryInterface | RootPackageRepository | PlatformRepository. getDependents walks require/replace/conflict links recursively up to root. findPackagesWithReplacersAndProviders checks name, provides, and replaces."
    },
