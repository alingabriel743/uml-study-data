  "key_relationships": [
    "RepositoryInterface extends \\Countable",
    "WritableRepositoryInterface extends RepositoryInterface",
    "InstalledRepositoryInterface extends WritableRepositoryInterface",
    "ArrayRepository implements RepositoryInterface",
    "WritableArrayRepository extends ArrayRepository, implements WritableRepositoryInterface",
    "PlatformRepository extends ArrayRepository",
    "CompositeRepository implements RepositoryInterface",
    "InstalledRepository extends CompositeRepository",
    "FilesystemRepository extends WritableArrayRepository",
    "RepositoryManager aggregates RepositoryInterface[] (repositories)",
    "RepositoryManager aggregates InstalledRepositoryInterface (localRepository)",
    "RepositorySet aggregates RepositoryInterface[] (repositories)",
    "RepositorySet creates Pool via PoolBuilder",
    "FilesystemRepository depends_on JsonFile, ArrayLoader, ArrayDumper, InstallationManager",
    "PlatformRepository depends_on Runtime, HhvmDetector, VersionParser",
    "InstalledRepository restricts addRepository to LockArrayRepository|InstalledRepositoryInterface|RootPackageRepository|PlatformRepository"
  ],

  "important_notes": "ArrayRepository is the central base class — lazy initializes $packages on first access via initialize(). PlatformRepository builds platform packages (php, ext-*, lib-*) in initialize(). CompositeRepository delegates all ops to wrapped repos. InstalledRepository is a typed CompositeRepository for installed packages. FilesystemRepository persists to installed.json and optionally installed.php + InstalledVersions.php. RepositoryManager is the factory/registry (type->class map). RepositorySet is not a RepositoryInterface — it is the coordinator for building a Pool for dependency resolution.",

