  "key_relationships": [
    "Filesystem aggregates ProcessExecutor (optional, lazy-init via getProcess())",
    "Git composes ProcessExecutor, Filesystem, HttpDownloader (constructor injection)",
    "Git creates GitHub, GitLab, Bitbucket, AuthHelper on demand within runCommand()",
    "GitHub composes ProcessExecutor, HttpDownloader (constructor injection, fallback to Factory)",
    "GitLab composes ProcessExecutor, HttpDownloader (constructor injection, fallback to Factory)",
    "Bitbucket composes ProcessExecutor, HttpDownloader (constructor injection, fallback to Factory)",
    "AuthHelper creates GitHub, GitLab, Bitbucket on demand within promptAuthIfNeeded()",
    "HttpDownloader composes CurlDownloader (optional, curl extension required) and RemoteFilesystem",
    "HttpDownloader uses Url.getOrigin() and Url.sanitize()",
    "ProcessExecutor references GitHub.GITHUB_TOKEN_REGEX for credential masking in outputCommandRun()",
    "Svn composes ProcessExecutor",
    "Url is a static helper class; referenced by HttpDownloader, Git, ProcessExecutor"
  ],

  "structural_patterns": [
    "GitHub, GitLab, Bitbucket share identical structure: IOInterface + Config + ProcessExecutor + HttpDownloader; all have authorizeOAuth() and authorizeOAuthInteractively()",
    "HttpDownloader and ProcessExecutor both implement async job queue pattern with STATUS_QUEUED/STARTED/COMPLETED/FAILED/ABORTED states and countActiveJobs()/wait() lifecycle",
    "Filesystem delegates system calls to ProcessExecutor for rm/mv/xcopy/mklink commands",
    "Git.runCommand() orchestrates multi-protocol fallback (ssh/https/git) with per-provider auth delegation",
    "AuthHelper acts as a facade routing auth prompts to GitHub/GitLab/Bitbucket helpers based on origin domain"
  ],

  "external_dependencies": [
    "Composer\\IO\\IOInterface — I/O abstraction (all classes)",
    "Composer\\Config — configuration access (all classes except Filesystem)",
    "Composer\\Factory — HttpDownloader factory used by GitHub/GitLab/Bitbucket fallback",
    "Composer\\Util\\Http\\CurlDownloader — curl-based HTTP backend",
    "Composer\\Util\\Http\\Response — HTTP response DTO",
    "Composer\\Util\\RemoteFilesystem — fallback HTTP backend",
    "Composer\\Util\\StreamContextFactory — TLS defaults for HttpDownloader",
    "Composer\\Util\\Platform — env/OS utilities",
    "Composer\\Util\\Silencer — error suppression",
    "React\\Promise\\Promise / PromiseInterface — async job promises",
    "Symfony\\Component\\Process\\Process — process execution backend",
    "Symfony\\Component\\Finder\\Finder — directory iteration in Filesystem"
  ],

  "important_notes": "Git is the central orchestrator: it delegates to GitHub/GitLab/Bitbucket for host-specific auth and uses Filesystem for cleanup. AuthHelper mirrors the same provider routing. HttpDownloader prefers CurlDownloader (when curl extension is available) and falls back to RemoteFilesystem. Svn is standalone (no HTTP). Url is purely static. ProcessExecutor supports both sync (execute) and async (executeAsync) execution with a capped job queue (default 10, env COMPOSER_MAX_PARALLEL_PROCESSES).",

