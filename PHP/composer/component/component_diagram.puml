@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam arrow {
    Color #495057
    FontColor #6C757D
    FontSize 10
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Composer — PHP Dependency Manager\nComponent Architecture

' ─────────────────────────────────────────────
' CLI LAYER
' ─────────────────────────────────────────────
package "CLI Layer" {
    [Console Application] as ConsoleApp
    note right of ConsoleApp
        Application.php
        GithubActionError
        HtmlOutputFormatter
    end note

    [Commands] as Commands
    note right of Commands
        38 commands:
        install, update, require,
        remove, search, show,
        audit, bump, validate …
    end note
}

' ─────────────────────────────────────────────
' CORE LAYER
' ─────────────────────────────────────────────
package "Core Layer" {
    [Composer Facade] as ComposerFacade
    note right of ComposerFacade
        Composer.php
        PartialComposer.php
        InstalledVersions.php
    end note

    [Factory] as Factory
    [Config] as Config
    [Cache] as Cache
    [Installer] as Installer
    [Compiler] as Compiler
}

' ─────────────────────────────────────────────
' PACKAGE MANAGEMENT LAYER
' ─────────────────────────────────────────────
package "Package Management Layer" {
    [Package Model] as Package
    note right of Package
        Package, CompletePackage,
        AliasPackage, Link,
        Version, RootPackage
    end note

    [Repository] as Repository
    note right of Repository
        ComposerRepository,
        VcsRepository,
        PathRepository,
        InstalledFilesystemRepository,
        PlatformRepository …
    end note

    [Downloader] as Downloader
    note right of Downloader
        DownloadManager,
        FileDownloader, GitDownloader,
        ZipDownloader, TarDownloader …
    end note
}

' ─────────────────────────────────────────────
' DEPENDENCY RESOLUTION LAYER
' ─────────────────────────────────────────────
package "Dependency Resolution Layer" {
    [Dependency Resolver] as DepResolver
    note right of DepResolver
        Solver (SAT-based),
        Pool, PoolBuilder,
        Request, RuleSet,
        RuleSetGenerator …
    end note

    [Solver Operations] as SolverOps
    note right of SolverOps
        InstallOperation,
        UpdateOperation,
        UninstallOperation,
        MarkAliasInstalled …
    end note

    [Platform Requirement Filter] as PlatformFilter
    note right of PlatformFilter
        IgnoreAllPlatformRequirementFilter,
        IgnoreListPlatformRequirementFilter,
        PlatformRequirementFilterFactory
    end note
}

' ─────────────────────────────────────────────
' SECURITY LAYER
' ─────────────────────────────────────────────
package "Security Layer" {
    [Advisory] as Advisory
    note right of Advisory
        Auditor,
        SecurityAdvisory,
        PartialSecurityAdvisory,
        AuditConfig, IgnoredSecurityAdvisory
    end note

    [Filter List] as FilterList
    note right of FilterList
        FilterListConfig,
        FilterListAuditor,
        FilterListProviderConfig,
        ComposerRepositoryFilterInformation
    end note
}

' ─────────────────────────────────────────────
' INFRASTRUCTURE LAYER
' ─────────────────────────────────────────────
package "Infrastructure Layer" {
    [Autoload Generator] as Autoload
    note right of Autoload
        AutoloadGenerator,
        ClassLoader,
        ClassMapGenerator
    end note

    [Event Dispatcher] as EventDispatcher
    note right of EventDispatcher
        EventDispatcher,
        Event,
        ScriptExecutionException,
        EventSubscriberInterface
    end note

    [Plugin System] as Plugin
    note right of Plugin
        PluginInterface,
        PluginManager,
        Capability interfaces
    end note

    [IO / Util] as IOUtil
    note right of IOUtil
        IO (ConsoleIO, NullIO),
        Filesystem, Git,
        ProcessExecutor, Platform
    end note

    [JSON Handler] as Json
    note right of Json
        JsonFile, JsonManipulator,
        JsonValidationException
    end note
}

' ─────────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────────

' CLI → Core
ConsoleApp --> Commands        : registers
Commands    --> ComposerFacade : uses
Commands    --> Config         : reads

' Core internal
Factory        --> ComposerFacade : creates
ComposerFacade --> Installer      : delegates install to
ComposerFacade --> Config         : reads
ComposerFacade --> Cache          : caches via
Compiler       --> ComposerFacade : builds PHAR from

' Core → Package Management
Installer  --> Repository : queries
Installer  --> Downloader : downloads via
Installer  --> Package    : manages

' Core → Resolution
Installer   --> DepResolver : resolves deps via
DepResolver --> SolverOps   : produces
DepResolver --> PlatformFilter : applies
DepResolver --> Repository  : pools packages from

' Core → Security
Installer --> Advisory   : audits with
Advisory  --> FilterList : checks against

' Core → Infrastructure
ComposerFacade --> EventDispatcher : fires events
Installer      --> EventDispatcher : dispatches
Installer      --> Autoload        : generates autoload
Commands       --> Plugin          : loads
ComposerFacade --> Plugin          : manages
Commands       --> IOUtil          : writes output
Factory        --> Json            : parses composer.json
Repository     --> Json            : parses JSON metadata

@enduml
