@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam node {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam artifact {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
    FontColor #0C5460
}
skinparam database {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #533f03
}
skinparam cloud {
    BackgroundColor #E2D9F3
    BorderColor #6F42C1
    FontColor #4B2E83
}
skinparam component {
    BackgroundColor #D4EDDA
    BorderColor #155724
    FontColor #155724
}

title Composer (PHP Dependency Manager) — Deployment Diagram

'─────────────────────────────────────────────
' 1. SOURCE REPOSITORY
'─────────────────────────────────────────────
node "GitHub Repository\n(composer/composer)" <<Git>> as github_repo {
    artifact "PHP Source Files\n(src/, bin/, res/)" as src
    artifact "composer.json\n(project manifest)" as composer_json_src
    artifact ".github/workflows/\n(CI + Release pipelines)" as gh_workflows
}

'─────────────────────────────────────────────
' 2. CI/CD — GitHub Actions
'─────────────────────────────────────────────
node "GitHub Actions Runner\n(ubuntu-latest, PHP 8.4)" <<CI/CD>> as gh_actions {
    component "Continuous Integration\n(Unit tests, PHPStan)" as ci_job
    component "Compiler\n(bin/compile → Compiler.php)" as compiler
    component "GPG Signing\n(contact@packagist.com key)" as gpg_signer
    component "Provenance Attestation\n(actions/attest)" as attestation
}

'─────────────────────────────────────────────
' 3. RELEASE ARTIFACTS
'─────────────────────────────────────────────
node "GitHub Release\n(tagged versions)" <<Distribution>> as gh_release {
    artifact "composer.phar\n(self-contained PHAR, SHA-512)" as phar
    artifact "composer.phar.asc\n(GPG detached signature)" as phar_sig
}

'─────────────────────────────────────────────
' 4. DISTRIBUTION CHANNELS
'─────────────────────────────────────────────
cloud "getcomposer.org" <<Web>> as getcomposer {
    artifact "Installer Script\n(installer)" as installer_script
    artifact "Download Page\n(stable / preview)" as download_page
}

cloud "Docker Hub\n(composer/docker)" <<Container Registry>> as docker_hub {
    artifact "Docker Image\n(composer:<version>)" as docker_image
}

'─────────────────────────────────────────────
' 5. END-USER / DEVELOPER MACHINE
'─────────────────────────────────────────────
node "Developer / CI Machine" <<Host>> as dev_machine {

    node "PHP Runtime\n(PHP 7.2.5+ | 8.0+)" <<Runtime>> as php_runtime {
        artifact "composer.phar\n(deployed CLI tool)" as phar_runtime
    }

    node "Project Directory" <<Filesystem>> as project_dir {
        artifact "composer.json\n(project manifest)" as composer_json
        artifact "composer.lock\n(locked dependency tree)" as composer_lock
        artifact "vendor/\n(installed packages)" as vendor_dir
    }

    database "Local Cache\n(~/.composer/cache)" <<Filesystem>> as local_cache {
        artifact "cache/files/\n(downloaded ZIP archives)" as cache_files
        artifact "cache/repo/\n(repository metadata)" as cache_repo
        artifact "cache/vcs/\n(VCS clones)" as cache_vcs
    }
}

'─────────────────────────────────────────────
' 6. EXTERNAL PACKAGE REPOSITORIES
'─────────────────────────────────────────────
cloud "Packagist.org\n(repo.packagist.org)" <<Package Repository>> as packagist {
    artifact "Package Metadata\n(JSON API)" as packagist_meta
    artifact "Package Dist Files\n(ZIP / tar archives)" as packagist_dist
}

cloud "GitHub API\n(api.github.com)" <<VCS Host>> as github_api {
    artifact "Repository API\n(tags, branches, files)" as github_api_data
}

cloud "GitLab\n(gitlab.com)" <<VCS Host>> as gitlab {
    artifact "Repository API\n(tags, packages)" as gitlab_api_data
}

cloud "Bitbucket\n(bitbucket.org)" <<VCS Host>> as bitbucket {
    artifact "Repository API\n(packages, dist)" as bitbucket_api_data
}

cloud "Custom Composer\nRepository" <<Package Repository>> as custom_repo {
    artifact "packages.json\n(Satis / Toran)" as custom_meta
}

'─────────────────────────────────────────────
' RELATIONSHIPS — Build & Release Pipeline
'─────────────────────────────────────────────
github_repo --> gh_actions : "git push / tag\ntriggers workflow"
gh_actions --> ci_job : "runs tests &\nstatic analysis"
src --> compiler : "compiled into"
compiler --> phar : "php -d phar.readonly=0\nbin/compile → composer.phar\n(SHA-512 signed)"
phar --> gpg_signer : "signs"
gpg_signer --> phar_sig : "produces"
phar --> attestation : "provenance\nrecorded"
compiler --> gh_release : "uploads\nphar + signature"
gh_release --> getcomposer : "synced to\ndownload page"
gh_release --> docker_hub : "triggers Docker\nimage build"

'─────────────────────────────────────────────
' RELATIONSHIPS — Installation
'─────────────────────────────────────────────
getcomposer --> phar_runtime : "HTTPS download\n(installer script)"
docker_hub --> phar_runtime : "docker pull\ncomposer:<tag>"
gh_release --> phar_runtime : "direct HTTPS\ndownload"

'─────────────────────────────────────────────
' RELATIONSHIPS — Runtime
'─────────────────────────────────────────────
phar_runtime --> composer_json : "reads project\ndependencies"
phar_runtime --> composer_lock : "reads/writes\nlocked versions"
phar_runtime --> vendor_dir : "installs\npackages into"
phar_runtime --> local_cache : "caches\narchives & metadata"

phar_runtime --> packagist : "HTTPS — resolve\npackage metadata"
phar_runtime --> github_api : "HTTPS — GitHub API\n(oauth token optional)"
phar_runtime --> gitlab : "HTTPS — GitLab API\n(oauth/token optional)"
phar_runtime --> bitbucket : "HTTPS — Bitbucket API\n(oauth optional)"
phar_runtime --> custom_repo : "HTTPS — custom\nrepository endpoint"

@enduml
