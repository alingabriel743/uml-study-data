{
  "scope": "github_driver_api_flow",
  "title": "GitHub VCS Driver: API Interaction",
  "diagram_type": "sequence",
  "key_participants": [
    "VcsRepository",
    "GitHubDriver",
    "VcsDriver (parent)",
    "HttpDownloader",
    "Cache",
    "GitHub (Util)",
    "GitDriver (fallback)"
  ],
  "interaction_flow": [
    "== Initialization ==",
    "VcsRepository → GitHubDriver: initialize()",
    "GitHubDriver → Cache: new Cache(io, cache-repo-dir/originUrl/owner/repo)",
    "GitHubDriver → Cache: setReadOnly(config.cache-read-only)",
    "GitHubDriver → GitHubDriver: fetchRootIdentifier()",
    "GitHubDriver → HttpDownloader: get(apiUrl + '/repos/owner/repo', options) [via getContents()]",
    "HttpDownloader → GitHub API: GET /repos/{owner}/{repo}",
    "GitHub API → HttpDownloader: repoData JSON (default_branch, private, has_issues, archived)",
    "HttpDownloader → GitHubDriver: Response",
    "GitHubDriver → GitHubDriver: sets rootIdentifier, isPrivate, hasIssues, isArchived from repoData",

    "== getComposerInformation(identifier) ==",
    "VcsRepository → GitHubDriver: getComposerInformation(identifier)",
    "GitHubDriver → VcsDriver: shouldCache(identifier) [checks 40-char hex SHA]",
    "alt Cache HIT",
    "  GitHubDriver → Cache: read(identifier)",
    "  Cache → GitHubDriver: raw JSON string",
    "  GitHubDriver → JsonFile: parseJson(res)",
    "else Cache MISS",
    "  GitHubDriver → VcsDriver: getBaseComposerInformation(identifier)",
    "  VcsDriver → GitHubDriver: getFileContent('composer.json', identifier)",
    "  GitHubDriver → HttpDownloader: get(apiUrl + '/repos/owner/repo/contents/composer.json?ref=identifier')",
    "  GitHub API → HttpDownloader: base64-encoded file content",
    "  alt file > 1MB (encoding=none, git_url present)",
    "    GitHubDriver → HttpDownloader: get(git_url) [raw blob endpoint]",
    "  end",
    "  GitHubDriver → GitHubDriver: base64_decode(content)",
    "  GitHubDriver → Cache: write(identifier, JsonFile::encode(composer))",
    "end",
    "GitHubDriver → GitHubDriver: enrich composer (support.source, support.issues, abandoned, funding)",

    "== getTags() ==",
    "VcsRepository → GitHubDriver: getTags()",
    "loop paginate (Link header 'next')",
    "  GitHubDriver → HttpDownloader: get(apiUrl + '/repos/owner/repo/tags?per_page=100')",
    "  GitHub API → HttpDownloader: [{name, commit.sha}, ...]",
    "  GitHubDriver → GitHubDriver: getNextPage(response) from Link header",
    "end",
    "GitHubDriver → VcsRepository: map[tagName => sha]",

    "== getBranches() ==",
    "VcsRepository → GitHubDriver: getBranches()",
    "loop paginate (Link header 'next')",
    "  GitHubDriver → HttpDownloader: get(apiUrl + '/repos/owner/repo/git/refs/heads?per_page=100')",
    "  GitHub API → HttpDownloader: [{ref, object.sha}, ...] (skips 'gh-pages')",
    "  GitHubDriver → GitHubDriver: getNextPage(response)",
    "end",
    "GitHubDriver → VcsRepository: map[branchName => sha]",

    "== getDist(identifier) ==",
    "VcsRepository → GitHubDriver: getDist(identifier)",
    "GitHubDriver → VcsRepository: {type:'zip', url:apiUrl+'/repos/owner/repo/zipball/identifier', reference, shasum:''} [no HTTP call]",

    "== getSource(identifier) ==",
    "VcsRepository → GitHubDriver: getSource(identifier)",
    "GitHubDriver → VcsRepository: {type:'git', url: SSH if isPrivate else HTTPS, reference:identifier} [no HTTP call]",

    "== getContents() error handling ==",
    "GitHubDriver → VcsDriver: parent::getContents(url) → httpDownloader.get(url, options)",
    "alt TransportException 401/404",
    "  GitHubDriver → GitHub(Util): authorizeOAuth(originUrl)",
    "  alt not interactive",
    "    GitHubDriver → GitHubDriver: attemptCloneFallback() → setupGitDriver(sshUrl)",
    "    GitHubDriver → GitDriver: new GitDriver([url], io, config, httpDownloader, process)",
    "    GitHubDriver → GitDriver: initialize()",
    "  else interactive",
    "    GitHubDriver → GitHub(Util): authorizeOAuthInteractively(originUrl, message)",
    "    GitHubDriver → VcsDriver: parent::getContents(url) [retry]",
    "  end",
    "else TransportException 403 (rate limit)",
    "  GitHubDriver → GitHub(Util): isRateLimited(headers) / getRateLimit(headers)",
    "  GitHubDriver → IOInterface: writeError(rate limit message)",
    "end"
  ],
  "key_relationships": [
    "GitHubDriver extends VcsDriver",
    "GitHubDriver composes Cache (created in initialize())",
    "GitHubDriver depends_on HttpDownloader (injected via VcsDriver constructor)",
    "GitHubDriver depends_on GitHub (Util) [created on-demand in getContents() error handling]",
    "GitHubDriver delegates_to GitDriver (fallback when API unavailable or no-api config)",
    "VcsDriver owns getContents(url) → httpDownloader.get(url, options)",
    "VcsDriver owns getBaseComposerInformation(identifier) → calls getFileContent()",
    "VcsDriver owns shouldCache(identifier) [regex: 40-char hex SHA]",
    "Cache depends_on Filesystem, IOInterface"
  ],
  "api_endpoints": [
    "GET /repos/{owner}/{repo}  → fetchRootIdentifier (repo metadata)",
    "GET /repos/{owner}/{repo}/contents/{file}?ref={id}  → getFileContent (composer.json)",
    "GET /repos/{owner}/{repo}/tags?per_page=100  → getTags (paginated)",
    "GET /repos/{owner}/{repo}/git/refs/heads?per_page=100  → getBranches (paginated)",
    "GET /repos/{owner}/{repo}/zipball/{id}  → getDist URL (not fetched, just returned)",
    "GET /repos/{owner}/{repo}/contents/.github/FUNDING.yml  → getFundingInfo",
    "GET /repos/{owner}/.github/contents/FUNDING.yml  → getFundingInfo (fallback)",
    "GET /{git_url} (blob)  → getFileContent large file fallback"
  ],
  "cache_strategy": {
    "key": "identifier (SHA1 40-char hex only, checked by shouldCache())",
    "location": "config[cache-repo-dir]/{originUrl}/{owner}/{repo}/{identifier}",
    "read": "cache.read(identifier) → file_get_contents",
    "write": "cache.write(identifier, json) → atomic write via tmp file + rename",
    "read_only_mode": "set via config[cache-read-only]; writes skipped"
  },
  "fallback_logic": {
    "trigger": "config use-github-api=false OR repoConfig[no-api]=true OR TransportException(499) OR clone fallback",
    "action": "setupGitDriver(url) → new GitDriver + initialize(); all subsequent calls delegated to gitDriver"
  },
  "important_notes": "GitHubDriver overrides getContents() to add OAuth retry/interactive auth on 401/403/404. getDist returns a direct zip URL without making an HTTP request. getTags/getBranches both auto-paginate using Link response header. Cache only applies to SHA identifiers (40-char hex), not branch/tag names.",
  "source_files_analyzed": [
    "src/Composer/Repository/Vcs/GitHubDriver.php",
    "src/Composer/Cache.php",
    "src/Composer/Repository/Vcs/VcsDriver.php (key methods via grep)"
  ]
}
