{
  "scope": "show_command_flow",
  "title": "Show Command: Package Information Display",
  "diagram_type": "sequence",
  "key_participants": [
    "CLI/User",
    "ShowCommand",
    "InstalledRepository",
    "CompositeRepository",
    "RepositorySet",
    "Pool",
    "DefaultPolicy",
    "VersionSelector",
    "Package (CompletePackageInterface)",
    "IOInterface"
  ],
  "class_info": {
    "ShowCommand": {
      "extends": "BaseCommand",
      "namespace": "Composer\\Command",
      "key_methods": [
        "configure(): void",
        "execute(InputInterface $input, OutputInterface $output): int",
        "getPackage(InstalledRepository $installedRepo, RepositoryInterface $repos, string $name, $version=null): array{CompletePackageInterface|null, array<string,string>}",
        "printPackageInfo(CompletePackageInterface $package, array $versions, InstalledRepository $installedRepo, ?PackageInterface $latestPackage=null): void",
        "printMeta(CompletePackageInterface $package, array $versions, InstalledRepository $installedRepo, ?PackageInterface $latestPackage=null): void",
        "printVersions(CompletePackageInterface $package, array $versions, InstalledRepository $installedRepo): void",
        "printLinks(CompletePackageInterface $package, string $linkType, ?string $title=null): void",
        "printPackages(IOInterface $io, array $packages, ...): void",
        "printPackageInfoAsJson(CompletePackageInterface $package, array $versions, InstalledRepository $installedRepo, ?PackageInterface $latestPackage=null): void",
        "findLatestPackage(PackageInterface $package, Composer $composer, PlatformRepository $platformRepo, bool $majorOnly, bool $minorOnly, bool $patchOnly, PlatformRequirementFilterInterface $platformReqFilter): ?PackageInterface",
        "generatePackageTree(PackageInterface $package, InstalledRepository $installedRepo, RepositoryInterface $repos): array",
        "displayPackageTree(array $arrayTree): void",
        "getUpdateStatus(PackageInterface $latestPackage, PackageInterface $package): string",
        "getVersionStyle(PackageInterface $latestPackage, PackageInterface $package): string"
      ]
    },
    "CompositeRepository": {
      "implements": "RepositoryInterface",
      "namespace": "Composer\\Repository",
      "key_methods": [
        "__construct(array $repositories)",
        "addRepository(RepositoryInterface $repository): void",
        "findPackage($name, $constraint): ?BasePackage",
        "findPackages($name, $constraint=null): array",
        "getPackages(): array",
        "hasPackage(PackageInterface $package): bool",
        "search(string $query, int $mode=0, ?string $type=null): array",
        "getRepositories(): array",
        "count(): int"
      ],
      "notes": "Delegates all calls to each wrapped RepositoryInterface; flattens nested CompositeRepositories on addRepository()"
    }
  },
  "interaction_flow": [
    "CLI/User → ShowCommand: execute(InputInterface $input, OutputInterface $output)",
    "ShowCommand → ShowCommand: resolve display mode from options (--self|--platform|--available|--all|--locked|default)",
    "ShowCommand → PlatformRepository: new PlatformRepository([], $platformOverrides)",
    "ShowCommand → Composer: getRepositoryManager()->getLocalRepository()",
    "ShowCommand → InstalledRepository: new InstalledRepository([$localRepo, $platformRepo, ...])",
    "ShowCommand → CompositeRepository: new CompositeRepository($composer->getRepositoryManager()->getRepositories())",
    "ShowCommand → EventDispatcher: dispatch('show', CommandEvent) [if composer available]",
    "--- BRANCH: single package display ---",
    "ShowCommand → ShowCommand: getPackage($installedRepo, $repos, $packageFilter, $version)",
    "ShowCommand.getPackage → RepositorySet: new RepositorySet('dev'); addRepository($repos)",
    "ShowCommand.getPackage → RepositorySet: createPoolForPackage($name) or createPoolWithAllPackages()",
    "ShowCommand.getPackage → Pool: whatProvides($name, $constraint) → PackageInterface[]",
    "ShowCommand.getPackage → InstalledRepository: hasPackage($package) [find exact match]",
    "ShowCommand.getPackage → DefaultPolicy: selectPreferredPackages($pool, $literals) [if no exact match]",
    "ShowCommand.getPackage → Pool: literalToPackage($preferred[0]) → CompletePackageInterface",
    "ShowCommand → ShowCommand: findLatestPackage($package, $composer, ...) [if --latest]",
    "ShowCommand.findLatestPackage → VersionSelector: findBestCandidate($name, $targetVersion, $bestStability, ...) → PackageInterface",
    "ShowCommand → ShowCommand: generatePackageTree(...) [if --tree]",
    "ShowCommand → ShowCommand: displayPackageTree($arrayTree) [text] OR io->write(JsonFile::encode()) [json]",
    "ShowCommand → ShowCommand: printPackageInfo($package, $versions, $installedRepo, $latestPackage) [text format]",
    "ShowCommand.printPackageInfo → ShowCommand: printMeta($package, $versions, $installedRepo, $latestPackage)",
    "ShowCommand.printMeta → InstalledRepository: hasPackage($package) → bool",
    "ShowCommand.printMeta → Package: getPrettyName(), getDescription(), getKeywords(), getType(), getHomepage(), getSourceType/Url/Reference(), getDistType/Url/Reference(), getNames()",
    "ShowCommand.printMeta → ShowCommand: printVersions($package, $versions, $installedRepo)",
    "ShowCommand.printVersions → InstalledRepository: findPackages($package->getName()) → PackageInterface[]",
    "ShowCommand.printVersions → Semver: rsort($versions) → sorted array",
    "ShowCommand.printVersions → IOInterface: write('<info>versions</info> : ...')",
    "ShowCommand.printMeta → ShowCommand: getVersionStyle($latestPackage, $package) → string",
    "ShowCommand.printMeta → IOInterface: write(name, description, keywords, versions, type, licenses, homepage, source, dist, path, names)",
    "ShowCommand.printPackageInfo → ShowCommand: printLinks($package, TYPE_REQUIRE)",
    "ShowCommand.printPackageInfo → ShowCommand: printLinks($package, TYPE_DEV_REQUIRE)",
    "ShowCommand.printPackageInfo → ShowCommand: printLinks($package, TYPE_PROVIDE|CONFLICT|REPLACE)",
    "ShowCommand → ShowCommand: printPackageInfoAsJson(...) [json format]",
    "--- BRANCH: list packages display ---",
    "ShowCommand → RepositoryUtils: flattenRepositories($repos) → RepositoryInterface[]",
    "ShowCommand → each repo: getPackages() OR getPackageNames($filter) [ComposerRepository]",
    "ShowCommand → ShowCommand: findLatestPackage(each package, ...) [if --latest]",
    "ShowCommand → Package: getPrettyName(), getFullPrettyVersion(), getDescription(), getReleaseDate()",
    "ShowCommand → InstallationManager: getInstallPath($package) [if --path]",
    "ShowCommand → IOInterface: write(JsonFile::encode($viewData)) [json] OR printPackages()/writeError() [text]"
  ],
  "display_mode_resolution": {
    "--self": "InstalledRepository([RootPackageRepository($rootPkg)])",
    "--platform / -p": "InstalledRepository([$platformRepo])",
    "--available / -a": "repos = CompositeRepository(all remote repos); installedRepo includes localRepo",
    "--all (with composer)": "repos = CompositeRepository([FilterRepository($installedRepo), ...remoteRepos]); installedRepo includes lockedRepo+localRepo+platformRepo",
    "--locked": "installedRepo = InstalledRepository([$lockedRepo]) from Locker::getLockedRepository()",
    "default (installed)": "repos = installedRepo = InstalledRepository([$rootRepo, $localRepo])"
  },
  "key_relationships": [
    "ShowCommand extends BaseCommand",
    "ShowCommand depends_on CompositeRepository (wraps remote repositories for --available/--all)",
    "ShowCommand depends_on InstalledRepository (wraps local installed packages)",
    "ShowCommand depends_on RepositorySet + Pool (package lookup/resolution in getPackage())",
    "ShowCommand depends_on DefaultPolicy (selects preferred package from pool literals)",
    "ShowCommand depends_on VersionSelector (finds latest/best-candidate package)",
    "CompositeRepository implements RepositoryInterface",
    "CompositeRepository aggregates RepositoryInterface[] (delegates all queries)",
    "InstalledRepository aggregates RepositoryInterface[] (local/locked/platform repos)",
    "Pool created by RepositorySet; provides whatProvides(name, constraint)",
    "VersionSelector uses RepositorySet + PlatformRepository to find best candidate"
  ],
  "output_formats": {
    "text": "Columnar list via printPackages() or detailed printPackageInfo()/printMeta()/printVersions()/printLinks()",
    "json": "JsonFile::encode($viewData) for lists; printPackageInfoAsJson() for single package",
    "tree": "generatePackageTree() → displayPackageTree() or JsonFile::encode(['installed'=>$arrayTree])"
  },
  "important_notes": [
    "ShowCommand also aliased as 'info'",
    "Single-package flow: getPackage() builds RepositorySet→Pool→whatProvides() then DefaultPolicy selects best; returns [CompletePackageInterface, versions[]]",
    "List flow: iterates flattenRepositories(), categorises each as platform/locked/installed/available, builds $viewData array, then renders",
    "findLatestPackage respects --major-only/--minor-only/--patch-only by building targetVersion constraint before calling VersionSelector::findBestCandidate()",
    "--outdated sets --latest=true internally; --strict returns exit code 1 when outdated packages found",
    "printMeta calls InstallationManager::getInstallPath() only when package is installed (not platform package)"
  ],
  "source_files_analyzed": [
    "src/Composer/Command/ShowCommand.php",
    "src/Composer/Repository/CompositeRepository.php"
  ]
}
