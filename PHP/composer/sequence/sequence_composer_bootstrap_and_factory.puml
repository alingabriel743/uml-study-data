@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    GroupBackgroundColor #E9ECEF
    GroupBorderColor #6C757D
    DividerBackgroundColor #DEE2E6
    DividerBorderColor #6C757D
}
skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F0AD4E

title Composer Bootstrap and Factory Initialization

actor Caller
participant "Factory" as factory
participant "JsonFile" as jsonFile
participant "Config" as config
participant "IOInterface" as io
participant "HttpDownloader" as httpDl
participant "ProcessExecutor" as process
participant "Loop" as loop
participant "EventDispatcher" as dispatcher
participant "RepositoryManager" as rm
participant "RootPackageLoader" as rpl
participant "InstallationManager" as im
participant "DownloadManager" as dm
participant "Locker" as locker
participant "PluginManager" as pm
participant "Composer\n/ PartialComposer" as composer

== Entry Point ==

Caller -> factory : create(io, config, disablePlugins, disableScripts)  [static]
activate factory

factory -> factory : new static() → $factory
factory -> factory : createComposer(io, config, disablePlugins, cwd=null, fullLoad=true, disableScripts)
note right of factory : Main wiring method

== Resolve Composer File ==

factory -> factory : getComposerFile()  [reads COMPOSER env or './composer.json']
factory -> jsonFile : new JsonFile(composerFile, null, io)
activate jsonFile
factory -> jsonFile : exists() → bool
factory -> jsonFile : validateSchema(LAX_SCHEMA)
factory -> jsonFile : read() → $localConfig (array)
deactivate jsonFile

== Config Creation (layered merge) ==

factory -> factory : createConfig(io, cwd)  [static]
activate factory
factory -> config : new Config(useEnvironment=true, cwd)
activate config
config -> config : load $defaultConfig + $defaultRepositories
note right of config
  Layer 1: built-in defaults
  + default packagist repository
end note
factory -> config : merge([home, cache-dir, data-dir], SOURCE_DEFAULT)

factory -> jsonFile : new JsonFile($COMPOSER_HOME/config.json)
activate jsonFile
factory -> jsonFile : exists() + read() → globalConfig
deactivate jsonFile
factory -> config : merge(globalConfig, filePath)
note right of config : Layer 2: global config.json

factory -> config : setConfigSource(new JsonConfigSource(globalConfigFile))

factory -> jsonFile : new JsonFile($COMPOSER_HOME/auth.json)
activate jsonFile
factory -> jsonFile : exists() + read() → globalAuthData
deactivate jsonFile
factory -> config : merge(['config' => globalAuthData], filePath)
note right of config : Layer 3: global auth.json
factory -> config : setAuthConfigSource(new JsonConfigSource(authFile, isAuth=true))

factory -> factory : loadComposerAuthEnv(config, io)
note right of factory : Layer 4: COMPOSER_AUTH env var

factory --> factory : returns Config
deactivate factory

== Merge Local Config ==

factory -> config : merge(localConfig, localConfigSource)
note right of config : Layer 5: local composer.json
factory -> config : setConfigSource(new JsonConfigSource(realpath(composerFile)))

factory -> jsonFile : new JsonFile(dirname/auth.json)
activate jsonFile
factory -> jsonFile : exists() + read() → localAuthData
deactivate jsonFile
factory -> config : merge(['config' => localAuthData], path)
note right of config : Layer 6: local auth.json
factory -> config : setLocalAuthConfigSource(new JsonConfigSource(localAuthFile, true))

factory -> factory : loadComposerAuthEnv(config, io)
note right of factory : Layer 7: COMPOSER_AUTH re-applied last

== Composer Instantiation ==

alt fullLoad = true
    factory -> composer : new Composer()
else fullLoad = false
    factory -> composer : new PartialComposer()
end

activate composer
factory -> composer : setConfig(config)

opt isGlobal = true
    factory -> composer : setGlobal()
end

opt fullLoad = true
    factory -> io : loadConfiguration(config)
    note right of io : Load auth credentials into IO
end

== Core Service Wiring ==

factory -> httpDl : createHttpDownloader(io, config) → HttpDownloader
activate httpDl
factory -> process : new ProcessExecutor(io)
activate process
factory -> loop : new Loop(httpDownloader, process)
activate loop
factory -> composer : setLoop(loop)

factory -> dispatcher : new EventDispatcher(composer, io, process)
activate dispatcher
factory -> dispatcher : setRunScripts(!disableScripts)
factory -> composer : setEventDispatcher(dispatcher)

factory -> rm : RepositoryFactory::manager(io, config, httpDownloader, dispatcher, process) → RepositoryManager
activate rm
factory -> composer : setRepositoryManager(rm)

== Root Package Loading ==

factory -> rpl : new VersionParser() + new VersionGuesser(config, process, parser, io)
factory -> rpl : loadRootPackage(rm, config, parser, guesser, io) → RootPackageLoader
activate rpl
factory -> rpl : load(localConfig, 'RootPackage', cwd) → $package
rpl --> factory : RootPackage
deactivate rpl

factory -> composer : setPackage(package)
factory -> rm : addLocalRepository(vendorDir/composer/installed.json)
factory -> rm : setLocalRepository(InstalledFilesystemRepository)

== Installation Manager ==

factory -> im : createInstallationManager(loop, io, dispatcher) → InstallationManager
activate im
factory -> composer : setInstallationManager(im)

== Full-Load Only Services ==

alt fullLoad = true (Composer instance)
    factory -> dm : createDownloadManager(io, config, httpDownloader, process, dispatcher) → DownloadManager
    activate dm
    factory -> composer : setDownloadManager(dm)

    factory -> composer : setAutoloadGenerator(new AutoloadGenerator(dispatcher, io))

    factory -> composer : setArchiveManager(createArchiveManager(config, dm, loop))
end

factory -> factory : createDefaultInstallers(im, composer, io, process)
note right of factory : Adds LibraryInstaller,\nPluginInstaller,\nMetapackageInstaller

== Locker ==

factory -> factory : getLockFile(composerFile) → lockFilePath
factory -> locker : new Locker(io, JsonFile(lockFile), im, file_get_contents(composerFile), process)
activate locker
factory -> composer : setLocker(locker)

== Plugin Manager ==

opt !isGlobal
    factory -> factory : createGlobalComposer(io, config, disablePlugins, disableScripts) → globalComposer
    note right of factory : Recursive createComposer() call\npointing at $COMPOSER_HOME/composer.json
end

factory -> pm : createPluginManager(io, composer, globalComposer, disablePlugins) → PluginManager
activate pm
factory -> composer : setPluginManager(pm)
factory -> pm : loadInstalledPlugins()

== Final Boot Events ==

opt fullLoad = true
    factory -> dispatcher : dispatch(PluginEvents::INIT)
    factory -> factory : purgePackages(rm.getLocalRepository(), im)
    note right of factory : Remove packages missing from disk
end

factory --> Caller : return Composer
deactivate composer
deactivate pm
deactivate locker
deactivate dm
deactivate im
deactivate rm
deactivate dispatcher
deactivate loop
deactivate process
deactivate httpDl
deactivate config
deactivate factory

@enduml
