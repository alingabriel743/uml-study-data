@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    BoxBorderColor #6C757D
    BoxBackgroundColor #F1F3F5
    GroupBorderColor #6C757D
    GroupBackgroundColor #DEE2E6
    DividerBackgroundColor #CED4DA
    DividerBorderColor #6C757D
}

title Installer Run: Full Install/Update Orchestration

participant "Installer" as installer
participant "Locker" as locker
participant "DownloadManager" as dlmgr
participant "RepositoryManager" as repomgr
participant "RepositorySet" as reposet
participant "Request" as request
participant "Pool" as pool
participant "Solver" as solver
participant "LocalRepoTransaction" as localtx
participant "InstallationManager" as instmgr
participant "EventDispatcher" as evtdisp
participant "AutoloadGenerator" as autogen
participant "Auditor" as auditor

== Installer::run() ==

installer -> installer: gc_collect_cycles() / gc_disable()
activate installer

installer -> locker: isLocked()
activate locker
locker --> installer: bool $isLocked
deactivate locker

alt !update && !isLocked
    installer -> installer: force update = true
end

installer -> dlmgr: setPreferSource() / setPreferDist() / setSourceFallback()
activate dlmgr
deactivate dlmgr

installer -> repomgr: getLocalRepository()
activate repomgr
repomgr --> installer: $localRepo
deactivate repomgr

alt update = true
    installer -> installer: doUpdate($localRepo, $doInstall)
else update = false
    installer -> installer: doInstall($localRepo)
end

opt runScripts
    installer -> evtdisp: dispatchScript(PRE_UPDATE_CMD | PRE_INSTALL_CMD)
    activate evtdisp
    deactivate evtdisp
end

opt dumpAutoloader
    installer -> autogen: dump(config, localRepo, package, installationManager, ...)
    activate autogen
    autogen --> installer: autoload files written
    deactivate autogen
end

installer -> instmgr: ensureBinariesPresence($package) [for each package]
activate instmgr
deactivate instmgr

opt runScripts
    installer -> evtdisp: dispatchScript(POST_UPDATE_CMD | POST_INSTALL_CMD)
    activate evtdisp
    deactivate evtdisp
end

opt auditConfig.audit
    installer -> auditor: audit(io, repoSet, packages, ...)
    activate auditor
    auditor --> installer: audit result
    deactivate auditor
end

deactivate installer

== Installer::doUpdate($localRepo, $doInstall) ==

installer -> installer: createPlatformRepo(true)
activate installer

installer -> locker: isLocked()
activate locker
locker --> installer: bool
deactivate locker

opt isLocked
    installer -> locker: getLockedRepository(true)
    activate locker
    locker --> installer: $lockedRepository
    deactivate locker
end

installer -> installer: createPolicy(true, $lockedRepository)
note right: returns DefaultPolicy

installer -> installer: createRepositorySet(true, $platformRepo, $aliases)

    installer -> reposet: new RepositorySet(minimumStability, stabilityFlags, aliases, ...)
    activate reposet
    installer -> reposet: addRepository(RootPackageRepository)
    installer -> reposet: addRepository($platformRepo)

installer -> repomgr: getRepositories()
activate repomgr
repomgr --> installer: $repositories[]
deactivate repomgr

loop for each $repository
    installer -> reposet: addRepository($repository)
end

opt isLocked
    installer -> reposet: addRepository($lockedRepository)
end

installer -> installer: createRequest($fixedRootPackage, $platformRepo, $lockedRepository)

    installer -> request: new Request($lockedRepository)
    activate request
    installer -> request: fixPackage($fixedRootPackage)

opt updateAllowList set
    installer -> request: setUpdateAllowList(...)
end

installer -> reposet: createPool($request, $io, $eventDispatcher, $poolOptimizer, ...)
reposet -> pool: [PoolBuilder builds pool]
activate pool
pool --> reposet: Pool
deactivate pool
reposet --> installer: $pool
deactivate reposet

installer -> solver: new Solver($policy, $pool, $io)
activate solver
installer -> solver: solve($request, $platformRequirementFilter)
solver --> installer: LockTransaction
deactivate solver

installer -> installer: extractDevPackages($lockTransaction, ...) [second solver pass for non-dev]

installer -> locker: setLockData(newLockPackages, devPackages, platformReqs, ...)
activate locker
note right: writes composer.lock
locker --> installer: void
deactivate locker

opt doInstall
    installer -> installer: doInstall($localRepo, alreadySolved=true)
end

deactivate installer

== Installer::doInstall($localRepo, $alreadySolved) ==

activate installer
installer -> locker: getLockedRepository($devMode)
activate locker
locker --> installer: $lockedRepository
deactivate locker

alt !alreadySolved
    installer -> installer: createPlatformRepo(false)
    installer -> installer: createPolicy(false)
    installer -> installer: createRepositorySet(false, $platformRepo, [], $lockedRepository)
    installer -> reposet: addRepository($lockedRepository)
    activate reposet
    deactivate reposet
    installer -> installer: createRequest($fixedRootPackage, $platformRepo, $lockedRepository)
    installer -> request: fixLockedPackage($pkg) [for each locked package]
    activate request
    deactivate request
    installer -> locker: isFresh()
    activate locker
    locker --> installer: bool [warn if stale]
    deactivate locker
    installer -> reposet: createPool($request, $io, $eventDispatcher, null, ...)
    activate reposet
    reposet -> pool: [PoolBuilder builds pool]
    activate pool
    pool --> reposet: Pool
    deactivate pool
    reposet --> installer: $pool
    deactivate reposet
    installer -> solver: new Solver($policy, $pool, $io)
    activate solver
    installer -> solver: solve($request, ...) [validates lock file]
    solver --> installer: LockTransaction
    deactivate solver
end

installer -> localtx: new LocalRepoTransaction($lockedRepository, $localRepo)
activate localtx
note right: computes install/update/uninstall operations\nby diffing locked vs installed packages
localtx --> installer: $localRepoTransaction
deactivate localtx

installer -> evtdisp: dispatchInstallerEvent(PRE_OPERATIONS_EXEC, $devMode, $executeOperations, $localRepoTransaction)
activate evtdisp
deactivate evtdisp

alt executeOperations
    installer -> instmgr: execute($localRepo, $operations, $devMode, $runScripts, $downloadOnly)
    activate instmgr
    instmgr --> installer: void
    deactivate instmgr
else dry-run / no execution
    installer -> installer: output operations without executing
end

deactivate installer

@enduml
