@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam sequenceGroupBorderColor #6C757D
skinparam noteBackgroundColor #FFF3CD
skinparam noteBorderColor #FFC107

title Repository Set and Policy Creation

participant "Installer" as installer
participant "Config" as config
participant "Locker" as locker
participant "PlatformRepository" as platformRepo
participant "RootPackageRepository" as rootPkgRepo
participant "RepositorySet" as repoSet
participant "LockArrayRepository" as lockArrayRepo
participant "RepositoryManager" as repoMgr
participant "CompositeRepository" as compositeRepo
participant "DefaultPolicy" as policy
participant "Request" as request

== Entry Points ==

alt forUpdate = true  [doUpdate() path]

    note over installer: doUpdate() — reads live\nconfiguration from package/config

    ' --- createPlatformRepo(true) ---
    installer -> installer: createPlatformRepo(true)
    activate installer
    installer -> config: get('platform')
    activate config
    config --> installer: platformOverrides[]
    deactivate config
    installer -> platformRepo: new PlatformRepository([], platformOverrides)
    activate platformRepo
    note right of platformRepo: Lazy-initialises PHP,\nextensions, and libs\non first access
    platformRepo --> installer: PlatformRepository
    deactivate platformRepo
    deactivate installer

    ' --- createPolicy(true, lockedRepo?) ---
    installer -> installer: createPolicy(true, lockedRepo?)
    activate installer
    installer -> installer: $this->package->getPreferStable()\n$this->package->getPreferLowest()

    opt minimalUpdate = true AND lockedRepo != null
        installer -> lockArrayRepo: getPackages()
        activate lockArrayRepo
        lockArrayRepo --> installer: packages[]
        deactivate lockArrayRepo
        note right of installer: Builds preferredVersions map\nfrom locked packages
    end

    installer -> policy: new DefaultPolicy(preferStable, preferLowest,\npreferredVersions?)
    activate policy
    policy --> installer: DefaultPolicy
    deactivate policy
    deactivate installer

    ' --- createRepositorySet(true, platformRepo, aliases) ---
    installer -> installer: createRepositorySet(true, platformRepo, rootAliases)
    activate installer
    installer -> installer: $this->package->getMinimumStability()
    installer -> installer: $this->package->getStabilityFlags()
    installer -> installer: getRequires() + getDevRequires()\n→ filter via platformRequirementFilter
    installer -> installer: clone $this->package\n→ fixedRootPackage\n(clears requires/devRequires)

    installer -> repoSet: new RepositorySet(minimumStability, stabilityFlags,\nrootAliases, references, rootRequires, tempConstraints)
    activate repoSet

    installer -> rootPkgRepo: new RootPackageRepository(fixedRootPackage)
    activate rootPkgRepo
    rootPkgRepo --> installer: RootPackageRepository
    deactivate rootPkgRepo

    installer -> repoSet: addRepository(RootPackageRepository)
    installer -> repoSet: addRepository(platformRepo)

    opt additionalFixedRepository exists
        alt additionalFixedRepository is CompositeRepository
            installer -> compositeRepo: getRepositories()
            activate compositeRepo
            compositeRepo --> installer: subRepos[]
            deactivate compositeRepo
            loop each subRepo
                installer -> repoSet: addRepository(subRepo)
            end
            opt subRepo is InstalledRepository
                installer -> repoSet: allowInstalledRepositories()
            end
        else
            installer -> repoSet: addRepository(additionalFixedRepository)
        end
    end

    repoSet --> installer: RepositorySet
    deactivate repoSet
    deactivate installer

    ' --- Add remote repos from RepositoryManager ---
    installer -> repoMgr: getRepositories()
    activate repoMgr
    repoMgr --> installer: repositories[]
    deactivate repoMgr
    loop each remote repository
        installer -> repoSet: addRepository(repo)
        activate repoSet
        deactivate repoSet
    end

    opt lockedRepository exists
        installer -> repoSet: addRepository(lockedRepository: LockArrayRepository)
        activate repoSet
        deactivate repoSet
    end

else forUpdate = false  [doInstall() path]

    note over installer: doInstall() — reads configuration\nfrom the lock file (Locker)

    ' --- Read locked repository ---
    installer -> locker: getLockedRepository(devMode)
    activate locker
    locker --> installer: LockArrayRepository
    deactivate locker

    ' --- createPlatformRepo(false) ---
    installer -> installer: createPlatformRepo(false)
    activate installer
    installer -> locker: getPlatformOverrides()
    activate locker
    locker --> installer: platformOverrides[]
    deactivate locker
    installer -> platformRepo: new PlatformRepository([], platformOverrides)
    activate platformRepo
    platformRepo --> installer: PlatformRepository
    deactivate platformRepo
    deactivate installer

    ' --- createPolicy(false) ---
    installer -> installer: createPolicy(false)
    activate installer
    installer -> locker: getPreferStable()
    activate locker
    locker --> installer: preferStable
    deactivate locker
    installer -> locker: getPreferLowest()
    activate locker
    locker --> installer: preferLowest
    deactivate locker
    installer -> policy: new DefaultPolicy(preferStable, preferLowest, null)
    activate policy
    policy --> installer: DefaultPolicy
    deactivate policy
    deactivate installer

    ' --- createRepositorySet(false, platformRepo, [], lockedRepository) ---
    installer -> installer: createRepositorySet(false, platformRepo, [],\nlockedRepository)
    activate installer
    installer -> locker: getMinimumStability()
    activate locker
    locker --> installer: minimumStability
    deactivate locker
    installer -> locker: getStabilityFlags()
    activate locker
    locker --> installer: stabilityFlags[]
    deactivate locker

    installer -> lockArrayRepo: getPackages()
    activate lockArrayRepo
    lockArrayRepo --> installer: packages[]
    deactivate lockArrayRepo
    note right of installer: Builds requires[] as\nexact-version constraints\nfrom locked packages

    installer -> repoSet: new RepositorySet(minimumStability, stabilityFlags,\n[], [], rootRequires, [])
    activate repoSet

    installer -> rootPkgRepo: new RootPackageRepository(fixedRootPackage)
    activate rootPkgRepo
    rootPkgRepo --> installer: RootPackageRepository
    deactivate rootPkgRepo

    installer -> repoSet: addRepository(RootPackageRepository)
    installer -> repoSet: addRepository(platformRepo)

    repoSet --> installer: RepositorySet
    deactivate repoSet
    deactivate installer

    installer -> repoSet: addRepository(lockedRepository: LockArrayRepository)
    activate repoSet
    deactivate repoSet

end

== Create Request ==

installer -> installer: createRequest(fixedRootPackage, platformRepo,\nlockedRepository?)
activate installer
installer -> request: new Request(lockedRepository?)
activate request
request --> installer: Request
deactivate request
installer -> request: fixPackage(rootPackage)
activate request
deactivate request
opt platformRepo packages present
    loop each platform package
        installer -> request: fixConstraint(pkg, constraint)
        activate request
        deactivate request
    end
end
installer --> installer: Request ready
deactivate installer

note over installer, request: RepositorySet + DefaultPolicy + Request are\nnow ready to be handed off to PoolBuilder / Solver

@enduml
