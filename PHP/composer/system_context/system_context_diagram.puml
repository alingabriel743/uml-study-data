@startuml
title Composer — PHP Dependency Manager\nSystem Context Diagram

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actor {
    BackgroundColor<<Person>> #08427B
    FontColor<<Person>> #FFFFFF
    BorderColor<<Person>> #052E56
}

skinparam arrow {
    Color #424242
    FontSize 10
    FontColor #616161
}

' ── Actors ──────────────────────────────────────────────────────────────────
actor "PHP Developer\n[CLI / Shell]" as developer <<Person>>
actor "CI/CD Pipeline\n[GitHub Actions / Jenkins]" as cicd <<Person>>
actor "Package Maintainer\n[Publishes packages]" as maintainer <<Person>>

' ── Core System ─────────────────────────────────────────────────────────────
rectangle "**Composer**\n[PHP Dependency Manager]\n\nResolves, downloads and installs\nPHP package dependencies.\nManages composer.json / composer.lock,\nautoloading, and version constraints." as system <<System>>

' ── Local Infrastructure ─────────────────────────────────────────────────────
rectangle "**Local Filesystem Cache**\n[~/.composer/cache]\n\nCaches downloaded ZIP archives,\nmetadata, and VCS clones to\navoid redundant network requests." as cache <<Cache>>

rectangle "**Project Filesystem**\n[vendor/ directory]\n\nInstalled package source files,\nautoload maps, and\ncomposer.lock snapshot." as vendor <<Database>>

rectangle "**Artifact Repository**\n[Local ZIP Archives]\n\nOffline package archives\nresolved from local paths\nor mounted directories." as artifact <<Database>>

' ── Package Registries ───────────────────────────────────────────────────────
rectangle "**Packagist.org**\n[Default Composer Registry]\n\nCentral PHP package index.\nExposes packages.json metadata\nand dist download URLs." as packagist <<External>>

rectangle "**Private Composer Repository**\n[Satis / Toran Proxy]\n\nSelf-hosted registry for\nproprietary or mirrored\npackage metadata." as private_repo <<External>>

rectangle "**PEAR Repository**\n[Legacy PHP Registry]\n\nLegacy PEAR channel packages\nresolved via channel XML\nand REST API." as pear <<External>>

' ── VCS Platforms ────────────────────────────────────────────────────────────
rectangle "**GitHub**\n[Git Hosting + OAuth API]\n\nSource code repository,\nrelease tarballs, and\nOAuth token authentication." as github <<External>>

rectangle "**GitLab**\n[Git Hosting + OAuth API]\n\nSelf-hosted or cloud Git forge.\nPackage metadata, archive\ndownloads, OAuth 2.0 tokens." as gitlab <<External>>

rectangle "**Bitbucket**\n[Git/Hg Hosting + OAuth API]\n\nAtlassian-hosted repositories.\nOAuth 2.0 consumer tokens\nfor private repo access." as bitbucket <<External>>

rectangle "**Forgejo / Gitea**\n[Self-Hosted Git Forge]\n\nOpen-source self-hosted\nGit platform with Composer\nrepository driver support." as forgejo <<External>>

' ── Legacy VCS Servers ───────────────────────────────────────────────────────
rectangle "**SVN Server**\n[Apache Subversion]\n\nCentralised version control.\nTags and branches mapped\nto Composer package versions." as svn <<External>>

rectangle "**Perforce Depot**\n[Helix Core / p4]\n\nEnterprise version control.\nDepot paths resolved via\np4 CLI process execution." as perforce <<External>>

' ── Network Infrastructure ───────────────────────────────────────────────────
rectangle "**HTTP/HTTPS Proxy**\n[Corporate / Forward Proxy]\n\nHTTP_PROXY / HTTPS_PROXY\nenvironment-configured proxy\nfor outbound requests." as proxy <<Infrastructure>>

rectangle "**TLS / PKI**\n[Certificate Authorities]\n\nTLS certificate validation\nfor secure HTTPS connections\nto remote registries and APIs." as tls <<Infrastructure>>

' ── Relationships: Actors → System ──────────────────────────────────────────
developer --> system : "CLI commands\n(install, update, require,\ndump-autoload)"
cicd --> system : "CLI invocation\n(composer install --no-dev)"
maintainer --> system : "CLI commands\n(composer publish /\ncomposer.json authoring)"

' ── Relationships: System ↔ Local Environment ────────────────────────────────
system --> cache : "Filesystem I/O\n(read/write package\nZIPs and metadata)"
system --> vendor : "Filesystem I/O\n(write installed sources,\nautoload maps, lock file)"
system --> artifact : "Filesystem scan\n(discover local\nZIP archives)"

' ── Relationships: System ↔ Package Registries ───────────────────────────────
system --> packagist : "HTTPS REST\n(fetch packages.json,\npackage metadata, dist ZIPs)"
system --> private_repo : "HTTPS REST\n(fetch packages.json,\nprivate package metadata)"
system --> pear : "HTTP REST\n(PEAR channel XML,\npackage release info)"

' ── Relationships: System ↔ VCS Platforms ────────────────────────────────────
system --> github : "HTTPS REST API\n(repo metadata, tags,\narchive downloads)"
github --> system : "HTTPS OAuth\n(access token exchange\nfor private repos)"

system --> gitlab : "HTTPS REST API\n(repo info, tags,\ndist archive download)"
gitlab --> system : "HTTPS OAuth 2.0\n(token grant for\nprivate repo access)"

system --> bitbucket : "HTTPS REST API\n(repo metadata,\narchive downloads)"
bitbucket --> system : "HTTPS OAuth 2.0\n(consumer token exchange)"

system --> forgejo : "HTTPS REST API\n(Forgejo/Gitea API,\nrepo metadata, tags)"
forgejo --> system : "HTTPS OAuth / token\n(authentication for\nprivate repositories)"

' ── Relationships: System ↔ Legacy VCS ───────────────────────────────────────
system --> svn : "SVN protocol / HTTPS\n(svn ls, svn export,\nbranches & tags)"
system --> perforce : "p4 CLI process\n(p4 login, p4 sync,\ndepot path resolution)"

' ── Relationships: System ↔ Network Infrastructure ───────────────────────────
system --> proxy : "HTTP CONNECT /\nHTTPS tunnel\n(all outbound requests\nrouted via proxy)"
system --> tls : "TLS handshake\n(certificate chain\nvalidation on HTTPS)"

@enduml
