@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Archive Management\n<size:11>(composer archive — Creating distribution archives of packages)</size>

left to right direction

actor "Developer" as developer #D4EDDA
actor "EventDispatcher" as eventDispatcher #D1ECF1
actor "DownloadManager" as downloadManager #FFF3CD

rectangle "Composer Archive Management" {

    usecase "Archive Current\nProject" as UC1
    usecase "Archive Specific\nPackage by Name/Version" as UC2
    usecase "Select Archive\nFormat" as UC3
    note right of UC3
      Formats: zip, tar,
      tar.gz, tar.bz2
      (ZipArchiver / PharArchiver)
    end note
    usecase "Specify Output Directory\n& Filename" as UC4
    note right of UC4
      --dir, --file options;\n auto-generated from
      package name + version
      if omitted
    end note
    usecase "Ignore Archive\nFilters" as UC5
    usecase "Skip Overwrite of\nExisting Archive" as UC6
    usecase "Dispatch Pre/Post\nArchive Events" as UC7

}

' --- Primary Actor Associations ---
developer --> UC1 : runs composer archive\n(root package)
developer --> UC2 : runs composer archive\n<package> [<version>]
developer --> UC5 : passes --ignore-filters

' --- Include Relationships ---
UC1 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>
UC2 ..> UC3 : <<include>>
UC2 ..> UC4 : <<include>>

' --- Extend Relationships ---
UC5 ..> UC1 : <<extend>>
UC5 ..> UC2 : <<extend>>
UC6 ..> UC1 : <<extend>>\n[overwriteFiles=false\n& archive exists]
UC6 ..> UC2 : <<extend>>\n[overwriteFiles=false\n& archive exists]
UC7 ..> UC1 : <<extend>>\n[Composer instance\npresent]
UC7 ..> UC2 : <<extend>>\n[Composer instance\npresent]

' --- Secondary Actor Associations ---
eventDispatcher --> UC7 : fires PRE_ARCHIVE_CMD\n& POST_ARCHIVE_CMD
downloadManager --> UC2 : downloads remote\npackage sources\nto temp dir

@enduml
