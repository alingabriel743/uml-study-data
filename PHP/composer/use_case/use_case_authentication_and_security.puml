@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Authentication and Security

left to right direction

actor "Developer" as Developer
actor "Repository Server\n(GitHub / GitLab / Bitbucket)" as RepositoryServer
actor "System Environment\n(Proxy Env Vars)" as SystemEnvironment
actor "Security Advisory\nSource" as SecurityAdvisorySource

rectangle "Composer — Authentication & Security" {

    usecase "Audit Packages\nfor Vulnerabilities" as UC1
    usecase "Authenticate\nwith Repository" as UC2
    usecase "Store Credentials\nto auth.json" as UC3
    usecase "Add Authentication\nHeaders to Request" as UC4
    usecase "Configure Proxy\nfor HTTP Requests" as UC5
    usecase "Raise Security Exception\non Invalid Signature" as UC6

    note right of UC1
      <b>AuditCommand::execute()</b>
      Options: --no-dev, --locked,
      --format, --abandoned,
      --ignore-severity, --filtered
      Exit code: non-zero = vulnerabilities found
    end note

    note right of UC2
      <b>AuthHelper::promptAuthIfNeeded()</b>
      Handles 401/403 responses.
      Strategies: GitHub OAuth, GitLab OAuth,
      Bitbucket OAuth, HTTP Basic
    end note

    note right of UC4
      <b>AuthHelper::addAuthenticationOptions()</b>
      Injects Bearer, GitHub token,
      GitLab private-token, Bitbucket OAuth,
      SSL cert, or HTTP Basic headers
    end note

    note right of UC5
      <b>ProxyManager::getProxyForRequest()</b>
      Reads http_proxy, https_proxy, no_proxy.
      Restricts http_proxy to CLI SAPI only
      (prevents CGI header injection).
    end note
}

' Primary actor relationships
Developer --> UC1 : runs composer audit
Developer --> UC2 : responds to auth prompt

' Secondary actor relationships
RepositoryServer --> UC2 : returns 401 / 403
RepositoryServer --> UC6 : bad package signature
SystemEnvironment --> UC5 : provides proxy env vars
SecurityAdvisorySource --> UC1 : supplies advisories

' Include / Extend between use cases
UC1 ..> UC5 : <<include>>\nHTTP via proxy
UC2 <.. UC1 : <<extend>>\nadvisory fetch triggers 401
UC2 ..> UC3 : <<include>>\npersist on success
UC2 ..> UC4 : <<include>>\ninject headers on retry

@enduml
