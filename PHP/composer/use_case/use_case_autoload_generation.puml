@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam ArrowColor #495057

title Autoload Generation

left to right direction

actor "Developer" as developer
actor "EventDispatcher\n(PRE/POST_AUTOLOAD_DUMP)" as eventDispatcher #D0E8FF
actor "Filesystem\n(vendor/composer/)" as filesystem #D0E8FF

rectangle "Composer — Autoload Generation" {

    usecase "Dump Autoload Files\n(composer dump-autoload)" as UC1
    usecase "Configure Autoloader Mode\n(standard / optimised / authoritative / APCu)" as UC2
    usecase "Enable Dry-Run Mode\n(preview without writing)" as UC3
    usecase "Generate Optimised Class Map\n(scan PSR-0/PSR-4 dirs)" as UC4
    usecase "Validate PSR Mappings\n(--strict-psr)" as UC5
    usecase "Detect Ambiguous Classes\n(--strict-ambiguous)" as UC6
    usecase "Filter Dev Dependencies\n(--no-dev)" as UC7
    usecase "Query Installed\nPackage Versions\n(InstalledVersions API)" as UC8

}

' Primary actor relationships
developer --> UC1
developer --> UC2
developer --> UC3
developer --> UC4
developer --> UC5
developer --> UC6
developer --> UC7
developer --> UC8

' Secondary system actor relationships
UC1 --> eventDispatcher : fires script events
UC1 --> filesystem : writes autoload_*.php\n& installed.php

' Include relationships
UC1 ..> UC8 : <<include>>
UC4 ..> UC6 : <<include>>

' Extend relationships
UC2 ..> UC1 : <<extend>>
UC3 ..> UC1 : <<extend>>
UC4 ..> UC1 : <<extend>>
UC5 ..> UC1 : <<extend>>
UC6 ..> UC1 : <<extend>>
UC7 ..> UC1 : <<extend>>

note bottom of UC1
  Entry: DumpAutoloadCommand::execute()
  ↓ AutoloadGenerator::dump()
  Artifacts: vendor/autoload.php,
  autoload_real.php, autoload_psr4.php,
  autoload_classmap.php, autoload_files.php,
  autoload_static.php, installed.php,
  platform_check.php
end note

note right of UC5
  Requires --optimize or
  --classmap-authoritative.
  Exits with code 1 on violation.
end note

note right of UC6
  Requires --optimize or
  --classmap-authoritative.
  Exits with code 2 on detection.
end note

@enduml
