@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #1A1A2E
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Cache Management

left to right direction

actor "Developer" as developer
actor "FileDownloader" as fileDownloader
actor "ComposerRepository" as composerRepo

rectangle "Composer Cache System\n(Cache + ClearCacheCommand)" {

    usecase "Clear All Caches\n(composer clear-cache)" as UC1
    usecase "Run Garbage Collection\n(--gc flag)" as UC2
    usecase "Read Package from Cache" as UC3
    usecase "Write Package to Cache" as UC4
    usecase "Remove Cache Entry on Error" as UC5
    usecase "Cache Repository Metadata" as UC6
    usecase "Automatic Garbage Collection" as UC7
    usecase "Check Cache Availability" as UC8

}

' Primary actor associations
developer --> UC1
developer --> UC2

' FileDownloader actor associations
fileDownloader --> UC3
fileDownloader --> UC4
fileDownloader --> UC5
fileDownloader --> UC7
fileDownloader --> UC8

' ComposerRepository actor associations
composerRepo --> UC6

' Include relationships (mandatory sub-flows)
UC1 ..> UC8 : <<include>>
UC2 ..> UC8 : <<include>>
UC3 ..> UC8 : <<include>>
UC4 ..> UC8 : <<include>>
UC7 ..> UC2 : <<include>>

' Extend relationships (optional/conditional variations)
UC1 <.. UC2 : <<extend>>\n(--gc option)
UC3 <.. UC7 : <<extend>>\n(auto-GC during download)

note bottom of UC2
  Two-pass GC:
  1. Delete by TTL expiry
  2. LRU eviction until under maxSize
end note

note bottom of UC7
  Probabilistic trigger:
  ~1/51 chance per download
end note

note right of UC8
  Graceful degradation:
  warns via IO if not writable,
  sets enabled = false
end note

@enduml
