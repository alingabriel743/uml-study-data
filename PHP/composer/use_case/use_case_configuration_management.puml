@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #336699
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Configuration Management

left to right direction

actor "Developer" as dev

rectangle "Composer Configuration Management" {

    ' --- Config Read/Write ---
    usecase "Read Configuration Value\n<size:10>[composer config <key>]</size>" as UC1
    usecase "List All Configuration\n<size:10>[composer config --list]</size>" as UC2
    usecase "Set Configuration Value\n<size:10>[composer config <key> <value>]</size>" as UC3
    usecase "Unset Configuration Value\n<size:10>[composer config --unset <key>]</size>" as UC4
    usecase "Edit Config in Editor\n<size:10>[composer config --editor]</size>" as UC5

    ' --- Global config modifier ---
    usecase "Manage Global Configuration\n<size:10>[--global flag → {home}/config.json]</size>" as UC6

    ' --- Validation ---
    usecase "Validate composer.json\n<size:10>[composer validate]</size>" as UC7
    usecase "Check Lock File Freshness\n<size:10>[--check-lock]</size>" as UC8
    usecase "Validate Dependency\ncomposer.json Files\n<size:10>[--with-dependencies]</size>" as UC9
}

' --- Actor associations ---
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4
dev --> UC5
dev --> UC6
dev --> UC7
dev --> UC8
dev --> UC9

' --- Include relationships ---
UC7 ..> UC8 : <<include>>

' --- Extend relationships ---
UC1 <.. UC6 : <<extend>>
UC2 <.. UC6 : <<extend>>
UC3 <.. UC6 : <<extend>>
UC4 <.. UC6 : <<extend>>
UC5 <.. UC6 : <<extend>>
UC7 <.. UC9 : <<extend>>

note bottom of UC6
  Targets global {home}/config.json
  instead of local composer.json.
  All read/write/list/unset operations
  are affected when --global is passed.
end note

note right of UC8
  Checks composer.lock via
  Locker::isFresh(); reports
  missing requirements.
end note

note right of UC3
  Writes to composer.json (local)
  or config.json / auth.json (global).
  Auth credentials stored in auth.json.
end note

@enduml
