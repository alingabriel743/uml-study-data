@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

left to right direction

title Dependency Analysis

actor "Developer" as dev

rectangle "Composer — Dependency Analysis" {

    usecase "Find Why Package\nIs Installed\n(composer depends / why)" as UC1
    usecase "Find Why Package\nCannot Be Installed\n(composer prohibits / why-not)" as UC2
    usecase "List Outdated Packages\n(composer outdated)" as UC3

    usecase "Resolve Dependency Chain\nRecursively" as UC_RECURSE
    usecase "Display Results\nas Tree" as UC_TREE
    usecase "Read from composer.lock\n(--locked)" as UC_LOCKED
    usecase "Apply Version Constraint\nFilter" as UC_CONSTRAINT
    usecase "Show Update Hint\n(composer require/update --dry-run)" as UC_HINT
    usecase "Delegate to\ncomposer show --latest" as UC_DELEGATE
}

' Developer initiates primary use cases
dev --> UC1
dev --> UC2
dev --> UC3

' UC1: depends / why — shared options
UC_RECURSE <.. UC1   : <<extend>>
UC_TREE    <.. UC1   : <<extend>>
UC_LOCKED  <.. UC1   : <<extend>>

' UC2: prohibits / why-not — adds version constraint + hint
UC_RECURSE   <.. UC2 : <<extend>>
UC_TREE      <.. UC2 : <<extend>>
UC_LOCKED    <.. UC2 : <<extend>>
UC2 ..> UC_CONSTRAINT : <<include>>
UC_HINT      <.. UC2 : <<extend>>

' UC3: outdated — proxy to show command
UC3 ..> UC_DELEGATE  : <<include>>

note right of UC1
  <b>composer depends &lt;package&gt;</b>
  alias: composer why
  Shows which installed packages
  require the given package.
  Traces chain upward to root.
end note

note right of UC2
  <b>composer prohibits &lt;package&gt; &lt;version&gt;</b>
  alias: composer why-not
  Shows which packages conflict with
  the requested package+version.
  Requires package AND version args.
end note

note right of UC3
  <b>composer outdated</b>
  Pure proxy — delegates all filtering
  logic to ShowCommand via
  Application::run(show --latest --outdated)
end note

@enduml
