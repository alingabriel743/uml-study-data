@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam ArrowFontColor #212529
skinparam ArrowFontSize 11
skinparam usecaseBorderThickness 1.5

title Dependency Resolution

left to right direction

' ── Primary Actor ──────────────────────────────────────────
actor "Developer" as dev

' ── System Actors ───────────────────────────────────────────
actor "Installer" as installer <<system>>
actor "Solver" as solver <<system>>
actor "Locker" as locker <<system>>
actor "Pool" as pool <<system>>
actor "PolicyInterface" as policy <<system>>

' ── System Boundary ─────────────────────────────────────────
rectangle "Composer — Dependency Resolution" {

    ' Developer-facing entry points
    usecase "Run Install\n(composer install)" as UC1
    usecase "Run Update\n(composer update)" as UC2
    usecase "Install from\nLock File" as UC8

    ' Lock file management
    usecase "Check Lock File\nExistence" as UC7
    usecase "Verify Lock File\nFreshness" as UC6
    usecase "Read Locked\nRepository" as UC5
    usecase "Write Lock File" as UC4
    usecase "Generate\nContent Hash" as UC12
    usecase "Validate Missing\nRequirements" as UC10

    ' SAT resolution
    usecase "Solve Dependency\nGraph (SAT)" as UC3
    usecase "Extract Non-Dev\nPackages" as UC9
    usecase "Select Preferred\nPackages" as UC11
}

' ── Developer interactions ───────────────────────────────────
dev --> UC1
dev --> UC2

' ── Run Install flow ─────────────────────────────────────────
UC1 ..> UC7  : <<include>>
UC1 ..> UC2  : <<extend>>\n[no lock file]
UC1 ..> UC8  : <<extend>>\n[lock file exists]

' ── Run Update flow ──────────────────────────────────────────
UC2 ..> UC3  : <<include>>
UC2 ..> UC9  : <<include>>
UC2 ..> UC4  : <<include>>
UC2 ..> UC8  : <<include>>

' ── SAT Solver internals ─────────────────────────────────────
UC3 ..> UC11 : <<include>>

' ── Install from lock flow ───────────────────────────────────
UC8 ..> UC5  : <<include>>
UC8 ..> UC6  : <<include>>
UC8 ..> UC10 : <<include>>

' ── Lock file internals ──────────────────────────────────────
UC4 ..> UC12 : <<include>>

' ── System actor associations ────────────────────────────────
installer --> UC3
installer --> UC4
installer --> UC5
installer --> UC8
installer --> UC9

solver --> UC3
solver --> UC11

locker --> UC4
locker --> UC5
locker --> UC6
locker --> UC7
locker --> UC10
locker --> UC12

pool --> UC3
policy --> UC11

note bottom of UC3
  SAT/CDCL algorithm
  Throws SolverProblemsException
  on unresolvable conflicts
end note

note bottom of UC4
  Persists packages, platform
  reqs, aliases, and stability
  flags to composer.lock
end note

@enduml
