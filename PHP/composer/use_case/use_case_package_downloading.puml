@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057

title Package Downloading

left to right direction

actor "Developer" as Developer
actor "Package\nRepository" as PackageRepository

rectangle "Package Download Subsystem (Composer\\Downloader)" {

    usecase "Install Package" as UC1
    usecase "Update Package" as UC2
    usecase "Remove Package" as UC3
    usecase "Download Package" as UC4
    usecase "Configure Download\nPreferences" as UC5
    usecase "Register Downloader" as UC6
    usecase "Prepare Operation" as UC7
    usecase "Cleanup Failed\nOperation" as UC8
    usecase "Download via Git" as UC9
    usecase "Download via\nZIP/Archive" as UC10
    usecase "Download via HTTP" as UC11
    usecase "Download via SVN" as UC12
    usecase "Handle Local\nChanges" as UC13
    usecase "Fallback to\nAlternative Source" as UC14

}

' Developer interactions
Developer --> UC1
Developer --> UC2
Developer --> UC3
Developer --> UC5
Developer --> UC6
Developer --> UC7
Developer --> UC8
Developer --> UC13

' PackageRepository interactions
PackageRepository --> UC9
PackageRepository --> UC10
PackageRepository --> UC11
PackageRepository --> UC12

' Include relationships
UC1 ..> UC4 : <<include>>
UC1 ..> UC7 : <<include>>
UC1 ..> UC8 : <<include>>

UC2 ..> UC4 : <<include>>
UC2 ..> UC3 : <<include>>
UC2 ..> UC7 : <<include>>
UC2 ..> UC8 : <<include>>

UC4 ..> UC9  : <<include>>
UC4 ..> UC10 : <<include>>
UC4 ..> UC11 : <<include>>
UC4 ..> UC12 : <<include>>

' Extend relationships
UC14 <.. UC4 : <<extend>>
UC13 <.. UC9 : <<extend>>

note bottom of UC4
  Source order resolved by:
  preferSource / preferDist flags,
  per-package patterns, isDev() check
end note

note bottom of UC14
  Retries with next source (dist↔source)
  on RuntimeException when
  sourceFallback=true
end note

@enduml
