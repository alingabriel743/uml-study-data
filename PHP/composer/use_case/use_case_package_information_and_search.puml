@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057

title Package Information and Search

left to right direction

actor "Developer" as developer
actor "Repository\nManager" as repoManager <<system>>
actor "Locker" as locker <<system>>

rectangle "Package Information and Search" {

    usecase "Show Package\nInformation" as UC1
    usecase "View Installed\nPackages List" as UC1a
    usecase "View Package\nDetails" as UC1b
    usecase "View Dependency\nTree" as UC1c
    usecase "Check Outdated\nPackages" as UC1d
    usecase "View Package\nPaths" as UC1e
    usecase "View Platform\nPackages" as UC1f
    usecase "View Available\nRemote Packages" as UC1g
    usecase "View Root\nPackage Info" as UC1h

    usecase "Search Packages" as UC2

    usecase "Show Package\nSuggestions" as UC3

    usecase "View Dependency\nLicenses" as UC4

    usecase "Discover Funding\nInformation" as UC5

}

' Developer initiates all top-level use cases
developer --> UC1
developer --> UC2
developer --> UC3
developer --> UC4
developer --> UC5

' Sub-use cases of Show Package Information
UC1 ..> UC1a : <<include>>
UC1 ..> UC1b : <<include>>
UC1 <.. UC1c : <<extend>>
UC1 <.. UC1d : <<extend>>
UC1 <.. UC1e : <<extend>>
UC1 <.. UC1f : <<extend>>
UC1 <.. UC1g : <<extend>>
UC1 <.. UC1h : <<extend>>

' System actor relationships
UC1 --> repoManager
UC2 --> repoManager
UC3 --> repoManager
UC4 --> repoManager
UC5 --> repoManager

UC3 --> locker
UC4 --> locker

@enduml
