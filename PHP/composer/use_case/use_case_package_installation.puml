@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam ArrowColor #495057

title Package Installation

left to right direction

actor "Developer" as developer #D0E8FF

rectangle "Composer — Package Installation" {

    usecase "Install from\ncomposer.lock / composer.json" as UC1
    usecase "Add New Dependency\n(composer require)" as UC2
    usecase "Dry-run Installation" as UC8

    usecase "Resolve Dependency Graph\n(Solver::solve)" as UC3
    usecase "Execute Package Operations\n(install / update / uninstall)" as UC4
    usecase "Generate Autoloader" as UC5
    usecase "Run Security Audit" as UC6
    usecase "Revert composer.json on Failure" as UC7

}

actor "Dependency\nSolver" as solver #FFE8C0
actor "Installation\nManager" as instmgr #FFE8C0
actor "Event\nDispatcher" as evtdisp #FFE8C0

' Primary actor initiates top-level use cases
developer --> UC1
developer --> UC2
developer --> UC8

' Dry-run extends both install and require
UC8 ..> UC1 : <<extend>>
UC8 ..> UC2 : <<extend>>

' Install and Require both include resolution and operation execution
UC1 ..> UC3 : <<include>>
UC2 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>
UC2 ..> UC4 : <<include>>

' Autoloader generation is included post-install
UC1 ..> UC5 : <<include>>
UC2 ..> UC5 : <<include>>

' Security audit is optional (extend)
UC1 ..> UC6 : <<extend>>
UC2 ..> UC6 : <<extend>>

' Revert on failure is an extension of require only
UC2 ..> UC7 : <<extend>>

' Secondary system actors
solver --> UC3
instmgr --> UC4
evtdisp --> UC1 : fires PRE_INSTALL_CMD\nhooks
evtdisp --> UC2 : fires PRE_UPDATE_CMD\nhooks

note bottom of UC1
  Entry: InstallCommand::execute()
  Reads composer.lock first;
  falls back to composer.json
  (triggers update mode)
end note

note bottom of UC2
  Entry: RequireCommand::execute()
  Writes requirement into
  composer.json via JsonManipulator;
  always runs Installer with
  setUpdate(true)
end note

note right of UC7
  Triggered on non-zero exit
  from Installer::run()
  (excluding AUDIT_FAILED=5).
  Restores composer.json +
  composer.lock from backup.
end note

@enduml
