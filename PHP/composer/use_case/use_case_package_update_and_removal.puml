@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #FFF9E6
skinparam NoteBorderColor #D4AC0D

title Package Update and Removal

left to right direction

actor "Developer" as dev

rectangle "Composer Package Lifecycle Management" {

    ' --- Update Use Cases ---
    usecase "Update All Packages\n<size:10>(composer update)</size>" as UC1
    usecase "Update Specific Packages\n<size:10>(composer update vendor/pkg)</size>" as UC2
    usecase "Update Packages Interactively\n<size:10>(composer update --interactive)</size>" as UC3
    usecase "Update with Temporary Constraints\n<size:10>(composer update vendor/pkg:1.0.*)</size>" as UC4
    usecase "Refresh Lock Metadata\n<size:10>(composer update --lock)</size>" as UC5
    usecase "Bump Constraints After Update\n<size:10>(composer update --bump-after-update)</size>" as UC6

    ' --- Remove Use Cases ---
    usecase "Remove Package\n<size:10>(composer remove vendor/pkg)</size>" as UC7
    usecase "Remove Unused Packages\n<size:10>(composer remove --unused)</size>" as UC8

    ' --- Reinstall Use Case ---
    usecase "Reinstall Packages\n<size:10>(composer reinstall acme/foo)</size>" as UC9

    ' --- Bump Use Case ---
    usecase "Bump Version Constraints\n<size:10>(composer bump)</size>" as UC10
}

' --- Actor associations ---
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4
dev --> UC5
dev --> UC6
dev --> UC7
dev --> UC8
dev --> UC9
dev --> UC10

' --- Extend relationships ---
UC3 ..> UC2 : <<extend>>\ninteractive selection
UC4 ..> UC2 : <<extend>>\ntemporary constraints
UC5 ..> UC1 : <<extend>>\nmirror/lock refresh
UC6 ..> UC1 : <<extend>>\nbump-after-update

' --- Include relationships ---
UC6 ..> UC10 : <<include>>\ninvokes BumpCommand.doBump()

' --- Remove extends ---
UC8 ..> UC7 : <<extend>>\n--unused detection

@enduml
