@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Platform Requirements and Diagnostics

left to right direction

actor "Developer" as developer

rectangle "Composer — Platform Requirements & Diagnostics" {

    ' ── Check Platform Requirements ──────────────────────────────
    usecase "Check Platform\nRequirements" as UC_CPR
    note right of UC_CPR
      check-platform-reqs
      Exit: 0 satisfied · 1 mismatch · 2 missing
    end note

    usecase "Read Lock File" as UC_Lock
    usecase "Filter Dev Packages" as UC_NoDev
    usecase "Output as JSON" as UC_JSON

    ' ── Diagnose Environment ──────────────────────────────────────
    usecase "Diagnose Environment" as UC_DIAG
    note right of UC_DIAG
      diagnose
      Exit: 0 OK · 1 warnings · 2 errors
    end note

    usecase "Check PHP Extensions\n& ini Settings" as UC_PHP
    usecase "Check Network\nConnectivity" as UC_NET
    usecase "Check Public Keys\n(phar only)" as UC_PUB
    usecase "Check Composer\nVersion (phar only)" as UC_VER

    ' ── Show Local Package Status ─────────────────────────────────
    usecase "Show Local\nPackage Status" as UC_STATUS
    note right of UC_STATUS
      status
      Exit: 0 clean · 1 local · 2 unpushed · 4 drift
    end note

    usecase "Show Verbose\nFile Diff" as UC_VERB
}

' ── Actor associations ────────────────────────────────────────────
developer --> UC_CPR
developer --> UC_DIAG
developer --> UC_STATUS

' ── Check Platform Requirements relationships ─────────────────────
UC_CPR ..> UC_Lock   : <<include>>
UC_CPR ..> UC_NoDev  : <<include>>
UC_JSON .up.> UC_CPR : <<extend>>

' ── Diagnose Environment relationships ───────────────────────────
UC_DIAG ..> UC_PHP   : <<include>>
UC_DIAG ..> UC_NET   : <<include>>
UC_PUB  .up.> UC_DIAG : <<extend>>
UC_VER  .up.> UC_DIAG : <<extend>>

' ── Show Local Package Status relationships ───────────────────────
UC_VERB .up.> UC_STATUS : <<extend>>

@enduml
