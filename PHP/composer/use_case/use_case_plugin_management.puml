@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 11

left to right direction

title Plugin Management\n<size:11>//Loading, registering, activating, and deactivating Composer plugins//</size>

actor "Developer" as Developer
actor "Composer" as ComposerApp

rectangle "Composer Plugin System (PluginManager)" {

    usecase "Load Installed\nPlugins" as UC1
    usecase "Register\nPlugin Package" as UC2
    usecase "Activate\nPlugin" as UC3
    usecase "Deactivate\nPlugin Package" as UC4
    usecase "Deactivate\nPlugin Instance" as UC5
    usecase "Uninstall\nPlugin" as UC6
    usecase "Check Plugin\nAllowed" as UC7
    usecase "Query Plugin\nCapabilities" as UC8
    usecase "Disable\nPlugins" as UC10

    usecase "Implement\nPluginInterface" as UC9

}

' --- Actor associations ---
ComposerApp --> UC1
ComposerApp --> UC2
ComposerApp --> UC4
ComposerApp --> UC6
ComposerApp --> UC8
ComposerApp --> UC10

Developer --> UC9

' --- Include relationships ---
UC1 ..> UC2 : <<include>>
UC2 ..> UC7 : <<include>>
UC2 ..> UC3 : <<include>>
UC4 ..> UC5 : <<include>>
UC6 ..> UC5 : <<include>>

' --- Extend relationships ---
UC8 <.. UC3 : <<extend>>\n//if Capable//

' --- Developer plugin feeds into system ---
UC9 ..> UC2 : <<precedes>>\n//plugin package\navailable for//

note bottom of UC7
  Matches allow-plugins rules.
  Prompts user interactively if
  unconfigured; throws
  PluginBlockedException if denied.
end note

note right of UC10
  Sets disablePlugins flag
  ('local' | 'global' | true).
  All load/add calls are
  silently skipped.
end note

note bottom of UC2
  Validates composer-plugin-api
  constraint (^2.9.0), autoloads
  classes, instantiates plugin.
  Guards: duplicate registration
  silently skipped.
end note

@enduml
