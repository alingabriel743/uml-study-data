@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam arrow {
    Color #495057
    FontColor #495057
    FontSize 11
}

title Project Initialization

left to right direction

actor "Developer" as dev
actor "Git" as git #E8F5E9;line:#388E3C

rectangle "Composer — Project Initialization" {

    package "composer init" {
        usecase "Initialize New Package\n(composer init)" as UC1
        usecase "Run Interactive\nSetup Wizard" as UC1_wizard
        usecase "Validate Package\nMetadata" as UC1_validate
        usecase "Write composer.json" as UC1_write
        usecase "Run dump-autoload" as UC1_autoload
        usecase "Update .gitignore" as UC1_gitignore
        usecase "Install Initial\nDependencies" as UC1_deps
    }

    package "composer create-project" {
        usecase "Create Project from\nPackage (composer create-project)" as UC2
        usecase "Install Root Package" as UC2a
        usecase "Resolve Best Package\nCandidate" as UC2_resolve
        usecase "Install Project\nDependencies" as UC2b
        usecase "Remove VCS History" as UC2_vcs
        usecase "Dispatch Project\nScript Events" as UC2_events
    }

    package "Bootstrap / Infrastructure" {
        usecase "Load / Create\nConfiguration" as UC3
        usecase "Create Composer\nInstance" as UC4
    }

}

' ── Primary actor associations ──────────────────────────────────────────────
dev --> UC1 : composer init
dev --> UC2 : composer create-project

' ── Git reads author / .git presence ─────────────────────────────────────────
git --> UC1 : provides git config\n& .git context

' ── composer init internal flow ──────────────────────────────────────────────
UC1 ..> UC1_wizard     : <<include>>\n(interactive mode)
UC1 ..> UC1_validate   : <<include>>
UC1 ..> UC1_write      : <<include>>
UC1 ..> UC3            : <<include>>\n(if --repository)

UC1_autoload ..> UC1   : <<extend>>\n(--autoload, no deps)
UC1_gitignore ..> UC1  : <<extend>>\n(.git exists, interactive)
UC1_deps ..> UC1       : <<extend>>\n(hasDependencies, confirmed)

' ── composer create-project internal flow ────────────────────────────────────
UC2 ..> UC3            : <<include>>
UC2 ..> UC2a           : <<include>>\n(packageName given)
UC2 ..> UC2b           : <<include>>\n(unless --no-install)

UC2a ..> UC2_resolve   : <<include>>
UC2a ..> UC4           : <<include>>

UC2b ..> UC2_events    : <<include>>
UC2_vcs ..> UC2b       : <<extend>>\n(installed from VCS,\nnot --keep-vcs)

' ── shared infrastructure ────────────────────────────────────────────────────
UC4 ..> UC3            : <<include>>

@enduml
