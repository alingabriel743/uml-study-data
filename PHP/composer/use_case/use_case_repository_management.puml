@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Repository Management

left to right direction

' ── Actors ──────────────────────────────────────────────────────────
actor "Developer" as Developer
actor "Packagist\n(packagist.org)" as Packagist #D0E8FF
actor "VCS Host\n(GitHub / GitLab /\nBitbucket / SVN / Hg)" as VCSHost #D0E8FF
actor "Composer\nSystem" as ComposerSystem #D8F5D8

' ── System boundary ─────────────────────────────────────────────────
rectangle "Repository Management" {

    ' ── CLI Repository Operations ───────────────────────────────────
    package "CLI Repository Commands" {
        usecase "List Repositories\n<size:10>(repo list)</size>" as UC1
        usecase "Add Repository\n<size:10>(repo add <name> <type> <url>)</size>" as UC2
        usecase "Remove Repository\n<size:10>(repo remove <name>)</size>" as UC3
        usecase "Set Repository URL\n<size:10>(repo set-url <name> <url>)</size>" as UC4
        usecase "Get Repository URL\n<size:10>(repo get-url <name>)</size>" as UC5
        usecase "Disable Packagist\n<size:10>(repo disable packagist.org)</size>" as UC6
        usecase "Enable Packagist\n<size:10>(repo enable packagist.org)</size>" as UC7
    }

    ' ── Ordering sub-use cases ───────────────────────────────────────
    package "Repository Ordering (Add Options)" {
        usecase "Prepend Repository\n<size:10>(default, high priority)</size>" as UC2a
        usecase "Append Repository\n<size:10>(--append, low priority)</size>" as UC2b
        usecase "Insert Repository\n<size:10>(--before / --after <name>)</size>" as UC2c
    }

    ' ── Internal System Operations ───────────────────────────────────
    package "Internal System Operations" {
        usecase "Register Repository Type\n<size:10>(map type string → class)</size>" as UC8
        usecase "Create Repository Instance\n<size:10>(instantiate & optionally wrap\nin FilterRepository)</size>" as UC9
        usecase "Find Package in Repositories\n<size:10>(iterate repos by name+constraint)</size>" as UC11
    }

    ' ── External Data Sources ────────────────────────────────────────
    package "External Data Sources" {
        usecase "Fetch Packages from Packagist\n<size:10>(HTTP API / metadata v2 / cache)</size>" as UC12
        usecase "Discover Packages from VCS\n<size:10>(tags, branches, composer.json per ref)</size>" as UC10
    }
}

' ── Developer relationships ─────────────────────────────────────────
Developer --> UC1
Developer --> UC2
Developer --> UC3
Developer --> UC4
Developer --> UC5
Developer --> UC6
Developer --> UC7

' ── Add ordering options (include) ──────────────────────────────────
UC2 ..> UC2a : <<include>>
UC2 <.. UC2b : <<extend>>
UC2 <.. UC2c : <<extend>>

' ── Remove implicitly disables Packagist ────────────────────────────
UC3 <.. UC6 : <<extend>>\n<size:10>when name = packagist.org</size>

' ── ComposerSystem internal use cases ───────────────────────────────
ComposerSystem --> UC8
ComposerSystem --> UC9
ComposerSystem --> UC11

' ── System bootstraps repo types before creation ────────────────────
UC9 ..> UC8 : <<include>>

' ── Package resolution triggers external fetches ────────────────────
UC11 ..> UC12 : <<include>>\n<size:10>composer repo</size>
UC11 ..> UC10 : <<include>>\n<size:10>vcs repo</size>

' ── External systems feed data back into Composer ───────────────────
Packagist --> UC12
VCSHost --> UC10

@enduml
