@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7ABD
    FontColor #1B3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 11

left to right direction

title Script and Binary Execution

actor "Developer" as dev

rectangle "Composer Script & Event System" {

    ' ── Developer-facing use cases ──────────────────────────────────────────
    package "Script Invocation" {
        usecase "Run Composer Script\n<size:10><i>composer run-script <script></i></size>" as UC1
        usecase "List Available Scripts\n<size:10><i>composer run-script --list</i></size>" as UC2
        usecase "Interactively Select Script\n<size:10><i>composer run-script (no args)</i></size>" as UC3
        usecase "Invoke Script Alias\n<size:10><i>composer <script-name></i></size>" as UC6
    }

    package "Binary Execution" {
        usecase "Execute Vendor Binary\n<size:10><i>composer exec <binary></i></size>" as UC4
        usecase "List Vendor Binaries\n<size:10><i>composer exec --list</i></size>" as UC5
    }

    ' ── Internal dispatch use cases ─────────────────────────────────────────
    package "Event Dispatch & Handler Routing" {
        usecase "Dispatch Script Event\n<size:10><i>EventDispatcher::dispatchScript()</i></size>" as UC7
        usecase "Execute PHP Class\nMethod Handler\n<size:10><i>ClassName::methodName(event)</i></size>" as UC8
        usecase "Execute Shell Command\n<size:10><i>process / executeTty()</i></size>" as UC9
        usecase "Execute Nested\nScript Reference\n<size:10><i>@scriptName / @composer</i></size>" as UC10
        usecase "Execute Command\nClass Handler\n<size:10><i>Symfony Command subclass</i></size>" as UC11
    }
}

' ── Developer → top-level use cases ─────────────────────────────────────────
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4
dev --> UC5
dev --> UC6

' ── Interactive selection extends run-script ─────────────────────────────────
UC3 .> UC1 : <<extend>>

' ── All three invocation paths include dispatch ──────────────────────────────
UC1 .> UC7 : <<include>>
UC4 .> UC7 : <<include>>
UC6 .> UC7 : <<include>>

' ── Dispatch fans out to handler types ───────────────────────────────────────
UC7 .> UC8  : <<include>>\n[PHP class callable]
UC7 .> UC9  : <<include>>\n[shell string]
UC7 .> UC10 : <<include>>\n[@ reference]
UC7 .> UC11 : <<include>>\n[Command class]

' ── Recursive nesting ────────────────────────────────────────────────────────
UC10 .> UC7 : <<include>>\n[recursive dispatch]

@enduml
