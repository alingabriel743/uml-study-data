@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Self-Update and Global Commands

left to right direction

actor "Developer" as dev
actor "getcomposer.org" as getcomposer #D0E8FF
actor "Operating System" as os #D0E8FF

rectangle "Composer CLI" {

    package "Self-Update (SelfUpdateCommand)" {
        usecase "Update Composer\n(self-update)" as UC1
        usecase "Rollback Composer\n(--rollback)" as UC2
        usecase "Update Public Keys\n(--update-keys)" as UC3
        usecase "Select Update Channel\n(--stable/--preview/--snapshot)" as UC4
    }

    package "Global Package Management (GlobalCommand)" {
        usecase "Run Global Command\n(composer global <cmd>)" as UC5
        usecase "Install Global Package\n(global require)" as UC6
        usecase "Remove Global Package\n(global remove)" as UC7
        usecase "Update Global Packages\n(global update)" as UC8
    }

    package "Utility Commands" {
        usecase "Browse Package Homepage\n/ Repository (browse|home)" as UC9
        usecase "Show Composer Info\n(about)" as UC10
    }
}

' Developer interactions
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4
dev --> UC5
dev --> UC9
dev --> UC10

' Include/Extend relationships
UC1 ..> UC2 : <<extend>>\n--rollback
UC1 ..> UC3 : <<extend>>\n--update-keys
UC1 ..> UC4 : <<extend>>\nchannel flags

UC5 ..> UC6 : <<include>>
UC5 ..> UC7 : <<include>>
UC5 ..> UC8 : <<include>>

' External system interactions
UC1 --> getcomposer : fetch version info\n& download phar
UC9 --> os : open browser\n(xdg-open / open / start)

note bottom of UC1
  Verifies OpenSSL SHA384 signature.
  Only available when running from a phar.
  Windows: UAC elevation via VBScript/sudo.
end note

note bottom of UC5
  Proxy command: clears COMPOSER env var,
  changes cwd to COMPOSER_HOME, then
  re-runs the sub-command in global scope.
end note

@enduml
