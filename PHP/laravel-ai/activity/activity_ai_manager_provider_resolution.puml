@startuml activity_ai_manager_provider_resolution

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
    BarColor #495057
}

skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title AI Manager Provider Resolution

|Caller|
start
note right
  Providers: Text, Audio, Image,
  Embedding, Reranking,
  Transcription, File, Store
end note

|Caller|
:Invoke **xxxProvider(?name)**\nor **fakeableXxxProvider(?name)**;

|AiManager|
:Call **instance($name)**\n→ delegate to MultipleInstanceManager;

|MultipleInstanceManager|
if ($name is null?) then (yes)
    :Call **getDefaultInstance()**\nRead config **'ai.default'**;
    if (value is Lab enum?) then (yes)
        :Convert enum **→ ->value** string;
    else (no)
    endif
    :Use resolved default name;
else (no)
    :Use provided **$name**;
endif

:Call **getInstanceConfig($name)**\nRead config **'ai.providers.{name}'**;

if (config driver is Lab enum?) then (yes)
    :Convert driver enum **→ ->value** string;
else (no)
endif

:Inject **config['name'] = $name**;

:Resolve driver key\n→ Call **create{Driver}Driver(config)**;

note right
  Drivers with dedicated gateways:
  anthropic → AnthropicGateway + config + Dispatcher
  gemini    → GeminiGateway + config + Dispatcher
  openai    → OpenAiGateway + config + Dispatcher
  others    → config + Dispatcher only
end note

:Instantiate **ConcreteProvider**\n(implements one or more XxxProvider interfaces);

|AiManager|
if (**$instance instanceof XxxProvider**?) then (no)
    #FFD6D6:Throw **LogicException**\n'Provider does not support {type} generation.';
    stop
else (yes)
endif

' ─────────────────────────────────────────────────
' Branch: standard vs. fakeable vs. textProviderFor
' ─────────────────────────────────────────────────

|Caller|
if (Method called?) then (fakeableXxxProvider)

    |AiManager|
    if (**xxxIsFaked()**?\n(fakeXxxGateway property ≠ null)) then (yes)
        :Clone provider instance;
        :Call **(clone)->useXxxGateway(\n    $this->fakeXxxGateway())**;
        :Return **cloned provider**\nbacked by **FakeXxxGateway**;
    else (no)
        :Return **real provider** as-is;
    endif

elseif (Method called?) then (textProviderFor\n(Agent))

    |AiManager|
    if (**hasFakeGatewayFor(Agent)**?\n(InteractsWithFakeAgents trait)) then (yes)
        :Clone TextProvider instance;
        :Call **(clone)->useTextGateway(\n    $this->fakeGatewayFor($agent))**;
        :Return **cloned TextProvider**\nbacked by per-agent fake gateway;
    else (no)
        :Return **real TextProvider**\nfor agent as-is;
    endif

else (xxxProvider\n(standard))

    |AiManager|
    :Return **real provider** instance;

endif

|Caller|
:Receive typed **XxxProvider** instance;
stop

' ─────────────────────────────────────────────────
' Faking Setup (Test Context — parallel concern)
' ─────────────────────────────────────────────────

|Caller|
detach

partition "**Faking Setup (Test Context)**" {
    |Caller|
    start
    :Call **AiManager::fakeXxx(responses)**\n(e.g. fakeAudio, fakeImages, fakeEmbeddings,\nfakeReranking, fakeTranscriptions,\nfakeFiles, fakeStores);

    |AiManager|
    :Instantiate **FakeXxxGateway(responses)**;
    :Store in **$this->fakeXxxGateway** property\n(one property per provider type);

    note right
      Trait per type:
      InteractsWithFakeAudio
      InteractsWithFakeImages
      InteractsWithFakeEmbeddings
      InteractsWithFakeReranking
      InteractsWithFakeTranscriptions
      InteractsWithFakeFiles
      InteractsWithFakeStores
    end note

    if (Is agent-level faking?) then (yes)
        :Call **fakeAgent(Agent, responses)**\n→ store per-agent gateway\nin map (InteractsWithFakeAgents);
    else (no)
    endif

    :**xxxIsFaked()** / **hasFakeGatewayFor()**\nwill now return **true**\non subsequent provider resolution;
    stop
}

@enduml
