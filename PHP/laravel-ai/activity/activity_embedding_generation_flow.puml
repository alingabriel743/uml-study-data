@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
    DiamondFontColor #212529
}

skinparam swimlane {
    BackgroundColor #FFFFFF
    BorderColor #6C757D
    TitleBackgroundColor #DEE2E6
    TitleFontColor #212529
    TitleFontStyle bold
}

skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Embedding Generation Flow

|Caller|
start
:Invoke **Embeddings::for**(string[] $inputs);

|Embeddings Facade|
:new **PendingEmbeddingsGeneration**($inputs);
note right
  Optional fluent configuration:
  ->dimensions(int)
  ->timeout(int)
  ->cache(?int  TTL in seconds)
end note

|Caller|
if (Dispatch path?) then (->generate(?provider, ?model))

  |PendingEmbeddingsGeneration|
  :Resolve provider + model list\nvia **Provider::formatProviderAndModelList()**\n(from arg or //ai.default_for_embeddings// config);

  repeat

    :Ai::fakeableEmbeddingProvider($provider)\n→ inject FakeEmbeddingGateway if faked;
    :Resolve $model and $dimensions\n(apply provider defaults if null);

    if (Cache enabled?) then (yes)
      :Compute SHA-256 cache key\n//sha256(driver-model-dimensions-inputs)//;
      if (Cache hit?) then (yes)
        :Deserialize and return\n**EmbeddingsResponse** from cache;
        stop
      else (miss)
        :Proceed to provider call;
      endif
    else (no)
    endif

    |GeneratesEmbeddings (Provider)|
    :Generate **UUID7** invocationId;
    :new **EmbeddingsPrompt**\n(inputs, dimensions, provider, model, timeout);

    if (Ai::embeddingsAreFaked()?) then (yes)
      :Ai::recordEmbeddingsGeneration($prompt)\nAppend to recordedEmbeddingsGenerations[];
    else (no)
    endif

    :Dispatch **GeneratingEmbeddings** event\n(invocationId, provider, model, prompt);

    :Call **embeddingGateway()->generateEmbeddings()**\n(provider, model, inputs, dimensions, timeout);

    if (Gateway type?) then (Real Gateway)

      |EmbeddingGateway (Real)|
      :HTTP POST to provider API\n//e.g. POST https://api.voyageai.com/v1/embeddings//\n//Bearer token auth, {model, input, output_dimension}//;
      :Parse JSON response\n//{data[].embedding, usage.total_tokens}//;
      :new **EmbeddingsResponse**\n(embeddings[][], tokens, Meta(provider, model));

    else (FakeEmbeddingGateway)

      |FakeEmbeddingGateway|
      if (responses is Closure?) then (yes)
        :call_user_func($closure, $prompt)\n→ get response;
      else (array)
        :responses[$currentResponseIndex];
      endif

      if (Response is null?) then (yes)
        if (preventStrayGenerations enabled?) then (yes)
          #Pink:throw **RuntimeException**\n"Stray embeddings generation";
          stop
        else (no)
          :generateFakeEmbeddings(count, dimensions)\n**Embeddings::fakeEmbedding**(dim) × N\n//Random normalized unit float[] vectors//;
          :new **EmbeddingsResponse**\n(fake embeddings, 0 tokens, Meta);
        endif
      else (not null)
        if (Response is array<array<float>>?) then (yes)
          :new **EmbeddingsResponse**\n(response, 0, Meta(provider, model));
        else (EmbeddingsResponse object)
          :Return response as-is;
        endif
      endif

      :Increment currentResponseIndex++;

    endif

    |GeneratesEmbeddings (Provider)|
    :Dispatch **EmbeddingsGenerated** event\n(invocationId, provider, model, prompt, response);
    :Return **EmbeddingsResponse**;

    |PendingEmbeddingsGeneration|
    if (FailoverableException thrown?) then (no — success)
      if (Cache enabled?) then (yes)
        :cacheStore()->put(cacheKey,\njson_encode(response), TTL)\n//Default TTL: 30 days//;
      else (no)
      endif
      :Return **EmbeddingsResponse** to Caller;
      stop
    else (yes — failover)
      :Dispatch **ProviderFailedOver** event;
      :Move to next provider in list;
    endif

  repeat while (Next provider available?) is (yes)
  -> all providers exhausted;

  #Pink:Throw last **FailoverableException**\n(all providers failed);
  stop

else (->queue(?provider, ?model))

  |PendingEmbeddingsGeneration|
  if (Ai::embeddingsAreFaked()?) then (yes)
    :Ai::recordEmbeddingsGeneration\n(new **QueuedEmbeddingsPrompt**(...));
    :Return **QueuedEmbeddingsResponse**\n(FakePendingDispatch);
    stop
  else (no)
    :**GenerateEmbeddings**::dispatch($this, $provider, $model)\n//Dispatches to queue//;
    :Return **QueuedEmbeddingsResponse**\n(PendingDispatch);
    stop
  endif

endif

note right
  **Testing / Fake Support**
  Embeddings::fake(Closure|array $responses) → registers FakeEmbeddingGateway
  Assert methods: assertEmbeddingsGenerated(), assertEmbeddingsNotGenerated(),
  assertNoEmbeddingsGenerated(), assertEmbeddingsQueued(), assertEmbeddingsNotQueued()
end note

@enduml
