@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
    BarColor #495057
}

skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Provider Failover Handling

|PendingResponse|
start
:Caller invokes resolve()\n<i>(generate, embed, rerank, etc.)</i>;

|AiManager|
:Build ordered providers list from config\n<i>(primary provider + fallback chain)</i>;

|PendingResponse|
:Initialize **$lastException** = null;

repeat

  |AiManager|
  :Resolve Provider instance\n<i>Ai::textProviderFor() /\nAi::fakeableEmbeddingProvider() / etc.</i>;
  :Determine effective model\n<i>(explicit model or provider default)</i>;

  |Gateway / HandlesFailoverErrors|
  :Enter **withErrorHandling**($providerName, $callback);
  :Execute HTTP API call to provider;

  if (HTTP call succeeds?) then (yes)
    |PendingResponse|
    :Return successful response;
    stop
  else (no — RequestException thrown)
    :Inspect HTTP status code\nand error message body;

    if (status == 429?) then (yes)
      :Throw **RateLimitedException**::forProvider()\n<i>implements FailoverableException</i>;
    elseif (status in overloadedStatusCodes()\n<i>default: [503]</i>?) then (yes)
      :Throw **ProviderOverloadedException**::forProvider()\n<i>implements FailoverableException</i>;
    elseif (message matches\ninsufficientCreditPatterns()?) then (yes)
      :Throw **InsufficientCreditsException**::forProvider()\n<i>implements FailoverableException</i>;
    else (other HTTP error)
      :Re-throw original **RequestException**\n<i>(NOT failoverable — no retry)</i>;
      |PendingResponse|
      :Propagate non-failoverable exception\nto caller;
      stop
    endif
  endif

  |PendingResponse|
  :Catch **FailoverableException** $e;
  :$lastException = $e;

  |Laravel Event Dispatcher|
  :Dispatch **ProviderFailedOver** event\n<i>new ProviderFailedOver($provider, $model, $e)</i>;

  |PendingResponse|

repeat while (More providers in list?) is (yes — try next provider)
-> no — all providers exhausted;

:Throw **$lastException**\n<i>(last FailoverableException captured)</i>;

stop

@enduml
