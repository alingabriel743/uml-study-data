@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D6EAF8
    BorderColor #2980B9
    FontColor #1A5276
}

title Agent & Capability Contracts

' ─────────────────────────────────────────────
' Core + Capability Contracts
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Contracts" {

    interface Agent {
        +instructions(): Stringable|string
        +prompt(prompt, attachments, provider, model): AgentResponse
        +stream(prompt, attachments, provider, model): StreamableAgentResponse
        +queue(prompt, attachments, provider, model): QueuedAgentResponse
        +broadcast(prompt, channels, attachments, now, provider, model): StreamableAgentResponse
        +broadcastNow(prompt, channels, attachments, provider, model): StreamableAgentResponse
        +broadcastOnQueue(prompt, channels, attachments, provider, model): QueuedAgentResponse
    }

    interface Conversational {
        +messages(): iterable<Message>
    }

    interface HasTools {
        +tools(): iterable<Tool|ProviderTool>
    }

    interface HasStructuredOutput {
        +schema(schema: JsonSchema): array<string, Type>
    }

    interface HasMiddleware {
        +middleware(): array
    }

    interface HasProviderOptions {
        +providerOptions(provider: Lab|string): array<string, mixed>
    }

    interface Tool {
        +description(): Stringable|string
        +handle(request: Request): Stringable|string
        +schema(schema: JsonSchema): array<string, Type>
    }

    interface ConversationStore {
        +latestConversationId(userId: string|int): ?string
        +storeConversation(userId: string|int|null, title: string): string
        +storeUserMessage(conversationId, userId, prompt: AgentPrompt): string
        +storeAssistantMessage(conversationId, userId, prompt, response: AgentResponse): string
        +getLatestConversationMessages(conversationId, limit: int): Collection<Message>
    }

    interface Schemable {
        +name(): string
        +toSchema(): array<string, mixed>
    }

}

' ─────────────────────────────────────────────
' Trait & Concrete Implementations
' ─────────────────────────────────────────────
package "Laravel\\Ai" {

    class Promptable <<trait>> {
        +{static} make(...arguments): static
        +prompt(prompt, attachments, provider, model, timeout): AgentResponse
        +stream(prompt, attachments, provider, model, timeout): StreamableAgentResponse
        +queue(prompt, attachments, provider, model): QueuedAgentResponse
        +broadcast(...): StreamableAgentResponse
        +broadcastNow(...): StreamableAgentResponse
        +broadcastOnQueue(...): QueuedAgentResponse
        +{static} fake(responses): FakeTextGateway
        +{static} assertPrompted(callback): void
        +{static} assertNotPrompted(...): void
        +{static} assertNeverPrompted(): void
        +{static} isFaked(): bool
        #getProvidersAndModels(provider, model): array
        #getDefaultModelFor(provider: Provider): string
        #getTimeout(timeout): int
        -withModelFailover(callback, provider, model): mixed
    }

    class AnonymousAgent {
        -$instructions: string
        -$messages: iterable
        -$tools: iterable
        +__construct(instructions, messages, tools)
        +instructions(): string
        +messages(): iterable
        +tools(): iterable
    }

    class StructuredAnonymousAgent {
        -$schema: SerializableClosure
        +__construct(instructions, messages, tools, schema: Closure)
        +schema(schema: JsonSchema): array
    }

}

' ─────────────────────────────────────────────
' Response Hierarchy
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Responses" {

    class TextResponse {
        +$text: string
        +$usage: Usage
        +$meta: Meta
        +$messages: Collection
        +$toolCalls: Collection
        +$toolResults: Collection
        +$steps: Collection
        +withMessages(messages: Collection): self
        +withToolCallsAndResults(calls, results): self
        +withSteps(steps: Collection): self
        +__toString(): string
    }

    class AgentResponse {
        +$invocationId: string
        +$conversationId: ?string
        +$conversationUser: ?object
        +withinConversation(id, user): self
        +then(callable): self
    }

    class StructuredAgentResponse {
        +toArray(): array
        +toJson(options): string
        +jsonSerialize(): mixed
        +__toString(): string
    }

    class StreamableAgentResponse {
        +$invocationId: string
        +$text: ?string
        +$usage: ?Usage
        +$events: Collection
        +$conversationId: ?string
        +$conversationUser: ?object
        +each(callable): self
        +then(callable): self
        +withinConversation(id, user): self
        +usingVercelDataProtocol(enabled): self
        +toResponse(request): Response
        +getIterator(): Traversable
    }

    class QueuedAgentResponse {
        +$dispatchable: PendingDispatch
    }

}

' ─────────────────────────────────────────────
' Supporting Value Types (external references)
' ─────────────────────────────────────────────
class Message {
    +$role
    +$content
}

class "Tools\\Request" as ToolRequest {
    +all(keys): array
    +offsetGet(offset): mixed
}

' ─────────────────────────────────────────────
' Relationships — Inheritance & Implementation
' ─────────────────────────────────────────────

' AnonymousAgent implements core contracts
AnonymousAgent ..|> Agent
AnonymousAgent ..|> Conversational
AnonymousAgent ..|> HasTools

' AnonymousAgent uses Promptable trait
AnonymousAgent ..> Promptable : <<uses trait>>

' StructuredAnonymousAgent extends AnonymousAgent and adds structured output
StructuredAnonymousAgent --|> AnonymousAgent
StructuredAnonymousAgent ..|> HasStructuredOutput

' Response inheritance chain
AgentResponse --|> TextResponse
StructuredAgentResponse --|> AgentResponse

' ─────────────────────────────────────────────
' Relationships — Dependencies
' ─────────────────────────────────────────────

' Agent contract produces response types
Agent ..> AgentResponse : returns
Agent ..> StreamableAgentResponse : returns
Agent ..> QueuedAgentResponse : returns

' HasTools depends on Tool contract
HasTools ..> Tool : uses

' Tool contract uses ToolRequest
Tool ..> ToolRequest : handle(request)

' ConversationStore depends on Message and AgentResponse
ConversationStore ..> Message : stores/retrieves
ConversationStore ..> AgentResponse : records

' Conversational depends on Message
Conversational ..> Message : yields

' Schemable is a generic schema contract (Tool and HasStructuredOutput both define schema())
Tool --|> Schemable
HasStructuredOutput --|> Schemable

@enduml
