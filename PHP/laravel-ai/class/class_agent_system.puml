@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
    FontColor #1A5276
}

title Agent System

' ─────────────────────────────────────────────
'  Contracts
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Contracts" {

    interface Agent {
    }

    interface Conversational {
        +messages(): iterable
    }

    interface HasTools {
        +tools(): iterable
    }

    interface HasStructuredOutput {
        +schema(schema: JsonSchema): array
    }
}

' ─────────────────────────────────────────────
'  Core — Trait
' ─────────────────────────────────────────────
package "Laravel\\Ai" {

    class Promptable <<trait>> {
        +{static} make(...arguments): static
        +prompt(prompt: string, attachments: array, provider, model: ?string, timeout: ?int): AgentResponse
        +stream(prompt: string, attachments: array, provider, model: ?string, timeout: ?int): StreamableAgentResponse
        +queue(prompt: string, attachments: array, provider, model: ?string): QueuedAgentResponse
        +broadcast(prompt: string, channels, attachments: array, now: bool, provider, model: ?string): StreamableAgentResponse
        +broadcastNow(prompt: string, channels, attachments: array, provider, model: ?string): StreamableAgentResponse
        +broadcastOnQueue(prompt: string, channels, attachments: array, provider, model: ?string): QueuedAgentResponse
        #getProvidersAndModels(provider, model: ?string): array
        #getDefaultModelFor(provider: Provider): string
        #getTimeout(timeout: ?int): int
        -withModelFailover(callback: Closure, provider, model: ?string): mixed
        +{static} fake(responses: Closure|array): FakeTextGateway
        +{static} assertPrompted(callback: Closure|string): void
        +{static} assertNotPrompted(callback: Closure|string): void
        +{static} assertNeverPrompted(): void
        +{static} assertQueued(callback: Closure|string): void
        +{static} assertNeverQueued(): void
        +{static} isFaked(): bool
    }

    ' ─────────────────────────────────────────
    '  Agent classes
    ' ─────────────────────────────────────────
    class AnonymousAgent {
        +instructions: string
        +messages: iterable
        +tools: iterable
        --
        +__construct(instructions: string, messages: iterable, tools: iterable)
        +instructions(): string
        +messages(): iterable
        +tools(): iterable
    }

    class StructuredAnonymousAgent {
        +schema: SerializableClosure
        --
        +__construct(instructions: string, messages: iterable, tools: iterable, schema: Closure)
        +schema(schema: JsonSchema): array
    }

    ' ─────────────────────────────────────────
    '  Data object
    ' ─────────────────────────────────────────
    class QueuedAgentPrompt {
        +agent: Agent
        +prompt: string
        +attachments: Collection|array
        +provider: Lab|array|string|null
        +model: ?string
        --
        +__construct(agent: Agent, prompt: string, attachments, provider, model: ?string)
    }

    ' ─────────────────────────────────────────
    '  Response types (value objects)
    ' ─────────────────────────────────────────
    class AgentResponse <<(V,#ABEBC6) response>> {
    }

    class StreamableAgentResponse <<(V,#ABEBC6) response>> {
    }

    class QueuedAgentResponse <<(V,#ABEBC6) response>> {
    }

    ' ─────────────────────────────────────────
    '  PHP Attributes
    ' ─────────────────────────────────────────
    class "«attribute»\nModel" as ModelAttr <<attribute>> {
    }

    class "«attribute»\nProvider" as ProviderAttr <<attribute>> {
    }

    class "«attribute»\nTimeout" as TimeoutAttr <<attribute>> {
    }

    class "«attribute»\nUseSmartestModel" as UseSmartestModel <<attribute>> {
    }

    class "«attribute»\nUseCheapestModel" as UseCheapestModel <<attribute>> {
    }
}

' ─────────────────────────────────────────────
'  Relationships — inheritance & implementation
' ─────────────────────────────────────────────

' AnonymousAgent implements contracts
AnonymousAgent ..|> Agent
AnonymousAgent ..|> Conversational
AnonymousAgent ..|> HasTools

' StructuredAnonymousAgent extends AnonymousAgent and adds HasStructuredOutput
StructuredAnonymousAgent --|> AnonymousAgent
StructuredAnonymousAgent ..|> HasStructuredOutput

' Trait usage
AnonymousAgent ..> Promptable : <<uses trait>>

' ─────────────────────────────────────────────
'  Relationships — dependencies & compositions
' ─────────────────────────────────────────────

' QueuedAgentPrompt holds an Agent reference
QueuedAgentPrompt *-- Agent : agent

' Promptable creates / returns response types
Promptable ..> AgentResponse          : returns from prompt()
Promptable ..> StreamableAgentResponse : returns from stream()\nbroadcast()
Promptable ..> QueuedAgentResponse    : returns from queue()\nbroadcastOnQueue()

' Promptable creates QueuedAgentPrompt for faking
Promptable ..> QueuedAgentPrompt : creates (faking)

' PHP Attributes consumed by Promptable for resolution
Promptable ..> ModelAttr       : reads #[Model]
Promptable ..> ProviderAttr    : reads #[Provider]
Promptable ..> TimeoutAttr     : reads #[Timeout]
Promptable ..> UseSmartestModel : reads attribute
Promptable ..> UseCheapestModel : reads attribute

@enduml
