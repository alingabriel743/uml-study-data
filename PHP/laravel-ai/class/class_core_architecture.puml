@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
    FontColor #1A5276
}
skinparam stereotypeCBackgroundColor #D5E8D4
skinparam stereotypeCBorderColor #82B366

title Core Architecture & Service Provider

' ─────────────────────────────────────────
'  Laravel Framework Bases
' ─────────────────────────────────────────
package "Illuminate\\Support" {
    class Facade <<Laravel>> {
    }
    class MultipleInstanceManager <<Laravel>> {
    }
    class ServiceProvider <<Laravel>> {
    }
}

' ─────────────────────────────────────────
'  Provider Contracts
' ─────────────────────────────────────────
package "Provider Contracts" {
    interface AudioProvider
    interface EmbeddingProvider
    interface RerankingProvider
    interface ImageProvider
    interface TextProvider
    interface TranscriptionProvider
    interface FileProvider
    interface StoreProvider
}

' ─────────────────────────────────────────
'  Fake Interaction Traits
' ─────────────────────────────────────────
package "Laravel\\Ai\\Concerns (Fake Traits)" {
    class InteractsWithFakeAgents <<trait>>
    class InteractsWithFakeAudio <<trait>>
    class InteractsWithFakeEmbeddings <<trait>>
    class InteractsWithFakeFiles <<trait>>
    class InteractsWithFakeImages <<trait>>
    class InteractsWithFakeReranking <<trait>>
    class InteractsWithFakeStores <<trait>>
    class InteractsWithFakeTranscriptions <<trait>>
}

' ─────────────────────────────────────────
'  IoC / Container Bindings
' ─────────────────────────────────────────
package "IoC Bindings" {
    interface ConversationStore
    class DatabaseConversationStore {
    }
    class MakeAgentCommand <<Command>>
    class MakeAgentMiddlewareCommand <<Command>>
    class MakeToolCommand <<Command>>
}

' ─────────────────────────────────────────
'  Core Laravel AI Package
' ─────────────────────────────────────────
package "Laravel\\Ai" {

    class Ai {
        #getFacadeAccessor(): string
        .. note ..
        Routes all static calls
        to AiManager
    }

    class AiManager {
        #driverKey: string = "driver"
        ==Provider Resolvers==
        +audioProvider(?name): AudioProvider
        +fakeableAudioProvider(?name): AudioProvider
        +embeddingProvider(?name): EmbeddingProvider
        +fakeableEmbeddingProvider(?name): EmbeddingProvider
        +rerankingProvider(?name): RerankingProvider
        +fakeableRerankingProvider(?name): RerankingProvider
        +imageProvider(?name): ImageProvider
        +fakeableImageProvider(?name): ImageProvider
        +textProvider(?name): TextProvider
        +textProviderFor(agent, ?name): TextProvider
        +transcriptionProvider(?name): TranscriptionProvider
        +fakeableTranscriptionProvider(?name): TranscriptionProvider
        +fileProvider(?name): FileProvider
        +fakeableFileProvider(?name): FileProvider
        +storeProvider(?name): StoreProvider
        +fakeableStoreProvider(?name): StoreProvider
        ==Driver Factories==
        +createAnthropicDriver(config): AnthropicProvider
        +createOpenaiDriver(config): OpenAiProvider
        +createGeminiDriver(config): GeminiProvider
        +createAzureDriver(config): AzureOpenAiProvider
        +createCohereDriver(config): CohereProvider
        +createDeepseekDriver(config): DeepSeekProvider
        +createElevenDriver(config): ElevenLabsProvider
        +createGroqDriver(config): GroqProvider
        +createJinaDriver(config): JinaProvider
        +createMistralDriver(config): MistralProvider
        +createOllamaDriver(config): OllamaProvider
        +createOpenrouterDriver(config): OpenRouterProvider
        +createVoyageaiDriver(config): VoyageAiProvider
        +createXaiDriver(config): XaiProvider
        ==Config==
        +getDefaultInstance(): string
        +setDefaultInstance(name): void
        +getInstanceConfig(name): array
    }

    class AiServiceProvider {
        +register(): void
        +boot(): void
        #registerCommands(): void
        #registerPublishing(): void
        ==Registers==
        app.scoped(AiManager::class)
        app.singleton(ConversationStore)
        ..Publishes..
        config/ai.php
        stubs/
        database/migrations
    }
}

' ─────────────────────────────────────────
'  Inheritance
' ─────────────────────────────────────────
Ai          --|> Facade
AiManager   --|> MultipleInstanceManager
AiServiceProvider --|> ServiceProvider

' ─────────────────────────────────────────
'  Facade Accessor
' ─────────────────────────────────────────
Ai ..> AiManager : <<accessor>>

' ─────────────────────────────────────────
'  Traits used by AiManager
' ─────────────────────────────────────────
AiManager ..> InteractsWithFakeAgents        : <<use>>
AiManager ..> InteractsWithFakeAudio         : <<use>>
AiManager ..> InteractsWithFakeEmbeddings    : <<use>>
AiManager ..> InteractsWithFakeFiles         : <<use>>
AiManager ..> InteractsWithFakeImages        : <<use>>
AiManager ..> InteractsWithFakeReranking     : <<use>>
AiManager ..> InteractsWithFakeStores        : <<use>>
AiManager ..> InteractsWithFakeTranscriptions : <<use>>

' ─────────────────────────────────────────
'  AiManager returns typed Provider contracts
' ─────────────────────────────────────────
AiManager ..> AudioProvider        : returns
AiManager ..> EmbeddingProvider    : returns
AiManager ..> RerankingProvider    : returns
AiManager ..> ImageProvider        : returns
AiManager ..> TextProvider         : returns
AiManager ..> TranscriptionProvider : returns
AiManager ..> FileProvider         : returns
AiManager ..> StoreProvider        : returns

' ─────────────────────────────────────────
'  AiServiceProvider IoC wiring
' ─────────────────────────────────────────
AiServiceProvider ..> AiManager               : <<registers scoped>>
AiServiceProvider ..> DatabaseConversationStore : <<registers singleton>>
AiServiceProvider ..> MakeAgentCommand          : <<registers>>
AiServiceProvider ..> MakeAgentMiddlewareCommand : <<registers>>
AiServiceProvider ..> MakeToolCommand           : <<registers>>

DatabaseConversationStore ..|> ConversationStore

@enduml
