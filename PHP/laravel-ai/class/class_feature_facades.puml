@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam stereotype {
    CBackgroundColor #D4EDDA
    CBorderColor #28A745
    IBackgroundColor #D1ECF1
    IBorderColor #17A2B8
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
}

title AI Feature Facades\n<size:11><i>High-level static entry-points for each AI capability (Laravel\\Ai)</i></size>

' ─────────────────────────────────────────────
' Central Hub
' ─────────────────────────────────────────────
package "Core" {
    class Ai <<Facade>> {
        # {static} getFacadeAccessor(): string
    }
}

' ─────────────────────────────────────────────
' Feature Facades
' ─────────────────────────────────────────────
package "Feature Facades" {

    class Audio <<static facade>> {
        + {static} of(text: string): PendingAudioGeneration
        + {static} fake(responses: Closure|array = []): FakeAudioGateway
        + {static} assertGenerated(callback: Closure): void
        + {static} assertNotGenerated(callback: Closure): void
        + {static} assertNothingGenerated(): void
        + {static} assertQueued(callback: Closure): void
        + {static} assertNotQueued(callback: Closure): void
        + {static} assertNothingQueued(): void
        + {static} isFaked(): bool
    }

    class Image <<static facade>> {
        + {static} of(prompt: string): PendingImageGeneration
        + {static} fake(responses: Closure|array = []): FakeImageGateway
        + {static} assertGenerated(callback: Closure): void
        + {static} assertNotGenerated(callback: Closure): void
        + {static} assertNothingGenerated(): void
        + {static} assertQueued(callback: Closure): void
        + {static} assertNotQueued(callback: Closure): void
        + {static} assertNothingQueued(): void
        + {static} isFaked(): bool
    }

    class Transcription <<static facade>> {
        + {static} of(audio: TranscribableAudio|UploadedFile|string): PendingTranscriptionGeneration
        + {static} fromBase64(base64: string, mimeType: ?string): PendingTranscriptionGeneration
        + {static} fromPath(path: string, mimeType: ?string): PendingTranscriptionGeneration
        + {static} fromStorage(path: string, disk: ?string): PendingTranscriptionGeneration
        + {static} fromUpload(file: UploadedFile): PendingTranscriptionGeneration
        + {static} fake(responses: Closure|array = []): FakeTranscriptionGateway
        + {static} assertGenerated(callback: Closure): void
        + {static} assertNotGenerated(callback: Closure): void
        + {static} assertNothingGenerated(): void
        + {static} assertQueued(callback: Closure): void
        + {static} assertNotQueued(callback: Closure): void
        + {static} assertNothingQueued(): void
        + {static} isFaked(): bool
    }

    class Embeddings <<static facade>> {
        + {static} for(inputs: string[]): PendingEmbeddingsGeneration
        + {static} fake(responses: Closure|array = []): FakeEmbeddingGateway
        + {static} fakeEmbedding(dimensions: int): float[]
        + {static} assertGenerated(callback: Closure): void
        + {static} assertNotGenerated(callback: Closure): void
        + {static} assertNothingGenerated(): void
        + {static} assertQueued(callback: Closure): void
        + {static} assertNotQueued(callback: Closure): void
        + {static} assertNothingQueued(): void
        + {static} isFaked(): bool
    }

    class Reranking <<static facade>> {
        + {static} of(documents: Collection|array): PendingReranking
        + {static} fake(responses: Closure|array = []): FakeRerankingGateway
        + {static} assertReranked(callback: Closure): void
        + {static} assertNotReranked(callback: Closure): void
        + {static} assertNothingReranked(): void
        + {static} isFaked(): bool
    }
}

' ─────────────────────────────────────────────
' Pending Response Builders
' ─────────────────────────────────────────────
package "Pending Responses" {

    class PendingAudioGeneration {
        - $voice: string
        - $instructions: string
        - $timeout: int
        + voice(voice: string): self
        + male(): self
        + female(): self
        + instructions(instructions: string): self
        + timeout(seconds: int): self
        + generate(provider, model): mixed
        + queue(provider, model): mixed
    }

    class PendingImageGeneration {
        - $size: string
        - $quality: string
        - $timeout: int
        + size(size: string): self
        + square(): self
        + portrait(): self
        + landscape(): self
        + quality(quality: string): self
        + timeout(timeout: int): self
        + generate(provider, model): mixed
        + queue(provider, model): mixed
    }

    class PendingTranscriptionGeneration {
        - $language: string
        - $diarize: bool
        - $timeout: int
        + language(language: string): self
        + diarize(diarize: bool): self
        + timeout(seconds: int): self
        + generate(provider, model): mixed
        + queue(provider, model): mixed
    }

    class PendingEmbeddingsGeneration {
        - $dimensions: int
        - $cacheSeconds: int
        - $timeout: int
        + dimensions(dimensions: int): self
        + cache(seconds: int): self
        + timeout(seconds: int): self
        + generate(provider, model): mixed
        + queue(provider, model): mixed
    }

    class PendingReranking {
        - $limit: int
        + limit(limit: int): self
        + rerank(query: string, provider, model): mixed
    }
}

' ─────────────────────────────────────────────
' Fake Gateways (Test Doubles)
' ─────────────────────────────────────────────
package "Fake Gateways" {
    class FakeAudioGateway <<fake>>
    class FakeImageGateway <<fake>>
    class FakeTranscriptionGateway <<fake>>
    class FakeEmbeddingGateway <<fake>>
    class FakeRerankingGateway <<fake>>
}

' ─────────────────────────────────────────────
' Transcription Audio Input Helpers
' ─────────────────────────────────────────────
package "Audio Input Helpers" {

    interface TranscribableAudio <<interface>> {
    }

    class Base64Audio {
    }

    class LocalAudio {
    }

    class StoredAudio {
    }

    Base64Audio ..|> TranscribableAudio
    LocalAudio  ..|> TranscribableAudio
    StoredAudio ..|> TranscribableAudio
}

' ─────────────────────────────────────────────
' Relationships: Facades → Ai (delegation)
' ─────────────────────────────────────────────
Audio       ..> Ai : delegates assert/fake
Image       ..> Ai : delegates assert/fake
Transcription ..> Ai : delegates assert/fake
Embeddings  ..> Ai : delegates assert/fake
Reranking   ..> Ai : delegates assert/fake

' ─────────────────────────────────────────────
' Relationships: Facades → Pending Builders
' ─────────────────────────────────────────────
Audio       ..> PendingAudioGeneration        : creates via of()
Image       ..> PendingImageGeneration        : creates via of()
Transcription ..> PendingTranscriptionGeneration : creates via of()/from*()
Embeddings  ..> PendingEmbeddingsGeneration   : creates via for()
Reranking   ..> PendingReranking              : creates via of()

' ─────────────────────────────────────────────
' Relationships: Facades → Fake Gateways
' ─────────────────────────────────────────────
Audio       ..> FakeAudioGateway          : fake() returns
Image       ..> FakeImageGateway          : fake() returns
Transcription ..> FakeTranscriptionGateway : fake() returns
Embeddings  ..> FakeEmbeddingGateway      : fake() returns
Reranking   ..> FakeRerankingGateway      : fake() returns

' ─────────────────────────────────────────────
' Relationships: Transcription → Audio Helpers
' ─────────────────────────────────────────────
Transcription ..> Base64Audio : wraps via fromBase64()
Transcription ..> LocalAudio  : wraps via fromPath()
Transcription ..> StoredAudio : wraps via fromStorage()
Transcription ..> TranscribableAudio : accepts in of()

note bottom of Reranking
  No queue-based asserts.
  Validates input is a list
  (not associative array).
end note

note bottom of Embeddings
  Uses <b>for()</b> instead of <b>of()</b>.
  fakeEmbedding() generates a
  unit-normalized random vector.
end note

note bottom of Transcription
  Most complex facade: 4 factory
  methods normalise different audio
  input types into TranscribableAudio.
end note

@enduml
