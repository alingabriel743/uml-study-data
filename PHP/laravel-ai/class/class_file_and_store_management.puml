@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
}
skinparam stereotypeCBackgroundColor #FFF3CD
skinparam stereotypeIBackgroundColor #D4EDDA

title File & Vector Store Management

' ─────────────────────────────────────────────
'  Contracts / Interfaces
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Contracts\\Files" {
    interface StorableFile {
    }

    interface HasProviderId {
    }
}

package "Laravel\\Ai\\Contracts\\Providers" {
    interface FileProvider {
    }

    interface StoreProvider {
    }
}

' ─────────────────────────────────────────────
'  Core Facade & Entity Classes
' ─────────────────────────────────────────────
package "Laravel\\Ai" {
    class Files <<static facade>> {
        +{static} get(fileId: string, provider: ?string): FileResponse
        +{static} put(file, mimeType: ?string, name: ?string, provider: ?string): StoredFileResponse
        +{static} putFromPath(path: string, mimeType: ?string, name: ?string, provider: ?string): StoredFileResponse
        +{static} putFromStorage(path: string, disk: ?string, name: ?string, provider: ?string): StoredFileResponse
        +{static} delete(fileId: string, provider: ?string): void
        +{static} fake(responses): FakeFileGateway
        +{static} fakeId(for: string): string
        +{static} assertStored(callback: Closure): void
        +{static} assertNotStored(callback: Closure): void
        +{static} assertNothingStored(): void
        +{static} assertDeleted(callback): void
        +{static} assertNotDeleted(callback): void
        +{static} assertNothingDeleted(): void
        +{static} isFaked(): bool
    }

    class Stores <<static facade>> {
        +{static} get(storeId: string, provider: ?string): Store
        +{static} create(name: string, description: ?string, fileIds, expiresWhenIdleFor: ?DateInterval, provider: ?string): Store
        +{static} delete(storeId: string, provider: ?string): bool
        +{static} fake(responses, files: bool): FakeStoreGateway
        +{static} fakeId(for: string): string
        +{static} assertCreated(callback): void
        +{static} assertNotCreated(callback): void
        +{static} assertNothingCreated(): void
        +{static} assertDeleted(callback): void
        +{static} assertNotDeleted(callback): void
        +{static} assertNothingDeleted(): void
        +{static} isFaked(): bool
    }

    class Store {
        #provider: FileProvider & StoreProvider
        +id: string
        +name: ?string
        +fileCounts: StoreFileCounts
        +ready: bool
        --
        +__construct(provider, id: string, name: ?string, fileCounts: StoreFileCounts, ready: bool)
        +add(file, metadata: array): AddedDocumentResponse
        +remove(documentId, deleteFile: bool): bool
        +refresh(): self
        +delete(): bool
        +assertAdded(fileId): self
        +assertNotAdded(fileId): self
        +assertRemoved(documentId): self
        +assertNotRemoved(documentId): self
        #storeFile(file: StorableFile): HasProviderId
        #fileAssertionCallback(fileId): Closure
        #fileIdMatches(file, expectedFileId: string): bool
    }
}

' ─────────────────────────────────────────────
'  Concrete File-Type Classes
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Files" {
    class Base64Document {
        +{static} fromUpload(file: UploadedFile): Base64Document
        +as(name: string): self
    }

    class Document {
        +{static} fromPath(path: string): Document
        +{static} fromStorage(path: string, disk: ?string): Document
    }

    class ProviderDocument {
        +__construct(fileId: string)
    }
}

' ─────────────────────────────────────────────
'  Testing / Fake Gateways
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Gateway" {
    class FakeFileGateway {
    }

    class FakeStoreGateway {
    }
}

' ─────────────────────────────────────────────
'  Response & Value Objects
' ─────────────────────────────────────────────
package "Responses & Value Objects" {
    class FileResponse <<value object>> {
    }

    class StoredFileResponse <<value object>> {
    }

    class AddedDocumentResponse <<value object>> {
    }

    class StoreFileCounts <<value object>> {
    }
}

' ─────────────────────────────────────────────
'  Interface Implementations
' ─────────────────────────────────────────────
Base64Document    ..|> StorableFile
Document          ..|> StorableFile
StoredFileResponse ..|> HasProviderId
ProviderDocument  ..|> HasProviderId

' ─────────────────────────────────────────────
'  Files Facade Relationships
' ─────────────────────────────────────────────
Files ..> FileResponse        : returns (get)
Files ..> StoredFileResponse  : returns (put/putFromPath/putFromStorage)
Files ..> FakeFileGateway     : creates (fake)
Files ..> Base64Document      : normalises string/UploadedFile input
Files ..> Document            : delegates fromPath / fromStorage

' ─────────────────────────────────────────────
'  Stores Facade Relationships
' ─────────────────────────────────────────────
Stores ..> Store             : creates / returns (get, create)
Stores ..> FakeStoreGateway  : creates (fake)
Stores ..> Files             : fake() calls Files::fake()

' ─────────────────────────────────────────────
'  Store Entity Relationships
' ─────────────────────────────────────────────
Store *-- StoreFileCounts      : fileCounts
Store ..> AddedDocumentResponse : returns (add)
Store ..> StorableFile          : accepts (add, storeFile)
Store ..> HasProviderId         : uses / returns (storeFile, remove)
Store ..> FileProvider          : injected as provider
Store ..> StoreProvider         : injected as provider
Store ..> Files                 : storeFile → Files::put;\nremove → Files::delete
Store ..> Base64Document        : normalises UploadedFile (add)
Store ..> ProviderDocument      : wraps string fileId for provider call

@enduml
