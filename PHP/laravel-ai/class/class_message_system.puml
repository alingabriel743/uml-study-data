@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}

title Message System

package "Laravel\\Ai\\Messages" {

    class Message {
        +role: MessageRole
        +content: ?string
        --
        +__construct(role: MessageRole|string, content: ?string = '')
        +{static} tryFrom(message: mixed): static
    }

    class UserMessage {
        +attachments: Collection
        --
        +__construct(content: string, attachments: Collection|array = [])
    }

    class AssistantMessage {
        +toolCalls: Collection
        --
        +__construct(content: string, toolCalls: ?Collection = null)
    }

    class ToolResultMessage {
        +toolResults: Collection
        --
        +__construct(toolResults: Collection)
    }

    enum MessageRole <<enumeration>> {
        Assistant = "assistant"
        User = "user"
        ToolResult = "tool_result"
    }

}

' Inheritance relationships
UserMessage --|> Message : extends
AssistantMessage --|> Message : extends
ToolResultMessage --|> Message : extends

' Dependency relationships
Message ..> MessageRole : uses (role property\n& tryFrom resolution)

note bottom of Message
  Concrete base class.
  tryFrom() is a static factory that accepts
  Message instance, array, or object
  with role/content properties.
end note

note right of ToolResultMessage
  content is always null;\n  role is fixed to 'tool_result'.
end note

@enduml
