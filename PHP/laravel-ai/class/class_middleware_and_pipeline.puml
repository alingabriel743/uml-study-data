@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
    FontColor #212529
}

title Middleware & Request Pipeline

' ─────────────────────────────────────────────
' Contracts
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Contracts" {

    interface HasMiddleware {
        +middleware(): array
    }

    interface ConversationStore {
        +latestConversationId(userId: string|int): ?string
        +storeConversation(userId: string|int|null, title: string): string
        +storeUserMessage(conversationId: string, userId: string|int|null, prompt: AgentPrompt): string
        +storeAssistantMessage(conversationId: string, userId: string|int|null, prompt: AgentPrompt, response: AgentResponse): string
        +getLatestConversationMessages(conversationId: string, limit: int): Collection
    }

}

package "Laravel\\Ai\\Contracts\\Providers" {

    interface TextProvider {
        +prompt(prompt: AgentPrompt): AgentResponse
        +stream(prompt: AgentPrompt): StreamableAgentResponse
        +textGateway(): TextGateway
        +useTextGateway(gateway: TextGateway): self
        +defaultTextModel(): string
        +cheapestTextModel(): string
        +smartestTextModel(): string
    }

}

package "Laravel\\Ai\\Contracts\\Gateway" {

    interface TextGateway {
        +generateText(provider: TextProvider, model: string, instructions: ?string, messages: array, tools: array, schema: ?array, options: ?TextGenerationOptions, timeout: ?int): TextResponse
        +streamText(invocationId: string, provider: TextProvider, model: string, instructions: ?string, messages: array, tools: array, schema: ?array, options: ?TextGenerationOptions, timeout: ?int): Generator
        +onToolInvocation(invoking: Closure, invoked: Closure): self
    }

}

' ─────────────────────────────────────────────
' Middleware
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Middleware" {

    class RememberConversation {
        #store: ConversationStore
        #provider: TextProvider
        --
        +__construct(store: ConversationStore, provider: TextProvider)
        +handle(prompt: AgentPrompt, next: Closure): mixed
        #generateTitle(prompt: string): string
    }

    note right of RememberConversation
        Laravel pipeline middleware.
        handle() calls $next($prompt)
        then chains AgentResponse::then()
        to persist conversation & messages.
        generateTitle() uses cheapest model
        via TextGateway; falls back to
        Str::limit() on any Throwable.
    end note

}

' ─────────────────────────────────────────────
' Prompts
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Prompts" {

    abstract class Prompt {
        +{readonly} prompt: string
        +{readonly} provider: TextProvider
        +{readonly} model: string
        --
        +__construct(prompt: string, provider: TextProvider, model: string)
    }

    class AgentPrompt {
        +{readonly} agent: Agent
        +{readonly} attachments: Collection
        +{readonly} timeout: ?int
        --
        +__construct(agent: Agent, prompt: string, attachments: Collection|array, provider: TextProvider, model: string, timeout: ?int)
        +contains(string: string): bool
        +prepend(prompt: string): AgentPrompt
        +append(prompt: string): AgentPrompt
        +revise(prompt: string, attachments: Collection|array|null): AgentPrompt
        +withAttachments(attachments: Collection|array): AgentPrompt
        +provider(): TextProvider
    }

}

' ─────────────────────────────────────────────
' Responses
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Responses" {

    class AgentResponse {
        +invocationId: string
        +conversationId: ?string
        +conversationUser: ?object
        --
        +__construct(invocationId: string, text: string, usage: Usage, meta: Meta)
        +withinConversation(conversationId: string, conversationUser: object): self
        +then(callback: callable): self
    }

}

' ─────────────────────────────────────────────
' Concerns (Trait)
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Concerns" {

    class RemembersConversations <<trait>> {
        #conversationId: ?string
        #conversationUser: ?object
        --
        +forUser(user): static
        +continue(conversationId: string, as: object): static
        +continueLastConversation(as: object): static
        +messages(): iterable
        +currentConversation(): ?string
        +hasConversationParticipant(): bool
        +conversationParticipant(): ?object
        #maxConversationMessages(): int
    }

    note bottom of RemembersConversations
        Used by Agent classes.
        continueLastConversation() and
        messages() resolve ConversationStore
        from the service container.
    end note

}

' ─────────────────────────────────────────────
' External placeholders
' ─────────────────────────────────────────────
class TextResponse <<external>> {
    +text: string
}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' Inheritance
AgentPrompt   --|> Prompt         : extends
AgentResponse --|> TextResponse   : extends

' RememberConversation dependencies (constructor injection)
RememberConversation *-- ConversationStore : #store
RememberConversation *-- TextProvider      : #provider

' RememberConversation uses (method params / return)
RememberConversation ..> AgentPrompt   : handle() param
RememberConversation ..> AgentResponse : handle() returns via $next

' TextProvider exposes TextGateway
TextProvider ..> TextGateway : textGateway()

' RemembersConversations resolves ConversationStore at runtime
RemembersConversations ..> ConversationStore : resolves from container

' AgentPrompt owns an Agent that uses the trait
AgentPrompt ..> RemembersConversations : agent uses trait

@enduml
