@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9E6
    BorderColor #D4B106
}

title Pending Response Builder Classes

' ─────────────────────────────────────────
'  Shared trait
' ─────────────────────────────────────────
package "Laravel\\Illuminate\\Support" {
    class Conditionable <<trait>> {
        +when(mixed $value, callable $callback): static
        +unless(mixed $value, callable $callback): static
    }
}

' ─────────────────────────────────────────
'  Core Infrastructure Dependencies
' ─────────────────────────────────────────
package "Laravel\\Ai\\Support" {
    class Provider <<utility>> {
        +{static} formatProviderAndModelList(mixed $provider, ?string $model): array
    }

    class Ai <<facade>> {
        +{static} fakeableImageProvider(string $name): ImageProviderContract
        +{static} fakeableAudioProvider(string $name): AudioProviderContract
        +{static} fakeableTranscriptionProvider(string $name): TranscriptionProviderContract
        +{static} fakeableEmbeddingProvider(string $name): EmbeddingProviderContract
        +{static} fakeableRerankingProvider(string $name): RerankingProviderContract
        +{static} imagesAreFaked(): bool
        +{static} audioIsFaked(): bool
        +{static} transcriptionsAreFaked(): bool
        +{static} embeddingsAreFaked(): bool
        +{static} recordImageGeneration(mixed $prompt): void
        +{static} recordAudioGeneration(mixed $prompt): void
        +{static} recordTranscriptionGeneration(mixed $prompt): void
        +{static} recordEmbeddingsGeneration(mixed $prompt): void
    }

    class FakePendingDispatch <<fake>> {
        +__construct(mixed $job)
        +onConnection(string $connection): self
        +onQueue(string $queue): self
        +delay(mixed $delay): self
        +afterCommit(): self
        +chain(array $chain): self
        +getJob(): mixed
    }

    class FailoverableException <<exception>> {
    }

    class ProviderFailedOver <<event>> {
    }
}

' ─────────────────────────────────────────
'  Contracts
' ─────────────────────────────────────────
package "Laravel\\Ai\\Contracts" {
    interface TranscribableAudio <<contract>> {
    }

    interface CacheRepository <<contract>> {
        +get(string $key): mixed
        +put(string $key, mixed $value, mixed $ttl): bool
    }
}

' ─────────────────────────────────────────
'  Response Types
' ─────────────────────────────────────────
package "Laravel\\Ai\\Responses" {
    class ImageResponse <<response>> {
    }
    class QueuedImageResponse <<queued-response>> {
    }

    class AudioResponse <<response>> {
    }
    class QueuedAudioResponse <<queued-response>> {
    }

    class TranscriptionResponse <<response>> {
    }
    class QueuedTranscriptionResponse <<queued-response>> {
    }

    class EmbeddingsResponse <<response>> {
    }
    class QueuedEmbeddingsResponse <<queued-response>> {
    }

    class RerankingResponse <<response>> {
    }
}

' ─────────────────────────────────────────
'  Pending Builder Classes
' ─────────────────────────────────────────
package "Laravel\\Ai\\PendingResponses" {

    class PendingImageGeneration {
        +array $attachments = []
        +?string $size = null
        +?string $quality = null
        +?int $timeout = null
        --
        +__construct(string $prompt)
        ..Fluent Configuration..
        +attachments(array $attachments): self
        +size(string $size): self
        +square(): self
        +portrait(): self
        +landscape(): self
        +quality(string $quality): self
        +timeout(?int $timeout): self
        ..Dispatch..
        +generate(mixed $provider, ?string $model): ImageResponse
        +queue(mixed $provider, ?string $model): QueuedImageResponse
        ..Internal..
        #ensureAttachmentsAreQueueable(): void
    }

    class PendingAudioGeneration {
        #string $text
        #string $voice = 'default-female'
        #?string $instructions = null
        #int $timeout = 30
        --
        +__construct(string $text)
        ..Fluent Configuration..
        +voice(string $voice): self
        +male(): self
        +female(): self
        +instructions(string $instructions): self
        +timeout(int $seconds): self
        ..Dispatch..
        +generate(mixed $provider, ?string $model): AudioResponse
        +queue(mixed $provider, ?string $model): QueuedAudioResponse
    }

    class PendingTranscriptionGeneration {
        #TranscribableAudio $audio
        #?string $language = null
        #bool $diarize = false
        #int $timeout = 30
        --
        +__construct(TranscribableAudio $audio)
        ..Fluent Configuration..
        +language(string $language): self
        +diarize(bool $diarize = true): self
        +timeout(int $seconds): self
        ..Dispatch..
        +generate(mixed $provider, ?string $model): TranscriptionResponse
        +queue(mixed $provider, ?string $model): QueuedTranscriptionResponse
    }

    class PendingEmbeddingsGeneration {
        #array $inputs
        #?int $dimensions = null
        #?int $cacheSeconds = null
        #int $timeout = 30
        --
        +__construct(array $inputs)
        ..Fluent Configuration..
        +dimensions(int $dimensions): self
        +cache(?int $seconds = null): self
        +timeout(int $seconds): self
        ..Dispatch..
        +generate(mixed $provider, ?string $model): EmbeddingsResponse
        +queue(mixed $provider, ?string $model): QueuedEmbeddingsResponse
        ..Cache Internals..
        #generateFromCache(Provider $provider, string $model, int $dimensions): ?EmbeddingsResponse
        #cacheEmbeddings(Provider $provider, string $model, int $dims, EmbeddingsResponse $r): void
        #cacheKey(Provider $provider, string $model, int $dimensions): string
        #cacheStore(): CacheRepository
        #shouldCache(): bool
    }

    class PendingReranking {
        #array $documents
        #?int $limit = null
        --
        +__construct(array $documents)
        ..Fluent Configuration..
        +limit(?int $limit): self
        ..Dispatch (sync only)..
        +rerank(string $query, mixed $provider, ?string $model): RerankingResponse
    }

    note bottom of PendingReranking
        Synchronous only.
        No queue() method.
    end note

    note right of PendingEmbeddingsGeneration
        Cache key = sha256(driver + model + dimensions + inputs)
        Default TTL = 30 days
    end note
}

' ─────────────────────────────────────────
'  Trait Usage
' ─────────────────────────────────────────
PendingImageGeneration ..|> Conditionable : <<use>>
PendingAudioGeneration ..|> Conditionable : <<use>>
PendingTranscriptionGeneration ..|> Conditionable : <<use>>
PendingEmbeddingsGeneration ..|> Conditionable : <<use>>
PendingReranking ..|> Conditionable : <<use>>

' ─────────────────────────────────────────
'  Dispatch Return Types
' ─────────────────────────────────────────
PendingImageGeneration ..> ImageResponse : generate() returns
PendingImageGeneration ..> QueuedImageResponse : queue() returns

PendingAudioGeneration ..> AudioResponse : generate() returns
PendingAudioGeneration ..> QueuedAudioResponse : queue() returns

PendingTranscriptionGeneration ..> TranscriptionResponse : generate() returns
PendingTranscriptionGeneration ..> QueuedTranscriptionResponse : queue() returns

PendingEmbeddingsGeneration ..> EmbeddingsResponse : generate() returns
PendingEmbeddingsGeneration ..> QueuedEmbeddingsResponse : queue() returns

PendingReranking ..> RerankingResponse : rerank() returns

' ─────────────────────────────────────────
'  Constructor Dependencies
' ─────────────────────────────────────────
PendingTranscriptionGeneration o-- TranscribableAudio : depends on

' ─────────────────────────────────────────
'  Shared Infrastructure Dependencies
' ─────────────────────────────────────────
PendingImageGeneration ..> Provider : resolves providers via
PendingAudioGeneration ..> Provider : resolves providers via
PendingTranscriptionGeneration ..> Provider : resolves providers via
PendingEmbeddingsGeneration ..> Provider : resolves providers via
PendingReranking ..> Provider : resolves providers via

PendingImageGeneration ..> Ai : fake / record via
PendingAudioGeneration ..> Ai : fake / record via
PendingTranscriptionGeneration ..> Ai : fake / record via
PendingEmbeddingsGeneration ..> Ai : fake / record via

PendingImageGeneration ..> FakePendingDispatch : queue (faked) wraps
PendingAudioGeneration ..> FakePendingDispatch : queue (faked) wraps
PendingTranscriptionGeneration ..> FakePendingDispatch : queue (faked) wraps
PendingEmbeddingsGeneration ..> FakePendingDispatch : queue (faked) wraps

PendingImageGeneration ..> FailoverableException : failover loop
PendingAudioGeneration ..> FailoverableException : failover loop
PendingTranscriptionGeneration ..> FailoverableException : failover loop
PendingEmbeddingsGeneration ..> FailoverableException : failover loop
PendingReranking ..> FailoverableException : failover loop

PendingImageGeneration ..> ProviderFailedOver : fires on failover
PendingAudioGeneration ..> ProviderFailedOver : fires on failover
PendingTranscriptionGeneration ..> ProviderFailedOver : fires on failover
PendingEmbeddingsGeneration ..> ProviderFailedOver : fires on failover
PendingReranking ..> ProviderFailedOver : fires on failover

PendingEmbeddingsGeneration ..> CacheRepository : optional caching via

@enduml
