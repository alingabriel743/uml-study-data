@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #EEF4FF
    BorderColor #3B6FD4
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Provider Contracts & Interfaces

'------------------------------------------------------------
' External
'------------------------------------------------------------
interface Stringable <<PHP>> #F0F0F0 {
    +__toString(): string
}

'------------------------------------------------------------
' File Contracts
'------------------------------------------------------------
package "Laravel\\Ai\\Contracts\\Files" {

    interface HasContent {
        +content(): string
    }

    interface HasMimeType {
        +mimeType(): ?string
    }

    interface HasName {
        +name(): ?string
        +as(name: ?string): static
    }

    interface HasProviderId {
        +id(): string
    }

    interface StorableFile {
        ' Composite: HasContent + HasMimeType + HasName + Stringable
    }

    interface TranscribableAudio {
        +transcription(): PendingTranscriptionGeneration
    }
}

'------------------------------------------------------------
' Gateway Interfaces
'------------------------------------------------------------
package "Laravel\\Ai\\Contracts\\Gateway" {

    interface TextGateway {
        +generateText(provider, model, instructions, messages,\n  tools, schema, options, timeout): TextResponse
        +streamText(invocationId, provider, model, instructions,\n  messages, tools, schema, options, timeout): Generator
        +onToolInvocation(invoking: Closure, invoked: Closure): self
    }

    interface AudioGateway {
        +generateAudio(provider, model, text, voice,\n  instructions, timeout): AudioResponse
    }

    interface ImageGateway {
        +generateImage(provider, model, prompt, attachments,\n  size, quality, timeout): ImageResponse
    }

    interface EmbeddingGateway {
        +generateEmbeddings(provider, model, inputs,\n  dimensions, timeout): EmbeddingsResponse
    }

    interface RerankingGateway {
        +rerank(provider, model, documents, query,\n  limit): RerankingResponse
    }

    interface TranscriptionGateway {
        +generateTranscription(provider, model, audio,\n  language, diarize, timeout): TranscriptionResponse
    }

    interface FileGateway {
        +getFile(provider, fileId): FileResponse
        +putFile(provider, file: StorableFile): StoredFileResponse
        +deleteFile(provider, fileId): void
    }

    interface StoreGateway {
        +getStore(provider, storeId): Store
        +createStore(provider, name, description,\n  fileIds, expiresWhenIdleFor): Store
        +addFile(provider, storeId, fileId, metadata): string
        +removeFile(provider, storeId, documentId): bool
        +deleteStore(provider, storeId): bool
    }

    interface Gateway {
        ' Composite gateway — aggregates Text, Audio,\n  Image, Embedding & Transcription gateways
    }
}

'------------------------------------------------------------
' Provider Interfaces
'------------------------------------------------------------
package "Laravel\\Ai\\Contracts\\Providers" {

    interface TextProvider {
        +prompt(prompt: AgentPrompt): AgentResponse
        +stream(prompt: AgentPrompt): StreamableAgentResponse
        +textGateway(): TextGateway
        +useTextGateway(gateway: TextGateway): self
        +defaultTextModel(): string
        +cheapestTextModel(): string
        +smartestTextModel(): string
    }

    interface AudioProvider {
        +audio(text, voice, instructions, model,\n  timeout): AudioResponse
        +audioGateway(): AudioGateway
        +useAudioGateway(gateway: AudioGateway): self
        +defaultAudioModel(): string
    }

    interface ImageProvider {
        +image(prompt, attachments, size, quality,\n  model, timeout): ImageResponse
        +imageGateway(): ImageGateway
        +useImageGateway(gateway: ImageGateway): self
        +defaultImageModel(): string
        +defaultImageOptions(size, quality): array
    }

    interface EmbeddingProvider {
        +embeddings(inputs, dimensions, model,\n  timeout): EmbeddingsResponse
        +embeddingGateway(): EmbeddingGateway
        +useEmbeddingGateway(gateway: EmbeddingGateway): self
        +defaultEmbeddingsModel(): string
        +defaultEmbeddingsDimensions(): int
    }

    interface RerankingProvider {
        +rerank(documents, query, limit, model): RerankingResponse
        +rerankingGateway(): RerankingGateway
        +useRerankingGateway(gateway: RerankingGateway): self
        +defaultRerankingModel(): string
    }

    interface TranscriptionProvider {
        +transcribe(audio: TranscribableAudio, language,\n  diarize, model): TranscriptionResponse
        +transcriptionGateway(): TranscriptionGateway
        +useTranscriptionGateway(gateway: TranscriptionGateway): self
        +defaultTranscriptionModel(): string
    }

    interface FileProvider {
        +getFile(fileId: string): FileResponse
        +putFile(file: StorableFile): StoredFileResponse
        +deleteFile(fileId: string): void
        +fileGateway(): FileGateway
        +useFileGateway(gateway: FileGateway): self
    }

    interface StoreProvider {
        +getStore(storeId: string): Store
        +createStore(name, description, fileIds,\n  expiresWhenIdleFor): Store
        +addFileToStore(storeId, file: HasProviderId): string
        +removeFileFromStore(storeId, fileId): bool
        +deleteStore(storeId: string): bool
        +storeGateway(): StoreGateway
        +useStoreGateway(gateway: StoreGateway): self
    }

    ' Capability Mixin Interfaces
    interface SupportsFileSearch {
        +fileSearchToolOptions(search: FileSearch): array
    }

    interface SupportsWebSearch {
        +webSearchToolOptions(search: WebSearch): array
    }

    interface SupportsWebFetch {
        +webFetchToolOptions(fetch: WebFetch): array
    }
}

'------------------------------------------------------------
' File Contract Inheritance
'------------------------------------------------------------
HasContent    --|> Stringable
StorableFile  --|> HasContent
StorableFile  --|> HasMimeType
StorableFile  --|> HasName
TranscribableAudio --|> HasContent
TranscribableAudio --|> HasMimeType

'------------------------------------------------------------
' Composite Gateway Inheritance
'------------------------------------------------------------
Gateway --|> TextGateway
Gateway --|> AudioGateway
Gateway --|> ImageGateway
Gateway --|> EmbeddingGateway
Gateway --|> TranscriptionGateway

'------------------------------------------------------------
' Provider ↔ Gateway Associations (getter/setter pattern)
'------------------------------------------------------------
TextProvider         o-- TextGateway         : uses / configures
AudioProvider        o-- AudioGateway        : uses / configures
ImageProvider        o-- ImageGateway        : uses / configures
EmbeddingProvider    o-- EmbeddingGateway    : uses / configures
RerankingProvider    o-- RerankingGateway    : uses / configures
TranscriptionProvider o-- TranscriptionGateway : uses / configures
FileProvider         o-- FileGateway         : uses / configures
StoreProvider        o-- StoreGateway        : uses / configures

'------------------------------------------------------------
' Provider Dependencies on File Contracts
'------------------------------------------------------------
TranscriptionProvider ..> TranscribableAudio : <<input>>
FileProvider          ..> StorableFile       : <<input>>
StoreProvider         ..> HasProviderId      : <<input>>

'------------------------------------------------------------
' Capability Mixin Notes
'------------------------------------------------------------
note bottom of SupportsFileSearch
  Optional capability mixin for
  TextProvider implementations
end note

note bottom of SupportsWebSearch
  Optional capability mixin for
  TextProvider implementations
end note

note bottom of SupportsWebFetch
  Optional capability mixin for
  TextProvider implementations
end note

note bottom of Gateway
  Composite: aggregates Text + Audio +
  Image + Embedding + Transcription gateways.
  FileGateway, StoreGateway & RerankingGateway
  are NOT part of the composite.
end note

@enduml
