@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontColor #0D47A1
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Provider Implementations

' ─────────────────────────────────────────────
' PROVIDER CAPABILITY CONTRACTS
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Contracts\\Providers" {

    interface TextProvider {
        +prompt(AgentPrompt): AgentResponse
        +stream(AgentPrompt): StreamableAgentResponse
        +defaultTextModel(): string
        +cheapestTextModel(): string
        +smartestTextModel(): string
    }

    interface ImageProvider {
        +image(prompt, attachments, size, quality, model, timeout): ImageResponse
        +defaultImageModel(): string
        +defaultImageOptions(?string, mixed): array
    }

    interface AudioProvider {
        +audio(text, voice, instructions, model, timeout): AudioResponse
        +defaultAudioModel(): string
    }

    interface TranscriptionProvider {
        +transcribe(TranscribableAudio, language, diarize, model): TranscriptionResponse
        +defaultTranscriptionModel(): string
    }

    interface EmbeddingProvider {
        +embeddings(inputs, dimensions, model, timeout): EmbeddingsResponse
        +defaultEmbeddingsModel(): string
        +defaultEmbeddingsDimensions(): int
    }

    interface RerankingProvider {
        +rerank(documents, query, limit, model): RerankingResponse
        +defaultRerankingModel(): string
    }

    interface FileProvider {
        +getFile(fileId): FileResponse
        +putFile(StorableFile): StoredFileResponse
        +deleteFile(fileId): void
    }

    interface StoreProvider {
        +getStore(storeId): Store
        +createStore(name, description, fileIds, expiresWhenIdleFor): Store
        +addFileToStore(storeId, file): string
        +deleteStore(storeId): bool
    }

    interface SupportsFileSearch {
        +fileSearchToolOptions(FileSearch): array
    }

    interface SupportsWebSearch {
        +webSearchToolOptions(WebSearch): array
    }

    interface SupportsWebFetch {
        +webFetchToolOptions(WebFetch): array
    }
}

' ─────────────────────────────────────────────
' ABSTRACT BASE PROVIDER
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Providers" {

    abstract class Provider {
        #Gateway $gateway
        #array $config
        #Dispatcher $events
        --
        +__construct(Gateway, array, Dispatcher)
        +name(): string
        +driver(): string
        +providerCredentials(): array
        +additionalConfiguration(): array
        +__toString(): string
    }

    ' ─── Concrete Providers ───────────────────

    class OpenAiProvider {
        +defaultTextModel(): string
        +cheapestTextModel(): string
        +smartestTextModel(): string
        +defaultImageModel(): string
        +defaultAudioModel(): string
        +defaultTranscriptionModel(): string
        +defaultEmbeddingsModel(): string
        +defaultEmbeddingsDimensions(): int
        +fileSearchToolOptions(FileSearch): array
        +webSearchToolOptions(WebSearch): array
    }

    class AnthropicProvider {
        +defaultTextModel(): string
        +cheapestTextModel(): string
        +smartestTextModel(): string
        +webFetchToolOptions(WebFetch): array
        +webSearchToolOptions(WebSearch): array
    }

    class GeminiProvider {
        +defaultTextModel(): string
        +cheapestTextModel(): string
        +smartestTextModel(): string
        +defaultImageModel(): string
        +defaultEmbeddingsModel(): string
        +defaultEmbeddingsDimensions(): int
        +fileSearchToolOptions(FileSearch): array
        +webFetchToolOptions(WebFetch): array
        +webSearchToolOptions(WebSearch): array
    }

    class AzureOpenAiProvider {
        +__construct(array, Dispatcher)
        +defaultTextModel(): string
        +cheapestTextModel(): string
        +defaultEmbeddingsModel(): string
        +defaultEmbeddingsDimensions(): int
        -azureGateway(): AzureOpenAiGateway
    }

    class ElevenLabsProvider {
        +__construct(array, Dispatcher)
        +defaultAudioModel(): string
        +defaultTranscriptionModel(): string
    }

    class CohereProvider {
        +__construct(array, Dispatcher)
        +defaultEmbeddingsModel(): string
        +defaultEmbeddingsDimensions(): int
        +defaultRerankingModel(): string
    }

    class VoyageAiProvider {
        +__construct(array, Dispatcher)
        +defaultEmbeddingsModel(): string
        +defaultEmbeddingsDimensions(): int
        +defaultRerankingModel(): string
    }

    class JinaProvider {
        +__construct(array, Dispatcher)
        +defaultEmbeddingsModel(): string
        +defaultRerankingModel(): string
    }

    class MistralProvider {
        +defaultTextModel(): string
        +defaultEmbeddingsModel(): string
        +defaultTranscriptionModel(): string
    }

    class GroqProvider {
        +defaultTextModel(): string
    }

    class DeepSeekProvider {
        +defaultTextModel(): string
    }

    class OllamaProvider {
        +defaultTextModel(): string
        +defaultEmbeddingsModel(): string
    }

    class OpenRouterProvider {
        +defaultTextModel(): string
        +defaultEmbeddingsModel(): string
    }

    class XaiProvider {
        +defaultTextModel(): string
        +defaultImageModel(): string
    }
}

' ─────────────────────────────────────────────
' CONCERN TRAITS (abbreviated)
' ─────────────────────────────────────────────
package "Laravel\\Ai\\Providers\\Concerns" {

    class GeneratesText <<trait>> {
        +prompt(): AgentResponse
    }
    class GeneratesImages <<trait>> {
        +image(): ImageResponse
    }
    class GeneratesAudio <<trait>> {
        +audio(): AudioResponse
    }
    class GeneratesEmbeddings <<trait>> {
        +embeddings(): EmbeddingsResponse
    }
    class GeneratesTranscriptions <<trait>> {
        +transcribe(): TranscriptionResponse
    }
    class StreamsText <<trait>> {
        +stream(): StreamableAgentResponse
    }
    class ManagesFiles <<trait>> {
        +getFile() / putFile() / deleteFile()
    }
    class ManagesStores <<trait>> {
        +getStore() / createStore() / deleteStore()
    }
    class Reranks <<trait>> {
        +rerank(): RerankingResponse
    }
}

' ─────────────────────────────────────────────
' INHERITANCE: all providers extend Provider
' ─────────────────────────────────────────────
Provider <|-- OpenAiProvider
Provider <|-- AnthropicProvider
Provider <|-- GeminiProvider
Provider <|-- AzureOpenAiProvider
Provider <|-- ElevenLabsProvider
Provider <|-- CohereProvider
Provider <|-- VoyageAiProvider
Provider <|-- JinaProvider
Provider <|-- MistralProvider
Provider <|-- GroqProvider
Provider <|-- DeepSeekProvider
Provider <|-- OllamaProvider
Provider <|-- OpenRouterProvider
Provider <|-- XaiProvider

' ─────────────────────────────────────────────
' INTERFACE IMPLEMENTATIONS
' ─────────────────────────────────────────────
' OpenAi — most capable (text, image, audio, embeddings, transcription, file, store, fileSearch, webSearch)
OpenAiProvider ..|> TextProvider
OpenAiProvider ..|> ImageProvider
OpenAiProvider ..|> AudioProvider
OpenAiProvider ..|> EmbeddingProvider
OpenAiProvider ..|> TranscriptionProvider
OpenAiProvider ..|> FileProvider
OpenAiProvider ..|> StoreProvider
OpenAiProvider ..|> SupportsFileSearch
OpenAiProvider ..|> SupportsWebSearch

' Anthropic — text, file, webFetch, webSearch
AnthropicProvider ..|> TextProvider
AnthropicProvider ..|> FileProvider
AnthropicProvider ..|> SupportsWebFetch
AnthropicProvider ..|> SupportsWebSearch

' Gemini — text, image, embeddings, file, store, fileSearch, webFetch, webSearch
GeminiProvider ..|> TextProvider
GeminiProvider ..|> ImageProvider
GeminiProvider ..|> EmbeddingProvider
GeminiProvider ..|> FileProvider
GeminiProvider ..|> StoreProvider
GeminiProvider ..|> SupportsFileSearch
GeminiProvider ..|> SupportsWebFetch
GeminiProvider ..|> SupportsWebSearch

' Azure — text + embeddings only (shared gateway)
AzureOpenAiProvider ..|> TextProvider
AzureOpenAiProvider ..|> EmbeddingProvider

' ElevenLabs — audio + transcription only
ElevenLabsProvider ..|> AudioProvider
ElevenLabsProvider ..|> TranscriptionProvider

' Cohere — embeddings + reranking
CohereProvider ..|> EmbeddingProvider
CohereProvider ..|> RerankingProvider

' VoyageAi — embeddings + reranking
VoyageAiProvider ..|> EmbeddingProvider
VoyageAiProvider ..|> RerankingProvider

' Jina — embeddings + reranking
JinaProvider ..|> EmbeddingProvider
JinaProvider ..|> RerankingProvider

' Mistral — text + embeddings + transcription
MistralProvider ..|> TextProvider
MistralProvider ..|> EmbeddingProvider
MistralProvider ..|> TranscriptionProvider

' Groq / DeepSeek — text only
GroqProvider ..|> TextProvider
DeepSeekProvider ..|> TextProvider

' Ollama / OpenRouter — text + embeddings
OllamaProvider ..|> TextProvider
OllamaProvider ..|> EmbeddingProvider
OpenRouterProvider ..|> TextProvider
OpenRouterProvider ..|> EmbeddingProvider

' Xai — text + image
XaiProvider ..|> TextProvider
XaiProvider ..|> ImageProvider

' ─────────────────────────────────────────────
' TRAIT USAGE (representative — not exhaustive)
' ─────────────────────────────────────────────
OpenAiProvider ..> GeneratesText : uses
OpenAiProvider ..> GeneratesImages : uses
OpenAiProvider ..> GeneratesAudio : uses
OpenAiProvider ..> GeneratesEmbeddings : uses
OpenAiProvider ..> GeneratesTranscriptions : uses
OpenAiProvider ..> StreamsText : uses
OpenAiProvider ..> ManagesFiles : uses
OpenAiProvider ..> ManagesStores : uses

AnthropicProvider ..> GeneratesText : uses
AnthropicProvider ..> StreamsText : uses
AnthropicProvider ..> ManagesFiles : uses

GeminiProvider ..> GeneratesText : uses
GeminiProvider ..> GeneratesImages : uses
GeminiProvider ..> GeneratesEmbeddings : uses
GeminiProvider ..> StreamsText : uses
GeminiProvider ..> ManagesFiles : uses
GeminiProvider ..> ManagesStores : uses

CohereProvider ..> GeneratesEmbeddings : uses
CohereProvider ..> Reranks : uses
VoyageAiProvider ..> GeneratesEmbeddings : uses
VoyageAiProvider ..> Reranks : uses
JinaProvider ..> GeneratesEmbeddings : uses
JinaProvider ..> Reranks : uses

ElevenLabsProvider ..> GeneratesAudio : uses
ElevenLabsProvider ..> GeneratesTranscriptions : uses

' ─────────────────────────────────────────────
' NOTES
' ─────────────────────────────────────────────
note top of AzureOpenAiProvider
  Shares a single AzureOpenAiGateway
  for both TextGateway and EmbeddingGateway
end note

note bottom of Provider
  CohereProvider, VoyageAiProvider,
  ElevenLabsProvider, AzureOpenAiProvider,
  JinaProvider omit the Gateway parameter
  from their constructors
end note

@enduml
