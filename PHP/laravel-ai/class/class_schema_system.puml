@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Schema & Structured Output

package "Laravel\\Ai\\Contracts" {
    interface Schemable {
        +name(): string
        +toSchema(): array<string,mixed>
    }
}

package "Laravel\\Ai" {
    class Schema {
        +Type $schema
        +string $name = "schema_definition"
        +bool $strict = true
        --
        +__construct(Type $schema, string $name, bool $strict)
        +name(): string
        +withName(string $name): self
        +toArray(): array
        +toSchema(): array
    }

    class ObjectSchema {
        --
        +__construct(array $schema, string $name, bool $strict)
        +toSchema(): array
        +schemaType(): string
        #disableAdditionalProperties(array $schema): array
    }

    class StructuredAnonymousAgent {
        -Schemable $schema
        --
        +__construct(Schemable $schema)
        +schema(Schemable $schema): self
    }
}

package "Prism (External)" <<Rectangle>> {
    interface PrismSchema <<external>> {
        +toArray(): array
    }

    interface HasSchemaType <<external>> {
        +schemaType(): string
    }
}

package "Illuminate\\JsonSchema (External)" <<Rectangle>> {
    class Type <<external>> {
        +toArray(): array
    }

    class ObjectType <<external>> {
        +withoutAdditionalProperties(): self
    }
}

' Inheritance
ObjectSchema --|> Schema : extends
ObjectType --|> Type : extends

' Interface implementations
Schema ..|> PrismSchema : implements
Schema ..|> Schemable : implements
ObjectSchema ..|> HasSchemaType : implements

' Composition / Dependencies
Schema *-- Type : composes\n$schema
ObjectSchema ..> ObjectType : creates in\nconstructor
StructuredAnonymousAgent o-- Schemable : holds\n$schema

note bottom of ObjectSchema
  Recursively sets
  additionalProperties=false
  on all object/array nodes
  via disableAdditionalProperties()
end note

note right of Schema
  Immutable builder pattern:
  withName() returns a new instance
end note

@enduml
