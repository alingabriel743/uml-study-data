@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D1ECF1
    BorderColor #0C5460
    FontColor #0C5460
}

title Testing & Fake Support

' ─── Contracts (Interfaces) ──────────────────────────────────
package "Laravel\\Ai\\Contracts\\Gateway" {
    interface TextGateway {
        +generateText(...): TextResponse
        +streamText(...): Generator
        +onToolInvocation(Closure, Closure): self
    }
    interface EmbeddingGateway {
        +generateEmbeddings(...): EmbeddingsResponse
    }
    interface AudioGateway {
        +generateAudio(...): AudioResponse
    }
    interface ImageGateway {
        +generateImage(...): ImageResponse
    }
    interface TranscriptionGateway {
        +generateTranscription(...): TranscriptionResponse
    }
    interface RerankingGateway {
        +rerank(...): RerankingResponse
    }
    interface FileGateway {
        +getFile(...): FileResponse
        +putFile(...): StoredFileResponse
        +deleteFile(...): void
    }
    interface StoreGateway {
        +getStore(...): Store
        +createStore(...): Store
        +addFile(...): string
        +removeFile(...): bool
        +deleteStore(...): bool
    }
}

' ─── Fake Gateways ───────────────────────────────────────────
package "Laravel\\Ai\\Gateway" {
    class FakeTextGateway {
        -responses: Closure|array
        -currentResponseIndex: int
        -preventStrayPrompts: bool
        --
        +__construct(Closure|array $responses)
        +generateText(...): TextResponse
        +streamText(...): Generator
        +onToolInvocation(Closure, Closure): self
        +preventStrayPrompts(bool): self
        #nextResponse(...): mixed
        #marshalResponse(...): mixed
    }

    class FakeEmbeddingGateway {
        -responses: Closure|array
        -currentResponseIndex: int
        -preventStrayGenerations: bool
        --
        +__construct(Closure|array $responses = [])
        +generateEmbeddings(...): EmbeddingsResponse
        +preventStrayEmbeddings(bool): self
        #nextResponse(...): EmbeddingsResponse
        #marshalResponse(...): EmbeddingsResponse
        #generateFakeEmbeddings(int $count, int $dimensions): array
    }

    class FakeAudioGateway {
        -responses: Closure|array
        -currentResponseIndex: int
        -preventStrayGenerations: bool
        --
        +__construct(Closure|array $responses = [])
        +generateAudio(...): AudioResponse
        +preventStrayAudio(bool): self
        #nextResponse(...): AudioResponse
        #marshalResponse(...): AudioResponse
    }

    class FakeImageGateway {
        -responses: Closure|array
        -currentResponseIndex: int
        -preventStrayGenerations: bool
        --
        +__construct(Closure|array $responses = [])
        +generateImage(...): ImageResponse
        +preventStrayImages(bool): self
        #nextResponse(...): ImageResponse
        #marshalResponse(...): ImageResponse
    }

    class FakeTranscriptionGateway {
        -responses: Closure|array
        -currentResponseIndex: int
        -preventStrayGenerations: bool
        --
        +__construct(Closure|array $responses = [])
        +generateTranscription(...): TranscriptionResponse
        +preventStrayTranscriptions(bool): self
        #nextResponse(...): TranscriptionResponse
        #marshalResponse(...): TranscriptionResponse
    }

    class FakeRerankingGateway {
        -responses: Closure|array
        -currentResponseIndex: int
        -preventStrayRerankings: bool
        --
        +__construct(Closure|array $responses = [])
        +rerank(...): RerankingResponse
        +preventStrayRerankings(bool): self
        #nextResponse(...): RerankingResponse
        #marshalResponse(...): RerankingResponse
        #generateFakeRanking(array $docs, ?int $limit): array
    }

    class FakeFileGateway {
        -responses: Closure|array
        -currentResponseIndex: int
        -preventStrayOperations: bool
        --
        +__construct(Closure|array $responses = [])
        +getFile(FileProvider, string $fileId): FileResponse
        +putFile(FileProvider, StorableFile): StoredFileResponse
        +deleteFile(FileProvider, string $fileId): void
        +preventStrayOperations(bool): self
        #nextGetResponse(string $fileId): FileResponse
        #marshalGetResponse(mixed, string $fileId): FileResponse
    }

    class FakeStoreGateway {
        -responses: Closure|array
        -currentResponseIndex: int
        -preventStrayOperations: bool
        --
        +__construct(Closure|array $responses = [])
        +getStore(StoreProvider, string $storeId): Store
        +createStore(StoreProvider, string $name, ...): Store
        +addFile(StoreProvider, string $storeId, string $fileId, ...): string
        +removeFile(StoreProvider, string $storeId, string $documentId): bool
        +deleteStore(StoreProvider, string $storeId): bool
        +preventStrayOperations(bool): self
        #nextGetResponse(...): Store
        #marshalGetResponse(...): Store
    }
}

' ─── Dispatch & Queue Fake ───────────────────────────────────
package "Laravel\\Ai" {
    class FakePendingDispatch {
        --
        +__construct(): void
        +onConnection($connection): static
        +onQueue($queue): static
        +onGroup($group): static
        +delay($delay): static
        +withoutDelay(): static
        +afterCommit(): static
        +beforeCommit(): static
        +chain($chain): static
        +afterResponse($afterResponse = true): static
        +getJob(): mixed
        +__call($method, $parameters): static
        +__destruct(): void
        #shouldDispatch(): bool
    }
}

' ─── Response Concerns ───────────────────────────────────────
package "Laravel\\Ai\\Responses\\Concerns" {
    class HasQueuedResponseCallbacks << (T,#FF9900) Trait >> {
        +then(Closure $callback): self
        +catch(Closure $callback): self
    }
}

' ─── Test Infrastructure ─────────────────────────────────────
package "Tests" {
    abstract class TestCase {
        +getPackageProviders($app): array
    }
}

package "Laravel\\Ai\\Migrations" {
    abstract class AiMigration {
        +getConnection(): ?string
    }
}

' ─── External Base Classes ───────────────────────────────────
package "External" #F0F0F0 {
    class "Illuminate\\Foundation\\Bus\\PendingDispatch" as PendingDispatch <<external>>
    class "Orchestra\\Testbench\\TestCase" as OrchestraTestCase <<external>>
    class "Illuminate\\Database\\Migrations\\Migration" as IlluminateMigration <<external>>
}

' ─── Interface Implementations ───────────────────────────────
FakeTextGateway ..|> TextGateway
FakeEmbeddingGateway ..|> EmbeddingGateway
FakeAudioGateway ..|> AudioGateway
FakeImageGateway ..|> ImageGateway
FakeTranscriptionGateway ..|> TranscriptionGateway
FakeRerankingGateway ..|> RerankingGateway
FakeFileGateway ..|> FileGateway
FakeStoreGateway ..|> StoreGateway

' ─── Inheritance ─────────────────────────────────────────────
FakePendingDispatch --|> PendingDispatch : extends (no-op overrides)
TestCase --|> OrchestraTestCase : extends
AiMigration --|> IlluminateMigration : extends

' ─── Cross-cutting Dependencies ──────────────────────────────
HasQueuedResponseCallbacks ..> FakePendingDispatch : instanceof check\nskips callback wiring

' ─── Facade Entry Points Note ────────────────────────────────
note as FacadeNote
  **Facade Entry Points (::fake())**
  Promptable::fake()     → FakeTextGateway
  Embeddings::fake()     → FakeEmbeddingGateway
  Audio::fake()          → FakeAudioGateway
  Image::fake()          → FakeImageGateway
  Transcription::fake()  → FakeTranscriptionGateway
  Reranking::fake()      → FakeRerankingGateway
  Files::fake()          → FakeFileGateway
  Stores::fake()         → FakeStoreGateway
  (Stores::fake also calls Files::fake internally)
end note

' ─── Shared Pattern Note ─────────────────────────────────────
note bottom of FakeTextGateway
  **Shared Fake Gateway Pattern**
  All Fake*Gateway classes share:
  constructor(Closure|array), $currentResponseIndex cursor,
  $preventStray* flag, nextResponse() / marshalResponse()
  pipeline. marshalResponse() resolves Closures, generates
  default stubs, or passes typed response objects through.
end note

@enduml
