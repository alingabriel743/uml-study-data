@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D9EAF7
    BorderColor #2C7BB6
    FontColor #212529
}

title Tools System

' ─────────────────────────────────────────
' External / Illuminate contracts (collapsed)
' ─────────────────────────────────────────
package "PHP / Illuminate Contracts" <<Frame>> {
    interface Arrayable {
        +toArray(): array
    }

    interface ArrayAccess {
        +offsetExists(offset): bool
        +offsetGet(offset): mixed
        +offsetSet(offset, value): void
        +offsetUnset(offset): void
    }

    interface JsonSchema {
        +string(name): Type
        +required(fields): self
    }

    class "Collection" as IlluminateCollection <<Illuminate\\Support>> {
        +rerank(by, query, limit): self
    }
}

' ─────────────────────────────────────────
' Laravel\Ai\Contracts
' ─────────────────────────────────────────
package "Laravel\\Ai\\Contracts" {
    interface Tool {
        +description(): Stringable|string
        +handle(request: Request): Stringable|string
        +schema(schema: JsonSchema): array
    }
}

' ─────────────────────────────────────────
' Laravel\Ai\Tools
' ─────────────────────────────────────────
package "Laravel\\Ai\\Tools" {

    class Request {
        #arguments: array = []
        .. traits ..
        ~Conditionable
        ~InteractsWithData
        ~Macroable
        .. methods ..
        +__construct(arguments: array = [])
        +all(keys: mixed = null): array
        #data(key: mixed = null, default: mixed = null): mixed
        +toArray(): array
        +offsetExists(offset: mixed): bool
        +offsetGet(offset: mixed): mixed
        +offsetSet(offset: mixed, value: mixed): void
        +offsetUnset(offset: mixed): void
    }

    class SimilaritySearch {
        +using: Closure
        #description: ?string
        #rerank: bool = false
        #rerankBy: Closure|array|string|null = null
        #rerankLimit: ?int = null
        .. constructor ..
        +__construct(using: Closure)
        .. factory ..
        {static} +usingModel(model: string, column: string, minSimilarity: float = 0.6, limit: int = 15, query: ?Closure = null): self
        .. Tool interface ..
        +description(): string
        +handle(request: Request): string
        +schema(schema: JsonSchema): array
        .. fluent builder ..
        +withDescription(description: string): self
        +rerank(by: Closure|array|string, limit: ?int = null): self
    }
}

' ─────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────

' SimilaritySearch implements the Tool contract
SimilaritySearch ..|> Tool : implements

' Request implements Illuminate / PHP contracts
Request ..|> Arrayable : implements
Request ..|> ArrayAccess : implements

' Tool depends on Request (handle parameter)
Tool ..> Request : <<uses>>\nhandle(request)

' SimilaritySearch depends on Request (handle parameter)
SimilaritySearch ..> Request : <<uses>>\nhandle(request)

' SimilaritySearch depends on JsonSchema (schema method)
SimilaritySearch ..> JsonSchema : <<uses>>\nschema(schema)

' SimilaritySearch uses Collection internally for result normalisation / reranking
SimilaritySearch ..> IlluminateCollection : <<uses>>\nresult normalisation\n& reranking

@enduml
