{
  "scope": "agent_contracts",
  "title": "Agent & Capability Contracts",
  "diagram_type": "class",
  "namespace": "Laravel\\Ai\\Contracts",

  "interfaces": [
    {
      "name": "Agent",
      "namespace": "Laravel\\Ai\\Contracts",
      "methods": [
        "instructions(): Stringable|string",
        "prompt(string $prompt, array $attachments=[], Lab|array|string|null $provider=null, ?string $model=null): AgentResponse",
        "stream(string $prompt, array $attachments=[], Lab|array|string|null $provider=null, ?string $model=null): StreamableAgentResponse",
        "queue(string $prompt, array $attachments=[], Lab|array|string|null $provider=null, ?string $model=null): QueuedAgentResponse",
        "broadcast(string $prompt, Channel|array $channels, array $attachments=[], bool $now=false, Lab|array|string|null $provider=null, ?string $model=null): StreamableAgentResponse",
        "broadcastNow(string $prompt, Channel|array $channels, array $attachments=[], Lab|array|string|null $provider=null, ?string $model=null): StreamableAgentResponse",
        "broadcastOnQueue(string $prompt, Channel|array $channels, array $attachments=[], Lab|array|string|null $provider=null, ?string $model=null): QueuedAgentResponse"
      ],
      "imports": ["AgentResponse", "QueuedAgentResponse", "StreamableAgentResponse", "Lab", "Channel", "Stringable"]
    },
    {
      "name": "Conversational",
      "namespace": "Laravel\\Ai\\Contracts",
      "methods": [
        "messages(): iterable<Message>"
      ],
      "imports": ["Message"]
    },
    {
      "name": "HasTools",
      "namespace": "Laravel\\Ai\\Contracts",
      "methods": [
        "tools(): iterable<Tool|ProviderTool>"
      ],
      "imports": ["Tool", "ProviderTool"]
    },
    {
      "name": "HasStructuredOutput",
      "namespace": "Laravel\\Ai\\Contracts",
      "methods": [
        "schema(JsonSchema $schema): array<string, Type>"
      ],
      "imports": ["JsonSchema", "Type"]
    },
    {
      "name": "HasMiddleware",
      "namespace": "Laravel\\Ai\\Contracts",
      "methods": [
        "middleware(): array"
      ]
    },
    {
      "name": "HasProviderOptions",
      "namespace": "Laravel\\Ai\\Contracts",
      "methods": [
        "providerOptions(Lab|string $provider): array<string, mixed>"
      ],
      "imports": ["Lab"]
    },
    {
      "name": "Tool",
      "namespace": "Laravel\\Ai\\Contracts",
      "methods": [
        "description(): Stringable|string",
        "handle(Request $request): Stringable|string",
        "schema(JsonSchema $schema): array<string, Type>"
      ],
      "imports": ["Request (Tools\\Request)", "JsonSchema", "Type", "Stringable"]
    },
    {
      "name": "ConversationStore",
      "namespace": "Laravel\\Ai\\Contracts",
      "methods": [
        "latestConversationId(string|int $userId): ?string",
        "storeConversation(string|int|null $userId, string $title): string",
        "storeUserMessage(string $conversationId, string|int|null $userId, AgentPrompt $prompt): string",
        "storeAssistantMessage(string $conversationId, string|int|null $userId, AgentPrompt $prompt, AgentResponse $response): string",
        "getLatestConversationMessages(string $conversationId, int $limit): Collection<int, Message>"
      ],
      "imports": ["Message", "AgentPrompt", "AgentResponse", "Collection"]
    },
    {
      "name": "Schemable",
      "namespace": "Laravel\\Ai\\Contracts",
      "methods": [
        "name(): string",
        "toSchema(): array<string, mixed>"
      ]
    }
  ],

  "concrete_classes": [
    {
      "name": "AnonymousAgent",
      "namespace": "Laravel\\Ai",
      "implements": ["Agent", "Conversational", "HasTools"],
      "uses_traits": ["Promptable"],
      "constructor": "__construct(string $instructions, iterable $messages, iterable $tools)",
      "methods": [
        "instructions(): string",
        "messages(): iterable",
        "tools(): iterable"
      ]
    },
    {
      "name": "StructuredAnonymousAgent",
      "namespace": "Laravel\\Ai",
      "extends": "AnonymousAgent",
      "implements": ["HasStructuredOutput"],
      "constructor": "__construct(string $instructions, iterable $messages, iterable $tools, Closure $schema)",
      "properties": ["$schema: SerializableClosure"],
      "methods": [
        "schema(JsonSchema $schema): array"
      ],
      "notes": "Wraps Closure in SerializableClosure for queue serialization"
    }
  ],

  "traits": [
    {
      "name": "Promptable",
      "namespace": "Laravel\\Ai",
      "uses_traits": ["SerializesModels"],
      "methods": [
        "static make(...$arguments): static",
        "prompt(string $prompt, array $attachments=[], Lab|array|string|null $provider=null, ?string $model=null, ?int $timeout=null): AgentResponse",
        "stream(string $prompt, array $attachments=[], Lab|array|string|null $provider=null, ?string $model=null, ?int $timeout=null): StreamableAgentResponse",
        "queue(string $prompt, array $attachments=[], Lab|array|string|null $provider=null, ?string $model=null): QueuedAgentResponse",
        "broadcast(...): StreamableAgentResponse",
        "broadcastNow(...): StreamableAgentResponse",
        "broadcastOnQueue(...): QueuedAgentResponse",
        "static fake(Closure|array $responses=[]): FakeTextGateway",
        "static assertPrompted(Closure|string $callback): void",
        "static assertNotPrompted(...): void",
        "static assertNeverPrompted(): void",
        "static assertQueued(...): void",
        "static assertNotQueued(...): void",
        "static assertNeverQueued(): void",
        "static isFaked(): bool",
        "private withModelFailover(Closure, Lab|array|string|null, ?string): mixed",
        "protected getProvidersAndModels(...): array",
        "protected getDefaultModelFor(Provider): string",
        "protected getTimeout(?int): int"
      ],
      "notes": "Provides full Agent contract implementation. Handles provider/model resolution via #[Provider], #[Model], #[Timeout] attributes or method overrides. Supports #[UseSmartestModel] and #[UseCheapestModel] attributes."
    }
  ],

  "response_classes": [
    {
      "name": "TextResponse",
      "namespace": "Laravel\\Ai\\Responses",
      "properties": ["$text: string", "$usage: Usage", "$meta: Meta", "$messages: Collection", "$toolCalls: Collection", "$toolResults: Collection", "$steps: Collection"],
      "methods": ["withMessages(Collection): self", "withToolCallsAndResults(Collection, Collection): self", "withSteps(Collection): self", "__toString(): string"]
    },
    {
      "name": "AgentResponse",
      "extends": "TextResponse",
      "namespace": "Laravel\\Ai\\Responses",
      "properties": ["$invocationId: string", "$conversationId: ?string", "$conversationUser: ?object"],
      "methods": ["withinConversation(string, object): self", "then(callable): self"]
    },
    {
      "name": "StructuredAgentResponse",
      "extends": "AgentResponse",
      "implements": ["Arrayable", "ArrayAccess", "Jsonable", "JsonSerializable"],
      "uses_traits": ["ProvidesStructuredResponse"],
      "constructor": "__construct(string $invocationId, array $structured, string $text, Usage $usage, Meta $meta)",
      "methods": ["toArray(): array", "toJson(int $options=0): string", "jsonSerialize(): mixed", "__toString(): string"]
    },
    {
      "name": "StreamableAgentResponse",
      "namespace": "Laravel\\Ai\\Responses",
      "implements": ["IteratorAggregate", "Responsable"],
      "uses_traits": ["CanStreamUsingVercelProtocol"],
      "properties": ["$invocationId: string", "$text: ?string", "$usage: ?Usage", "$events: Collection", "$conversationId: ?string", "$conversationUser: ?object"],
      "methods": ["each(callable): self", "then(callable): self", "withinConversation(?string, ?object): self", "usingVercelDataProtocol(bool): self", "toResponse($request): Response", "getIterator(): Traversable"],
      "notes": "Lazily resolves stream via Closure generator; caches events for replay; triggers thenCallbacks after completion"
    },
    {
      "name": "QueuedAgentResponse",
      "namespace": "Laravel\\Ai\\Responses",
      "uses_traits": ["HasQueuedResponseCallbacks"],
      "properties": ["$dispatchable: PendingDispatch"],
      "notes": "Wraps PendingDispatch; proxies unknown method calls to it"
    }
  ],

  "key_relationships": [
    "AnonymousAgent implements Agent, Conversational, HasTools",
    "StructuredAnonymousAgent extends AnonymousAgent, implements HasStructuredOutput",
    "Promptable trait provides concrete implementation of Agent contract methods",
    "AnonymousAgent uses Promptable trait",
    "Agent interface depends_on AgentResponse, StreamableAgentResponse, QueuedAgentResponse",
    "ConversationStore depends_on AgentPrompt, AgentResponse, Message",
    "HasTools depends_on Tool (contract), ProviderTool",
    "HasStructuredOutput depends_on JsonSchema, Type",
    "Tool contract depends_on Tools\\Request, JsonSchema, Type",
    "AgentResponse extends TextResponse",
    "StructuredAgentResponse extends AgentResponse",
    "TextResponse aggregates Usage, Meta, Collection<Messages>, Collection<ToolCalls>, Collection<ToolResults>"
  ],

  "optional_capability_interfaces": [
    "Conversational — agent maintains conversation history (messages(): iterable<Message>)",
    "HasTools — agent exposes tools to LLM (tools(): iterable<Tool|ProviderTool>)",
    "HasStructuredOutput — agent enforces JSON schema output (schema(JsonSchema): array)",
    "HasMiddleware — agent declares prompt middleware stack (middleware(): array)",
    "HasProviderOptions — agent provides provider-specific overrides (providerOptions(Lab|string): array)"
  ],

  "important_notes": "All agent classes should use Promptable trait for default Agent contract implementation. Provider/model selection supports: explicit args, method overrides (provider()/model()), PHP attributes (#[Provider], #[Model], #[UseSmartestModel], #[UseCheapestModel], #[Timeout]), or config fallback. Failover across providers is transparent via FailoverableException. Schemable is a generic schema interface; Tool and HasStructuredOutput both define schema() with same signature (JsonSchema→array<string,Type>).",

  "source_files_analyzed": [
