{
  "scope": "core_architecture",
  "title": "Core Architecture & Service Provider",
  "diagram_type": "class",
  "namespace": "Laravel\\Ai",

  "classes": [
    {
      "name": "Ai",
      "extends": "Illuminate\\Support\\Facades\\Facade",
      "namespace": "Laravel\\Ai",
      "methods": [
        "protected static getFacadeAccessor(): string"
      ],
      "notes": "Facade accessor returns AiManager::class — routes all static calls to AiManager"
    },
    {
      "name": "AiManager",
      "extends": "Illuminate\\Support\\MultipleInstanceManager",
      "namespace": "Laravel\\Ai",
      "traits": [
        "Concerns\\InteractsWithFakeAgents",
        "Concerns\\InteractsWithFakeAudio",
        "Concerns\\InteractsWithFakeEmbeddings",
        "Concerns\\InteractsWithFakeFiles",
        "Concerns\\InteractsWithFakeImages",
        "Concerns\\InteractsWithFakeReranking",
        "Concerns\\InteractsWithFakeStores",
        "Concerns\\InteractsWithFakeTranscriptions"
      ],
      "properties": [
        "protected string $driverKey = 'driver'"
      ],
      "provider_getters": [
        "audioProvider(?string $name = null): AudioProvider",
        "fakeableAudioProvider(?string $name = null): AudioProvider",
        "embeddingProvider(?string $name = null): EmbeddingProvider",
        "fakeableEmbeddingProvider(?string $name = null): EmbeddingProvider",
        "rerankingProvider(?string $name = null): RerankingProvider",
        "fakeableRerankingProvider(?string $name = null): RerankingProvider",
        "imageProvider(?string $name = null): ImageProvider",
        "fakeableImageProvider(?string $name = null): ImageProvider",
        "textProvider(?string $name = null): TextProvider",
        "textProviderFor(Agent $agent, ?string $name = null): TextProvider",
        "transcriptionProvider(?string $name = null): TranscriptionProvider",
        "fakeableTranscriptionProvider(?string $name = null): TranscriptionProvider",
        "fileProvider(?string $name = null): FileProvider",
        "fakeableFileProvider(?string $name = null): FileProvider",
        "storeProvider(?string $name = null): StoreProvider",
        "fakeableStoreProvider(?string $name = null): StoreProvider"
      ],
      "driver_factories": [
        "createAnthropicDriver(array $config): AnthropicProvider",
        "createAzureDriver(array $config): AzureOpenAiProvider",
        "createCohereDriver(array $config): CohereProvider",
        "createDeepseekDriver(array $config): DeepSeekProvider",
        "createElevenDriver(array $config): ElevenLabsProvider",
        "createGeminiDriver(array $config): GeminiProvider",
        "createGroqDriver(array $config): GroqProvider",
        "createJinaDriver(array $config): JinaProvider",
        "createMistralDriver(array $config): MistralProvider",
        "createOllamaDriver(array $config): OllamaProvider",
        "createOpenaiDriver(array $config): OpenAiProvider",
        "createOpenrouterDriver(array $config): OpenRouterProvider",
        "createVoyageaiDriver(array $config): VoyageAiProvider",
        "createXaiDriver(array $config): XaiProvider"
      ],
      "config_methods": [
        "getDefaultInstance(): string",
        "setDefaultInstance(string $name): void",
        "getInstanceConfig(string $name): array"
      ],
      "notes": "getDefaultInstance reads ai.default; getInstanceConfig reads ai.providers.<name>. Drivers with dedicated gateways: Anthropic→AnthropicGateway, Gemini→GeminiGateway, OpenAI→OpenAiGateway (all receive $app['events']/Dispatcher). All others receive only ($config, Dispatcher)."
    },
    {
      "name": "AiServiceProvider",
      "extends": "Illuminate\\Support\\ServiceProvider",
      "namespace": "Laravel\\Ai",
      "methods": [
        "register(): void",
        "boot(): void",
        "protected registerCommands(): void",
        "protected registerPublishing(): void"
      ],
      "register_bindings": [
        "app->scoped(AiManager::class, fn => new AiManager($app))",
        "app->singleton(ConversationStore::class, DatabaseConversationStore::class)"
      ],
      "boot_actions": [
        "registerCommands() — if runningInConsole",
        "registerPublishing() — if runningInConsole",
        "Stringable::macro('toEmbeddings', ...) — calls Embeddings::for()->generate()",
        "Collection::macro('rerank', ...) — calls Reranking::of()->rerank()"
      ],
      "commands_registered": [
        "MakeAgentCommand",
        "MakeAgentMiddlewareCommand",
        "MakeToolCommand"
      ],
      "publishes": [
        "config/ai.php → config_path('ai.php')",
        "stubs/ → base_path('stubs/')",
        "database/migrations → database_path('migrations')"
      ]
    }
  ],

  "key_relationships": [
    "Ai extends Facade (Laravel facade pattern)",
    "Ai uses_accessor AiManager (getFacadeAccessor returns AiManager::class)",
    "AiManager extends MultipleInstanceManager (driver/instance management)",
    "AiManager uses_trait Concerns\\InteractsWithFakeAgents",
    "AiManager uses_trait Concerns\\InteractsWithFakeAudio",
    "AiManager uses_trait Concerns\\InteractsWithFakeEmbeddings",
    "AiManager uses_trait Concerns\\InteractsWithFakeFiles",
    "AiManager uses_trait Concerns\\InteractsWithFakeImages",
    "AiManager uses_trait Concerns\\InteractsWithFakeReranking",
    "AiManager uses_trait Concerns\\InteractsWithFakeStores",
    "AiManager uses_trait Concerns\\InteractsWithFakeTranscriptions",
    "AiManager creates AnthropicProvider (via createAnthropicDriver)",
    "AiManager creates GeminiProvider (via createGeminiDriver)",
    "AiManager creates OpenAiProvider (via createOpenaiDriver)",
    "AiManager creates [AzureOpenAiProvider|CohereProvider|DeepSeekProvider|ElevenLabsProvider|GroqProvider|JinaProvider|MistralProvider|OllamaProvider|OpenRouterProvider|VoyageAiProvider|XaiProvider]",
    "AiManager depends_on AnthropicGateway, GeminiGateway, OpenAiGateway (injected into specific providers)",
    "AiManager depends_on Dispatcher (Illuminate\\Contracts\\Events\\Dispatcher)",
    "AiServiceProvider extends ServiceProvider",
    "AiServiceProvider registers AiManager (scoped singleton)",
    "AiServiceProvider registers ConversationStore -> DatabaseConversationStore",
    "AiServiceProvider registers_commands [MakeAgentCommand, MakeAgentMiddlewareCommand, MakeToolCommand]",
    "AiManager returns AudioProvider|EmbeddingProvider|RerankingProvider|ImageProvider|TextProvider|TranscriptionProvider|FileProvider|StoreProvider (contract-validated)"
  ],

  "provider_contracts_validated": [
    "AudioProvider", "EmbeddingProvider", "RerankingProvider",
    "ImageProvider", "TextProvider", "TranscriptionProvider",
    "FileProvider", "StoreProvider"
  ],

  "faking_pattern": "Each fakeableXProvider() method: gets real provider via xProvider(), checks if that modality is faked (from trait), if so clones provider and swaps gateway to fake implementation",

  "important_notes": "Ai is a pure facade, no state. AiManager is the central hub — acts as a driver factory (MultipleInstanceManager pattern) AND as a typed provider resolver. 8 Fake* traits provide test-double injection for each modality. AiServiceProvider wires everything into the Laravel IoC container with scoped binding (per-request lifecycle). PrismGateway imported but no createPrismDriver found in this file.",

  "source_files_analyzed": [
    "src/Ai.php",
    "src/AiManager.php",
    "src/AiServiceProvider.php"
  ]
}
