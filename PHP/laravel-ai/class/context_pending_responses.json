  "shared_patterns": {
    "trait": "Conditionable (all classes)",
    "provider_resolution": "All use Provider::formatProviderAndModelList() + config('ai.default_for_*') fallback",
    "failover_loop": "Iterate providers, catch FailoverableException, fire ProviderFailedOver event, continue",
    "fake_support": "Ai::fakeable*Provider() wraps provider; Ai::*AreFaked() check gates queue() path",
    "queue_pattern": "queue() creates Queued*Prompt, returns Queued*Response wrapping a PendingDispatch job",
    "generate_pattern": "generate() calls provider->*(inputs...) synchronously and returns typed Response"
  },

  "key_relationships": [
    "PendingImageGeneration uses Image, LocalImage, StoredImage (attachment types)",
    "PendingTranscriptionGeneration depends_on TranscribableAudio (contract)",
    "PendingTranscriptionGeneration queue() guards: StoredAudio | LocalAudio only",
    "PendingEmbeddingsGeneration depends_on CacheRepository (via Cache facade)",
    "All classes depend_on Provider (static factory method)",
    "All classes depend_on Ai (facade for faking/recording)",
    "All classes depend_on FailoverableException + ProviderFailedOver",
    "All classes depend_on FakePendingDispatch (fake queue dispatch object)",
    "PendingReranking has no queue() method — sync-only"
  ],

  "response_types": {
    "PendingImageGeneration": {"sync": "ImageResponse", "queued": "QueuedImageResponse"},
    "PendingAudioGeneration": {"sync": "AudioResponse", "queued": "QueuedAudioResponse"},
    "PendingTranscriptionGeneration": {"sync": "TranscriptionResponse", "queued": "QueuedTranscriptionResponse"},
    "PendingEmbeddingsGeneration": {"sync": "EmbeddingsResponse", "queued": "QueuedEmbeddingsResponse"},
    "PendingReranking": {"sync": "RerankingResponse", "queued": null}
  },

