{
  "scope": "provider_contracts",
  "title": "Provider Contracts & Interfaces",
  "diagram_type": "class",
  "namespaces": {
    "providers": "Laravel\\Ai\\Contracts\\Providers",
    "gateways": "Laravel\\Ai\\Contracts\\Gateway",
    "files": "Laravel\\Ai\\Contracts\\Files"
  },
  "interfaces": {
    "providers": [
      {
        "name": "TextProvider",
        "methods": [
          "prompt(AgentPrompt $prompt): AgentResponse",
          "stream(AgentPrompt $prompt): StreamableAgentResponse",
          "textGateway(): TextGateway",
          "useTextGateway(TextGateway $gateway): self",
          "defaultTextModel(): string",
          "cheapestTextModel(): string",
          "smartestTextModel(): string"
        ],
        "uses_gateway": "TextGateway",
        "response_types": ["AgentResponse", "StreamableAgentResponse"]
      },
      {
        "name": "AudioProvider",
        "methods": [
          "audio(string $text, string $voice, ?string $instructions, ?string $model, int $timeout): AudioResponse",
          "audioGateway(): AudioGateway",
          "useAudioGateway(AudioGateway $gateway): self",
          "defaultAudioModel(): string"
        ],
        "uses_gateway": "AudioGateway",
        "response_types": ["AudioResponse"]
      },
      {
        "name": "ImageProvider",
        "methods": [
          "image(string $prompt, array $attachments, ?string $size, ?string $quality, ?string $model, ?int $timeout): ImageResponse",
          "imageGateway(): ImageGateway",
          "useImageGateway(ImageGateway $gateway): self",
          "defaultImageModel(): string",
          "defaultImageOptions(?string $size, $quality): array"
        ],
        "uses_gateway": "ImageGateway",
        "response_types": ["ImageResponse"],
        "notes": "size: '3:2'|'2:3'|'1:1', quality: 'low'|'medium'|'high'"
      },
      {
        "name": "EmbeddingProvider",
        "methods": [
          "embeddings(array $inputs, ?int $dimensions, ?string $model, int $timeout): EmbeddingsResponse",
          "embeddingGateway(): EmbeddingGateway",
          "useEmbeddingGateway(EmbeddingGateway $gateway): self",
          "defaultEmbeddingsModel(): string",
          "defaultEmbeddingsDimensions(): int"
        ],
        "uses_gateway": "EmbeddingGateway",
        "response_types": ["EmbeddingsResponse"]
      },
      {
        "name": "RerankingProvider",
        "methods": [
          "rerank(array $documents, string $query, ?int $limit, ?string $model): RerankingResponse",
          "rerankingGateway(): RerankingGateway",
          "useRerankingGateway(RerankingGateway $gateway): self",
          "defaultRerankingModel(): string"
        ],
        "uses_gateway": "RerankingGateway",
        "response_types": ["RerankingResponse"]
      },
      {
        "name": "TranscriptionProvider",
        "methods": [
          "transcribe(TranscribableAudio $audio, ?string $language, bool $diarize, ?string $model): TranscriptionResponse",
          "transcriptionGateway(): TranscriptionGateway",
          "useTranscriptionGateway(TranscriptionGateway $gateway): self",
          "defaultTranscriptionModel(): string"
        ],
        "uses_gateway": "TranscriptionGateway",
        "response_types": ["TranscriptionResponse"],
        "depends_on": ["TranscribableAudio"]
      },
      {
        "name": "FileProvider",
        "methods": [
          "getFile(string $fileId): FileResponse",
          "putFile(StorableFile $file): StoredFileResponse",
          "deleteFile(string $fileId): void",
          "fileGateway(): FileGateway",
          "useFileGateway(FileGateway $gateway): self"
        ],
        "uses_gateway": "FileGateway",
        "response_types": ["FileResponse", "StoredFileResponse"],
        "depends_on": ["StorableFile"]
      },
      {
        "name": "StoreProvider",
        "methods": [
          "getStore(string $storeId): Store",
          "createStore(string $name, ?string $description, ?Collection $fileIds, ?DateInterval $expiresWhenIdleFor): Store",
          "addFileToStore(string $storeId, HasProviderId $file): string",
          "removeFileFromStore(string $storeId, HasProviderId|string $fileId): bool",
          "deleteStore(string $storeId): bool",
          "storeGateway(): StoreGateway",
          "useStoreGateway(StoreGateway $gateway): self"
        ],
        "uses_gateway": "StoreGateway",
        "response_types": ["Store"],
        "depends_on": ["HasProviderId"]
      }
    ],
    "capability_mixins": [
      {
        "name": "SupportsFileSearch",
        "methods": ["fileSearchToolOptions(FileSearch $search): array"],
        "note": "Marker/mixin interface for TextProvider implementations that support file search"
      },
      {
        "name": "SupportsWebSearch",
        "methods": ["webSearchToolOptions(WebSearch $search): array"],
        "note": "Marker/mixin interface for TextProvider implementations that support web search"
      },
      {
        "name": "SupportsWebFetch",
        "methods": ["webFetchToolOptions(WebFetch $fetch): array"],
        "note": "Marker/mixin interface for TextProvider implementations that support web fetch"
      }
    ],
    "gateways": [
      {
        "name": "Gateway",
        "extends": ["AudioGateway", "EmbeddingGateway", "ImageGateway", "TextGateway", "TranscriptionGateway"],
        "note": "Composite gateway — a single implementation that covers all main provider types (no File/Store/Reranking)"
      },
      {
        "name": "TextGateway",
        "methods": [
          "generateText(TextProvider $provider, string $model, ?string $instructions, array $messages, array $tools, ?array $schema, ?TextGenerationOptions $options, ?int $timeout): TextResponse",
          "streamText(string $invocationId, TextProvider $provider, string $model, ?string $instructions, array $messages, array $tools, ?array $schema, ?TextGenerationOptions $options, ?int $timeout): Generator",
          "onToolInvocation(Closure $invoking, Closure $invoked): self"
        ],
        "depends_on": ["TextProvider", "TextGenerationOptions", "Message", "Tool", "TextResponse"]
      },
      {
        "name": "AudioGateway",
        "methods": [
          "generateAudio(AudioProvider $provider, string $model, string $text, string $voice, ?string $instructions, int $timeout): AudioResponse"
        ],
        "depends_on": ["AudioProvider", "AudioResponse"]
      },
      {
        "name": "ImageGateway",
        "methods": [
          "generateImage(ImageProvider $provider, string $model, string $prompt, array $attachments, ?string $size, ?string $quality, ?int $timeout): ImageResponse"
        ],
        "depends_on": ["ImageProvider", "ImageResponse"]
      },
      {
        "name": "EmbeddingGateway",
        "methods": [
          "generateEmbeddings(EmbeddingProvider $provider, string $model, array $inputs, int $dimensions, int $timeout): EmbeddingsResponse"
        ],
        "depends_on": ["EmbeddingProvider", "EmbeddingsResponse"]
      },
      {
        "name": "RerankingGateway",
        "methods": [
          "rerank(RerankingProvider $provider, string $model, array $documents, string $query, ?int $limit): RerankingResponse"
        ],
        "depends_on": ["RerankingProvider", "RerankingResponse"]
      },
      {
        "name": "TranscriptionGateway",
        "methods": [
          "generateTranscription(TranscriptionProvider $provider, string $model, TranscribableAudio $audio, ?string $language, bool $diarize, int $timeout): TranscriptionResponse"
        ],
        "depends_on": ["TranscriptionProvider", "TranscribableAudio", "TranscriptionResponse"]
      },
      {
        "name": "FileGateway",
        "methods": [
          "getFile(FileProvider $provider, string $fileId): FileResponse",
          "putFile(FileProvider $provider, StorableFile $file): StoredFileResponse",
          "deleteFile(FileProvider $provider, string $fileId): void"
        ],
        "depends_on": ["FileProvider", "StorableFile", "FileResponse", "StoredFileResponse"]
      },
      {
        "name": "StoreGateway",
        "methods": [
          "getStore(StoreProvider $provider, string $storeId): Store",
          "createStore(StoreProvider $provider, string $name, ?string $description, ?Collection $fileIds, ?DateInterval $expiresWhenIdleFor): Store",
          "addFile(StoreProvider $provider, string $storeId, string $fileId, array $metadata): string",
          "removeFile(StoreProvider $provider, string $storeId, string $documentId): bool",
          "deleteStore(StoreProvider $provider, string $storeId): bool"
        ],
        "depends_on": ["StoreProvider", "Store"]
      }
    ],
    "file_contracts": [
      {
        "name": "HasContent",
        "extends": ["Stringable"],
        "methods": ["content(): string"]
      },
      {
        "name": "HasMimeType",
        "methods": ["mimeType(): ?string"]
      },
      {
        "name": "HasName",
        "methods": ["name(): ?string", "as(?string $name): static"]
      },
      {
        "name": "HasProviderId",
        "methods": ["id(): string"]
      },
      {
        "name": "StorableFile",
        "extends": ["HasContent", "HasMimeType", "HasName", "Stringable"],
        "methods": [],
        "note": "Composite file interface — no additional methods beyond its parents"
      },
      {
        "name": "TranscribableAudio",
        "extends": ["HasContent", "HasMimeType", "Stringable"],
        "methods": ["transcription(): PendingTranscriptionGeneration"]
      }
    ]
  },
  "key_relationships": [
    "TextProvider uses_gateway TextGateway (getter/setter pattern)",
    "AudioProvider uses_gateway AudioGateway (getter/setter pattern)",
    "ImageProvider uses_gateway ImageGateway (getter/setter pattern)",
    "EmbeddingProvider uses_gateway EmbeddingGateway (getter/setter pattern)",
    "RerankingProvider uses_gateway RerankingGateway (getter/setter pattern)",
    "TranscriptionProvider uses_gateway TranscriptionGateway (getter/setter pattern)",
    "FileProvider uses_gateway FileGateway (getter/setter pattern)",
    "StoreProvider uses_gateway StoreGateway (getter/setter pattern)",
    "Gateway extends AudioGateway + EmbeddingGateway + ImageGateway + TextGateway + TranscriptionGateway",
    "StorableFile extends HasContent + HasMimeType + HasName + Stringable",
    "TranscribableAudio extends HasContent + HasMimeType + Stringable",
    "Each XGateway.method receives its XProvider as first param (bidirectional coupling via parameters)",
    "TranscriptionProvider depends_on TranscribableAudio (input)",
    "FileProvider depends_on StorableFile (input for putFile)",
    "StoreProvider depends_on HasProviderId (input for addFileToStore/removeFileFromStore)",
    "SupportsFileSearch / SupportsWebSearch / SupportsWebFetch are optional mixin interfaces for TextProvider impls"
  ],
  "pattern_notes": "Every Provider interface follows the same pattern: (1) primary operation method(s), (2) xGateway() getter, (3) useXGateway() setter returning self, (4) defaultXModel() string. Gateway methods always receive their paired Provider as first argument. Gateway interface = aggregate of TextGateway+AudioGateway+ImageGateway+EmbeddingGateway+TranscriptionGateway (no File/Store/Reranking in composite).",
  "source_files_analyzed": [
    "src/Contracts/Providers/TextProvider.php",
    "src/Contracts/Providers/AudioProvider.php",
    "src/Contracts/Providers/ImageProvider.php",
    "src/Contracts/Providers/EmbeddingProvider.php",
    "src/Contracts/Providers/RerankingProvider.php",
    "src/Contracts/Providers/TranscriptionProvider.php",
    "src/Contracts/Providers/FileProvider.php",
    "src/Contracts/Providers/StoreProvider.php",
    "src/Contracts/Providers/SupportsFileSearch.php",
    "src/Contracts/Providers/SupportsWebSearch.php",
    "src/Contracts/Providers/SupportsWebFetch.php",
    "src/Contracts/Gateway/Gateway.php",
    "src/Contracts/Gateway/TextGateway.php",
    "src/Contracts/Gateway/AudioGateway.php",
    "src/Contracts/Gateway/ImageGateway.php",
    "src/Contracts/Gateway/EmbeddingGateway.php",
    "src/Contracts/Gateway/RerankingGateway.php",
    "src/Contracts/Gateway/TranscriptionGateway.php",
    "src/Contracts/Gateway/FileGateway.php",
    "src/Contracts/Gateway/StoreGateway.php",
    "src/Contracts/Files/HasContent.php",
    "src/Contracts/Files/HasMimeType.php",
    "src/Contracts/Files/HasName.php",
    "src/Contracts/Files/HasProviderId.php",
    "src/Contracts/Files/StorableFile.php",
    "src/Contracts/Files/TranscribableAudio.php"
  ]
}
