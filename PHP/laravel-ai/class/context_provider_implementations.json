      "own_methods": ["fileSearchToolOptions(FileSearch): array (fileSearchStoreNames, metadataFilter)", "webFetchToolOptions(WebFetch): array (empty)", "webSearchToolOptions(WebSearch): array (empty)", "defaultTextModel(): string (gemini-3-flash-preview)", "cheapestTextModel(): string (gemini-3.1-flash-lite-preview)", "smartestTextModel(): string (gemini-3.1-pro-preview)", "defaultImageModel(): string (gemini-3.1-flash-image-preview)", "defaultImageOptions(): array (image_size, aspect_ratio)", "defaultEmbeddingsModel(): string (gemini-embedding-001)", "defaultEmbeddingsDimensions(): int (3072)", "fileGateway(): FileGateway → new GeminiFileGateway", "storeGateway(): StoreGateway → new GeminiStoreGateway"],
