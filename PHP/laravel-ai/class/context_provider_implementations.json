{
  "scope": "provider_implementations",
  "title": "Provider Implementations",
  "diagram_type": "class",
  "namespace": "Laravel\\Ai\\Providers",

  "abstract_base": {
    "class": "Provider",
    "namespace": "Laravel\\Ai\\Providers",
    "constructor": "__construct(Gateway $gateway, array $config, Dispatcher $events)",
    "properties": ["protected Gateway $gateway", "protected array $config", "protected Dispatcher $events"],
    "methods": [
      "name(): string",
      "driver(): string",
      "providerCredentials(): array",
      "additionalConfiguration(): array",
      "formatProviderAndModelList(Lab|array|string $providers, ?string $model): array",
      "__toString(): string"
    ],
    "note": "CohereProvider, VoyageAiProvider, ElevenLabsProvider, AzureOpenAiProvider override constructor omitting Gateway"
  },

  "provider_contracts": [
    {
      "interface": "TextProvider",
      "methods": ["prompt(AgentPrompt): AgentResponse", "stream(AgentPrompt): StreamableAgentResponse", "textGateway(): TextGateway", "useTextGateway(TextGateway): self", "defaultTextModel(): string", "cheapestTextModel(): string", "smartestTextModel(): string"]
    },
    {
      "interface": "ImageProvider",
      "methods": ["image(string $prompt, array $attachments, ?string $size, ?string $quality, ?string $model, ?int $timeout): ImageResponse", "imageGateway(): ImageGateway", "useImageGateway(ImageGateway): self", "defaultImageModel(): string", "defaultImageOptions(?string $size, mixed $quality): array"]
    },
    {
      "interface": "AudioProvider",
      "methods": ["audio(string $text, string $voice, ?string $instructions, ?string $model, int $timeout): AudioResponse", "audioGateway(): AudioGateway", "useAudioGateway(AudioGateway): self", "defaultAudioModel(): string"]
    },
    {
      "interface": "EmbeddingProvider",
      "methods": ["embeddings(array $inputs, ?int $dimensions, ?string $model, int $timeout): EmbeddingsResponse", "embeddingGateway(): EmbeddingGateway", "useEmbeddingGateway(EmbeddingGateway): self", "defaultEmbeddingsModel(): string", "defaultEmbeddingsDimensions(): int"]
    },
    {
      "interface": "TranscriptionProvider",
      "methods": ["transcribe(TranscribableAudio $audio, ?string $language, bool $diarize, ?string $model): TranscriptionResponse", "transcriptionGateway(): TranscriptionGateway", "useTranscriptionGateway(TranscriptionGateway): self", "defaultTranscriptionModel(): string"]
    },
    {
      "interface": "FileProvider",
      "methods": ["getFile(string $fileId): FileResponse", "putFile(StorableFile $file): StoredFileResponse", "deleteFile(string $fileId): void", "fileGateway(): FileGateway", "useFileGateway(FileGateway): self"]
    },
    {
      "interface": "StoreProvider",
      "methods": ["getStore(string $storeId): Store", "createStore(string $name, ?string $description, ?Collection $fileIds, ?DateInterval $expiresWhenIdleFor): Store", "addFileToStore(string $storeId, HasProviderId $file): string", "removeFileFromStore(string $storeId, HasProviderId|string $fileId): bool", "deleteStore(string $storeId): bool", "storeGateway(): StoreGateway", "useStoreGateway(StoreGateway): self"]
    },
    {
      "interface": "RerankingProvider",
      "methods": ["rerank(array $documents, string $query, ?int $limit, ?string $model): RerankingResponse", "rerankingGateway(): RerankingGateway", "useRerankingGateway(RerankingGateway): self", "defaultRerankingModel(): string"]
    },
    {
      "interface": "SupportsFileSearch",
      "methods": ["fileSearchToolOptions(FileSearch $search): array"]
    },
    {
      "interface": "SupportsWebSearch",
      "methods": ["webSearchToolOptions(WebSearch $search): array"]
    },
    {
      "interface": "SupportsWebFetch",
      "methods": ["webFetchToolOptions(WebFetch $fetch): array"]
    }
  ],

