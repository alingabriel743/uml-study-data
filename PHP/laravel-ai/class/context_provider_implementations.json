      "own_methods": ["azureGateway(): AzureOpenAiGateway (shared, lazy)", "textGateway(): TextGateway → azureGateway()", "embeddingGateway(): EmbeddingGateway → azureGateway()", "providerCredentials(): array (key)", "additionalConfiguration(): array (url, api_version)", "defaultTextModel(): string (gpt-4o)", "cheapestTextModel(): string (gpt-4o-mini)", "smartestTextModel(): string (gpt-4o)", "defaultEmbeddingsModel(): string (text-embedding-3-small)", "defaultEmbeddingsDimensions(): int (1536)"],
