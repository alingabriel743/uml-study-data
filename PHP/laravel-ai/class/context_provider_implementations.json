  "concern_traits": [
    {"trait": "GeneratesText", "key_logic": "prompt() → pipeline → textGateway().generateText(); dispatches PromptingAgent + AgentPrompted events; tool invocation callbacks via listenForToolInvocations()"},
    {"trait": "StreamsText", "key_logic": "stream() → pipeline → textGateway().streamText(); returns StreamableAgentResponse; dispatches StreamingAgent + AgentStreamed events"},
    {"trait": "GeneratesImages", "key_logic": "image() → imageGateway().generateImage(); dispatches GeneratingImage + ImageGenerated events"},
    {"trait": "GeneratesAudio", "key_logic": "audio() → audioGateway().generateAudio(); dispatches GeneratingAudio + AudioGenerated events"},
    {"trait": "GeneratesEmbeddings", "key_logic": "embeddings() → embeddingGateway().generateEmbeddings(); validates model+dimensions; dispatches GeneratingEmbeddings + EmbeddingsGenerated events"},
    {"trait": "GeneratesTranscriptions", "key_logic": "transcribe() → transcriptionGateway().generateTranscription(); dispatches GeneratingTranscription + TranscriptionGenerated events"},
    {"trait": "ManagesFiles", "key_logic": "getFile/putFile/deleteFile → fileGateway(); dispatches StoringFile + FileStored + FileDeleted events"},
    {"trait": "ManagesStores", "key_logic": "getStore/createStore/addFileToStore/removeFileFromStore/deleteStore → storeGateway(); dispatches CreatingStore, StoreCreated, AddingFileToStore, FileAddedToStore, RemovingFileFromStore, FileRemovedFromStore, StoreDeleted events"},
    {"trait": "HasTextGateway", "key_logic": "property TextGateway $textGateway; textGateway() falls back to $this->gateway if not set"},
    {"trait": "HasImageGateway", "key_logic": "property ImageGateway $imageGateway; imageGateway() / useImageGateway()"},
    {"trait": "HasAudioGateway", "key_logic": "property AudioGateway $audioGateway; audioGateway() / useAudioGateway()"},
    {"trait": "HasEmbeddingGateway", "key_logic": "property EmbeddingGateway $embeddingGateway; embeddingGateway() / useEmbeddingGateway()"},
    {"trait": "HasTranscriptionGateway", "key_logic": "property TranscriptionGateway $transcriptionGateway; transcriptionGateway() / useTranscriptionGateway()"},
    {"trait": "HasFileGateway", "key_logic": "property FileGateway $fileGateway; fileGateway() / useFileGateway()"},
    {"trait": "HasStoreGateway", "key_logic": "property StoreGateway $storeGateway; storeGateway() / useStoreGateway()"},
    {"trait": "HasRerankingGateway", "key_logic": "property RerankingGateway $rerankingGateway; rerankingGateway() / useRerankingGateway()"},
    {"trait": "Reranks", "key_logic": "rerank() → rerankingGateway().rerank(); dispatches Reranking + Reranked events"}
  ],

  "key_relationships": [
    "All providers extend abstract Provider (inheritance)",
    "OpenAiProvider implements 9 interfaces — the most capable provider",
    "AnthropicProvider implements TextProvider + FileProvider + SupportsWebFetch + SupportsWebSearch (text-only, no image/audio/embedding)",
    "GeminiProvider implements TextProvider + ImageProvider + EmbeddingProvider + FileProvider + StoreProvider + 3 Supports interfaces",
    "AzureOpenAiProvider shares single AzureOpenAiGateway for both TextGateway and EmbeddingGateway (composition)",
    "CohereProvider/VoyageAiProvider/JinaProvider: embedding + reranking only (no text generation)",
    "ElevenLabsProvider: audio + transcription only",
    "GroqProvider/DeepSeekProvider: text only",
    "Provider base class depends_on Gateway (injected), Dispatcher (injected)",
    "Each Generate* trait calls corresponding *Gateway interface method",
    "HasTextGateway trait falls back to Provider.$gateway if dedicated textGateway not set"
  ],

