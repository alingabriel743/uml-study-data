      "own_methods": ["fileSearchToolOptions(FileSearch): array", "webSearchToolOptions(WebSearch): array", "defaultTextModel(): string (gpt-5.4)", "cheapestTextModel(): string (gpt-5.4-nano)", "smartestTextModel(): string (gpt-5.4-pro)", "defaultImageModel(): string (gpt-image-1.5)", "defaultImageOptions(?string, mixed): array", "defaultAudioModel(): string (gpt-4o-mini-tts)", "defaultTranscriptionModel(): string (gpt-4o-transcribe-diarize)", "defaultEmbeddingsModel(): string (text-embedding-3-small)", "defaultEmbeddingsDimensions(): int (1536)", "fileGateway(): FileGateway → new OpenAiFileGateway", "storeGateway(): StoreGateway → new OpenAiStoreGateway"],
      "gateways_created": ["OpenAiFileGateway", "OpenAiStoreGateway"]
