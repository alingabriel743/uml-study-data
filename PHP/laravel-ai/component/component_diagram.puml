@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam interface {
    BackgroundColor #D4EDDA
    BorderColor #28A745
    FontColor #155724
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #856404
}

title Laravel AI Package — Component Architecture

' ─────────────────────────────────────────────────
'  APPLICATION ENTRY POINT
' ─────────────────────────────────────────────────
package "Application Entry Point" <<Rectangle>> {
    [Ai Facade] as AiFacade
    [AiManager] as AiManager
    [AiServiceProvider] as AiServiceProvider
}

' ─────────────────────────────────────────────────
'  AGENT SYSTEM
' ─────────────────────────────────────────────────
package "Agent System" <<Rectangle>> {
    [Agent (Abstract)] as Agent
    [AnonymousAgent] as AnonymousAgent
    [Pipeline] as Pipeline
    [QueuedAgentPrompt] as QueuedAgentPrompt
    [StructuredAnonymousAgent] as StructuredAnonymousAgent
    [Promptable] as Promptable
}

' ─────────────────────────────────────────────────
'  AI CAPABILITIES
' ─────────────────────────────────────────────────
package "AI Capabilities" <<Rectangle>> {
    [Embeddings] as Embeddings
    [Transcription] as Transcription
    [Reranking] as Reranking
    [Files] as FilesService
    [Stores] as Stores
    [Audio] as Audio
    [Image] as Image
}

' ─────────────────────────────────────────────────
'  CONTRACTS / INTERFACES
' ─────────────────────────────────────────────────
package "Contracts & Interfaces" <<Rectangle>> {
    package "Agent Contracts" {
        interface "Agent" as IAgent
        interface "Tool" as ITool
        interface "HasMiddleware" as IHasMiddleware
        interface "HasTools" as IHasTools
        interface "Conversational" as IConversational
        interface "HasStructuredOutput" as IHasStructuredOutput
    }
    package "Gateway Contracts" {
        interface "Gateway" as IGateway
        interface "TextGateway" as ITextGateway
        interface "EmbeddingGateway" as IEmbeddingGateway
        interface "TranscriptionGateway" as ITranscriptionGateway
        interface "RerankingGateway" as IRerankingGateway
        interface "AudioGateway" as IAudioGateway
        interface "ImageGateway" as IImageGateway
        interface "FileGateway" as IFileGateway
        interface "StoreGateway" as IStoreGateway
    }
    package "Provider Contracts" {
        interface "TextProvider" as ITextProvider
        interface "EmbeddingProvider" as IEmbeddingProvider
        interface "AudioProvider" as IAudioProvider
        interface "ImageProvider" as IImageProvider
        interface "TranscriptionProvider" as ITranscriptionProvider
        interface "RerankingProvider" as IRerankingProvider
        interface "FileProvider" as IFileProvider
        interface "StoreProvider" as IStoreProvider
    }
    package "File Contracts" {
        interface "StorableFile" as IStorableFile
        interface "HasMimeType" as IHasMimeType
        interface "TranscribableAudio" as ITranscribableAudio
    }
}

' ─────────────────────────────────────────────────
'  PROVIDER GATEWAYS
' ─────────────────────────────────────────────────
package "Provider Gateways" <<Rectangle>> {
    package "OpenAI" {
        [OpenAiGateway] as OpenAiGateway
        [OpenAiFileGateway] as OpenAiFileGateway
        [OpenAiStoreGateway] as OpenAiStoreGateway
    }
    package "Anthropic" {
        [AnthropicGateway] as AnthropicGateway
        [AnthropicFileGateway] as AnthropicFileGateway
    }
    package "Azure OpenAI" {
        [AzureOpenAiGateway] as AzureOpenAiGateway
    }
    package "Gemini" {
        [GeminiGateway] as GeminiGateway
        [GeminiFileGateway] as GeminiFileGateway
        [GeminiStoreGateway] as GeminiStoreGateway
    }
    package "Other Providers" {
        [GroqGateway] as GroqGateway
        [MistralGateway] as MistralGateway
        [DeepSeekGateway] as DeepSeekGateway
        [OllamaGateway] as OllamaGateway
        [OpenRouterGateway] as OpenRouterGateway
        [PrismGateway] as PrismGateway
    }
    package "Specialised Gateways" {
        [ElevenLabsGateway] as ElevenLabsGateway
        [CohereGateway] as CohereGateway
        [JinaGateway] as JinaGateway
    }
}

' ─────────────────────────────────────────────────
'  FILE SYSTEM
' ─────────────────────────────────────────────────
package "File Abstractions" <<Rectangle>> {
    [Document] as Document
    [LocalDocument] as LocalDocument
    [RemoteDocument] as RemoteDocument
    [ProviderDocument] as ProviderDocument
    [Base64Image] as Base64Image
    [RemoteImage] as RemoteImage
    [Base64Audio] as Base64Audio
    [RemoteAudio] as RemoteAudio
}

' ─────────────────────────────────────────────────
'  AGENT CONFIGURATION (ATTRIBUTES)
' ─────────────────────────────────────────────────
package "Agent Attributes" <<Rectangle>> {
    [Model] as AttrModel
    [Temperature] as AttrTemperature
    [MaxTokens] as AttrMaxTokens
    [Timeout] as AttrTimeout
    [Provider] as AttrProvider
    [MaxSteps] as AttrMaxSteps
    [UseSmartestModel] as AttrUseSmartest
    [UseCheapestModel] as AttrUseCheapest
}

' ─────────────────────────────────────────────────
'  EVENTS & EXCEPTIONS
' ─────────────────────────────────────────────────
package "Events" <<Rectangle>> {
    [AgentPrompted] as EvtAgentPrompted
    [ToolInvoked] as EvtToolInvoked
    [AgentFailedOver] as EvtAgentFailedOver
    [FileStored / FileDeleted] as EvtFileEvents
    [GeneratingAudio / GeneratingTranscription] as EvtMediaEvents
}

package "Exceptions" <<Rectangle>> {
    [AiException] as ExAiException
    [RateLimitedException] as ExRateLimited
    [FailoverableException] as ExFailoverable
    [ProviderOverloadedException] as ExOverloaded
    [InsufficientCreditsException] as ExInsufficientCredits
}

' ─────────────────────────────────────────────────
'  CONSOLE COMMANDS
' ─────────────────────────────────────────────────
package "Console Commands" <<Rectangle>> {
    [MakeAgentCommand] as CmdMakeAgent
    [MakeToolCommand] as CmdMakeTool
    [MakeAgentMiddlewareCommand] as CmdMakeMiddleware
    [ChatCommand] as CmdChat
}

' ─────────────────────────────────────────────────
'  TESTING / FAKE LAYER
' ─────────────────────────────────────────────────
package "Testing & Fake Layer" <<Rectangle>> {
    [FakeTextGateway] as FakeText
    [FakeEmbeddingGateway] as FakeEmbedding
    [FakeFileGateway] as FakeFile
    [FakeStoreGateway] as FakeStore
    [FakeAudioGateway] as FakeAudio
    [FakeImageGateway] as FakeImage
    [FakeTranscriptionGateway] as FakeTranscription
    [FakePendingDispatch] as FakePendingDispatch
}

' ─────────────────────────────────────────────────
'  RELATIONSHIPS
' ─────────────────────────────────────────────────

' Entry point wires everything together
AiFacade --> AiManager
AiManager --> Agent
AiManager --> Embeddings
AiManager --> Transcription
AiManager --> Reranking
AiManager --> FilesService
AiManager --> Stores
AiManager --> Audio
AiManager --> Image
AiServiceProvider --> AiManager : registers

' Agent system internal
Agent --> Pipeline : runs through
Agent --> AnonymousAgent : instantiates
Agent --> StructuredAnonymousAgent : instantiates
Agent --> QueuedAgentPrompt : dispatches
AnonymousAgent --> Promptable : uses
StructuredAnonymousAgent --> IHasStructuredOutput : implements

' Agent implements contracts
Agent .up.|> IAgent
Agent .up.|> IHasTools
Agent .up.|> IHasMiddleware

' Capabilities use gateway contracts
Embeddings --> IEmbeddingGateway : calls
Transcription --> ITranscriptionGateway : calls
Reranking --> IRerankingGateway : calls
FilesService --> IFileGateway : calls
Stores --> IStoreGateway : calls
Audio --> IAudioGateway : calls
Image --> IImageGateway : calls
Agent --> ITextGateway : calls

' Gateway contracts extend base
ITextGateway .up.|> IGateway
IEmbeddingGateway .up.|> IGateway
ITranscriptionGateway .up.|> IGateway
IRerankingGateway .up.|> IGateway
IAudioGateway .up.|> IGateway
IImageGateway .up.|> IGateway
IFileGateway .up.|> IGateway
IStoreGateway .up.|> IGateway

' Provider gateways implement contracts
OpenAiGateway .up.|> ITextGateway
OpenAiGateway .up.|> ITextProvider
OpenAiFileGateway .up.|> IFileGateway
OpenAiStoreGateway .up.|> IStoreGateway

AnthropicGateway .up.|> ITextGateway
AnthropicFileGateway .up.|> IFileGateway

AzureOpenAiGateway .up.|> ITextGateway

GeminiGateway .up.|> ITextGateway
GeminiFileGateway .up.|> IFileGateway
GeminiStoreGateway .up.|> IStoreGateway

GroqGateway .up.|> ITextGateway
MistralGateway .up.|> ITextGateway
DeepSeekGateway .up.|> ITextGateway
OllamaGateway .up.|> ITextGateway
OpenRouterGateway .up.|> ITextGateway
PrismGateway .up.|> ITextGateway

ElevenLabsGateway .up.|> IAudioGateway
CohereGateway .up.|> IRerankingGateway
JinaGateway .up.|> IEmbeddingGateway

' Fake gateways implement same contracts (testing)
FakeText .up.|> ITextGateway
FakeEmbedding .up.|> IEmbeddingGateway
FakeFile .up.|> IFileGateway
FakeStore .up.|> IStoreGateway
FakeAudio .up.|> IAudioGateway
FakeImage .up.|> IImageGateway
FakeTranscription .up.|> ITranscriptionGateway

' File abstractions implement file contracts
LocalDocument .up.|> IStorableFile
RemoteDocument .up.|> IStorableFile
ProviderDocument .up.|> IStorableFile
Base64Audio .up.|> ITranscribableAudio
RemoteAudio .up.|> ITranscribableAudio
Document --> LocalDocument : subtype
Document --> RemoteDocument : subtype
Document --> ProviderDocument : subtype

' Agent attributes configure agents
AttrModel --> Agent : configures
AttrTemperature --> Agent : configures
AttrMaxTokens --> Agent : configures
AttrTimeout --> Agent : configures
AttrProvider --> AiManager : selects provider
AttrMaxSteps --> Pipeline : limits steps
AttrUseSmartest --> AiManager : model selection
AttrUseCheapest --> AiManager : model selection

' Events emitted from services
Agent --> EvtAgentPrompted : emits
Agent --> EvtToolInvoked : emits
Agent --> EvtAgentFailedOver : emits
FilesService --> EvtFileEvents : emits
Audio --> EvtMediaEvents : emits
Transcription --> EvtMediaEvents : emits

' Console commands generate code stubs
CmdMakeAgent --> Agent : generates stub
CmdMakeTool --> ITool : generates stub
CmdMakeMiddleware --> IHasMiddleware : generates stub
CmdChat --> AiFacade : invokes

@enduml
