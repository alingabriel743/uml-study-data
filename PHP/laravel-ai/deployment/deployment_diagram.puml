@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam node {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam artifact {
    BackgroundColor #DEE2E6
    BorderColor #6C757D
}
skinparam database {
    BackgroundColor #D0EBFF
    BorderColor #339AF0
}
skinparam cloud {
    BackgroundColor #E3FAFC
    BorderColor #15AABF
}

title Laravel AI SDK — Deployment Diagram

' ─────────────────────────────────────────
' Laravel Application Host
' ─────────────────────────────────────────
node "Laravel Application Server" <<PHP 8.3+>> {
    artifact "laravel/ai Package" as laravel_ai {
        artifact "AiManager" as ai_manager
        artifact "AiServiceProvider" as ai_provider
        artifact "Gateway Layer" as gateway
        artifact "Prism Bridge (prism-php/prism)" as prism
    }
    database "Laravel Cache\n(embeddings)" as cache_store
    database "Database\n(conversation store)" as db
}

' ─────────────────────────────────────────
' Local AI Node (self-hosted)
' ─────────────────────────────────────────
node "Local Machine / LAN" <<Self-hosted>> {
    artifact "Ollama Server\n:11434" as ollama
}

' ─────────────────────────────────────────
' Text / LLM Providers
' ─────────────────────────────────────────
cloud "OpenAI API\napi.openai.com/v1" as openai
cloud "Anthropic API\napi.anthropic.com/v1" as anthropic
cloud "Azure OpenAI\n(configurable URL)" as azure_openai
cloud "Google Gemini API" as gemini
cloud "Groq API\napi.groq.com/openai/v1" as groq
cloud "DeepSeek API\napi.deepseek.com" as deepseek
cloud "Mistral AI\napi.mistral.ai/v1" as mistral
cloud "OpenRouter\nopenrouter.ai/api/v1" as openrouter
cloud "xAI API\napi.x.ai/v1" as xai

' ─────────────────────────────────────────
' Embedding / Reranking / Specialised Providers
' ─────────────────────────────────────────
cloud "Cohere API\n(reranking)" as cohere
cloud "Jina AI\n(embeddings)" as jina
cloud "VoyageAI\napi.voyageai.com/v1" as voyageai
cloud "ElevenLabs\n(text-to-speech)" as elevenlabs

' ─────────────────────────────────────────
' Internal relationships
' ─────────────────────────────────────────
ai_manager --> gateway : "routes request"
ai_provider --> ai_manager : "registers & scopes"
gateway --> prism : "delegates via\nPrism bridge"
gateway --> cache_store : "caches embeddings"
ai_manager --> db : "persists conversations\n(DatabaseConversationStore)"

' ─────────────────────────────────────────
' External provider connections
' ─────────────────────────────────────────
gateway --> openai      : "HTTPS · text / audio /\ntranscription / embeddings\n(default provider)"
gateway --> anthropic   : "HTTPS · text generation"
gateway --> azure_openai: "HTTPS · text / embeddings\n(GPT-4o)"
gateway --> gemini      : "HTTPS · text / images\n(default for images)"
gateway --> groq        : "HTTPS · text generation"
gateway --> deepseek    : "HTTPS · text generation"
gateway --> mistral     : "HTTPS · text generation"
gateway --> openrouter  : "HTTPS · text generation"
gateway --> xai         : "HTTPS · text generation"
gateway --> ollama      : "HTTP · local text generation"
gateway --> cohere      : "HTTPS · reranking\n(default for reranking)"
gateway --> jina        : "HTTPS · embeddings"
gateway --> voyageai    : "HTTPS · embeddings"
gateway --> elevenlabs  : "HTTPS · audio synthesis"

@enduml
