{
  "scope": "reranking_flow",
  "title": "Reranking Flow",
  "diagram_type": "sequence",
  "key_participants": [
    "Client",
    "Reranking",
    "PendingReranking",
    "Ai (facade)",
    "AiManager",
    "RerankingProvider (interface)",
    "Provider (Reranks trait)",
    "RerankingGateway",
    "EventDispatcher"
  ],
  "interaction_flow": [
    "Client → Reranking: of(Collection|array $documents): PendingReranking",
    "Reranking → Reranking: validate documents is list (throws InvalidArgumentException if associative)",
    "Reranking → PendingReranking: new PendingReranking($documents)",
    "Reranking → Client: return PendingReranking",
    "Client → PendingReranking: limit(?int $limit): self  [optional, fluent]",
    "Client → PendingReranking: rerank(string $query, Lab|array|string|null $provider, ?string $model): RerankingResponse",
    "PendingReranking → Provider: formatProviderAndModelList($provider ?? config('ai.default_for_reranking'), $model)",
    "PendingReranking → Ai: fakeableRerankingProvider($provider)  [per provider in loop]",
    "Ai → AiManager: fakeableRerankingProvider(?string $name)",
    "AiManager → AiManager: rerankingProvider($name)  [validates RerankingProvider interface]",
    "AiManager → AiManager: rerankingIsFaked() → if faked: clone provider + useRerankingGateway(fakeGateway)",
    "AiManager → PendingReranking: return RerankingProvider instance",
    "PendingReranking → RerankingProvider: defaultRerankingModel()  [if model is null]",
    "PendingReranking → RerankingProvider: rerank($documents, $query, $limit, $model)",
    "Provider(Reranks) → Provider(Reranks): generate invocationId (UUID7)",
    "Provider(Reranks) → RerankingPrompt: new RerankingPrompt($documents, $query, $limit, $provider, $model)",
    "Provider(Reranks) → Ai: rerankingIsFaked() → if true: recordReranking($prompt)",
    "Provider(Reranks) → EventDispatcher: dispatch(Reranking($invocationId, $provider, $model, $prompt))",
    "Provider(Reranks) → RerankingGateway: rerank($provider, $model, $documents, $query, $limit)",
    "RerankingGateway → Provider(Reranks): return RerankingResponse",
    "Provider(Reranks) → EventDispatcher: dispatch(Reranked($invocationId, $provider, $model, $prompt, $response))",
    "Provider(Reranks) → PendingReranking: return RerankingResponse",
    "PendingReranking → Client: return RerankingResponse [results: RankedDocument[], meta: Meta]",
    "NOTE: FailoverableException triggers ProviderFailedOver event and continues to next provider in loop"
  ],
  "key_relationships": [
    "Reranking static-factory creates PendingReranking",
    "PendingReranking depends_on Ai (facade) for fakeableRerankingProvider()",
    "Ai (facade) delegates to AiManager",
    "AiManager extends MultipleInstanceManager, uses InteractsWithFakeReranking trait",
    "AiManager resolves RerankingProvider instances by driver name from config",
    "RerankingProvider is an interface; concrete providers implement it via Reranks trait",
    "Reranks trait composes RerankingGateway for actual API calls",
    "PendingReranking supports provider failover loop with FailoverableException",
    "RerankingResponse contains array<RankedDocument> and Meta"
  ],
  "method_signatures": {
    "Reranking::of": "static of(Collection|array $documents): PendingReranking",
    "PendingReranking::limit": "limit(?int $limit): self",
    "PendingReranking::rerank": "rerank(string $query, Lab|array|string|null $provider = null, ?string $model = null): RerankingResponse",
    "AiManager::rerankingProvider": "rerankingProvider(?string $name = null): RerankingProvider",
    "AiManager::fakeableRerankingProvider": "fakeableRerankingProvider(?string $name = null): RerankingProvider",
    "RerankingProvider::rerank": "rerank(array $documents, string $query, ?int $limit = null, ?string $model = null): RerankingResponse",
    "RerankingProvider::defaultRerankingModel": "defaultRerankingModel(): string",
    "RerankingProvider::rerankingGateway": "rerankingGateway(): RerankingGateway",
    "RerankingProvider::useRerankingGateway": "useRerankingGateway(RerankingGateway $gateway): self"
  },
  "events_dispatched": [
    "Reranking($invocationId, $provider, $model, $prompt) — before gateway call",
    "Reranked($invocationId, $provider, $model, $prompt, $response) — after gateway call",
    "ProviderFailedOver($provider, $model, $exception) — on failover"
  ],
  "important_notes": "Failover: PendingReranking iterates multiple providers; catches FailoverableException, fires ProviderFailedOver event, continues. Fake support: AiManager clones the provider and swaps in FakeRerankingGateway. RerankingResponse implements Arrayable, Countable, IteratorAggregate, JsonSerializable.",
