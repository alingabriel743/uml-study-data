@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequence {
    ArrowColor #495057
    ActorBorderColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    ParticipantBorderColor #495057
    ParticipantBackgroundColor #F8F9FA
    ParticipantFontColor #212529
    BoxBackgroundColor #F1F3F5
    BoxBorderColor #ADB5BD
    DividerBackgroundColor #DEE2E6
    GroupBackgroundColor #E9ECEF
    NoteBackgroundColor #FFF9DB
    NoteBorderColor #FAB005
}

title File Management Flow

actor Client

participant "Files\n(Static Facade)" as Files
participant "Ai\n(Laravel Facade)" as Ai
participant "AiManager" as AiManager
participant "FileProvider\n(ManagesFiles)" as FileProvider
participant "FileGateway\n/ FakeFileGateway" as FileGateway
participant "EventDispatcher" as EventDispatcher

== Fake Setup (Test Context) ==

Client -> Files : fake(?responses)
activate Files
Files -> Ai : fakeFiles(responses)
activate Ai
Ai -> AiManager : fakeFiles(responses)
activate AiManager
AiManager -> AiManager : new FakeFileGateway(responses)\n→ store as $fakeFileGateway
AiManager --> Files : FakeFileGateway
deactivate AiManager
deactivate Ai
Files --> Client : FakeFileGateway
deactivate Files

note over AiManager : filesAreFaked() = true\nwhen $fakeFileGateway !== null

== Get File ==

Client -> Files : get(fileId, ?provider)
activate Files
Files -> Ai : fakeableFileProvider(?provider)
activate Ai
Ai -> AiManager : fakeableFileProvider(?provider)
activate AiManager
AiManager -> AiManager : fileProvider(name)\n[validates instanceof FileProvider]

alt filesAreFaked()
    AiManager -> AiManager : clone provider
    AiManager -> FileProvider : useFileGateway(fakeFileGateway)
end

AiManager --> Files : FileProvider
deactivate AiManager
deactivate Ai

Files -> FileProvider : getFile(fileId)
activate FileProvider
FileProvider -> FileGateway : getFile(provider, fileId)
activate FileGateway
FileGateway --> FileProvider : FileResponse
deactivate FileGateway
FileProvider --> Files : FileResponse
deactivate FileProvider
Files --> Client : FileResponse
deactivate Files

== Put File ==

Client -> Files : put(file, ?mimeType, ?name, ?provider)
activate Files

alt file is string
    Files -> Files : Base64Document(base64_encode(str), mimeType)\n→ as(name)
else file is UploadedFile
    Files -> Files : Base64Document::fromUpload(file)\n→ as(name ?? originalName)
end

Files -> Ai : fakeableFileProvider(?provider)
activate Ai
Ai -> AiManager : fakeableFileProvider(?provider)
activate AiManager
AiManager --> Files : FileProvider
deactivate AiManager
deactivate Ai

Files -> FileProvider : putFile(file)
activate FileProvider
FileProvider -> FileProvider : invocationId = Str::uuid7()

alt Ai::filesAreFaked()
    FileProvider -> Ai : recordFileUpload(file)
    note right : stored in\nrecordedFileUploads
end

FileProvider -> EventDispatcher : dispatch(StoringFile(invocationId, provider, file))
activate EventDispatcher
EventDispatcher --> FileProvider
deactivate EventDispatcher

FileProvider -> FileGateway : putFile(provider, file)
activate FileGateway
FileGateway --> FileProvider : StoredFileResponse
deactivate FileGateway

FileProvider -> EventDispatcher : dispatch(FileStored(invocationId, provider, file, response))
activate EventDispatcher
EventDispatcher --> FileProvider
deactivate EventDispatcher

FileProvider --> Files : StoredFileResponse
deactivate FileProvider
Files --> Client : StoredFileResponse
deactivate Files

== Put File From Path / Storage ==

group putFromPath (delegates to put)
    Client -> Files : putFromPath(path, ?mimeType, ?name, ?provider)
    activate Files
    Files -> Files : Document::fromPath(path)
    Files -> Files : static::put(document, mimeType, name, provider)
    Files --> Client : StoredFileResponse
    deactivate Files
end

group putFromStorage (delegates to put)
    Client -> Files : putFromStorage(path, ?disk, ?name, ?provider)
    activate Files
    Files -> Files : Document::fromStorage(path, disk)
    Files -> Files : static::put(document, name: name, provider: provider)
    Files --> Client : StoredFileResponse
    deactivate Files
end

== Delete File ==

Client -> Files : delete(fileId, ?provider)
activate Files
Files -> Ai : fakeableFileProvider(?provider)
activate Ai
Ai -> AiManager : fakeableFileProvider(?provider)
activate AiManager
AiManager --> Files : FileProvider
deactivate AiManager
deactivate Ai

Files -> FileProvider : deleteFile(fileId)
activate FileProvider
FileProvider -> FileProvider : invocationId = Str::uuid7()

alt Ai::filesAreFaked()
    FileProvider -> Ai : recordFileDeletion(fileId)
    note right : stored in\nrecordedFileDeletions
end

FileProvider -> FileGateway : deleteFile(provider, fileId)
activate FileGateway
FileGateway --> FileProvider : void
deactivate FileGateway

FileProvider -> EventDispatcher : dispatch(FileDeleted(invocationId, provider, fileId))
activate EventDispatcher
EventDispatcher --> FileProvider
deactivate EventDispatcher

FileProvider --> Files : void
deactivate FileProvider
Files --> Client : void
deactivate Files

@enduml
