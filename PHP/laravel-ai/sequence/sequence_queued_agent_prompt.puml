@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    GroupBorderColor #6C757D
    GroupBackgroundColor #DEE2E6
    GroupBodyBackgroundColor #F8F9FA
    DividerBackgroundColor #E9ECEF
    DividerBorderColor #6C757D
}

title Queued Agent Prompt Dispatch

actor Caller as caller
participant "Agent\n<<Promptable trait>>" as agent
participant "Ai\n<<facade>>" as ai
participant "QueuedAgentPrompt\n<<DTO>>" as dto
participant "FakePendingDispatch" as fake
participant "InvokeAgent\n<<Job>>" as job
participant "Queue\n<<Laravel>>" as queue
participant "QueuedAgentResponse" as response

caller -> agent : queue(prompt, attachments, provider, model)
activate agent

agent -> ai : isFaked()\n[hasFakeGatewayFor(static::class)]
activate ai
ai --> agent : bool $isFaked
deactivate ai

alt Test Path — Agent is faked ($isFaked === true)

    agent -> dto : new QueuedAgentPrompt(\n  agent, prompt, attachments,\n  provider, model\n)
    activate dto
    dto --> agent : $queuedPrompt
    deactivate dto

    agent -> ai : recordPrompt($queuedPrompt)
    activate ai
    note right of ai
        Stores QueuedAgentPrompt for
        later test assertions:
        assertQueued() / assertNotQueued()
        / assertNeverQueued()
    end note
    ai --> agent : void
    deactivate ai

    agent -> fake : new FakePendingDispatch()
    activate fake
    note right of fake
        No-op constructor.
        Overrides all fluent methods
        (onConnection, onQueue, delay,
        chain, afterCommit…) as $this.
        __destruct() is empty —
        prevents dispatch-on-destruct.
        getJob() returns empty anon class.
    end note
    fake --> agent : $fakePendingDispatch
    deactivate fake

    agent -> response : new QueuedAgentResponse($fakePendingDispatch)
    activate response
    response --> agent : $queuedResponse
    deactivate response

    agent --> caller : return $queuedResponse\n(wraps FakePendingDispatch — no queue push)

else Production Path — Agent is real ($isFaked === false)

    agent -> job : dispatch(\n  agent, prompt, attachments,\n  provider, model\n)
    activate job
    note right of job
        InvokeAgent::dispatch()
        returns a real PendingDispatch
    end note

    job -> queue : push InvokeAgent job
    activate queue
    queue --> job : queued
    deactivate queue

    job --> agent : $pendingDispatch
    deactivate job

    agent -> response : new QueuedAgentResponse($pendingDispatch)
    activate response
    response --> agent : $queuedResponse
    deactivate response

    agent --> caller : return $queuedResponse\n(wraps real PendingDispatch)

end

deactivate agent

@enduml
