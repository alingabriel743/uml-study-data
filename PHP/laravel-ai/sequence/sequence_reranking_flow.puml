@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #495057
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #ADB5BD
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam sequenceGroupFontColor #212529
skinparam sequenceGroupFontStyle bold
skinparam noteBorderColor #ADB5BD
skinparam noteBackgroundColor #FFF3CD

title Reranking Flow

actor Client as client
participant "Reranking" as reranking
participant "PendingReranking" as pending
participant "Ai (Facade)" as ai
participant "AiManager" as manager
participant "RerankingProvider\n(Reranks trait)" as provider
participant "RerankingGateway" as gateway
participant "EventDispatcher" as events

' ─── Step 1: Static factory ───────────────────────────────────────────────────
client -> reranking : of(Collection|array $documents)
activate reranking

reranking -> reranking : validate documents is list\n(throws InvalidArgumentException\nif associative array)

reranking -> pending ** : new PendingReranking($documents)
reranking --> client : return PendingReranking
deactivate reranking

' ─── Step 2: Optional configuration ──────────────────────────────────────────
opt Configure limit (fluent)
    client -> pending : limit(?int $limit): self
    activate pending
    pending --> client : return $this
    deactivate pending
end

' ─── Step 3: Trigger reranking ────────────────────────────────────────────────
client -> pending : rerank(string $query,\nLab|array|string|null $provider,\n?string $model): RerankingResponse
activate pending

pending -> pending : formatProviderAndModelList(\n  $provider ?? config('ai.default_for_reranking'),\n  $model\n)

' ─── Step 4: Provider resolution loop (with failover) ────────────────────────
loop For each resolved provider in list
    pending -> ai : fakeableRerankingProvider($providerName)
    activate ai

    ai -> manager : fakeableRerankingProvider(?string $name)
    activate manager

    manager -> manager : rerankingProvider($name)\n[validates RerankingProvider interface]

    alt Reranking is faked
        manager -> manager : clone provider\n+ useRerankingGateway(FakeRerankingGateway)
    end

    manager --> ai : RerankingProvider instance
    deactivate manager
    ai --> pending : RerankingProvider instance
    deactivate ai

    ' ─── Step 5: Resolve default model if needed ──────────────────────────────
    opt $model is null
        pending -> provider : defaultRerankingModel()
        activate provider
        provider --> pending : string $model
        deactivate provider
    end

    ' ─── Step 6: Delegate rerank call to provider ────────────────────────────
    pending -> provider : rerank($documents, $query, $limit, $model)
    activate provider

    provider -> provider : generate invocationId (UUID7)

    create participant "RerankingPrompt" as prompt
    provider -> prompt : new RerankingPrompt(\n  $documents, $query,\n  $limit, $provider, $model\n)

    opt Reranking is faked
        provider -> ai : recordReranking($prompt)
    end

    provider -> events : dispatch(\n  Reranking($invocationId,\n  $provider, $model, $prompt)\n)
    activate events
    events --> provider
    deactivate events

    ' ─── Step 7: Gateway call ─────────────────────────────────────────────────
    provider -> gateway : rerank($provider, $model,\n$documents, $query, $limit)
    activate gateway
    gateway --> provider : RerankingResponse
    deactivate gateway

    provider -> events : dispatch(\n  Reranked($invocationId,\n  $provider, $model,\n  $prompt, $response)\n)
    activate events
    events --> provider
    deactivate events

    alt FailoverableException thrown
        note over provider, events #FFD6D6
            FailoverableException caught by PendingReranking:\n
            → dispatch ProviderFailedOver($provider, $model, $exception)\n
            → continue to next provider in list
        end note
    end

    provider --> pending : RerankingResponse
    deactivate provider
end

' ─── Step 8: Return to client ─────────────────────────────────────────────────
pending --> client : RerankingResponse\n[results: RankedDocument[], meta: Meta]
deactivate pending

note over client, events #D4EDDA
    RerankingResponse implements:\n
    Arrayable, Countable,\nIteratorAggregate, JsonSerializable
end note

@enduml
