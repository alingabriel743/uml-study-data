@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #495057
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #6C757D
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam sequenceGroupFontColor #212529
skinparam noteBorderColor #ADB5BD
skinparam noteBackgroundColor #FFF9E6

title AI Service Provider Boot & Registration

participant "Laravel\nApplication" as app
participant "AiServiceProvider" as provider
participant "AiManager" as manager
participant "Ai (Facade)" as facade
participant "ConversationStore\n(Interface)" as store
participant "DatabaseConversation\nStore" as dbstore
participant "Stringable" as stringable
participant "Collection" as collection
participant "Dispatcher" as dispatcher

== REGISTER Phase ==

app -> provider : register()
activate provider

provider -> app : mergeConfigFrom(\n  'config/ai.php', 'ai')
activate app
app --> provider : config merged
deactivate app

provider -> app : app->scoped(\n  AiManager::class,\n  fn($app) => new AiManager($app))
activate app
note right of app
  AiManager registered as
  **scoped** (per-request lifetime)
end note
app --> provider : binding registered
deactivate app

provider -> app : app->singleton(\n  ConversationStore::class,\n  DatabaseConversationStore::class)
activate app
app --> provider : singleton registered
deactivate app

note over app, dbstore
  IoC Container now holds:
  • AiManager::class  →  scoped closure
  • ConversationStore::class  →  DatabaseConversationStore (singleton)
end note

deactivate provider

== BOOT Phase ==

app -> provider : boot()
activate provider

provider -> app : app->runningInConsole()
activate app
app --> provider : boolean
deactivate app

alt Running in Console

    provider -> provider : registerCommands()
    activate provider
    provider -> app : commands([\n  MakeAgentCommand,\n  MakeAgentMiddlewareCommand,\n  MakeToolCommand])
    activate app
    app --> provider : commands registered
    deactivate app
    deactivate provider

    provider -> provider : registerPublishing()
    activate provider
    provider -> provider : publishes(\n  [config/ai.php => config_path()],\n  tags: ['ai', 'ai-config'])
    provider -> provider : publishes(\n  [stubs/* => base_path('stubs')],\n  tag: 'ai-stubs')
    provider -> provider : publishesMigrations(\n  [database/migrations\n   => database_path('migrations')])
    note right of provider
      Inherited from
      Illuminate\Support\ServiceProvider
    end note
    deactivate provider

end

provider -> stringable : macro('toEmbeddings', Closure)
activate stringable
stringable --> provider : macro registered
deactivate stringable

provider -> collection : macro('rerank', Closure)
activate collection
collection --> provider : macro registered
deactivate collection

deactivate provider

== Facade Resolution (lazy — on first use) ==

[-> facade : Ai::someMethod()
activate facade

facade -> app : getFacadeAccessor()\n→ AiManager::class
activate app
app -> manager : resolve scoped instance\n(or create new AiManager($app))
activate manager
manager --> app : AiManager instance
deactivate manager
app --> facade : AiManager instance
deactivate app

facade -> manager : delegate call
activate manager

manager -> app : config('ai.default')\n[getDefaultInstance()]
activate app
app --> manager : $defaultProvider name
deactivate app

manager -> app : config('ai.providers.'.$name)\n[getInstanceConfig($name)]
activate app
app --> manager : $providerConfig array
deactivate app

manager -> manager : createXxxDriver($config)\ne.g. createOpenaiDriver,\ncreateAnthropicDriver, etc.
activate manager

manager -> dispatcher : app->make(Dispatcher::class)
activate dispatcher
dispatcher --> manager : Dispatcher instance
deactivate dispatcher

note right of manager
  **Drivers with dedicated Gateways:**
  • AnthropicProvider  ← AnthropicGateway
  • GeminiProvider    ← GeminiGateway
  • OpenAiProvider    ← OpenAiGateway

  **Drivers (config + Dispatcher only):**
  AzureOpenAiProvider, CohereProvider,
  DeepSeekProvider, ElevenLabsProvider,
  GroqProvider, JinaProvider,
  MistralProvider, OllamaProvider,
  OpenRouterProvider, VoyageAiProvider,
  XaiProvider
end note

manager --> manager : provider driver instance
deactivate manager

manager --> facade : result
deactivate manager

facade --> [: response
deactivate facade

@enduml
