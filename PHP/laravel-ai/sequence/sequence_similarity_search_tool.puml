@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequenceArrowColor #495057
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #6C757D
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam sequenceGroupFontColor #212529
skinparam noteBorderColor #6C757D
skinparam noteBackgroundColor #FFF9E6

title Similarity Search Tool Execution

actor "Agent" as Agent
participant "SimilaritySearch\n<<Tool>>" as SimilaritySearch
participant "Closure\n($using adapter)" as UsingClosure
participant "EloquentBuilder\n(whereVectorSimilarTo)" as EloquentBuilder
participant "Stringable\n(toEmbeddings macro)" as Stringable
participant "Embeddings\n<<static>>" as Embeddings
participant "PendingEmbeddingsGeneration" as PendingEmbeddings
participant "EmbeddingProvider" as EmbeddingProvider
participant "Collection\n(rerank macro)" as Collection
participant "Reranking\n<<static>>" as Reranking
participant "PendingReranking" as PendingReranking
participant "RerankingProvider\n(Reranks trait)" as RerankingProvider
participant "EventDispatcher" as EventDispatcher
participant "RerankingGateway" as RerankingGateway

== Tool Invocation ==

Agent -> SimilaritySearch : handle(Request $request)
activate SimilaritySearch

note right of SimilaritySearch
  Request contains
  'query' string parameter
end note

== Vector Similarity Query ==

SimilaritySearch -> UsingClosure : call_user_func($using, $request->string('query'))
activate UsingClosure

UsingClosure -> EloquentBuilder : $model::query()\n->whereVectorSimilarTo($column, $queryString, $minSimilarity)
activate EloquentBuilder

note right of EloquentBuilder
  Eloquent scope triggers
  embedding generation
end note

EloquentBuilder -> Stringable : $queryString->toEmbeddings()
activate Stringable

Stringable -> Embeddings : for([$queryString])
activate Embeddings

Embeddings -> PendingEmbeddings : new PendingEmbeddingsGeneration($inputs)
activate PendingEmbeddings

PendingEmbeddings -> EmbeddingProvider : embeddings(inputs, dimensions, model, timeout)
activate EmbeddingProvider
EmbeddingProvider --> PendingEmbeddings : EmbeddingsResponse\n(embeddings[0] = float[])
deactivate EmbeddingProvider

PendingEmbeddings --> Embeddings : EmbeddingsResponse
deactivate PendingEmbeddings

Embeddings --> Stringable : embedding vector (float[])
deactivate Embeddings

Stringable --> EloquentBuilder : embedding vector
deactivate Stringable

EloquentBuilder -> EloquentBuilder : apply optional $query closure\napply result limit
EloquentBuilder -> Collection : ->get()->map(fn($model) =>\n  Arr::except($model->toArray(), [$column]))
activate Collection
Collection --> EloquentBuilder : Collection (without vector column)
deactivate Collection

EloquentBuilder --> UsingClosure : Collection of results
deactivate EloquentBuilder

UsingClosure --> SimilaritySearch : Collection | array | Builder results
deactivate UsingClosure

== Result Normalization ==

SimilaritySearch -> SimilaritySearch : normalize result to Collection\n(array → wrap, Builder → ->get())

alt results are empty
    SimilaritySearch --> Agent : "No relevant results found."
    note right: Early exit — no further processing
end

== Optional Reranking ==

opt $this->rerank === true
    SimilaritySearch -> Collection : ->rerank($rerankBy, $query, $rerankLimit)
    activate Collection

    Collection -> Reranking : of($documents)
    activate Reranking

    Reranking -> PendingReranking : new PendingReranking($documents)
    activate PendingReranking

    PendingReranking -> PendingReranking : ->limit($rerankLimit)\n->rerank($query, $provider, $model)

    PendingReranking -> RerankingProvider : provider->rerank(\n  documents, query, limit, model)
    activate RerankingProvider

    RerankingProvider -> EventDispatcher : dispatch Reranking event
    activate EventDispatcher
    EventDispatcher --> RerankingProvider
    deactivate EventDispatcher

    RerankingProvider -> RerankingGateway : rerankingGateway()->rerank(\n  provider, model, documents, query, limit)
    activate RerankingGateway
    RerankingGateway --> RerankingProvider : RerankingResponse
    deactivate RerankingGateway

    RerankingProvider -> EventDispatcher : dispatch Reranked event
    activate EventDispatcher
    EventDispatcher --> RerankingProvider
    deactivate EventDispatcher

    RerankingProvider --> PendingReranking : RerankingResponse
    deactivate RerankingProvider

    PendingReranking --> Reranking : RerankingResponse
    deactivate PendingReranking

    Reranking --> Collection : ranked indices
    deactivate Reranking

    Collection -> Collection : map results by index\n→ reordered Collection
    Collection --> SimilaritySearch : reranked Collection
    deactivate Collection
end

== Final Response ==

SimilaritySearch --> Agent : "Relevant results found. They are listed\nbelow in order of relevance:\n\n" + JSON (pretty-printed)
deactivate SimilaritySearch

@enduml
