@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipant underline
skinparam sequenceBoxBackgroundColor #E9ECEF
skinparam sequenceBoxBorderColor #6C757D
skinparam sequenceLifeLineBorderColor #495057
skinparam sequenceActiveBorderColor #212529
skinparam sequenceGroupBackgroundColor #F1F3F5
skinparam sequenceGroupBorderColor #6C757D
skinparam noteBorderColor #6C757D
skinparam noteBackgroundColor #FFF9C4

title Structured Agent Response with Schema

actor Client

participant "agent()\nfunctions.php" as AgentFn
participant "StructuredAnonymousAgent\n(HasStructuredOutput)" as SAA
participant "Promptable\n(trait)" as Promptable
participant "AiManager\n(Ai facade)" as AiManager
participant "TextProvider\n(GeneratesText)" as Provider
participant "Pipeline\n(Middleware)" as Pipeline
participant "JsonSchemaTypeFactory" as SchemaFactory
participant "ObjectSchema / Schema" as SchemaObj
participant "TextGateway" as Gateway
participant "StructuredAgentResponse" as StructResp
participant "EventDispatcher" as Events

== Agent Creation ==

Client -> AgentFn : agent(instructions, messages,\n tools, $schema closure)
activate AgentFn

AgentFn -> SAA : new StructuredAnonymousAgent(\n  instructions, messages,\n  tools, SerializableClosure($schema))
activate SAA
SAA --> AgentFn : StructuredAnonymousAgent instance
deactivate SAA

AgentFn --> Client : StructuredAnonymousAgent
deactivate AgentFn

== Prompt Invocation ==

Client -> SAA : prompt($prompt, $attachments?)
activate SAA

SAA -> Promptable : withModelFailover(callback,\n provider, model)
activate Promptable

Promptable -> Promptable : getProvidersAndModels(provider, model)
note right
  Resolves provider/model from:
  1. Method provider()/model()
  2. PHP attributes #[Provider], #[Model]
  3. config('ai.default')
end note

Promptable -> AiManager : textProviderFor(agent, provider)
activate AiManager
AiManager --> Promptable : Provider instance
deactivate AiManager

Promptable -> Provider : prompt(new AgentPrompt(\n  agent, prompt, attachments,\n  provider, model, timeout))
activate Provider

== Middleware Pipeline ==

Provider -> Pipeline : send(AgentPrompt)\n.through(middleware)\n.then(handler)
activate Pipeline
note right of Pipeline
  Middleware may include:
  - RememberConversation
  - Custom agent middleware
end note
Pipeline --> Provider : processed AgentPrompt
deactivate Pipeline

== Schema Resolution ==

Provider -> Events : dispatch(PromptingAgent\n(invocationId, prompt))
activate Events
Events --> Provider
deactivate Events

Provider -> SAA : schema(new JsonSchemaTypeFactory)
activate SAA
SAA -> SchemaFactory : [invoke closure($schema)]
activate SchemaFactory
SchemaFactory --> SAA : JsonSchema type definitions
deactivate SchemaFactory
SAA -> SchemaObj : new ObjectSchema(schemaArray)
activate SchemaObj
SchemaObj -> SchemaObj : disableAdditionalProperties()\n(recursively on all object nodes)
SchemaObj --> SAA : ObjectSchema instance
deactivate SchemaObj
SAA --> Provider : schema array
deactivate SAA

== Gateway Text Generation ==

Provider -> Gateway : generateText(\n  provider, model,\n  instructions, messages,\n  tools, schema,\n  TextGenerationOptions, timeout)
activate Gateway
note right of Gateway
  Schema is passed as a
  structured output constraint
  (e.g. JSON mode / response_format)
end note
Gateway --> Provider : GatewayResponse\n{ structured: array,\n  text: string,\n  usage: Usage,\n  meta: Meta,\n  toolCalls, toolResults,\n  steps }
deactivate Gateway

== Structured Response Assembly ==

Provider -> StructResp : new StructuredAgentResponse(\n  invocationId, structured,\n  text, usage, meta)
activate StructResp
StructResp -> StructResp : withToolCallsAndResults()\n.withSteps()
StructResp --> Provider : StructuredAgentResponse
deactivate StructResp

Provider -> Events : dispatch(AgentPrompted\n(invocationId, prompt, response))
activate Events
Events --> Provider
deactivate Events

Provider --> Promptable : StructuredAgentResponse
deactivate Provider

Promptable --> SAA : StructuredAgentResponse
deactivate Promptable

SAA --> Client : StructuredAgentResponse
deactivate SAA

== Client Accesses Structured Output ==

Client -> StructResp : toArray() / toJson() / offsetGet()
activate StructResp
note right
  StructuredAgentResponse implements
  Arrayable, ArrayAccess, Jsonable,
  JsonSerializable — validated
  structured data is directly accessible
end note
StructResp --> Client : structured output (array / JSON)
deactivate StructResp

@enduml
