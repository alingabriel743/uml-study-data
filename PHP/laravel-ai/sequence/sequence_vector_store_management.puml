@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequence {
    ArrowColor #495057
    ActorBorderColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    ParticipantBorderColor #495057
    ParticipantBackgroundColor #F8F9FA
    ParticipantFontColor #212529
    BoxBackgroundColor #F1F3F5
    BoxBorderColor #ADB5BD
    DividerBackgroundColor #DEE2E6
    GroupBackgroundColor #E9ECEF
}

title Vector Store Management Flow

actor Client
participant "Stores" as Stores
participant "Ai" as Ai
participant "AiManager" as AiMgr
participant "StoreProvider" as SP
participant "Store" as Store
participant "Files" as Files
participant "FileProvider" as FP

' ===========================
' CREATE STORE
' ===========================
== Create Store ==

Client -> Stores : create(name, description, fileIds,\nexpiresWhenIdleFor, provider)
activate Stores

Stores -> Ai : fakeableStoreProvider(provider)
activate Ai
Ai -> AiMgr : fakeableStoreProvider(name)
activate AiMgr
AiMgr -> AiMgr : storeProvider(name)\n[validates StoreProvider contract]

alt Fake mode enabled
    AiMgr -> AiMgr : storesAreFaked()
    AiMgr -> AiMgr : clone provider\n+ useStoreGateway(fakeStoreGateway())
end

AiMgr --> Ai : StoreProvider
deactivate AiMgr
Ai --> Stores : StoreProvider
deactivate Ai

Stores -> SP : createStore(name, description,\nCollection<fileIds>, expiresWhenIdleFor)
activate SP
SP --> Stores : Store instance
deactivate SP

Stores --> Client : Store
deactivate Stores

' ===========================
' GET STORE
' ===========================
== Get Store ==

Client -> Stores : get(storeId, provider)
activate Stores

Stores -> Ai : fakeableStoreProvider(provider)
activate Ai
Ai -> AiMgr : fakeableStoreProvider(name)
activate AiMgr
AiMgr --> Ai : StoreProvider
deactivate AiMgr
Ai --> Stores : StoreProvider
deactivate Ai

Stores -> SP : getStore(storeId)
activate SP
SP --> Stores : Store
deactivate SP

Stores --> Client : Store
deactivate Stores

' ===========================
' DELETE STORE (via Stores facade)
' ===========================
== Delete Store (Facade) ==

Client -> Stores : delete(storeId, provider)
activate Stores

Stores -> Ai : fakeableStoreProvider(provider)
activate Ai
Ai -> AiMgr : fakeableStoreProvider(name)
activate AiMgr
AiMgr --> Ai : StoreProvider
deactivate AiMgr
Ai --> Stores : StoreProvider
deactivate Ai

Stores -> SP : deleteStore(storeId)
activate SP
SP --> Stores : bool
deactivate SP

Stores --> Client : bool
deactivate Stores

' ===========================
' ADD DOCUMENT TO STORE
' ===========================
== Add Document to Store ==

Client -> Store : add(file, metadata)
activate Store

alt file is UploadedFile
    Store -> Store : Base64Document::fromUpload(file)\n->as(originalName)
else file is StorableFile
    Store -> Store : storeFile(file)
    activate Store
    Store -> Files : put(file, provider=provider->name())
    activate Files
    Files -> FP : upload file
    activate FP
    FP --> Files : HasProviderId
    deactivate FP
    Files --> Store : HasProviderId
    deactivate Files
    deactivate Store

    opt Ai::storesAreFaked()
        Store -> Ai : recordFileAddition(storeId, fileId, originalFile)
    end
else file is HasProviderId / string
    note right of Store : Used directly\nno upload needed
end

Store -> SP : addFileToStore(storeId,\nProviderDocument|HasProviderId, metadata)
activate SP
SP --> Store : provider response
deactivate SP

Store --> Client : AddedDocumentResponse\n(providerResponse, fileId)
deactivate Store

' ===========================
' REMOVE DOCUMENT FROM STORE
' ===========================
== Remove Document from Store ==

Client -> Store : remove(documentId, deleteFile=false)
activate Store

Store -> SP : removeFileFromStore(storeId, documentId)
activate SP
SP --> Store : bool (removed)
deactivate SP

alt deleteFile == true && removed == true
    Store -> Files : delete(documentId->id(), provider=provider->name())
    activate Files
    Files --> Store : void
    deactivate Files
end

Store --> Client : bool
deactivate Store

' ===========================
' REFRESH STORE
' ===========================
== Refresh Store ==

Client -> Store : refresh()
activate Store

Store -> SP : getStore(this->id)
activate SP
SP --> Store : new Store instance
deactivate SP

Store --> Client : self (refreshed Store)
deactivate Store

' ===========================
' DELETE STORE (instance method)
' ===========================
== Delete Store (Instance) ==

Client -> Store : delete()
activate Store

Store -> SP : deleteStore(this->id)
activate SP
SP --> Store : bool
deactivate SP

Store --> Client : bool
deactivate Store

@enduml
