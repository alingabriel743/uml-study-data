@startuml
title Laravel AI Package -- System Context Diagram

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actorBackgroundColor<<Person>> #08427B
skinparam actorFontColor<<Person>> #FFFFFF
skinparam actorBorderColor<<Person>> #052E56

skinparam packageBackgroundColor #F5F5F5
skinparam packageBorderColor #BDBDBD
skinparam packageFontColor #424242
skinparam packageFontStyle bold

skinparam ArrowColor #424242
skinparam ArrowFontSize 10
skinparam ArrowFontColor #616161

' -- Actors ------------------------------------------------------------------
actor "Laravel Application\n[Host App / PHP]\nCalls Ai facade or\nfluent builder API\nto perform AI operations" as laravelApp <<Person>>

actor "Queue Worker\n[Laravel Queue]\nProcesses queued AI\njobs asynchronously\n(text, audio, images)" as queueWorker <<Person>>

actor "Artisan CLI\n[Developer / CI]\nRuns make:agent\ncommand to scaffold\nAgent classes" as artisan <<Person>>

' -- Core System -------------------------------------------------------------
rectangle "**Laravel AI Package**\n[PHP / Laravel Service Provider]\n\nUnified AI abstraction layer for Laravel.\nProvides text generation, image generation,\naudio TTS/transcription, embeddings,\nreranking, vector stores, and AI agents\nvia a consistent fluent API." as system <<System>>

' -- Laravel Infrastructure --------------------------------------------------
package "Laravel Infrastructure" {
    rectangle "**Laravel Queue**\n[Illuminate\\Queue]\n\nDefers AI tasks as\nqueued jobs for async\nbackground processing" as queue <<Queue>>

    rectangle "**Cache Store**\n[Database / Redis driver]\n\nCaches generated\nembeddings to avoid\nredundant API calls" as cache <<Cache>>
}

' -- LLM Text Providers ------------------------------------------------------
package "LLM Text Providers" {
    rectangle "**OpenAI**\n[api.openai.com/v1]\n\nText generation, streaming,\ntool/function calling,\nDALL-E image generation,\nWhisper transcription,\nTTS audio, vector stores" as openai <<External>>

    rectangle "**Anthropic**\n[api.anthropic.com/v1]\n\nText generation, streaming,\ntool use, file upload,\nClaude model family" as anthropic <<External>>

    rectangle "**Google Gemini**\n[generativelanguage.googleapis.com]\n\nText generation, streaming,\ntool calling, image gen,\nfile upload, vector stores\n(Gemini / Imagen models)" as gemini <<External>>

    rectangle "**Mistral AI**\n[api.mistral.ai/v1]\n\nText generation,\nstreaming, tool calling,\nMistral model family" as mistral <<External>>

    rectangle "**Groq**\n[api.groq.com/openai/v1]\n\nFast LLM inference,\ntext generation,\nstreaming responses" as groq <<External>>

    rectangle "**xAI / Grok**\n[api.x.ai/v1]\n\nText generation,\nstreaming, tool use,\nimage generation (Aurora)" as xai <<External>>

    rectangle "**DeepSeek**\n[api.deepseek.com/v1]\n\nText generation,\nstreaming, tool use,\nDeepSeek model family" as deepseek <<External>>

    rectangle "**OpenRouter**\n[openrouter.ai/api/v1]\n\nLLM aggregation proxy,\ntext generation,\nstreaming, multi-model\nrouting" as openrouter <<External>>

    rectangle "**Azure OpenAI**\n[custom Azure endpoint]\n\nOpenAI-compatible API\nhosted on Azure,\ntext generation,\nembeddings" as azure <<External>>

    rectangle "**Ollama**\n[localhost:11434]\n\nLocal LLM inference,\nself-hosted models,\ntext generation,\nstreaming" as ollama <<External>>
}

' -- Embedding & Reranking Providers -----------------------------------------
package "Embedding & Reranking Providers" {
    rectangle "**Cohere**\n[api.cohere.com/v2]\n\nVector embeddings,\nsemantic reranking\nof search results" as cohere <<External>>

    rectangle "**Jina AI**\n[api.jina.ai/v1]\n\nVector embeddings,\nsemantic reranking,\nmultimodal embeddings" as jina <<External>>

    rectangle "**VoyageAI**\n[api.voyageai.com/v1]\n\nHigh-quality vector\nembeddings for\nsemantic search" as voyage <<External>>
}

' -- Audio & Speech Provider -------------------------------------------------
package "Audio & Speech" {
    rectangle "**ElevenLabs**\n[api.elevenlabs.io/v1]\n\nText-to-speech audio\ngeneration, speech-to-text\ntranscription with diarization" as elevenlabs <<External>>
}

' -- Alternative Gateway -----------------------------------------------------
package "Alternative Gateway" {
    rectangle "**Prism PHP**\n[echolabs/prism]\n\nThird-party Laravel AI\nlibrary used as alternate\ngateway for text generation\nand embeddings" as prism <<External>>
}

' -- Relationships: Actors -> System -----------------------------------------
laravelApp --> system : "PHP API / Facade\n(Ai::text(), Ai::image(),\nAi::audio(), Ai::embeddings(),\nAi::agent(), Ai::store())"
queueWorker --> system : "PHP dispatch()\n(queued AI jobs:\nQueuedAgentPrompt,\nQueuedImagePrompt, etc.)"
artisan --> system : "Artisan CLI\n(php artisan make:agent)"

' -- Relationships: System <-> Laravel Infrastructure -----------------------
system --> queue : "Illuminate\\Queue\n(dispatch queued AI jobs\nfor async execution)"
queue --> system : "Illuminate\\Queue\n(execute queued jobs\nvia queue workers)"
system --> cache : "Laravel Cache\n(read/write embedding\ncache by input hash)"

' -- Relationships: System -> LLM Text Providers ----------------------------
system --> openai : "HTTPS REST\n(text, streaming SSE,\ntool calls, DALL-E images,\nfiles, vector stores)"
system --> anthropic : "HTTPS REST\n(text, streaming SSE,\ntool use, file uploads)"
system --> gemini : "HTTPS REST\n(text, streaming SSE,\ntool calls, image gen,\nfiles, corpus stores)"
system --> mistral : "HTTPS REST\n(text, streaming SSE,\ntool calls)"
system --> groq : "HTTPS REST\n(text, streaming SSE)"
system --> xai : "HTTPS REST\n(text, streaming SSE,\ntool calls, image gen)"
system --> deepseek : "HTTPS REST\n(text, streaming SSE,\ntool calls)"
system --> openrouter : "HTTPS REST\n(text, streaming SSE,\nrouted to any model)"
system --> azure : "HTTPS REST\n(OpenAI-compatible API\ntext + embeddings)"
system --> ollama : "HTTP REST\n(local text generation,\nstreaming SSE)"

' -- Relationships: System -> Embedding/Reranking ---------------------------
system --> cohere : "HTTPS REST\n(generate embeddings,\nrerank results)"
system --> jina : "HTTPS REST\n(generate embeddings,\nrerank results)"
system --> voyage : "HTTPS REST\n(generate embeddings)"

' -- Relationships: System -> Audio -----------------------------------------
system --> elevenlabs : "HTTPS REST\n(TTS: text to audio,\nSTT: audio to transcript)"

' -- Relationships: System -> Prism -----------------------------------------
system --> prism : "PHP Library Call\n(text generation,\nembeddings via\nPrismGateway)"

@enduml
