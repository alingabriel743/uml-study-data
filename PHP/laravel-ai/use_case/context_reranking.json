{
  "scope": "reranking",
  "title": "Reranking",
  "diagram_type": "use_case",
  "description": "Developer reranks a list of documents or passages relative to a query using dedicated reranking providers (Cohere, VoyageAI, Jina).",

  "actors": [
    {
      "name": "Developer",
      "type": "primary",
      "description": "Application developer who initiates document reranking operations"
    },
    {
      "name": "CohereAPI",
      "type": "external_system",
      "description": "Cohere external REST API (https://api.cohere.com/v2)"
    },
    {
      "name": "VoyageAiAPI",
      "type": "external_system",
      "description": "VoyageAI external REST API"
    },
    {
      "name": "JinaAPI",
      "type": "external_system",
      "description": "Jina external REST API (https://api.jina.ai/v1)"
    }
  ],

  "use_cases": [
    {
      "id": "UC1",
      "name": "Rerank Documents",
      "actor": "Developer",
      "description": "Developer provides a list of documents and a query; the system returns them ranked by relevance.",
      "entry_point": "Reranking::of(documents)",
      "steps": [
        "Call Reranking::of(Collection|array $documents) → returns PendingReranking",
        "Optionally call PendingReranking::limit(?int $limit) to cap results",
        "Call PendingReranking::rerank(string $query, provider?, model?) → RerankingResponse",
        "Resolve provider list via Provider::formatProviderAndModelList()",
        "Resolve default model from config('ai.default_for_reranking') if not specified",
        "Dispatch Reranking event (invocationId, provider, model, prompt)",
        "Delegate to RerankingGateway::rerank(provider, model, documents, query, limit)",
        "Gateway POSTs to provider API /rerank endpoint",
        "Map API results to RankedDocument[] (index, document, relevance_score)",
        "Dispatch Reranked event",
        "Return RerankingResponse(results: RankedDocument[], meta: Meta)"
      ]
    },
    {
      "id": "UC2",
      "name": "Rerank with Cohere",
      "actor": "Developer",
      "extends": "UC1",
      "description": "Uses CohereProvider + CohereGateway. POSTs to /rerank with top_n parameter. Default model: rerank-v3.5.",
      "api_field": "top_n"
    },
    {
      "id": "UC3",
      "name": "Rerank with VoyageAI",
      "actor": "Developer",
      "extends": "UC1",
      "description": "Uses VoyageAiProvider + VoyageAiGateway (uses CreatesVoyageAiClient trait). POSTs to /rerank with top_k parameter.",
      "api_field": "top_k"
    },
    {
      "id": "UC4",
      "name": "Rerank with Jina",
      "actor": "Developer",
      "extends": "UC1",
      "description": "Uses JinaProvider + JinaGateway. POSTs to /rerank with top_n parameter.",
      "api_field": "top_n"
    },
    {
      "id": "UC5",
      "name": "Limit Reranking Results",
      "actor": "Developer",
      "description": "Developer calls PendingReranking::limit(n) before reranking to restrict the number of returned results.",
      "included_in": "UC1"
    },
    {
      "id": "UC6",
      "name": "Fake Reranking (Testing)",
      "actor": "Developer",
      "description": "Developer calls Reranking::fake(Closure|array) to stub reranking via FakeRerankingGateway. Records invocations for assertions.",
      "entry_point": "Reranking::fake(responses)",
      "related_assertions": ["assertReranked(Closure)", "assertNotReranked(Closure)", "assertNothingReranked()"]
    },
    {
      "id": "UC7",
      "name": "Failover to Next Provider",
      "actor": "Developer",
      "description": "If a FailoverableException is thrown by a provider, the system fires ProviderFailedOver event and retries with the next provider in the list.",
      "included_in": "UC1"
    }
  ],

  "key_classes": [
    {
      "name": "Reranking",
      "namespace": "Laravel\\Ai",
      "type": "static facade/entry-point",
      "methods": ["of(Collection|array): PendingReranking", "fake(Closure|array): FakeRerankingGateway", "assertReranked(Closure)", "assertNotReranked(Closure)", "assertNothingReranked()", "isFaked(): bool"]
    },
    {
      "name": "PendingReranking",
      "namespace": "Laravel\\Ai\\PendingResponses",
      "type": "builder/fluent",
      "traits": ["Conditionable"],
      "properties": ["documents: array<int,string>", "limit: ?int"],
      "methods": ["limit(?int): self", "rerank(string $query, Lab|array|string|null $provider, ?string $model): RerankingResponse"]
    },
    {
      "name": "RerankingProvider",
      "namespace": "Laravel\\Ai\\Contracts\\Providers",
      "type": "interface",
      "methods": ["rerank(array, string, ?int, ?string): RerankingResponse", "rerankingGateway(): RerankingGateway", "useRerankingGateway(RerankingGateway): self", "defaultRerankingModel(): string"]
    },
    {
      "name": "RerankingGateway",
      "namespace": "Laravel\\Ai\\Contracts\\Gateway",
      "type": "interface",
      "methods": ["rerank(RerankingProvider, string $model, array $documents, string $query, ?int $limit): RerankingResponse"]
    },
    {
      "name": "CohereProvider",
      "namespace": "Laravel\\Ai\\Providers",
      "type": "concrete provider",
      "implements": ["EmbeddingProvider", "RerankingProvider"],
      "traits": ["GeneratesEmbeddings", "HasEmbeddingGateway", "HasRerankingGateway", "Reranks"],
      "default_model": "rerank-v3.5",
      "gateway": "CohereGateway"
    },
    {
      "name": "VoyageAiProvider",
      "namespace": "Laravel\\Ai\\Providers",
      "type": "concrete provider",
      "implements": ["EmbeddingProvider", "RerankingProvider"],
      "gateway": "VoyageAiGateway"
    },
    {
      "name": "JinaProvider",
      "namespace": "Laravel\\Ai\\Providers",
      "type": "concrete provider",
      "implements": ["EmbeddingProvider", "RerankingProvider"],
      "gateway": "JinaGateway"
    },
    {
      "name": "CohereGateway",
      "namespace": "Laravel\\Ai\\Gateway",
      "type": "concrete gateway",
      "implements": ["EmbeddingGateway", "RerankingGateway"],
      "api_base": "https://api.cohere.com/v2",
      "rerank_endpoint": "POST /rerank",
      "limit_param": "top_n"
    },
    {
      "name": "VoyageAiGateway",
      "namespace": "Laravel\\Ai\\Gateway\\VoyageAi",
      "type": "concrete gateway",
      "implements": ["EmbeddingGateway", "RerankingGateway"],
      "traits": ["CreatesVoyageAiClient"],
      "rerank_endpoint": "POST /rerank",
      "limit_param": "top_k"
    },
    {
      "name": "JinaGateway",
      "namespace": "Laravel\\Ai\\Gateway",
      "type": "concrete gateway",
      "implements": ["EmbeddingGateway", "RerankingGateway"],
      "api_base": "https://api.jina.ai/v1",
      "rerank_endpoint": "POST /rerank",
      "limit_param": "top_n"
    },
    {
      "name": "RerankingResponse",
      "namespace": "Laravel\\Ai\\Responses",
      "type": "response DTO",
      "implements": ["Arrayable", "Countable", "IteratorAggregate", "JsonSerializable"],
      "properties": ["results: RankedDocument[]", "meta: Meta"],
      "methods": ["first(): ?RankedDocument", "documents(): Collection", "count(): int", "collect(): Collection"]
    },
    {
      "name": "Reranks",
      "namespace": "Laravel\\Ai\\Providers\\Concerns",
      "type": "trait",
      "description": "Shared reranking logic used by all providers. Fires Reranking/Reranked events, delegates to rerankingGateway().",
      "events_fired": ["Reranking (before)", "Reranked (after)"]
    },
    {
      "name": "FakeRerankingGateway",
      "namespace": "Laravel\\Ai\\Gateway",
      "type": "test double",
      "implements": ["RerankingGateway"],
      "description": "Used in testing to intercept and record reranking calls without hitting real APIs."
    }
  ],

  "key_relationships": [
    "Reranking (static) creates PendingReranking via ::of()",
    "PendingReranking delegates to Provider::rerank() (via Reranks trait)",
    "Reranks trait delegates to RerankingGateway::rerank()",
    "CohereProvider implements RerankingProvider, uses CohereGateway",
    "VoyageAiProvider implements RerankingProvider, uses VoyageAiGateway",
    "JinaProvider implements RerankingProvider, uses JinaGateway",
    "CohereGateway implements RerankingGateway (and EmbeddingGateway)",
    "VoyageAiGateway implements RerankingGateway (and EmbeddingGateway)",
    "JinaGateway implements RerankingGateway (and EmbeddingGateway)",
    "All gateways return RerankingResponse(RankedDocument[], Meta)",
    "PendingReranking supports provider failover on FailoverableException"
  ],

  "important_notes": "Provider resolved from config('ai.default_for_reranking') or passed inline. Failover iterates provider list and retries on FailoverableException. All three gateways share the same interface but differ in limit param name (top_n vs top_k) and HTTP client setup. Testing via Reranking::fake() replaces gateway with FakeRerankingGateway.",

  "source_files_analyzed": [
    "src/Reranking.php",
