    "src/Providers/Concerns/Reranks.php",
    "src/Providers/CohereProvider.php",
    "src/Gateway/CohereGateway.php",
    "src/Gateway/VoyageAi/VoyageAiGateway.php",
    "src/Gateway/JinaGateway.php",
    "src/Responses/RerankingResponse.php"
  ]
}
