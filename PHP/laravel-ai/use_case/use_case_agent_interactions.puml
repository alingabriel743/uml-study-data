@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}

title Agent Interactions

left to right direction

actor "Developer" as developer
actor "Queue System" as queue #E9ECEF
actor "Broadcast Channel" as broadcast #E9ECEF

rectangle "Agent Interactions System" {

    package "Agent Definition" {
        usecase "Define Agent" as UC1
    }

    package "Synchronous Invocation" {
        usecase "Invoke Agent Synchronously" as UC5
        usecase "Invoke Agent with Streaming" as UC6
    }

    package "Asynchronous / Queue Invocation" {
        usecase "Invoke Agent on Queue" as UC7
        usecase "Execute Queued Agent Prompt" as UC8
    }

    package "Broadcast Streaming" {
        usecase "Broadcast Streamed Events" as UC9
        usecase "Broadcast Streamed Events on Queue" as UC10
    }

    package "Testing" {
        usecase "Fake Agent for Testing" as UC11
        usecase "Assert Agent Prompts" as UC12
    }
}

' Developer → core invocation use cases
developer --> UC1
developer --> UC5
developer --> UC6
developer --> UC7
developer --> UC9
developer --> UC10
developer --> UC11
developer --> UC12

' Queue System handles async execution
queue --> UC8

' Broadcast Channel receives streamed events
broadcast --> UC9
broadcast --> UC10

' Include relationships (internal delegation)
UC8 ..> UC5 : <<include>>
UC9 ..> UC6 : <<include>>
UC12 ..> UC11 : <<include>>

@enduml
