@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Async & Queued Operations

left to right direction

actor "Developer" as developer
actor "Laravel Queue Worker" as worker
actor "Agent (Contract)" as agent
actor "Broadcast System" as broadcast
actor "Test Environment" as testenv

rectangle "Async & Queued Operations" {

    usecase "Dispatch Agent Prompt\nto Queue" as UC1
    note right of UC1
      Wraps agent + prompt in
      QueuedAgentPrompt DTO,
      dispatches InvokeAgent job
      via QueuedAgentResponse
    end note

    usecase "Configure Queue\nDispatch Options" as UC6
    note right of UC6
      onQueue(), onConnection(),
      delay(), afterCommit(),
      chain() — proxied via
      QueuedAgentResponse.__call()
    end note

    usecase "Register Success\nCallback" as UC4
    usecase "Register Failure\nCallback" as UC5

    usecase "Process Agent Invocation\nin Background" as UC2
    note right of UC2
      InvokeAgent::handle()
      calls agent->prompt(),
      then fires thenCallbacks[]
    end note

    usecase "Stream Agent Response\nwith Broadcast" as UC3
    note right of UC3
      BroadcastAgent::handle()
      streams via agent->stream(),
      broadcasts each StreamEvent
      in real-time, then fires callbacks
    end note

    usecase "Fake Queue Dispatch\nfor Testing" as UC7
    note right of UC7
      FakePendingDispatch replaces
      PendingDispatch; all methods
      are no-ops, prevents real dispatch
    end note

}

' Developer interactions
developer --> UC1 : dispatches
developer --> UC6 : configures
developer --> UC4 : registers
developer --> UC5 : registers

' Queue worker interactions
worker --> UC2 : executes
worker --> UC3 : executes

' Include relationships
UC2 ..> UC4 : <<include>>
UC2 ..> UC5 : <<include>>
UC3 ..> UC4 : <<include>>
UC3 ..> UC5 : <<include>>

UC1 ..> UC6 : <<extend>>
UC1 ..> UC4 : <<extend>>
UC1 ..> UC5 : <<extend>>

' System actor interactions
agent --> UC2 : invoked by
agent --> UC3 : streamed by
broadcast --> UC3 : receives StreamEvents

' Test environment
testenv --> UC7 : uses
UC7 ..> UC1 : <<extend>>

@enduml
