@startuml

skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #343A40
    FontColor #212529
    FontStyle bold
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Audio Generation & Transcription

left to right direction

actor "Developer" as dev
actor "ElevenLabs API" as elevenlabs <<external system>>
actor "Queue System" as queue <<external system>>

rectangle "Audio Generation & Transcription System" {

    package "Text-to-Speech (TTS)" {
        usecase "Generate Audio\nfrom Text" as UC1
        usecase "Configure Voice\n& Instructions" as UC1a
        usecase "Queue Audio\nGeneration" as UC2
    }

    package "Speech-to-Text (STT)" {
        usecase "Transcribe\nAudio File" as UC3
        usecase "Configure Language\n& Diarization" as UC3a
        usecase "Queue Transcription\nGeneration" as UC4
    }

    package "Testing Support" {
        usecase "Fake Audio\nGeneration" as UC5
        usecase "Fake Transcription\nGeneration" as UC6
        usecase "Assert Audio\nOperations" as UC7
        usecase "Assert Transcription\nOperations" as UC8
    }
}

' Developer initiates all use cases
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4
dev --> UC5
dev --> UC6
dev --> UC7
dev --> UC8

' External system interactions
UC1 --> elevenlabs : POST /v1/text-to-speech/{voice_id}
UC3 --> elevenlabs : POST /v1/speech-to-text (multipart)
UC2 --> queue : dispatches GenerateAudio job
UC4 --> queue : dispatches GenerateTranscription job

' Include relationships — sub-flows always executed
UC1 ..> UC1a : <<include>>
UC3 ..> UC3a : <<include>>

' Queue use cases defer to their synchronous counterpart
UC2 ..> UC1 : <<include>>
UC4 ..> UC3 : <<include>>

' Fake gateways extend real generation (testing override)
UC5 ..> UC1 : <<extend>>
UC6 ..> UC3 : <<extend>>

' Assertions depend on fake context
UC7 ..> UC5 : <<include>>
UC8 ..> UC6 : <<include>>

note bottom of UC4
  <b>Constraint:</b> Only LocalAudio or StoredAudio allowed.
  Base64/UploadedFile types throw LogicException
  (serialization restriction for queued jobs).
end note

note right of UC1
  Default voice model: eleven_multilingual_v2
  Default male voice: onwK4e9ZLuTAKqWW03F9
  Default female voice: XrExE9yKIg1WjnnlVkGX
  Returns: AudioResponse (base64, mime: audio/mpeg)
end note

note right of UC3
  Default STT model: scribe_v2
  Accepts: Base64Audio, LocalAudio, StoredAudio
  Diarization returns TranscriptionSegment[]
  (text, speaker_id, start, end per word)
end note

@enduml
