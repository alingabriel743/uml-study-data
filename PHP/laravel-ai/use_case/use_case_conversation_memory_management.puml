@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam ArrowColor #495057

title Conversation Memory Management

left to right direction

actor "Developer" as developer
actor "Database\n(agent_conversations\nagent_conversation_messages)" as db #E3F2FD
actor "TextProvider\n(cheapest text model)" as textProvider #E3F2FD

rectangle "Conversation Memory Management System" {

    usecase "Start New Conversation\nfor User\n(forUser)" as UC1
    usecase "Continue Existing\nConversation\n(continue)" as UC2
    usecase "Resume Latest\nConversation\n(continueLastConversation)" as UC3
    usecase "Retrieve Conversation\nHistory\n(messages)" as UC4
    usecase "Auto-Register Memory\nMiddleware\n(GeneratesText pipeline)" as UC11

    usecase "Fetch Latest\nConversation ID\n(latestConversationId)" as UC10

    usecase "Auto-Persist\nConversation Turn\n(RememberConversation)" as UC5
    usecase "Auto-Generate\nConversation Title\n(generateTitle)" as UC6
    usecase "Store Conversation\nRecord\n(storeConversation)" as UC7
    usecase "Store User\nMessage\n(storeUserMessage)" as UC8
    usecase "Store Assistant\nMessage\n(storeAssistantMessage)" as UC9
}

' Developer interactions
developer --> UC1 : sets up agent\nbefore first prompt
developer --> UC2 : resumes known\nconversation UUID
developer --> UC3 : resumes most\nrecent thread
developer --> UC4 : reads history\nfor prompt context
developer --> UC11 : configures agent\nwith RemembersConversations

' Include relationships from Developer use cases
UC3 ..> UC10 : <<include>>
UC11 ..> UC5 : <<include>>\nauto-injects middleware

' Include relationships from Auto-Persist
UC5 ..> UC6 : <<include>>\non first message
UC5 ..> UC7 : <<include>>\nif no conversation
UC5 ..> UC8 : <<include>>
UC5 ..> UC9 : <<include>>

UC4 ..> UC10 : <<include>>\ngetLatestConversationMessages

' Secondary actor interactions
UC7 --> db : INSERT agent_conversations
UC8 --> db : INSERT agent_conversation_messages\n(role = user)
UC9 --> db : INSERT agent_conversation_messages\n(role = assistant)
UC10 --> db : SELECT agent_conversations\nORDER BY updated_at DESC
UC6 --> textProvider : generateText(cheapestTextModel)\nfallback: Str::limit(prompt, 100)

note bottom of UC5
  **RememberConversation Middleware Flow:**
  1. Pass prompt to next handler
  2. Check agent->currentConversation()
  3. If null → storeConversation + auto-title
  4. agent->continue(conversationId)
  5. storeUserMessage + storeAssistantMessage
  6. response->withinConversation(conversationId)
end note

note bottom of UC11
  **Auto-Registration Condition:**
  class_uses_recursive($agent)
  includes RemembersConversations trait
  AND $agent->hasConversationParticipant()
end note

@enduml
