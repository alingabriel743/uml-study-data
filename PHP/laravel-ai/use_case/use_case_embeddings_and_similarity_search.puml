@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Embeddings & Similarity Search

left to right direction

actor "Developer" as developer
actor "AI Agent\n(LLM Tool Consumer)" as agent
actor "Test Environment" as test

rectangle "Embeddings & Similarity Search" {

    usecase "Generate Embeddings\n(Synchronous)" as UC1
    usecase "Queue Embeddings\n(Asynchronous)" as UC2
    usecase "Search Similar\nDocuments" as UC3
    usecase "Fake Embeddings\nfor Testing" as UC4
    usecase "Assert Embeddings\nBehaviour" as UC5

    usecase "Configure Fluent Builder\n(dimensions / cache / timeout)" as UC1a
    usecase "Resolve Provider & Model" as UC1b
    usecase "Check Embedding Cache" as UC1c
    usecase "Handle Provider Failover" as UC1d
    usecase "Dispatch GenerateEmbeddings\nJob (Queue)" as UC2a
    usecase "Query Vector Store\n(whereVectorSimilarTo)" as UC3a
    usecase "Rerank Results" as UC3b
    usecase "Auto-generate Random\nFloat Vector" as UC4a
    usecase "Prevent Stray Embeddings\n(strict mode)" as UC4b

}

' Actor → Use Case associations
developer --> UC1
developer --> UC2
agent    --> UC3
test     --> UC4
test     --> UC5

' UC1 sub-flows (include)
UC1 ..> UC1a : <<include>>
UC1 ..> UC1b : <<include>>
UC1 ..> UC1c : <<include>>
UC1d ..> UC1 : <<extend>>\ncache miss + failover

' UC2 sub-flows (include)
UC2 ..> UC2a : <<include>>
UC2 ..> UC1b : <<include>>

' UC3 sub-flows
UC3 ..> UC3a : <<include>>
UC3b ..> UC3 : <<extend>>\nrerank enabled

' UC4 sub-flows
UC4 ..> UC4a : <<extend>>\nno response defined
UC4b ..> UC4 : <<extend>>\npreventStrayEmbeddings=true

' UC5 depends on fake setup
UC5 ..> UC4 : <<include>>

@enduml
