@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}

skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title File & Vector Store Management

left to right direction

actor "Developer" as dev

actor "FileProvider" as fileProv
actor "StoreProvider" as storeProv
actor "FileGateway" as fileGw
actor "StoreGateway" as storeGw

rectangle "File & Vector Store Management" {

    package "File Operations" {
        usecase "Upload File\n(Files::put / putFromPath\n/ putFromStorage)" as UC1
        usecase "Retrieve File\n(Files::get)" as UC2
        usecase "Delete File\n(Files::delete)" as UC3
    }

    package "Vector Store Operations" {
        usecase "Create Vector Store\n(Stores::create)" as UC4
        usecase "Retrieve Vector Store\n(Stores::get / Store::refresh)" as UC5
        usecase "Delete Vector Store\n(Stores::delete / Store::delete)" as UC6
        usecase "Add File to Store\n(Store::add)" as UC7
        usecase "Remove File from Store\n(Store::remove)" as UC8
    }

    package "Testing & Faking" {
        usecase "Fake File Provider\n(Files::fake)" as UC9
        usecase "Fake Store Provider\n(Stores::fake)" as UC10
    }
}

' Developer initiates all primary use cases
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4
dev --> UC5
dev --> UC6
dev --> UC7
dev --> UC8
dev --> UC9
dev --> UC10

' Include relationships between use cases
UC7 ..> UC1 : <<include>>\nauto-upload raw file
UC3 <.. UC8 : <<extend>>\nif deleteFile=true

' File operations delegate to FileProvider → FileGateway
UC1 --> fileProv
UC2 --> fileProv
UC3 --> fileProv
fileProv --> fileGw

' Vector store operations delegate to StoreProvider → StoreGateway
UC4 --> storeProv
UC5 --> storeProv
UC6 --> storeProv
UC7 --> storeProv
UC8 --> storeProv
storeProv --> storeGw

' Testing doubles replace real gateways
UC9 --> fileGw : <<fake>>
UC10 --> storeGw : <<fake>>

note bottom of UC7
  Store::add() accepts StorableFile,
  UploadedFile, HasProviderId, or string.
  Raw files are auto-uploaded via Files::put()
  before being attached to the store.
end note

note bottom of UC8
  Store::remove(documentId, deleteFile).
  When deleteFile=true and removal succeeds,
  Files::delete() is called automatically.
end note

@enduml
