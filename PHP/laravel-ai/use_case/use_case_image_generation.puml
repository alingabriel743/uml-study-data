@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}

left to right direction

title Image Generation

actor "Developer" as developer
actor "AI Provider\n(OpenAI DALL·E / XAI)" as ai_provider <<external system>>
actor "Queue System\n(Laravel Queue)" as queue <<external system>>

rectangle "Image Generation" {

    package "Core Generation" {
        usecase "Generate Image\nSynchronously" as UC1
        usecase "Queue Image\nGeneration" as UC2
        usecase "Configure Image Options\n(size, quality, timeout,\nattachments)" as UC3
        usecase "Select Provider\nand Model" as UC4
        usecase "Handle Provider\nFailover" as UC5
    }

    package "Testing & Assertions" {
        usecase "Fake Image\nGeneration" as UC6
        usecase "Assert Image\nGenerated" as UC7
        usecase "Assert Image\nQueued" as UC8
    }

}

' Developer initiates all primary use cases
developer --> UC1
developer --> UC2
developer --> UC6
developer --> UC7
developer --> UC8

' Include relationships — sub-steps always performed
UC1 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>
UC2 ..> UC3 : <<include>>
UC2 ..> UC4 : <<include>>

' Extend relationship — failover optionally extends synchronous generation
UC5 ..> UC1 : <<extend>>

' Testing assertions require fake mode to be active
UC7 ..> UC6 : <<extend>>
UC8 ..> UC6 : <<extend>>

' External system interactions
UC1 --> ai_provider : calls generateImage()
UC2 --> queue       : dispatches GenerateImage job
queue --> ai_provider : executes generate() via job

@enduml
