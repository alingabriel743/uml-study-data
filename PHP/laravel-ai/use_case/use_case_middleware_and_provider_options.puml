@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Middleware & Provider Options

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────
actor "Developer" as Dev

actor "GeneratesText\n(Provider Trait)" as GT #D0E8FF
actor "BuildsTextRequests\n(Gateway Trait)" as BTR #D0E8FF

' ── System Boundary ─────────────────────────────────────────────────────
rectangle "Laravel AI Package" {

    ' Middleware sub-group
    package "Middleware Pipeline" {
        usecase "Implement HasMiddleware\non an Agent" as UC1
        usecase "Generate Middleware\nScaffold (artisan\nmake:agent-middleware)" as UC2
        usecase "Write Custom\nMiddleware Logic\n(handle / next pattern)" as UC3
        usecase "Run Middleware\nPipeline on prompt()" as UC6
        usecase "Apply Built-in\nRememberConversation\nMiddleware" as UC8
    }

    ' Provider Options sub-group
    package "Provider Options" {
        usecase "Implement HasProviderOptions\non an Agent" as UC4
        usecase "Configure Generation Options\nvia PHP Attributes\n(#[MaxTokens] / #[Temperature] / #[MaxSteps])" as UC5
        usecase "Read providerOptions\nat Request Build Time" as UC7
    }
}

' ── Developer associations ───────────────────────────────────────────────
Dev --> UC1 : implements interface
Dev --> UC2 : runs artisan command
Dev --> UC3 : writes handle() logic
Dev --> UC4 : implements interface
Dev --> UC5 : annotates agent class

' ── System actor associations ────────────────────────────────────────────
GT  --> UC6 : executes pipeline
GT  --> UC8 : auto-injects when\nRemembersConversations
BTR --> UC7 : merges options\ninto HTTP request

' ── Include / Extend relationships ───────────────────────────────────────
UC2 ..> UC3  : <<include>>\n(scaffold generates\nmiddleware stub)
UC6 ..> UC1  : <<include>>\n(collects agent\nmiddleware array)
UC6 ..> UC8  : <<include>>\n(conversation agents\nauto-get this middleware)
UC7 ..> UC4  : <<include>>\n(reads agent\nproviderOptions())
UC7 ..> UC5  : <<include>>\n(reads TextGenerationOptions\nattributes via Reflection)

@enduml
