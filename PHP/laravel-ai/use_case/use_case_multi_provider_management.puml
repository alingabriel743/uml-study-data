@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #1E6FA8
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Multi-Provider Management

left to right direction

' ─── Primary Actor ───────────────────────────────────────────
actor "Developer" as Dev

' ─── External AI Provider Actors ─────────────────────────────
actor "OpenAI\nProvider" as OpenAI #D5F5E3
actor "Anthropic\nProvider" as Anthropic #D5F5E3
actor "Gemini\nProvider" as Gemini #D5F5E3
actor "Ollama\nProvider" as Ollama #FEF9E7
actor "Mistral\nProvider" as Mistral #FEF9E7
actor "Groq\nProvider" as Groq #FEF9E7
actor "Azure / Cohere /\nDeepSeek / Others" as Others #F2F3F4

' ─── System Boundary: AiManager ──────────────────────────────
rectangle "AiManager — Multi-Provider System" {

    ' --- Provider Configuration ---
    package "Provider Configuration" {
        usecase "Select Default Provider" as UC1
        usecase "Switch Provider at Runtime" as UC2
        usecase "Resolve Provider by Name" as UC3
    }

    ' --- Capability Providers ---
    package "Capability Resolution" {
        usecase "Create Text Provider" as UC4
        usecase "Create Image Provider" as UC5
        usecase "Create Audio Provider" as UC6
        usecase "Create Embedding Provider" as UC7
        usecase "Create Transcription Provider" as UC8
        usecase "Create File Provider" as UC9
        usecase "Create Store Provider" as UC10
    }

    ' --- Built-in Tool Capabilities ---
    package "Tool Capabilities" {
        usecase "Use Web Search Tool" as UC11
        usecase "Use Web Fetch Tool" as UC12
        usecase "Use File Search Tool" as UC13
    }

    ' --- Advanced Usage ---
    package "Advanced Usage" {
        usecase "Fake Provider for Testing" as UC14
        usecase "Compose Provider with Agent" as UC15
    }
}

' ─── Developer → Use Cases ───────────────────────────────────
Dev --> UC1
Dev --> UC2
Dev --> UC3
Dev --> UC4
Dev --> UC5
Dev --> UC6
Dev --> UC7
Dev --> UC8
Dev --> UC9
Dev --> UC10
Dev --> UC11
Dev --> UC12
Dev --> UC13
Dev --> UC14
Dev --> UC15

' ─── Include relationships (capability resolution reuses provider lookup) ──
UC4 ..> UC3 : <<include>>
UC5 ..> UC3 : <<include>>
UC6 ..> UC3 : <<include>>
UC7 ..> UC3 : <<include>>
UC8 ..> UC3 : <<include>>
UC9 ..> UC3 : <<include>>
UC10 ..> UC3 : <<include>>
UC15 ..> UC4 : <<include>>
UC14 ..> UC3 : <<include>>

' ─── Extend relationship (runtime switch overrides default) ──
UC2 ..> UC1 : <<extend>>

' ─── Providers supporting Text ───────────────────────────────
UC4 --> OpenAI
UC4 --> Anthropic
UC4 --> Gemini
UC4 --> Ollama
UC4 --> Mistral
UC4 --> Groq

' ─── Providers supporting Image ──────────────────────────────
UC5 --> OpenAI
UC5 --> Gemini

' ─── Providers supporting Audio ──────────────────────────────
UC6 --> OpenAI

' ─── Providers supporting Embeddings ─────────────────────────
UC7 --> OpenAI
UC7 --> Gemini
UC7 --> Ollama
UC7 --> Mistral

' ─── Providers supporting Transcription ──────────────────────
UC8 --> OpenAI
UC8 --> Mistral

' ─── Providers supporting Files ──────────────────────────────
UC9 --> OpenAI
UC9 --> Anthropic
UC9 --> Gemini

' ─── Providers supporting Vector Stores ──────────────────────
UC10 --> OpenAI
UC10 --> Gemini

' ─── Providers supporting Web Search ─────────────────────────
UC11 --> OpenAI
UC11 --> Anthropic
UC11 --> Gemini

' ─── Providers supporting Web Fetch ──────────────────────────
UC12 --> Anthropic
UC12 --> Gemini

' ─── Providers supporting File Search ────────────────────────
UC13 --> OpenAI
UC13 --> Gemini

' ─── Other registered providers (factory-registered) ─────────
UC3 --> Others

@enduml
