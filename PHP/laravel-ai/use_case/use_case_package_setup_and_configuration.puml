@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam ArrowColor #495057

title Package Setup & Configuration

left to right direction

actor "Developer" as dev
actor "Laravel\nApplication" as laravelApp <<system>>
actor "Artisan CLI" as artisan <<system>>

rectangle "Laravel AI Package (Laravel\\Ai)" {

    usecase "Register Service Provider\n<size:10>(AiServiceProvider::register())</size>" as UC1
    usecase "Bootstrap Package Services\n<size:10>(AiServiceProvider::boot())</size>" as UC2
    usecase "Publish Config File\n<size:10>vendor:publish --tag=ai-config</size>" as UC3
    usecase "Publish Database Migrations\n<size:10>vendor:publish --tag=ai-migrations</size>" as UC4
    usecase "Publish Stubs\n<size:10>vendor:publish --tag=ai-stubs</size>" as UC5
    usecase "Configure AI Providers\n<size:10>Edit config/ai.php + .env vars</size>" as UC6
    usecase "Select AI Provider\n<size:10>Set driver in providers array</size>" as UC7
    usecase "Generate Boilerplate via Artisan\n<size:10>make:agent | make:tool | make:agent-middleware</size>" as UC8
    usecase "Resolve Provider via Facade\n<size:10>Ai::textProvider() / Ai::embeddingProvider()</size>" as UC9

}

' --- Laravel Application triggers ---
laravelApp --> UC1 : auto-discovery\n(app bootstrap)
laravelApp --> UC2 : app boot phase

' --- Developer triggers ---
dev --> UC3
dev --> UC4
dev --> UC5
dev --> UC6
dev --> UC7
dev --> UC8
dev --> UC9

' --- Artisan CLI participates in publish & make commands ---
artisan --> UC3
artisan --> UC4
artisan --> UC5
artisan --> UC8

' --- Include / dependency relationships ---
UC3 ..> UC6 : <<include>>\npublish config first
UC4 ..> UC1 : <<include>>\nmigrations need\nregistered store
UC7 ..> UC6 : <<include>>\nconfigure before select
UC9 ..> UC1 : <<include>>\nrequires IoC binding
UC9 ..> UC7 : <<include>>\nrequires provider config

' --- Register always precedes Boot ---
UC1 <.. UC2 : <<extend>>\nregister precedes boot

note right of UC1
  Binds AiManager as scoped singleton
  Binds ConversationStore →
  DatabaseConversationStore
  Merges config/ai.php under key 'ai'
end note

note right of UC7
  Supported drivers:
  anthropic · azure · cohere · deepseek
  eleven · gemini · groq · jina · mistral
  ollama · openai · openrouter · voyageai · xai
end note

note bottom of UC2
  Registers: MakeAgentCommand,
  MakeToolCommand, MakeAgentMiddlewareCommand
  Registers publishable resources
  Registers Stringable::toEmbeddings() macro
  Registers Collection::rerank() macro
end note

@enduml
