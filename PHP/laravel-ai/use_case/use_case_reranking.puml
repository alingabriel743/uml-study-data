@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}

title Reranking

left to right direction

actor "Developer" as developer
actor "Cohere API\n(api.cohere.com/v2)" as cohereApi
actor "VoyageAI API" as voyageApi
actor "Jina API\n(api.jina.ai/v1)" as jinaApi

rectangle "Reranking System" {

    usecase "Rerank Documents" as UC1
    note right of UC1
      Reranking::of(documents)
      → PendingReranking
      → RerankingResponse
    end note

    usecase "Limit Reranking Results" as UC5
    usecase "Failover to Next Provider" as UC7

    usecase "Rerank with Cohere\n(default model: rerank-v3.5)" as UC2
    usecase "Rerank with VoyageAI" as UC3
    usecase "Rerank with Jina" as UC4

    usecase "Fake Reranking\n(Testing)" as UC6
    note bottom of UC6
      Reranking::fake()
      → FakeRerankingGateway
      assertReranked / assertNotReranked
      / assertNothingReranked
    end note
}

' Primary actor relationships
developer --> UC1
developer --> UC6

' Include relationships within UC1
UC1 ..> UC5 : <<include>>
UC1 ..> UC7 : <<include>>

' Provider-specific use cases extend UC1
UC1 <.. UC2 : <<extend>>
UC1 <.. UC3 : <<extend>>
UC1 <.. UC4 : <<extend>>

' External API relationships
UC2 --> cohereApi
UC3 --> voyageApi
UC4 --> jinaApi

@enduml
