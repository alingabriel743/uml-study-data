@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam ArrowColor #495057
skinparam ArrowFontColor #6C757D
skinparam ArrowFontSize 10

title Streaming Responses

left to right direction

' ── Actors ──────────────────────────────────────────────────────
actor "Developer" as Developer
actor "AI Provider" as AIProvider #D4EDDA
actor "Browser /\nSSE Client" as BrowserClient #D1ECF1
actor "WebSocket\nChannel" as WSChannel #D1ECF1
actor "Queue Worker" as QueueWorker #FFF3CD

' ── System Boundary ─────────────────────────────────────────────
rectangle "Streaming Responses" {

    ' ── Core Streaming ─────────────────────────────────────────
    package "Core Streaming" {
        usecase "Stream Agent Response\n<size:10>Agent::stream(prompt, ...)\n→ StreamableAgentResponse</size>" as UC1
        usecase "Iterate Stream Events\n<size:10>StreamableAgentResponse::getIterator()\nforeach(\$response as \$event)</size>" as UC2
    }

    ' ── Event Consumption ──────────────────────────────────────
    package "Event Consumption" {
        usecase "Consume Text\nDelta Chunks\n<size:10>TextDelta events\ndelta, messageId</size>" as UC3
        usecase "Handle Tool\nCall Events\n<size:10>ToolCall events\nname, arguments</size>" as UC4
        usecase "Handle Tool\nResult Events\n<size:10>ToolResult events\nresult, successful</size>" as UC5
        usecase "Receive Stream\nFinish Event\n<size:10>StreamEnd event\nreason, usage</size>" as UC6
        usecase "Receive Reasoning\nEvents\n<size:10>ReasoningStart /\nDelta / End</size>" as UC13
        usecase "Register Post-Stream\nCallback\n<size:10>StreamableAgentResponse\n::then(callable)</size>" as UC7
    }

    ' ── HTTP Delivery ──────────────────────────────────────────
    package "HTTP Delivery" {
        usecase "Return SSE\nHTTP Response\n<size:10>toResponse(\$request)\ntext/event-stream</size>" as UC8
        usecase "Stream via Vercel\nAI SDK Protocol\n<size:10>usingVercelDataProtocol()\n→ toResponse()</size>" as UC9
    }

    ' ── Broadcast Delivery ─────────────────────────────────────
    package "Broadcast Delivery" {
        usecase "Broadcast Stream\nEvents (Sync)\n<size:10>Agent::broadcastNow()\nStreamEvent::broadcastNow()</size>" as UC10
        usecase "Broadcast Stream\nEvents (Queued)\n<size:10>Agent::broadcastOnQueue()\n→ BroadcastAgent job</size>" as UC11
    }

    ' ── Conversation Tracking ──────────────────────────────────
    package "Conversation Tracking" {
        usecase "Associate Stream\nwith Conversation\n<size:10>withinConversation(\nconversationId, user?)</size>" as UC12
    }

}

' ── Developer interactions ───────────────────────────────────────
Developer --> UC1
Developer --> UC8
Developer --> UC10
Developer --> UC11
Developer --> UC12

' ── AI Provider provides the raw token stream ───────────────────
AIProvider --> UC1

' ── Browser / SSE Client receives HTTP streams ──────────────────
UC8 --> BrowserClient
UC9 --> BrowserClient

' ── WebSocket Channel receives broadcast events ─────────────────
UC10 --> WSChannel
UC11 --> WSChannel

' ── Queue Worker executes the queued broadcast job ──────────────
QueueWorker --> UC11

' ── Include / Extend relationships ──────────────────────────────

' Iterating events is mandatory to consume a stream
UC1 ..> UC2 : <<include>>

' Event types consumed during iteration
UC2 ..> UC3  : <<include>>
UC2 ..> UC4  : <<include>>
UC2 ..> UC5  : <<include>>
UC2 ..> UC6  : <<include>>
UC2 ..> UC13 : <<include>>

' Optional callback after full iteration
UC7 ..> UC2 : <<extend>>

' HTTP response delivery extends the base stream
UC8 ..> UC1 : <<extend>>

' Vercel protocol is a specialisation of SSE delivery
UC9 ..> UC8 : <<extend>>

' Broadcast extends the iteration behavior
UC10 ..> UC2 : <<extend>>

' Queued broadcast extends synchronous broadcast
UC11 ..> UC10 : <<extend>>

' Conversation association extends base stream setup
UC12 ..> UC1 : <<extend>>

@enduml
