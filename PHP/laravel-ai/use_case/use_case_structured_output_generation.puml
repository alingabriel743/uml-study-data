@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #1A1A2E
    FontSize 13
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    FontSize 12
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343A40
    FontSize 13
    FontStyle bold
}

left to right direction

title Structured Output Generation

' ── Actors ──────────────────────────────────────────────
actor "Developer" as developer
actor "Agent\n(HasStructuredOutput)" as agent
actor "AI Gateway / Provider" as gateway

' ── System boundary ─────────────────────────────────────
rectangle "Structured Output Generation" {

    usecase "Define Object Schema\n<size:10>(ObjectSchema / Schema)</size>" as UC1
    usecase "Implement HasStructuredOutput\non Agent\n<size:10>(StructuredAnonymousAgent)</size>" as UC2
    usecase "Prompt Agent for\nStructured Response\n<size:10>(GeneratesText::prompt)</size>" as UC3
    usecase "Enforce Schema\nin AI Request\n<size:10>(ComposesSchemaInstructions\n/ Prism native structured output)</size>" as UC4
    usecase "Receive Structured\nAgent Response\n<size:10>(StructuredAgentResponse)</size>" as UC5
    usecase "Access Structured\nText Response\n<size:10>(StructuredTextResponse)</size>" as UC6

}

' ── Actor → Use-case associations ───────────────────────
developer --> UC1
developer --> UC2
developer --> UC3
developer --> UC5
developer --> UC6

agent --> UC2
agent --> UC3

gateway --> UC4

' ── Use-case relationships ───────────────────────────────
UC2 ..> UC1  : <<include>>
UC3 ..> UC2  : <<include>>
UC3 ..> UC4  : <<include>>
UC3 ..> UC5  : <<include>>
UC5 <.. UC6  : <<extend>>

' ── Notes ────────────────────────────────────────────────
note right of UC1
  ObjectSchema enforces
  additionalProperties=false
  recursively on all nested
  object nodes and array items.
end note

note right of UC4
  Two strategies:
  1. Native: Prism gateway uses
     ObjectSchema::schemaType()
  2. Injected: ComposesSchemaInstructions
     embeds schema as system prompt
end note

note bottom of UC5
  Implements Arrayable, ArrayAccess,
  Jsonable, JsonSerializable —
  developer accesses data via
  $response['key'] or toArray()
end note

@enduml
