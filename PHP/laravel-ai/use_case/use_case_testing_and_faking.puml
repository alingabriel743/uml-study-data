@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #343A40
    FontColor #212529
    BorderThickness 2
}
skinparam packageStyle rectangle

title Testing & Faking

left to right direction

actor "Developer\n(Test Author)" as dev
actor "PHPUnit / Pest\n(Test Framework)" as phpunit

rectangle "Laravel AI — Testing & Faking" {

    package "Fake Gateways" as FG {
        usecase "Fake Text Generation\n(FakeTextGateway)" as UC1
        usecase "Fake Embedding Generation\n(FakeEmbeddingGateway)" as UC2
        usecase "Fake Audio Generation\n(FakeAudioGateway)" as UC3
        usecase "Fake Image Generation\n(FakeImageGateway)" as UC4
        usecase "Fake Transcription\n(FakeTranscriptionGateway)" as UC5
        usecase "Fake File / Store /\nReranking Operations" as UC6
    }

    package "Strict Mode Control" as SM {
        usecase "Prevent Stray Prompts\n(preventStrayPrompts)" as UC7
        usecase "Prevent Stray Embeddings\n(preventStrayEmbeddings)" as UC8
        usecase "Prevent Stray Audio/Images\n(preventStrayAudio/Images)" as UC9
    }

    package "Agent Assertions\n(InteractsWithFakeAgents)" as AA {
        usecase "Register Fake Agent\nvia fakeAgent()" as UC10
        usecase "Assert Agent\nWas Prompted" as UC11
        usecase "Assert Agent\nPrompt Was Queued" as UC12
        usecase "Assert Agent\nNever Prompted / Queued" as UC13
    }

    package "Spy & HTTP Mocking" as SH {
        usecase "Spy on Gateway Calls\n(SpyOpenAiGateway)" as UC14
        usecase "Mock HTTP Provider\nResponses\n(fakeOpenAiResponse, etc.)" as UC15
        usecase "Simulate Queued Job\nDispatch (FakePendingDispatch)" as UC16
    }

    package "Response Validation\n(tests/Expectations.php)" as RV {
        usecase "Validate Agent\nResponse Structure\n(toBeValidAgentResponse)" as UC17
        usecase "Validate Token\nUsage (toHaveUsage)" as UC18
        usecase "Validate Streaming\nEvent Types\n(toContainStreamEventTypes)" as UC19
    }

}

' Developer interactions — configuring fakes and spies
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4
dev --> UC5
dev --> UC6
dev --> UC7
dev --> UC8
dev --> UC9
dev --> UC10
dev --> UC14
dev --> UC15
dev --> UC16

' PHPUnit/Pest executes the assertions
phpunit --> UC11
phpunit --> UC12
phpunit --> UC13
phpunit --> UC17
phpunit --> UC18
phpunit --> UC19

' Strict mode extends the fake gateway use cases
UC1 <.. UC7 : <<extend>>
UC2 <.. UC8 : <<extend>>
UC3 <.. UC9 : <<extend>>
UC4 <.. UC9 : <<extend>>

' Agent assertion use cases include registering the fake first
UC11 ..> UC10 : <<include>>
UC12 ..> UC10 : <<include>>
UC13 ..> UC10 : <<include>>

@enduml
