@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}

skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Text Generation

left to right direction

actor "Developer" as developer
actor "AI Provider API\n(OpenAI / Anthropic\n/ Gemini / Groq / etc.)" as aiProvider

rectangle "Text Generation System" {

    usecase "Generate Text Completion" as UC1
    note right of UC1
      Promptable::prompt()
      → GeneratesText → TextGateway
      → AgentResponse
    end note

    usecase "Stream Text Response" as UC2
    note right of UC2
      Promptable::stream()
      → StreamsText → TextGateway
      → StreamableAgentResponse
    end note

    usecase "Queue Text Generation" as UC3
    note right of UC3
      Promptable::queue()
      → InvokeAgent job
      → QueuedAgentResponse
    end note

    usecase "Broadcast Streamed Response" as UC4

    usecase "Select Provider and Model" as UC5
    note right of UC5
      AiManager::textProvider()
      Supports: openai, anthropic,
      gemini, groq, mistral, ollama,
      deepseek, xai, openrouter, azure
    end note

    usecase "Receive Structured Output" as UC7
    note right of UC7
      Agent implements HasStructuredOutput
      → JSON schema → StructuredAgentResponse
    end note

    usecase "Invoke Tools During Generation" as UC8

    usecase "Override Gateway\n(Testing / Fake)" as UC6

}

' Developer → Use Case associations
developer --> UC1
developer --> UC2
developer --> UC3
developer --> UC4
developer --> UC5
developer --> UC6
developer --> UC7

' AI Provider API → Use Case associations
aiProvider --> UC8

' Include relationships
UC1 .down.> UC5 : <<include>>
UC2 .down.> UC5 : <<include>>
UC3 .down.> UC5 : <<include>>
UC4 .down.> UC2 : <<include>>

' Extend relationships
UC7 .right.> UC1 : <<extend>>
UC8 .up.> UC1 : <<extend>>
UC8 .up.> UC2 : <<extend>>

' AI Provider API participates in generation calls
UC1 --> aiProvider
UC2 --> aiProvider

@enduml
