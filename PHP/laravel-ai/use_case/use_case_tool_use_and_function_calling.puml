@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Tool Use & Function Calling

left to right direction

actor "Developer" as dev
actor "Agent" as agent
actor "AI Provider" as provider <<external>>
actor "Gateway" as gateway

rectangle "Tool Use & Function Calling" {

    package "Tool Authoring" {
        usecase "Scaffold a new Tool class\n(make:tool Artisan command)" as UC1
        usecase "Implement Tool contract\n(description / schema / handle)" as UC2
        usecase "Register Tools on an Agent\n(HasTools::tools())" as UC3
        usecase "Use a Provider-Native Tool\n(WebSearch, WebFetch, FileSearch)" as UC4
    }

    package "Agent Invocation" {
        usecase "Invoke Agent Prompt\nwith Tools" as UC6
        usecase "Perform Similarity Search\n(SimilaritySearch built-in tool)" as UC9
    }

    package "Gateway Processing" {
        usecase "Map Tools to\nProvider API Format\n(MapsTools)" as UC5
        usecase "Execute Tool on\nProvider Request\n(InvokesTools)" as UC7
        usecase "Feed Tool Result\nBack to Provider\n(tool_result message)" as UC10
    }

    package "Observability" {
        usecase "Observe Tool\nInvocation Events\n(InvokingTool / ToolInvoked)" as UC8
    }
}

' Developer relationships
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4
dev --> UC8

' Agent relationships
agent --> UC6
agent --> UC9

' Gateway relationships
gateway --> UC5
gateway --> UC7
gateway --> UC10

' AI Provider relationships
provider --> UC7 : requests tool call
provider --> UC10 : receives tool result

' Include / Extend relationships
UC6 ..> UC5 : <<include>>
UC6 ..> UC7 : <<include>>
UC7 ..> UC10 : <<include>>
UC3 ..> UC6 : <<include>>
UC4 ..> UC5 : <<extend>>
UC9 ..> UC7 : <<extend>>
UC8 ..> UC7 : <<extend>>

@enduml
