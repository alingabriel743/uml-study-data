@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
}
skinparam swimlane {
    BackgroundColor #F0F4F8
    BorderColor #6C757D
    TitleBackgroundColor #DEE2E6
    TitleFontColor #212529
}

title Long-Term Memory Update Flow

|Agent (LLM)|
start
:Determine current task contains\nimportant long-term information;
:Call **do_start_long_term_update**(args, response);

|Memory System|
:get_global_memory()\nRead memory/global_mem_insight.txt\n+ assets/insight_fixed_structure.txt\n→ build formatted memory snapshot;
:file_read(memory/memory_management_sop.md\nshow_linenos=False)\n→ read memory update SOP;

if (memory_management_sop.md exists?) then (yes)
  :Return StepOutcome:\n  SOP content\n  + memory_update_instructions\n    injected as next_prompt;
else (no)
  #FFD7D7:Return "Memory Management SOP not found.\nDo not update memory.";
  |Agent (LLM)|
  stop
endif

|Agent (LLM)|
:Receive global memory snapshot\n+ SOP instructions from StepOutcome;
:Begin classification pass\non extracted information;

if (Information category?) then (L2 – Environment facts\npaths / credentials / config)
  :Set target file:\n**memory/global_mem_insight.txt**;
else (L3 – Complex task experience\npitfalls / prerequisites / key steps)
  :Set target file:\n**memory/<task_sop>.md**;
endif

:Call **do_file_read**(path = target_file);

|Memory System|
:file_read(path, start, keyword, count, show_linenos)\nlog_memory_access(path)\n→ append to file_access_stats.json;
:Return current file content to agent;

|Agent (LLM)|
if (Content is genuinely new\n(not already stored)?) then (no – already known)
  #FFFDE7:No new value –\nskip memory update;
  stop
else (yes – new information found)
endif

:Call **do_file_patch**(\n  path        = target_file,\n  old_content = existing_block,\n  new_content = updated_block);

|Memory System|
:expand_file_refs(new_content)\nResolve any {{file:...}} references\nin new_content;
:file_patch(path, old_content, new_content)\nLocate unique old_content block in file\nand replace with new_content in-place;

if (Patch outcome?) then (success – count = 1)
  #C8E6C9:File updated with\nminimal local change\n(no full overwrite);
elseif (not found – count = 0) then
  #FFD7D7:Error: old_content block\nnot found in file;
  |Agent (LLM)|
  :Re-read target file\nvia do_file_read;
  :Retry do_file_patch\nwith corrected old_content block;
  detach
else (ambiguous – count > 1)
  #FFD7D7:Error: ambiguous match\n(multiple occurrences);
  |Agent (LLM)|
  :Retry do_file_patch with\nlonger / more specific\nold_content block;
  detach
endif

|Agent (LLM)|
if (Update working checkpoint?) then (yes – optional)
  :Call **do_update_working_checkpoint**\n(key_info, related_sop);
  |Memory System|
  :Update self.working['key_info']\nself.working['related_sop']\nReset passed_sessions = 0;
  |Agent (LLM)|
else (skip)
endif

#C8E6C9:Memory update complete;
stop

@enduml
