@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
    BarColor #495057
}

skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}

title Reflect / Autonomous Mode Loop

|Reflect Orchestrator\n(agentmain.py)|
start

:Parse **args.reflect** — script file path;

:importlib.util.spec_from_file_location('reflect_script', path)\nmodule_from_spec(spec)\n**spec.loader.exec_module(mod)** — initial load;

:Record **_mt** = os.path.getmtime(script)\nPrint "[Reflect] loaded {script}";

repeat

  if (os.path.getmtime(script) != _mt ?) then (mtime changed)
    :spec.loader.exec_module(mod) — **hot-reload**\nUpdate **_mt**\nPrint "[Reflect] reloaded";
  else (no change)
  endif

  note right
    Reload error →
    print "[Reflect] reload error: {e}"
    (skipped, continue)
  end note

  :time.sleep(**mod.INTERVAL**)
  //default 5s; autonomous.py = 1800s (30 min)//;

|Reflect Script Module\n(mod)|

  :task = **mod.check()**
  //autonomous.py: always returns '[AUTO]' prompt//;

|Reflect Orchestrator\n(agentmain.py)|

  if (check() raised exception?) then (yes)
    :Print "[Reflect] check() error: {e}";
    note right: continue loop
  elseif (task is None?) then (yes)
    note right: continue loop
  else (task returned)
    :Print "[Reflect] triggered: {task[:80]}";

|Agent Thread\n(GeneraticAgent + LLM)|

    :dq = agent.**put_task**(task, source='reflect')
    Enqueue {query, source='reflect', output: Queue}
    Returns **display_queue**;

    repeat
      :dq.get(timeout=120)
      Wait for next LLM chunk or done item;
    repeat while ('done' not in item?) is (next chunk)
    ->done item received;

|Reflect Orchestrator\n(agentmain.py)|

    if (drain raised timeout / error?) then (yes)
      :result = '[ERROR] {e}'\nPrint "[Reflect] drain error: {e}";
      if (mod.ONCE == True?) then (yes)
        :Re-raise exception;
        stop
      else (no)
        note right: log error, continue loop
      endif
    else (success)
      :result = item['done'] — full LLM response text\nPrint result;

|Logging\n(temp/reflect_logs/)|

      :os.makedirs('temp/reflect_logs', exist_ok=True)\nAppend to **{script}_{YYYY-MM-DD}.log**\n"[MM-DD HH:MM]\n{result}\n";

|Reflect Script Module\n(mod)|

      if (getattr(mod, 'on_done', None) exists?) then (yes)
        :mod.**on_done**(result)
        //autonomous.py: NOT defined//;
      else (no)
      endif

      note right
        on_done error →
        print "[Reflect] on_done error: {e}"
      end note

|Reflect Orchestrator\n(agentmain.py)|

      if (mod.ONCE == True?) then (yes)
        :Print "[Reflect] ONCE=True, exiting.";
        break
      else (no — loop forever)
      endif
    endif
  endif

repeat while (while True) is (continue)

stop

@enduml
