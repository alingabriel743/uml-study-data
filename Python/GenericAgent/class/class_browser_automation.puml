@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Browser Automation (TMWebDriver)

' ─── External / framework classes ───────────────────────────────────────────

package "simple_websocket_server" {
    abstract class WebSocket {
        +send_message(msg): None
    }
    class WebSocketServer {
        +__init__(host, port, handler_class)
    }
}

package "wsgiref / socketserver" {
    class ThreadingMixIn
    class WSGIServer
    class WSGIRequestHandler {
        +log_request(*args): None
    }
}

' ─── TMWebDriver module ──────────────────────────────────────────────────────

package "TMWebDriver.py" {

    class Session {
        +id: str
        +info: dict
        +connect_at: float
        +disconnect_at: float | None
        +type: str
        +ws_client: WebSocket | None
        +http_queue: Queue | None
        --
        +url: str  <<property>>
        --
        +__init__(session_id, info, client=None)
        +is_active(): bool
        +reconnect(client, info): None
        +mark_disconnected(): None
    }

    class TMWebDriver {
        +host: str
        +port: int
        +sessions: Dict[str, Session]
        +results: Dict[str, dict]
        +acks: Dict[str, bool]
        +default_session_id: str | None
        +latest_session_id: str | None
        +is_remote: bool
        +remote: str
        +server: WebSocketServer
        +app: Bottle
        --
        +__init__(host='127.0.0.1', port=18765)
        +start_ws_server(): None
        +start_http_server(): None
        +clean_sessions(): None
        +_register_client(session_id, client, session_info): None
        +_unregister_client(client: WebSocket): None
        +execute_js(code, timeout=15, session_id=None): Any
        +_remote_cmd(cmd: dict): dict
        +get_all_sessions(): list
        +get_session_dict(): dict
        +find_session(url_pattern: str): list
        +set_session(url_pattern: str): str | None
        +jump(url, timeout=10): Any
        +newtab(url=None): Any
    }

    class JSExecutor {
        {field} <<inner class — created by start_ws_server()>>
        --
        +handle(): None
        +connected(): None
        +handle_close(): None
    }

    class _T {
        {field} <<inner class — threaded WSGI server>>
    }

    class _H {
        {field} <<inner class — silent request handler>>
        --
        +log_request(*a): None
    }

}

' ─── Inheritance ─────────────────────────────────────────────────────────────

JSExecutor  --|>  WebSocket
_T          --|>  ThreadingMixIn
_T          --|>  WSGIServer
_H          --|>  WSGIRequestHandler

' ─── Composition / Aggregation ───────────────────────────────────────────────

TMWebDriver "1" *-- "1..*" Session        : manages >
TMWebDriver  *--  WebSocketServer          : creates / owns >
TMWebDriver  *--  JSExecutor               : defines as handler >

' ─── Associations ────────────────────────────────────────────────────────────

Session     o--  WebSocket                 : ws_client
Session     o--  "queue.Queue"             : http_queue

TMWebDriver ..>  _T                        : <<instantiates>>
TMWebDriver ..>  _H                        : <<instantiates>>

JSExecutor  ..>  TMWebDriver               : <<calls _register_client\n_unregister_client\nwrites results/acks>>

' ─── HTTP Routes note ────────────────────────────────────────────────────────

note bottom of TMWebDriver
  HTTP Gateway routes (Bottle):
  POST /api/longpoll  — browser long-poll; blocks ≤5s for command
  POST /api/result    — browser posts JS execution result / error
  POST /link          — remote control proxy (execute_js, sessions)
  --
  Dual-mode: local (WS + HTTP servers) or remote proxy (is_remote flag)
  Session transport types: 'ws', 'ext_ws', 'http'
end note

@enduml
