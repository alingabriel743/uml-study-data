@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Chat Frontend Base & Common Infrastructure

package "frontends" {

    package "chatapp_common.py" {

        abstract class AgentChatMixin {
            +{static} label: str = "Chat"
            +{static} source: str = "chat"
            +{static} split_limit: int = 1500
            +{static} ping_interval: int = 20
            --
            -agent: Agent
            -user_tasks: dict
            --
            +__init__(agent, user_tasks): None
            +{abstract} send_text(chat_id, content, **ctx): None
            +send_done(chat_id, raw_text, **ctx): None
            +handle_command(chat_id, cmd, **ctx): None
            +run_agent(chat_id, text, **ctx): None
        }

        note right of AgentChatMixin
            <b>Command dispatch:</b>
            /stop  → agent.abort()
            /status → report llm & running state
            /llm [n] → switch/list LLMs
            /restore → reload history from logs
            /new → clear history
            default → send HELP_TEXT
            ----
            <b>run_agent flow:</b>
            1. Mark state running=True
            2. Send "thinking..." message
            3. Enqueue via agent.put_task()
            4. Poll dequeue with 3s timeout
            5. Ping every ping_interval seconds
            6. On done: call send_done()
        end note

        class "TextProcessingUtils" as TextUtils <<utility>> {
            +{static} clean_reply(text): str
            +{static} extract_files(text): list[str]
            +{static} strip_files(text): str
            +{static} split_text(text, limit): list[str]
            +{static} build_done_text(raw_text): str
        }

        class "RestoreHistoryUtils" as RestoreUtils <<utility>> {
            +{static} format_restore(): tuple[info, err]
            -{static} _restore_log_files(): list[str]
            -{static} _restore_text_pairs(content): list[str]
            -{static} _restore_native_history(content): list[str]
            -{static} _native_prompt_obj(prompt_body): dict
            -{static} _native_prompt_text(prompt): str
            -{static} _native_history_lines(prompt_text): list[str]
            -{static} _native_first_user_line(prompt_text): str
            -{static} _native_response_summary(response_body): str
        }

        class "AccessControlUtils" as AccessUtils <<utility>> {
            +{static} public_access(allowed): bool
            +{static} to_allowed_set(value): set
            +{static} allowed_label(allowed): str | list
        }

        class "RuntimeHelpers" as RuntimeUtils <<utility>> {
            +{static} ensure_single_instance(port, label): socket
            +{static} require_runtime(agent, label, **required): None
            +{static} redirect_log(script_file, log_name, label, allowed): None
        }
    }

    package "qqapp.py" {
        class QQApp {
            +{static} label: str = "QQ"
            +{static} source: str = "qq"
            +{static} split_limit: int = 1500
            --
            +send_text(chat_id, content, msg_id, is_group): None
            +on_message(data, is_group): None
        }
    }

    package "wecomapp.py" {
        class WeComApp {
            +{static} label: str = "WeCom"
            +{static} source: str = "wecom"
            +{static} split_limit: int = 1200
            --
            +send_text(chat_id, content): None
            +on_message(...): None
        }
    }

    package "dingtalkapp.py" {
        class DingTalkApp {
            +{static} label: str = "DingTalk"
            +{static} source: str = "dingtalk"
            +{static} split_limit: int = 1800
            --
            +send_text(chat_id, content): None
            +on_message(content, sender_id, sender_name, conversation_type, conversation_id): None
        }
    }
}

class Agent <<external>> {
    +history: list
    +is_running: bool
    +llm_no: int
    +llmclient: object
    --
    +put_task(text, source): Queue
    +abort(): None
    +get_llm_name(): str
    +next_llm(n): None
    +list_llms(): list
}

' Inheritance
QQApp --|> AgentChatMixin
WeComApp --|> AgentChatMixin
DingTalkApp --|> AgentChatMixin

' Composition
AgentChatMixin *--> Agent : agent

' Usage dependencies
AgentChatMixin ..> TextUtils : uses
AgentChatMixin ..> RestoreUtils : uses (handle_command /restore)
AgentChatMixin ..> AccessUtils : uses
RuntimeUtils ..> Agent : validates

@enduml
