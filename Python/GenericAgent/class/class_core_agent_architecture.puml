@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Core Agent Architecture

' ─────────────────────────────────────────
'  agentmain.py
' ─────────────────────────────────────────
package "agentmain.py" {

    class GeneraticAgent {
        -llmclients : list[ToolClient|NativeToolClient]
        -llmclient  : ToolClient|NativeToolClient
        -lock       : threading.Lock
        -task_dir   : Optional[str]
        -history    : list[str]
        -task_queue : queue.Queue
        -is_running : bool
        -stop_sig   : bool
        -llm_no     : int
        -inc_out    : bool
        -handler    : Optional[GenericAgentHandler]
        -verbose    : bool
        --
        +__init__() : None
        +next_llm(n=-1) : None
        +list_llms() : list[tuple]
        +get_llm_name() : str
        +abort() : None
        +put_task(query, source, images) : queue.Queue
        +_handle_slash_cmd(raw_query, display_queue) : Optional[str]
        +run() : None
    }

    class load_tool_schema <<function>> {
        +load_tool_schema(suffix='') : None
    }

    class get_system_prompt <<function>> {
        +get_system_prompt() : str
    }
}

' ─────────────────────────────────────────
'  agent_loop.py
' ─────────────────────────────────────────
package "agent_loop.py" {

    class BaseHandler {
        -_done_hooks   : list
        +max_turns     : int
        +current_turn  : int
        --
        +tool_before_callback(tool_name, args, response) : None
        +tool_after_callback(tool_name, args, response, ret) : None
        +turn_end_callback(response, tool_calls, tool_results,\n  turn, next_prompt, exit_reason) : str
        +dispatch(tool_name, args, response, index=0) : Generator[str, None, StepOutcome]
    }

    class StepOutcome <<dataclass>> {
        +data          : Any
        +next_prompt   : Optional[str]
        +should_exit   : bool
    }

    class agent_runner_loop <<function>> {
        +agent_runner_loop(client, system_prompt, user_input,\n  handler, tools_schema, max_turns=40,\n  verbose=True, initial_user_content=None) : Generator
    }

    class try_call_generator <<function>> {
        +try_call_generator(func, *args, **kwargs) : Generator
    }

    class exhaust <<function>> {
        +exhaust(g) : Any
    }
}

' ─────────────────────────────────────────
'  ga.py
' ─────────────────────────────────────────
package "ga.py" {
    class GenericAgentHandler {
        +do_<tool_name>(...) : Generator[str, None, StepOutcome]
    }
}

' ─────────────────────────────────────────
'  llmcore.py
' ─────────────────────────────────────────
package "llmcore.py" {
    class ToolClient {
        +chat(messages, tools) : Response
    }
    class NativeToolClient {
        +chat(messages, tools) : Response
    }
}

' ─────────────────────────────────────────
'  Relationships
' ─────────────────────────────────────────

' Inheritance
GenericAgentHandler --|> BaseHandler : extends

' Composition / Aggregation
GeneraticAgent *-- GenericAgentHandler      : creates per task
GeneraticAgent o-- ToolClient               : llmclients[ ]
GeneraticAgent o-- NativeToolClient         : llmclients[ ]

' Dependencies (GeneraticAgent → helpers)
GeneraticAgent ..> load_tool_schema         : calls in __init__ /\nnext_llm()
GeneraticAgent ..> get_system_prompt        : calls in run()
GeneraticAgent ..> agent_runner_loop        : calls in run()

' Dependencies (agent_runner_loop → handler & utilities)
agent_runner_loop ..> BaseHandler           : dispatch() /\nturn_end_callback()
agent_runner_loop ..> try_call_generator    : uses
agent_runner_loop ..> exhaust               : uses

' BaseHandler ↔ StepOutcome
BaseHandler ..> StepOutcome                 : returns from\ndispatch()

' ─────────────────────────────────────────
'  Exit-outcome legend
' ─────────────────────────────────────────
note bottom of StepOutcome
  Loop exit conditions:
  • should_exit = True  → EXITED
  • next_prompt is None → CURRENT_TASK_DONE
  • turn >= max_turns   → MAX_TURNS_EXCEEDED
end note

note right of GeneraticAgent
  Slash-command patterns handled
  by _handle_slash_cmd():
  • /session.<attr>=<val>
  • /resume
  • other /cmd  → pass-through
end note

@enduml
