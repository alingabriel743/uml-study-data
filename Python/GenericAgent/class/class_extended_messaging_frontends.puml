@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam stereotype {
    CBackgroundColor #D0E8FF
    CBorderColor #3A7BD5
}

title Extended Messaging Frontends (WeChat, Telegram, Feishu)

' ─────────────────────────────────────────────
' WeChat Frontend
' ─────────────────────────────────────────────
package "frontends/wechatapp.py" {

    class WxBotClient {
        - _tf: Path
        - token: str
        - bot_id: str
        - _buf: str
        --
        + __init__(token, token_file)
        + login_qr(poll_interval): dict
        + get_updates(timeout): list
        + send_text(to_user_id, text, context_token): dict
        + send_typing(to_user_id, typing_ticket, cancel): dict
        + send_file(to_user_id, file_path, context_token): dict
        + {static} extract_text(msg): str
        + {static} is_user_msg(msg): bool
        + run_loop(on_message, poll_timeout)
        - _load()
        - _save(**kw)
        - _post(ep, body, timeout): dict
    }

    class WeChatApp <<module>> {
        ~ agent: GeneraticAgent
        ~ bot: WxBotClient
        --
        + on_message(bot, msg)
        - _dl_media(items): list
        - _clean(t): str
        - _strip_md(t): str
        - _split(text, limit): list[str]
    }

    note bottom of WxBotClient
        Polls ilinkai.weixin.qq.com API.
        AES-ECB encryption for CDN media.
        Supports image / video / file / voice.
    end note
}

' ─────────────────────────────────────────────
' Telegram Frontend
' ─────────────────────────────────────────────
package "frontends/tgapp.py" {

    class TelegramHandler <<module>> {
        ~ agent: GeneraticAgent
        ~ ALLOWED: set
        --
        + handle_msg(update, ctx) <<async>>
        + cmd_abort(update, ctx) <<async>>
        + cmd_llm(update, ctx) <<async>>
        - _stream(dq, msg) <<async>>
        - _clean(t): str
        - _to_html(t): str
        - _inline_md(s): str
        - _error_handler(update, context) <<async>>
    }

    note bottom of TelegramHandler
        Uses python-telegram-bot:
        ApplicationBuilder + HTTPXRequest(proxy).
        Live message editing via asyncio streaming.
        Supports photo / document attachments.
    end note
}

' ─────────────────────────────────────────────
' Feishu / Lark Frontend
' ─────────────────────────────────────────────
package "frontends/fsapp.py" {

    class FeishuClient <<module>> {
        ~ agent: GeneraticAgent
        ~ client: lark.Client
        ~ user_tasks: dict
        ~ APP_ID: str
        ~ APP_SECRET: str
        ~ ALLOWED_USERS: set
        ~ PUBLIC_ACCESS: bool
        --
        + create_client(): lark.Client
        + send_message(receive_id, content, msg_type, use_card): str
        + update_message(message_id, content): bool
        + handle_message(data)
        + handle_command(open_id, cmd, chat_id)
        + main()
        - _build_user_message(message): tuple
        - _send_generated_files(receive_id, raw_text)
        - _send_local_file(receive_id, file_path): bool
        - _upload_image_sync(file_path): str
        - _upload_file_sync(file_path): str
        - _download_image_sync(message_id, image_key): tuple
        - _download_file_sync(message_id, file_key): tuple
        - _extract_post_content(content_json): tuple
        - _extract_interactive_content(content): list
        - _clean(text): str
        - _card(text): str
    }

    note bottom of FeishuClient
        Uses lark_oapi WebSocket long-polling.
        Supports DM (open_id) & group chat (chat_id).
        Commands: /stop /new /status /restore /llm /help.
        Media: image / audio / file / media / post / interactive.
    end note
}

' ─────────────────────────────────────────────
' Shared Core
' ─────────────────────────────────────────────
class GeneraticAgent <<agentmain>> {
    + llm_no: int
    + is_running: bool
    + history: list
    --
    + put_task(query, source, images): Queue
    + abort()
    + run()
    + next_llm(n)
    + list_llms(): list
    + get_llm_name(): str
}

' ─────────────────────────────────────────────
' External Libraries
' ─────────────────────────────────────────────
class "lark.Client" <<external>> {
    + APP_ID: str
    + APP_SECRET: str
}

class "lark.ws.Client" <<external>> {
    + start()
}

class "ApplicationBuilder" <<python-telegram-bot>> {
    + token(token): ApplicationBuilder
    + request(request): ApplicationBuilder
    + build(): Application
}

class "chatapp_common" <<module>> {
    + format_restore(): str
}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' WeChat composition & dependency
WeChatApp *-- WxBotClient : creates / owns
WeChatApp ..> GeneraticAgent : put_task() / abort()

' Telegram dependencies
TelegramHandler ..> GeneraticAgent : put_task() / abort()
TelegramHandler ..> "ApplicationBuilder" : builds bot

' Feishu dependencies
FeishuClient ..> GeneraticAgent : put_task() / abort()
FeishuClient *-- "lark.Client" : creates
FeishuClient ..> "lark.ws.Client" : starts WebSocket listener
FeishuClient ..> "chatapp_common" : format_restore()

@enduml
