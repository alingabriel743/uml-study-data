@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9E6
    BorderColor #C9A000
}

title Memory & Key/Credential Management

' ─────────────────────────────────────────────────────────
' Package: memory/keychain.py  (System 1 — XOR-obfuscated)
' ─────────────────────────────────────────────────────────
package "memory/keychain.py" {

    class SecretStr {
        -_name: str
        -_val: str
        --
        +__init__(name: str, val: str)
        +use(): str
        +__repr__(): str
        +__str__(): str
    }

    class _Keys {
        -_d: dict
        --
        +__init__()
        +__getattr__(k: str): SecretStr
        +set(k: str, v: str = None, *, file: str = None)
        +ls(): list
    }

    class "«module»\nkeychain" as keychain_module {
        {field} _PATH: Path = ~/ga_keychain.enc
        {field} _MASK: bytes  <<SHA-256 user mask>>
        {field} keys: _Keys  <<singleton>>
        --
        ~_xor(data: bytes): bytes
        ~__getattr__(name: str): SecretStr
    }

}

' ─────────────────────────────────────────────────────────
' mykey_template.py / mykey.py  (System 2 — plaintext)
' ─────────────────────────────────────────────────────────
package "mykey_template.py → mykey.py" {

    class "«config module»\nmykey" as mykey_module {
        {field} mixin_config: dict
        {field} native_claude_config0: dict
        {field} native_claude_config1: dict
        {field} native_oai_config: dict
        {field} proxy: str
    }

    class "«config dict»\nSessionConfig" as SessionConfig {
        {field} name: str
        {field} apikey: str
        {field} apibase: str
        {field} model: str
        {field} fake_cc_system_prompt: bool
        {field} thinking_type: str
        {field} thinking_budget_tokens: int
        {field} reasoning_effort: str
        {field} temperature: float
        {field} max_tokens: int
        {field} context_win: int
        {field} max_retries: int
        {field} connect_timeout: int
        {field} read_timeout: int
        {field} stream: bool
        {field} api_mode: str
    }

}

' ─────────────────────────────────────────────────────────
' llmcore.py  (bridge layer)
' ─────────────────────────────────────────────────────────
package "llmcore.py" {

    class "«module»\nllmcore" as llmcore_module {
        {field} mykeys: dict  <<lazy-loaded>>
        {field} proxies: dict  <<lazy-loaded>>
        --
        ~_load_mykeys(): dict
        ~__getattr__(name: str): Any
    }

}

' ─────────────────────────────────────────────────────────
' Consumer stubs (external)
' ─────────────────────────────────────────────────────────
class "«entrypoint»\nagentmain" as agentmain {
    +instantiate_sessions()
}

class "«frontend»\nApp Frontends" as app_frontends {
    {field} tgapp / qqapp / fsapp\nwecomapp / dingtalkapp
}

' ─────────────────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────────────────

' Internal keychain composition
_Keys *-- SecretStr : wraps raw string >
keychain_module *-- _Keys : singleton keys >
keychain_module ..> SecretStr : __getattr__ returns

' mykey config dict ownership
mykey_module *-- SessionConfig : contains config dicts >

' llmcore loads mykey
llmcore_module ..> mykey_module : imports via _load_mykeys()
llmcore_module ..> SessionConfig : reads apikey / model / proxy

' Consumers depend on llmcore
agentmain ..> llmcore_module : reads mykeys\nselects session class
app_frontends ..> llmcore_module : reads bot tokens\napp secrets

' agentmain may also use keychain directly (optional)
agentmain ..> keychain_module : optional keys.name.use()

' ─────────────────────────────────────────────────────────
' Storage notes
' ─────────────────────────────────────────────────────────
note bottom of _Keys
  Persists to ~/ga_keychain.enc
  Format: JSON → XOR-obfuscated bytes
  (_MASK = SHA-256 of "{login}@ga_keychain")
  ⚠ XOR obfuscation, NOT cryptographic encryption
end note

note bottom of mykey_module
  Copied from mykey_template.py by user.
  Stored as plain Python module or mykey.json.
  ⚠ Credentials are in plaintext — file-system
  access control only.
end note

note right of SessionConfig
  Variable name in mykey.py selects session class:
  • "native" + "claude"  → NativeClaudeSession
  • "native" + "oai"     → NativeOAISession
  • "claude" (no native) → ClaudeSession (deprecated)
  • "oai"    (no native) → LLMSession (deprecated)
  • "mixin"              → MixinSession (failover)
end note

note right of SecretStr
  Masked repr — never exposes full value:
  ≤4 chars  → "***"
  ≤16 chars → first3···last3
  ≤40 chars → first6···last6 (len=N)
  else      → first10···last6 (len=N)
  Call .use() to retrieve raw secret.
end note

@enduml
