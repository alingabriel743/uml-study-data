@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9E6
    BorderColor #CCAA00
}

title Memory Scanning & UI Detection Tools

' ─────────────────────────────────────────────
' Package 1: Windows Process Memory Scanner
' ─────────────────────────────────────────────
package "memory/procmem_scanner" {

    class MEMORY_BASIC_INFORMATION <<ctypes.Structure>> {
        +BaseAddress: LPVOID
        +AllocationBase: LPVOID
        +AllocationProtect: DWORD
        +RegionSize: SIZE_T
        +State: DWORD
        +Protect: DWORD
        +Type: DWORD
    }

    class ProcMemScanner <<module>> {
        +k32: ctypes.WinDLL
        --
        +is_hex_pattern(pattern: str): bool
        +build_rules(pattern: str, mode: str): yara.Rules
        +format_llm_context(data: bytes, offset: int, base_addr: int, length: int): LLMContextDict
        +scan_memory(pid: int, pattern: str, context_size: int, mode: str, llm_mode: bool): list
    }

    class LLMContextDict <<dataclass>> {
        +address: str
        +offset: str
        +hex: str
        +ascii: str
        +hit_pos: int
    }
}

' ─────────────────────────────────────────────
' Package 2: ADB-based Android UI Interaction
' ─────────────────────────────────────────────
package "memory/adb_ui" {

    class AdbUI <<module>> {
        +ADB: str
        +LOCAL_XML: str
        --
        -_dump_u2(): str
        -_dump_native(): str
        -_parse_xml(xml_str: str, keyword: str, clickable_only: bool, raw: bool): list
        +ui(keyword: str, clickable_only: bool, raw: bool): list
        +tap(x: int, y: int): void
    }

    class UINodeDict <<dataclass>> {
        +text: str
        +click: bool
        +edit: bool
        +cx: int
        +cy: int
        +cls: str
        +rid: str
    }
}

' ─────────────────────────────────────────────
' Package 3: Image-based UI Element Detection
' ─────────────────────────────────────────────
package "memory/ui_detect" {

    class UIDetect <<module>> {
        +DEFAULT_MODEL: str
        +ocr_engine: RapidOCR
        +HAS_OCR: bool
        --
        +detect_ui_elements(image_path: str, model_path: str, conf_threshold: float): list
        +ocr_text(image_path: str): list
        +visualize(image_path: str, detections: list, ocr_results: list, output_path: str): PIL.Image
        +main(): void
    }

    class DetectionDict <<dataclass>> {
        +bbox: list
        +confidence: float
        +class: int
    }

    class OCRDict <<dataclass>> {
        +text: str
        +bbox: list
        +confidence: float
    }
}

' ─────────────────────────────────────────────
' External Dependencies
' ─────────────────────────────────────────────
class "ctypes.Structure" <<external>> {
}

class "yara.Rules" <<external>> {
    +match(data: bytes): list
}

class "kernel32" <<WinAPI>> {
    +OpenProcess()
    +VirtualQueryEx()
    +ReadProcessMemory()
    +CloseHandle()
}

class "YOLO" <<ultralytics>> {
    +__call__(image, conf, verbose): Results
}

class "RapidOCR" <<optional>> {
    +__call__(image_path): list
}

class "uiautomator2" <<optional>> {
    +connect(): Device
    +dump_hierarchy(): str
}

' ─────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────

' Inheritance
MEMORY_BASIC_INFORMATION --|> "ctypes.Structure"

' procmem_scanner internal
ProcMemScanner ..> MEMORY_BASIC_INFORMATION : instantiates (mbi)
ProcMemScanner ..> LLMContextDict : returns (llm_mode=True)
ProcMemScanner ..> "yara.Rules" : creates via build_rules
ProcMemScanner ..> kernel32 : calls WinAPI

' adb_ui internal
AdbUI ..> UINodeDict : returns node list
AdbUI ..> uiautomator2 : uses (preferred dump)

' ui_detect internal
UIDetect ..> DetectionDict : returns per element
UIDetect ..> OCRDict : returns per text region
UIDetect ..> YOLO : loads model
UIDetect ..> RapidOCR : uses (if HAS_OCR)

@enduml
