@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Messaging Platform Frontend Integrations

' ── Core Agent ──────────────────────────────────────────
package "agentmain" {
    class GeneraticAgent {
        +verbose: bool
        +llm_no: int
        +is_running: bool
        +history: list
        --
        +run()
        +abort()
        +put_task(text, source): Queue
        +get_llm_name(): str
        +next_llm(n)
        +list_llms(): list
    }
}

' ── Shared Base ─────────────────────────────────────────
package "frontends.chatapp_common" {
    abstract class AgentChatMixin {
        {static} +label: str = "Chat"
        {static} +source: str = "chat"
        {static} +split_limit: int = 1500
        {static} +ping_interval: int = 20
        --
        #agent: GeneraticAgent
        #user_tasks: dict
        --
        +__init__(agent, user_tasks)
        +{abstract} send_text(chat_id, content, **ctx)
        +send_done(chat_id, raw_text, **ctx)
        +handle_command(chat_id, cmd, **ctx)
        +run_agent(chat_id, text, **ctx)
    }
}

' ── WeCom Frontend ──────────────────────────────────────
package "frontends.wecomapp" {
    class WeComApp {
        {static} +label: str = "WeCom"
        {static} +source: str = "wecom"
        {static} +split_limit: int = 1200
        --
        -client: WSClient
        -chat_frames: dict
        --
        +__init__()
        +send_text(chat_id, content)
        +on_text(frame)
        +on_enter_chat(frame)
        +on_connected(frame)
        +on_authenticated(frame)
        +on_disconnected(frame)
        +on_error(frame)
        +start()
    }
}

' ── DingTalk Frontend ───────────────────────────────────
package "frontends.dingtalkapp" {
    class DingTalkApp {
        {static} +label: str = "DingTalk"
        {static} +source: str = "dingtalk"
        {static} +split_limit: int = 1800
        --
        -client: DingTalkStreamClient
        -access_token: str
        -token_expiry: float
        -background_tasks: set
        --
        +__init__()
        -_get_access_token()
        -_send_batch_message(chat_id, msg_key, msg_param)
        +send_text(chat_id, content)
        +on_message(content, sender_id, sender_name, ...)
        +start()
    }

    class _DingTalkHandler {
        -app: DingTalkApp
        --
        +__init__(app: DingTalkApp)
        +process(message): AckMessage
    }

    note right of _DingTalkHandler
        Adapter: bridges DingTalk SDK
        CallbackHandler.process() contract
        to DingTalkApp.on_message()
    end note
}

' ── QQ Frontend ─────────────────────────────────────────
package "frontends.qqapp" {
    class QQApp {
        {static} +label: str = "QQ"
        {static} +source: str = "qq"
        {static} +split_limit: int = 1500
        --
        -client: QQBot
        --
        +__init__()
        +send_text(chat_id, content, msg_id, is_group)
        +on_message(data, is_group)
        +start()
    }

    class QQBot <<dynamic>> {
        --
        +__init__()
        +on_ready()
        +on_c2c_message_create(message: C2CMessage)
        +on_group_at_message_create(message: GroupMessage)
        +on_direct_message_create(message)
    }

    note right of QQBot
        Dynamically created via
        _make_bot_class(app).
        Holds closure reference
        to QQApp instance.
    end note
}

' ── WeChat Frontend ─────────────────────────────────────
package "frontends.wechatapp" {
    class WxBotClient {
        -token: str
        -bot_id: str
        -_buf: str
        --
        +__init__(token, token_file)
        +login_qr(poll_interval)
        +get_updates(timeout): list
        +send_text(to_user_id, text, context_token)
        +send_typing(to_user_id, typing_ticket, cancel)
        +send_file(to_user_id, file_path, context_token)
        +run_loop(on_message, poll_timeout)
        {static} +extract_text(msg): str
        {static} +is_user_msg(msg): bool
    }

    note bottom of WxBotClient
        Function-based module:
        on_message() dispatches
        commands or calls
        agent.put_task()
    end note
}

' ── Telegram Frontend (function-based) ──────────────────
package "frontends.tgapp" {
    class "TelegramApp\n<<module>>" as TelegramApp <<module>> {
        .. module-level state ..
        +agent: GeneraticAgent
        +ALLOWED: set
        .. async handlers ..
        +handle_msg(update, ctx)
        +cmd_abort(update, ctx)
        +cmd_llm(update, ctx)
        .. streaming ..
        -_stream(dq, msg)
        -_to_html(text): str
        -_clean(text): str
    }

    note bottom of TelegramApp
        Uses python-telegram-bot SDK.
        ApplicationBuilder + polling loop.
        No AgentChatMixin — standalone.
    end note
}

' ── Feishu Frontend (function-based) ────────────────────
package "frontends.fsapp" {
    class "FeishuApp\n<<module>>" as FeishuApp <<module>> {
        .. module-level state ..
        +agent: GeneraticAgent
        +client: lark.Client
        +ALLOWED_USERS: set
        .. message handling ..
        +handle_message(data)
        +handle_command(open_id, cmd, chat_id)
        +send_message(receive_id, content, ...): str
        +update_message(message_id, content)
        +create_client(): lark.Client
    }

    note bottom of FeishuApp
        Uses lark_oapi SDK (WebSocket).
        EventDispatcherHandler routes
        P2 IM events to handle_message().
        No AgentChatMixin — standalone.
    end note
}

' ── External SDK Types ───────────────────────────────────
package "External SDKs" <<frame>> {
    class WSClient <<external>> {
        +connect_async()
        +reply_stream(chat_id, content, req_id)
        +reply_welcome(chat_id, content)
    }

    class DingTalkStreamClient <<external>> {
        +register_all_event_handler(handler)
        +start()
    }

    abstract class CallbackHandler <<external>> {
        +{abstract} process(message)
    }

    class "botpy.Client" as BotpyClient <<external>> {
        +start(appid: str, secret: str)
    }
}

' ── Inheritance ─────────────────────────────────────────
WeComApp      --|> AgentChatMixin
DingTalkApp   --|> AgentChatMixin
QQApp         --|> AgentChatMixin
_DingTalkHandler --|> CallbackHandler
QQBot         --|> BotpyClient

' ── Composition ─────────────────────────────────────────
AgentChatMixin *-down- GeneraticAgent : agent

WeComApp    *-- WSClient              : client
DingTalkApp *-- DingTalkStreamClient  : client
QQApp       *-- QQBot                 : client (factory)

' ── Dependencies ────────────────────────────────────────
DingTalkApp   ..> _DingTalkHandler : creates in start()
_DingTalkHandler --> DingTalkApp   : delegates\non_message()
QQBot         ..> QQApp            : on_message()\nvia closure

TelegramApp ..> GeneraticAgent : agent.put_task()
FeishuApp   ..> GeneraticAgent : agent.put_task()
WxBotClient <.. "frontends.wechatapp" : on_message\nuses

@enduml
