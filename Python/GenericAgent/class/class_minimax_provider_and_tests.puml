@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title MiniMax LLM Provider & Test Suite

' ─────────────────────────────────────────────
'  Production Classes  (llmcore.py)
' ─────────────────────────────────────────────
package "llmcore (Production)" {

    abstract class BaseSession {
    }

    class LLMSession {
        -api_base: str
        -api_key: str
        -model: str
        -temperature: float
        -max_tokens: int
        -max_retries: int
        -connect_timeout: float
        -read_timeout: float
        -proxies: dict
        +raw_ask(messages): generator
        +make_messages(raw_list): list
    }

    class NativeClaudeSession {
        +raw_ask(messages): generator
        +ask(msg): generator
    }

    class NativeOAISession {
        +raw_ask(messages): generator
        +ask(msg): generator
    }

    class ToolClient {
        +backend: BaseSession
        +auto_save_tokens: bool
        +last_tools: str
        +name: str
        +total_cd_tokens: int
        +chat(messages, tools=None): generator
        -_build_protocol_prompt(messages, tools): str
        -_parse_mixed_response(text): MockResponse
        -_prepare_tool_instruction(tools): str
        -_estimate_content_len(content): int
    }

    class NativeToolClient {
        +chat(messages, tools=None): generator
    }

    class MockResponse {
        +thinking: str
        +content: str
        +tool_calls: list[MockToolCall]
        +raw: str
        +stop_reason: str
    }

    class MockToolCall {
        +function: MockFunction
        +id: str
    }

    class MockFunction {
        +name: str
        +arguments: str
    }

    class "LLMCoreFunctions" as LLMCoreFunctions <<utility>> {
        +_openai_stream(api_base, api_key, messages, model,\n  temperature, max_tokens, tools, ...): generator
        +auto_make_url(base: str, path: str): str
        +compress_history_tags(messages, keep_recent,\n  max_len, force): list
    }
}

note right of LLMCoreFunctions
  **MiniMax temperature clamping** (in _openai_stream):
  if 'minimax' in model.lower():
      temperature = max(0.01, min(temperature, 1.0))
  Kimi/Moonshot: temperature hard-forced to 1.0
  ——
  **compress_history_tags**: truncates <think>/<thinking>
  blocks in old messages; runs every 5 calls via _cd counter
end note

' ─────────────────────────────────────────────
'  Unit Tests  (tests/test_minimax.py)
' ─────────────────────────────────────────────
package "tests/test_minimax.py (Unit Tests)" {

    class TestMiniMaxTemperatureClamping {
        -_make_stream_call(model, temperature): dict
        +test_minimax_temp_zero_clamped()
        +test_minimax_temp_negative_clamped()
        +test_minimax_temp_normal_preserved()
        +test_minimax_temp_one_preserved()
        +test_minimax_temp_above_one_clamped()
        +test_minimax_case_insensitive()
        +test_non_minimax_temp_zero_unchanged()
        +test_kimi_temp_still_forced()
    }

    class TestMiniMaxThinkTagHandling {
        +test_think_tag_stripped_from_response()
        +test_thinking_tag_still_works()
        +test_think_tag_with_tool_use()
    }

    class TestMiniMaxCompressHistoryTags {
        +test_think_tag_compressed_in_old_messages()
    }

    class TestMiniMaxAutoMakeUrl {
        +test_minimax_base_url()
        +test_minimax_base_url_no_version()
        +test_minimax_full_url_preserved()
    }

    class TestMiniMaxNativeOAISessionThinkTag {
        +test_think_tag_extracted_in_native_oai()
    }

    class TestMiniMaxLLMSessionConfig {
        +test_llm_session_init_with_minimax()
        +test_llm_session_minimax_highspeed()
    }

    class TestMiniMaxNativeToolClientThinkTag {
        +test_native_tool_client_think_tag()
    }
}

' ─────────────────────────────────────────────
'  Integration Tests  (tests/test_minimax_integration.py)
' ─────────────────────────────────────────────
package "tests/test_minimax_integration.py (Integration Tests)" {

    class TestMiniMaxEndToEnd {
        +test_full_pipeline_with_think_tag()
        +test_full_pipeline_with_tool_call()
        +test_temperature_enforced_in_request()
    }

    class TestMiniMaxLive {
        +test_live_chat_completion()
        +test_live_tool_client_pipeline()
        +test_live_streaming_chunks()
    }

    note bottom of TestMiniMaxLive
      @skipUnless MINIMAX_API_KEY env var is set
      Performs real HTTP calls to MiniMax API
    end note
}

' ─────────────────────────────────────────────
'  External base class
' ─────────────────────────────────────────────
class "unittest.TestCase" as UnitTestCase <<external>> {
}

' ─────────────────────────────────────────────
'  Inheritance relationships
' ─────────────────────────────────────────────
LLMSession          --|> BaseSession
NativeClaudeSession --|> BaseSession
NativeOAISession    --|> NativeClaudeSession

TestMiniMaxTemperatureClamping      --|> UnitTestCase
TestMiniMaxThinkTagHandling         --|> UnitTestCase
TestMiniMaxCompressHistoryTags      --|> UnitTestCase
TestMiniMaxAutoMakeUrl              --|> UnitTestCase
TestMiniMaxNativeOAISessionThinkTag --|> UnitTestCase
TestMiniMaxLLMSessionConfig         --|> UnitTestCase
TestMiniMaxNativeToolClientThinkTag --|> UnitTestCase
TestMiniMaxEndToEnd                 --|> UnitTestCase
TestMiniMaxLive                     --|> UnitTestCase

' ─────────────────────────────────────────────
'  Composition / Aggregation
' ─────────────────────────────────────────────
ToolClient       o-- BaseSession      : backend
NativeToolClient o-- NativeOAISession : session

MockResponse  "1" *-- "0..*" MockToolCall : tool_calls
MockToolCall        *--       MockFunction : function

' ─────────────────────────────────────────────
'  Production dependencies / produces
' ─────────────────────────────────────────────
LLMSession          ..> LLMCoreFunctions : delegates to\n_openai_stream
NativeOAISession    ..> LLMCoreFunctions : delegates to\n_openai_stream
ToolClient          ..> MockResponse     : produces
NativeClaudeSession ..> MockResponse     : produces

' ─────────────────────────────────────────────
'  Test → SUT dependencies
' ─────────────────────────────────────────────
TestMiniMaxTemperatureClamping      ..> LLMCoreFunctions    : tests _openai_stream\ntemp clamping
TestMiniMaxThinkTagHandling         ..> ToolClient          : tests _parse_mixed_response
TestMiniMaxThinkTagHandling         ..> LLMSession          : uses for context
TestMiniMaxCompressHistoryTags      ..> LLMCoreFunctions    : tests compress_history_tags
TestMiniMaxAutoMakeUrl              ..> LLMCoreFunctions    : tests auto_make_url
TestMiniMaxNativeOAISessionThinkTag ..> NativeOAISession    : tests ask()
TestMiniMaxLLMSessionConfig         ..> LLMSession          : tests __init__
TestMiniMaxNativeToolClientThinkTag ..> NativeToolClient    : tests chat()
TestMiniMaxEndToEnd                 ..> LLMSession          : tests (HTTP mocked)
TestMiniMaxEndToEnd                 ..> ToolClient          : tests (HTTP mocked)
TestMiniMaxLive                     ..> LLMSession          : tests (real HTTP)
TestMiniMaxLive                     ..> ToolClient          : tests (real HTTP)

@enduml
