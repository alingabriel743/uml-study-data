@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Qt Desktop Frontend

' ─── Qt base classes (external stubs) ────────────────────────────────────────
package "Qt Widgets (external)" <<Frame>> {
    class QWidget <<Qt>>
    class QFrame <<Qt>>
    class QLabel <<Qt>>
    class QPushButton <<Qt>>
}

' ─── External agent dependency ───────────────────────────────────────────────
package "Agent Core (external)" <<Frame>> {
    class GeneraticAgent <<external>> {
        +put_task(query, source, images): Queue
        +abort()
        +get_llm_name(): str
        +llmclient
        +is_running: bool
    }
}

' ─── Qt Desktop Frontend ─────────────────────────────────────────────────────
package "frontends/qtapp.py" {

    class FloatingButton {
        ' Constants
        {static} +SIZE: int = 60
        {static} +MARGIN: int = 14
        {static} +TOTAL: int = SIZE + MARGIN*2
        ' State
        -chat_panel: QWidget
        -_drag_origin_global: QPoint|None
        -_drag_origin_win: QPoint|None
        -_dragged: bool
        -_glow: float
        -_glow_dir: int
        -_hovering: bool
        -_hover_clock: float
        -_hover_strength: float
        -_flow_phase: float
        -_running: bool
        -_last_toggle_ms: int
        -_timer: QTimer
        ' Methods
        +__init__(chat_panel: QWidget)
        -_tick()
        +paintEvent(_event)
        +enterEvent(event)
        +leaveEvent(event)
        +mousePressEvent(event)
        +mouseMoveEvent(event)
        +mouseDoubleClickEvent(event)
        +mouseReleaseEvent(event)
        -_toggle()
        -_position_panel()
    }

    class ChatPanel {
        ' Agent
        +agent: GeneraticAgent
        ' Session state
        -_messages: list[dict]
        -_session: dict
        -_history: list[dict]
        -_pending_files: list[dict]
        -_settings_health_checked: bool
        ' Streaming state
        -_display_queue: Queue|None
        -_streaming_row: _MsgRow|None
        -_streaming_text: str
        -_is_streaming: bool
        -_user_scrolled_up: bool
        -_poll_timer: QTimer
        ' UI state
        +autonomous_enabled: bool
        +last_reply_time: float
        -_drag_pos: QPoint|None
        ' UI widgets
        -_stack: QStackedWidget
        -_model_badge: _Badge
        -_streaming_badge: _StreamingBadge
        -_msg_layout: QVBoxLayout
        -_scroll: QScrollArea
        -_input: QTextEdit
        -_send_btn: QPushButton
        -_token_lbl: QLabel
        -_hist_list: QListWidget
        -_sop_list: QListWidget
        -_sop_viewer: QTextBrowser
        -_auto_btn: QPushButton
        ' Lifecycle
        +__init__(agent)
        +paintEvent(_event)
        +resizeEvent(event)
        ' Builder methods
        -_build_ui()
        -_build_titlebar(): QWidget
        -_build_tabbar(): QWidget
        -_build_chat_page(): QWidget
        -_build_input_area(): QWidget
        -_build_history_page(): QWidget
        -_build_sop_page(): QWidget
        -_build_settings_page(): QWidget
        -_build_model_rows()
        ' Tab navigation
        -_switch_tab(idx: int)
        -_do_switch_to(idx: int)
        ' Send / Stop
        -_on_send_btn_click()
        -_handle_send()
        -_set_send_mode()
        -_set_stop_mode()
        -_do_stop()
        ' Streaming / Queue
        -_poll_queue()
        -_add_msg_row(role: str, text: str): _MsgRow
        -_regenerate_response()
        -_on_scroll(value: int)
        -_scroll_bottom()
        +inject_message(text: str)
        ' History / SOP
        -_refresh_history()
        -_restore_selected(item)
        -_delete_selected()
        -_rebuild_messages()
        -_refresh_sop()
        -_load_sop(item)
        ' Settings / Model
        -_start_health_checks()
        -_poll_health_results()
        -_check_backend(idx: int, backend)
        -_refresh_model_rows_style()
        -_do_switch_model()
        -_do_reset_prompt()
        -_model_name(): str
        ' Misc
        -_update_token_usage()
        -_add_system_notice(text: str)
        -_auto_save()
        -_do_save()
        -_do_clear()
        -_new_session()
        -_do_toggle_auto()
        -_do_trigger_auto()
        -_on_text_changed()
        -_attach_files()
        -_refresh_chips()
        +eventFilter(obj, event)
        {static} -_small_btn_style(color: str): str
        -_tb_press(e)
        -_tb_move(e)
        -_tb_release(_e)
    }

    class _MsgRow {
        -_text: str
        -_role: str
        -_on_resend: callable|None
        -_action_row: QWidget|None
        -_finished: bool
        -_label: QLabel|QTextBrowser
        +__init__(text: str, role: str, parent, on_resend)
        +enterEvent(event)
        +leaveEvent(event)
        +resizeEvent(event)
        +set_finished(done: bool)
        +set_text(text: str)
        -_copy_text()
        -_do_resend()
        -_adjust_browser_height()
    }

    class _Badge {
        +__init__(text: str, parent)
    }

    class _StreamingBadge {
        -visible: bool
        +__init__(parent)
    }

    class _Separator {
        +__init__(parent)
    }

    class _TabButton {
        +__init__(text: str, parent)
    }

}

' ─── Inheritance ─────────────────────────────────────────────────────────────
FloatingButton    --|> QWidget
ChatPanel         --|> QWidget
_MsgRow           --|> QWidget
_Badge            --|> QLabel
_StreamingBadge   --|> QLabel
_Separator        --|> QFrame
_TabButton        --|> QPushButton

' ─── Composition / Aggregation ───────────────────────────────────────────────
FloatingButton    o--  ChatPanel          : "aggregates\n(toggles visibility)"
ChatPanel         *--  _MsgRow            : "composes\n(message rows)"
ChatPanel         *--  _Badge             : "composes\n(model badge)"
ChatPanel         *--  _StreamingBadge    : "composes\n(streaming indicator)"
ChatPanel         *--  _Separator         : "composes\n(UI dividers)"
ChatPanel         *--  _TabButton         : "composes\n(tab navigation)"

' ─── Dependency ──────────────────────────────────────────────────────────────
ChatPanel         ..>  GeneraticAgent     : "uses\n(put_task / abort)"
FloatingButton    ..>  ChatPanel          : "reads _is_streaming\n& agent.is_running"

note bottom of ChatPanel
  **Tabs (QStackedWidget)**
  0: Chat — message scroll + input
  1: History — past sessions list
  2: SOP — memory/*.md file browser
  3: Settings — model & health checks

  **Streaming state machine**
  _is_streaming=False → send mode
  _is_streaming=True  → stop mode
  40 ms _poll_timer reads Queue
  {next: text} → set_text(text + '▌')
  {done: true}  → set_finished(True)

  **Autonomous mode**
  QTimer (2 min) idle check →
  inject_message() after 30 min
end note

note right of FloatingButton
  Frameless, always-on-top, Tool window.
  30 fps QTimer animation:
  spring-bounce hover + glow pulse.
  Drag to reposition on screen.
end note

note right of _MsgRow
  user   → QLabel (plain text)
  assistant → QTextBrowser (HTML)
  Hover shows copy / resend actions.
end note

@enduml
