@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Skill Search Engine

package "skill_search" {

    class SkillIndex <<dataclass>> {
        +key: str
        +name: str
        +description: str
        +one_line_summary: str
        +category: str
        +tags: list[str]
        +language: str
        +os: list[str]
        +runtimes: list[str]
        +tools: list[str]
        +needs_tool_calling: bool
        +needs_reasoning: bool
        +clarity: int
        +completeness: int
        +actionability: int
        +autonomous_safe: bool
        +blast_radius: str
        +capabilities: list[str]
        +github_stars: int
        --
        +quality_score: float <<property>>
        +{static} from_dict(d: dict): SkillIndex
    }

    class SearchResult <<dataclass>> {
        +skill: SkillIndex
        +relevance: float
        +quality: float
        +final_score: float
        +match_reasons: list[str]
        +warnings: list[str]
        --
        +{static} from_dict(d: dict): SearchResult
    }

    class SkillSearchError <<exception>> {
    }

    class EngineModule <<module>> {
        ' -- Environment Detection --
        +detect_environment(): dict
        -_detect_os(): str
        -_detect_shell(): str
        -_detect_runtimes(): list[str]
        -_detect_tools(): list[str]
        ' -- API Layer --
        -_get_api_url(): str
        -_get_api_key(): str | None
        -_run(cmd: str): str
        -_api_request(endpoint: str, payload: dict): dict
        ' -- Public API --
        +search(query: str, env: dict | None, category: str | None, top_k: int): list[SearchResult]
        +get_stats(env: dict | None): dict
    }

    class CLIFormatter <<module>> {
        +format_results(results: list[SearchResult], env: dict, query: str): str
        +format_results_json(results: list[SearchResult]): list[dict]
        +main(): None
    }

}

class Exception <<builtin>> {
}

' Inheritance
SkillSearchError --|> Exception : extends

' Composition
SearchResult *-- SkillIndex : skill

' Dependencies
EngineModule ..> SearchResult : <<creates>>
EngineModule ..> SkillIndex : <<creates via SearchResult>>
EngineModule ..> SkillSearchError : <<raises>>

CLIFormatter ..> EngineModule : calls search()\ncalls get_stats()\ncalls detect_environment()
CLIFormatter ..> SearchResult : formats

@enduml
