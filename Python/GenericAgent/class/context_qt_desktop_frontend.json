  "relationships": [
    "FloatingButton aggregates ChatPanel (holds reference, toggles visibility)",
    "FloatingButton reads ChatPanel._is_streaming and ChatPanel.agent.is_running for status",
    "ChatPanel composes _MsgRow (creates via _add_msg_row, holds _streaming_row)",
    "ChatPanel composes _Badge (model name badge in title bar)",
    "ChatPanel composes _StreamingBadge (streaming indicator in title bar)",
    "ChatPanel composes _Separator (UI dividers)",
    "ChatPanel composes _TabButton (tab bar navigation)",
    "ChatPanel depends_on GeneraticAgent (agent.put_task, agent.abort, agent.get_llm_name, agent.llmclient)",
    "_MsgRow contains QTextBrowser (for assistant messages) or QLabel (for user messages)",
    "main() instantiates GeneraticAgent → ChatPanel(agent) → FloatingButton(panel)"
  ],

  "key_interactions": [
    "User types → _handle_send() → agent.put_task(prompt) → _display_queue (Queue)",
    "_poll_timer (40ms) → _poll_queue() → reads Queue items {next, done}",
    "Queue 'next' item → _streaming_row.set_text(text + '▌')",
    "Queue 'done' item → _streaming_row.set_text(final), set_finished(True), _auto_save()",
    "_do_stop() → agent.abort(), _poll_timer.stop(), _streaming_row.set_finished(True)",
    "FloatingButton._toggle() → ChatPanel show/hide toggle",
    "_MsgRow hover enter/leave → _action_row show/hide (copy/regen buttons)",
    "_MsgRow._do_resend() → on_resend callback → ChatPanel._regenerate_response()",
    "ChatPanel._regenerate_response() → finds last user message → _handle_send()",
    "idle_check() QTimer (2min) → panel.inject_message() if autonomous + idle > 30min"
  ],

  "streaming_state_machine": {
    "_is_streaming=False": "_set_send_mode: send button shows send icon",
    "_is_streaming=True": "_set_stop_mode: send button becomes stop button",
    "transition_to_streaming": "_handle_send sets _is_streaming=True via _set_stop_mode",
    "transition_from_streaming": "_poll_queue 'done' or _do_stop calls _set_send_mode"
  },

  "tabs": [
    "0: Chat page (_build_chat_page) — message scroll area + input area",
    "1: History page (_build_history_page) — QListWidget of past sessions",
    "2: SOP page (_build_sop_page) — memory/*.md file browser + viewer",
    "3: Settings page (_build_settings_page) — model selection + health checks"
  ],

  "important_notes": [
    "Single-file app; all classes in frontends/qtapp.py",
    "Frameless always-on-top windows (both FloatingButton and ChatPanel use Qt.FramelessWindowHint | Qt.WindowStaysOnTopHint | Qt.Tool)",
    "Agent runs in daemon thread; UI ↔ agent communication via queue.Queue returned by agent.put_task()",
    "_MsgRow renders assistant text as HTML via _md_to_html() in QTextBrowser; user text as plain QLabel",
    "Autonomous mode: QTimer idles every 2min; after 30min inactivity auto-injects SOP prompt",
    "Sessions persisted to JSON via _load_history()/_save_history() helpers",
    "FloatingButton uses 30fps QTimer animation with spring-bounce hover effect and glow pulse"
  ]
}
