@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam ArrowThickness 1.2

title Generatic Agent — Component Architecture

' ─────────────────────────────────────────────
' FRONTEND LAYER
' ─────────────────────────────────────────────
package "Frontend Layer" {
    [Streamlit App\n(stapp / stapp2)] as stapp
    [Qt GUI App\n(qtapp)] as qtapp
    [QQ Bot\n(qqapp)] as qqapp
    [Telegram Bot\n(tgapp)] as tgapp
    [DingTalk App\n(dingtalkapp)] as dingapp
    [WeCom App\n(wecomapp)] as wecomapp
    [WeChat App\n(wechatapp)] as wechatapp
    [FastAPI / Flask App\n(fsapp)] as fsapp
    [Chat Common Utilities\n(chatapp_common)] as chatcommon
}

' ─────────────────────────────────────────────
' CORE AGENT LAYER
' ─────────────────────────────────────────────
package "Core Agent Layer" {
    [Generatic Agent\nEntry Point\n(agentmain)] as agentmain
    [Agent Runner Loop\n(agent_loop)] as agentloop
    [Generic Agent Handler\n& Tool Executor\n(ga)] as ga
}

' ─────────────────────────────────────────────
' LLM CORE LAYER
' ─────────────────────────────────────────────
package "LLM Core Layer" {
    [LLM Session Manager\n(llmcore)] as llmcore
    [Claude Session\n(ClaudeSession /\nNativeClaudeSession)] as claude
    [OpenAI-Compatible Session\n(LLMSession /\nNativeOAISession)] as oai
    [Mixin Session\n(multi-provider routing)] as mixin
    [Tool Client\n(ToolClient /\nNativeToolClient)] as toolclient
}

' ─────────────────────────────────────────────
' MEMORY & SENSING LAYER
' ─────────────────────────────────────────────
package "Memory & Sensing Layer" {
    [Global Memory Store\n(global_mem.txt)] as globalmem
    [Keychain / Secrets\n(keychain)] as keychain
    [OCR Utilities\n(ocr_utils)] as ocr
    [ADB / UI Interaction\n(adb_ui)] as adbui
    [UI Detection\n(ui_detect)] as uidetect
    [Process Memory Scanner\n(procmem_scanner)] as procmem
    [LJQ Controller\n(ljqCtrl)] as ljqctrl
    [L4 Raw Sessions\n(L4_raw_sessions)] as l4sessions
    [Skill Search\n(skill_search)] as skillsearch
    [Autonomous Operation SOP\n(autonomous_operation_sop)] as autosop
}

' ─────────────────────────────────────────────
' REFLECTION & SCHEDULING LAYER
' ─────────────────────────────────────────────
package "Reflection & Scheduling Layer" {
    [Autonomous Trigger\n(reflect/autonomous)] as autonomous
    [Task Scheduler\n(reflect/scheduler)] as scheduler
}

' ─────────────────────────────────────────────
' WEB AUTOMATION LAYER
' ─────────────────────────────────────────────
package "Web Automation Layer" {
    [TM Web Driver\n(TMWebDriver)] as tmwebdriver
    [CDP Bridge\n(assets/tmwd_cdp_bridge)] as cdpbridge
}

' ─────────────────────────────────────────────
' ASSETS / CONFIGURATION
' ─────────────────────────────────────────────
package "Assets & Configuration" {
    [Tool Schema\n(tools_schema.json)] as toolschema
    [System Prompt\n(sys_prompt.txt)] as sysprompt
    [Code Run Header\n(code_run_header.py)] as codeheader
    [API Keys Config\n(mykey.json / mykey.py)] as apikeys
}

' ─────────────────────────────────────────────
' EXTERNAL SYSTEMS
' ─────────────────────────────────────────────
package "External LLM Providers" {
    [Anthropic Claude API] as claudeapi
    [OpenAI / OAI-Compatible API] as openaiapi
    [MiniMax API] as minimaxapi
}

' ─────────────────────────────────────────────
' RELATIONSHIPS — Frontend → Core
' ─────────────────────────────────────────────
stapp --> agentmain : "starts agent"
qtapp --> agentmain : "starts agent"
qqapp --> agentmain : "starts agent"
tgapp --> agentmain : "starts agent"
dingapp --> agentmain : "starts agent"
wecomapp --> agentmain : "starts agent"
wechatapp --> agentmain : "starts agent"
fsapp --> agentmain : "starts agent"

stapp --> chatcommon : "uses"
qqapp --> chatcommon : "uses"
tgapp --> chatcommon : "uses"
dingapp --> chatcommon : "uses"
wecomapp --> chatcommon : "uses"
wechatapp --> chatcommon : "uses"
fsapp --> chatcommon : "uses"

' ─────────────────────────────────────────────
' RELATIONSHIPS — Core Agent
' ─────────────────────────────────────────────
agentmain --> agentloop : "drives loop"
agentmain --> llmcore : "configures sessions"
agentmain --> ga : "registers handler"
agentmain --> toolschema : "loads tool schema"
agentmain --> sysprompt : "loads system prompt"
agentmain --> globalmem : "reads/writes memory"

agentloop --> toolclient : "sends chat request"
agentloop --> ga : "dispatches tool calls"

ga --> globalmem : "read/write global memory"
ga --> tmwebdriver : "web automation"
ga --> skillsearch : "searches skills"
ga --> codeheader : "prepends to code runs"

' ─────────────────────────────────────────────
' RELATIONSHIPS — LLM Core
' ─────────────────────────────────────────────
llmcore --> apikeys : "loads API keys"
toolclient --> claude : "wraps"
toolclient --> oai : "wraps"
mixin --> claude : "routes to"
mixin --> oai : "routes to"

claude --> claudeapi : "HTTP requests"
oai --> openaiapi : "HTTP requests"
oai --> minimaxapi : "HTTP requests"

' ─────────────────────────────────────────────
' RELATIONSHIPS — Memory & Sensing
' ─────────────────────────────────────────────
ga --> ocr : "screen capture / OCR"
ga --> adbui : "Android UI control"
ga --> uidetect : "UI element detection"
ga --> procmem : "process memory scan"
ga --> ljqctrl : "system control"
ga --> l4sessions : "session history"
ga --> autosop : "autonomous SOP"
keychain --> apikeys : "stores secrets"

' ─────────────────────────────────────────────
' RELATIONSHIPS — Reflection & Scheduling
' ─────────────────────────────────────────────
autonomous --> agentmain : "triggers autonomous task"
scheduler --> agentmain : "schedules tasks"
autonomous --> autosop : "reads SOP"

' ─────────────────────────────────────────────
' RELATIONSHIPS — Web Automation
' ─────────────────────────────────────────────
tmwebdriver --> cdpbridge : "CDP protocol"

@enduml
