@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam node {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam artifact {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam database {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam cloud {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam ArrowColor #495057

title GenericAgent — Deployment Diagram

' ─── Local Host Machine ───────────────────────────────────────────────────────
node "Host Machine" <<Python Runtime>> {

    package "Agent Core" {
        artifact "agentmain.py\n(GeneraticAgent)" as agentmain
        artifact "agent_loop.py\n(agent_runner_loop)" as agent_loop
        artifact "ga.py\n(GenericAgentHandler)" as ga
        artifact "llmcore.py\n(LLM Session Manager)" as llmcore
    }

    package "TMWebDriver" {
        artifact "WebSocket Server\nws://127.0.0.1:18765" as ws_server
        artifact "HTTP Server\nhttp://127.0.0.1:18766" as http_server
    }

    package "Memory Subsystem" {
        database "global_mem.txt\n(L2 Global Memory)" as global_mem
        database "L4 Raw Sessions\n(Conversation Logs)" as raw_sessions
        artifact "skill_search\n(Skill Index Engine)" as skill_search
        artifact "compress_session.py\n(History Compressor)" as compress
    }

    package "Frontend Adapters" {
        artifact "stapp.py / stapp2.py\n(Streamlit Web UI)" as streamlit
        artifact "qtapp.py\n(Qt Desktop GUI)" as qtapp
        artifact "tgapp.py\n(Telegram Bot)" as tgapp
        artifact "qqapp.py\n(QQ Bot)" as qqapp
        artifact "fsapp.py\n(Feishu / Lark)" as fsapp
        artifact "wecomapp.py\n(WeCom / Enterprise WeChat)" as wecomapp
        artifact "dingtalkapp.py\n(DingTalk)" as dingtalkapp
        artifact "wechatapp.py\n(WeChat)" as wechatapp
    }

    package "Assets" {
        artifact "tools_schema.json\n(Tool Definitions)" as tools_schema
        artifact "sys_prompt.txt\n(System Prompt)" as sys_prompt
        artifact "CDP Bridge\n(tmwd_cdp_bridge/config.js)" as cdp_bridge
    }
}

' ─── Browser (local) ──────────────────────────────────────────────────────────
node "Web Browser" <<Browser>> {
    artifact "Browser Tab\n(CDP / JS Executor)" as browser_tab
}

' ─── Optional HTTP Proxy ──────────────────────────────────────────────────────
node "HTTP Proxy" <<Optional>> {
    artifact "Proxy Server\n(e.g. 127.0.0.1:2082)" as proxy
}

' ─── External LLM API Providers ───────────────────────────────────────────────
cloud "Anthropic Cloud" {
    artifact "Claude API\n(api.anthropic.com)" as claude_api
}

cloud "OpenAI Cloud" {
    artifact "OpenAI API\n(api.openai.com)" as openai_api
}

cloud "CC Switch / Relay" {
    artifact "Claude Relay\n(CC-Switch / CRS)" as cc_relay
}

cloud "Third-Party LLM APIs" {
    artifact "MiniMax API\n(api.minimaxi.com)" as minimax_api
    artifact "Moonshot / Kimi API\n(api.moonshot.cn)" as kimi_api
    artifact "OpenRouter\n(openrouter.ai)" as openrouter
}

' ─── Messaging Platforms ──────────────────────────────────────────────────────
cloud "Messaging Platforms" {
    artifact "Telegram\n(api.telegram.org)" as telegram
    artifact "QQ Bot\n(open.qq.com)" as qq
    artifact "Feishu / Lark\n(open.feishu.cn)" as feishu
    artifact "WeCom\n(qyapi.weixin.qq.com)" as wecom
    artifact "DingTalk\n(oapi.dingtalk.com)" as dingtalk
}

' ─── Internal relationships ───────────────────────────────────────────────────
agentmain --> agent_loop : "drives"
agentmain --> llmcore    : "creates sessions"
agentmain --> ga         : "uses handler"
ga         --> ws_server : "controls browser"
ga         --> tools_schema : "loads tool definitions"
agentmain  --> sys_prompt   : "loads system prompt"
agent_loop --> global_mem   : "reads/writes memory"
compress   --> raw_sessions : "compresses logs"
skill_search --> global_mem : "indexes skills"

streamlit   --> agentmain : "submits tasks"
qtapp       --> agentmain : "submits tasks"
tgapp       --> agentmain : "submits tasks"
qqapp       --> agentmain : "submits tasks"
fsapp       --> agentmain : "submits tasks"
wecomapp    --> agentmain : "submits tasks"
dingtalkapp --> agentmain : "submits tasks"
wechatapp   --> agentmain : "submits tasks"

' ─── Browser control ──────────────────────────────────────────────────────────
ws_server  <--> browser_tab : "WebSocket\n(JS execution)"
http_server <--> browser_tab : "HTTP Long-Poll\n(fallback)"
cdp_bridge --> browser_tab  : "CDP Bridge"

' ─── LLM API calls ───────────────────────────────────────────────────────────
llmcore --> proxy       : "HTTP (optional)\nrouting"
proxy   --> claude_api  : "HTTPS"
proxy   --> openai_api  : "HTTPS"
proxy   --> cc_relay    : "HTTPS"
proxy   --> minimax_api : "HTTPS"
proxy   --> kimi_api    : "HTTPS"
proxy   --> openrouter  : "HTTPS"

llmcore --> claude_api  : "HTTPS (direct)\nx-api-key / Bearer"
llmcore --> openai_api  : "HTTPS (direct)\nBearer"
llmcore --> cc_relay    : "HTTPS (direct)\nBearer"
llmcore --> minimax_api : "HTTPS (direct)\nBearer"
llmcore --> kimi_api    : "HTTPS (direct)\nBearer"
llmcore --> openrouter  : "HTTPS (direct)\nBearer"

' ─── Messaging platform connections ──────────────────────────────────────────
tgapp       --> telegram : "HTTPS\nBot API (polling)"
qqapp       --> qq       : "HTTPS\nBot API"
fsapp       --> feishu   : "HTTPS\nEvent Subscription"
wecomapp    --> wecom    : "HTTPS\nWebhook / API"
dingtalkapp --> dingtalk : "HTTPS\nEvent Subscription"

@enduml
