@startuml
title GenericAgent — System Context Diagram

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actor {
    BackgroundColor<<Person>> #08427B
    FontColor<<Person>> #FFFFFF
    BorderColor<<Person>> #052E56
}

skinparam arrow {
    Color #424242
    FontSize 10
    FontColor #616161
}

' ── Actors ──────────────────────────────────────────────────────────────────
actor "End User
[Human / Operator]" as user <<Person>>
actor "Autonomous Scheduler
[reflect / cron tasks]" as scheduler <<Person>>

' ── Core System ──────────────────────────────────────────────────────────────
rectangle "**GenericAgent**
[Python Autonomous Agent Framework]

~3K lines. 9 atomic tools + Agent Loop
give any LLM system-level control over
browser, terminal, filesystem, ADB & screen" as system <<System>>

' ── Chat Platform Frontends ──────────────────────────────────────────────────
rectangle "**Telegram Bot**
[python-telegram-bot]

Text/photo/file messages,
streaming replies via HTTPX" as tg <<External>>

rectangle "**Feishu / Lark Bot**
[lark_oapi SDK]

Enterprise IM messages,
events & card replies" as feishu <<External>>

rectangle "**WeChat Personal Bot**
[requests + qrcode]

Personal WeChat client,
QR login, bulk messaging" as wechat <<External>>

rectangle "**WeCom Bot**
[wecom_aibot_sdk]

企业微信 enterprise chat,
webhook & bot API" as wecom <<External>>

rectangle "**DingTalk Bot**
[dingtalk-stream]

钉钉 streaming connector,
AI-card push & receive" as dingtalk <<External>>

rectangle "**QQ Bot**
[qqapp frontend]

QQ group/private messages,
bot event dispatch" as qq <<External>>

rectangle "**Streamlit Web UI**
[stapp / stapp2]

Browser-based chat UI,
file upload, display queue" as streamlit <<External>>

rectangle "**Qt Desktop App**
[qtapp / PyQt]

Native desktop GUI,
local chat interface" as qtapp <<External>>

' ── LLM API Providers ────────────────────────────────────────────────────────
rectangle "**Anthropic Claude API**
[NativeClaudeSession / ClaudeSession]

claude-sonnet / opus models,
prompt caching, thinking blocks" as claude <<External>>

rectangle "**OpenAI-compatible API**
[LLMSession / NativeOAISession]

GPT-4o, o-series, or any
3rd-party OpenAI-compat endpoint" as openai <<External>>

rectangle "**MiniMax API**
[https://api.minimax.io/v1]

MiniMax-M2.7 model,
OpenAI-compat format" as minimax <<External>>

rectangle "**Other Chinese LLMs**
[GLM / Kimi / Qwen / Ernie]

Zhipu GLM, Moonshot Kimi,
etc. via OpenAI-compat" as otherllm <<External>>

' ── System-Level Resources Controlled ────────────────────────────────────────
rectangle "**Chrome / Edge Browser**
[TMWebDriver + CDP Bridge]

Real browser automation,
login sessions preserved,
JavaScript execution" as browser <<Infrastructure>>

rectangle "**Android Device (ADB)**
[adb_ui.py / UIDetect]

Remote ADB shell, tap,
swipe, screenshot via
UI detection + OCR" as adb <<Infrastructure>>

rectangle "**Local Filesystem**
[memory/, temp/, skills/]

Global memory (L2/L4),
session logs, skill store,
task IO files" as fs <<Database>>

rectangle "**RapidOCR (ONNX)**
[rapidocr_onnxruntime]

On-device OCR engine,
screen text extraction,
image understanding" as ocr <<Cache>>

rectangle "**Process Memory Scanner**
[procmem_scanner.py]

Windows process memory
read for credential / state
extraction tasks" as procmem <<Infrastructure>>

' ── Relationships: Users → System ────────────────────────────────────────────
user --> tg         : "sends messages"
user --> feishu     : "sends messages"
user --> wechat     : "sends messages"
user --> wecom      : "sends messages"
user --> dingtalk   : "sends messages"
user --> qq         : "sends messages"
user --> streamlit  : "browser interaction"
user --> qtapp      : "desktop UI input"

tg       --> system : "HTTPS polling\n(user prompt + images)"
feishu   --> system : "HTTPS webhook\n(Lark event push)"
wechat   --> system : "HTTP REST\n(WeChat message events)"
wecom    --> system : "HTTPS SDK\n(WeCom bot events)"
dingtalk --> system : "WebSocket stream\n(DingTalk events)"
qq       --> system : "HTTP REST\n(QQ bot messages)"
streamlit --> system : "In-process queue\n(display_queue)"
qtapp    --> system : "In-process queue\n(task dispatch)"

scheduler --> system : "In-process\n(reflect/cron trigger)"

' ── Relationships: System → LLM APIs ─────────────────────────────────────────
system --> claude   : "HTTPS REST\n(POST /messages,\nstreaming SSE)"
system --> openai   : "HTTPS REST\n(POST /chat/completions,\nstreaming SSE)"
system --> minimax  : "HTTPS REST\n(OpenAI-compat,\nPOST /chat/completions)"
system --> otherllm : "HTTPS REST\n(OpenAI-compat\nendpoints)"

' ── Relationships: System → Local Resources ──────────────────────────────────
system --> browser  : "WebSocket CDP\n(JS exec, DOM read,\ncookie access)"
system --> adb      : "ADB shell / TCP\n(tap, swipe,\nscreenshot, install)"
system --> fs       : "Local I/O\n(read/write memory,\nskills, session logs)"
system --> ocr      : "In-process call\n(image → text\nextraction)"
system --> procmem  : "Win32 API\n(process memory\nread/scan)"

' ── Reply flows ───────────────────────────────────────────────────────────────
system --> tg       : "HTTPS Bot API\n(edit_message / send_photo)"
system --> feishu   : "HTTPS REST\n(send card / message)"
system --> wechat   : "HTTP REST\n(send text / file)"
system --> wecom    : "HTTPS SDK\n(send message)"
system --> dingtalk : "HTTPS REST\n(send AI card)"
system --> qq       : "HTTP REST\n(send message)"

@enduml
