@startuml use_case_agent_core_loop

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Agent Core Loop & Turn Management

left to right direction

' ── Primary Actors ──────────────────────────────────────────────────
actor "User" as User
actor "ReflectScript\n(--reflect)" as ReflectScript
actor "TaskFile\n(--task)" as TaskFile

' ── Secondary / External Actors ─────────────────────────────────────
actor "LLM Backend\n(Claude / OAI / etc.)" as LLMBackend
actor "OS / Shell" as OSShell

' ── System Boundary ─────────────────────────────────────────────────
rectangle "GeneraticAgent / Agent Orchestration System" {

    ' ── Entry & Control ─────────────────────────────────────────────
    usecase "Submit Query\n(put_task)" as UC1
    usecase "Handle Slash Command\n(_handle_slash_cmd)" as UC16
    usecase "Abort Agent\n(abort)" as UC13
    usecase "Switch LLM Backend\n(next_llm)" as UC14
    usecase "Load Tool Schema\n(load_tool_schema)" as UC15

    ' ── Core Loop ───────────────────────────────────────────────────
    usecase "Run Agent Turn Loop\n(agent_runner_loop)" as UC2
    usecase "Call LLM for Response\n(client.chat)" as UC3
    usecase "Handle Turn End\n(turn_end_callback)" as UC8

    ' ── Tool Dispatch ───────────────────────────────────────────────
    usecase "Dispatch Tool Call\n(handler.dispatch)" as UC4

    ' ── Concrete Tool Use Cases ─────────────────────────────────────
    usecase "Run Code\n(do_code_run)" as UC5
    usecase "Ask User Question\n(do_ask_user)" as UC6
    usecase "Web Scan / Execute JS\n(do_web_scan / do_web_execute_js)" as UC7
    usecase "Read / Write File\n(do_file_read / write / patch)" as UC9
    usecase "Update Working Checkpoint\n(do_update_working_checkpoint)" as UC10
    usecase "Handle No-Tool Response\n(do_no_tool)" as UC11
    usecase "Start Long-Term Update\n(do_start_long_term_update)" as UC12
}

' ── Actor → Use Case Associations ────────────────────────────────────
User         --> UC1
User         --> UC16
User         --> UC13
User         --> UC14
User         --> UC15
User         --> UC6   : responds to prompt

ReflectScript --> UC1
TaskFile      --> UC1

LLMBackend   --> UC3
OSShell      --> UC5
OSShell      --> UC7
OSShell      --> UC9

' ── Include Relationships (core loop composition) ────────────────────
UC1  ..> UC16 : <<include>>
UC2  ..> UC3  : <<include>>
UC2  ..> UC4  : <<include>>
UC2  ..> UC8  : <<include>>

UC4  ..> UC5  : <<include>>
UC4  ..> UC6  : <<include>>
UC4  ..> UC7  : <<include>>
UC4  ..> UC9  : <<include>>
UC4  ..> UC10 : <<include>>
UC4  ..> UC11 : <<include>>
UC4  ..> UC12 : <<include>>

' ── Extend / Trigger Relationships ───────────────────────────────────
UC14 ..> UC15 : <<include>>
UC2  <.. UC13 : <<extend>>\n(stop_sig check)

@enduml
