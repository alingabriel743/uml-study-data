@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Android Device Control (ADB)

left to right direction

actor "Agent\n(AI Automation Script)" as Agent

actor "uiautomator2\n(u2 Library)" as U2
actor "ADB\n(Android Debug Bridge)" as ADB
actor "Android Device" as Device
actor "Windows Host\n(ljqCtrl)" as WinHost

rectangle "Android Device Control System" {

    package "UI Inspection" {
        usecase "Read Device State" as UC6
        usecase "Dump UI Hierarchy" as UC1
        usecase "Dump via uiautomator2\n(preferred)" as UC1a
        usecase "Dump via Native ADB\n(fallback)" as UC1b
        usecase "Parse & Filter UI Nodes" as UC2
    }

    package "Touch & Input" {
        usecase "Tap on Screen" as UC3
        usecase "Swipe on Screen" as UC4
        usecase "Input Text" as UC5
    }

    package "Windows Automation" {
        usecase "Windows Desktop\nInteraction" as UC7
        usecase "Mouse Click / Double Click" as UC7a
        usecase "Keyboard Shortcut" as UC7b
        usecase "Image Template Matching" as UC7c
    }

}

' --- Primary actor relationships ---
Agent --> UC6 : inspect screen state
Agent --> UC3 : trigger tap gesture
Agent --> UC4 : trigger swipe gesture
Agent --> UC5 : type into EditText field
Agent --> UC7 : control Windows desktop

' --- Include / Extend relationships ---
UC6 ..> UC1  : <<include>>
UC1 ..> UC1a : <<include>>\npreferred path
UC1 <.. UC1b : <<extend>>\nwhen u2 fails or\nresult < 100 chars
UC1 ..> UC2  : <<include>>

UC7 ..> UC7a : <<include>>
UC7 ..> UC7b : <<include>>
UC7 ..> UC7c : <<include>>

' --- Secondary actor relationships ---
UC1a --> U2     : d.dump_hierarchy()
UC1b --> ADB    : uiautomator dump --compressed\n+ adb pull
UC3  --> ADB    : adb shell input tap x y
UC4  --> ADB    : adb shell input swipe x1 y1 x2 y2
UC5  --> ADB    : adb shell input text <string>
ADB  --> Device : executes commands on device

UC7a --> WinHost : win32api mouse events
UC7b --> WinHost : win32api keybd_event
UC7c --> WinHost : cv2.matchTemplate\n+ ImageGrab screenshot

@enduml
