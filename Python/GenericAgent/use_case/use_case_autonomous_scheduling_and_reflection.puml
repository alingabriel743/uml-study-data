@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}

title Autonomous Scheduling & Reflection

left to right direction

' ── Primary Actor ──────────────────────────────────────────────
actor "Agent\n(LLM)" as Agent

' ── System Actors ───────────────────────────────────────────────
actor "Scheduler\n(poll every 120s)" as Scheduler #D4EDDA
actor "Autonomous Monitor\n(poll every 1800s)" as AutonomousMonitor #D4EDDA

' ── External Systems ────────────────────────────────────────────
actor "Task File System\n(sche_tasks/*.json)" as TaskFileSystem #FFF3CD
actor "L4 Archive System\n(compress_session)" as L4ArchiveSystem #FFF3CD

' ── System Boundary ─────────────────────────────────────────────
rectangle "Autonomous Scheduling & Reflection System" {

    ' ── Scheduler use cases ─────────────────────────────────────
    usecase "Trigger Scheduled Task\n[scheduler.check()]" as UC1
    note right of UC1
      Scans sche_tasks/*.json
      Evaluates: enabled flag,
      schedule HH:MM, repeat cadence,
      max_delay_hours, cooldown window.
      Returns prompt string or None.
    end note

    usecase "Archive L4 Sessions\n[compress_session.batch_process()]" as UC3
    note right of UC3
      Runs silently every 12h
      inside scheduler.check().
      Processes temp/model_responses/.
    end note

    ' ── Autonomous Monitor use case ─────────────────────────────
    usecase "Trigger Autonomous Mode\n[autonomous.check()]" as UC2
    note right of UC2
      Fires after user absent >30 min.
      Returns fixed SOP instruction
      directing Agent to self-directed tasks.
    end note

    ' ── Agent use cases ─────────────────────────────────────────
    usecase "Read Task TODO\n[helper.get_todo()]" as UC4

    usecase "Read Task History\n[helper.get_history()]" as UC5

    usecase "Get TODO File Path\n[helper.set_todo()]" as UC6

    usecase "Complete Autonomous Task\n[helper.complete_task()]" as UC7
    note right of UC7
      1. Validate & move report →
         autonomous_reports/R{N}_name.md
      2. Prepend entry to history.txt
         (rollback on failure)
      3. Return instruction to mark
         TODO item as done [x] R{N}
    end note
}

' ── Relationships: Scheduler ────────────────────────────────────
Scheduler --> UC1 : triggers
Scheduler --> UC3 : includes (every 12h)
UC1 ..> UC3 : <<include>>

' ── Relationships: Autonomous Monitor ──────────────────────────
AutonomousMonitor --> UC2 : triggers\n(idle > 30 min)

' ── Relationships: Agent ────────────────────────────────────────
UC1 --> Agent : dispatches\nscheduled prompt
UC2 --> Agent : dispatches\nautonomous prompt

Agent --> UC4 : uses (read TODO)
Agent --> UC5 : uses (review history)
Agent --> UC6 : uses (locate TODO path)
Agent --> UC7 : uses (finalize task)

' ── Relationships: External Systems ────────────────────────────
UC1 ..> TaskFileSystem : <<reads>>\nsche_tasks/*.json
UC7 ..> TaskFileSystem : <<writes>>\ndone/ completion records
UC3 ..> L4ArchiveSystem : <<calls>>\nbatch_process()

' ── Extend: Scheduled task completion ──────────────────────────
UC1 ..> UC7 : <<extend>>\n(scheduled tasks\nwrite to done/)

@enduml
