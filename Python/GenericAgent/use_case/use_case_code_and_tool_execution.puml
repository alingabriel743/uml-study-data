@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Code Execution & General Agent Actions

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────────

actor "Agent" as Agent
actor "User" as User

actor "OS Process\n(subprocess)" as OSProcess #DDE8F0
actor "File System" as FileSystem #DDE8F0
actor "Browser\n(TMWebDriver)" as Browser #DDE8F0

' ── System Boundary ──────────────────────────────────────────────────────────

rectangle "Generic Agent Tool Layer\n(ga.py + simphtml.py)" {

    ' ── Code Execution ───────────────────────────────────────────────────────
    package "Code Execution" {
        usecase "Execute Python Script" as UC01
        usecase "Inline Eval (Python)" as UC01a
        usecase "Execute Shell Command" as UC02
        usecase "Prepend Code Run Header" as UC09
        usecase "Stream Subprocess Output" as UC10
    }

    ' ── File Operations ──────────────────────────────────────────────────────
    package "File Operations" {
        usecase "Read File" as UC03
        usecase "Write File" as UC04
        usecase "Patch File" as UC05
    }

    ' ── Browser & Web ────────────────────────────────────────────────────────
    package "Browser & Web" {
        usecase "Scan Web Page" as UC06
        usecase "Execute JavaScript in Browser" as UC07
        usecase "Save JS Result to File" as UC07a
        usecase "Optimise HTML for Tokens" as UC11
        usecase "Cut Repetitive List Items" as UC12
        usecase "Monitor DOM Changes" as UC13
    }

    ' ── Agent Memory & Control ───────────────────────────────────────────────
    package "Agent Memory & Control" {
        usecase "Ask User for Input" as UC08
        usecase "Update Working Checkpoint" as UC14
        usecase "Trigger Long-Term Memory Update" as UC15
    }
}

' ── Agent → Use Cases ────────────────────────────────────────────────────────

Agent --> UC01
Agent --> UC02
Agent --> UC03
Agent --> UC04
Agent --> UC05
Agent --> UC06
Agent --> UC07
Agent --> UC08
Agent --> UC14
Agent --> UC15

' ── User Interactions ────────────────────────────────────────────────────────

User --> UC08 : answers interrupt

' ── External Systems ─────────────────────────────────────────────────────────

UC01 --> OSProcess : spawns subprocess
UC02 --> OSProcess : spawns subprocess
UC03 --> FileSystem : reads
UC04 --> FileSystem : writes
UC05 --> FileSystem : reads & writes
UC06 --> Browser : get_all_sessions / get_html
UC07 --> Browser : execute_js

' ── Include Relationships ────────────────────────────────────────────────────

UC01 ..> UC09 : <<include>>
UC01 ..> UC10 : <<include>>
UC02 ..> UC10 : <<include>>
UC06 ..> UC11 : <<include>>
UC06 ..> UC12 : <<include>>
UC07 ..> UC13 : <<include>>

' ── Extend Relationships ─────────────────────────────────────────────────────

UC01a ..> UC01 : <<extend>>\ninline_eval=True
UC07a ..> UC07 : <<extend>>\nsave_to_file provided

@enduml
