@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Desktop & Web UI Interactions

left to right direction

actor "User" as user
actor "GeneraticAgent\n(Backend)" as agent #D0E8FF

rectangle "Desktop & Web UI System" {

    rectangle "Qt Desktop App\n(PySide6)" as QtApp {
        usecase "Toggle Chat Panel\nVisibility" as UC05
        usecase "Drag / Reposition\nFloating Button" as UC06
        usecase "Send Chat Message" as UC01_qt
        usecase "View Streamed\nResponse" as UC02_qt
        usecase "Stop / Abort Task" as UC03_qt
        usecase "Upload File\nAttachment" as UC07
        usecase "Browse Chat\nHistory" as UC08
        usecase "Browse SOP /\nKnowledge" as UC09
        usecase "Configure Settings\n& Switch LLM" as UC10
        usecase "Copy / Regenerate\nMessage" as UC11
    }

    rectangle "Streamlit Web UI v1\n(stapp.py)" as StApp {
        usecase "Send Chat Message" as UC01_st1
        usecase "View Streamed\nResponse" as UC02_st1
        usecase "Stop / Abort Task" as UC03_st1
        usecase "Switch LLM\nBackend" as UC04_st1
        usecase "View Turn Summaries\n(Folded)" as UC13
        usecase "Enable / Disable\nAutonomous Mode" as UC14_st1
        usecase "Reinject Tools /\nSystem Prompt" as UC15_st1
        usecase "Launch Desktop\nPet" as UC12
    }

    rectangle "Streamlit Web UI v2\n(stapp2.py — Anthropic Theme)" as StApp2 {
        usecase "Send Chat Message" as UC01_st2
        usecase "View Streamed\nResponse" as UC02_st2
        usecase "Stop / Abort Task" as UC03_st2
        usecase "Switch LLM\nBackend" as UC04_st2
        usecase "Enable / Disable\nAutonomous Mode" as UC14_st2
        usecase "Reinject Tools /\nSystem Prompt" as UC15_st2
        usecase "Rename Agent" as UC17
        usecase "Adjust Font Size" as UC18
    }

    rectangle "Desktop Pet Companion\n(desktop_pet_v2.pyw — HTTP :41983)" as DesktopPet {
        usecase "Receive Turn\nNotification" as UC16
        usecase "Animate State\n(walk / idle)" as UC16b
    }

}

' --- User → Qt App ---
user --> UC05
user --> UC06
user --> UC01_qt
user --> UC02_qt
user --> UC03_qt
user --> UC07
user --> UC08
user --> UC09
user --> UC10
user --> UC11

' --- User → StApp ---
user --> UC01_st1
user --> UC02_st1
user --> UC03_st1
user --> UC04_st1
user --> UC13
user --> UC14_st1
user --> UC15_st1
user --> UC12

' --- User → StApp2 ---
user --> UC01_st2
user --> UC02_st2
user --> UC03_st2
user --> UC04_st2
user --> UC14_st2
user --> UC15_st2
user --> UC17
user --> UC18

' --- User → Desktop Pet ---
user --> UC16

' --- Agent backend involvement ---
agent --> UC02_qt : streams response
agent --> UC02_st1 : streams response
agent --> UC02_st2 : streams response
agent --> UC16 : turn-end hook\n(HTTP GET :41983)

' --- Include relationships ---
UC01_qt ..> UC02_qt : <<include>>
UC01_st1 ..> UC02_st1 : <<include>>
UC01_st2 ..> UC02_st2 : <<include>>

UC12 ..> UC16 : <<include>>\nlaunches & hooks

UC16 ..> UC16b : <<include>>

@enduml
