@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title LLM Backend Integration

left to right direction

' ── Actors ────────────────────────────────────────────
actor "Agent" as Agent
actor "Developer" as Developer

actor "Anthropic API" as AnthropicAPI
actor "OAI-Compatible API" as OAIAPI
actor "MiniMax API" as MiniMaxAPI

' ── System boundary ───────────────────────────────────
rectangle "LLM Backend Integration" {

    ' ── Configuration ──────────────────────────────
    usecase "Load API Credentials" as UC01
    usecase "Configure Session\n(ClaudeSession / LLMSession\n/ NativeClaudeSession\n/ NativeOAISession)" as UC02
    usecase "Apply Thinking Mode\n(adaptive / enabled / disabled)" as UC12

    ' ── Core send / receive ────────────────────────
    usecase "Send Prompt &\nStream Response" as UC03
    usecase "Send to Anthropic API\n(Text Protocol)" as UC04
    usecase "Send to OAI-Compatible API\n(Text Protocol)" as UC05
    usecase "Send to Anthropic API\n(Native Tool Protocol)" as UC06
    usecase "Send to OAI API\n(Native Tool Protocol)" as UC07

    ' ── Fallback & resilience ──────────────────────
    usecase "Fail Over Across\nMultiple Backends\n(MixinSession)" as UC08

    ' ── History & token management ─────────────────
    usecase "Trim Message History\n(context window)" as UC10
    usecase "Compress History Tags\n(thinking / tool blocks)" as UC09
    usecase "Optimize Token Budget\n(tool-prompt deduplication)" as UC11

    ' ── Client wrappers ────────────────────────────
    usecase "Chat via Text Protocol\nWrapper (ToolClient)" as UC15
    usecase "Chat via Native Tool\nProtocol Wrapper\n(NativeToolClient)" as UC16

    ' ── SSE parsing ────────────────────────────────
    usecase "Parse Streaming SSE\nResponse (Anthropic)" as UC13
    usecase "Parse Streaming SSE\nResponse (OAI)" as UC14
}

' ── Developer associations ────────────────────────────
Developer --> UC01
Developer --> UC02
Developer --> UC12

' ── Agent associations ────────────────────────────────
Agent --> UC03
Agent --> UC08
Agent --> UC09
Agent --> UC10
Agent --> UC11
Agent --> UC15
Agent --> UC16

' ── External system associations ─────────────────────
AnthropicAPI --> UC04
AnthropicAPI --> UC13
OAIAPI --> UC07
OAIAPI --> UC14
MiniMaxAPI --> UC05
MiniMaxAPI --> UC06

' ── Include relationships ─────────────────────────────
UC03 .> UC10 : <<include>>
UC03 .> UC04 : <<include>>
UC03 .> UC05 : <<include>>

UC10 .> UC09 : <<include>>

UC15 .> UC11 : <<include>>
UC15 .> UC03 : <<include>>

UC16 .> UC06 : <<include>>
UC16 .> UC07 : <<include>>

UC08 .> UC03 : <<include>>

' ── Extend relationships ──────────────────────────────
UC04 .> UC12 : <<extend>>
UC06 .> UC12 : <<extend>>

UC04 .> UC13 : <<extend>>
UC06 .> UC13 : <<extend>>

UC05 .> UC14 : <<extend>>
UC07 .> UC14 : <<extend>>

UC02 .> UC01 : <<include>>

@enduml
