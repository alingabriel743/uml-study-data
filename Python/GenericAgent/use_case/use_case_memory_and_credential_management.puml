@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Memory & Credential Management

left to right direction

actor "Agent / User" as Agent
actor "File System" as FileSystem #E3F2FD
actor "Skill Search API" as SkillSearchAPI #E8F5E9

rectangle "Memory & Credential Management" {

    package "Keychain (keychain.py)" #EEF2FF {
        usecase "Store API Key / Secret\n<size:10>[keys.set(k, v)]</size>" as UC1
        usecase "Retrieve Secret\n<size:10>[keys.<name> → SecretStr]</size>" as UC2
        usecase "List Stored Keys\n<size:10>[keys.ls()]</size>" as UC3
        usecase "Load Keychain from Disk\n<size:10>[_Keys.__init__()]</size>" as UC4
    }

    package "Session Archiving (compress_session.py)" #FFF8E1 {
        usecase "Batch Archive Sessions\n<size:10>[batch_process(src, ...)]</size>" as UC7
        usecase "Compress Session File\n<size:10>[compress_session(src)]</size>" as UC5
        usecase "Extract Conversation History\n<size:10>[extract_history(src)]</size>" as UC6
    }

    package "Skill Search (engine.py)" #F1F8E9 {
        usecase "Search for Skills\n<size:10>[search(query, env, top_k)]</size>" as UC8
        usecase "Get Skill Index Stats\n<size:10>[get_stats(env)]</size>" as UC10
        usecase "Detect Environment\n<size:10>[detect_environment()]</size>" as UC9
    }
}

' --- Agent connections ---
Agent --> UC1 : stores secret
Agent --> UC2 : retrieves secret
Agent --> UC3 : lists keys
Agent --> UC5 : compresses session
Agent --> UC7 : batch archives sessions
Agent --> UC8 : searches skills
Agent --> UC10 : queries index stats

' --- FileSystem connections ---
FileSystem --> UC4 : loads ~/ga_keychain.enc\nat startup
UC1 --> FileSystem : writes encrypted\n~/ga_keychain.enc
UC5 --> FileSystem : reads raw .txt /\nwrites compressed .txt
UC7 --> FileSystem : reads/writes zip\narchives & all_histories.txt

' --- Skill Search API connections ---
UC8 --> SkillSearchAPI : POST /search\n(Bearer token)
UC10 --> SkillSearchAPI : GET /stats

' --- Include / Extend relationships ---
UC7 ..> UC5 : <<include>>
UC7 ..> UC6 : <<include>>
UC8 ..> UC9 : <<include>>
UC10 ..> UC9 : <<include>>
UC2 ..> UC3 : <<extend>>\n(list keys first)

note bottom of UC4
  Auto-loads on import.
  Corrupt file → renamed to .enc.bak;
  fresh empty keychain started.
end note

note right of UC1
  XOR-encrypts JSON dict with
  SHA-256(username)-derived mask.
end note

note right of UC2
  Returns SecretStr — value is
  masked in __repr__ to prevent
  accidental log leaks.
end note

@enduml
