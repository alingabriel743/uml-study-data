@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #4A90D9
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
    FontStyle bold
}

title Messaging Frontend Interactions

left to right direction

' ── Abstract / general actor ──────────────────────────────────────────────────
actor "Platform User\n〈all 6 frontends〉" as PlatformUser

' ── Concrete platform actors ──────────────────────────────────────────────────
actor "Telegram User" as TgUser
actor "QQ User"       as QQUser
actor "DingTalk User" as DTUser
actor "WeCom User"    as WCUser
actor "WeChat User"   as WXUser
actor "Feishu/Lark User" as FsUser

' ── Backend system actor ──────────────────────────────────────────────────────
actor "GeneraticAgent\n(Backend)" as Agent <<system>>

' ── Generalisations: concrete → abstract ─────────────────────────────────────
TgUser    --|> PlatformUser
QQUser    --|> PlatformUser
DTUser    --|> PlatformUser
WCUser    --|> PlatformUser
WXUser    --|> PlatformUser
FsUser    --|> PlatformUser

' ══════════════════════════════════════════════════════════════════════════════
rectangle "Messaging Platform Frontend Layer" {

    ' ── Core messaging ──────────────────────────────────────────────────────
    usecase "Send Text Message"          as UC1
    usecase "Receive Agent Response"     as UC2
    usecase "Access Control /\nAuthorization" as UC11

    ' ── Command use cases ───────────────────────────────────────────────────
    usecase "Stop Running Task\n(/stop / /abort)"          as UC3
    usecase "Switch LLM Model\n(/llm [n])"                 as UC4
    usecase "Clear Conversation\nContext  (/new)"          as UC5
    usecase "Restore Conversation\nHistory  (/restore)"    as UC6
    usecase "View Agent Status\n(/status)"                 as UC7
    usecase "View Help\n(/help)"                           as UC8

    ' ── Media & file use cases ──────────────────────────────────────────────
    usecase "Send / Receive Files"   as UC9
    usecase "Send Media Messages\n(image / audio / video)" as UC10

    ' ── Platform-specific use cases ─────────────────────────────────────────
    usecase "QR Code Login"           as UC12
    usecase "Receive Welcome Message" as UC13
    usecase "Send Group Message"      as UC14

    ' ── Relationships between use cases ─────────────────────────────────────
    UC2  <.. UC9 : <<extend>>
    UC10 ..> UC1 : <<include>>
}

' ══════════════════════════════════════════════════════════════════════════════
' Common use cases — all platform users
' ══════════════════════════════════════════════════════════════════════════════
PlatformUser --> UC1
PlatformUser --> UC2
PlatformUser --> UC11
PlatformUser --> UC3
PlatformUser --> UC4
PlatformUser --> UC5

' ── UC6 / UC7 / UC8 : all frontends except WeChat ───────────────────────────
note "Not available\non WeChat" as NoteExclWeChat
UC6 .. NoteExclWeChat
UC7 .. NoteExclWeChat
UC8 .. NoteExclWeChat

TgUser --> UC6
QQUser --> UC6
DTUser --> UC6
WCUser --> UC6
FsUser --> UC6

TgUser --> UC7
QQUser --> UC7
DTUser --> UC7
WCUser --> UC7
FsUser --> UC7

TgUser --> UC8
QQUser --> UC8
DTUser --> UC8
WCUser --> UC8
FsUser --> UC8

' ── Media & file use cases : WeChat + Feishu only ───────────────────────────
WXUser --> UC9
FsUser --> UC9
WXUser --> UC10
FsUser --> UC10

' ── WeChat-only ─────────────────────────────────────────────────────────────
WXUser --> UC12

' ── WeCom-only ──────────────────────────────────────────────────────────────
WCUser --> UC13

' ── Group messaging : QQ + DingTalk ─────────────────────────────────────────
QQUser --> UC14
DTUser --> UC14

' ══════════════════════════════════════════════════════════════════════════════
' Backend agent participates in core messaging use cases
' ══════════════════════════════════════════════════════════════════════════════
Agent --> UC1 : dispatches task\n(put_task)
Agent --> UC2 : streams / returns\nresponse
Agent --> UC3 : aborts running\ntask (abort)
Agent --> UC4 : switches / lists\nLLM models
Agent --> UC5 : clears history

@enduml
