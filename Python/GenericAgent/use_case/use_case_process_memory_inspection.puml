@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Process Memory Inspection

left to right direction

' ── Actors ──────────────────────────────────────────────────
actor "Agent / Operator" as AgentOp
actor "Target Process" as TargetProc

actor "Windows Kernel\n(kernel32.dll)" as WinKernel #E3F2FD
actor "YARA Engine" as YaraEngine #E3F2FD

' ── System Boundary ─────────────────────────────────────────
rectangle "Process Memory Inspection System\n(procmem_scanner.py)" {

    usecase "Scan Process Memory\n<size:10>(scan_memory(pid, pattern, mode, llm_mode))</size>" as UC1
    usecase "Build YARA Pattern Rule\n<size:10>(build_rules(pattern, mode='auto'))</size>" as UC2
    usecase "Open Process Handle\n<size:10>(OpenProcess(PROCESS_QUERY_INFORMATION | PROCESS_VM_READ))</size>" as UC3
    usecase "Enumerate Memory Regions\n<size:10>(VirtualQueryEx → MEMORY_BASIC_INFORMATION)</size>" as UC4
    usecase "Read Memory Region\n<size:10>(ReadProcessMemory → raw bytes buffer)</size>" as UC5
    usecase "Match Pattern in Memory Buffer\n<size:10>(rules.match(data=raw_bytes))</size>" as UC6
    usecase "Format Match Context\n<size:10>(format_llm_context() | hex string)</size>" as UC7
    usecase "Perform Differential\nAddress Scan\n<size:10>(read_addrs(pid, addrs))</size>" as UC8

}

' ── Actor → Use Case associations ───────────────────────────
AgentOp    --> UC1
AgentOp    --> UC2
AgentOp    --> UC7
AgentOp    --> UC8

WinKernel  --> UC3
WinKernel  --> UC4
WinKernel  --> UC5

YaraEngine --> UC6

TargetProc --> UC3 : is opened by >
TargetProc --> UC4 : regions queried from >
TargetProc --> UC5 : bytes read from >

' ── Include relationships ────────────────────────────────────
UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>
UC1 ..> UC5 : <<include>>
UC1 ..> UC6 : <<include>>

UC6 ..> UC7 : <<include>>

UC8 ..> UC3 : <<include>>
UC8 ..> UC5 : <<include>>

' ── Notes ───────────────────────────────────────────────────
note right of UC4
  Filters regions where:
  State == MEM_COMMIT (0x1000)
  AND Protect & 0xEE (readable flags)
end note

note right of UC7
  Two output modes:
  • llm_mode=True → dict
    {address, offset, hex, ascii, hit_pos}
  • default → "Addr: 0x...\nHex: ..." string
end note

note bottom of UC8
  Differential scan workflow:
  full scan → store addresses →
  trigger UI state change →
  re-read addresses →
  filter changed/unchanged →
  converge to unique address
end note

@enduml
