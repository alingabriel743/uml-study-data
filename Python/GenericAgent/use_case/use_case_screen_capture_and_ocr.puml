@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Screen Capture & OCR

left to right direction

' ── Actors ──────────────────────────────────────────────
actor "Agent\n(Automation Client)" as Agent
actor "RapidOCR Engine\n(rapidocr-onnxruntime)" as RapidOCR
actor "YOLO Model\n(OmniParser icon_detect)" as YOLO
actor "Operating System\n(Win32 API)" as OS

' ── System Boundary ─────────────────────────────────────
rectangle "Screen Capture & OCR System" {

    ' Screen Capture use cases
    usecase "Capture Full Screen"                  as UC1
    usecase "Capture Screen Region"                as UC2
    usecase "Capture Window via\nPrintWindow API"  as UC3
    usecase "OCR Image File"                       as UC4

    ' OCR & Detection use cases
    usecase "Extract Text with OCR"                as UC5
    usecase "OCR Text from Image File"             as UC7
    usecase "Detect UI Elements"                   as UC6
    usecase "Visualize Detection Results"          as UC8
}

' ── Actor → Use Case relationships ──────────────────────
Agent      --> UC1
Agent      --> UC2
Agent      --> UC3
Agent      --> UC4
Agent      --> UC6
Agent      --> UC8

RapidOCR   --> UC5
RapidOCR   --> UC7

YOLO       --> UC6

OS         --> UC3 : win32gui /\nPrintWindow

' ── Include / Extend relationships ──────────────────────
UC1 ..> UC4  : <<include>>
UC2 ..> UC4  : <<include>>
UC3 ..> UC4  : <<include>>

UC4 ..> UC5  : <<include>>

UC8 ..> UC6  : <<include>>
UC8 ..> UC7  : <<extend>>\n(HAS_OCR)

note bottom of UC3
  Fallback when RDP session is
  disconnected (ImageGrab → black frame)
end note

note right of UC6
  Returns [{bbox, confidence, class}]
  Model: ../temp/weights/icon_detect/model.pt
end note

@enduml
