@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7FD5
    FontColor #1A1A2E
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Web Browsing & JavaScript Execution

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────────

actor "Agent\n(ga.py)" as Agent
actor "Browser\nExtension" as Extension #D0F0C0
actor "Browser\nTab" as BrowserTab #F0E0FF
actor "Remote\nTMWebDriver" as RemoteDriver #FFE4CC

' ── System Boundary ──────────────────────────────────────────────────────────

rectangle "TMWebDriver Browser Automation System" {

    usecase "Initialize Driver\n(start WS :18765 + HTTP :18766)" as UC1
    usecase "Connect Browser\nSession" as UC2
    usecase "Find / Select\nSession" as UC3
    usecase "Execute JavaScript\nin Browser" as UC4
    usecase "Navigate Browser\n(Jump / New Tab)" as UC5
    usecase "Scan Page HTML" as UC6
    usecase "Monitor Page\nChanges" as UC7
    usecase "Handle Session\nReconnect / Disconnect" as UC8
    usecase "Receive Long-Poll\nCommands (HTTP Mode)" as UC9
    usecase "Execute CDP /\nCookie / Batch Commands" as UC10
    usecase "Proxy Commands\nto Remote Driver" as UC11

}

' ── Agent relationships ───────────────────────────────────────────────────────

Agent --> UC1 : initialise
Agent --> UC3 : query / set\ntarget session
Agent --> UC4 : submit JS code
Agent --> UC5 : navigate / open tab
Agent --> UC6 : fetch page HTML
Agent --> UC7 : detect DOM changes
Agent --> UC10 : send CDP / cookie\n/ batch command
Agent --> UC11 : is_remote=True

' ── Browser Extension relationships ──────────────────────────────────────────

Extension --> UC2 : ws connect\n(ext_ready / tabs_update)
Extension --> UC4 : return JS result\nor error
Extension --> UC8 : reconnect /\ndisconnect event

' ── Browser Tab relationships ─────────────────────────────────────────────────

BrowserTab --> UC9 : long-poll /api/longpoll\npost /api/result

' ── Remote Driver relationship ────────────────────────────────────────────────

RemoteDriver --> UC11 : accepts HTTP\nPOST /link

' ── Include / Extend relationships ───────────────────────────────────────────

UC4 ..> UC2 : <<include>>\n(requires active session)
UC5 ..> UC4 : <<include>>\n(navigate via execute_js)
UC6 ..> UC4 : <<include>>\n(fetch HTML via execute_js)
UC7 ..> UC4 : <<include>>\n(before/after DOM diff)
UC10 ..> UC4 : <<include>>\n(routes through JS dispatch)
UC4 <.. UC9 : <<extend>>\n(HTTP fallback transport)
UC4 <.. UC11 : <<extend>>\n(remote proxy path)

' ── Notes ─────────────────────────────────────────────────────────────────────

note right of UC4
  Dispatch flow:
  1. Agent → execute_js(code)
  2. Driver → ws_client.send_message()
     OR http_queue.put()  [HTTP mode]
  3. Extension → chrome.scripting.executeScript
     (MAIN world) OR CDP fallback (CSP pages)
  4. Extension → {type:result, id, result}
  5. Driver returns {data, newTabs}
  ACK protocol resets timeout on receipt.
end note

note bottom of UC2
  Session types:
  • ws  — content-script WebSocket
  • ext_ws — extension manages all tabs
  • http — long-poll fallback
end note

note bottom of UC8
  Inactive sessions (>600 s) auto-deleted.
  execute_js auto-failovers to alive session
  when default is disconnected.
end note

@enduml
