@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Environment Setup & Validation\n<size:11>(Lyra-1/scripts/test_environment.py)</size>

|Script (Module Level)|
start

:Module is imported / executed;

|parse_args()|
:Parse CLI arguments\nusing argparse;
note right
  --training flag (store_true)
  Default: False
end note
:Return Namespace\n(.training: bool);

|Script (Module Level)|
:Receive args Namespace;

' ─── Python Version Check ───────────────────────────
:Check Python version\n(sys.version_info);

if (major == 3\nAND minor >= 10?) then (PASS)
    :Continue;
else (FAIL)
    #FFB3B3:Print ERROR:\nDetected Python version;
    note right: **HARD FAIL**\nFatal — script cannot\ncontinue
    :sys.exit(1);
    stop
endif

' ─── Conda Environment Check ────────────────────────
:Check os.environ\nfor 'CONDA_PREFIX';

if ('CONDA_PREFIX'\nin environment?) then (SET)
    :Continue;
else (NOT SET)
    #FFF3CD:Print WARNING:\nConda environment\nnot detected;
    note right: **SOFT WARNING**\nNon-fatal — execution\ncontinues
endif

' ─── Package Import Phase ───────────────────────────
:Print "Attempting to import\ncritical packages...";
:SET all_success = True;

:Define base package list:\ntorch, torchvision, diffusers,\ntransformers, megatron.core,\ntransformer_engine;

|check_packages()|
:Receive base package list;

repeat
    :Call importlib.import_module(package);
    if (Import\nSuccessful?) then (yes)
        #C3E6CB:Print [SUCCESS] <package>;
    else (no — ImportError\nor Exception)
        #FFB3B3:Print [ERROR] <package>;
        :Set global\nall_success = False;
    endif
repeat while (More packages\nin list?) is (yes)
-> no;

|Script (Module Level)|
:Return from check_packages();

' ─── Training-Only Package Check ────────────────────
if (args.training\n== True?) then (yes)
    :Define training package list:\napex.multi_tensor_apply;

    |check_packages()|
    :Receive training package list;

    repeat
        :Call importlib.import_module(package);
        if (Import\nSuccessful?) then (yes)
            #C3E6CB:Print [SUCCESS] <package>;
        else (no — ImportError\nor Exception)
            #FFB3B3:Print [ERROR] <package>;
            :Set global\nall_success = False;
        endif
    repeat while (More training\npackages?) is (yes)
    -> no;

    |Script (Module Level)|
    :Return from check_packages();

else (no)
    :Skip training\npackage check;
endif

' ─── Final Result ────────────────────────────────────
if (all_success\n== True?) then (yes)
    #C3E6CB:Print final\nSUCCESS banner;
else (no)
    :End silently\n(failures already\nprinted inline);
    note right
      Exit code: 0 (implicit)
      Package failures are
      non-fatal at OS level
    end note
endif

stop

@enduml
