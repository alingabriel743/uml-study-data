@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Guardrail Checkpoint Download

|Script Entry|
start
:Invoke script as \`__main__\`;
:Call **download_guardrail_checkpoints**("checkpoints");

|download_guardrail_checkpoints|
:Define **models_to_download** list:
  • meta-llama/Llama-Guard-3-8B  (text guardrail)
  • nvidia/Cosmos-Guardrail1       (video guardrail);
:os.makedirs(destination_root, exist_ok=True)
  — ensure destination directory exists;
:Call **download_models**(models_to_download, destination_root);

|download_models|
:Iterate over each model_id in models list;

repeat

  if (Does model_id contain ':'?) then (yes)
    :Split model_id on ':'
    → extract **model_id** and **revision**;
  else (no)
    :Keep model_id as-is
    Set **revision** = None;
  endif

  :Print "Downloading {model_id}...";
  :Compute **model_path** =
    os.path.join(destination_root, model_id);

  |HuggingFace Hub|
  :Call **snapshot_download**(
    repo_id   = model_id,
    local_dir = model_path,
    revision  = revision
  );

  |download_models|
  if (Download succeeded?) then (yes)
    :Print "Successfully downloaded
    {model_id} to {model_path}";
  else (no — Exception raised)
    :Catch Exception;
    #FFD6D6:Raise **RuntimeError**:
    "Error downloading {model_id}: <msg>.
    Please delete the directory and try again.";
    kill
  endif

repeat while (More models to download?) is (yes) not (no)

|Script Entry|
:All guardrail checkpoints downloaded successfully;
stop

@enduml
