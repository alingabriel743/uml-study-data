@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
}

title Prompt Upsampling Flow

|Pipeline|
start
:generate(prompt, negative_prompt,\nword_limit_to_skip_upsampler);

if (enable_prompt_upsampler == True?) then (yes)
  :Compute word_count = len(prompt.split());
  if (word_limit is None\nOR word_count <= word_limit?) then (yes)

    |#D4EDDA|Prompt Upsampler|
    if (offload_prompt_upsampler == True?) then (yes)
      :_load_prompt_upsampler_model()
      from checkpoint_dir / prompt_upsampler_dir;
    else (no)
      note right
        Model already resident
        in memory from __init__
      end note
    endif

    if (Pipeline type?) then (Text2World)
      :_run_prompt_upsampler_on_prompt(prompt: str);
      :run_chat_completion(prompt_upsampler, prompt);
    else (Video2World)
      :_run_prompt_upsampler_on_prompt\n(image_or_video_path: str);
      :prepare_dialog(image_or_video_path) → dialog;
      :run_chat_completion_vlm(prompt_upsampler, dialog,\nmax_gen_len=400, temp=0.01, top_p=0.9);
    endif

    :Log upsampled_prompt;

    if (offload_prompt_upsampler == True?) then (yes)
      :_offload_prompt_upsampler_model();
      :del self.prompt_upsampler
      gc.collect()
      torch.cuda.empty_cache();
    else (no)
      :Keep model in GPU memory;
    endif

    :Return enhanced_prompt;

    |Pipeline|
    :Receive upsampled_prompt;

    if (disable_guardrail == False\nAND prompt was upsampled?) then (yes)
      |#FDECEA|Guardrail|
      :_run_guardrail_on_prompt_with_offload\n(upsampled_prompt);
      if (Prompt is safe?) then (yes)
        |Pipeline|
        :Continue with upsampled prompt;
      else (no)
        :Log CRITICAL safety violation;
        :Return None (abort generation);
        stop
      endif
    else (no)
      :Continue with upsampled prompt\n(guardrail disabled);
    endif

  else (no)
    :Log skip reason
    (word_count > word_limit);
    :Use raw prompt (unchanged);
  endif

else (no)
  :Use raw prompt\n(upsampling disabled);
endif

|Pipeline|
:Proceed with text encoding\nand video diffusion generation;
:Return (video_frames, final_prompt);
stop

@enduml
