@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
    BarColor #495057
}

skinparam swimlane {
    BorderColor #6C757D
    TitleFontColor #212529
    TitleFontSize 13
    TitleBackgroundColor #E9ECEF
}

title Tokenizer Checkpoint Download\n<size:11>(NVIDIA Cosmos-Tokenize1 — HuggingFace with MD5 Integrity Verification)</size>

|__main__ / CLI|
start
:Invoke script via command line;
:Call **parse_args()**\n  --tokenizer_types (nargs=*)\n  --checkpoint_dir (default: "checkpoints");
note right
  Default: all 8 tokenizer types
  CV8x8x8-720p, DV8x16x16-720p,
  CI8x8-360p, CI16x16-360p,
  CV4x8x8-360p, DI8x8-360p,
  DI16x16-360p, DV4x8x8-360p
end note

|main()|
:Receive parsed **args**;
:Set ORG_NAME = "nvidia";
:Build **model_map**\n  (8 shorthand keys → HuggingFace repo names);
:Resolve **checkpoints_dir** = Path(args.checkpoint_dir)\nmkdir(parents=True, exist_ok=True);
:Define **download_kwargs**\n  allow_patterns:\n  README.md, model.pt, mean_std.pt,\n  config.json, *.jit;

|main()|
:Iterate over **args.tokenizer_types**;

repeat

  :Resolve **model_name** = model_map[tokenizer_type]\nBuild **repo_id** = "nvidia/{model_name}"\nSet **local_dir** = checkpoints_dir / model_name;

  |MD5 Verification|
  :Call **get_md5_checksum**(checkpoints_dir, model_name);
  :Iterate **MD5_CHECKSUM_LOOKUP** entries\nwhere key starts with model_name;

  repeat
    :Pick next matching entry\n  key = "ModelName/filename"\n  expected_md5 = lookup value;
    :Build **file_path** = checkpoints_dir / key;

    if (file_path exists?) then (no)
      :Print "Checkpoint {key} does not exist.";
      :Return **False**;
      detach
    else (yes)
      :Open file in binary mode\nCompute **file_md5** =\nhashlib.md5(f.read()).hexdigest();
      if (file_md5 == expected_md5?) then (no)
        :Print "MD5 checksum does not match.";
        :Return **False**;
        detach
      else (yes)
        :File verified — continue;
      endif
    endif
  repeat while (more entries for model_name?) is (yes)
  ->no;

  :Print "Model checkpoints exist\nwith matched MD5 checksums.";
  :Return **True**;

  |main()|
  if (get_md5_checksum returned False\n(files missing or MD5 mismatch)?) then (yes — download needed)
    :Create **local_dir** mkdir\n(parents=True, exist_ok=True);
    :Print "Downloading {repo_id} to {local_dir}...";

    |HuggingFace Hub|
    :Call **snapshot_download**(\n  repo_id = "nvidia/{model_name}"\n  local_dir = str(local_dir)\n  local_dir_use_symlinks = False\n  allow_patterns = [*.jit, model.pt,\n  mean_std.pt, config.json, README.md]\n);
    note right
      Downloads artifact files:
      autoencoder.jit, encoder.jit,
      decoder.jit, mean_std.pt
      (portable copies, no symlinks)
    end note

    |main()|
    :Checkpoint files saved to local_dir;
  else (no — already valid, skip)
    :Skip download for this model;
  endif

repeat while (more tokenizer_types?) is (yes)
->no;

|Guardrail Downloader|
:Call **download_guardrail_checkpoints**(args.checkpoint_dir);
note right
  Always runs after all
  tokenizer downloads complete,
  regardless of which tokenizer
  types were selected.
end note
:Guardrail checkpoints saved;

|main()|
stop

@enduml
