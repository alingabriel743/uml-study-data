@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #495057
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #DEE2E6
    TitleFontColor #212529
    TitleFontSize 13
}

title Main Training Pipeline\n(Lyra-1 / train.py)

|CLI / Config|
start
:Parse CLI args\n--config, --config_default\n--wandb_run_name, --wandb_group_name;
:Load YAML schema (config_default)\nMerge with config YAML + CLI dotlist\nvia OmegaConf;
:Call main(config, wandb_run_name,\nwandb_group_name, app_start_time);

|Setup|
:prepare_config(config)\nSet LOCAL_RANK from env\nSet vae_path default, use_lora default;

:Build Accelerator\n(configure DDP kwargs, AutocastKwargs);

if (use_fsdp?) then (yes)
    :Add FSDP plugin to Accelerator;
elseif (use_deepspeed?) then (yes)
    :Add DeepSpeed plugin\n(ZeRO Stage 2);
else (no)
endif

:Set logging verbosity\n(main vs. non-main process);

if (seed provided?) then (yes)
    :set_seed(config.seed);
else (no)
endif

if (main process?) then (yes)
    :mkdir output_dir\nSave config.yaml via OmegaConf.save;
else (no)
endif

:Load VAE: load_vae(vae_backbone, vae_path)\ninside deepspeed_zero_init_disabled context;
:Determine weight_dtype\n(fp16 / bf16) from mixed_precision;
:Instantiate LatentRecon transformer\nfrom config;

if (lambda_lpips > 0?) then (yes)
    :Load LPIPS perceptual loss module;
else (no)
endif

if (resume_pretrained_model_ckpt set?) then (yes)
    :Load pretrained weights\ninto transformer;
else (no)
endif

:transformer.train()\ntransformer.requires_grad_(False)\nCast VAE / modules to weight_dtype;

if (compile_frozen_modules?) then (yes)
    :torch.compile(vae.encode);
else (no)
endif

if (use_lora?) then (yes)
    :Add LoRA adapter via\npeft.LoraConfig to transformer;
else (no)
endif

:Define save_model_hook\n(saves transformer, EMA, LoRA weights);
:Define load_model_hook\n(loads transformer from pretrained subfolder);

if (FSDP or DeepSpeed?) then (no)
    :Register save/load hooks\nwith Accelerator;
else (yes)
endif

|Optimizer Setup|
if (allow_tf32?) then (yes)
    :Enable TF32 on CUDA;
else (no)
endif

if (scale_lr?) then (yes)
    :LR *= grad_accum\n× batch_size × num_processes;
else (no)
endif

if (use_8bit_adam?) then (yes)
    :Select bitsandbytes AdamW8bit;
else (no)
    :Select torch.optim.AdamW;
endif

if (transformer_trainable_modules set?) then (yes)
    :Build selective params list\nfrom trainable module names;
else (no)
    :Use all transformer parameters;
endif

if (use_fsdp?) then (yes)
    :accelerator.prepare(transformer)\nbefore optimizer creation;
else (no)
endif

:Create optimizer\n(lr, betas, weight_decay, eps);
:Create lr_scheduler via get_scheduler\n(lr_scheduler, warmup, max_train_steps);

if (use_fsdp?) then (no)
    :accelerator.prepare\n(transformer, optimizer, lr_scheduler);
else (yes)
endif

|Setup|
if (main process?) then (yes)
    :Init trackers (wandb)\nwith experiment_name, run/group names;
else (no)
endif

:resume_from_ckpt(config, accelerator, transformer)
→ initial_global_step, global_step,
  first_epoch, loaded_accelerator;

if (resume_from_checkpoint found?) then (yes)
    :accelerator.load_state(path_ckpt)\n[fallback: load_model_weights];
    :Parse global_step from\ncheckpoint folder name;
else (no)
    if (first run & seed set?) then (yes)
        :Reset seed (device_specific=True)\nfor data loading;
    else (no)
    endif
endif

if (lr_overwrite set?) then (yes)
    :Overwrite LR\nRecreate lr_scheduler;
else (no)
endif

:Create dataloaders\nget_multi_dataloader(config, accelerator)\n→ train_dataloader, test_dataloader;

|Training Loop|
:Initialize progress_bar\nglobal_step counter, break_loop = False;

while (break_loop == False?) is (continue)
    :Iterate: for step, batch\nin train_dataloader;

    |Train Step|
    :Move batch tensors to accelerator.device\nCast to weight_dtype\n(except intrinsics / c2ws);

    if ('rgb_latents' in batch?) then (yes)
        :Use pre-encoded latents directly;
    else (no)
        :encode_multi_view_video(vae, video, ...)\n→ batch['images_input_embed'];
    endif

    if (compute_plucker_cuda?) then (yes)
        :Compute Plucker embeddings on GPU\nget_plucker_embedding_and_rays\n(intrinsics, c2ws, img_size, patch_size);
    else (no)
    endif

    if (use_time_embedding + time_embedding_vae?) then (yes)
        :encode_latent_time_vae;
    else (no)
    endif

    if (plucker_embedding_vae?) then (yes)
        :encode_plucker_vae;
    else (no)
    endif

    :Forward pass inside\naccelerator.accumulate(transformer)\nmodel_output = transformer(batch);
    :Extract pred_images, pred_depths,\npred_opacity from model_output;
    :compute_loss(accelerator, train_loss,\npred_images, gt_images,\npred_depths, gt_depths,\npred_opacity, config, lpips_loss_module);
    :accelerator.backward(loss);

    if (accelerator.sync_gradients?) then (yes)
        :clip_grad_norm_(transformer.parameters(),\nmax_grad_norm);
        :Check inf/NaN via scaler;
    else (no)
    endif

    :optimizer.step()\nlr_scheduler.step()\noptimizer.zero_grad();

    |Training Loop|
    if (accelerator.sync_gradients?) then (yes)
        :Update progress_bar\nIncrement global_step\nLog train_loss + lr to tracker;

        if (global_step % checkpointing_steps == 0?) then (yes)
            |Checkpointing|
            if (checkpoints_total_limit exceeded?) then (yes)
                :Remove oldest non-permanent\ncheckpoint directory;
            else (no)
            endif
            :accelerator.save_state\n(checkpoint-{global_step});
            if (save_random_state?) then (yes)
                :Save per-process random state\n(for reproducible resumption);
            else (no)
            endif
            |Training Loop|
        else (no)
        endif

        if (global_step % job_stop_steps == 0?) then (yes)
            :Set break_loop = True;
            break
        else (no)
        endif

        if (global_step >= max_train_steps?) then (yes)
            :Set break_loop = True;
            break
        else (no)
        endif
    else (no)
    endif

    :Update progress_bar postfix\n(step_loss, lr, dir,\noverflow flag if grad skipped);
endwhile (break_loop)

|Setup|
:accelerator.wait_for_everyone();
:accelerator.end_training();
stop

@enduml
