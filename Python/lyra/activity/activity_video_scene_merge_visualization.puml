@startuml activity_video_scene_merge_visualization

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    StartColor #212529
    EndColor #212529
    BarColor #495057
}

skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}

title Dynamic Video Scene Merging & Visualization\n<size:11><color:#6C757D>dynamic_scene_merge.py — FPS Probing, Path Escaping & Scene Clip Concatenation</color></size>

|CLI / Entry Point|
start
:Parse CLI arguments;
note right
  <b>parse_args()</b>
  • input_dirs (positional, nargs='+')
  • --strides / -s (int list, required)
  • --output_dir / -o (required)
end note
:Call process_and_concat\n(input_dirs, strides, output_dir);

|process_and_concat|
if (len(strides) != len(input_dirs)?) then (yes)
    :Raise ValueError\n"stride count mismatch";
    stop
else (no)
endif

:os.makedirs(output_dir, exist_ok=True);
:Collect .mp4 files from each input_dir\n<i>mp4s(d) closure for each directory</i>;
:Compute common_files =\nset.intersection of all mp4 sets;

if (common_files is empty?) then (yes)
    :Print warning message;
    stop
else (no)
endif

:tempfile.mkdtemp(prefix='stride_concat_')\n→ temp_root;
note right
  All intermediate segment files
  are written here and cleaned
  up in the finally block
end note

|process_and_concat|
:BEGIN try/finally block;

repeat
    :Select next filename\nfrom sorted(common_files);

    |ffprobe_fps|
    :Run ffprobe subprocess\non reference input file\n(input_dirs[0] / filename);
    :Extract avg_frame_rate\nfrom video stream metadata;

    if (avg_frame_rate invalid?\n('0/0', '', or 'N/A')) then (yes)
        :Re-probe using\nr_frame_rate field instead;
    else (no)
    endif

    if (Fraction(val) parseable?) then (yes)
        :fps = float(Fraction(val));
    else (no — parse error)
        :fps = 30.0 (fallback default);
    endif
    :Return fps float to caller;

    |process_and_concat|
    :Initialize processed_segments list;

    repeat
        :Select next (input_dir_i, stride_i)\nfrom zip(input_dirs, strides);

        |subsample_one|
        :Build segment temp path:\ntemp_root/NN__dirname__filename;
        :Run ffmpeg subprocess with filter:\nselect='not(mod(n,stride))'\nsetpts=N/FRAME_RATE/TB\nfps=fps=target_fps;
        note right
          <b>Encode params:</b>
          codec: libx264
          crf: 18, preset: fast
          pixel format: yuv420p
          audio: dropped (-an)
        end note
        :Write encoded segment\nto temp path (seg_i.mp4);
        :Return seg path to caller;

        |process_and_concat|
        :Append seg to processed_segments list;

    repeat while (more (dir, stride) pairs?) is (yes)
    -> no (all dirs processed);

    |process_and_concat|
    :Build concat list file path:\ntemp_root/list_<filename>.txt;

    fork
        :Compute absolute path\nfor each segment (os.path.abspath);
    fork again
        :escape_concat_path(p):\nwrap path in single-quotes,\nescape embedded single-quotes;
    end fork

    :Write concat list file\n(one 'file <escaped_path>' line per segment);

    |ffmpeg concat|
    :Run ffmpeg concat demuxer:\n-f concat -safe 0\n-i list_path -c copy\n→ output_dir/filename.mp4;
    note right
      -safe 0 allows absolute paths
      -c copy avoids re-encoding
      at concatenation stage
    end note
    :Output merged video file;

    |process_and_concat|
repeat while (more filenames in common_files?) is (yes)
-> no (all files processed);

|process_and_concat|
:FINALLY: shutil.rmtree(temp_root,\nignore_errors=True);
note right
  Executes even if ffmpeg
  encounters an error mid-loop
end note

|CLI / Entry Point|
:Visualization output complete\nAll merged videos written to output_dir;
stop

@enduml
