@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
    StartColor #212529
    EndColor #212529
}
skinparam swimlane {
    BorderColor #6C757D
    TitleFontColor #212529
    TitleBackgroundColor #E9ECEF
}

title Video-to-World Multiview Generation\n<size:11><i>DiffusionVideo2WorldMultiviewGenerationPipeline — 6-view video-conditioned world synthesis</i></size>

|Pipeline|
start
:Receive **generate(prompt: dict, image_or_video_path: str)**;
note right
  prompt keys:
  front · front_left · front_right
  back · back_left · back_right
end note

:Extract 6-view prompts from dict\n[front, front_left, front_right,\n back, back_left, back_right];

|T5 Text Encoder|
if (offload_text_encoder_model?) then (yes)
    :_load_text_encoder_model()\n<size:10>CosmosT5TextEncoder → GPU</size>;
endif

:Encode each of 6 view prompts independently\ntext_encoder.encode_prompts(prompt_i)\n<size:10>→ 6 embeddings + 6 attention masks</size>;

if (offload_text_encoder_model?) then (yes)
    :_offload_text_encoder_model()\n<size:10>delete + gc.collect()</size>;
endif

|Pipeline|
:Collect prompt_embeddings\n<size:10>list[6 × torch.Tensor]</size>;

|Tokenizer|
if (offload_tokenizer?) then (yes)
    :_load_tokenizer()\n<size:10>Cosmos-Tokenize1-CV8x8x8-720p → GPU</size>;
endif

:Build video batch for multiview model\n**get_video_batch_for_multiview_model()**\n<size:10>num_video_frames × n_views (6) total frames</size>;
note right
  Returns: data_batch (dict),
  state_shape (list)
end note

:Encode condition latent from input video\n**get_condition_latent_multiview()**\n<size:10>_run_tokenizer_encoding(image_or_video_path, state_shape)</size>\n<size:10>→ condition_latent (torch.Tensor), condition_frames</size>;

|Diffusion Model|
if (offload_network?) then (yes)
    :_load_network()\n<size:10>DiffusionMultiviewV2WModel weights → GPU</size>;
endif

:Run diffusion inference\n**generate_world_from_video()**\n<size:10>_run_model(embedding, condition_latent, data_batch, state_shape)</size>;
note right
  Params: guidance, num_steps,
  seed, num_input_frames,
  is_negative_prompt=False
  Returns: sample (torch.Tensor latents)
end note

if (offload_network?) then (yes)
    :_offload_network()\n<size:10>delete + gc.collect()</size>;
endif

|Tokenizer|
:Decode latent sample\n**model.decode(sample)**\n<size:10>→ raw video [B, 3, T, H, W]</size>;

:Rearrange temporal → view dimension\n<size:10>'b c (v t) h w → b c v t h w'  (v = 6)</size>;

:Reorder views to display order\n<size:10>[1, 0, 2, 4, 3, 5]\nfront · left · right · back · back_left · back_right</size>;

:Compose 2×3 grid layout\n<size:10>'b c (h w) t h1 w1 → b c t (h h1) (w w1)'  h=2, w=3</size>;

:Convert to uint8 numpy arrays\n<size:10>grid_video  [T, H×2, W×3, C]\nvideo       [T, H, W, C] per-view</size>;

if (offload_tokenizer?) then (yes)
    :_offload_tokenizer()\n<size:10>delete + gc.collect()</size>;
endif

|Pipeline|
:Return **(video_list, prompt_dict)**\n<size:10>[grid_video, video], original prompt dict</size>;
stop

@enduml
