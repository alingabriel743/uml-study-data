@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Lyra-1 Autoregressive Inference Pipeline

' ─────────────────────────────────────────────
' External / Base Types
' ─────────────────────────────────────────────
package "External Bases" <<Frame>> {
    abstract class "torch.nn.Module" as TorchModule {
    }

    abstract class DiffusionT2WModel {
        +encode(state): Tensor
        +decode(latent): Tensor
    }

    abstract class BaseVideoCondition {
    }

    abstract class BaseWorldGenerationPipeline {
        +offload_network: bool
        +offload_tokenizer: bool
        +offload_guardrail_models: bool
        +disable_guardrail: bool
        #_load_model()
        #_load_network()
        #_load_tokenizer()
        #_offload_network()
        #_offload_tokenizer()
        #_run_guardrail_on_video_with_offload(output_video)
        #_run_guardrail_on_prompt_with_offload(prompt: str): bool
        #_run_text_embedding_on_prompt_with_offload(prompts: List): Tuple
    }
}

' ─────────────────────────────────────────────
' Config / Value Objects
' ─────────────────────────────────────────────
package "Configuration" <<Frame>> {
    class InferenceConfig {
    }

    class TokenizerConfig {
    }

    class DiffusionDecoderSamplingConfig {
    }

    class SamplingConfig {
    }
}

' ─────────────────────────────────────────────
' Inference Pipeline
' ─────────────────────────────────────────────
package "cosmos_predict1.autoregressive.inference" <<Rectangle>> {

    class ARBaseGenerationPipeline {
        +inference_config: InferenceConfig
        +tokenizer_config: TokenizerConfig
        +model: AutoRegressiveModel
        +diffusion_decoder_model: Optional[LatentDiffusionDecoderModel]
        +dd_sampling_config: DiffusionDecoderSamplingConfig
        +latent_shape: List[int]
        +parallel_size: int
        +disable_diffusion_decoder: bool
        +offload_diffusion_decoder: bool
        #_supported_context_len: int
        +generic_prompt: dict
        +diffusion_decoder_ckpt_path: str
        +diffusion_decoder_config: str
        --
        +__init__(inference_type, checkpoint_dir, checkpoint_name, ...)
        #_load_model()
        #_load_network()
        #_load_tokenizer()
        #_load_diffusion_decoder()
        #_offload_diffusion_decoder()
        #_run_model(inp_vid, num_input_frames, seed, sampling_config): Tuple
        #_run_model_with_offload(inp_vid, ...): Tuple
        #_run_diffusion_decoder(out_videos, indices_tensor, t5_emb_batch): List[Tensor]
        #_run_diffusion_decoder_with_offload(...): List[Tensor]
        +generate(inp_vid, sampling_config, num_input_frames, seed): ndarray
        +generate_partial_tokens_from_data_batch(...): Tuple
        +generate_video_from_tokens(prompt_tokens, latent_shape, ...): Tuple[Tensor, Tensor]
    }

    class ARVideo2WorldGenerationPipeline {
        +offload_text_encoder_model: bool
        --
        #_run_model(prompt_embedding, prompt_mask, inp_vid, ...): Tuple
        #_run_model_with_offload(prompt_embedding, prompt_mask, ...): Tuple
        +generate(inp_prompt: str, inp_vid: Tensor, ...): ndarray
    }
}

' ─────────────────────────────────────────────
' AR Model
' ─────────────────────────────────────────────
package "cosmos_predict1.autoregressive.model" <<Rectangle>> {

    class AutoRegressiveModel {
        +tokenizer: DiscreteMultimodalTokenizer
        +config: ModelConfig
        --
        +__init__(config, model_parallel)
        +load_ar_model(shard_checkpoint, tokenizer_config)
        +load_tokenizer(tokenizer_config)
        +generate(prompt_tokens, temperature, top_p, echo, seed, ...): Tuple[Tensor, ...]
    }
}

' ─────────────────────────────────────────────
' Diffusion Decoder
' ─────────────────────────────────────────────
package "cosmos_predict1.autoregressive.diffusion_decoder" <<Rectangle>> {

    class LatentDiffusionDecoderModel {
        +latent_corruptor
        +pixel_corruptor
        +tokenizer_corruptor
        +scheduler: EDMEulerScheduler
        +diffusion_decoder_cond_sigma_low: float
        +diffusion_decoder_cond_sigma_high: float
        +diffusion_decoder_corrupt_prob: float
        +condition_on_tokenizer_corruptor_token: bool
        --
        +__init__(config)
        +generate_samples_from_batch(data_batch, guidance, seed, ...): Tensor
        #_get_conditions(data_batch, ...): Tuple
        #_add_latent_conditions_to_data_batch(data_batch, ...)
        +decode(latent): Tensor
    }

    class VideoLatentDiffusionDecoderCondition <<dataclass>> {
        +latent_condition: Optional[Tensor]
        +latent_condition_sigma: Optional[Tensor]
    }
}

' ─────────────────────────────────────────────
' Tokenizer
' ─────────────────────────────────────────────
package "cosmos_predict1.autoregressive.tokenizer" <<Rectangle>> {

    class DiscreteMultimodalTokenizer {
        +tokenizer_config: TokenizerConfig
        +text_tokenizer: Optional[Module]
        +video_tokenizer: Optional[BaseDiscreteVideoFSQTokenizer]
        +vocab_size: int
        +video_vocab_size: int
        +video_special_tokens: dict
        +training_type: str
        +total_seq_len: int
        +pad_to_multiple_of: Optional[int]
        --
        +__init__(tokenizer_config: TokenizerConfig)
        #_build_text_tokenizer()
        #_build_video_tokenizer()
        #_tokenize_text(raw_text, max_text_seq_len): List[List[int]]
        #_tokenize_video(videos: Tensor, pixel_chunk_duration): List[List[int]]
        #_tokenize_class(cls_labels): List[List[int]]
        +tokenize(data_batch: dict): Tuple[LongTensor, dict]
        +pad_id(): int
        +ignore_index(): int
        +stop_tokens(): List
    }

    abstract class BaseDiscreteVideoFSQTokenizer {
        +encoder: Module
        +decoder: Module
        +fsq_quantizer: FSQuantizer
        +dtype: torch.dtype
        +channel: int
        +pixel_chunk_duration: int
        +latent_chunk_duration: int
        +max_enc_batch_size: int
        +max_dec_batch_size: int
        +levels: List[int]
        +compress_ratio: List[int]
        --
        +__init__(name, latent_ch, is_bf16, ...)
        +encode(state: Tensor, pixel_chunk_duration): Tuple[Tensor, Tensor]
        +decode(indices: Tensor, pixel_chunk_duration): Tensor
        +reset_dtype(*args, **kwargs)
    }

    class DiscreteVideoFSQJITTokenizer {
        --
        +load_encoder(enc_fp: str): None
        +load_decoder(dec_fp: str): None
    }

    class DiscreteVideoFSQStateDictTokenizer {
        +tokenizer_module: torch.nn.Module
        --
        +load_encoder_and_decoder(enc_fp, dec_fp, tokenizer_module): None
        +reset_dtype(*args, **kwargs)
    }

    class FSQuantizer {
        -_levels: Tensor
        -_basis: Tensor
        +codebook_size: int
        +codebook_dim: int
        +project_in: Linear
        +project_out: Linear
        +implicit_codebook: Tensor
        --
        +__init__(levels, dim, num_codebooks, ...)
        +bound(z, eps): Tensor
        +quantize(z): Tensor
        +codes_to_indices(zhat): Tensor
        +indices_to_codes(indices, project_out): Tensor
        +forward(z): Tuple[Tensor, Tensor, Tensor]
    }
}

' ─────────────────────────────────────────────
' Inheritance
' ─────────────────────────────────────────────
BaseWorldGenerationPipeline        --|> ARBaseGenerationPipeline
ARBaseGenerationPipeline           --|> ARVideo2WorldGenerationPipeline

TorchModule                        --|> AutoRegressiveModel
TorchModule                        --|> BaseDiscreteVideoFSQTokenizer
TorchModule                        --|> FSQuantizer

DiffusionT2WModel                  --|> LatentDiffusionDecoderModel
BaseVideoCondition                 --|> VideoLatentDiffusionDecoderCondition

BaseDiscreteVideoFSQTokenizer      --|> DiscreteVideoFSQJITTokenizer
BaseDiscreteVideoFSQTokenizer      --|> DiscreteVideoFSQStateDictTokenizer

' ─────────────────────────────────────────────
' Composition / Association
' ─────────────────────────────────────────────
ARBaseGenerationPipeline           *-- AutoRegressiveModel           : model
ARBaseGenerationPipeline           *-- LatentDiffusionDecoderModel   : diffusion_decoder_model\n(optional)
ARBaseGenerationPipeline           ..> InferenceConfig               : uses
ARBaseGenerationPipeline           ..> TokenizerConfig               : uses
ARBaseGenerationPipeline           ..> DiffusionDecoderSamplingConfig : uses
ARBaseGenerationPipeline           ..> SamplingConfig                : uses

AutoRegressiveModel                *-- DiscreteMultimodalTokenizer   : tokenizer

DiscreteMultimodalTokenizer        *-- BaseDiscreteVideoFSQTokenizer : video_tokenizer

BaseDiscreteVideoFSQTokenizer      *-- FSQuantizer                   : fsq_quantizer

LatentDiffusionDecoderModel        ..> VideoLatentDiffusionDecoderCondition : produces

@enduml
