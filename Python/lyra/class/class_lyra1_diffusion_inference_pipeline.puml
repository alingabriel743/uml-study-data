@startuml lyra1_diffusion_inference_pipeline

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Lyra-1 Diffusion Inference & World Generation

' ─────────────────────────────────────────
'  External / Framework types
' ─────────────────────────────────────────
namespace torch {
    class "nn.Module" as TorchModule {
    }
}

' ─────────────────────────────────────────
'  Base pipeline
' ─────────────────────────────────────────
package "cosmos_predict1.utils" {

    abstract class BaseWorldGenerationPipeline {
        #inference_type: str
        #checkpoint_dir: str
        #checkpoint_name: str
        #has_text_input: bool
        #offload_network: bool
        #offload_tokenizer: bool
        #offload_text_encoder_model: bool
        #offload_guardrail_models: bool
        #disable_guardrail: bool
        #disable_prompt_encoder: bool
        #text_guardrail: Any
        #video_guardrail: Any
        #text_encoder: CosmosT5TextEncoder
        #model: Any
        __
        #{abstract} _load_model(): Any
        #_load_network()
        #_load_tokenizer()
        #_load_text_encoder_model()
        #_load_text_guardrail()
        #_load_video_guardrail()
        #_offload_network()
        #_offload_tokenizer()
        #_offload_guardrail_models()
        #_offload_text_encoder_model()
        #{abstract} _run_model(*args, **kwargs): Tensor
        #{abstract} _run_model_with_offload(*args, **kwargs): Tensor
        #_run_guardrail_on_prompt(prompt: str): bool
        #_run_guardrail_on_prompt_with_offload(prompt: str): bool
        #_run_guardrail_on_video(video: ndarray): ndarray
        #_run_text_embedding_on_prompt(prompts: list[str]): tuple
        #{abstract} _run_tokenizer_decoding(samples: Tensor): ndarray
        +{abstract} generate(*args, **kwargs)
    }
}

' ─────────────────────────────────────────
'  Diffusion inference pipelines
' ─────────────────────────────────────────
package "cosmos_predict1.diffusion.inference" {

    class DiffusionText2WorldGenerationPipeline {
        #model_name: str
        #guidance: float = 7.0
        #num_steps: int = 35
        #height: int = 704
        #width: int = 1280
        #fps: int = 24
        #num_video_frames: int = 121
        #seed: int = 0
        #enable_prompt_upsampler: bool
        #offload_prompt_upsampler: bool
        #prompt_upsampler: Any
        __
        #_load_model()
        #_load_network()
        #_load_tokenizer()
        #_load_prompt_upsampler_model()
        #_offload_prompt_upsampler_model()
        #_run_prompt_upsampler_on_prompt(prompt: str): str
        #_run_model(embedding: Tensor, neg_embedding: Tensor): Tensor
        #_run_model_with_offload(embedding: Tensor, neg_embedding: Tensor): ndarray
        #_run_tokenizer_decoding(sample: Tensor): ndarray
        +generate(prompt: str, negative_prompt: str, word_limit: int): tuple
    }

    class DiffusionVideo2WorldGenerationPipeline {
        #num_input_frames: int = 1
        __
        #_load_model()
        #_load_prompt_upsampler_model()
        #_run_prompt_upsampler_on_prompt(image_or_video_path: str): str
        #_run_tokenizer_encoding(image_or_video_path: str): Tensor
        #_run_model(embedding, condition_latent, neg_embedding): Tensor
        #_run_model_with_offload(embedding, path, neg_embedding): ndarray
        +generate(prompt: str, image_or_video_path: str, negative_prompt: str): tuple
    }

    class DiffusionText2WorldMultiviewGenerationPipeline {
        #n_views: int = 6
        #frame_repeat_negative_condition: int = 10
        __
        #_load_model()
        #_run_model(embedding, neg_embedding): Tensor
        #_run_tokenizer_decoding(sample: Tensor): list[ndarray]
        +generate(prompt: dict): tuple
        .. notes ..
        ' enable_prompt_upsampler forced False
        ' prompt dict: prompt / _left / _right / _back / ...
    }

    class DiffusionVideo2WorldMultiviewGenerationPipeline {
        #num_input_frames: int = 1
        __
        #_load_model()
        #_run_model(embedding, condition_latent, neg_embedding, ...): Tensor
    }

    class DiffusionWorldInterpolatorGenerationPipeline {
        #num_input_frames: int = 1
        #num_frame_pairs: int = 1
        #frame_index_start: int = 0
        #frame_stride: int = 1
        ' guidance default = -1.0 (disabled)
        __
        #_load_model()
        #_load_prompt_upsampler_model()
        #_run_model(condition_latent, neg_embedding, num_of_loops, ...): ndarray
        +generate(...): tuple
    }

    class Gen3cPipeline {
        ' 3D-cache-conditioned novel view synthesis
        __
        ' Overrides _run_model to inject Cache3D/Cache4D warp conditioning
        +generate(...)
    }

    ' ── Cache classes ──────────────────────

    abstract class Cache3D_Base {
        #weight_dtype: torch.dtype
        #is_depth: bool
        #device: str
        #filter_points_threshold: float
        #foreground_masking: bool
        #input_image: Tensor
        #input_points: Tensor
        #input_mask: Tensor
        #input_depth: Tensor
        #boundary_mask: Tensor
        __
        +__init__(input_image, input_depth, input_w2c, ...)
        #_compute_input_points(depth, w2c, intrinsics): Tensor
        +{abstract} update_cache()
        +input_frame_count(): int
        +render_cache(target_w2cs, target_intrinsics, render_depth, start_frame_idx): tuple
    }

    class Cache3D_Buffer {
        #frame_buffer_max: int = 0
        #noise_aug_strength: float = 0
        #generator: Any
        __
        +update_cache(new_image, new_depth, new_w2c, new_mask, ...)
        +render_cache(target_w2cs, target_intrinsics, render_depth, start_frame_idx): tuple
        .. notes ..
        ' Sliding buffer (newest-first); rigid / non_rigid depth alignment
    }

    class Cache3D_BufferSelector {
        #frame_buffer_max: int = 1
        #mask_for_max_buffer_model: bool = True
        #mask_full_threshold: float = 0.9
        __
        +update_cache()
        +render_cache(target_w2cs, target_intrinsics, render_depth, start_frame_idx): tuple
        .. notes ..
        ' Read-only; selects top-K frames by coverage overlap
    }

    class Cache4D {
        __
        +update_cache(**kwargs)
        +render_cache(target_w2cs, target_intrinsics, render_depth, start_frame_idx): tuple
        .. notes ..
        ' Thin wrapper; supports start_frame_idx for temporal slicing
    }
}

' ─────────────────────────────────────────
'  Sampler
' ─────────────────────────────────────────
package "cosmos_predict1.diffusion.modules" {

    class SamplerConfig <<dataclass>> {
        +solver: SolverConfig
        +timestamps: SolverTimestampConfig
        +sample_clean: bool = True
    }

    class Sampler {
        #cfg: SamplerConfig
        __
        +__init__(cfg: SamplerConfig)
        +forward(x0_fn, x_sigma_max, num_steps, sigma_min, sigma_max, ...): Tensor
        #_forward_impl(denoiser_fn, noisy_input, sampler_cfg, callback_fns): Tensor
        .. notes ..
        ' EDM-style schedule via get_rev_ts()
        ' Supports 2ab multistep and Runge-Kutta solvers
    }
}

' ─────────────────────────────────────────
'  External model stubs (used by pipelines)
' ─────────────────────────────────────────
package "cosmos_predict1.diffusion.model" {
    class DiffusionT2WModel <<model>>
    class DiffusionV2WModel <<model>>
    class DiffusionMultiviewT2WModel <<model>>
    class DiffusionMultiviewV2WModel <<model>>
    class DiffusionWorldInterpolatorWModel <<model>>
    class GEN3C_Cosmos_7B <<model>>
}

package "cosmos_predict1.text_encoder" {
    class CosmosT5TextEncoder {
        +encode(prompts: list[str]): tuple[list[Tensor], list[Tensor]]
    }
}

' ─────────────────────────────────────────
'  Inheritance relationships
' ─────────────────────────────────────────
BaseWorldGenerationPipeline --|> DiffusionText2WorldGenerationPipeline
DiffusionText2WorldGenerationPipeline --|> DiffusionVideo2WorldGenerationPipeline
DiffusionText2WorldGenerationPipeline --|> DiffusionText2WorldMultiviewGenerationPipeline
DiffusionText2WorldMultiviewGenerationPipeline --|> DiffusionVideo2WorldMultiviewGenerationPipeline
DiffusionVideo2WorldGenerationPipeline --|> DiffusionWorldInterpolatorGenerationPipeline
DiffusionVideo2WorldGenerationPipeline --|> Gen3cPipeline

Cache3D_Base --|> Cache3D_Buffer
Cache3D_Base --|> Cache3D_BufferSelector
Cache3D_Base --|> Cache4D

TorchModule --|> Sampler

' ─────────────────────────────────────────
'  Composition / Aggregation
' ─────────────────────────────────────────
BaseWorldGenerationPipeline *-- CosmosT5TextEncoder : text_encoder

Sampler *-- SamplerConfig : cfg

' ─────────────────────────────────────────
'  Dependencies (pipelines → models)
' ─────────────────────────────────────────
DiffusionText2WorldGenerationPipeline ..> DiffusionT2WModel : loads via\nload_model_by_config
DiffusionVideo2WorldGenerationPipeline ..> DiffusionV2WModel : loads
DiffusionText2WorldMultiviewGenerationPipeline ..> DiffusionMultiviewT2WModel : loads
DiffusionVideo2WorldMultiviewGenerationPipeline ..> DiffusionMultiviewV2WModel : loads
DiffusionWorldInterpolatorGenerationPipeline ..> DiffusionWorldInterpolatorWModel : loads
Gen3cPipeline ..> GEN3C_Cosmos_7B : loads

' ─────────────────────────────────────────
'  Gen3c ↔ Cache
' ─────────────────────────────────────────
Gen3cPipeline o-- Cache3D_Buffer : warp conditioning
Gen3cPipeline o-- Cache4D : warp conditioning

@enduml
