@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Lyra-1 Diffusion Model Hierarchy

' ─────────────────────────────────────────
'  External base
' ─────────────────────────────────────────
class "torch.nn.Module" as TorchModule <<external>> {
}

' ─────────────────────────────────────────
'  Training subsystem
' ─────────────────────────────────────────
package "cosmos_predict1.diffusion.training" {

    class Model <<utility>> {
        ' Generic utility base wrapping nn.Module
    }

    class ImageDiffusionModel <<alias: model_image.DiffusionModel>> {
        +config
        +net
        +conditioner
        +logvar
        +sde
        +sampler
        +sigma_data : float
        +state_shape
        +tensor_kwargs : dict
        +loss_reduce
        --
        +training_step(data_batch, iteration) : Tuple
        +validation_step(data, iteration) : tuple
        +denoise(xt, sigma, condition : CosmosCondition) : DenoisePrediction
        +encode(state) : Tensor
        +decode(latent) : Tensor
        +get_data_and_condition(data_batch) : Tuple
        +draw_training_sigma_and_epsilon(size, condition) : Tuple
        +compute_loss_with_epsilon_and_sigma(...)
        +generate_samples_from_batch(data_batch, ...) : Tensor
    }

    class DiffusionModel {
        +trained_data_record : dict
        +data_parallel_size : int
        +video_noise_multiplier : float
        +input_data_key : str
        +input_image_key : str
        --
        +setup_data_key() : void
        +is_image_batch(data_batch) : bool
        +draw_training_sigma_and_epsilon(size, condition) : Tuple
        +get_data_and_condition(data_batch) : Tuple
        +training_step(data_batch, iteration) : Tuple
        +validation_step(data, iteration) : tuple
        +get_x0_fn_from_batch(data_batch, guidance, ...) : Callable
        +generate_samples_from_batch(...) : Tensor
        +compute_loss_with_epsilon_and_sigma(...)
        +on_train_start(memory_format)
        +state_dict() : Dict
        +load_state_dict(state_dict, strict, assign)
        +get_grad_norm(norm_type, filter_fn) : float
        +clip_grad_norm_(max_norm) : Tensor
        -_normalize_video_databatch_inplace(data_batch, input_key)
        -_augment_image_dim_inplace(data_batch, input_key)
    }

    class FSDPDiffusionModel <<FSDP>> {
        ' @diffusion_fsdp_class_decorator
        ' (empty body — pass)
    }

    class ExtendDiffusionModel {
        +is_extend_model : bool = true
        --
        +get_data_and_condition(data_batch, num_condition_t) : Tuple
        +denoise(noise_x, sigma, condition : VideoExtendCondition) : VideoDenoisePrediction
        +generate_samples_from_batch(...) : Tensor
        +get_x0_fn_from_batch_with_condition_latent(...) : Callable
        +add_condition_video_indicator_and_video_input_mask(...) : VideoExtendCondition
        +add_condition_pose(data_batch, condition) : VideoExtendCondition
        +augment_conditional_latent_frames(condition, ...) : Tuple
        +drop_out_condition_region(augment_latent, noise_x, ...) : Tensor
        +draw_augment_sigma_and_epsilon(size, condition, ...) : Tuple
        +sample_tokens_start_from_p_or_i(latent_state) : Tensor
    }

    class FSDPExtendDiffusionModel <<FSDP>> {
        ' @diffusion_fsdp_class_decorator
        ' (empty body — pass)
    }
}

' ─────────────────────────────────────────
'  Inference subsystem
' ─────────────────────────────────────────
package "cosmos_predict1.diffusion.model" {

    class DiffusionT2WModel <<Text-to-World>> {
        +config
        +precision : torch.dtype
        +tensor_kwargs : dict
        +sigma_data : float
        +state_shape : list
        +scheduler : EDMEulerScheduler
        +tokenizer : BaseVAE
        +model : ModuleDict
        --
        ' Properties: net, conditioner, logvar -> model.*
        +set_up_tokenizer(tokenizer_dir : str)
        +set_up_model(memory_format)
        +build_model() : ModuleDict
        +setup_data_key()
        +encode(state) : Tensor
        +decode(latent) : Tensor
        +generate_samples_from_batch(...) : Tensor
        -_get_conditions(data_batch, is_negative_prompt) : Tuple
    }

    class DiffusionMultiviewT2WModel <<Multiview T2W>> {
        +n_views : int
        --
        +encode(state) : Tensor
        +decode(latent) : Tensor
        +generate_samples_from_batch(...) : Tensor
    }

    class DiffusionV2WModel <<Video-to-World>> {
        --
        +add_condition_video_indicator_and_video_input_mask(...) : VideoExtendCondition
        +generate_samples_from_batch(..., condition_latent, ...) : Tensor
        -_get_conditions(data_batch, is_negative_prompt, ...) : Tuple
        -_augment_noise_with_latent(xt, sigma, condition, ...) : Tuple
        -_reverse_precondition_input(xt, sigma) : Tensor
        -_reverse_precondition_output(latent, xt, sigma) : Tensor
    }

    class DiffusionMultiviewV2WModel <<Multiview V2W>> {
        +n_views : int
        --
        +encode(state) : Tensor
        +decode(latent) : Tensor
        +add_condition_video_indicator_and_video_input_mask(...) : VideoExtendCondition
        +generate_samples_from_batch(...) : Tensor
        -_augment_noise_with_latent(...) : Tuple
    }

    class DiffusionWorldInterpolatorWModel <<World Interpolator>> {
        +is_extend_model : bool = true
        +num_valid_latents : int
        +input_data_key : str
        +input_image_key : str
        +sampler : Sampler
        +scaling : EDMScaling
        +sde : EDMSDE
        --
        +setup_data_key()
        +is_image_batch(data_batch) : bool
        +normalize_condition_latent(condition_latent) : Tensor
        +super_denoise(xt, sigma, condition : CosmosCondition) : DenoisePrediction
        +denoise(noise_x, sigma, condition : VideoExtendCondition) : VideoDenoisePrediction
        +generate_samples_from_batch(..., return_noise) : Tensor
        +get_x0_fn_from_batch_with_condition_latent(...) : Callable
        +add_condition_video_indicator_and_video_input_mask(...) : VideoExtendCondition
        +add_condition_pose(data_batch, condition) : VideoExtendCondition
        +augment_conditional_latent_frames(condition, ...) : Tuple
        +drop_out_condition_region(augment_latent, noise_x, ...) : Tensor
        +draw_augment_sigma_and_epsilon(size, condition, ...) : Tuple
    }
}

' ─────────────────────────────────────────
'  Condition / Prediction data types
' ─────────────────────────────────────────
package "Condition & Prediction Types" {

    class CosmosCondition <<dataclass>> {
        +crossattn_emb : Tensor
        +crossattn_mask : Tensor
        +padding_mask : Optional[Tensor]
        +scalar_feature : Optional[Tensor]
        --
        +to_dict() : Dict
    }

    class VideoDenoisePrediction <<dataclass>> {
        +x0 : Tensor
        +eps : Optional[Tensor]
        +logvar : Optional[Tensor]
        +net_in : Optional[Tensor]
        +net_x0_pred : Optional[Tensor]
        +xt : Optional[Tensor]
        +x0_pred_replaced : Optional[Tensor]
    }
}

' ─────────────────────────────────────────
'  External components
' ─────────────────────────────────────────
class BaseVAE <<external>> {
    +encode(state) : Tensor
    +decode(latent) : Tensor
}

class EDMEulerScheduler <<external>> {
    +sigma_max : float
    +sigma_min : float
}

class Sampler <<external>> {
}

class EDMScaling <<external>> {
}

class EDMSDE <<external>> {
    +p_mean : float
    +p_std : float
    +sigma_max : float
    +sigma_min : float
}

' ─────────────────────────────────────────
'  Inheritance — Training hierarchy
' ─────────────────────────────────────────
Model                   --|> TorchModule
ImageDiffusionModel     --|> Model
DiffusionModel          --|> ImageDiffusionModel
FSDPDiffusionModel      --|> DiffusionModel
ExtendDiffusionModel    --|> DiffusionModel
FSDPExtendDiffusionModel --|> ExtendDiffusionModel

' ─────────────────────────────────────────
'  Inheritance — Inference hierarchy
' ─────────────────────────────────────────
DiffusionT2WModel              --|> TorchModule
DiffusionMultiviewT2WModel     --|> DiffusionT2WModel
DiffusionV2WModel              --|> DiffusionT2WModel
DiffusionMultiviewV2WModel     --|> DiffusionV2WModel
DiffusionWorldInterpolatorWModel --|> DiffusionV2WModel

' ─────────────────────────────────────────
'  Composition — inference model components
' ─────────────────────────────────────────
DiffusionT2WModel *-- EDMEulerScheduler   : scheduler
DiffusionT2WModel *-- BaseVAE             : tokenizer
DiffusionWorldInterpolatorWModel *-- Sampler    : res_sampler
DiffusionWorldInterpolatorWModel *-- EDMScaling : scaling
DiffusionWorldInterpolatorWModel *-- EDMSDE     : sde

' ─────────────────────────────────────────
'  Usage — condition / prediction types
' ─────────────────────────────────────────
ImageDiffusionModel          ..> CosmosCondition        : uses (denoise)
DiffusionWorldInterpolatorWModel ..> CosmosCondition    : uses (super_denoise)
ExtendDiffusionModel         ..> VideoDenoisePrediction : returns
DiffusionWorldInterpolatorWModel ..> VideoDenoisePrediction : returns

note bottom of DiffusionWorldInterpolatorWModel
  Uses EDM-style <b>x0_fn + Sampler ODE</b> instead of
  EDMEulerScheduler step loop used by DiffusionV2WModel.
  Supports condition_location: first_n, first_and_last_1,
  first_random_n, random (for frame interpolation).
end note

note right of FSDPDiffusionModel
  Created via
  @diffusion_fsdp_class_decorator
  (empty body)
end note

note right of FSDPExtendDiffusionModel
  Created via
  @diffusion_fsdp_class_decorator
  (empty body)
end note

note top of DiffusionT2WModel
  <b>Inference</b> model — standalone, not
  a subclass of the training hierarchy.
  Exposes net / conditioner / logvar
  as properties backed by self.model (ModuleDict).
end note

@enduml
