@startuml lyra1_diffusion_training

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #856404
}

title Lyra-1 Diffusion Training Pipeline

' ─────────────────────────────────────────
' ENUM
' ─────────────────────────────────────────

enum DataType {
    IMAGE = 'image'
    VIDEO = 'video'
    MIX   = 'mix'
}

' ─────────────────────────────────────────
' EMBEDDING MODELS
' ─────────────────────────────────────────

package "Embedding Models" {

    abstract class AbstractEmbModel {
        #_is_trainable: bool
        #_dropout_rate: float | Tensor
        #_input_key: str
        #_return_dict: bool
        +random_dropout_input(in_tensor, dropout_rate, key): Tensor
        +summary(): str
        +details(): str
    }

    class BaseConditionEntry {
        #_dropout_rate: float | Tensor
        #_input_key: str
        #_return_dict: bool
        +random_dropout_input(in_tensor, dropout_rate, key): Tensor
        +summary(): str
    }

    class TextAttr {
        +forward(token: Tensor, mask: Tensor): dict
        +random_dropout_input(in_tensor, dropout_rate, key): Tensor
    }

    class TrajectoryAttr {
        +traj_dim: int
        +forward(traj: Tensor): dict
    }

    class FrameRepeatAttr {
        +forward(frame_repeat: Tensor): dict
    }

    class BooleanFlag {
        +output_key: Optional[str]
        +flag: Tensor
        +forward(*args, **kwargs): dict
        +random_dropout_input(in_tensor, dropout_rate, key): Tensor
    }

    BaseConditionEntry <|-- TextAttr
    AbstractEmbModel   <|-- TrajectoryAttr
    AbstractEmbModel   <|-- FrameRepeatAttr
    AbstractEmbModel   <|-- BooleanFlag
}

' ─────────────────────────────────────────
' CONDITIONER CLASSES
' ─────────────────────────────────────────

package "Conditioner Classes" {

    abstract class GeneralConditioner {
        +KEY2DIM: dict
        +embedders: nn.ModuleDict
        +{abstract} forward(batch, override_dropout_rate): Any
        #_forward(batch, override_dropout_rate): Dict
        +get_condition_uncondition(data_batch): Tuple
        +get_condition_with_negative_prompt(data_batch): Tuple
    }

    class VideoConditioner {
        +forward(batch, override_dropout_rate): BaseVideoCondition
    }

    class VideoExtendConditioner {
        +forward(batch, override_dropout_rate): VideoExtendCondition
    }

    class VideoDiffusionDecoderConditioner {
        +forward(batch, override_dropout_rate): VideoLatentDiffusionDecoderCondition
    }

    class VideoConditionerWithTraingOnlyEmb {
        +get_condition_uncondition(data_batch): Tuple
        +forward(batch, override_dropout_rate): BaseVideoCondition
    }

    class VideoExtendConditionerWithTraingOnlyEmb {
        +forward(batch, override_dropout_rate): VideoExtendCondition
    }

    class VideoConditionerWithCtrl {
        +forward(batch, override_dropout_rate): BaseWithCtrlCondition
    }

    class ActionConditionalVideoExtendConditioner {
        +forward(batch, override_dropout_rate): ActionConditionalVideoExtendCondition
    }

    GeneralConditioner <|-- VideoConditioner
    GeneralConditioner <|-- VideoExtendConditioner
    GeneralConditioner <|-- VideoDiffusionDecoderConditioner
    GeneralConditioner <|-- VideoConditionerWithTraingOnlyEmb
    VideoConditionerWithTraingOnlyEmb <|-- VideoExtendConditionerWithTraingOnlyEmb
    VideoExtendConditioner            <|-- VideoConditionerWithCtrl
    VideoExtendConditioner            <|-- ActionConditionalVideoExtendConditioner
}

' ─────────────────────────────────────────
' CONDITION DATACLASSES
' ─────────────────────────────────────────

package "Condition Dataclasses" {

    class CosmosCondition <<dataclass>> {
        +crossattn_emb: Tensor
        +crossattn_mask: Tensor
        +padding_mask: Optional[Tensor]
        +scalar_feature: Optional[Tensor]
        +to_dict(): Dict
    }

    class BaseVideoCondition <<dataclass>> {
        +crossattn_emb: Tensor
        +crossattn_mask: Tensor
        +data_type: DataType = VIDEO
        +padding_mask: Optional[Tensor]
        +fps: Optional[Tensor]
        +num_frames: Optional[Tensor]
        +image_size: Optional[Tensor]
        +scalar_feature: Optional[Tensor]
        +trajectory: Optional[Tensor]
        +frame_repeat: Optional[Tensor]
        +to_dict(): Dict
    }

    class VideoExtendCondition <<dataclass>> {
        +video_cond_bool: Optional[Tensor]
        +gt_latent: Optional[Tensor]
        +condition_video_indicator: Optional[Tensor]
        +condition_video_input_mask: Optional[Tensor]
        +condition_video_augment_sigma: Optional[Tensor]
        +condition_video_pose: Optional[Tensor]
    }

    class VideoLatentDiffusionDecoderCondition <<dataclass>> {
        +latent_condition: Optional[Tensor]
        +latent_condition_sigma: Optional[Tensor]
        +get_condition_for_cp(cp_group): void
    }

    class BaseWithCtrlCondition <<dataclass>> {
        +hint_key: Optional[str]
        +control_weight: Optional[float] = 1.0
        +num_layers_to_use: Optional[int] = -1
        +base_model: Optional[nn.Module]
        +control_input_*: Optional[Tensor]
    }

    class ActionConditionalVideoExtendCondition <<dataclass>> {
        +action: Optional[Tensor]
    }

    class VideoDenoisePrediction <<dataclass>> {
        +x0: Tensor
        +eps: Optional[Tensor]
        +logvar: Optional[Tensor]
        +net_in: Optional[Tensor]
        +net_x0_pred: Optional[Tensor]
        +xt: Optional[Tensor]
        +x0_pred_replaced: Optional[Tensor]
    }

    BaseVideoCondition               <|-- VideoExtendCondition
    BaseVideoCondition               <|-- VideoLatentDiffusionDecoderCondition
    VideoExtendCondition             <|-- BaseWithCtrlCondition
    VideoExtendCondition             <|-- ActionConditionalVideoExtendCondition
}

' ─────────────────────────────────────────
' DIFFUSION MODEL HIERARCHY
' ─────────────────────────────────────────

package "Diffusion Models" {

    abstract class Model {
    }

    class "DiffusionModel\n[image]" as ImageDiffusionModel {
        +sigma_data: float
        +sde: EDMSDE
        +sampler: Sampler
        +scaling: EDMScaling
        +vae: BaseVAE
        +net: GeneralDIT
        +conditioner: GeneralConditioner
        +logvar: nn.Sequential
        +build_model(): nn.ModuleDict
        +encode(x): Tensor
        +decode(z): Tensor
        +denoise(noise_x, sigma, condition): DenoisePrediction
        +training_step(data_batch, iteration): Tuple
        +get_data_and_condition(data_batch): Tuple
        +generate_samples_from_batch(data_batch, ...): Tensor
    }

    class "DiffusionModel\n[video]" as VideoDiffusionModel {
        +trained_data_record: dict
        +data_parallel_size: int
        +video_noise_multiplier: float
        +setup_data_key(): void
        +is_image_batch(data_batch): bool
        +get_data_and_condition(data_batch): Tuple
        +training_step(data_batch, iteration): void
        +draw_training_sigma_and_epsilon(size, condition): Tuple
        +get_x0_fn_from_batch(data_batch, ...): Callable
        +on_after_backward(iteration): void
        +clip_grad_norm_(max_norm): Tensor
    }

    class ExtendDiffusionModel {
        +is_extend_model: bool = True
        +get_data_and_condition(data_batch, num_condition_t): Tuple
        +add_condition_video_indicator_and_video_input_mask(...): VideoExtendCondition
        +add_condition_pose(data_batch, condition): VideoExtendCondition
        +sample_tokens_start_from_p_or_i(latent_state): Tensor
    }

    class MultiviewDiffusionModel {
    }

    class MultiviewExtendDiffusionModel {
    }

    class InterpolatorDiffusionModel {
    }

    class PEFTVideoDiffusionModel {
    }

    class PEFTExtendDiffusionModel {
    }

    class "FSDPDiffusionModel\n[image]" as FSDPImageDiffusionModel <<FSDP>> {
    }

    class "FSDPDiffusionModel\n[video]" as FSDPVideoDiffusionModel <<FSDP>> {
    }

    class FSDPExtendDiffusionModel <<FSDP>> {
    }

    Model                  <|-- ImageDiffusionModel
    ImageDiffusionModel    <|-- VideoDiffusionModel
    VideoDiffusionModel    <|-- ExtendDiffusionModel
    VideoDiffusionModel    <|-- MultiviewDiffusionModel
    ExtendDiffusionModel   <|-- MultiviewExtendDiffusionModel
    ExtendDiffusionModel   <|-- InterpolatorDiffusionModel
    ExtendDiffusionModel   <|-- PEFTExtendDiffusionModel
    ExtendDiffusionModel   <|-- FSDPExtendDiffusionModel
    VideoDiffusionModel    <|-- PEFTVideoDiffusionModel
    VideoDiffusionModel    <|-- FSDPVideoDiffusionModel
    ImageDiffusionModel    <|-- FSDPImageDiffusionModel
}

' ─────────────────────────────────────────
' DiT NETWORKS
' ─────────────────────────────────────────

package "DiT Networks" {

    class GeneralDIT {
        +forward(x, timesteps, context, ...): Tensor
    }

    class VideoExtendGeneralDIT {
        ' Accepts condition_video_input_mask channel concat
    }

    class ActionConditionalGeneralDIT {
        ' Conditions on robot action trajectory
    }

    class ActionConditionalVideoExtendGeneralDIT {
    }

    class MultiviewGeneralDIT {
    }

    GeneralDIT                       <|-- VideoExtendGeneralDIT
    GeneralDIT                       <|-- ActionConditionalGeneralDIT
    GeneralDIT                       <|-- MultiviewGeneralDIT
    ActionConditionalGeneralDIT      <|-- ActionConditionalVideoExtendGeneralDIT
}

' ─────────────────────────────────────────
' DATASET CLASSES
' ─────────────────────────────────────────

package "Dataset Classes" {

    class "torch.utils.data.Dataset" as TorchDataset {
    }

    class Dataset_3D {
        +data_path: str
        +video_path: str
        +sequence_length: int
        +sequence_interval: int
        +cam_ids: list
        +action_dim: int = 7
        +accumulate_action: bool
        +c_act_scaler: ndarray
        +samples: List[dict]
        +preprocess: T.Compose
        +load_t5_embeddings: bool
        +load_action: bool
        +__len__(): int
        +__getitem__(index, cam_id, return_video): dict
        #_init_anns(data_dir): List[str]
        #_init_sequences(ann_files): List[dict]
        #_load_video(video_path, frame_ids): ndarray
        #_get_frames(label, frame_ids, cam_id, pre_encode): Tensor
        #_get_robot_states(label, frame_ids): Tuple
        #_get_actions(arm_states, gripper_states, accumulate_action): Tensor
        #_get_all_actions(arm_states, gripper_states, accumulate_action): Tensor
    }

    class Dataset_3DBinary {
        ' Binary gripper state variant
    }

    TorchDataset  <|-- Dataset_3D
    Dataset_3D    <|-- Dataset_3DBinary
}

' ─────────────────────────────────────────
' VAE / TOKENIZERS (abbreviated)
' ─────────────────────────────────────────

package "VAE / Tokenizers" {

    abstract class BaseVAE {
        +latent_ch: int
        +{abstract} encode(x): Tensor
        +{abstract} decode(z): Tensor
    }

    class BasePretrainedImageVAE {
    }

    class JITVAE {
        ' TorchScript JIT VAE
    }

    class StateDictVAE {
    }

    interface VideoTokenizerInterface {
        +encode(x): Tensor
        +decode(z): Tensor
    }

    class VideoJITTokenizer {
    }

    class VideoJITVAEChunkWiseTokenizer {
    }

    class JointImageVideoTokenizer {
        ' Handles both image and video encoding
    }

    BaseVAE                   <|-- BasePretrainedImageVAE
    BasePretrainedImageVAE    <|-- JITVAE
    BasePretrainedImageVAE    <|-- StateDictVAE
    JITVAE                    <|-- VideoJITTokenizer
    VideoTokenizerInterface   <|.. VideoJITTokenizer
    VideoJITTokenizer         <|-- VideoJITVAEChunkWiseTokenizer
    BaseVAE                   <|-- JointImageVideoTokenizer
    VideoTokenizerInterface   <|.. JointImageVideoTokenizer
}

' ─────────────────────────────────────────
' CROSS-PACKAGE RELATIONSHIPS
' ─────────────────────────────────────────

' GeneralConditioner aggregates embedders
GeneralConditioner o-- AbstractEmbModel  : embedders\n(nn.ModuleDict)

' DiffusionModel owns conditioner, net, vae
ImageDiffusionModel o-- GeneralConditioner : conditioner
ImageDiffusionModel o-- GeneralDIT         : net
ImageDiffusionModel o-- BaseVAE            : vae

' DiffusionModel returns condition dataclasses
VideoDiffusionModel  ..> BaseVideoCondition         : <<returns>>\nget_data_and_condition
ExtendDiffusionModel ..> VideoExtendCondition        : <<returns>>\nget_data_and_condition

' Dataset_3D feeds TrajectoryAttr / DiffusionModel
Dataset_3D ..> TrajectoryAttr : action tensor\n[T-1,7]

' BaseVideoCondition uses DataType
BaseVideoCondition ..> DataType : data_type

@enduml
