@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam enum {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}

title Lyra-1 Tokenizer Encoder/Decoder Modules

' ─────────────────────────────────────────
' ENUMS
' ─────────────────────────────────────────
package "Registry Enums" {

    enum EncoderType {
        Default = Encoder
    }

    enum DecoderType {
        Default = Decoder
    }

    enum Encoder3DType {
        BASE = EncoderBase
        FACTORIZED = EncoderFactorized
    }

    enum Decoder3DType {
        BASE = DecoderBase
        FACTORIZED = DecoderFactorized
        FACTORIZEDVanilla = DecoderFactorizedVanilla
        BASEVanilla = DecoderBaseVanilla
    }

    enum ContinuousFormulation {
        VAE = GaussianDistribution
        AE = IdentityDistribution
    }

    enum DiscreteQuantizer {
        VQ = VectorQuantizer
        LFQ = LFQuantizer
        FSQ = FSQuantizer
        RESFSQ = ResidualFSQuantizer
    }
}

' ─────────────────────────────────────────
' 2D LAYERS
' ─────────────────────────────────────────
package "2D Layers (layers2d.py)" {

    class Encoder {
        -num_resolutions: int
        -num_res_blocks: int
        -num_downsamples: int
        -patcher: Patcher
        -conv_in: Conv2d
        -down: ModuleList
        -mid: Module
        -norm_out: GroupNorm
        -conv_out: Conv2d
        +__init__(in_channels, channels, channels_mult, num_res_blocks, attn_resolutions, dropout, resolution, z_channels, spatial_compression)
        +forward(x): z
    }

    class Decoder {
        -num_resolutions: int
        -num_res_blocks: int
        -num_upsamples: int
        -unpatcher: UnPatcher
        -conv_in: Conv2d
        -mid: Module
        -up: ModuleList
        -norm_out: GroupNorm
        -conv_out: Conv2d
        +__init__(out_channels, channels, channels_mult, num_res_blocks, attn_resolutions, dropout, resolution, z_channels, spatial_compression)
        +forward(z): x
    }

    class ResnetBlock {
        -norm1: GroupNorm
        -conv1: Conv2d
        -norm2: GroupNorm
        -dropout: Dropout
        -conv2: Conv2d
        -nin_shortcut: Conv2d
        +forward(x): Tensor
    }

    class AttnBlock {
        -norm: GroupNorm
        -q: Conv2d
        -k: Conv2d
        -v: Conv2d
        -proj_out: Conv2d
        +forward(x): Tensor
    }

    class Upsample {
        -conv: Conv2d
        +forward(x): Tensor
    }

    class Downsample {
        -conv: Conv2d
        +forward(x): Tensor
    }
}

' ─────────────────────────────────────────
' 3D LAYERS
' ─────────────────────────────────────────
package "3D Layers (layers3d.py)" {

    class EncoderBase {
        -patcher: Patcher
        -conv_in: CausalConv3d
        -down: ModuleList
        -mid: Module
        -norm_out: CausalNormalize
        -conv_out: CausalConv3d
        +__init__(in_channels, channels, channels_mult, num_res_blocks, attn_resolutions, dropout, resolution, z_channels)
        +forward(x): z
    }

    class DecoderBase {
        -unpatcher: UnPatcher
        -conv_in: CausalConv3d
        -mid: Module
        -up: ModuleList
        -norm_out: CausalNormalize
        -conv_out: CausalConv3d
        +__init__(out_channels, channels, channels_mult, num_res_blocks, attn_resolutions, dropout, resolution, z_channels)
        +forward(z): x
    }

    class EncoderFactorized {
        -patcher3d: Patcher3D
        -conv_in: Sequential
        -down: ModuleList
        -mid: Module
        -norm_out: CausalNormalize
        -conv_out: Sequential
        +__init__(in_channels, channels, channels_mult, num_res_blocks, attn_resolutions, dropout, resolution, z_channels, spatial_compression, temporal_compression)
        +forward(x): z
    }

    class DecoderFactorized {
        -unpatcher3d: UnPatcher3D
        -conv_in: Sequential
        -mid: Module
        -up: ModuleList
        -norm_out: CausalNormalize
        -conv_out: Sequential
        +__init__(out_channels, channels, channels_mult, num_res_blocks, attn_resolutions, dropout, resolution, z_channels, spatial_compression, temporal_compression)
        +forward(z): x
    }

    class DecoderFactorizedVanilla {
        {field} Variant of DecoderFactorized (no patching)
        -conv_in: CausalConv3d
        -up: ModuleList
        -norm_out: CausalNormalize
        -conv_out: CausalConv3d
        +forward(z): x
    }

    class DecoderBaseVanilla {
        {field} Variant of DecoderBase (no patching)
        -conv_in: CausalConv3d
        -up: ModuleList
        -norm_out: CausalNormalize
        -conv_out: CausalConv3d
        +forward(z): x
    }
}

' ─────────────────────────────────────────
' 3D BUILDING BLOCKS
' ─────────────────────────────────────────
package "3D Building Blocks" {

    class CausalConv3d {
        -conv3d: Conv3d
        -time_pad: int
        -spatial_pad: tuple
        -pad_mode: str
        +forward(x): Tensor
    }

    class CausalNormalize {
        -norm: GroupNorm
        -num_groups: int
        +forward(x): Tensor
    }

    class CausalResnetBlock3d {
        -norm1: CausalNormalize
        -conv1: CausalConv3d
        -norm2: CausalNormalize
        -dropout: Dropout
        -conv2: CausalConv3d
        -nin_shortcut: CausalConv3d
        +forward(x): Tensor
    }

    class CausalResnetBlockFactorized3d {
        -norm1: CausalNormalize
        -conv1: Sequential
        -norm2: CausalNormalize
        -dropout: Dropout
        -conv2: Sequential
        -nin_shortcut: CausalConv3d
        +forward(x): Tensor
        ' factorized (1,3,3)+(3,1,1) convolutions
    }

    class CausalAttnBlock {
        -norm: CausalNormalize
        -q: CausalConv3d
        -k: CausalConv3d
        -v: CausalConv3d
        -proj_out: CausalConv3d
        +forward(x): Tensor
        ' spatial attention per-frame (time2batch trick)
    }

    class CausalTemporalAttnBlock {
        -norm: CausalNormalize
        -q: CausalConv3d
        -k: CausalConv3d
        -v: CausalConv3d
        -proj_out: CausalConv3d
        +forward(x): Tensor
        ' causal temporal attention (space2batch + tril mask)
    }

    class CausalDownsample3d {
        -conv: CausalConv3d
        +forward(x): Tensor
        ' stride=2 spatiotemporal
    }

    class CausalUpsample3d {
        -conv: CausalConv3d
        +forward(x): Tensor
        ' repeat_interleave + trim
    }

    class CausalHybridDownsample3d {
        -conv1: CausalConv3d
        -conv2: CausalConv3d
        -conv3: CausalConv3d
        -spatial_down: bool
        -temporal_down: bool
        +forward(x): Tensor
    }

    class CausalHybridUpsample3d {
        -conv1: CausalConv3d
        -conv2: CausalConv3d
        -conv3: CausalConv3d
        -spatial_up: bool
        -temporal_up: bool
        +forward(x): Tensor
    }
}

' ─────────────────────────────────────────
' PATCHING
' ─────────────────────────────────────────
package "Patching (patching.py)" {

    class Patcher {
        -patch_size: int
        -patch_method: str
        -wavelets: buffer
        -_arange: buffer
        +forward(x): Tensor
        +_dwt(x): Tensor
        +_haar(x): Tensor
        +_arrange(x): Tensor
    }

    class Patcher3D {
        -patch_size_buffer: buffer
        +_dwt(x, wavelet): Tensor
        +_haar(x): Tensor
        +_arrange(x): Tensor
        ' 3D DWT with 8 subbands
    }

    class UnPatcher {
        -patch_size: int
        -patch_method: str
        -wavelets: buffer
        +forward(x): Tensor
        +_idwt(x): Tensor
        +_ihaar(x): Tensor
        +_iarrange(x): Tensor
    }

    class UnPatcher3D {
        +_idwt(x): Tensor
        +_ihaar(x): Tensor
        +_iarrange(x): Tensor
        ' inverse 3D DWT
    }
}

' ─────────────────────────────────────────
' DISTRIBUTIONS
' ─────────────────────────────────────────
package "Distributions (distributions.py)" {

    class GaussianDistribution {
        -min_logvar: float = -30.0
        -max_logvar: float = 20.0
        +sample(mean, logvar): Tensor
        +forward(parameters): Tuple
        ' VAE reparameterization (KL divergence)
    }

    class IdentityDistribution {
        +forward(parameters): Tuple
        ' AE pass-through, zeros for KL terms
    }
}

' ─────────────────────────────────────────
' QUANTIZERS
' ─────────────────────────────────────────
package "Quantizers (quantizers.py)" {

    class VectorQuantizer {
        -n_e: int
        -e_dim: int
        -beta: float
        -embedding: Embedding
        -legacy: bool
        +forward(z): Tuple
        +get_codebook_entry(indices, shape): Tensor
        +remap_to_used(inds): Tensor
        +unmap_to_all(inds): Tensor
        ' nearest-neighbor codebook lookup
    }

    class LFQuantizer {
        -codebook_dim: int
        -default_temp: float
        -commitment_loss_weight: float
        -entropy_loss_weight: float
        -project_in: Linear
        -project_out: Linear
        -mask: buffer
        -codebook: buffer
        +forward(z, temp): Tuple
        ' sign quantization with straight-through gradient
    }

    class FSQuantizer {
        -_levels: buffer
        -_basis: buffer
        -codebook_dim: int
        -num_codebooks: int
        -project_in: Linear
        -project_out: Linear
        -implicit_codebook: buffer
        +forward(z): Tuple
        +quantize(z): Tensor
        +bound(z, eps): Tensor
        +codes_to_indices(zhat): Tensor
        +indices_to_codes(indices, project_out): Tensor
        ' finite scalar quantization with STE
    }

    class ResidualFSQuantizer {
        -layers: ModuleList
        -dtype: torch.dtype
        +forward(x): Tuple
        +indices_to_codes(indices_stack): Tensor
        ' stacked FSQuantizers on residuals
    }

    class InvQuantizerJit {
        -quantizer: FSQuantizer
        +forward(indices): Tensor
        ' JIT-traceable index->code wrapper
    }
}

' ═══════════════════════════════════════════
' RELATIONSHIPS
' ═══════════════════════════════════════════

' Enum -> class references (dependency)
EncoderType      ..> Encoder            : references
DecoderType      ..> Decoder            : references
Encoder3DType    ..> EncoderBase        : references
Encoder3DType    ..> EncoderFactorized  : references
Decoder3DType    ..> DecoderBase        : references
Decoder3DType    ..> DecoderFactorized  : references
Decoder3DType    ..> DecoderFactorizedVanilla : references
Decoder3DType    ..> DecoderBaseVanilla : references
ContinuousFormulation ..> GaussianDistribution : references
ContinuousFormulation ..> IdentityDistribution : references
DiscreteQuantizer ..> VectorQuantizer   : references
DiscreteQuantizer ..> LFQuantizer       : references
DiscreteQuantizer ..> FSQuantizer       : references
DiscreteQuantizer ..> ResidualFSQuantizer : references

' Inheritance
Patcher3D    --|> Patcher
UnPatcher3D  --|> UnPatcher

' 2D Encoder/Decoder composition
Encoder  *-- Patcher       : patcher
Encoder  *-- ResnetBlock   : down blocks
Encoder  *-- AttnBlock     : attention
Encoder  *-- Downsample    : spatial down
Decoder  *-- UnPatcher     : unpatcher
Decoder  *-- ResnetBlock   : up blocks
Decoder  *-- AttnBlock     : attention
Decoder  *-- Upsample      : spatial up

' 3D EncoderBase/DecoderBase composition
EncoderBase  *-- Patcher             : patcher (frame-wise)
EncoderBase  *-- CausalConv3d        : conv_in/conv_out
EncoderBase  *-- CausalResnetBlock3d : down blocks
EncoderBase  *-- CausalAttnBlock     : attention
EncoderBase  *-- CausalDownsample3d  : spatial/temporal down
DecoderBase  *-- UnPatcher           : unpatcher (frame-wise)
DecoderBase  *-- CausalConv3d        : conv_in/conv_out
DecoderBase  *-- CausalResnetBlock3d : up blocks
DecoderBase  *-- CausalAttnBlock     : attention
DecoderBase  *-- CausalUpsample3d    : spatial/temporal up

' 3D EncoderFactorized/DecoderFactorized composition
EncoderFactorized  *-- Patcher3D                    : patcher3d
EncoderFactorized  *-- CausalConv3d                 : conv_in/conv_out
EncoderFactorized  *-- CausalResnetBlockFactorized3d : down blocks
EncoderFactorized  *-- CausalAttnBlock              : spatial attention
EncoderFactorized  *-- CausalTemporalAttnBlock       : temporal attention
EncoderFactorized  *-- CausalHybridDownsample3d      : hybrid down
DecoderFactorized  *-- UnPatcher3D                  : unpatcher3d
DecoderFactorized  *-- CausalConv3d                 : conv_in/conv_out
DecoderFactorized  *-- CausalResnetBlockFactorized3d : up blocks
DecoderFactorized  *-- CausalAttnBlock              : spatial attention
DecoderFactorized  *-- CausalTemporalAttnBlock       : temporal attention
DecoderFactorized  *-- CausalHybridUpsample3d        : hybrid up

' 3D building block internal composition
CausalResnetBlock3d           *-- CausalConv3d    : conv1/conv2
CausalResnetBlock3d           *-- CausalNormalize : norm1/norm2
CausalResnetBlockFactorized3d *-- CausalConv3d    : factorized convs
CausalResnetBlockFactorized3d *-- CausalNormalize : norm1/norm2
CausalAttnBlock               *-- CausalConv3d    : q/k/v/proj_out
CausalTemporalAttnBlock       *-- CausalConv3d    : q/k/v/proj_out
CausalDownsample3d            *-- CausalConv3d    : conv
CausalUpsample3d              *-- CausalConv3d    : conv
CausalHybridDownsample3d      *-- CausalConv3d    : conv1/conv2/conv3
CausalHybridUpsample3d        *-- CausalConv3d    : conv1/conv2/conv3

' Quantizer composition
ResidualFSQuantizer *-- FSQuantizer   : layers (N stacked)
InvQuantizerJit     o-- FSQuantizer   : wraps
InvQuantizerJit     o-- LFQuantizer   : or wraps

@enduml
