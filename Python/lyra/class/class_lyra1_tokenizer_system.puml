@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Lyra-1 Tokenizer System

' ──────────────────────────────────────────────
' Training Model
' ──────────────────────────────────────────────
package "training.model" {
    class TokenizerModel {
        +config
        +network: nn.Module
        +loss: TokenizerLoss
        +metric: TokenizerMetric
        +precision: torch.dtype
        +ema: EMAModelTracker
        +image_key: str
        +video_key: str
        --
        +__init__(config)
        +get_input_key(data_batch): str
        +init_optimizer_scheduler(...): tuple
        +on_train_start(memory_format)
        +state_dict(...): dict
        +load_state_dict(state_dict, strict)
        +training_step(data_batch, iteration): tuple
        +validation_step(data_batch, iteration, ema_model): tuple
        +forward(data_batch): dict
        #_network_forward(data_batch): dict
        #_on_before_network_forward(data_batch)
        #_on_after_network_forward(data_batch, output_batch)
    }
}

' ──────────────────────────────────────────────
' Network Tokenizers
' ──────────────────────────────────────────────
package "networks" {
    class CausalDiscreteVideoTokenizer {
        +name: str
        +embedding_dim: int
        +encoder: EncoderBase | EncoderFactorized
        +decoder: DecoderBase | DecoderFactorized
        +quant_conv: CausalConv3d
        +post_quant_conv: CausalConv3d
        +quantizer: VQ | LFQ | FSQ | ResFSQ
        --
        +__init__(z_channels, z_factor, embedding_dim, **kwargs)
        +encode(x): (quant_info, quant_codes, quant_loss)
        +decode(quant): Tensor
        +decode_code(code_b): Tensor
        +forward(input): dict | NetworkEval
        +encoder_jit(): nn.Sequential
        +decoder_jit(): nn.Sequential
        +last_decoder_layer()
    }

    class DiscreteImageTokenizer {
        +name: str
        +embedding_dim: int
        +encoder: Encoder
        +decoder: Decoder
        +quant_conv: nn.Conv2d
        +post_quant_conv: nn.Conv2d
        +quantizer: VQ | LFQ | FSQ | ResFSQ
        --
        +__init__(z_channels, embedding_dim, **kwargs)
        +encode(x): (quant_info, quant_codes, quant_loss)
        +decode(quant): Tensor
        +decode_code(code_b): Tensor
        +forward(input): dict | NetworkEval
        +encoder_jit(): nn.Sequential
        +decoder_jit(): nn.Sequential
        +last_decoder_layer()
    }

    class ContinuousImageTokenizer {
        +name: str
        +latent_channels: int
        +encoder: Encoder
        +decoder: Decoder
        +quant_conv: nn.Conv2d
        +post_quant_conv: nn.Conv2d
        +distribution: GaussianDistribution | IdentityDistribution
        --
        +__init__(z_channels, z_factor, latent_channels, **kwargs)
        +encode(x): (latent, posteriors)
        +decode(z): Tensor
        +forward(input): dict | NetworkEval
        +encoder_jit(): nn.Sequential
        +decoder_jit(): nn.Sequential
        +last_decoder_layer()
    }

    class CausalContinuousVideoTokenizer {
        +name: str
        +latent_channels: int
        +encoder: EncoderBase | EncoderFactorized
        +decoder: DecoderBase | DecoderFactorized
        +quant_conv: CausalConv3d
        +post_quant_conv: CausalConv3d
        +distribution: GaussianDistribution | IdentityDistribution
        --
        +__init__(z_channels, z_factor, latent_channels, **kwargs)
        +encode(x): (latent, posteriors)
        +decode(z): Tensor
        +forward(input): dict | NetworkEval
        +encoder_jit(): nn.Sequential
        +decoder_jit(): nn.Sequential
        +last_decoder_layer()
    }
}

' ──────────────────────────────────────────────
' Training Metrics
' ──────────────────────────────────────────────
package "training.metrics" {
    class TokenizerMetric {
        +config
        +metric_modules: nn.ModuleDict
        --
        +__init__(config)
        +forward(inputs, output_batch, iteration): dict
    }

    class PSNRMetric {
        --
        +forward(inputs, output_batch, iteration): dict
    }

    class SSIMMetric {
        --
        +forward(inputs, output_batch, iteration): dict
    }

    class CodeUsageMetric {
        +codebook_size: int
        --
        +forward(inputs, output_batch, iteration): dict
    }

    class NULLMetric {
        --
        +forward(inputs, output_batch, iteration): dict
    }
}

' ──────────────────────────────────────────────
' Training Losses
' ──────────────────────────────────────────────
package "training.losses" {
    class TokenizerLoss {
        +config
        +reduce: Callable
        +loss_modules: nn.ModuleDict
        --
        +__init__(config)
        +forward(inputs, output_batch, iteration): tuple
    }

    class ColorLoss {
        +schedule: WeightScheduler
        --
        +forward(inputs, output_batch, iteration): dict
    }

    class KLLoss {
        +schedule: WeightScheduler
        --
        +kl(mean, logvar): Tensor
        +forward(inputs, output_batch, iteration): dict
    }

    class PerceptualLoss {
        +gram_enabled: bool
        +corr_enabled: bool
        +layer_weights: list
        +lpips_schedule: WeightScheduler
        +gram_schedule: WeightScheduler
        +corr_schedule: WeightScheduler
        --
        +forward(inputs, output_batch, iteration): dict
    }

    class FlowLoss {
        +schedule: WeightScheduler
        +scale: float
        +dtype: torch.dtype
        +enabled: bool
        +flow_model: RAFT
        --
        +forward(inputs, output_batch, iteration): dict
        +torch_compile()
        #_bidirectional_flow(input_video)
        #_run_model_fwd(input_video)
    }

    class VideoConsistencyLoss {
        +schedule: WeightScheduler
        +enabled: bool
        +num_frames: int
        +step: int
        +num_windows: int
        --
        +shuffle(inputs): Tensor
        +unshuffle(inputs): Tensor
        +forward(inputs, output_batch, iteration): dict
    }

    class WeightScheduler {
        +boundaries: list
        +values: list
        --
        +forward(iteration): float
    }
}

' ──────────────────────────────────────────────
' Quantizers
' ──────────────────────────────────────────────
package "modules.quantizers" {
    class ResidualFSQuantizer {
        +dtype: torch.dtype
        +layers: nn.ModuleList
        --
        +forward(x): (indices, quantized, loss)
        +indices_to_codes(indices_stack): Tensor
    }

    class FSQuantizer {
        +dtype
        +codebook_dim: int
        +num_codebooks: int
        +dim: int
        +codebook_size: int
        +project_in: Linear | Identity
        +project_out: Linear | Identity
        --
        +bound(z): Tensor
        +quantize(z): Tensor
        +codes_to_indices(zhat): Tensor
        +indices_to_codes(indices, project_out): Tensor
        +forward(z): (indices, out, dummy_loss)
    }

    class VectorQuantizer {
        +n_e: int
        +e_dim: int
        +beta: float
        +embedding: nn.Embedding
        +remap: str
        +legacy: bool
        --
        +forward(z): (z_q, loss, info)
        +get_codebook_entry(indices, shape): Tensor
        +remap_to_used(inds)
        +unmap_to_all(inds)
    }

    class LFQuantizer {
        +codebook_dim: int
        +entropy_loss: bool
        +project_in: Linear | Identity
        +project_out: Linear | Identity
        +dtype
        --
        +forward(z, temp): (z_q, loss, info)
    }

    class InvQuantizerJit {
        +quantizer: nn.Module
        --
        +forward(indices): Tensor
    }
}

' ──────────────────────────────────────────────
' Distributions
' ──────────────────────────────────────────────
package "modules.distributions" {
    class GaussianDistribution {
        +min_logvar: float
        +max_logvar: float
        --
        +sample(mean, logvar): Tensor
        +forward(parameters): (sample, (mean, logvar))
    }

    class IdentityDistribution {
        --
        +forward(parameters): (parameters, (0, 0))
    }
}

' ──────────────────────────────────────────────
' 2D Backbone Layers
' ──────────────────────────────────────────────
package "modules.layers2d" {
    class Encoder {
        ' 2D encoder: ResnetBlock + AttnBlock + Downsample
    }

    class Decoder {
        ' 2D decoder: ResnetBlock + AttnBlock + Upsample
    }
}

' ──────────────────────────────────────────────
' 3D Causal Layers
' ──────────────────────────────────────────────
package "modules.layers3d" {
    class EncoderBase {
        ' 3D causal: CausalConv3d + CausalResnetBlock3d + CausalAttnBlock
    }

    class EncoderFactorized {
        ' Factorized 3D: separate spatial + temporal paths
    }

    class DecoderBase {
        ' 3D causal decoder with CausalUpsample3d
    }

    class DecoderFactorized {
        ' Factorized 3D decoder
    }

    class CausalConv3d {
        ' Pads only past frames (causal)
    }
}

' ══════════════════════════════════════════════
' RELATIONSHIPS
' ══════════════════════════════════════════════

' TokenizerModel owns core components
TokenizerModel *-- TokenizerLoss : loss
TokenizerModel *-- TokenizerMetric : metric
TokenizerModel o-- CausalDiscreteVideoTokenizer : network
TokenizerModel o-- DiscreteImageTokenizer : network
TokenizerModel o-- ContinuousImageTokenizer : network
TokenizerModel o-- CausalContinuousVideoTokenizer : network

' Metric aggregates sub-metrics
TokenizerMetric *-- PSNRMetric : metric_modules
TokenizerMetric *-- SSIMMetric : metric_modules
TokenizerMetric *-- CodeUsageMetric : metric_modules
TokenizerMetric *-- NULLMetric : metric_modules

' Loss aggregates sub-losses
TokenizerLoss *-- ColorLoss : loss_modules
TokenizerLoss *-- KLLoss : loss_modules
TokenizerLoss *-- PerceptualLoss : loss_modules
TokenizerLoss *-- FlowLoss : loss_modules
TokenizerLoss *-- VideoConsistencyLoss : loss_modules

' Loss components use WeightScheduler
ColorLoss o-- WeightScheduler : schedule
KLLoss o-- WeightScheduler : schedule
PerceptualLoss o-- WeightScheduler : lpips_schedule
PerceptualLoss o-- WeightScheduler : gram_schedule
PerceptualLoss o-- WeightScheduler : corr_schedule
FlowLoss o-- WeightScheduler : schedule
VideoConsistencyLoss o-- WeightScheduler : schedule

' Discrete video tokenizer → 3D layers + quantizer
CausalDiscreteVideoTokenizer o-- EncoderBase : encoder (optional)
CausalDiscreteVideoTokenizer o-- EncoderFactorized : encoder (optional)
CausalDiscreteVideoTokenizer o-- DecoderBase : decoder (optional)
CausalDiscreteVideoTokenizer o-- DecoderFactorized : decoder (optional)
CausalDiscreteVideoTokenizer *-- CausalConv3d : quant_conv
CausalDiscreteVideoTokenizer o-- VectorQuantizer : quantizer (optional)
CausalDiscreteVideoTokenizer o-- LFQuantizer : quantizer (optional)
CausalDiscreteVideoTokenizer o-- FSQuantizer : quantizer (optional)
CausalDiscreteVideoTokenizer o-- ResidualFSQuantizer : quantizer (default)

' Discrete image tokenizer → 2D layers + quantizer
DiscreteImageTokenizer o-- Encoder : encoder
DiscreteImageTokenizer o-- Decoder : decoder
DiscreteImageTokenizer o-- VectorQuantizer : quantizer (optional)
DiscreteImageTokenizer o-- LFQuantizer : quantizer (optional)
DiscreteImageTokenizer o-- FSQuantizer : quantizer (optional)
DiscreteImageTokenizer o-- ResidualFSQuantizer : quantizer (optional)

' Continuous image tokenizer → 2D layers + distribution
ContinuousImageTokenizer o-- Encoder : encoder
ContinuousImageTokenizer o-- Decoder : decoder
ContinuousImageTokenizer o-- GaussianDistribution : distribution (VAE)
ContinuousImageTokenizer o-- IdentityDistribution : distribution (AE)

' Continuous video tokenizer → 3D layers + distribution
CausalContinuousVideoTokenizer o-- EncoderBase : encoder (optional)
CausalContinuousVideoTokenizer o-- EncoderFactorized : encoder (default)
CausalContinuousVideoTokenizer o-- DecoderBase : decoder (optional)
CausalContinuousVideoTokenizer o-- DecoderFactorized : decoder (default)
CausalContinuousVideoTokenizer *-- CausalConv3d : quant_conv
CausalContinuousVideoTokenizer o-- GaussianDistribution : distribution (VAE)
CausalContinuousVideoTokenizer o-- IdentityDistribution : distribution (AE)

' Residual quantizer stacks FSQuantizers
ResidualFSQuantizer *-- FSQuantizer : layers (ModuleList)

' InvQuantizerJit wraps any quantizer for JIT export
InvQuantizerJit o-- ResidualFSQuantizer : quantizer

@enduml
