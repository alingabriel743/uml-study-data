@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam arrow {
    Color #495057
}

title Lyra-2 Imaginaire Training Framework

' ─────────────────────────────────────────────
' CONFIG PACKAGE
' ─────────────────────────────────────────────
package "lyra_2._ext.imaginaire.config" {

    class Config << (C,#D4E6F1) attrs >> {
        +model: LazyDict
        +optimizer: LazyDict
        +scheduler: LazyDict
        +dataloader_train: LazyDict
        +dataloader_val: LazyDict
        +job: JobConfig
        +trainer: TrainerConfig
        +model_parallel: ModelParallelConfig | None
        +checkpoint: CheckpointConfig
        +upload_reproducible_setup: bool
        --
        +pretty_print(use_color: bool): str
        +to_dict(): dict
        +validate(): None
    }

    class JobConfig << (C,#D4E6F1) attrs >> {
        +project: str
        +group: str
        +name: str
        --
        +path: str
        +path_local: str
    }

    class TrainerConfig << (C,#D4E6F1) attrs >> {
        +type: Type[ImaginaireTrainer]
        +callbacks: LazyDict
        +distributed_parallelism: str
        +ddp: DDPConfig
        +cudnn: CuDNNConfig
        +seed: int
        +max_iter: int
        +max_val_iter: int | None
        +logging_iter: int
        +run_validation: bool
        +validation_iter: int
        +grad_accum_iter: int
        +memory_format: torch.memory_format
        +straggler_detection: StragglerDetectionConfig
        +profiling: Profiling
    }

    class CheckpointConfig << (C,#D4E6F1) attrs >> {
        +save_iter: int
        +load_path: str
        +load_training_state: bool
        +strict_resume: bool
        +dcp_async_mode_enabled: bool
        +load_ema_to_reg: bool
        +keys_not_to_resume: list[str]
        +verbose: bool
        +save_to_object_store: ObjectStoreConfig
        +load_from_object_store: ObjectStoreConfig
        +jit: JITConfig
    }

    class DDPConfig << (C,#D4E6F1) attrs >> {
        +find_unused_parameters: bool
        +static_graph: bool
        +broadcast_buffers: bool
    }

    class EMAConfig << (C,#D4E6F1) attrs >> {
        +enabled: bool
        +beta: float
        +torch_compile_buffer_renaming: bool
    }

    class PowerEMAConfig << (C,#D4E6F1) attrs >> {
        +enabled: bool
        +s: float
        +torch_compile_buffer_renaming: bool
    }

    class NVTXConfig << (C,#D4E6F1) attrs >> {
        +enabled: bool
        +cuda_synchronize: bool
    }

    class CuDNNConfig << (C,#D4E6F1) attrs >> {
        +deterministic: bool
        +benchmark: bool
    }

    class JITConfig << (C,#D4E6F1) attrs >> {
        +enabled: bool
        +input_shape: list[int] | None
        +device: str
        +dtype: str
        +strict: bool
    }

    class ObjectStoreConfig << (C,#D4E6F1) attrs >> {
        +enabled: bool
        +credentials: str
        +bucket: str
    }

    class StragglerDetectionConfig << (C,#D4E6F1) attrs >> {
        +enabled: bool
        +report_freq: int
        +profile_freq: int
        +max_diff: float
        +raise_error: bool
        +analyze_forward: bool
        +analyze_backward: bool
    }

    class Profiling << (C,#D4E6F1) attrs >> {
        +enable_profiling: bool
        +enable_memory_snapshot: bool
        +save_s3: bool
        +profile_freq: int
        +target_ranks: list[int]
        +record_shape: bool
        +profile_memory: bool
        +with_stack: bool
        +with_modules: bool
    }
}

' ─────────────────────────────────────────────
' TRAINER PACKAGE
' ─────────────────────────────────────────────
package "lyra_2._ext.imaginaire.trainer" {

    class ImaginaireTrainer {
        +config: Config
        +callbacks: CallBackGroup
        +checkpointer: Checkpointer
        +training_timer: TrainingTimer
        +straggler_detector: StragglerDetectorV2
        --
        +__init__(config: Config): None
        +train(model, dataloader_train, dataloader_val): None
        +training_step(model_ddp, optimizer, scheduler,\n  grad_scaler, data, iteration, grad_accum_iter): tuple
        +validate(model, dataloader_val, iteration): None
    }
}

' ─────────────────────────────────────────────
' MODEL PACKAGE
' ─────────────────────────────────────────────
package "lyra_2._ext.imaginaire.model" {

    class ImaginaireModel << (A,#FAD7A0) abstract >> {
        --
        +__init__(): None
        +init_optimizer_scheduler(optimizer_config, scheduler_config): tuple
        +{abstract} training_step(data_batch, iteration): tuple
        +{abstract} validation_step(data_batch, iteration): tuple
        +{abstract} forward(*args, **kwargs): Any
        +on_train_start(memory_format): None
        +on_after_backward(): None
        +on_before_zero_grad(optimizer, scheduler, iteration): None
    }

    note right of ImaginaireModel
      Extends torch.nn.Module.
      Subclasses implement
      training_step / validation_step
      / forward.
    end note
}

' ─────────────────────────────────────────────
' CALLBACK PACKAGE
' ─────────────────────────────────────────────
package "lyra_2._ext.imaginaire.utils.callback" {

    class CallBackGroup {
        -_callbacks: list<Callback>
        --
        +__init__(config: Config, trainer: ImaginaireTrainer): None
        +__getattr__(method_name: str): Callable
    }

    note right of CallBackGroup
      __getattr__ fans out any
      method call to all registered
      Callback instances.
    end note

    class Callback << (A,#FAD7A0) base >> {
        --
        +__init__(config, trainer)
        +on_train_start(model, iteration)
        +on_training_step_start(model, data, iteration)
        +on_training_step_end(model, data_batch,\n  output_batch, loss, iteration)
        +on_before_forward(iteration)
        +on_after_forward(iteration)
        +on_before_backward(model_ddp, loss, iteration)
        +on_after_backward(model_ddp, iteration)
        +on_before_optimizer_step(...)
        +on_before_zero_grad(...)
        +on_before_dataloading(iteration)
        +on_after_dataloading(iteration)
        +on_validation_start(model, dataloader_val, iteration)
        +on_validation_end(model, iteration)
        +on_load_checkpoint_end(model, iteration, path)
        +on_save_checkpoint_end(model, iteration)
        +on_train_end(model, iteration)
        +on_app_end()
    }

    class EMAModelCallback {
        --
        +on_train_start(model, iteration)
        +on_training_step_end(model, data_batch,\n  output_batch, loss, iteration)
    }

    class ProgressBarCallback {
        +train_pbar: tqdm.trange
        +val_pbar: tqdm.trange
        --
        +on_train_start(model, iteration)
        +on_training_step_end(...)
        +on_validation_start(...)
        +on_validation_step_end(...)
        +on_validation_end(model, iteration)
        +on_train_end(model, iteration)
    }

    class IterationLoggerCallback {
        +start_iteration_time: float
        +elapsed_iteration_time: float
        --
        +on_train_start(model, iteration)
        +on_training_step_start(model, data, iteration)
        +on_training_step_end(...)
    }

    class LowPrecisionCallback {
        +update_iter: int
        +precision_type: torch.dtype
        --
        +__init__(config, trainer, update_iter: int)
        +on_train_start(model, iteration)
        +on_training_step_start(model, data, iteration)
        +on_validation_step_start(model, data, iteration)
        +on_before_zero_grad(...)
    }

    class NVTXCallback {
        +synchronize: bool
        --
        +__init__(synchronize: bool, config, trainer)
        +on_before_forward(iteration)
        +on_after_forward(iteration)
        +on_before_backward(model_ddp, loss, iteration)
        +on_after_backward(model_ddp, iteration)
        +on_before_optimizer_step(...)
        +on_before_zero_grad(...)
        +on_before_dataloading(iteration)
        +on_after_dataloading(iteration)
    }

    note bottom of NVTXCallback
      Pushes/pops NVTX ranges around
      forward / backward / optimizer /
      dataloading for GPU profiling.
    end note
}

' ─────────────────────────────────────────────
' EMA PACKAGE
' ─────────────────────────────────────────────
package "lyra_2._ext.imaginaire.utils.ema" {

    class EMAModelTracker << nn.Module >> {
        +beta: float
        +torch_compile_buffer_renaming: bool
        +collected_params: list
        +is_cached: bool
        --
        +__init__(model, beta, torch_compile_buffer_renaming)
        +update_average(model, iteration): None
        +copy_to(model): None
        +cache(parameters, is_cpu): None
        +restore(parameters): None
        +{static} initialize_multi_rank_ema(model, rate,\n  num, enabled): EMAModelTracker | None
    }

    class PowerEMATracker {
        +exp: float
        --
        +__init__(model, s, torch_compile_buffer_renaming)
        +update_average(model, iteration): None
        +{static} initialize_multi_rank_ema(model, rate,\n  num, enabled): PowerEMATracker | None
    }

    class FastEmaModelUpdater {
        +is_cached: bool
        +collected_params: list
        --
        +__init__()
        +update_average(src_model, tgt_model, beta): None
        +copy_to(src_model, tgt_model): None
        +cache(parameters, is_cpu): None
        +restore(parameters): None
    }

    note right of FastEmaModelUpdater
      Stateless (no buffers).
      Designed for FSDP where
      buffer-based EMA breaks.
    end note
}

' ─────────────────────────────────────────────
' MODEL WEIGHTS STATS PACKAGE
' ─────────────────────────────────────────────
package "lyra_2._src.callbacks.model_weights_stats" {

    class TrainingStats << (D,#D5F5E3) dataclass >> {
        +video_samples: int
        +image_samples: int
        +iterations: int
        +training_hours: float
    }

    abstract class WeightTrainingStat << nn.Module, ABC >> {
        +accum_video_sample_counter: Tensor
        +accum_image_sample_counter: Tensor
        +accum_iteration: Tensor
        +accum_train_in_hours: Tensor
        --
        +__init__(): None
        -_initialize_tracking_buffers(): None
        +get_training_stats(): TrainingStats
        +{abstract} forward(*args, **kwargs): Any
    }
}

' ─────────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────────

' Config composition
Config *-- JobConfig : job
Config *-- TrainerConfig : trainer
Config *-- CheckpointConfig : checkpoint

' TrainerConfig composition
TrainerConfig *-- DDPConfig : ddp
TrainerConfig *-- CuDNNConfig : cudnn
TrainerConfig *-- StragglerDetectionConfig : straggler_detection
TrainerConfig *-- Profiling : profiling

' CheckpointConfig composition
CheckpointConfig *-- ObjectStoreConfig : save / load
CheckpointConfig *-- JITConfig : jit

' Trainer relationships
ImaginaireTrainer *-- CallBackGroup : callbacks
ImaginaireTrainer ..> Config : uses
ImaginaireTrainer ..> ImaginaireModel : trains / validates

' CallBackGroup aggregates Callbacks
CallBackGroup o-- Callback : dispatches to

' Callback inheritance
EMAModelCallback --|> Callback
ProgressBarCallback --|> Callback
IterationLoggerCallback --|> Callback
LowPrecisionCallback --|> Callback
NVTXCallback --|> Callback

' EMA tracker inheritance
PowerEMATracker --|> EMAModelTracker

' EMAModelCallback → EMAModelTracker
EMAModelCallback ..> EMAModelTracker : uses model.ema

' WeightTrainingStat produces TrainingStats
WeightTrainingStat ..> TrainingStats : produces

@enduml
