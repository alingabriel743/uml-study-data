@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Lyra-2 I/O and Storage Backends

' ─────────────────────────────────────────────
' External / stdlib types
' ─────────────────────────────────────────────
package "External (torch.distributed.checkpoint)" <<Frame>> {
    abstract class FileSystemBase {
        +create_stream(path, mode): Generator
        +concat_path(path, suffix): str
        +init_path(path): str
        +rename(path, new_path): None
        +exists(path): bool
    }
    class FileSystemWriter {
        +write_data(plan, planner): Future
    }
    class FileSystemReader {
        +read_data(plan, planner): Future
    }
}

package "External (stdlib / boto3)" <<Frame>> {
    class "io.BytesIO" as BytesIO {
        +read(): bytes
        +write(b): int
        +getvalue(): bytes
        +close(): None
    }
    class "boto3.client" as Boto3RawClient {
        +get_object(Bucket, Key)
        +put_object(Bucket, Key, Body)
        +list_objects_v2(Bucket, Prefix)
        +delete_object(Bucket, Key)
    }
}

' ─────────────────────────────────────────────
' easy_io package
' ─────────────────────────────────────────────
package "easy_io" <<Rectangle>> {

    abstract class BaseStorageBackend {
        #_allow_symlink: bool = False
        --
        +allow_symlink: bool  <<property>>
        +name: str  <<property>>
        --
        {abstract} +get(filepath): bytes
        {abstract} +get_text(filepath): str
    }

    class LocalBackend {
        #_allow_symlink: bool = True
        --
        +get(filepath: str|Path): bytes
        +get_text(filepath: str|Path, encoding='utf-8'): str
        +put(obj: bytes|BytesIO, filepath): None
        +put_text(obj: str, filepath): None
        +exists(filepath): bool
        +isdir(filepath): bool
        +isfile(filepath): bool
        +join_path(filepath, *filepaths): str
        +get_local_path(filepath): Generator
        +remove(filepath): None
        +rmtree(dir_path): None
        +copyfile(src, dst): str
        +copytree(src, dst): str
        +list_dir_or_file(dir_path, ...): Iterator[str]
    }

    class HardDiskBackend {
        --
        +name: str  <<property>>
        ' Thin alias for LocalBackend; registered as "disk" in FileClient
    }

    class Boto3Client {
        -_client: boto3.client
        -_s3_cred_info: dict
        -_mc_kv_store: Optional
        +max_attempt: int = 3
        --
        +__init__(s3_credential_path: str, max_attempt: int=3)
        +get(filepath: str): bytes
        +put(obj: bytes|BytesIO|str, filepath: str): None
        +fast_put(obj, filepath, num_processes=32): None
        +contains(filepath: str, max_retries=10): bool
        +isdir(filepath: str, max_retries=10): bool
        +delete(filepath: str): None
        +ls_dir(filepath: str): Generator[str]
        +list(filepath: str, exclude_prefix=None): Generator[str]
        -_check_path(filepath: str): str
        -_get_file_size(bucket, key, max_retries=10): int
    }

    class Boto3Backend {
        -_client: Boto3Client
        +path_mapping: Optional[dict]
        --
        +__init__(s3_credential_path: str='', path_mapping: Optional[dict]=None)
        +get(filepath: str|Path): bytes
        +get_text(filepath, encoding='utf-8'): str
        +put(obj: bytes|BytesIO, filepath): None
        +fast_put(obj, filepath, num_processes=32): None
        +put_text(obj: str, filepath): None
        +exists(filepath): bool
        +isdir(filepath): bool
        +isfile(filepath): bool
        +join_path(filepath, *filepaths): str
        +get_local_path(filepath): Generator
        +remove(filepath): None
        +copyfile(src, dst): str
        +copytree(src, dst): str
        +generate_presigned_url(url, client_method, expires_in): str
        +list_dir_or_file(dir_path, ...): Iterator[str]
        -_map_path(filepath): str
        -_format_path(filepath): str
        -_replace_prefix(filepath): str
    }

    class FileClient {
        ' Singleton pattern via __new__ + _instances dict
        -{static} _backends: dict
        -{static} _prefix_to_backends: dict
        -{static} _instances: dict
        -client: BaseStorageBackend
        --
        +__new__(cls, backend=None, prefix=None, **kwargs): FileClient
        +name: str  <<property>>
        +allow_symlink: bool  <<property>>
        +get(filepath): bytes|memoryview
        +get_text(filepath, encoding='utf-8'): str
        +put(obj: bytes, filepath): None
        +put_text(obj: str, filepath): None
        +remove(filepath): None
        +exists(filepath): bool
        +isdir(filepath): bool
        +isfile(filepath): bool
        +join_path(filepath, *filepaths): str
        +get_local_path(filepath): Generator
        +list_dir_or_file(dir_path, ...): Iterator[str]
        +{static} parse_uri_prefix(uri): Optional[str]
        +{static} infer_client(file_client_args=None, uri=None): FileClient
        +{static} register_backend(name, backend=None, force=False, prefixes=None)
    }

}

' ─────────────────────────────────────────────
' checkpointer package
' ─────────────────────────────────────────────
package "checkpointer (PyTorch DCP)" <<Rectangle>> {

    class S3Stream {
        ' Prevents premature close before S3 upload
        --
        +close(): None  ' noop — flush only
        +_true_close(): None
    }

    class S3FileSystem {
        +s3_client: boto3.client
        +max_attempts: int = 20
        +initial_backoff: float = 1.0
        +max_backoff: float = 30.0
        +backoff_factor: float = 2.0
        --
        +__init__(credential_path: str, max_attempts=20, ...)
        +create_stream(path, mode: 'rb'|'wb'): Generator[IOBase]
        +concat_path(path, suffix: str): str
        +init_path(path): str
        +rename(path, new_path): None
        +mkdir(path): None  ' noop
        +exists(path): bool
        +rm_file(path): None
        +{static} validate_checkpoint_id(checkpoint_id): bool
        -_retry_with_backoff(operation_func, *args, **kwargs)
        -_parse_s3_uri(uri: str): tuple[str, str]
    }

    class S3StorageWriter {
        +fs: S3FileSystem
        +path: str
        --
        +__init__(credential_path: str, path: str, **kwargs)
        +{static} validate_checkpoint_id(checkpoint_id): bool
    }

    class S3StorageReader {
        +fs: S3FileSystem
        +path: str
        +sync_files: bool = False
        --
        +__init__(credential_path: str, path: str)
        +{static} validate_checkpoint_id(checkpoint_id): bool
    }

}

' ─────────────────────────────────────────────
' Inheritance relationships
' ─────────────────────────────────────────────
BaseStorageBackend <|-- LocalBackend
LocalBackend       <|-- HardDiskBackend
BaseStorageBackend <|-- Boto3Backend

FileSystemBase     <|-- S3FileSystem
FileSystemWriter   <|-- S3StorageWriter
FileSystemReader   <|-- S3StorageReader
BytesIO            <|-- S3Stream

' ─────────────────────────────────────────────
' Composition / association relationships
' ─────────────────────────────────────────────
FileClient   *--  BaseStorageBackend   : client\n(resolved at runtime)
Boto3Backend *--  Boto3Client          : _client
S3StorageWriter *-- S3FileSystem       : fs
S3StorageReader *-- S3FileSystem       : fs

' ─────────────────────────────────────────────
' Dependencies
' ─────────────────────────────────────────────
Boto3Client   -->  Boto3RawClient : _client (s3)
S3FileSystem  -->  Boto3RawClient : s3_client (s3)

FileClient  ..>  HardDiskBackend : instantiates\n«disk»
FileClient  ..>  Boto3Backend    : instantiates\n«s3»

S3FileSystem ..>  S3Stream : creates for\n«wb» mode

' ─────────────────────────────────────────────
' Design pattern annotations
' ─────────────────────────────────────────────
note top of FileClient
  <b>Singleton</b> (keyed by backend:prefix:kwargs)
  <b>Facade</b> — proxies all ops to self.client
  <b>Strategy</b> — swappable BaseStorageBackend
end note

note right of Boto3Client
  fast_put uses <b>aioboto3</b> +
  multipart upload via
  <b>ProcessPoolExecutor</b>
end note

note right of S3FileSystem
  Independent of easy_io stack.
  Used for <b>PyTorch DCP</b>
  distributed checkpointing.
  Exponential backoff retry.
end note

note bottom of S3Stream
  <b>close()</b> is a noop —
  prevents PyTorch from closing
  buffer before S3 upload finishes.
  Call <b>_true_close()</b> to release.
end note

@enduml
