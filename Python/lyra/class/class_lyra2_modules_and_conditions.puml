@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Lyra-2 Conditioning Modules

' ─────────────────────────────────────────
' External / framework stubs
' ─────────────────────────────────────────
package "PyTorch (external)" {
    class "nn.Module" as nnModule {
    }
    class "ABC" as ABC {
    }
}

' ─────────────────────────────────────────
' Data-type enum & condition hierarchy
' ─────────────────────────────────────────
package "modules/conditioner.py" {

    enum DataType {
        IMAGE = "image"
        VIDEO = "video"
        MIX   = "mix"
        COUPLED = "coupled"
        +__str__() : str
    }

    abstract class BaseCondition <<frozen dataclass>> {
        -{field} _is_broadcasted : bool = False
        +is_broadcasted : bool
        +to_dict(skip_underscore=True) : Dict[str, Any]
        +{abstract} broadcast(process_group: ProcessGroup) : BaseCondition
    }

    class T2VCondition <<frozen dataclass>> {
        +crossattn_emb : Optional[Tensor] = None
        +data_type : DataType = DataType.VIDEO
        +padding_mask : Optional[Tensor] = None
        +fps : Optional[Tensor] = None
        +is_video : bool
        +edit_data_type(data_type: DataType) : T2VCondition
        +broadcast(process_group: ProcessGroup) : BaseCondition
    }

    abstract class AbstractEmbModel {
        -{field} _is_trainable
        -{field} _dropout_rate
        -{field} _input_key
        -{field} _return_dict : bool = False
        +is_trainable : bool
        +dropout_rate : Union[float, Tensor]
        +input_key : str
        +is_return_dict : bool
        +random_dropout_input(in_tensor: Tensor, dropout_rate=None, key=None) : Tensor
        +details() : str
        +summary() : str
    }

    class TextAttr {
        +__init__(input_key: List[str], dropout_rate: float = 0.0)
        +forward(token: Tensor) : Dict
        +random_dropout_input(in_tensor, dropout_rate=None, key=None) : Tensor
        +details() : str
    }

    class TextAttrEmptyStringDrop {
        +empty_prompt_data : Optional[Tensor] = None
        +__init__(input_key: List[str], dropout_rate: float = 0.0)
        +forward(token: Tensor) : Dict
        +random_dropout_input(in_tensor, dropout_rate=None, key=None) : Tensor
        +details() : str
    }

    class ReMapkey {
        +__init__(input_key: str, output_key: Optional[str]=None, dropout_rate=0.0, dtype: Optional[str]=None)
        +forward(element: Tensor) : Dict[str, Tensor]
        +details() : str
    }

    abstract class GeneralConditioner {
        +KEY2DIM : dict = \{"crossattn_emb": 1\}
        +embedders : nn.ModuleDict
        +__init__(**emb_models)
        +{abstract} forward(batch: Dict, override_dropout_rate=None) : Any
        +_forward(batch: Dict, override_dropout_rate=None) : Dict
        +get_condition_uncondition(data_batch: Dict) : Tuple[Any, Any]
        +get_condition_with_negative_prompt(data_batch: Dict) : Tuple[Any, Any]
    }
}

' ─────────────────────────────────────────
' Config-level concrete classes
' ─────────────────────────────────────────
package "configs/defaults/conditioner.py" {

    class Img2VidWan2pt1ConditionLyra2 <<frozen dataclass>> {
        +frame_cond_crossattn_emb_B_L_D : Optional[Tensor] = None
        +y_B_C_T_H_W : Optional[Tensor] = None
        +y_buffer_B_C_T_H_W : Optional[Tensor] = None
        +broadcast(process_group: ProcessGroup) : BaseCondition
    }

    class Img2VidWan2pt1ConditionerLyra2 {
        +forward(batch: Dict, override_dropout_rate=None) : Img2VidWan2pt1ConditionLyra2
    }
}

' ─────────────────────────────────────────
' CLIP visual embedder hierarchy
' ─────────────────────────────────────────
package "networks/clip_lyra2.py" {

    class Wan2pt1CLIPEmbLyra2 {
        +num_token : int = 257
        +model_dim : int = 1280
        +__init__(input_key: List[str], dropout_rate=0.0, num_token=257, dtype="bfloat16")
        +random_dropout_input(in_tensor, dropout_rate, key) : Tensor
        +forward(image_tensor, video_tensor, media_latents, mask, buffer_latents) : Dict[str, Tensor]
    }
}

package "modules/clip.py & umt5.py" {

    class CLIPModel {
        +model : XLMRobertaCLIP
        +transforms
        +__init__(dtype, device, checkpoint_path, tokenizer_path)
        +visual(videos_B_C_H_W_n1_p1) : Tensor
    }

    class HuggingfaceTokenizer {
        +tokenizer : AutoTokenizer
        +vocab_size : int
        +seq_len
        +clean
        +__init__(name, seq_len=None, clean=None)
        +__call__(sequence, **kwargs) : Tensor
        +_clean(text) : str
    }
}

' ─────────────────────────────────────────
' Inheritance relationships
' ─────────────────────────────────────────
nnModule      <|-- AbstractEmbModel
nnModule      <|-- GeneralConditioner
ABC           <|-- BaseCondition
ABC           <|-- GeneralConditioner

BaseCondition <|-- T2VCondition
T2VCondition  <|-- Img2VidWan2pt1ConditionLyra2

AbstractEmbModel <|-- TextAttr
AbstractEmbModel <|-- TextAttrEmptyStringDrop
AbstractEmbModel <|-- ReMapkey
AbstractEmbModel <|-- Wan2pt1CLIPEmbLyra2

GeneralConditioner <|-- Img2VidWan2pt1ConditionerLyra2

' ─────────────────────────────────────────
' Composition / dependency relationships
' ─────────────────────────────────────────
GeneralConditioner           *-- AbstractEmbModel          : embedders\n(nn.ModuleDict)

Wan2pt1CLIPEmbLyra2          *-- CLIPModel                 : clip_model
CLIPModel                    *-- HuggingfaceTokenizer       : tokenizer

T2VCondition                 --> DataType                   : data_type

GeneralConditioner           ..> T2VCondition               : creates in\nforward()
Img2VidWan2pt1ConditionerLyra2 ..> Img2VidWan2pt1ConditionLyra2 : creates in\nforward()

@enduml
