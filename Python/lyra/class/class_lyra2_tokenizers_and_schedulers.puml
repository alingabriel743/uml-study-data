@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Lyra-2 Tokenizers and Flow Schedulers

' ─────────────────────────────────────────
' External / framework classes
' ─────────────────────────────────────────
package "External (PyTorch / Diffusers)" <<Frame>> {
    abstract class "torch.nn.Module" as TorchModule {
    }
    abstract class ABC {
    }
    class "SchedulerMixin" as SchedulerMixin {
    }
    class "ConfigMixin" as ConfigMixin {
    }
    class "FlowMatchEulerDiscreteScheduler" as FMEuler {
        +set_timesteps()
        +sigmas: Tensor
    }
    class "diffusers.AutoencoderKL" as AutoencoderKL {
    }
}

' ─────────────────────────────────────────
' Tokenizer Interface
' ─────────────────────────────────────────
package "lyra_2._src.tokenizers" {

    abstract class VideoTokenizerInterface {
        +backend_args: None
        ..abstract..
        +{abstract} reset_dtype()
        +{abstract} encode(state: Tensor): Tensor
        +{abstract} decode(latent: Tensor): Tensor
        +{abstract} get_latent_num_frames(num_pixel_frames: int): int
        +{abstract} get_pixel_num_frames(num_latent_frames: int): int
        +{abstract} spatial_compression_factor: int
        +{abstract} temporal_compression_factor: int
        +{abstract} spatial_resolution: int
        +{abstract} pixel_chunk_duration: int
        +{abstract} latent_chunk_duration: int
        +{abstract} latent_ch: int
        ..concrete..
        +is_chunk_overlap: bool
        +is_causal: bool
    }

    ' ── BaseVAE hierarchy ──────────────────
    abstract class BaseVAE {
        +channel: int
        +name: str
        ..abstract..
        +{abstract} encode(state: Tensor): Tensor
        +{abstract} decode(latent: Tensor): Tensor
        ..concrete..
        +latent_ch: int
        +spatial_compression_factor
    }

    abstract class BasePretrainedImageVAE {
        +dtype: torch.dtype
        +is_image: bool
        +mean_std_fp: str
        +load_mean_std: bool
        +backend_args: None
        +latent_mean: Tensor
        +latent_std: Tensor
        --
        +register_mean_std(mean_std_fp: str): None
        +encode(state: Tensor): Tensor
        +decode(latent: Tensor): Tensor
        +reset_dtype()
    }

    class JITVAE {
        +encoder: TorchScript
        +decoder: TorchScript
        --
        +load_encoder(enc_fp: str): None
        +load_decoder(dec_fp: str): None
    }

    class StateDictVAE {
        +vae: nn.Module
        +encoder: Callable
        +decoder: Callable
        --
        +load_encoder_and_decoder(enc_fp, dec_fp, vae): None
        +reset_dtype()
    }

    class SDVAE {
        +dtype: bfloat16
        +scale: Tensor
        +bias: Tensor
        +batch_size: int
        +is_downsample: bool
        +vae: AutoencoderKL
        --
        +encode(state: Tensor): Tensor
        +decode(latent: Tensor): Tensor
        +reset_dtype()
        +spatial_compression_factor: 8
    }

    ' ── WanVAE components ─────────────────
    class WanVAE_ {
        +dim: int
        +z_dim: int
        +dim_mult: List[int]
        +num_res_blocks: int
        +temporal_window: int
        +encoder: Encoder3d
        +decoder: Decoder3d
        +conv1: CausalConv3d
        +conv2: CausalConv3d
        --
        +forward(x): (x_recon, mu, log_var)
        +encode(x, scale): Tensor
        +decode(z, scale): Tensor
        +reparameterize(mu, log_var): Tensor
        +sample(imgs, deterministic): Tensor
        +clear_cache(): None
        -_encode_single_batch(x, scale): Tensor
        -_decode_single_batch(z, scale): Tensor
    }

    class WanVAE {
        +dtype: torch.dtype
        +device: torch.device
        +temporal_window: int
        +mean: Tensor
        +std: Tensor
        +scale: List[Tensor]
        +model: WanVAE_
        +is_amp: bool
        --
        +encode(videos: Tensor): Tensor
        +decode(zs: Tensor): Tensor
        +count_param(): int
    }

    class Wan2pt1VAEInterface {
        +chunk_duration: int
        +model: WanVAE
        --
        +encode(state: Tensor): Tensor
        +decode(latent: Tensor): Tensor
        +reset_dtype()
        +get_latent_num_frames(n): int
        +get_pixel_num_frames(n): int
        +spatial_compression_factor: 8
        +temporal_compression_factor: 4
        +latent_ch: 16
        +spatial_resolution: 512
        +pixel_chunk_duration: int
        +latent_chunk_duration: int
    }

    ' ── Internal WanVAE_ sub-modules ──────
    class Encoder3d {
        +forward(x): Tensor
    }
    class Decoder3d {
        +forward(z): Tensor
    }
    class CausalConv3d {
        +forward(x): Tensor
    }
}

' ─────────────────────────────────────────
' Schedulers
' ─────────────────────────────────────────
package "lyra_2._src.schedulers" {

    class TrainTimeSampler {
        +distribution: str
        +max_timestep_boundary: float
        +min_timestep_boundary: float
        --
        +__call__(batch_size, device, dtype): Tensor
    }

    class TrainTimeWeight {
        +weight: str
        +noise_scheduler
        +linear_timesteps_weights: Tensor
        --
        +__call__(t, tensor_kwargs): Tensor
    }

    class RectifiedFlow {
        +velocity_field: Callable
        +use_t_in_reverse_order: bool
        +device: torch.device
        +dtype: torch.dtype
        +train_time_sampler: TrainTimeSampler
        +noise_scheduler: FlowMatchEulerDiscreteScheduler
        +train_time_weight: TrainTimeWeight
        --
        +sample_train_time(batch_size): Tensor
        +get_discrete_timestamp(u, tensor_kwargs): Tensor
        +get_sigmas(timesteps, tensor_kwargs): Tensor
        +get_interpolation(x_0, x_1, sigmas, t): Tuple
        +get_x0_from_flow_prediction(x_t, dot_x_t, t, sigmas): Tensor
        +temporary_use_t_in_reverse_order(flag)
    }
}

' ─────────────────────────────────────────
' Flow Solver
' ─────────────────────────────────────────
package "lyra_2._src.models" {

    class FlowUniPCMultistepScheduler {
        +predict_x0: bool
        +num_inference_steps: int
        +sigmas: Tensor
        +timesteps: Tensor
        +model_outputs: List[Tensor]
        +lower_order_nums: int
        +disable_corrector: List[int]
        +solver_p: SchedulerMixin
        +last_sample: Tensor
        +sigma_min: float
        +sigma_max: float
        --
        +set_timesteps(num_inference_steps, device, sigmas, mu, shift)
        +convert_model_output(model_output, sample): Tensor
        +multistep_uni_p_bh_update(model_output, sample, order): Tensor
        +multistep_uni_c_bh_update(this_model_output, last_sample, this_sample, order): Tensor
        +step(model_output, timestep, sample, return_dict): SchedulerOutput
        +add_noise(original_samples, noise, timesteps): Tensor
        +scale_model_input(sample): Tensor
        +time_shift(mu, sigma, t): float
        +__len__(): int
    }
}

' ─────────────────────────────────────────
' Inheritance relationships
' ─────────────────────────────────────────

' VideoTokenizerInterface extends ABC
ABC <|-- VideoTokenizerInterface

' BaseVAE extends nn.Module + ABC
TorchModule <|-- BaseVAE
ABC <|-- BaseVAE

' BasePretrainedImageVAE extends BaseVAE
BaseVAE <|-- BasePretrainedImageVAE

' Concrete VAEs
BasePretrainedImageVAE <|-- JITVAE
BasePretrainedImageVAE <|-- StateDictVAE
BaseVAE <|-- SDVAE

' WanVAE_ extends nn.Module
TorchModule <|-- WanVAE_

' Wan2pt1VAEInterface implements VideoTokenizerInterface
VideoTokenizerInterface <|.. Wan2pt1VAEInterface

' FlowUniPCMultistepScheduler extends SchedulerMixin + ConfigMixin
SchedulerMixin <|-- FlowUniPCMultistepScheduler
ConfigMixin <|-- FlowUniPCMultistepScheduler

' ─────────────────────────────────────────
' Composition / Aggregation
' ─────────────────────────────────────────

' WanVAE_ owns Encoder3d, Decoder3d, CausalConv3d
WanVAE_ *-- Encoder3d : encoder
WanVAE_ *-- Decoder3d : decoder
WanVAE_ *-- CausalConv3d : conv1 / conv2

' WanVAE wraps WanVAE_ (created via factory)
WanVAE o-- WanVAE_ : model

' Wan2pt1VAEInterface owns WanVAE
Wan2pt1VAEInterface *-- WanVAE : model

' StateDictVAE uses an injected nn.Module
StateDictVAE o-- TorchModule : vae

' SDVAE uses diffusers AutoencoderKL
SDVAE o-- AutoencoderKL : vae

' RectifiedFlow owns sampler, weight, and scheduler
RectifiedFlow *-- TrainTimeSampler : train_time_sampler
RectifiedFlow *-- TrainTimeWeight : train_time_weight
RectifiedFlow *-- FMEuler : noise_scheduler

' TrainTimeWeight references the same scheduler
TrainTimeWeight o-- FMEuler : noise_scheduler

' FlowUniPCMultistepScheduler optionally delegates to another solver
FlowUniPCMultistepScheduler o-- SchedulerMixin : solver_p (optional)

note bottom of RectifiedFlow
  Delegates time sampling to TrainTimeSampler.
  Uses FlowMatchEulerDiscreteScheduler for
  sigma / timestep schedule.
end note

note bottom of FlowUniPCMultistepScheduler
  Flow-matching UniPC predictor-corrector.
  step() runs UniC (corrector) then UniP (predictor).
  prediction_type = 'flow_prediction' only.
end note

note right of Wan2pt1VAEInterface
  3-layer delegation:
  Wan2pt1VAEInterface -> WanVAE -> WanVAE_
  spatial_compression = 8
  temporal_compression = 4
  latent_ch = 16
end note

@enduml
