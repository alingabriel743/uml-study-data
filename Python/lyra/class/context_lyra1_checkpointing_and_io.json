  "associations": [
    "AbstractCheckpointer uses easy_io (for exists, load, dump)",
    "Checkpointer(DDP) uses easy_io (save_worker calls easy_io.dump/load)",
    "Checkpointer(DDP) uses StateDictItemPath (namedtuple for state dict + path)",
    "FSDPCheckpointer uses easy_io (for read_latest_checkpoint_file)",
    "FSDPCheckpointer uses FSDP (torch.distributed.fsdp)",
    "FileClient composes BaseStorageBackend (via client attribute)",
    "easy_io uses BaseStorageBackend (via get_file_backend registry)",
    "easy_io uses FileClient (in load/dump when file_client_args provided, deprecated path)",
    "Boto3Backend composes Boto3Client",
    "AbstractCheckpointer depends_on CheckpointConfig",
    "AbstractCheckpointer depends_on JobConfig",
    "AbstractCheckpointer depends_on CallBackGroup"
  ],

  "registry": {
    "backends_registered": [
      "local -> LocalBackend (prefix: '')",
      "http -> HTTPBackend (prefix: 'http', 'https')",
      "s3/boto3 -> Boto3Backend (registered in Lyra-2 via register_backend)"
    ],
    "mechanism": "registry_utils.py maintains 'backends' and 'prefix_to_backends' dicts; easy_io routes by URI prefix"
  },

  "key_design_patterns": [
    "AbstractCheckpointer: Template Method pattern (save/load abstract, helpers concrete)",
    "FileClient: Singleton pattern (_instances dict keyed by backend:prefix args)",
    "easy_io: Facade + Factory (get_file_backend selects backend by URI prefix)",
    "Checkpointer(DDP): Strategy for broadcast (broadcast_via_filesystem flag toggles filesystem vs gloo broadcast)",
    "FSDPCheckpointer: uses FSDP full-state-dict with rank0_only offload-to-cpu"
  ],

  "important_notes": [
    "FSDPCheckpointer does NOT inherit from AbstractCheckpointer - it is a parallel hierarchy",
    "DDP/TP/PEFT Checkpointers use easy_io for I/O; PEFT uses torch.load directly",
    "TP checkpointer appends '_mp_{rank}.pt' to all non-trainer checkpoint files",
    "PEFT checkpointer requires broadcast_via_filesystem=True; normalizes 'model_model.pt' -> 'model.pt'",
    "Boto3Backend exists only in Lyra-2 codebase; Lyra-1 only has Local+HTTP backends natively",
    "Checkpointer saves asynchronously via threading.Thread (save_thread)",
    "easy_io.load/dump auto-selects handler by file extension (pt, json, yaml, pkl, txt, etc.)",
    "fast_backend=True uses fast_get/fast_put on backends that support it (e.g. Boto3Backend)"
  ]
