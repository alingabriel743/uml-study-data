{
  "scope": "lyra1_diffusion_inference_pipeline",
  "title": "Lyra-1 Diffusion Inference & World Generation",
  "diagram_type": "class",

  "classes": [
    {
      "name": "BaseWorldGenerationPipeline",
      "module": "cosmos_predict1.utils.base_world_generation_pipeline",
      "type": "abstract (ABC)",
      "key_attributes": [
        "inference_type: str",
        "checkpoint_dir: str",
        "checkpoint_name: str",
        "has_text_input: bool",
        "offload_network: bool",
        "offload_tokenizer: bool",
        "offload_text_encoder_model: bool",
        "offload_guardrail_models: bool",
        "disable_guardrail: bool",
        "disable_prompt_encoder: bool",
        "text_guardrail: Any",
        "video_guardrail: Any",
        "text_encoder: CosmosT5TextEncoder | DummyT5TextEncoder",
        "model: Any"
      ],
      "key_methods": [
        "_load_model() -> Any  [abstract]",
        "_load_network() [stub]",
        "_load_tokenizer() [stub]",
        "_load_text_encoder_model()",
        "_load_text_guardrail()",
        "_load_video_guardrail()",
        "_offload_network()",
        "_offload_tokenizer()",
        "_offload_guardrail_models()",
        "_offload_text_encoder_model()",
        "_run_model(*args, **kwargs) -> Tensor  [abstract]",
        "_run_model_with_offload(*args, **kwargs) -> Tensor  [abstract]",
        "_run_guardrail_on_prompt(prompt: str) -> bool",
        "_run_guardrail_on_prompt_with_offload(prompt: str) -> bool",
        "_run_guardrail_on_video(video: ndarray) -> ndarray | None",
        "_run_guardrail_on_video_with_offload(video: ndarray) -> ndarray | None",
        "_run_text_embedding_on_prompt(prompts: list[str]) -> tuple[list[Tensor], list[Tensor]]",
        "_run_text_embedding_on_prompt_with_offload(prompts: list[str]) -> tuple[list[Tensor], list[Tensor]]",
        "_run_tokenizer_decoding(samples: Tensor) -> ndarray  [abstract]",
        "generate(*args, **kwargs)  [abstract]"
      ]
    },
    {
      "name": "DiffusionText2WorldGenerationPipeline",
      "module": "cosmos_predict1.diffusion.inference.world_generation_pipeline",
      "inherits": "BaseWorldGenerationPipeline",
      "key_attributes": [
        "model_name: str  (from MODEL_NAME_DICT)",
        "guidance: float = 7.0",
        "num_steps: int = 35",
        "height: int = 704",
        "width: int = 1280",
        "fps: int = 24",
        "num_video_frames: int = 121",
        "seed: int = 0",
        "prompt_upsampler_dir: str",
        "enable_prompt_upsampler: bool",
        "offload_prompt_upsampler: bool",
        "prompt_upsampler: Any"
      ],
      "key_methods": [
        "_load_model()  -> uses DiffusionT2WModel, load_model_by_config",
        "_load_network()  -> load_network_model(model, checkpoint/model.pt)",
        "_load_tokenizer()  -> load_tokenizer_model(model, Cosmos-Tokenize1-CV8x8x8-720p)",
        "_load_prompt_upsampler_model()  -> create_prompt_upsampler()",
        "_offload_prompt_upsampler_model()",
        "_run_prompt_upsampler_on_prompt(prompt: str) -> str  (via run_chat_completion)",
        "_run_prompt_upsampler_on_prompt_with_offload(*args) -> str",
        "_run_model(embedding: Tensor, negative_prompt_embedding: Tensor) -> Tensor  (via get_video_batch + generate_world_from_text)",
        "_run_model_with_offload(prompt_embedding: Tensor, negative_prompt_embedding: Tensor) -> ndarray",
        "_run_tokenizer_decoding(sample: Tensor) -> ndarray  [BCTHW -> T,H,W,C uint8]",
        "generate(prompt: str, negative_prompt: str, word_limit_to_skip_upsampler: int) -> tuple[ndarray, str] | None"
      ],
      "generate_flow": [
        "1. _run_guardrail_on_prompt_with_offload(prompt)",
        "2. _run_prompt_upsampler_on_prompt_with_offload(prompt) -> enhanced_prompt",
        "3. _run_guardrail_on_prompt_with_offload(enhanced_prompt)",
        "4. _run_text_embedding_on_prompt_with_offload([prompt, negative_prompt]) -> embeddings",
        "5. _run_model_with_offload(prompt_embedding, negative_prompt_embedding) -> video",
        "6. _run_guardrail_on_video_with_offload(video) -> safe_video",
        "7. return (video, prompt)"
      ]
    },
    {
      "name": "DiffusionVideo2WorldGenerationPipeline",
      "module": "cosmos_predict1.diffusion.inference.world_generation_pipeline",
      "inherits": "DiffusionText2WorldGenerationPipeline",
      "extra_attributes": [
        "num_input_frames: int = 1"
      ],
      "overridden_methods": [
        "_load_model()  -> uses DiffusionV2WModel",
        "_load_prompt_upsampler_model()  -> create_vlm_prompt_upsampler()",
        "_run_prompt_upsampler_on_prompt(image_or_video_path: str) -> str  (VLM-based via prepare_dialog + run_chat_completion_vlm)",
        "_run_model(embedding, condition_latent, negative_prompt_embedding) -> Tensor  (via generate_world_from_video)",
        "_run_tokenizer_encoding(image_or_video_path: str) -> Tensor  (via get_condition_latent)",
        "_run_model_with_offload(prompt_embedding, image_or_video_path, negative_prompt_embedding) -> ndarray",
        "generate(prompt: str, image_or_video_path: str, negative_prompt: str) -> tuple[ndarray, str] | None"
      ]
    },
    {
      "name": "DiffusionText2WorldMultiviewGenerationPipeline",
      "module": "cosmos_predict1.diffusion.inference.world_generation_pipeline",
      "inherits": "DiffusionText2WorldGenerationPipeline",
      "extra_attributes": [
        "n_views: int = 6",
        "frame_repeat_negative_condition: int = 10"
      ],
      "overridden_methods": [
        "_load_model()  -> uses DiffusionMultiviewT2WModel",
        "_run_model(embedding, negative_prompt_embedding) -> Tensor  (via get_video_batch_for_multiview_model + generate_world_from_text)",
        "_run_tokenizer_decoding(sample: Tensor) -> list[ndarray]  (grid+raw, rearranged per view)",
        "generate(prompt: dict) -> tuple[ndarray, str] | None  (6-view prompt dict)"
      ],
      "notes": "enable_prompt_upsampler forced False; prompt dict has keys: prompt/prompt_left/prompt_right/prompt_back/prompt_back_left/prompt_back_right"
    },
    {
      "name": "DiffusionVideo2WorldMultiviewGenerationPipeline",
      "module": "cosmos_predict1.diffusion.inference.world_generation_pipeline",
      "inherits": "DiffusionText2WorldMultiviewGenerationPipeline",
      "extra_attributes": [
        "num_input_frames: int = 1"
      ],
      "overridden_methods": [
        "_load_model()  -> uses DiffusionMultiviewV2WModel",
        "_run_model(embedding, condition_latent, negative_prompt_embedding, data_batch, state_shape) -> Tensor"
      ]
    },
    {
      "name": "DiffusionWorldInterpolatorGenerationPipeline",
      "module": "cosmos_predict1.diffusion.inference.world_generation_pipeline",
      "inherits": "DiffusionVideo2WorldGenerationPipeline",
      "extra_attributes": [
        "num_input_frames: int = 1",
        "num_frame_pairs: int = 1",
        "frame_index_start: int = 0",
        "frame_stride: int = 1"
      ],
      "overridden_methods": [
        "_load_model()  -> uses DiffusionWorldInterpolatorWModel",
        "_load_prompt_upsampler_model()  -> create_vlm_prompt_upsampler()",
        "_run_model(condition_latent, negative_prompt_embedding, num_of_loops, num_of_latent_overlap_list, augment_sigma_list, ...) -> ndarray  (via generate_video_from_batch_with_loop)",
        "generate(...)  -> chunk-based video interpolation"
      ],
      "notes": "guidance default = -1.0 (disabled); supports multi-loop chunk video extension"
    },
    {
      "name": "Gen3cPipeline",
      "module": "cosmos_predict1.diffusion.inference.gen3c_pipeline",
      "inherits": "DiffusionVideo2WorldGenerationPipeline",
      "notes": "3D-cache-conditioned generation; uses Cache3D/Cache4D for novel view synthesis"
    },
    {
      "name": "Cache3D_Base",
      "module": "cosmos_predict1.diffusion.inference.cache_3d",
      "type": "3D point-cloud cache (base)",
      "key_attributes": [
        "weight_dtype: torch.dtype",
        "is_depth: bool",
        "device: str",
        "filter_points_threshold: float",
        "foreground_masking: bool",
        "input_image: Tensor  [B,F,N,V,C,H,W] on CPU",
        "input_points: Tensor  [B,F,N,V,H,W,3] on CPU",
        "input_mask: Tensor | None",
        "input_depth: Tensor | None",
        "boundary_mask: Tensor | None"
      ],
      "key_methods": [
        "__init__(input_image, input_depth, input_w2c, input_intrinsics, input_mask, input_format, input_points, weight_dtype, is_depth, device, filter_points_threshold, foreground_masking)",
        "_compute_input_points(input_depth, input_w2c, input_intrinsics) -> Tensor  (via unproject_points)",
        "update_cache()  [abstract: raises NotImplementedError]",
        "input_frame_count() -> int",
        "render_cache(target_w2cs, target_intrinsics, render_depth, start_frame_idx) -> tuple[Tensor, Tensor]  (forward warp via forward_warp())"
      ],
      "dependencies": ["forward_warp_utils_pytorch.forward_warp", "forward_warp_utils_pytorch.unproject_points", "forward_warp_utils_pytorch.reliable_depth_mask_range_batch", "camera_utils.align_depth"]
    },
    {
      "name": "Cache3D_Buffer",
      "module": "cosmos_predict1.diffusion.inference.cache_3d",
      "inherits": "Cache3D_Base",
      "extra_attributes": [
        "frame_buffer_max: int = 0",
        "noise_aug_strength: float = 0",
        "generator: Any"
      ],
      "key_methods": [
        "update_cache(new_image, new_depth, new_w2c, new_mask, new_intrinsics, depth_alignment, alignment_method)  [rigid or non_rigid depth alignment via align_depth]",
        "render_cache(target_w2cs, target_intrinsics, render_depth, start_frame_idx) -> tuple[Tensor, Tensor]  [adds per-buffer noise augmentation]"
      ],
      "notes": "Implements sliding buffer (newest-first), frame_buffer_max controls retention"
    },
    {
      "name": "Cache3D_BufferSelector",
      "module": "cosmos_predict1.diffusion.inference.cache_3d",
      "inherits": "Cache3D_Base",
      "extra_attributes": [
        "frame_buffer_max: int = 1",
        "mask_for_max_buffer_model: bool = True",
        "mask_full_threshold: float = 0.9"
      ],
      "key_methods": [
        "update_cache()  [raises NotImplementedError — read-only buffer]",
        "render_cache(target_w2cs, target_intrinsics, render_depth, start_frame_idx)  [selects top-K frames by overlap score, applies masking logic]"
      ],
      "notes": "Multi-source static buffer; selects K best frames per target view by coverage overlap"
    },
    {
      "name": "Cache4D",
      "module": "cosmos_predict1.diffusion.inference.cache_3d",
      "inherits": "Cache3D_Base",
      "key_methods": [
        "update_cache(**kwargs)  [raises NotImplementedError]",
        "render_cache(target_w2cs, target_intrinsics, render_depth, start_frame_idx)  [delegates to super]"
      ],
      "notes": "Thin wrapper over Cache3D_Base for 4D (spatiotemporal) caching; supports start_frame_idx for temporal slicing"
    },
    {
      "name": "SamplerConfig",
      "module": "cosmos_predict1.diffusion.modules.res_sampler",
      "type": "attrs dataclass (@make_freezable)",
      "attributes": [
        "solver: SolverConfig",
        "timestamps: SolverTimestampConfig",
        "sample_clean: bool = True"
      ]
    },
    {
      "name": "Sampler",
      "module": "cosmos_predict1.diffusion.modules.res_sampler",
      "inherits": "torch.nn.Module",
      "key_attributes": [
        "cfg: SamplerConfig"
      ],
      "key_methods": [
        "__init__(cfg: SamplerConfig = None)",
        "@torch.no_grad() forward(x0_fn: Callable, x_sigma_max: Tensor, num_steps: int, sigma_min, sigma_max, rho, S_churn, S_min, S_max, S_noise, solver_option) -> Tensor",
        "@torch.no_grad() _forward_impl(denoiser_fn, noisy_input_B_StateShape, sampler_cfg, callback_fns) -> Tensor  [timestep loop via get_rev_ts]"
      ],
      "notes": "EDM-style sampler; supports multistep (2ab) and Runge-Kutta solvers; uses get_rev_ts() for timestep schedule"
    }
  ],

  "inheritance_hierarchy": [
    "ABC <- BaseWorldGenerationPipeline",
    "BaseWorldGenerationPipeline <- DiffusionText2WorldGenerationPipeline",
    "DiffusionText2WorldGenerationPipeline <- DiffusionVideo2WorldGenerationPipeline",
    "DiffusionText2WorldGenerationPipeline <- DiffusionText2WorldMultiviewGenerationPipeline",
    "DiffusionText2WorldMultiviewGenerationPipeline <- DiffusionVideo2WorldMultiviewGenerationPipeline",
    "DiffusionVideo2WorldGenerationPipeline <- DiffusionWorldInterpolatorGenerationPipeline",
    "DiffusionVideo2WorldGenerationPipeline <- Gen3cPipeline",
    "Cache3D_Base <- Cache3D_Buffer",
    "Cache3D_Base <- Cache3D_BufferSelector",
    "Cache3D_Base <- Cache4D",
    "torch.nn.Module <- Sampler"
  ],

  "key_relationships": [
    "BaseWorldGenerationPipeline composes CosmosT5TextEncoder (text_encoder)",
    "BaseWorldGenerationPipeline composes guardrail_presets (text_guardrail, video_guardrail)",
    "DiffusionText2WorldGenerationPipeline depends_on DiffusionT2WModel (via load_model_by_config)",
    "DiffusionText2WorldGenerationPipeline depends_on inference_utils (generate_world_from_text, get_video_batch, load_network_model, load_tokenizer_model)",
    "DiffusionVideo2WorldGenerationPipeline depends_on DiffusionV2WModel",
    "DiffusionVideo2WorldGenerationPipeline depends_on inference_utils.generate_world_from_video",
    "DiffusionText2WorldMultiviewGenerationPipeline depends_on DiffusionMultiviewT2WModel",
    "DiffusionVideo2WorldMultiviewGenerationPipeline depends_on DiffusionMultiviewV2WModel",
    "DiffusionWorldInterpolatorGenerationPipeline depends_on DiffusionWorldInterpolatorWModel",
    "DiffusionWorldInterpolatorGenerationPipeline depends_on generate_video_from_batch_with_loop",
    "Gen3cPipeline depends_on Cache3D_Buffer / Cache4D for novel-view warp conditioning",
    "Cache3D_Base depends_on forward_warp_utils_pytorch (forward_warp, unproject_points)",
    "Cache3D_Buffer depends_on camera_utils.align_depth",
    "Sampler depends_on SamplerConfig, SolverConfig, SolverTimestampConfig"
  ],

  "model_class_map": {
    "DiffusionText2WorldGenerationPipeline": "DiffusionT2WModel",
    "DiffusionVideo2WorldGenerationPipeline": "DiffusionV2WModel",
    "DiffusionText2WorldMultiviewGenerationPipeline": "DiffusionMultiviewT2WModel",
    "DiffusionVideo2WorldMultiviewGenerationPipeline": "DiffusionMultiviewV2WModel",
    "DiffusionWorldInterpolatorGenerationPipeline": "DiffusionWorldInterpolatorWModel",
    "Gen3cPipeline": "GEN3C_Cosmos_7B"
  },

  "important_notes": [
    "MODEL_NAME_DICT maps checkpoint folder names to config job names (e.g. 'Cosmos-Predict1-7B-Text2World' -> 'Cosmos_Predict1_Text2World_7B')",
    "All pipelines support memory offloading via offload_network/offload_tokenizer/offload_text_encoder_model/offload_guardrail_models flags",
    "Cache3D_Base stores input data in BFNVCHW layout on CPU; GPU is only used during render_cache() chunked warping",
    "Cache3D_Buffer supports depth alignment (rigid or non_rigid) when updating the buffer",
    "Cache4D is identical to Cache3D_Base but supports start_frame_idx for temporal frame selection",
    "Sampler.forward() dispatches to _forward_impl() with EDM-style schedule (get_rev_ts); supports 2ab multistep and RK solvers",
    "DiffusionWorldInterpolatorGenerationPipeline uses generate_video_from_batch_with_loop for multi-chunk looped generation"
  ],

  "source_files_analyzed": [
    "cosmos_predict1/diffusion/inference/world_generation_pipeline.py",
    "cosmos_predict1/utils/base_world_generation_pipeline.py",
    "cosmos_predict1/diffusion/inference/cache_3d.py",
    "cosmos_predict1/diffusion/inference/text2world.py",
    "cosmos_predict1/diffusion/modules/res_sampler.py",
    "cosmos_predict1/diffusion/inference/gen3c_pipeline.py (class name only)"
  ]
}
