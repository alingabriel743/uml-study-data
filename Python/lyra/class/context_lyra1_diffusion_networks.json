  "key_compositions": [
    "GeneralDIT *-- PatchEmbed (x_embedder)",
    "GeneralDIT *-- VideoRopePosition3DEmb (pos_embedder)",
    "GeneralDIT *-- LearnablePosEmbAxis (extra_pos_embedder)",
    "GeneralDIT *-- GeneralDITTransformerBlock (blocks[0..N-1])",
    "GeneralDIT *-- FinalLayer (final_layer)",
    "GeneralDIT *-- Timesteps+TimestepEmbedding (t_embedder)",
    "MultiviewGeneralDIT *-- nn.Embedding (view_embeddings)",
    "MultiviewGeneralDIT *-- MultiviewVideoRopePosition3DEmb (pos_embedder)",
    "MultiviewGeneralDIT *-- MultiviewSinCosPosEmbAxis (extra_pos_embedder)",
    "VideoExtendGeneralDIT *-- Timesteps+TimestepEmbedding (augment_sigma_embedder, optional)",
    "GeneralDITTransformerBlock *-- DITBuildingBlock (blocks[0..M-1])",
    "DITBuildingBlock *-- VideoAttn | GPT2FeedForward (block)",
    "VideoAttn *-- Attention (attn)",
    "Attention *-- BaseAttentionOp (attn_op: DotProductAttention)",
    "JointImageVideoTokenizer *-- JITVAE (image_vae)",
    "JointImageVideoTokenizer *-- VideoJITTokenizer (video_vae)"
  ],

  "forward_flow": [
    "GeneralDIT.forward -> forward_before_blocks -> prepare_embedded_sequence -> x_embedder(PatchEmbed) + pos_embedder(RoPE) + extra_pos_embedder",
    "forward_before_blocks -> t_embedder(Timesteps + TimestepEmbedding) -> affline_emb_B_D, adaln_lora_B_3D",
    "GeneralDIT.forward -> loop blocks (GeneralDITTransformerBlock.forward)",
    "GeneralDITTransformerBlock.forward -> optional extra_per_block_pos_emb add -> loop DITBuildingBlock.forward",
    "DITBuildingBlock.forward -> adaLN_modulation(emb) -> shift/scale/gate -> norm_state -> VideoAttn or GPT2FeedForward -> gated residual",
    "VideoAttn.forward -> rearrange THWBD -> Attention.forward -> cal_qkv (RoPE applied) -> cal_attn (TE DotProductAttention) -> to_out",
    "GeneralDIT.forward -> decoder_head -> FinalLayer(final_layer) -> rearrange to B,C,T,H,W"
  ],

  "important_notes": [
    "Block config string (e.g. 'FA-CA-MLP') determines sequence of DITBuildingBlock types per transformer layer.",
    "AdaLN-LoRA: when use_adaln_lora=True, TimestepEmbedding returns 3D LoRA delta added to each block's adaLN_modulation output.",
    "RoPE embeddings (VideoRopePosition3DEmb) applied per-head in Attention.cal_qkv for self-attention only.",
    "Context parallelism: blocks use TE DotProductAttention with cp_group set for sequence-parallel attention.",
    "VideoExtendGeneralDIT concatenates condition_video_input_mask as an extra channel dimension to x before forwarding.",
    "MultiviewGeneralDIT multiplexes n_views into the batch/temporal dimension; view_embeddings are concatenated as channel input.",
    "BaseVAE is declared twice in pretrained_vae.py (lines 24 and 217) — same definition, likely a copy artifact.",
    "VideoJITTokenizer uses multiple inheritance (MRO): BasePretrainedVideoTokenizer.encode/decode wrap JITVAE.encode/decode with chunking logic.",
    "JointImageVideoTokenizer routes T==1 tensors to image_vae and T>1 to video_vae.",
    "Tensor formats: BTHWD (batch-first) and THWBD (sequence-first); blocks must all agree on x_format."
  ]
}
