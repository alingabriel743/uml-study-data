  "class_groups": {

    "embedding_models": {
      "description": "Embedding model base classes and concrete implementations (nn.Module embedders used inside conditioners)",
      "classes": [
        {
          "name": "AbstractEmbModel",
          "file": "training/conditioner.py",
          "base": "nn.Module",
          "is_abstract": true,
          "key_attributes": [
            "_is_trainable: bool",
            "_dropout_rate: float | Tensor",
            "_input_key: str",
            "_return_dict: bool"
          ],
          "key_methods": [
            "random_dropout_input(in_tensor, dropout_rate, key) -> Tensor",
            "summary() -> str",
            "details() -> str"
          ],
          "notes": "Training-side base for all embedders; parallel to BaseConditionEntry in diffusion/conditioner.py"
        },
        {
          "name": "BaseConditionEntry",
          "file": "diffusion/conditioner.py",
          "base": "nn.Module",
          "is_abstract": false,
          "key_attributes": [
            "_dropout_rate: float | Tensor",
            "_input_key: str",
            "_return_dict: bool"
          ],
          "key_methods": [
            "random_dropout_input(in_tensor, dropout_rate, key) -> Tensor",
            "summary() -> str"
          ],
          "notes": "Base-module-level conditioner entry used in diffusion/conditioner.py conditioners"
        },
        {
          "name": "TextAttr",
          "file": "diffusion/conditioner.py",
          "base": "BaseConditionEntry",
          "key_methods": [
            "forward(token: Tensor, mask: Tensor) -> {'crossattn_emb': token, 'crossattn_mask': mask}",
            "random_dropout_input(in_tensor, dropout_rate, key) -> Tensor  # skips mask keys"
          ]
        },
        {
          "name": "TrajectoryAttr",
          "file": "training/conditioner.py",
          "base": "AbstractEmbModel",
          "key_attributes": ["traj_dim: int"],
          "key_methods": [
            "forward(traj: Tensor) -> {'trajectory': traj}"
          ],
          "notes": "Passes raw trajectory tensor; output key 'trajectory' added to BaseVideoCondition"
        },
        {
          "name": "FrameRepeatAttr",
          "file": "training/conditioner.py",
          "base": "AbstractEmbModel",
          "key_methods": [
            "forward(frame_repeat: Tensor) -> {'frame_repeat': frame_repeat / 10.0}"
          ],
          "notes": "Always dropped out in VideoConditionerWithTraingOnlyEmb.get_condition_uncondition"
        },
        {
          "name": "BooleanFlag",
          "file": "training/conditioner.py",
          "base": "AbstractEmbModel",
          "key_attributes": ["output_key: Optional[str]", "flag: bool Tensor"],
          "key_methods": [
            "forward(*args, **kwargs) -> {key: self.flag}",
            "random_dropout_input(in_tensor, dropout_rate, key) -> Tensor  # sets self.flag via Bernoulli"
          ]
        }
      ]
    },

    "conditioner_classes": {
      "description": "Conditioner classes: wrap collections of embedders, produce typed condition dataclasses",
      "classes": [
        {
          "name": "GeneralConditioner",
          "file": "diffusion/conditioner.py",
          "base": "nn.Module, ABC",
          "is_abstract": true,
          "key_attributes": [
            "KEY2DIM: dict = {'crossattn_emb': 1, 'crossattn_mask': 1}",
            "embedders: nn.ModuleDict  # keyed by embedder name"
          ],
          "key_methods": [
            "forward(batch, override_dropout_rate) -> Any  [abstract]",
            "_forward(batch, override_dropout_rate) -> Dict  # iterates embedders, applies dropout, concatenates",
            "get_condition_uncondition(data_batch) -> Tuple[Any, Any]",
            "get_condition_with_negative_prompt(data_batch) -> Tuple[Any, Any]"
          ],
          "notes": "Shared by both diffusion/conditioner.py and training/conditioner.py subclasses"
        },
        {
          "name": "VideoConditioner",
          "file": "training/conditioner.py",
          "base": "GeneralConditioner",
          "key_methods": [
            "forward(batch, override_dropout_rate) -> BaseVideoCondition"
          ]
        },
        {
          "name": "VideoExtendConditioner",
          "file": "training/conditioner.py",
          "base": "GeneralConditioner",
          "key_methods": [
            "forward(batch, override_dropout_rate) -> VideoExtendCondition"
          ]
        },
        {
          "name": "VideoDiffusionDecoderConditioner",
          "file": "training/conditioner.py",
          "base": "GeneralConditioner",
          "key_methods": [
            "forward(batch, override_dropout_rate) -> VideoLatentDiffusionDecoderCondition"
          ]
        },
        {
          "name": "VideoConditionerWithTraingOnlyEmb",
          "file": "training/conditioner.py",
          "base": "GeneralConditioner",
          "key_methods": [
            "get_condition_uncondition(data_batch) -> Tuple  # FrameRepeatAttr always dropped",
            "forward(batch, override_dropout_rate) -> BaseVideoCondition"
          ]
        },
        {
          "name": "VideoExtendConditionerWithTraingOnlyEmb",
          "file": "training/conditioner.py",
          "base": "VideoConditionerWithTraingOnlyEmb",
          "key_methods": [
            "forward(batch, override_dropout_rate) -> VideoExtendCondition"
          ]
        },
        {
          "name": "VideoConditionerWithCtrl",
          "file": "training/conditioner.py",
          "base": "VideoExtendConditioner",
          "key_methods": [
            "forward(batch, override_dropout_rate) -> BaseWithCtrlCondition  # adds hint_key, control_weight, num_layers_to_use"
          ]
        },
        {
          "name": "ActionConditionalVideoExtendConditioner",
          "file": "training/config/video2world_action/registry.py",
          "base": "VideoExtendConditioner",
          "key_methods": [
            "forward(batch, override_dropout_rate) -> ActionConditionalVideoExtendCondition"
          ]
        }
      ]
    },

