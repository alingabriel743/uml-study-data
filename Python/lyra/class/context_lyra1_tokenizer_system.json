  "relationships": [
    "TokenizerModel extends Model",
    "TokenizerModel HAS-A network (CausalDiscreteVideoTokenizer | DiscreteImageTokenizer | ContinuousImageTokenizer | CausalContinuousVideoTokenizer)",
    "TokenizerModel HAS-A loss: TokenizerLoss",
    "TokenizerModel HAS-A metric: TokenizerMetric",
    "TokenizerModel HAS-A ema: EMAModelTracker (optional)",
    "CausalDiscreteVideoTokenizer HAS-A encoder: Encoder3DType (EncoderBase or EncoderFactorized)",
    "CausalDiscreteVideoTokenizer HAS-A decoder: Decoder3DType (DecoderBase or DecoderFactorized)",
    "CausalDiscreteVideoTokenizer HAS-A quant_conv: CausalConv3d",
    "CausalDiscreteVideoTokenizer HAS-A post_quant_conv: CausalConv3d",
    "CausalDiscreteVideoTokenizer HAS-A quantizer: VectorQuantizer|LFQuantizer|FSQuantizer|ResidualFSQuantizer",
    "DiscreteImageTokenizer HAS-A encoder: Encoder (2D)",
    "DiscreteImageTokenizer HAS-A decoder: Decoder (2D)",
    "DiscreteImageTokenizer HAS-A quant_conv: nn.Conv2d",
    "DiscreteImageTokenizer HAS-A quantizer: VectorQuantizer|LFQuantizer|FSQuantizer|ResidualFSQuantizer",
    "ContinuousImageTokenizer HAS-A encoder: Encoder (2D)",
    "ContinuousImageTokenizer HAS-A decoder: Decoder (2D)",
    "ContinuousImageTokenizer HAS-A distribution: GaussianDistribution|IdentityDistribution",
    "CausalContinuousVideoTokenizer HAS-A encoder: Encoder3DType",
    "CausalContinuousVideoTokenizer HAS-A decoder: Decoder3DType",
    "CausalContinuousVideoTokenizer HAS-A quant_conv: CausalConv3d",
    "CausalContinuousVideoTokenizer HAS-A distribution: GaussianDistribution|IdentityDistribution",
    "TokenizerMetric CONTAINS metric_modules: {PSNRMetric, SSIMMetric, CodeUsageMetric, NULLMetric}",
    "TokenizerLoss CONTAINS loss_modules: {ColorLoss, KLLoss, PerceptualLoss, FlowLoss, VideoConsistencyLoss, NullLoss}",
    "PerceptualLoss extends LPIPS",
    "ResidualFSQuantizer CONTAINS layers: ModuleList[FSQuantizer]",
    "InvQuantizerJit WRAPS quantizer (used in decoder_jit of discrete tokenizers)",
    "ColorLoss, KLLoss, VideoConsistencyLoss USES WeightScheduler",
    "PerceptualLoss USES WeightScheduler (3 instances: lpips, gram, corr)",
    "FlowLoss USES WeightScheduler and RAFT flow_model",
    "DiscreteQuantizer enum MAPS to VectorQuantizer|LFQuantizer|FSQuantizer|ResidualFSQuantizer",
    "ContinuousFormulation enum MAPS to GaussianDistribution|IdentityDistribution",
    "Encoder3DType enum MAPS to EncoderBase|EncoderFactorized",
    "Decoder3DType enum MAPS to DecoderBase|DecoderFactorized|DecoderFactorizedVanilla|DecoderBaseVanilla"
  ],

  "forward_flow": {
    "discrete_tokenizer": [
      "input → encoder(input) → h",
      "h → quant_conv(h) → h_quant",
      "h_quant → quantizer(h_quant) → (quant_info, quant_codes, quant_loss)",
      "quant_codes → post_quant_conv(quant_codes) → z_dec",
      "z_dec → decoder(z_dec) → reconstructions",
      "return NetworkEval(reconstructions, quant_loss, quant_info)"
    ],
    "continuous_tokenizer": [
      "input → encoder(input) → h",
      "h → quant_conv(h) → moments",
      "moments → distribution(moments) → (latent, posteriors)",
      "latent → post_quant_conv(latent) → z_dec",
      "z_dec → decoder(z_dec) → reconstructions",
      "return NetworkEval(reconstructions, posteriors, latent)"
    ],
    "training_step": [
      "data_batch → _network_forward(data_batch) → output_dict",
      "output_dict + data_batch → loss(inputs, output_dict, iteration) → (loss_dict, loss_value)",
      "return ({PREDICTION: recon_images, ...loss_dict}, loss_value)"
    ],
    "validation_step": [
      "data_batch → _network_forward(data_batch) → output_dict",
      "output_dict + data_batch → loss() → (loss_dict, loss_value)",
      "input_images + output_dict → metric(input_images, output_dict, iteration) → metric_dict",
      "return ({PREDICTION: recon_images, ...loss_dict, ...metric_dict}, loss_value)"
    ]
  },

  "key_configs": {
    "continuous_image": "16x compression, 16 latent_channels, z_channels=16, AE formulation, patch_size=4 (Haar)",
    "discrete_image": "16x compression, z_channels=256, embedding_dim=6, FSQ levels=[8,8,8,5,5,5]",
    "continuous_video": "8x spatial + 8x temporal, latent_channels=16, AE, FACTORIZED encoder/decoder",
    "discrete_video": "8x temporal + 16x spatial, z_channels=16, embedding_dim=6, FSQ"
  },

  "important_notes": [
    "All 4 tokenizers share the same encode/decode/forward interface but differ in 2D vs 3D and discrete vs continuous",
    "Discrete tokenizers: forward returns (quant_info, quant_codes, quant_loss); continuous returns (latent, posteriors)",
    "encoder_jit() and decoder_jit() expose JIT-compilable sub-networks for inference",
    "TokenizerModel.state_dict() filters out loss, ema.loss, encoder.patcher, decoder.unpatcher keys",
    "VideoConsistencyLoss uses sliding-window shuffle/unshuffle around the network forward pass (injected via _on_before/after_network_forward)",
    "ResidualFSQuantizer stacks num_quantizers FSQuantizers with residual connections",
    "LFQuantizer supports optional entropy loss with codebook-level entropy regularization"
  ],

  "source_files_analyzed": [
