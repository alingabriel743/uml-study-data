  "internal_supporting_classes": [
    "CausalConv3d(nn.Conv3d) - causal 3D conv with temporal padding",
    "Encoder3d(nn.Module) - 3D video encoder with downsample blocks",
    "Decoder3d(nn.Module) - 3D video decoder with upsample blocks",
    "ResidualBlock(nn.Module) - residual block with CausalConv3d",
    "AttentionBlock(nn.Module) - single-head causal spatial attention",
    "Resample(nn.Module) - upsample2d/3d/downsample2d/3d",
    "RMS_norm(nn.Module) - RMS normalization",
    "Upsample(nn.Upsample) - bfloat16 safe nearest upsample"
  ],

  "relationships": [
    "VideoTokenizerInterface <|-- Wan2pt1VAEInterface (implements)",
    "torch.nn.Module + ABC <|-- BaseVAE",
    "BaseVAE <|-- BasePretrainedImageVAE",
    "BasePretrainedImageVAE <|-- JITVAE",
    "BasePretrainedImageVAE <|-- StateDictVAE",
    "BaseVAE <|-- SDVAE",
    "torch.nn.Module <|-- WanVAE_",
    "WanVAE_ *-- Encoder3d (encoder)",
    "WanVAE_ *-- Decoder3d (decoder)",
    "WanVAE_ *-- CausalConv3d (conv1, conv2)",
    "WanVAE o-- WanVAE_ (model, created via _video_vae factory)",
    "Wan2pt1VAEInterface *-- WanVAE (model)",
    "StateDictVAE o-- torch.nn.Module (vae, injected)",
    "RectifiedFlow *-- TrainTimeSampler (train_time_sampler)",
    "RectifiedFlow *-- TrainTimeWeight (train_time_weight)",
    "RectifiedFlow *-- FlowMatchEulerDiscreteScheduler (noise_scheduler, from diffusers)",
    "TrainTimeWeight o-- FlowMatchEulerDiscreteScheduler (noise_scheduler, ref)",
    "SchedulerMixin + ConfigMixin <|-- FlowUniPCMultistepScheduler",
    "FlowUniPCMultistepScheduler o-- SchedulerMixin (solver_p, optional)",
    "SDVAE o-- diffusers.AutoencoderKL (vae)"
  ],

  "key_design_patterns": [
    "VideoTokenizerInterface defines the external tokenizer API; Wan2pt1VAEInterface implements it, wrapping WanVAE which wraps WanVAE_ (3-layer delegation)",
    "BasePretrainedImageVAE provides encode/decode with automatic mean-std normalization; subclasses only need to supply encoder/decoder modules",
    "WanVAE_ uses feature caching (_feat_map, _enc_feat_map) for causal chunked temporal processing",
    "RectifiedFlow delegates time sampling to TrainTimeSampler and uses FlowMatchEulerDiscreteScheduler for sigma/timestep schedules",
    "FlowUniPCMultistepScheduler is a predictor-corrector: corrector (UniC) runs first on previous prediction, then predictor (UniP) produces next sample"
  ],

  "important_notes": "WanVAE_ z_dim defaults to 4 but Wan2pt1VAEInterface has latent_ch=16, matching _video_vae call with z_dim=16. temporal_compression_factor=4 (4 pixel frames per latent frame). spatial_compression_factor=8. FlowUniPCMultistepScheduler supports optional solver_p (another SchedulerMixin) for hybrid solver. TrainTimeSampler supports 'uniform' and 'logitnormal' distributions. SDVAE uses stabilityai/sd-vae-ft-mse with spatial_compression=8 and optional 2x downsampling."
}
