@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam arrow {
    Color #495057
}

title Lyra-1 / Cosmos Predict1 — Component Architecture

' ─────────────────────────────────────────────
' Entry Points
' ─────────────────────────────────────────────
package "Entry Points" as EP {
    [train.py\nTraining Launcher] as Train
    [sample.py\nInference Launcher] as Sample
    [scripts/\nDownload & Setup] as Scripts
}

' ─────────────────────────────────────────────
' Autoregressive Pipeline
' ─────────────────────────────────────────────
package "Autoregressive Pipeline\n(cosmos_predict1/autoregressive)" as AR {

    package "AR Core & Training" as ARCore {
        [AutoRegressiveModel\n& Trainer] as ARModel
        [AutoRegressiveTrainingModel] as ARTraining
    }

    package "AR Inference" as ARInfer {
        [ARBaseGenerationPipeline\nARVideo2WorldPipeline] as ARPipeline
    }

    package "AR Networks & Modules" as ARNet {
        [VisionTransformer\nTransformerBlock] as ARVIT
        [Attention\nRotaryPositionEmbedding] as ARAttn
    }

    package "AR Tokenizer" as ARTok {
        [DiscreteVideoFSQTokenizer\nDiscreteMultimodalTokenizer] as ARTokenizer
        [FSQuantizer / Patcher3D] as ARFSQ
    }

    package "AR Diffusion Decoder" as ARDiff {
        [LatentDiffusionDecoderModel\nDiffusionDecoderGeneralDIT] as ARDiffDec
    }

    package "AR Configs & Datasets" as ARConf {
        [ModelConfig / TrainingModelConfig\nVideoDatasetConfig] as ARConfig
        [VideoDataset / Augmentor] as ARData
    }

    package "AR Utils" as ARUtils {
        [CheckpointUtils\nTensorParallelUtils] as ARUtil
    }
}

' ─────────────────────────────────────────────
' Diffusion Pipeline
' ─────────────────────────────────────────────
package "Diffusion Pipeline\n(cosmos_predict1/diffusion)" as DP {

    package "Diffusion Core Models" as DPCore {
        [DiffusionT2WModel\nDiffusionV2WModel\nDiffusionMultiviewModel] as DPModel
        [FSDPDiffusionModel\nPEFTVideoDiffusionModel] as DPTrainModel
    }

    package "Diffusion Inference" as DPInfer {
        [DiffusionText2WorldPipeline\nDiffusionVideo2WorldPipeline\nDiffusionMultiviewPipeline] as DPPipeline
        [Gen3cPersistentModel\nWorldInterpolatorPipeline] as DPSpecial
    }

    package "Diffusion Networks" as DPNet {
        [GeneralDIT\nMultiviewGeneralDIT\nVideoExtendGeneralDIT] as DPDIT
        [ActionConditionalGeneralDIT] as DPAction
    }

    package "Diffusion Modules & Functional" as DPMod {
        [Sampler / EDMScaling\nSolverConfig] as DPSampler
        [BaseVAE / JITVAE\nVideoTokenizerInterface] as DPVAE
    }

    package "Conditioners" as DPCond {
        [VideoConditioner\nVideoExtendConditioner\nGeneralConditioner] as DPConditioner
    }

    package "Diffusion Configs" as DPConf {
        [Config (Text2World, Video2World\nMultiview, WorldInterpolator)] as DPConfig
        [FSDPConfig / DefaultModelConfig] as DPFSDP
    }

    package "Diffusion Datasets" as DPData {
        [Dataset / Dataset_3D\nResize_Preprocess] as DPDataset
    }

    package "Prompt Upsampler" as DPPrompt {
        [VLM Prompt Upsampler\nChatCompletion] as DPUpsamp
    }

    package "Training Utils & PEFT" as DPTUtils {
        [MultiRankCheckpointer\nLoRALinearLayer] as DPPEFT
    }
}

' ─────────────────────────────────────────────
' Auxiliary / Guardrail
' ─────────────────────────────────────────────
package "Auxiliary & Guardrail\n(cosmos_predict1/auxiliary)" as AUX {
    [CosmosT5TextEncoder\nDummyT5TextEncoder] as TextEnc

    package "Guardrail Suite" as GR {
        [ContentSafetyGuardrail\nGuardrailRunner] as GRRunner
        [Aegis / LlamaGuard3\nVideoContentSafetyFilter] as GRModels
        [Blocklist / FaceBlurFilter] as GRFilters
    }
}

' ─────────────────────────────────────────────
' Shared Infrastructure
' ─────────────────────────────────────────────
package "Shared Infrastructure\n(cosmos_predict1)" as INFRA {
    [Checkpointer\n(FSDP, Abstract)] as Ckpt
    [Callbacks\n(GradClip, EveryN)] as CB
}

' ─────────────────────────────────────────────
' Source / Rendering / Evaluation
' ─────────────────────────────────────────────
package "src — Scene Rendering & Evaluation" as SRC {
    [Gaussian Splatting Renderer\n(gs.py, gs_deferred.py)] as Renderer
    [Visualization\n(dynamic_scene, static_visu)] as Visu
    [Evaluation & Metrics\n(eval/metrics.py)] as Eval
    [Model Utils\n(attention, mamba2, cosmos_tokenizer)] as SrcUtils
}

' ─────────────────────────────────────────────
' Dependencies / Arrows
' ─────────────────────────────────────────────

' Entry points drive pipelines
Train --> ARModel
Train --> DPTrainModel
Sample --> ARPipeline
Sample --> DPPipeline

' AR internal flow
ARModel --> ARTraining
ARPipeline --> ARModel
ARPipeline --> ARTokenizer
ARModel --> ARVIT
ARVIT --> ARAttn
ARTokenizer --> ARFSQ
ARDiffDec --> DPVAE
ARConfig --> ARModel

' Diffusion internal flow
DPModel --> DPDIT
DPTrainModel --> DPModel
DPPipeline --> DPModel
DPPipeline --> DPConditioner
DPSpecial --> DPModel
DPSampler --> DPDIT
DPVAE --> DPModel
DPConditioner --> TextEnc
DPConfig --> DPModel
DPPrompt --> DPPipeline
DPPEFT --> DPTrainModel

' AR -> Diffusion Decoder coupling
ARPipeline --> ARDiffDec
ARDiffDec --> DPSampler

' Shared infrastructure
ARTraining --> Ckpt
DPTrainModel --> Ckpt
ARTraining --> CB
DPTrainModel --> CB
ARUtil --> Ckpt

' Guardrail integration
Sample --> GRRunner
GRRunner --> GRModels
GRRunner --> GRFilters

' src used by sample / eval
Sample --> Renderer
Renderer --> Visu
Eval --> Renderer
SrcUtils --> ARTokenizer

@enduml
