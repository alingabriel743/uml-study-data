{
  "scope": "wan_diffusion_model_training",
  "title": "WAN Diffusion Model Training",
  "diagram_type": "sequence",
  "key_participants": [
    "Trainer",
    "WANDiffusionModel",
    "T2VModelConfig",
    "I4LoraConfig",
    "RectifiedFlow",
    "BaseVAE (tokenizer)",
    "Conditioner",
    "net (WAN DiT)",
    "LoRA (peft)",
    "EMAWorker (FastEmaModelUpdater)",
    "Optimizer/Scheduler"
  ],
  "interaction_flow": [
    "--- Initialization ---",
    "Trainer → WANDiffusionModel: __init__(config: T2VModelConfig)",
    "WANDiffusionModel → WANDiffusionModel: setup_data_key() — sets input_data_key, input_image_key",
    "WANDiffusionModel → FlowUniPCMultistepScheduler: __init__(num_train_timesteps=1000, shift=1)",
    "WANDiffusionModel → lazy_instantiate(config.tokenizer) → BaseVAE",
    "WANDiffusionModel → hsdp_device_mesh(sharding_group_size) [if fsdp_shard_size > 1]",
    "WANDiffusionModel → WANDiffusionModel: set_up_model()",
    "  set_up_model → lazy_instantiate(config.conditioner) → Conditioner",
    "  set_up_model → WANDiffusionModel: build_net() → net",
    "    build_net → lazy_instantiate(config.net) [on meta device] → WAN DiT net",
    "    build_net → WANDiffusionModel: maybe_inject_lora_to_net(net, skip_load=True) [if lora_config present]",
    "      maybe_inject_lora_to_net → WANDiffusionModel: add_lora_to_model(adapter_name, lora_rank, lora_target_modules, init_lora_weights)",
    "        add_lora_to_model → LoraConfig(r, lora_alpha, target_modules) [peft]",
    "        add_lora_to_model → inject_adapter_in_model(lora_config, net) [peft, inplace]",
    "    build_net → net.to_empty(device='cuda') + net.init_weights()",
    "    build_net → broadcast_dtensor_model_states(net, fsdp_device_mesh) [if FSDP]",
    "    build_net → WANDiffusionModel: maybe_inject_lora_to_net(net, skip_inject=True) — loads LoRA weights",
    "      maybe_inject_lora_to_net → WANDiffusionModel: load_lora_weights(lora_path, adapter_name, training_mode)",
    "        load_lora_weights → load_state_dict(lora_path)",
    "        load_lora_weights → WANDiffusionModel: add_lora_to_model(...) [inject LoRA layers]",
    "        load_lora_weights → WANDiffusionModel: load_weights_to_lora(pretrained_lora_state_dict, converter, model)",
    "          load_weights_to_lora → model.load_state_dict(state_dict, strict=False)",
    "  set_up_model → build_net() again → net_ema [if ema.enabled]",
    "  set_up_model → FastEmaModelUpdater/DTensorFastEmaModelUpdater → net_ema_worker",
    "  set_up_model → net_ema_worker.copy_to(src=net, tgt=net_ema)",
    "WANDiffusionModel → RectifiedFlow: __init__(velocity_field=net, train_time_distribution, shift, ...)",
    "--- Optimizer Init ---",
    "Trainer → WANDiffusionModel: init_optimizer_scheduler(optimizer_config, scheduler_config)",
    "  init_optimizer_scheduler → lazy_instantiate(optimizer_config, model=self.net) → Optimizer",
    "  init_optimizer_scheduler → get_base_scheduler(optimizer, model, scheduler_config) → Scheduler",
    "  init_optimizer_scheduler → Trainer: return (optimizer, scheduler)",
    "--- on_train_start ---",
    "Trainer → WANDiffusionModel: on_train_start(memory_format)",
    "  on_train_start → net_ema.to(dtype=float32) [if ema.enabled]",
    "  on_train_start → tokenizer.reset_dtype() [if available]",
    "  on_train_start → net.to(memory_format, **tensor_kwargs)",
    "  on_train_start → torch.compile(net) [if use_torch_compile]",
    "--- Training Step ---",
    "Trainer → WANDiffusionModel: training_step(data_batch, iteration)",
    "  training_step → WANDiffusionModel: _update_train_stats(data_batch) — updates image/video counters",
    "  training_step → WANDiffusionModel: get_data_and_condition(data_batch) → (_, x0_B_C_T_H_W, condition)",
    "    get_data_and_condition → tokenizer.encode(video/image) → latents",
    "    get_data_and_condition → conditioner(data_batch) → T2VCondition",
    "  training_step → torch.randn(x0.size()) → epsilon_B_C_T_H_W",
    "  training_step → RectifiedFlow: sample_train_time(batch_size) → t_B",
    "  training_step → WANDiffusionModel: broadcast_split_for_model_parallelsim(x0, condition, epsilon, t_B)",
    "    broadcast_split_for_model_parallelsim → broadcast_split_tensor / broadcast [if context parallel > 1]",
    "    broadcast_split_for_model_parallelsim → net.enable_context_parallel(cp_group) or disable_context_parallel()",
    "  training_step → RectifiedFlow: get_discrete_timestamp(t_B) → timesteps",
    "  training_step → RectifiedFlow: get_sigmas(timesteps) → sigmas",
    "  training_step → RectifiedFlow: get_interpolation(epsilon, x0, sigmas) → (xt, vt)",
    "  training_step → net(x_B_C_T_H_W=xt, timesteps_B_T=timesteps, **condition.to_dict()) → vt_pred",
    "  training_step → RectifiedFlow: train_time_weight(timesteps) → time_weights_B",
    "  training_step → compute MSE loss: mean(time_weights * (vt_pred - vt)^2)",
    "  training_step → Trainer: return (output_batch={edm_loss}, loss)",
    "--- Post-Step EMA Update ---",
    "Trainer → WANDiffusionModel: on_before_zero_grad(optimizer, scheduler, iteration)",
    "  on_before_zero_grad → WANDiffusionModel: ema_beta(iteration) → beta",
    "  on_before_zero_grad → net_ema_worker.update_average(net, net_ema, beta=beta)"
  ],
  "key_relationships": [
    "WANDiffusionModel extends ImaginaireModel",
    "WANDiffusionModel composes T2VModelConfig (holds EMAConfig, I4LoraConfig, net/conditioner/tokenizer LazyDicts)",
    "WANDiffusionModel owns net (WAN DiT), net_ema, conditioner (Conditioner), tokenizer (BaseVAE), rectified_flow (RectifiedFlow)",
    "WANDiffusionModel owns net_ema_worker (FastEmaModelUpdater or DTensorFastEmaModelUpdater)",
    "WANDiffusionModel depends_on peft (LoraConfig, inject_adapter_in_model, BaseTunerLayer) for LoRA injection",
    "WANDiffusionModel depends_on RectifiedFlow for noise scheduling and loss weighting",
    "WANDiffusionModel depends_on lazy_instantiate for deferred construction of net/conditioner/tokenizer/optimizer",
    "build_net calls maybe_inject_lora_to_net twice: first with skip_load=True (inject structure), then skip_inject=True (load weights)",
    "init_optimizer_scheduler creates optimizer bound to self.net parameters only (LoRA params if lora_config.enabled)"
  ],
  "config_dataclasses": {
    "T2VModelConfig": ["tokenizer:LazyDict", "conditioner:LazyDict", "net:LazyDict", "ema:EMAConfig", "fsdp_shard_size:int", "precision:str", "lora_config:I4LoraConfig", "use_torch_compile:bool", "state_ch:int", "state_t:int", "resolution:str", "shift:int", "use_dynamic_shift:bool", "train_time_weight:str", "train_time_distribution:str"],
    "EMAConfig": ["enabled:bool", "rate:float", "iteration_shift:int"],
    "I4LoraConfig": ["enabled:bool", "pretrained_lora_path:str", "lora_rank:int", "adapter_name:str", "lora_target_modules:list[str]", "init_lora_weights:str"]
  },
  "important_notes": [
    "LoRA injection is two-phase in build_net: (1) inject adapter structure on meta device (skip_load=True), (2) load weights after cuda init (skip_inject=True)",
    "If lora_config.enabled, only LoRA parameters have requires_grad=True; base net is frozen",
    "FSDP uses DTensor parameters with hsdp_device_mesh for hierarchical sharding",
    "Context parallelism: net.enable/disable_context_parallel() called each training step based on cp_group size",
    "EMA beta is computed per-iteration via ema_beta(iteration) using polynomial roots formula",
    "on_train_start optionally torch.compiles the net with dynamic=False",
    "Loss is flow-matching MSE: mean(time_weights * ||vt_pred - vt||^2)",
    "net forward signature: net(x_B_C_T_H_W, timesteps_B_T, **condition.to_dict())"
  ],
  "source_files_analyzed": [
    "Lyra-2/lyra_2/_src/models/wan_t2v_model.py"
  ]
}
