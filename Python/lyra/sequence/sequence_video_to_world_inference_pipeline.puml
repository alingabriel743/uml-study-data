@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #6C757D
    LifeLineBackgroundColor #E9ECEF
    GroupBackgroundColor #E9ECEF
    GroupBorderColor #6C757D
    GroupFontColor #212529
    DividerBackgroundColor #DEE2E6
    DividerBorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #856404
    FontColor #212529
}

title Video-to-World Inference Pipeline

actor Caller as caller
participant "DiffusionVideo2World\nGenerationPipeline" as pipeline
participant "VLMPromptUpsampler" as vlm
participant "Guardrail" as guardrail
participant "TextEncoder\n(T5)" as t5
participant "inference_utils" as utils
participant "DiffusionV2WModel\n(tokenizer + DiT)" as v2w

== Entry Point ==

caller -> pipeline : generate(prompt, image_or_video_path,\nnegative_prompt)
activate pipeline

== Prompt Enhancement (optional) ==

opt enable_prompt_upsampler
    pipeline -> vlm : _run_prompt_upsampler_on_prompt_with_offload\n(image_or_video_path)
    activate vlm
    vlm -> vlm : prepare_dialog(image_or_video_path)
    vlm -> vlm : run_chat_completion_vlm(dialog)
    vlm --> pipeline : enhanced_prompt
    deactivate vlm
end

== Guardrail Check (Prompt) ==

opt not disable_guardrail
    pipeline -> guardrail : _run_guardrail_on_prompt_with_offload(prompt)
    activate guardrail
    guardrail --> pipeline : [pass / block]
    deactivate guardrail
end

== Text Embedding ==

pipeline -> t5 : _run_text_embedding_on_prompt_with_offload\n([prompt, negative_prompt])
activate t5
t5 --> pipeline : prompt_embeddings, negative_prompt_embedding
deactivate t5

== Model Inference with GPU Offload ==

pipeline -> pipeline : _run_model_with_offload(\nprompt_embedding, image_or_video_path,\nnegative_prompt_embedding)
activate pipeline

group Tokenizer Encoding — build condition_latent

    pipeline -> utils : get_condition_latent(model,\ninput_image_or_video_path,\nnum_input_frames, state_shape)
    activate utils

    utils -> utils : read_video_or_image_into_frames_BCTHW\n(input_path, H, W)
    note right of utils
      Loads mp4 / jpg / png
      Normalizes to [-1, 1]
      Resizes to (H, W)
      Rearranges TCHW → BCTHW
      Returns bfloat16 CUDA tensor
    end note

    utils -> utils : create_condition_latent_from_input_frames\n(model, input_frames, num_frames_condition)
    activate utils

    utils -> utils : pad frames to pixel_chunk_duration
    utils -> v2w : model.encode(encode_input_frames)
    activate v2w
    v2w --> utils : condition_latent [B, C, T, H, W]
    deactivate v2w
    deactivate utils

    utils --> pipeline : condition_latent
    deactivate utils

end

group DiT Inference — generate sample latents

    pipeline -> utils : get_video_batch(model,\nprompt_embedding, negative_prompt_embedding,\nheight, width, fps, num_video_frames)
    activate utils

    utils -> v2w : tokenizer.get_latent_num_frames\n(num_video_frames)
    activate v2w
    v2w --> utils : state_shape [C, T_latent, H/f, W/f]
    deactivate v2w

    utils -> utils : prepare_data_batch(...)
    utils --> pipeline : data_batch, state_shape
    deactivate utils

    pipeline -> utils : generate_world_from_video(model,\nstate_shape, data_batch,\ncondition_latent, num_input_frames,\nguidance, num_steps, seed)
    activate utils

    utils -> utils : pad condition_latent to state_shape[1]\n(if needed)
    utils -> utils : compute_num_latent_frames(model,\nnum_input_frames)\n→ num_of_latent_condition

    utils -> v2w : model.generate_samples_from_batch(\ndata_batch, guidance, state_shape,\nnum_steps, is_negative_prompt, seed,\ncondition_latent, num_condition_t,\ncondition_augment_sigma=0.001)
    activate v2w
    note right of v2w
      Diffusion denoising with
      video conditioning.
      augment_sigma = 0.001
      (DEFAULT_AUGMENT_SIGMA)
    end note
    v2w --> utils : sample latents
    deactivate v2w

    utils --> pipeline : sample latents
    deactivate utils

end

group Tokenizer Decoding — latents → video frames

    pipeline -> v2w : model.decode(sample)
    activate v2w
    v2w --> pipeline : video tensor [B, 3, T, H, W]
    deactivate v2w

    pipeline -> pipeline : clamp + permute + uint8 cast\n→ np.ndarray [T, H, W, C] ∈ [0, 255]

end

deactivate pipeline

== Guardrail Check (Video) ==

opt not disable_guardrail
    pipeline -> guardrail : _run_guardrail_on_video_with_offload(video)
    activate guardrail
    guardrail --> pipeline : [pass / block]
    deactivate guardrail
end

== Return Result ==

pipeline --> caller : (video_frames_np [T, H, W, C], final_prompt)
deactivate pipeline

@enduml
