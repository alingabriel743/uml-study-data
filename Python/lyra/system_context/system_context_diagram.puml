@startuml
title Lyra — Generative 3D World System · System Context

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actor {
    BackgroundColor<<Person>> #08427B
    FontColor<<Person>> #FFFFFF
    BorderColor<<Person>> #052E56
}

skinparam package {
    BackgroundColor #F5F5F5
    BorderColor #BDBDBD
    FontColor #424242
    FontStyle bold
}

skinparam arrow {
    Color #424242
    FontSize 10
    FontColor #616161
}

' ── Actors ──────────────────────────────────────────────────────────────────
actor "ML Researcher\n[Training & Evaluation]" as researcher <<Person>>
actor "End User\n[Inference / Sampling]" as user <<Person>>
actor "DevOps / Pipeline\n[Checkpoint Management]" as devops <<Person>>

' ── Core System ─────────────────────────────────────────────────────────────
rectangle "**Lyra**\n[Python / PyTorch]\n\nGenerative 3D & 4D world\nsystem. Supports feed-forward\nscene generation (Lyra-1) and\nlong-horizon explorable 3D\nworld generation (Lyra-2)\nvia video diffusion models." as system <<System>>

' ── Compute Infrastructure ──────────────────────────────────────────────────
package "Compute Infrastructure" {
    rectangle "**NVIDIA GPU Cluster**\n[CUDA / cuDNN]\n\nHigh-performance GPU compute\nfor model training,\nfine-tuning, and inference" as gpu <<Infrastructure>>

    rectangle "**PyTorch Distributed\n(NCCL)**\n[Multi-GPU / Multi-node]\n\nDistributed data-parallel\nand fully-sharded data-\nparallel (FSDP) training" as dist <<Infrastructure>>
}

' ── Model & Dataset Storage ─────────────────────────────────────────────────
package "Storage" {
    rectangle "**AWS S3**\n[Object Storage]\n\nModel checkpoints, training\ndatasets, generated outputs,\nand cached artefacts" as s3 <<Database>>

    rectangle "**Local Filesystem**\n[Disk / NFS]\n\nLocal model weights,\ntemporary outputs,\nand experiment logs" as localfs <<Database>>
}

' ── ML Model Registry ───────────────────────────────────────────────────────
package "ML Model Registry" {
    rectangle "**Hugging Face Hub**\n[Model Repository]\n\nPre-trained Lyra, GEN3C,\nand Cosmos Tokenizer weights;\nsnapshot_download & upload" as hfhub <<External>>

    rectangle "**Hugging Face Diffusers**\n[Diffusion Pipeline Library]\n\nDiffusion model pipelines,\nschedulers, and UNet\narchitecture utilities" as diffusers <<External>>

    rectangle "**Hugging Face Transformers**\n[Foundation Models]\n\nCLIP vision encoder,\nT5 / UMT5 text encoder\nfor conditioning" as transformers <<External>>
}

' ── Experiment Tracking ─────────────────────────────────────────────────────
package "Observability" {
    rectangle "**Weights & Biases\n(wandb)**\n[Experiment Tracker]\n\nTraining metrics, loss curves,\nrun management, and\nexperiment comparisons" as wandb <<External>>
}

' ── External ML Dependencies ────────────────────────────────────────────────
package "External ML Libraries" {
    rectangle "**Mamba / SSM**\n[State Space Models]\n\nMamba2 selective state-space\nblocks for efficient long-\nsequence modelling" as mamba <<External>>

    rectangle "**gsplat**\n[Gaussian Splatting]\n\n3D Gaussian splatting renderer;\nnerfstudio-project library for\nreal-time novel-view synthesis" as gsplat <<External>>

    rectangle "**MoGe**\n[Depth Estimation]\n\nMicrosoft MoGe monocular\ngeometry estimation used\nfor depth pre-processing" as moge <<External>>
}

' ── HTTP / Remote Data Fetch ────────────────────────────────────────────────
package "Remote Data Sources" {
    rectangle "**HTTP Remote Files**\n[HTTP/HTTPS Endpoints]\n\nRemote dataset files and\nassets fetched at runtime\nvia HTTPBackend" as http <<External>>
}

' ── Relationships ────────────────────────────────────────────────────────────
researcher --> system : "CLI / Python API\n(train, evaluate,\nrun experiments)"
user --> system : "CLI / Python API\n(sample.py inference,\nscene generation)"
devops --> system : "Shell / Scripts\n(download checkpoints,\nsetup environment)"

system --> gpu : "CUDA / cuDNN\n(forward/backward pass,\ntensor operations)"
system --> dist : "NCCL / torch.distributed\n(gradient sync,\nFSDP sharding)"

system --> s3 : "AWS SDK / Boto3\n(read/write checkpoints\nand datasets)"
system --> localfs : "POSIX I/O\n(load weights,\nsave outputs)"

system --> hfhub : "HTTPS / huggingface_hub\n(snapshot_download,\nupload_folder)"
system --> diffusers : "Python import\n(pipeline, scheduler,\nUNet components)"
system --> transformers : "Python import\n(CLIP, T5 tokenizer\n& encoder)"

system --> wandb : "HTTPS / wandb SDK\n(log metrics, losses,\nrun tracking)"

system --> mamba : "Python import\n(Mamba2 SSM blocks\nfor sequence models)"
system --> gsplat : "Python import\n(Gaussian renderer,\nnovel-view synthesis)"
system --> moge : "Python import / HTTPS\n(depth estimation\npre-processing)"

system --> http : "HTTP GET\n(fetch remote files\nvia HTTPBackend)"

@enduml
