@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title 3D Convolution & Upsampling

left to right direction

actor "LatentRecon\n(Decoder)" as decoder
actor "Configuration\n(opt.transposed_conv_type)" as config
actor "Gradient Checkpoint\nUtility" as gcu

rectangle "3D Upsampling Subsystem" {

    usecase "Decode Patchified Token Sequence\ninto Spatiotemporal Feature Volume\n(forward_gaussians)" as UC1

    usecase "Select Upsampling Module\nat Runtime" as UC2

    usecase "Upsample via Trilinear\nInterpolation + Conv3d\n[ConvTranspose3dFactorized]" as UC3

    usecase "Upsample via Channel\nReduction + Transposed Conv\n[ConvTranspose3dReduced]" as UC4

    usecase "Upsample via Multi-Stage\nTemporal + Spatial Deconv\n[MultiStageConvTranspose3d]" as UC5

    usecase "Apply Single-Shot\nTransposed Conv Fallback\n[nn.ConvTranspose3d]" as UC6

    usecase "Enable Gradient\nCheckpointing per Stage\n(forward_checkpointing)" as UC7

    usecase "Apply Temporal Deconv Stages\n(stride=(2,1,1) × log2(sD))" as UC8

    usecase "Apply Spatial Deconv Stages\n(stride=(1,2,2) × log2(sH))" as UC9

}

' Actor → use case associations
decoder --> UC1
decoder --> UC2
config  --> UC2
gcu     --> UC7

' Core flow: decode includes selecting the module and checkpointing
UC1 ..> UC2 : <<include>>
UC1 ..> UC7 : <<include>>

' Config-driven module selection extends with one of the four strategies
UC2 <.. UC3 : <<extend>>\nfactorized
UC2 <.. UC4 : <<extend>>\nreduce_transposed
UC2 <.. UC5 : <<extend>>\nmulti_stage_transpose
UC2 <.. UC6 : <<extend>>\ndefault fallback

' Multi-stage internal decomposition
UC5 ..> UC8 : <<include>>
UC5 ..> UC9 : <<include>>

note bottom of UC3
  Uses F.interpolate (trilinear,
  scale=stride) + regular Conv3d.
  Does NOT use ConvTranspose3d.
  Optional 1×1×1 channel reducer.
end note

note bottom of UC5
  Lazily computes ConstantPad3d
  on first forward pass.
  Decomposes stride=(sD,sH,sW)
  into log2 stages per axis.
end note

@enduml
