@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2979A8
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343A40
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F9A825

title 3D Gaussian Rendering

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────────
actor "LatentRecon\n(Model)" as LatentRecon
actor "Training\nPipeline" as TrainingPipeline
actor "gsplat GPU\nRasterizer" as Rasterizer #D6F5D6

' ── System boundary ──────────────────────────────────────────────────────────
rectangle "3D Gaussian Splatting Rendering Subsystem" {

    ' Standard rendering
    usecase "Render Scene\n(Standard Mode)" as UC_Standard
    note right of UC_Standard
      GaussianRenderer.render()
      RGB+ED rasterization
    end note

    ' Deferred rendering group
    usecase "Render Scene\n(Deferred Mode)" as UC_Deferred
    note right of UC_Deferred
      GaussianRendererDeferred
      .render() → DeferredBP.apply()
    end note

    usecase "Apply Deferred\nBackpropagation" as UC_DeferredBP
    note right of UC_DeferredBP
      Forward: no_grad rasterization
      Backward: re-run with grad
    end note

    ' Patch-based rendering
    usecase "Render Scene\n(Patch-Based Deferred)" as UC_Patch
    note right of UC_Patch
      DeferredBPPatch: divides image
      into tiles, shifts cx/cy per tile
    end note

    ' OOM downscale
    usecase "Render with OOM\nFallback Downscaling" as UC_OOM
    note right of UC_OOM
      render_downscale() →
      F.interpolate to restore size
    end note

    ' 3DGuT backend
    usecase "Render with\n3DGuT Backend" as UC_3DGuT
    note right of UC_3DGuT
      raster_kwargs: with_ut=True
      use_3dgut=True at init
    end note

    ' PLY I/O
    usecase "Export Scene\nto PLY File" as UC_SavePLY
    note right of UC_SavePLY
      save_ply(): prune opacity,
      inverse activations, SH norm
    end note

    usecase "Load Scene\nfrom PLY File" as UC_LoadPLY
    note right of UC_LoadPLY
      load_ply(): sigmoid/exp
      activations on load
    end note

    ' Rasterization (shared sub-use-case)
    usecase "Execute GPU\nRasterization" as UC_Raster
}

' ── Actor → Use-case associations ────────────────────────────────────────────
LatentRecon     --> UC_Standard
LatentRecon     --> UC_Deferred
LatentRecon     --> UC_Patch
LatentRecon     --> UC_OOM
LatentRecon     --> UC_3DGuT
LatentRecon     --> UC_SavePLY
LatentRecon     --> UC_LoadPLY

TrainingPipeline --> UC_Deferred
TrainingPipeline --> UC_Patch

Rasterizer      --> UC_Raster

' ── Include / Extend relationships ───────────────────────────────────────────
UC_Standard  ..> UC_Raster         : <<include>>
UC_Deferred  ..> UC_DeferredBP     : <<include>>
UC_DeferredBP ..> UC_Raster        : <<include>>
UC_Patch     ..> UC_DeferredBP     : <<include>>
UC_OOM       ..> UC_Deferred       : <<extend>>
UC_3DGuT     ..> UC_Deferred       : <<extend>>

@enduml
