@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}

title Checkpoint & Model Management

left to right direction

actor "Developer" as dev
actor "HuggingFace Hub" as hf #E8F4FD

rectangle "Checkpoint & Model Management" {

    usecase "Download Lyra\nCheckpoints" as UC1
    note right of UC1
      nvidia/Lyra →
      lyra_static.pt, lyra_dynamic.pt
    end note

    usecase "Download Gen3C\nCheckpoints" as UC2
    note right of UC2
      nvidia/Gen3C-Cosmos-7B +\nTokenizer CV8x8x8-720p + T5-11B
    end note

    usecase "Download Tokenizer\nCheckpoints" as UC3
    note right of UC3
      8 variants selectable via
      --tokenizer_types CLI arg
    end note

    usecase "Download Guardrail\nCheckpoints" as UC4
    note right of UC4
      Llama-Guard-3-8B +
      Cosmos-Guardrail1
    end note

    usecase "Verify MD5\nChecksum" as UC5
    note right of UC5
      Skip if hash matches;
      re-download on mismatch
    end note

    usecase "Convert Pixtral\nCheckpoint" as UC6
    note right of UC6
      mistralai/Pixtral-12B-2409 →
      split into VIT / projector / LLM
    end note

    usecase "Select Tokenizer\nTypes" as UC7
    note right of UC7
      Choose subset of 8 tokenizer
      variants (all 8 by default)
    end note
}

' Developer initiates top-level downloads
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4

' All download use cases interact with HuggingFace Hub
UC1 --> hf : snapshot_download()
UC2 --> hf : snapshot_download()
UC3 --> hf : snapshot_download()
UC4 --> hf : snapshot_download()

' Include relationships (mandatory sub-flows)
UC1 .> UC5 : <<include>>
UC2 .> UC5 : <<include>>
UC3 .> UC5 : <<include>>
UC3 .> UC4 : <<include>>
UC3 .> UC7 : <<include>>

' Extend relationships (optional / available but not auto-triggered)
UC6 .> UC1 : <<extend>>
UC6 .> UC2 : <<extend>>

@enduml
