@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}

title Context Parallel Position Embedding

left to right direction

actor "Distributed Trainer" as DistTrainer
actor "Inference Engine" as InfEngine
actor "DiT Network\n(forward caller)" as DiTNet
actor "Context Parallel Group\n(torch.distributed.ProcessGroup)" as CPGroup

rectangle "Context Parallel Position Embedding System" {

    package "CP Lifecycle Management" {
        usecase "Enable Context Parallel\n(set cp_group)" as UC_Enable
        usecase "Disable Context Parallel\n(set cp_group = None)" as UC_Disable
    }

    package "Embedding Generation" {
        usecase "Compute Full Sequence\nPosition Embeddings" as UC_Compute
        usecase "Generate Single-View\nEmbeddings (per batch)" as UC_GenSingle
        usecase "Generate Multiview\nEmbeddings (concat n_views)" as UC_GenMulti
    }

    package "CP-Aware Forward Pass" {
        usecase "Forward Pass —\nSingle View with CP" as UC_FwdSingle
        usecase "Forward Pass —\nMultiview RoPE with CP" as UC_FwdRope
        usecase "Forward Pass —\nMultiview SinCos with CP" as UC_FwdSinCos
        usecase "Split Embeddings\nfor CP Rank" as UC_Split
    }

}

' Actor → Use Case relationships
DistTrainer --> UC_Enable
DistTrainer --> UC_Disable
InfEngine --> UC_Disable
DiTNet --> UC_FwdSingle
DiTNet --> UC_FwdRope
DiTNet --> UC_FwdSinCos
CPGroup --> UC_Split

' Include relationships — forward passes depend on embedding generation
UC_FwdSingle ..> UC_Compute : <<include>>
UC_FwdRope ..> UC_Compute : <<include>>
UC_FwdSinCos ..> UC_Compute : <<include>>

UC_Compute ..> UC_GenSingle : <<include>>
UC_Compute ..> UC_GenMulti : <<include>>

' CP-enabled forward paths include splitting
UC_FwdSingle <.. UC_Split : <<extend>>\nwhen CP enabled
UC_FwdRope <.. UC_Split : <<extend>>\nwhen CP enabled
UC_FwdSinCos <.. UC_Split : <<extend>>\nwhen CP enabled

note bottom of UC_Split
  split_inputs_cp() slices the full
  embedding tensor along seq_dim
  for this process rank's CP shard.
  seq_dim=0 for RoPE3D, seq_dim=1
  for all other embeddings.
end note

note right of UC_GenMulti
  Calls generate_embedding_for_batch()
  n_views times and concatenates results.
  (MultiviewVideoRopePosition3DEmb)
end note

note top of UC_Enable
  Shared by VideoPositionEmb
  and MultiviewVideoPositionEmb
  base classes.
end note

@enduml
