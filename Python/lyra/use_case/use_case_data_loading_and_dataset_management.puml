@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057

title Data Loading & Dataset Management

left to right direction

actor "Training System" as TrainingSystem
actor "Data Loader" as DataLoader
actor "Developer" as Developer

rectangle "Data Loading & Dataset Management" {

    package "Dataset Configuration & Registry" {
        usecase "Configure Dataset" as UC_Configure
        usecase "Register Dataset\nin Registry" as UC_Register
        usecase "Enumerate Available\nData Fields" as UC_EnumFields
    }

    package "Raw Data Loading" {
        usecase "Load Video Files\n(MP4 via decord)" as UC_LoadVideo
        usecase "Load Depth Data\n(EXR / ZIP)" as UC_LoadDepth
        usecase "Load Camera Poses\n(NPZ)" as UC_LoadPoses
        usecase "Load Camera Intrinsics\n(NPZ)" as UC_LoadIntrinsics
        usecase "Load Instance Masks\n(PNG / ZIP)" as UC_LoadMasks
        usecase "Load Optical Flow\n(EXR / ZIP)" as UC_LoadFlow
        usecase "Load Captions\n(TXT)" as UC_LoadCaptions
        usecase "Load T5 Text Embeddings\n(PKL)" as UC_LoadT5
    }

    package "Frame & View Sampling" {
        usecase "Get Data for\nVideo Index" as UC_GetData
        usecase "Sample Frame Indices" as UC_SampleFrames
    }

    package "Data Preprocessing" {
        usecase "Apply Image Transforms\n(Crop / Resize / Normalize)" as UC_Transform
    }

    package "Batch Provision" {
        usecase "Provide Batches with\nWeighted Dataset Sampling" as UC_ProvideBatches
        usecase "Iterate Multiple Datasets\n(Ratio-Based)" as UC_IterateDatasets
    }
}

' Developer interactions
Developer --> UC_Configure
Developer --> UC_Register
Developer --> UC_EnumFields

' Training System interactions
TrainingSystem --> UC_Configure
TrainingSystem --> UC_GetData
TrainingSystem --> UC_SampleFrames
TrainingSystem --> UC_LoadVideo
TrainingSystem --> UC_LoadDepth
TrainingSystem --> UC_LoadPoses
TrainingSystem --> UC_LoadIntrinsics
TrainingSystem --> UC_LoadMasks
TrainingSystem --> UC_LoadFlow
TrainingSystem --> UC_LoadCaptions
TrainingSystem --> UC_LoadT5
TrainingSystem --> UC_Transform
TrainingSystem --> UC_ProvideBatches

' DataLoader interactions
DataLoader --> UC_ProvideBatches
DataLoader --> UC_IterateDatasets

' Include / Extend relationships
UC_GetData ..> UC_SampleFrames : <<include>>

UC_ProvideBatches ..> UC_GetData : <<include>>
UC_ProvideBatches ..> UC_Transform : <<include>>
UC_IterateDatasets ..> UC_ProvideBatches : <<include>>

UC_GetData ..> UC_LoadVideo : <<include>>
UC_GetData ..> UC_LoadDepth : <<extend>>\n(if requested)
UC_GetData ..> UC_LoadPoses : <<include>>
UC_GetData ..> UC_LoadIntrinsics : <<include>>
UC_GetData ..> UC_LoadMasks : <<extend>>\n(if requested)
UC_GetData ..> UC_LoadFlow : <<extend>>\n(if requested)
UC_GetData ..> UC_LoadCaptions : <<extend>>\n(if requested)
UC_GetData ..> UC_LoadT5 : <<extend>>\n(if requested)

UC_Configure ..> UC_Register : <<include>>

note bottom of UC_IterateDatasets
  IterativeGEN3CDataLoader
  performs weighted random
  sampling across named
  dataset ratio configs
end note

note right of UC_GetData
  Dispatches to Radym._read_data()
  keyed by DataField enum;
  LRU(10) cache for ZIP handles
end note

@enduml
