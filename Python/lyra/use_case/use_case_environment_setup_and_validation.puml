@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343A40
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Environment Setup & Validation\n<size:11>(scripts/test_environment.py)</size>

left to right direction

actor "Developer" as Dev

rectangle "Cosmos/Lyra Environment Validator" {

    usecase "Validate Python Version\n<size:10>(Python >= 3.10 required)</size>" as UC1
    usecase "Check Conda Environment\n<size:10>(CONDA_PREFIX warning)</size>" as UC2
    usecase "Validate Core Packages\n<size:10>torch · torchvision · diffusers\ntransformers · megatron.core\ntransformer_engine</size>" as UC3
    usecase "Configure Validation Mode\n<size:10>parse_args() --training flag</size>" as UC6
    usecase "Validate Training Packages\n<size:10>apex.multi_tensor_apply</size>" as UC4
    usecase "Report Environment Status\n<size:10>Print final success banner</size>" as UC5

}

' Developer triggers always-on checks
Dev --> UC1 : invokes script
Dev --> UC2 : invokes script
Dev --> UC3 : invokes script
Dev --> UC6 : passes --training flag
Dev --> UC4
Dev --> UC5

' Configure mode extends training validation
UC6 ..> UC4 : <<extend>>

' Both check paths feed into the status report
UC3 ..> UC5 : <<include>>
UC4 ..> UC5 : <<include>>

note bottom of UC1
  <b>Exit on failure</b>
  sys.exit(1) if Python < 3.10
end note

note right of UC2
  <b>Warning only</b>
  Does not halt execution
end note

note right of UC4
  <b>Conditional</b>
  Only when --training flag is set
end note

@enduml
