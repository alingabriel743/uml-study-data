@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7FCC
    FontColor #1A3F6F
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #FFFBEA
skinparam NoteBorderColor #CCAA00

title File I/O & Data Handlers

left to right direction

actor "External Caller\n(application / pipeline)" as ExternalCaller

rectangle "easy_io File Handler Subsystem" {

    package "Path-Level Operations\n(BaseFileHandler)" {
        usecase "Load Data from\nFile Path" as UC4
        usecase "Dump Data to\nFile Path" as UC5
    }

    package "Stream-Level Operations\n(TxtHandler / CsvHandler)" {
        usecase "Load Data from\nFile Object" as UC1
        usecase "Dump Data to\nFile Object" as UC2
        usecase "Dump Data to\nString" as UC3
    }

}

' Actor associations
ExternalCaller --> UC4
ExternalCaller --> UC5
ExternalCaller --> UC1
ExternalCaller --> UC2
ExternalCaller --> UC3

' Include relationships (delegation chain)
UC4 ..> UC1 : <<include>>
UC5 ..> UC2 : <<include>>

' Notes for TxtHandler behaviour
note right of UC1
  <b>TxtHandler:</b> returns raw str via file.read()
  <b>CsvHandler:</b> returns list[list[str]] via csv.reader
end note

note right of UC2
  <b>TxtHandler:</b> converts obj to str, then file.write()
  <b>CsvHandler:</b> validates list[list], then csv.writer.writerows()
end note

note right of UC3
  <b>TxtHandler:</b> str(obj)
  <b>CsvHandler:</b> writes via StringIO, returns getvalue()
end note

note bottom of UC4
  Opens file, then delegates to
  load_from_fileobj() — behaviour
  is handler-specific (Txt or CSV)
end note

note bottom of UC5
  Opens file, then delegates to
  dump_to_fileobj() — behaviour
  is handler-specific (Txt or CSV)
end note

@enduml
