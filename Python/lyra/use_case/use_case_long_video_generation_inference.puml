@startuml use_case_long_video_generation_inference

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2962A8
    FontColor #1A1A2E
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #EEF2F7
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Long Video Generation (LVG) Inference\n<size:11><color:#6C757D>Cosmos Predict1 — Multiview Video Extension Pipeline</color></size>

left to right direction

' ─── Primary Actor ───
actor "User" as User #D0E8FF

' ─── Secondary / System Actors ───
actor "Guardrail\n(Safety Filter)" as Guardrail #FFE0CC
actor "Text Encoder\n(T5)" as TextEncoder #D4F0D4
actor "VAE / Tokenizer" as VAETokenizer #D4F0D4
actor "Diffusion Network\n(MultiviewVideoExtendGeneralDIT)" as DiffusionNet #EDE7F6
actor "Inference Runtime\n(System)" as System #E8EAF6

' ─── System Boundary ───
rectangle "Cosmos Predict1 — LVG Inference System\n<size:10><color:#6C757D>DiffusionVideo2WorldMultiviewGenerationPipeline</color></size>" {

    usecase "Submit LVG Inference Request\n<size:10>video2world_multiview.py demo()\nProvide image/video path, per-camera prompts\n& generation params (H, W, fps, seed, steps)</size>" as UC1

    usecase "Validate Inputs &\nCheck Guardrails\n<size:10>validate_args() + guardrail.run()\nBlocks unsafe prompts / generated content</size>" as UC2

    usecase "Encode Per-View\nText Prompts\n<size:10>_run_text_embedding_on_prompt_with_offload()\n6 camera prompts → crossattn_emb tensors (T5)</size>" as UC3

    usecase "Encode Condition\nVideo to Latent\n<size:10>DiffusionMultiviewV2WModel.encode()\nB C (V T) H W → tokenizer.encode() → latent</size>" as UC4

    usecase "Prepare Video\nExtension Condition\n<size:10>add_condition_video_indicator_and_video_input_mask()\nSets condition_video_indicator & input mask\nfor first_n conditioned frames</size>" as UC5

    usecase "Run Multiview\nDiffusion Denoising Loop\n<size:10>generate_samples_from_batch()\n_augment_noise_with_latent() → DIT.forward()\nCFG: cond + guidance*(cond − uncond) × 35 steps</size>" as UC6

    usecase "Enable Multi-GPU\nContext Parallel Inference\n<size:10>megatron parallel_state init\nenable_context_parallel(process_group)\nSplit temporal T dim across GPUs per view</size>" as UC9

    usecase "Decode Latent to\nMulti-View Video\n<size:10>DiffusionMultiviewV2WModel.decode()\n(B V) C T H W → tokenizer.decode() → pixels</size>" as UC7

    usecase "Assemble & Save\nGenerated Video\n<size:10>save_video() writes per-camera .mp4 files\n+ 2×3 mosaic grid video; prompts saved to .txt\nDefault: 480×848 per cam, 57 frames @ 24 fps</size>" as UC8
}

' ─── Actor → Use Case associations ───
User      --> UC1
User      --> UC8

Guardrail  --> UC2

TextEncoder --> UC3

VAETokenizer --> UC4
VAETokenizer --> UC7

DiffusionNet --> UC6

System    --> UC5
System    --> UC9

' ─── Include / Extend relationships ───
UC1 .down.> UC2  : <<include>>
UC1 .down.> UC3  : <<include>>
UC1 .down.> UC4  : <<include>>
UC4 .down.> UC5  : <<include>>
UC5 .down.> UC6  : <<include>>
UC6 .down.> UC7  : <<include>>
UC7 .down.> UC8  : <<include>>

UC9 .up.> UC6  : <<extend>>\n[num_gpus > 1]

' ─── Notes ───
note right of UC6
  <b>Key params</b>
  guidance = 7.0 (CFG)
  num_steps = 35
  condition_augment_sigma = 0.001
  6 views: front, left, right,
  back, back-left, back-right
  Tensor shape: B C (V T) H W
end note

note right of UC2
  <b>Guardrail</b> also screens
  the final generated video
  (post-decode). Returns None
  if content is blocked.
end note

note bottom of UC8
  <b>Model</b>: Cosmos-Predict1-7B-Video2World-Sample-AV-Multiview
  <b>Network</b>: MultiviewVideoExtendGeneralDIT (+1 channel for condition mask)
end note

@enduml
