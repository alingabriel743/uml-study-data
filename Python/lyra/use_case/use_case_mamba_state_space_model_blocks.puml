@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7DCA
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Mamba State Space Model Blocks

left to right direction

actor "Video Encoder\n(enc_blocks)" as VideoEncoder
actor "DIT Block Builder" as ModelBuilder
actor "mamba_ssm\nTriton Library" as MambaLib #D5F5E3

rectangle "Mamba2 SSM System" {

    usecase "Process Sequential\nVideo Features" as UC1
    usecase "Apply Pre-Normalization\n(RMSNorm / LayerNorm)" as UC2
    usecase "Apply Residual\nConnection" as UC3
    usecase "Perform Bidirectional\nSequence Scan" as UC4
    usecase "Perform Single-Direction\nSequence Scan" as UC5
    usecase "Project Input to\nSSM Space (in_proj)" as UC6
    usecase "Execute Fused\nConv1D-SSM Kernel" as UC7
    usecase "Project SSM Output\nto Model Dimension (out_proj)" as UC8
    usecase "Configure Block\nArchitecture" as UC9
    usecase "Initialize SSM State\nParameters (A, D, dt_bias)" as UC10

}

' Actor → Use Case associations
VideoEncoder --> UC1
VideoEncoder --> UC4
VideoEncoder --> UC5

ModelBuilder --> UC9
ModelBuilder --> UC1

MambaLib --> UC7

' Include relationships
UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>
UC4 ..> UC6 : <<include>>
UC4 ..> UC7 : <<include>>
UC4 ..> UC8 : <<include>>

' Extend relationship
UC5 ..> UC4 : <<extend>>\n(scan_type="single")

' Dependency
UC7 ..> UC10 : <<include>>

note bottom of UC4
  Mamba2MultiScan flips the
  sequence and runs two
  Mamba2SingleScan passes,
  then sums the outputs.
end note

note right of UC7
  mamba_split_conv1d_scan_combined
  (Triton fused kernel)
  Input shape: (B, L, D)
  Output shape: (B, L, D)
end note

@enduml
