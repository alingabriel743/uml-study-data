@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7EC8
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343A40
}

title Model Configuration Management

left to right direction

actor "ML Engineer" as mle
actor "Config Registry\n(Hydra)" as hydra

rectangle "Multiview Diffusion Model Configuration System" {

    package "Architecture Setup" {
        usecase "Initialize Configuration\nvia make_config()" as UC1
        usecase "Set Model Architecture\nComponents (net, vae, conditioner)" as UC2
        usecase "Configure Number of\nCamera Views (n_views)" as UC3
        usecase "Set Latent Shape\nDimensions [T, C, H, W]" as UC4
        usecase "Set Input Data Keys\n(input_data_key, input_image_key)" as UC5
    }

    package "Noise & Diffusion Settings" {
        usecase "Configure SDE Noise\nSchedule Parameters" as UC6
        usecase "Configure EMA Settings\n(PowerEMAConfig)" as UC7
        usecase "Enable/Disable Video\nNoise Adjustment" as UC8
    }

    package "Training Configuration" {
        usecase "Set Training Precision\n(bfloat16)" as UC9
        usecase "Configure Loss Settings\n(mask, logvar, reduce, scale)" as UC10
        usecase "Configure Distributed\nTraining (FSDP)" as UC11
        usecase "Enable PEFT\nFine-Tuning" as UC12
        usecase "Enable Aesthetic\nFine-Tuning" as UC13
    }

    package "Optimization & Sampling" {
        usecase "Enable torch.compile\nOptimization" as UC14
        usecase "Configure Camera\nSample Weighting" as UC15
    }

    package "Config Group Registration" {
        usecase "Register Config Groups\n(text2world / video2world variants)" as UC16
        usecase "Register Multiview\nConfig Variants" as UC17
    }
}

' ML Engineer interactions
mle --> UC1
mle --> UC2
mle --> UC3
mle --> UC4
mle --> UC5
mle --> UC6
mle --> UC7
mle --> UC8
mle --> UC9
mle --> UC10
mle --> UC11
mle --> UC12
mle --> UC13
mle --> UC14
mle --> UC15
mle --> UC16

' Include relationships
UC1 ..> UC16 : <<include>>
UC1 ..> UC17 : <<include>>
UC16 ..> UC17 : <<include>>
UC9  <.. UC11 : <<extend>>
UC11 <.. UC12 : <<extend>>
UC12 <.. UC13 : <<extend>>

' Config Registry actor
hydra --> UC16
hydra --> UC17

@enduml
