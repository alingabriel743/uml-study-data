@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}

title Model Training Pipeline\nML Engineer launches and manages training runs for diffusion world models

left to right direction

' ─── Actors ───────────────────────────────────────────────
actor "ML Engineer" as MLEngineer
actor "WandB" as WandB
actor "Distributed\nGPU Cluster" as GPUCluster
actor "HuggingFace Hub" as HFHub

' ─── System Boundary ──────────────────────────────────────
rectangle "Model Training Pipeline" {

    ' ── Setup & Launch ────────────────────────────────────
    package "Setup & Launch" {
        usecase "Launch Training Run\n(train.py --config <yaml>)" as UC01
        usecase "Configure Training\nParameters (OmegaConf)" as UC02
        usecase "Initialize Distributed\nBackend (FSDP / ZeRO-2 / DDP)" as UC03
    }

    ' ── Model Initialization ──────────────────────────────
    package "Model Initialization" {
        usecase "Load Pretrained VAE\n(frozen, optional torch.compile)" as UC04
        usecase "Initialize Model\n(LatentRecon / MultiviewDiffusionModel)" as UC05
        usecase "Configure LoRA\nAdapters (PEFT, r=64)" as UC06
        usecase "Resume Training\nfrom Checkpoint" as UC07
    }

    ' ── Data & Training Loop ──────────────────────────────
    package "Training Loop" {
        usecase "Create Multi-view\nDataLoaders (WebDataset)" as UC08
        usecase "Execute Training Step\n(encode → forward → loss → backward)" as UC09
        usecase "Train Multiview\nDiffusion Model" as UC10
        usecase "Train Video\nExtension Model" as UC11
        usecase "Generate Diffusion\nSamples (CFG ODE)" as UC12
    }

    ' ── Persistence & Monitoring ──────────────────────────
    package "Persistence & Monitoring" {
        usecase "Save Training\nCheckpoint" as UC13
        usecase "Monitor Training\nMetrics (train_loss, lr)" as UC14
        usecase "Stop Training Run\n(max_train_steps / job_stop_steps)" as UC15
    }
}

' ─── Actor → Use Case associations ───────────────────────
MLEngineer --> UC01
MLEngineer --> UC02
MLEngineer --> UC03
MLEngineer --> UC04
MLEngineer --> UC05
MLEngineer --> UC06
MLEngineer --> UC07
MLEngineer --> UC08
MLEngineer --> UC12
MLEngineer --> UC13
MLEngineer --> UC15

GPUCluster --> UC09
GPUCluster --> UC10
GPUCluster --> UC11

WandB       --> UC14

HFHub       --> UC13

' ─── Include relationships ────────────────────────────────
UC01 .> UC02  : <<include>>
UC01 .> UC03  : <<include>>
UC01 .> UC04  : <<include>>
UC01 .> UC05  : <<include>>
UC01 .> UC08  : <<include>>
UC01 .> UC15  : <<include>>

UC09 .> UC10  : <<include>>
UC09 .> UC13  : <<include>>
UC09 .> UC14  : <<include>>

' ─── Extend relationships ─────────────────────────────────
UC06 .> UC05  : <<extend>>\n(optional LoRA)
UC07 .> UC01  : <<extend>>\n(if resume_from_checkpoint)
UC11 .> UC10  : <<extend>>\n(video conditioning)
UC12 .> UC09  : <<extend>>\n(validation / inference)

@enduml
