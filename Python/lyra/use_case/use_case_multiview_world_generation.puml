@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #4A90D9
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Multiview World Generation

left to right direction

' ── Actors ───────────────────────────────────────────────
actor "User / Developer" as User
actor "T5 Text Encoder" as T5
actor "Tokenizer / VAE" as VAE
actor "Diffusion Scheduler" as Scheduler
actor "Guardrail System" as Guardrail
actor "Context Parallel\nRuntime" as CPRuntime

' ── System Boundary ──────────────────────────────────────
rectangle "Multiview World Generation System" {

    ' Primary generation use cases
    usecase "Generate Multi-View World\nfrom Text Prompt\n(Text2World)" as UC1
    usecase "Generate Multi-View World\nfrom Video / Image Input\n(Video2World)" as UC2

    ' Supporting use cases
    usecase "Embed Per-View\nText Prompts" as UC_TE
    usecase "Encode Conditioning\nLatent (V2W)" as UC3
    usecase "Decode Multi-View\nLatent to Video" as UC4
    usecase "Run Multi-View\nDiffusion Sampling (CFG)" as UC5
    usecase "Enable Context\nParallel Inference" as UC7
    usecase "Safety Guardrail\nCheck" as UC8
}

' ── Actor → Use Case connections ─────────────────────────
User     --> UC1
User     --> UC2

T5       --> UC_TE
VAE      --> UC3
VAE      --> UC4
Scheduler --> UC5
Guardrail --> UC8
CPRuntime --> UC7

' ── Include relationships ─────────────────────────────────
UC1 .> UC_TE : <<include>>
UC1 .> UC5   : <<include>>
UC1 .> UC4   : <<include>>
UC1 .> UC8   : <<include>>

UC2 .> UC_TE : <<include>>
UC2 .> UC3   : <<include>>
UC2 .> UC5   : <<include>>
UC2 .> UC4   : <<include>>

' ── Extend relationships ──────────────────────────────────
UC7 .> UC5 : <<extend>>\n(multi-GPU)

' ── Notes ────────────────────────────────────────────────
note right of UC1
  Supports 6 per-view prompts:
  front · left · right
  back · back-left · back-right
  480×848, 57 frames/camera
  guidance=7.0, num_steps=35
end note

note right of UC5
  Iterative denoising with
  Classifier-Free Guidance:
  output = cond + g × (cond − uncond)
end note

note bottom of UC7
  Splits V×T dim across GPUs
  via megatron parallel_state
end note

@enduml
