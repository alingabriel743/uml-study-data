@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam ArrowFontColor #495057
skinparam ArrowFontSize 11

title Patch Embedding & Tokenization

left to right direction

actor "Diffusion Pipeline\n(GeneralDIT / MultiviewGeneralDIT)" as DiffusionPipeline
actor "Multiview Input Source\n(multi-camera frames)" as MultiviewInputSource
actor "Transformer Blocks\n(GeneralDITTransformerBlock)" as TransformerBlocks

rectangle "Patch Embedding & Tokenization Subsystem" {

    usecase "Build Patch Embedder\n(Base — PatchEmbed via GeneralDIT)" as UC2
    usecase "Build Patch Embedder\n(Multiview — expand view/traj channels)" as UC3
    usecase "Tokenize Spatial Patches\n(Rearrange+Linear or Conv3D → B,T',H',W',D)" as UC1
    usecase "Concatenate Padding\nMask Channel" as UC4
    usecase "Embed Per-View\nCamera Conditioning\n(nn.Embedding)" as UC5
    usecase "Embed Repeat-Frame\nConditioning\n(nn.Linear 1→D_v)" as UC6
    usecase "Embed Trajectory\nConditioning\n(nn.Linear 192→D_t)" as UC7
    usecase "Apply RoPE 3D\nPositional Embedding\n(MultiviewVideoRopePosition3DEmb)" as UC8
    usecase "Apply Sincos\nPositional Embedding\n(MultiviewSinCosPosEmbAxis)" as UC9
    usecase "Prepare Full\nEmbedded Sequence\n(MultiviewGeneralDIT)" as UC10
    usecase "Tokenize Video Extension\nwith Condition Mask\n(VideoExtendGeneralDIT)" as UC11

}

' Actor → use case associations
DiffusionPipeline --> UC2
DiffusionPipeline --> UC10
DiffusionPipeline --> UC11

MultiviewInputSource --> UC3
MultiviewInputSource --> UC5
MultiviewInputSource --> UC7

UC10 --> TransformerBlocks

' UC10 orchestrates the full tokenization pipeline
UC10 ..> UC4  : <<include>>
UC10 ..> UC5  : <<include>>
UC10 ..> UC1  : <<include>>
UC10 ..> UC8  : <<include>>
UC10 ..> UC9  : <<include>>

' UC11 delegates to UC10 after prepending condition mask
UC11 ..> UC10 : <<include>>

' Multiview patch embedder extends base
UC2 <.. UC3 : <<extend>>

' Optional conditioning extends base view embedding
UC5 <.. UC6 : <<extend>>
UC5 <.. UC7 : <<extend>>

note bottom of UC1
  Mode A (default): Rearrange patches then nn.Linear
  Mode B (legacy): nn.Conv3d(C, D, kernel=(t_p, s_p, s_p))
  Output: (B, T/t_patch, H/s_patch, W/s_patch, D)
end note

note bottom of UC10
  Tokenization flow:
  1. Optional padding mask concat
  2. View embedding broadcast
  3. Optional traj/repeat-frame embed
  4. PatchEmbed projection
  5. RoPE / sincos pos embed
  Returns: (x_BTHWD, rope_emb, extra_pos_emb)
end note

@enduml
