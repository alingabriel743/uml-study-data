@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7EC6
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam arrow {
    Color #495057
    FontColor #495057
    FontSize 11
}

title Position Embedding Computation

left to right direction

' ── Actors ──────────────────────────────────────────────────
actor "Transformer\nAttention Module" as TAM
actor "Training\nPipeline" as TP
actor "Inference\nPipeline" as IP
actor "Context Parallel\nCoordinator" as CPC

' ── System boundary ─────────────────────────────────────────
rectangle "Position Embedding Computation System" {

    ' Core computation use cases
    usecase "Compute Single-View\nVideo Position Embedding" as UC_SV
    usecase "Compute Multiview\nVideo Position Embedding" as UC_MV

    ' Encoding strategy use cases
    usecase "Apply 3D RoPE Encoding\n(T+H+W Decomposed)" as UC_ROPE3D
    usecase "Apply SinCos\nAxis-Based Encoding" as UC_SINCOS
    usecase "Apply Learnable\nAxis-Based Encoding" as UC_LEARN

    ' Advanced / conditional use cases
    usecase "Apply FPS-Aware\nTemporal Encoding" as UC_FPS
    usecase "Extrapolate Beyond\nTraining Dimensions\n(NTK Scaling)" as UC_NTK

    ' Parallel / infrastructure use cases
    usecase "Enable Context\nParallel Splitting" as UC_CP_EN
    usecase "Disable Context\nParallel" as UC_CP_DIS
    usecase "Generate Per-View\nEmbeddings (n_views loop)" as UC_VIEWS

}

' ── Actor → Use Case associations ───────────────────────────
TAM --> UC_SV
TAM --> UC_MV
TAM --> UC_ROPE3D
TAM --> UC_SINCOS
TAM --> UC_LEARN

TP --> UC_FPS
TP --> UC_CP_EN

IP --> UC_ROPE3D
IP --> UC_NTK

CPC --> UC_CP_EN
CPC --> UC_CP_DIS
CPC --> UC_VIEWS

' ── Include relationships ────────────────────────────────────
UC_SV       .> UC_CP_EN      : <<include>>
UC_MV       .> UC_VIEWS      : <<include>>
UC_MV       .> UC_CP_EN      : <<include>>
UC_ROPE3D   .> UC_NTK        : <<include>>
UC_SINCOS   .> UC_SV         : <<include>>

' ── Extend relationships ─────────────────────────────────────
UC_FPS      .> UC_SV         : <<extend>>

@enduml
