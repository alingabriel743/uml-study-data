@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #495057
    FontColor #212529
}

left to right direction

title Sampling & Generation

' ── Primary Actor ──────────────────────────────────────────────────
actor "User\n(CLI Operator)" as User

' ── External Supporting Actors ─────────────────────────────────────
actor "Guardrail System\n(Text & Video Safety)" as Guardrail
actor "Prompt Upsampler\n(LLM / VLM)" as Upsampler
actor "T5 Text Encoder\n(CosmosT5)" as T5
actor "VAE / Tokenizer\n(CV8x8x8-720p)" as VAE
actor "LatentRecon\n(3DGS Transformer)" as LatentRecon

' ── System Boundary ────────────────────────────────────────────────
rectangle "Cosmos Predict1 – World Generation System" {

    ' ── Top-Level Use Cases ──────────────────────────────────────
    usecase "Run 3DGS Latent\nReconstruction Sampling\n(sample.py)" as UC1

    usecase "Generate World Video\nfrom Text Prompt\n(Text2World)" as UC2

    usecase "Generate World Video\nfrom Input Video\n(Video2World)" as UC3

    usecase "Generate Multi-View World\nfrom Text Prompt\n(Multiview Text2World)" as UC4

    usecase "Generate Multi-View World\nfrom Input Video\n(Multiview Video2World)" as UC5

    usecase "Interpolate World Video\n(WorldInterpolator)" as UC6

    ' ── Shared Sub-Use Cases ─────────────────────────────────────
    usecase "Check Safety\nGuardrails\n(text + video)" as UCG

    usecase "Upsample / Enhance\nPrompt" as UCP

    usecase "Encode Text\nEmbeddings" as UCT

    usecase "Encode Video\nCondition Latent" as UCEL

    usecase "Decode Latents\nto Video Frames" as UCDV
}

' ── User Initiates Top-Level Use Cases ────────────────────────────
User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6

' ── Diffusion Pipeline: Include (mandatory shared steps) ──────────
UC2 ..> UCG  : <<include>>
UC2 ..> UCT  : <<include>>
UC2 ..> UCDV : <<include>>

' ── Diffusion Pipeline: Extend (optional / conditional) ──────────
UCP ..> UC2  : <<extend>>

' ── Video2World adds video conditioning on top of Text2World ─────
UC3 ..> UC2  : <<extend>>
UC3 ..> UCEL : <<include>>

' ── Multiview Text2World specialises Text2World (6-view output) ──
UC4 ..> UC2  : <<extend>>

' ── Multiview Video2World adds video input to Multiview T2W ──────
UC5 ..> UC4  : <<extend>>
UC5 ..> UCEL : <<include>>

' ── WorldInterpolator extends Video2World with looped chunks ─────
UC6 ..> UC3  : <<extend>>

' ── 3DGS Branch: dependencies ────────────────────────────────────
UC1 --> LatentRecon
UC1 --> VAE

' ── Sub-Use Case ↔ External System Connections ───────────────────
UCG  --> Guardrail
UCP  --> Upsampler
UCT  --> T5
UCEL --> VAE
UCDV --> VAE

@enduml
