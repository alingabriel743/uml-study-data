@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BorderColor #495057
    FontColor #212529
    BackgroundColor #FFFFFF
}
skinparam note {
    BackgroundColor #FFF9E6
    BorderColor #CCA300
    FontColor #212529
}

title Scene Visualization & Dynamic Scene Merging

left to right direction

' ── Actors ──────────────────────────────────────────────
actor "User\n(Researcher / Engineer)" as user
actor "FFmpeg / FFprobe" as ffmpeg <<external system>>
actor "OpenCV (cv2)" as opencv <<external system>>

' ── System boundary ─────────────────────────────────────
rectangle "Scene Visualization & Dynamic Scene Merging" {

    ' ── Generation Pipeline (upstream) ──────────────────
    package "Generation Pipeline" #EDF7ED {
        usecase "Reconstruct Latent\n3D Gaussians\n(LatentRecon)" as UC5
        usecase "Render 3D\nGaussian Scene\n(GaussianRenderer)" as UC4
    }

    ' ── Visualization Pipeline (post-processing) ────────
    package "Visualization Pipeline (CLI)" #FDF6E8 {
        usecase "Merge Dynamic\nScene Segments" as UC1
        usecase "Generate Static-Camera\nTimeline Videos" as UC2
        usecase "Create Teaser / Wave\n/ Grid Videos" as UC3
    }

    ' ── Sub-steps: UC1 (dynamic_scene_merge.py) ─────────
    usecase "Probe FPS\n(ffprobe avg_frame_rate)" as UC1a
    usecase "Subsample Frames\n(ffmpeg -vf select/setpts/fps)" as UC1b
    usecase "Concatenate Videos\n(ffmpeg concat demuxer)" as UC1c

    ' ── Sub-steps: UC2 (dynamic_scene_video_static_camera.py) ──
    usecase "Collect Video Indices\n(glob rgb_*_view_idx_0)" as UC2a
    usecase "Collect Frames\n(cv2.VideoCapture)" as UC2b
    usecase "Save Concatenated Videos\n(cv2.VideoWriter / avc1→mp4v)" as UC2c

    ' ── Sub-steps: UC3 (dynamic_scene_video_static_scene.py) ───
    usecase "Find Sub-Videos\n(parse sample_idx / param)" as UC3a
    usecase "Build Wave Videos\n(ffmpeg reverse + concat)" as UC3b
    usecase "Build Single-View Videos\n(ffmpeg filter_complex concat)" as UC3c
    usecase "Build Grid Videos\n(ffmpeg hstack + vstack)" as UC3d
}

' ── Actor → Use-Case associations ───────────────────────
user --> UC5
user --> UC1
user --> UC2
user --> UC3

' ── Generation pipeline internal flow ───────────────────
UC5 ..> UC4 : <<include>>

' ── Pre-rendered MP4s flow from generation to visu ──────
UC4 ..> UC1 : <<produces MP4s for>>
UC4 ..> UC2 : <<produces MP4s for>>
UC4 ..> UC3 : <<produces MP4s for>>

' ── UC1 inclusions ──────────────────────────────────────
UC1 ..> UC1a : <<include>>
UC1 ..> UC1b : <<include>>
UC1 ..> UC1c : <<include>>

' ── UC2 inclusions ──────────────────────────────────────
UC2 ..> UC2a : <<include>>
UC2 ..> UC2b : <<include>>
UC2 ..> UC2c : <<include>>

' ── UC3 inclusions / extension ──────────────────────────
UC3 ..> UC3a : <<include>>
UC3 ..> UC3b : <<include>>
UC3 ..> UC3c : <<include>>
UC3d ..> UC3 : <<extend>>

' ── External system connections ─────────────────────────
UC1a --> ffmpeg
UC1b --> ffmpeg
UC1c --> ffmpeg
UC3b --> ffmpeg
UC3c --> ffmpeg
UC3d --> ffmpeg
UC2b --> opencv
UC2c --> opencv

' ── Clarifying note ─────────────────────────────────────
note bottom of UC4
  H.264 / libx264, CRF 18, yuv420p
  Output pattern:
  rgb_{sample_idx}_view_idx_*_{param}.mp4
  stored under timestep-indexed dirs
  (main_path/{time_idx}/sub_path/)
end note

@enduml
