@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #2C6FAC
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #EEF2F7
    BorderColor #6C757D
    FontColor #343A40
}

title Text-to-World Generation

left to right direction

' ── External Actors ──────────────────────────────────────────────
actor "User / CLI" as User
actor "Guardrail\nSystem" as Guardrail
actor "File System" as FS

' ── System Boundary ──────────────────────────────────────────────
rectangle "Text-to-World Generation Pipeline\n(DiffusionText2WorldMultiviewGenerationPipeline)" {

    usecase "Generate Multi-View\nWorld Video" as UC0

    usecase "Submit 6-View\nText Prompts\n(front · left · right\nback · back-left · back-right)" as UC1

    usecase "Initialize Pipeline\nComponents" as UC2

    usecase "Validate Text\nPrompt Safety" as UC3

    usecase "Encode Text Prompts\nvia T5 Encoder" as UC4

    usecase "Build Multi-View\nVideo Batch" as UC5

    usecase "Run Diffusion\nDenoising Loop\n(MultiviewGeneralDIT)" as UC6

    usecase "Decode Latents to\nVideo Frames\n(CV8x8x8 Tokenizer)" as UC7

    usecase "Validate Generated\nVideo Safety" as UC8

    usecase "Save Multi-View\nGrid Video & Per-Camera\nVideo to Disk" as UC9
}

' ── Actor → Use Case connections ─────────────────────────────────
User      --> UC1
User      --> UC0

Guardrail --> UC3
Guardrail --> UC8

FS        --> UC9

' ── Include / Extend relationships ───────────────────────────────
UC0 ..> UC1 : <<include>>
UC0 ..> UC2 : <<include>>
UC0 ..> UC3 : <<include>>
UC0 ..> UC4 : <<include>>
UC0 ..> UC5 : <<include>>
UC0 ..> UC6 : <<include>>
UC0 ..> UC7 : <<include>>
UC0 ..> UC8 : <<include>>
UC0 ..> UC9 : <<include>>

' Guard ordering notes (extend-style)
UC3 ..> UC4 : <<extend>>\nguard: prompt safe
UC8 ..> UC9 : <<extend>>\nguard: video safe

' Internal data-flow dependencies shown as notes
note right of UC6
  Iterative CFG denoising:
  cond + guidance × (cond − uncond)
  Default: 35 steps, seed-controlled
end note

note right of UC7
  Rearranges latent
  B C (V·T) H W
  → per-view segments
  → 2×3 grid video
end note

note bottom of UC2
  Loads: DiffusionMultiviewT2WModel
  + Cosmos-Tokenize1-CV8x8x8-720p
  + CosmosT5TextEncoder
  + GuardrailSystem (text & video)
end note

@enduml
