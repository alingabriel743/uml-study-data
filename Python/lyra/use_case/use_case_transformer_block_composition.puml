@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7FC1
    FontColor #1A1A2E
    FontSize 12
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    FontSize 11
}
skinparam ArrowColor #495057

title Transformer Block Composition

left to right direction

' ─── Actors ───────────────────────────────────────────────
actor "DIT Network Builder\n(MultiviewGeneralDIT /\nGeneralDIT)" as NetworkBuilder
actor "Inference Runtime" as InferenceRT
actor "Training Runtime" as TrainingRT

' ─── System Boundary ──────────────────────────────────────
rectangle "Transformer Block Composition System" {

    ' --- Construction & Configuration ---
    usecase "Configure Block Sequence\nvia block_config String\n(e.g. 'FA-CA-MLP')" as UC_Config
    usecase "Assemble GeneralDITTransformerBlock\nfrom Ordered DITBuildingBlocks" as UC_Assemble
    usecase "Process Multi-View Inputs\nwith n_views Parameter" as UC_MultiView
    usecase "Support AdaLN-LoRA for\nParameter-Efficient Modulation" as UC_LoRA

    ' --- Forward Pass Orchestration ---
    usecase "Run Forward Pass\nThrough Sequenced Blocks" as UC_Forward

    ' --- Attention Blocks ---
    usecase "Apply Full Self-Attention (FA)\nwith AdaLN Modulation" as UC_FA
    usecase "Apply Cross-Attention (CA) with\nContext Embedding & Optional Mask" as UC_CA
    usecase "Apply MLP Feedforward Block\n(FF/MLP) with AdaLN Modulation" as UC_MLP

    ' --- Normalization & Regularization ---
    usecase "Apply Adaptive Layer Norm (AdaLN)\nShift / Scale / Gate from\nTimestep Embedding" as UC_AdaLN
    usecase "Apply Stochastic Depth\nRegularization via DropPath" as UC_DropPath

    ' --- Positional Embeddings ---
    usecase "Inject Rotary Positional\nEmbedding (RoPE) into\nAttention Blocks" as UC_RoPE
    usecase "Inject Per-Block Absolute\nPositional Embedding" as UC_PosEmb
}

' ─── Actor → Use Case Connections ─────────────────────────
NetworkBuilder --> UC_Config
NetworkBuilder --> UC_Assemble
NetworkBuilder --> UC_MultiView
NetworkBuilder --> UC_LoRA

InferenceRT --> UC_Forward
InferenceRT --> UC_RoPE
InferenceRT --> UC_PosEmb

TrainingRT --> UC_Forward
TrainingRT --> UC_DropPath
TrainingRT --> UC_LoRA

' ─── Include Relationships ────────────────────────────────
UC_Assemble ..> UC_Config       : <<include>>

UC_Forward ..> UC_FA            : <<include>>
UC_Forward ..> UC_CA            : <<include>>
UC_Forward ..> UC_MLP           : <<include>>

UC_FA  ..> UC_AdaLN             : <<include>>
UC_CA  ..> UC_AdaLN             : <<include>>
UC_MLP ..> UC_AdaLN             : <<include>>

UC_FA  ..> UC_RoPE              : <<include>>
UC_CA  ..> UC_RoPE              : <<include>>

UC_FA  ..> UC_DropPath          : <<include>>
UC_CA  ..> UC_DropPath          : <<include>>
UC_MLP ..> UC_DropPath          : <<include>>

' ─── Extend Relationships ─────────────────────────────────
UC_LoRA ..> UC_AdaLN            : <<extend>>
UC_PosEmb ..> UC_Forward        : <<extend>>
UC_MultiView ..> UC_CA          : <<extend>>

@enduml
