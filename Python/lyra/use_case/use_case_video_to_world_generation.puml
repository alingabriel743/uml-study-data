@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF8DC
    BorderColor #CCA800
}

title Video-to-World Generation

left to right direction

' ── Primary Actor ──────────────────────────────────────────────
actor "User" as User

' ── External System Actors ─────────────────────────────────────
actor "T5 Text Encoder\n(CosmosT5TextEncoder)" as T5
actor "Tokenizer / VAE" as VAE
actor "Diffusion DIT\n(MultiviewVideoExtendGeneralDIT)" as DIT
actor "Guardrail" as Guardrail
actor "Prompt Upsampler\n(VLM)" as VLM

' ── System Boundary ────────────────────────────────────────────
rectangle "Video-to-World Generation Pipeline\n(DiffusionVideo2WorldMultiviewGenerationPipeline)" {

    usecase "Generate Multiview\nWorld Video" as UC1
    usecase "Encode Per-View\nText Prompts\n(front / left / right /\nback / back_left / back_right)" as UC2
    usecase "Upsample Prompt\nvia VLM" as UC7
    usecase "Encode Conditioning\nVideo to Latent" as UC3
    usecase "Run Multiview\nDiffusion Denoising\n(35 steps, CFG guidance=7.0)" as UC4
    usecase "Augment Condition\nFrames with Noise" as UC4a
    usecase "Apply Condition\nVideo Mask (indicator)" as UC4b
    usecase "Decode Latent to\nVideo Frames" as UC5
    usecase "Safety Check\n(Guardrail)" as UC6

}

' ── User interactions ─────────────────────────────────────────
User --> UC1 : submit conditioning video\n+ per-view prompt dict
UC1 ..> UC2  : <<include>>
UC1 ..> UC3  : <<include>>
UC1 ..> UC4  : <<include>>
UC1 ..> UC5  : <<include>>
UC1 <.. UC6  : <<extend>>\n[optional]
UC1 <.. UC7  : <<extend>>\n[optional]

' ── Sub-steps inside denoising ───────────────────────────────
UC4 ..> UC4a : <<include>>
UC4 ..> UC4b : <<include>>

' ── System actor associations ────────────────────────────────
T5        --> UC2
VAE       --> UC3
VAE       --> UC5
DIT       --> UC4
Guardrail --> UC6
VLM       --> UC7

' ── Output note ───────────────────────────────────────────────
note bottom of UC1
  Returns: (video np.ndarray [T, H, W, C] uint8,
            prompt dict)
  Resolution: 704 × 1280 @ 24 fps
  Views: 6 (front, left, right, back, back_left, back_right)
  Frames: 121 per view
end note

note right of UC3
  Latent layout:
  B,C,(V*T),H,W rearranged
  to (B*V),C,T,H,W for
  per-view tokenizer ops
end note

note right of UC4
  Scheduler iterates 35 timesteps.
  Each step: noise augmentation on
  condition frames + CFG forward pass
  through MultiviewVideoExtendGeneralDIT
  (extra input channel for condition mask)
end note

@enduml
