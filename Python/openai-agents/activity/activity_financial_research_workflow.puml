@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #856404
    BarColor #495057
}
skinparam swimlane {
    BorderColor #6C757D
    TitleBackgroundColor #E9ECEF
    TitleFontColor #212529
    TitleFontSize 13
}
skinparam noteBackgroundColor #E8F4FD
skinparam noteBorderColor #4A90D9

title Financial Research Agent Workflow

|#E8F4F8|FinancialResearchManager|
start
:Receive user research **query**;
note right
  Entry point: FinancialResearchManager.run(query)
  Code-orchestrated pipeline — deterministic order
end note
:Generate trace ID\nWrap execution in trace\n**"Financial research trace"**;
note right
  Trace ID published to OpenAI platform
  for end-to-end observability
end note

|#FFF8E1|FinancialPlannerAgent\n(model: o3-mini)|
:Invoke planner agent\nRunner.run(planner_agent, "Query: {query}");
:Generate **FinancialSearchPlan**\n(5–15 FinancialSearchItem entries);
note right
  Each item contains:
  • reason: why this search is needed
  • query: specific search term
  Covers: recent news, earnings calls,
  10-K filings, analyst commentary,
  industry background
end note

|#E8F4F8|FinancialResearchManager|
:Dispatch all search tasks concurrently\n(asyncio.create_task per FinancialSearchItem)\nwrapped in custom_span("Search the web");

fork
  |#E8F8E8|FinancialSearchAgent [Task 1]\n(model: gpt-5.4 + WebSearchTool)|
  :Runner.run(search_agent,\n"Search term: {query}\\nReason: {reason}");
  if (Search succeeded?) then (yes)
    :Return **str summary**\n(≤ 300 words);
  else (no / exception)
    :Return **None**\n(increment num_failed);
  endif
fork again
  |#E8F8E8|FinancialSearchAgent [Task N]\n(model: gpt-5.4 + WebSearchTool)|
  :Runner.run(search_agent,\n"Search term: {query}\\nReason: {reason}");
  if (Search succeeded?) then (yes)
    :Return **str summary**\n(≤ 300 words);
  else (no / exception)
    :Return **None**\n(increment num_failed);
  endif
end fork

|#E8F4F8|FinancialResearchManager|
:Collect non-None summaries\nvia asyncio.as_completed\n→ list[str] **search_results**;
note right
  Tracks num_succeeded / num_failed
  across all concurrent search tasks
end note

:Prepare writer input\n(query + all search_results);

|#F3E8FF|FundamentalsAnalystAgent\n(as tool: 'fundamentals_analysis')|
note left
  Registered via agent.as_tool()
  with custom_output_extractor
  (_summary_extractor bridges
  AnalysisSummary → plain string)
end note
:Analyse key financial metrics\n(revenue, profit, margins, growth);
:Return **AnalysisSummary**;

|#FFE8F0|RiskAnalystAgent\n(as tool: 'risk_analysis')|
note left
  Registered via agent.as_tool()
  with custom_output_extractor
  Invoked inline during streaming
  if writer decides it is needed
end note
:Analyse competitive threats,\nregulatory & supply-chain risks;
:Return **AnalysisSummary**;

|#FFF0E0|FinancialWriterAgent\n(model: gpt-5.4, streamed)|
:Runner.run_streamed(\nwriter_with_tools, input_data);
note right
  Writer cloned with specialist tools:
  • fundamentals_analysis tool
  • risk_analysis tool
  Streaming printer updates every 5s:
  "Planning report structure..."
  "Writing sections..."
  "Finalizing report..."
end note
if (Fundamentals data needed?) then (yes)
  :Call **fundamentals_analysis** tool\n(FundamentalsAnalystAgent);
endif
if (Risk data needed?) then (yes)
  :Call **risk_analysis** tool\n(RiskAnalystAgent);
endif
:Synthesise **FinancialReportData**\n{short_summary,\nmarkdown_report,\nfollow_up_questions[]};

|#FFE8E8|VerificationAgent\n(model: gpt-5.4)|
:Runner.run(verifier_agent,\nreport.markdown_report);
:Audit report for\ninternal consistency,\nsourcing & unsupported claims;
:Return **VerificationResult**\n{verified: bool, issues: str};

|#E8F4F8|FinancialResearchManager|
if (Report verified?) then (verified = true)
  :Print **REPORT** section\n(markdown_report);
else (verified = false)
  :Print **REPORT** section\n+ flag verification issues;
  note right
    issues string populated
    with specific problems found
  end note
endif
:Print **FOLLOW UP QUESTIONS**\n(follow_up_questions[]);
:Print **VERIFICATION** result\n(verified status + issues);
stop

@enduml
