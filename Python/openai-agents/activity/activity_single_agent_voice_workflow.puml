@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
    DiamondBackgroundColor #E9ECEF
    DiamondBorderColor #6C757D
    StartColor #212529
    EndColor #212529
}

skinparam swimlane {
    BorderColor #6C757D
    TitleFontColor #212529
    TitleFontSize 13
    BackgroundColor #FEFEFE
}

skinparam noteBackgroundColor #FFF9C4
skinparam noteBorderColor #F0AD4E

title Single Agent Voice Workflow\n<size:11>Voice workflow run: receive transcript, invoke agent run, stream response tokens back to caller</size>

|VoicePipeline|
start

:Receive STT transcription: str\n(speech-to-text output from caller);

|SingleAgentVoiceWorkflow|

note right
  **State maintained across turns:**
  • _input_history: list[TResponseInputItem]
  • _current_agent: Agent (mutable via handoffs)
  • _callbacks: SingleAgentWorkflowCallbacks | None
end note

if (_callbacks is not None?) then (yes)
    :Call _callbacks.on_run(self, transcription)\n<size:10>[optional hook: log, modify, or observe the run]</size>;
else (no)
    :Skip callback;
endif

:Append {role: "user", content: transcription}\nto _input_history\n<size:10>[persists multi-turn conversation context]</size>;

|Runner|

:Runner.run_streamed(_current_agent, _input_history)\n→ returns RunResultStreaming result\n<size:10>[initiates async streamed LLM call]</size>;

note right
  **RunResultStreaming** opens an
  async event stream from the model.
  Stream is not complete until
  stream_events() iterator is exhausted.
end note

|VoiceWorkflowHelper|

:Iterate result.stream_events()\nvia VoiceWorkflowHelper.stream_text_from(result);

repeat
    :Receive next StreamEvent;
    if (event.type == "raw_response_event"\nAND event.data.type == "response.output_text.delta"?) then (yes)
        :Extract event.data.delta\n(text token / chunk);

        |VoicePipeline|
        :yield text chunk to caller\n<size:10>[streamed incrementally for real-time TTS]</size>;

        |VoiceWorkflowHelper|
    else (no)
        :Discard event\n<size:10>[tool calls, metadata, handoff events,\nagent_updated events — all excluded from TTS]</size>;
    endif
repeat while (More stream events?) is (yes)
-> no (stream exhausted);

|SingleAgentVoiceWorkflow|

:Update _input_history = result.to_input_list()\n<size:10>[replace history with fully normalised turn output]</size>;

if (result.last_agent != _current_agent?) then (yes — handoff occurred)
    :_current_agent = result.last_agent\n<size:10>[transparent agent handoff: next turn starts\nwith the handed-off agent]</size>;

    note right
      Agent handoffs are transparent to the
      VoicePipeline. The workflow silently
      swaps _current_agent after each turn.
    end note
else (no — same agent)
    :_current_agent unchanged;
endif

|VoicePipeline|

:Receive complete streamed response\n→ feed to TTS model for audio synthesis;

stop

@enduml
