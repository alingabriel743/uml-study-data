@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam partition {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #33270A
}

title Voice Pipeline: Single vs Multi-Turn Execution

|VoicePipeline|
start
:VoicePipeline.run(audio_input);
note right
  Accepts either:
  • AudioInput — static buffer (single-turn)
  • StreamedAudioInput — live stream (multi-turn)
end note

:Resolve STT/TTS models lazily\nvia VoicePipelineConfig.model_provider;

if (audio_input type?) then ([AudioInput] — Single-Turn)

  |StreamedAudioResult|
  :Create StreamedAudioResult\n(tts_model, tts_settings, config);

  |VoicePipeline|
  :asyncio.create_task(stream_events());
  note right
    StreamedAudioResult is returned to the caller
    immediately. Audio synthesis + streaming
    runs entirely in a background asyncio.Task.
  end note

  :Enter TraceCtxManager\n(workflow_name, trace_id=auto-generated,\ngroup_id, metadata);

  |STTModel|
  :STTModel.transcribe(\n  audio_input,\n  stt_settings,\n  trace_include_sensitive_data,\n  trace_include_sensitive_audio_data\n) → input_text : str;

  |VoiceWorkflow|
  :workflow.run(input_text)\n[e.g. SingleAgentVoiceWorkflow];
  :callbacks.on_run(self, transcription)\n[if SingleAgentWorkflowCallbacks present];
  :Append { role: "user", content: transcription }\nto _input_history;
  :Runner.run_streamed(\n  _current_agent, _input_history\n) → RunResultStreaming;
  :VoiceWorkflowHelper.stream_text_from(result)\nFilter: raw_response_event /\nresponse.output_text.delta\n→ yield text chunk;
  :_input_history = result.to_input_list();
  :_current_agent = result.last_agent;

  |StreamedAudioResult|
  :output._add_text(text_event)\n[for each streamed chunk];
  :output._turn_done();
  :output._done();

  |VoicePipeline|
  note right
    On exception:
    logger.error() →
    output._add_error(e) →
    re-raise
  end note

elseif ([StreamedAudioInput] — Multi-Turn?) then (yes)

  |StreamedAudioResult|
  :Create StreamedAudioResult\n(tts_model, tts_settings, config);

  |VoicePipeline|
  :asyncio.create_task(process_turns());
  note right
    StreamedAudioResult is returned to the caller
    immediately. Turn processing runs entirely
    in a background asyncio.Task.
  end note

  :Enter TraceCtxManager\n(workflow_name, trace_id=auto-generated,\ngroup_id, metadata);

  |VoiceWorkflow|
  :workflow.on_start()\n[optional: yield greeting / intro text];
  note right
    on_start() failure is caught and
    logged as a warning — execution
    continues to transcription loop.
  end note

  |StreamedAudioResult|
  :output._add_text(intro_text)\n[for each intro chunk yielded by on_start()];

  |STTModel|
  :STTModel.create_session(\n  audio_input, stt_settings,\n  trace_include_sensitive_data,\n  trace_include_sensitive_audio_data\n) → TranscriptionSession;

  :transcription_session.transcribe_turns()\n[async iterator: one input_text per spoken turn];

  |VoicePipeline|
  repeat

    |VoiceWorkflow|
    :workflow.run(input_text)\n[SingleAgentVoiceWorkflow];
    :callbacks.on_run(self, transcription)\n[if callbacks present];
    :Append { role: "user", content: transcription }\nto _input_history;
    :Runner.run_streamed(\n  _current_agent, _input_history\n) → RunResultStreaming;
    :VoiceWorkflowHelper.stream_text_from(result)\nFilter: raw_response_event /\nresponse.output_text.delta\n→ yield text chunk;
    :_input_history = result.to_input_list();
    note right
      Conversation history persists across
      turns — the full prior context is
      replayed to the LLM each turn.
    end note
    :_current_agent = result.last_agent;
    note right
      Supports agent handoffs:
      a different agent may handle
      subsequent turns transparently.
    end note

    |StreamedAudioResult|
    :output._add_text(text_event)\n[for each streamed chunk];
    :output._turn_done();

    |VoicePipeline|

  repeat while (next turn from\ntranscribe_turns()?) is (yes — more audio)
  ->no (async iterator exhausted\n[stream closed]);

  note right
    On exception:
    logger.error() →
    output._add_error(e) →
    re-raise
  end note

  :transcription_session.close()\n[finally block — always executed];

  |StreamedAudioResult|
  :output._done()\n[finally block — always executed];

  |VoicePipeline|

else ([unsupported type])

  #FFB3B3:raise UserError\n("Unsupported audio input type: <type>");
  stop

endif

:Return StreamedAudioResult\n(background task is running);
note right
  Caller streams audio events from
  StreamedAudioResult while the pipeline
  task synthesises and enqueues TTS audio.
end note

stop

@enduml
