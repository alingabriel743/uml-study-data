{
  "scope": "realtime_websocket_session",
  "title": "Realtime WebSocket Session",
  "diagram_type": "activity",
  "source_files_analyzed": [
    "examples/realtime/app/server.py",
    "src/agents/realtime/session.py",
    "docs/realtime/guide.md"
  ],
  "key_participants": [
    "Client (Browser/App)",
    "FastAPI WebSocket Endpoint /ws/{session_id}",
    "RealtimeWebSocketManager",
    "RealtimeRunner",
    "RealtimeSession",
    "RealtimeModel (OpenAIRealtimeWebSocketModel)"
  ],
  "activity_flow": [
    "START: Client opens WebSocket to /ws/{session_id}",
    "websocket_endpoint calls manager.connect(websocket, session_id)",
    "  → websocket.accept()",
    "  → get_starting_agent() → RealtimeAgent",
    "  → RealtimeRunner(agent) created with optional RealtimeRunConfig",
    "  → runner.run(model_config) → session_context (async context manager)",
    "  → session = await session_context.__aenter__() → RealtimeSession",
    "  → store in active_sessions[session_id], session_contexts[session_id], websockets[session_id]",
    "  → asyncio.create_task(_process_events(session_id))",
    "PARALLEL: _process_events loop starts concurrently",
    "  → async for event in session: (iterates session.__aiter__())",
    "    → _serialize_event(event) → dict",
    "    → websocket.send_text(json.dumps(event_data))",
    "    Event types handled: agent_start, agent_end, handoff, tool_start, tool_end,",
    "      tool_approval_required, audio, audio_interrupted, audio_end,",
    "      history_updated, history_added, guardrail_tripped, raw_model_event,",
    "      error, input_audio_timeout_triggered",
    "MAIN LOOP: while True → data = await websocket.receive_text()",
    "  → message = json.loads(data)",
    "  BRANCH on message['type']:",
    "  [audio]",
    "    → pack int16 array to bytes via struct.pack()",
    "    → manager.send_audio(session_id, audio_bytes)",
    "      → session.send_audio(audio_bytes)",
    "        → model.send_event(RealtimeModelSendAudio(audio, commit=False))",
    "  [image]",
    "    → extract data_url and prompt_text",
    "    → build RealtimeUserInputMessage with input_image + input_text content",
    "    → manager.send_user_message(session_id, user_msg)",
    "      → session.send_message(user_msg)",
    "        → model.send_event(RealtimeModelSendUserInput(user_input=message))",
    "    → websocket.send_text({type: client_info, info: image_enqueued})",
    "  [commit_audio]",
    "    → manager.send_client_event(session_id, {type: input_audio_buffer.commit})",
    "      → session.model.send_event(RealtimeModelSendRawMessage(message={type, other_data}))",
    "  [image_start]",
    "    → initialize image_buffers[img_id] = {text, chunks:[]}",
    "    → websocket.send_text({type: client_info, info: image_start_ack})",
    "  [image_chunk]",
    "    → append chunk to image_buffers[img_id]['chunks']",
    "    → every 10 chunks: websocket.send_text(image_chunk_ack)",
    "  [image_end]",
    "    → pop image_buffers[img_id]",
    "    → join chunks to data_url",
    "    → build RealtimeUserInputMessage and manager.send_user_message()",
    "    → websocket.send_text({type: client_info, info: image_enqueued})",
    "  [tool_approval_decision]",
    "    → extract call_id, approve, always flags",
    "    → GUARD: if no call_id → send error, continue",
    "    → IF approve == True:",
    "        → manager.approve_tool_call(session_id, call_id, always=always)",
    "          → session.approve_tool_call(call_id, always=always)",
    "            → pop from _pending_tool_calls",
    "            → context_wrapper.approve_tool(approval_item, always_approve=always)",
    "            → IF async_tool_calls: _enqueue_tool_call_task()",
    "               ELSE: await _handle_tool_call()",
    "    → IF approve == False:",
    "        → manager.reject_tool_call(session_id, call_id, always=always)",
    "          → session.reject_tool_call(call_id, always=always)",
    "            → pop from _pending_tool_calls",
    "            → send REJECTION_MESSAGE as tool output to model",
    "  [interrupt]",
    "    → manager.interrupt(session_id)",
    "      → session.interrupt()",
    "        → model.send_event(RealtimeModelSendInterrupt())",
    "EXCEPTION: WebSocketDisconnect",
    "  → manager.disconnect(session_id)",
    "    → session_contexts[session_id].__aexit__(None, None, None)",
    "    → del from session_contexts, active_sessions, websockets",
    "END"
  ],
  "key_conditions": [
    "message['type'] == 'audio' → send raw PCM16 audio bytes",
    "message['type'] == 'image' → single-shot image (data_url present/absent)",
    "message['type'] == 'image_start/chunk/end' → chunked image assembly",
    "message['type'] == 'commit_audio' → force close audio turn",
    "message['type'] == 'tool_approval_decision' AND approve == True → approve",
    "message['type'] == 'tool_approval_decision' AND approve == False → reject",
    "message['type'] == 'interrupt' → stop current model response",
    "session._async_tool_calls → enqueue vs await tool execution after approval",
    "_pending_tool_calls.pop(call_id) returns None → early return (no-op)",
    "WebSocketDisconnect → disconnect and cleanup"
  ],
  "key_data_structures": {
    "RealtimeWebSocketManager.active_sessions": "dict[session_id, RealtimeSession]",
    "RealtimeWebSocketManager.session_contexts": "dict[session_id, async context manager]",
    "RealtimeWebSocketManager.websockets": "dict[session_id, WebSocket]",
    "RealtimeSession._event_queue": "asyncio.Queue[RealtimeSessionEvent]",
    "RealtimeSession._pending_tool_calls": "dict[call_id, tuple(ToolCallEvent, Agent, FunctionTool, ToolApprovalItem)]",
    "RealtimeSession._history": "list[RealtimeItem]",
    "image_buffers": "dict[img_id, {text, chunks:[]}] — local to websocket_endpoint"
  },
  "session_events_emitted": [
    "agent_start → {type, agent.name}",
    "agent_end → {type, agent.name}",
    "handoff → {type, from, to}",
    "tool_start → {type, tool.name}",
    "tool_end → {type, tool.name, output}",
    "tool_approval_required → {type, tool.name, call_id, arguments, agent.name}",
    "audio → {type, audio: base64}",
    "audio_interrupted → {type}",
    "audio_end → {type}",
    "history_updated → {type, history: sanitized items}",
    "history_added → {type, item: sanitized}",
    "guardrail_tripped → {type, guardrail_results: [{name}]}",
    "raw_model_event → {type, raw_model_event: {type}}",
    "error → {type, error: str}",
    "input_audio_timeout_triggered → {type}"
  ],
  "model_config_defaults": {
    "model_name": "gpt-realtime-1.5",
    "turn_detection": "server_vad",
    "prefix_padding_ms": 300,
    "silence_duration_ms": 500,
    "interrupt_response": true,
    "create_response": true
  },
  "important_notes": [
    "_process_events runs as a background asyncio task, concurrent with main receive loop",
    "Audio sanitization: _sanitize_history_item strips audio/input_audio binary payloads, keeps transcripts",
    "always=True flag on approve/reject permanently allows/blocks that tool for the session",
    "Tool approval pauses tool execution until approve_tool_call or reject_tool_call is called",
    "session.__aiter__ checks _stored_exception before yielding, calls _cleanup if set",
    "Chunked image upload uses image_start/image_chunk/image_end handshake with ACKs every 10 chunks",
    "FastAPI WebSocket max frame size is 16MB (ws_max_size=16*1024*1024) to handle image data URLs",
    "RealtimeSession implements RealtimeModelListener (observer pattern for model events)"
  ]
}
