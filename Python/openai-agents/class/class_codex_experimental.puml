@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Experimental – Codex

' ═══════════════════════════════════════════════════════
'  CORE
' ═══════════════════════════════════════════════════════
package "codex — core" {

    class Codex {
        -_exec: CodexExec
        -_options: CodexOptions
        +__init__(options, codex_path_override, base_url, ...)
        +start_thread(options: ThreadOptions): Thread
        +resume_thread(thread_id: str, options: ThreadOptions): Thread
    }

    class Thread {
        -_exec: CodexExec
        -_options: CodexOptions
        -_id: str | None
        -_thread_options: ThreadOptions
        +id: str | None
        +run(input, turn_options: TurnOptions): Turn
        +run_streamed(input, turn_options: TurnOptions): StreamedTurn
        -_run_streamed_internal(input, turn_options): AsyncGenerator
    }

    class CodexExec {
        -_executable_path: str
        -_env_override: dict | None
        -_subprocess_stream_limit_bytes: int
        +run(args: CodexExecArgs): AsyncGenerator
        -_build_env(args: CodexExecArgs): dict
    }

    class CodexExecArgs <<frozen dataclass>> {
        +input: str
        +base_url: str | None
        +api_key: str | None
        +thread_id: str | None
        +model: str | None
        +sandbox_mode: SandboxMode | None
        +working_directory: str | None
        +additional_directories: list | None
        +output_schema_file: str | None
        +signal: asyncio.Event | None
        +idle_timeout_seconds: float | None
        +approval_policy: ApprovalMode | None
        +model_reasoning_effort: ModelReasoningEffort | None
        +network_access_enabled: bool | None
        +web_search_mode: WebSearchMode | None
    }

    class Turn <<frozen dataclass>> {
        +items: list[ThreadItem]
        +final_response: str
        +usage: Usage | None
    }

    class StreamedTurn <<frozen dataclass>> {
        +events: AsyncGenerator[ThreadEvent]
    }
}

' ═══════════════════════════════════════════════════════
'  OPTIONS
' ═══════════════════════════════════════════════════════
package "codex — options" {

    class CodexOptions <<frozen dataclass>> {
        +codex_path_override: str | None
        +base_url: str | None
        +api_key: str | None
        +env: Mapping | None
        +codex_subprocess_stream_limit_bytes: int | None
    }

    class ThreadOptions <<frozen dataclass>> {
        +model: str | None
        +sandbox_mode: SandboxMode | None
        +working_directory: str | None
        +skip_git_repo_check: bool | None
        +model_reasoning_effort: ModelReasoningEffort | None
        +network_access_enabled: bool | None
        +web_search_mode: WebSearchMode | None
        +web_search_enabled: bool | None
        +approval_policy: ApprovalMode | None
        +additional_directories: Sequence[str] | None
    }

    class TurnOptions <<frozen dataclass>> {
        +output_schema: dict | None
        +signal: asyncio.Event | None
        +idle_timeout_seconds: float | None
    }

    note bottom of ThreadOptions
        SandboxMode: read-only | workspace-write | danger-full-access
        ApprovalMode: never | on-request | on-failure | untrusted
    end note
}

' ═══════════════════════════════════════════════════════
'  EVENTS
' ═══════════════════════════════════════════════════════
package "codex — events" {

    abstract class _DictLike {
        +__getitem__(key: str): Any
        +get(key: str, default): Any
        +__contains__(key): bool
        +keys(): Iterable[str]
        +as_dict(): dict
        #_field_names(): list[str]
    }

    class Usage <<frozen dataclass>> {
        +input_tokens: int
        +cached_input_tokens: int
        +output_tokens: int
    }

    class ThreadError <<frozen dataclass>> {
        +message: str
    }

    class ThreadStartedEvent <<frozen dataclass>> {
        +thread_id: str
        +type: Literal[thread.started]
    }

    class TurnStartedEvent <<frozen dataclass>> {
        +type: Literal[turn.started]
    }

    class TurnCompletedEvent <<frozen dataclass>> {
        +usage: Usage | None
        +type: Literal[turn.completed]
    }

    class TurnFailedEvent <<frozen dataclass>> {
        +error: ThreadError
        +type: Literal[turn.failed]
    }

    class ItemStartedEvent <<frozen dataclass>> {
        +item: ThreadItem
        +type: Literal[item.started]
    }

    class ItemUpdatedEvent <<frozen dataclass>> {
        +item: ThreadItem
        +type: Literal[item.updated]
    }

    class ItemCompletedEvent <<frozen dataclass>> {
        +item: ThreadItem
        +type: Literal[item.completed]
    }

    class ThreadErrorEvent <<frozen dataclass>> {
        +message: str
        +type: Literal[error]
    }
}

' ═══════════════════════════════════════════════════════
'  ITEMS
' ═══════════════════════════════════════════════════════
package "codex — items" {

    class AgentMessageItem <<frozen dataclass>> {
        +id: str
        +text: str
        +type: Literal[agent_message]
    }

    class ReasoningItem <<frozen dataclass>> {
        +id: str
        +text: str
        +type: Literal[reasoning]
    }

    class CommandExecutionItem <<frozen dataclass>> {
        +id: str
        +command: str
        +status: CommandExecutionStatus
        +aggregated_output: str
        +exit_code: int | None
        +type: Literal[command_execution]
    }

    class FileChangeItem <<frozen dataclass>> {
        +id: str
        +changes: list[FileUpdateChange]
        +status: PatchApplyStatus
        +type: Literal[file_change]
    }

    class FileUpdateChange <<frozen dataclass>> {
        +path: str
        +kind: PatchChangeKind
    }

    class McpToolCallItem <<frozen dataclass>> {
        +id: str
        +server: str
        +tool: str
        +arguments: Any
        +status: McpToolCallStatus
        +result: McpToolCallResult | None
        +error: McpToolCallError | None
        +type: Literal[mcp_tool_call]
    }

    class WebSearchItem <<frozen dataclass>> {
        +id: str
        +query: str
        +type: Literal[web_search]
    }

    class TodoListItem <<frozen dataclass>> {
        +id: str
        +items: list[TodoItem]
        +type: Literal[todo_list]
    }

    class ErrorItem <<frozen dataclass>> {
        +id: str
        +message: str
        +type: Literal[error]
    }
}

' ═══════════════════════════════════════════════════════
'  TOOL INTEGRATION
' ═══════════════════════════════════════════════════════
package "codex — tool" {

    class CodexToolOptions <<dataclass>> {
        +name: str | None
        +description: str | None
        +parameters: type[BaseModel] | None
        +output_schema: OutputSchemaDescriptor | None
        +codex: Codex | None
        +codex_options: CodexOptions | None
        +default_thread_options: ThreadOptions | None
        +thread_id: str | None
        +sandbox_mode: SandboxMode | None
        +working_directory: str | None
        +default_turn_options: TurnOptions | None
        +span_data_max_chars: int = 8192
        +persist_session: bool = False
        +use_run_context_thread_id: bool = False
        +run_context_thread_id_key: str | None
        +on_stream: Callable | None
        +is_enabled: bool | Callable = True
    }

    class CodexToolResult <<frozen dataclass>> {
        +thread_id: str | None
        +response: str
        +usage: Usage | None
        +as_dict(): dict
        +__str__(): str
    }

    class CodexToolStreamEvent <<frozen dataclass>> {
        +event: ThreadEvent
        +thread: Thread
        +tool_call: Any
    }

    class CodexToolParameters <<Pydantic BaseModel>> {
        +inputs: list[CodexToolInputItem]
        +thread_id: str | None
        +validate_thread_id(): CodexToolParameters
    }

    class CodexToolRunContextParameters <<Pydantic BaseModel>> {
        +inputs: list[CodexToolInputItem]
    }

    class CodexToolInputItem <<Pydantic BaseModel>> {
        +type: Literal[text, local_image]
        +text: str | None
        +path: str | None
        +validate_item(): CodexToolInputItem
    }

    class OutputSchemaDescriptor <<TypedDict>> {
        +title: str
        +description: str
        +properties: list[OutputSchemaPropertyDescriptor]
        +required: list[str]
    }

    note right of CodexToolOptions
        codex_tool() factory wraps Codex
        as an agents.tool.FunctionTool.
        persist_session=True reuses a single
        Thread across tool calls.
        use_run_context_thread_id=True stores
        thread_id in RunContextWrapper under
        key "codex_thread_id" (default).
    end note
}

' ═══════════════════════════════════════════════════════
'  RELATIONSHIPS — CORE
' ═══════════════════════════════════════════════════════
Codex *-- CodexExec       : _exec
Codex *-- CodexOptions    : _options
Codex ..> Thread          : creates >

Thread *-- CodexExec      : _exec
Thread *-- CodexOptions   : _options
Thread *-- ThreadOptions  : _thread_options
Thread ..> Turn           : aggregates into >
Thread ..> StreamedTurn   : wraps events into >
Thread ..> CodexExecArgs  : builds >

CodexExec ..> CodexExecArgs : uses >

Turn o-- Usage            : usage

' ═══════════════════════════════════════════════════════
'  RELATIONSHIPS — EVENTS (_DictLike inheritance)
' ═══════════════════════════════════════════════════════
Usage              --|> _DictLike
ThreadError        --|> _DictLike
ThreadStartedEvent --|> _DictLike
TurnStartedEvent   --|> _DictLike
TurnCompletedEvent --|> _DictLike
TurnFailedEvent    --|> _DictLike
ItemStartedEvent   --|> _DictLike
ItemUpdatedEvent   --|> _DictLike
ItemCompletedEvent --|> _DictLike
ThreadErrorEvent   --|> _DictLike

TurnCompletedEvent o-- Usage       : usage
TurnFailedEvent    *-- ThreadError : error

' ═══════════════════════════════════════════════════════
'  RELATIONSHIPS — ITEMS (_DictLike inheritance)
' ═══════════════════════════════════════════════════════
AgentMessageItem    --|> _DictLike
ReasoningItem       --|> _DictLike
CommandExecutionItem--|> _DictLike
FileChangeItem      --|> _DictLike
McpToolCallItem     --|> _DictLike
WebSearchItem       --|> _DictLike
TodoListItem        --|> _DictLike
ErrorItem           --|> _DictLike

FileChangeItem *-- FileUpdateChange : changes

' ═══════════════════════════════════════════════════════
'  RELATIONSHIPS — TOOL INTEGRATION
' ═══════════════════════════════════════════════════════
CodexToolOptions o-- Codex              : codex
CodexToolOptions o-- CodexOptions       : codex_options
CodexToolOptions o-- ThreadOptions      : default_thread_options
CodexToolOptions o-- TurnOptions        : default_turn_options
CodexToolOptions o-- OutputSchemaDescriptor : output_schema

CodexToolResult o-- Usage              : usage

CodexToolStreamEvent o-- Thread        : thread

CodexToolParameters          *-- CodexToolInputItem : inputs
CodexToolRunContextParameters *-- CodexToolInputItem : inputs

' ═══════════════════════════════════════════════════════
'  NOTES
' ═══════════════════════════════════════════════════════
note bottom of Codex
    Main entry point for the Codex agent extension.
    Creates and resumes Thread instances.
    Wraps CodexExec and global CodexOptions.
end note

note bottom of Thread
    Captures thread_id from the first
    ThreadStartedEvent so callers can resume later.
    run() collects all events into a Turn.
    run_streamed() yields a StreamedTurn with
    an AsyncGenerator[ThreadEvent].
end note

note bottom of CodexExec
    Launches subprocess:
      codex exec --experimental-json
    Streams JSONL output line by line.
    Default stream limit: 8 MiB
    (env: OPENAI_AGENTS_CODEX_SUBPROCESS_STREAM_LIMIT_BYTES)
end note

@enduml
