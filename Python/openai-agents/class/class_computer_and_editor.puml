@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #FFF3CD
    BorderColor #856404
}
skinparam note {
    BackgroundColor #E8F4FD
    BorderColor #4A90D9
}

title Computer & Editor Tools

' ─── External / shared types ────────────────────────────────────────────────
package "External Types" <<Frame>> {
    class RunContextWrapper<TContext> {
        +context: TContext
    }
    class Agent<TOutput> {
        +name: str
    }
    class ResponsePromptParam {
    }
}

' ─── agents.computer ─────────────────────────────────────────────────────────
package "agents.computer" {

    class "«enumeration»\nEnvironment" as Environment {
        mac
        windows
        ubuntu
        browser
    }

    class "«enumeration»\nButton" as Button {
        left
        right
        wheel
        back
        forward
    }

    abstract class Computer {
        +environment: Environment | None
        +dimensions: tuple[int, int] | None
        --
        +{abstract} screenshot(): str
        +{abstract} click(x: int, y: int, button: Button): None
        +{abstract} double_click(x: int, y: int): None
        +{abstract} scroll(x: int, y: int, scroll_x: int, scroll_y: int): None
        +{abstract} type(text: str): None
        +{abstract} wait(): None
        +{abstract} move(x: int, y: int): None
        +{abstract} keypress(keys: list[str]): None
        +{abstract} drag(path: list[tuple[int, int]]): None
    }

    abstract class AsyncComputer {
        +environment: Environment | None
        +dimensions: tuple[int, int] | None
        --
        +{abstract} screenshot(): Awaitable[str]
        +{abstract} click(x: int, y: int, button: Button): Awaitable[None]
        +{abstract} double_click(x: int, y: int): Awaitable[None]
        +{abstract} scroll(x: int, y: int, scroll_x: int, scroll_y: int): Awaitable[None]
        +{abstract} type(text: str): Awaitable[None]
        +{abstract} wait(): Awaitable[None]
        +{abstract} move(x: int, y: int): Awaitable[None]
        +{abstract} keypress(keys: list[str]): Awaitable[None]
        +{abstract} drag(path: list[tuple[int, int]]): Awaitable[None]
    }
}

note right of Computer
  Sync abstract base for computer-use.
  Subclasses back <b>ComputerTool</b>.
  Mouse methods may accept keyword-only
  'keys' for modifier keys.
end note

note right of AsyncComputer
  Async mirror of Computer.
  All methods are coroutines.
end note

' ─── agents.editor ───────────────────────────────────────────────────────────
package "agents.editor" {

    class "«enumeration»\nApplyPatchOperationType" as ApplyPatchOperationType {
        create_file
        update_file
        delete_file
    }

    class ApplyPatchOperation <<dataclass>> {
        +type: ApplyPatchOperationType
        +path: str
        +diff: str | None = None
        +ctx_wrapper: RunContextWrapper | None = None
        +move_to: str | None = None
    }

    class ApplyPatchResult <<dataclass>> {
        +status: Literal['completed', 'failed'] | None = None
        +output: str | None = None
    }

    interface ApplyPatchEditor <<Protocol, runtime_checkable>> {
        +create_file(operation: ApplyPatchOperation): MaybeAwaitable[ApplyPatchResult | str | None]
        +update_file(operation: ApplyPatchOperation): MaybeAwaitable[ApplyPatchResult | str | None]
        +delete_file(operation: ApplyPatchOperation): MaybeAwaitable[ApplyPatchResult | str | None]
    }
}

note bottom of ApplyPatchEditor
  @runtime_checkable Protocol.
  Implementations can be duck-typed
  without explicit inheritance.
  Supports sync and async via
  <b>MaybeAwaitable</b>.
end note

' ─── agents.apply_diff ───────────────────────────────────────────────────────
package "agents.apply_diff" {

    class Chunk <<dataclass>> {
        +orig_index: int
        +del_lines: list[str]
        +ins_lines: list[str]
    }

    class ParserState <<dataclass>> {
        +lines: list[str]
        +index: int = 0
        +fuzz: int = 0
    }

    class ParsedUpdateDiff <<dataclass>> {
        +chunks: list[Chunk]
        +fuzz: int
    }

    class ReadSectionResult <<dataclass>> {
        +next_context: list[str]
        +section_chunks: list[Chunk]
        +end_index: int
        +eof: bool
    }

    class ContextMatch <<dataclass>> {
        +new_index: int
        +fuzz: int
    }

    class "«module functions»\napply_diff" as ApplyDiffFunctions {
        +apply_diff(input: str, diff: str, mode: ApplyDiffMode): str
        -_parse_create_diff(lines, newline): list[str]
        -_parse_update_diff(lines, input): ParsedUpdateDiff
        -_apply_chunks(input, chunks, newline): str
        -_find_context(lines, context, start, eof): ContextMatch
        -_read_section(lines, start_index): ReadSectionResult
    }
}

note bottom of ApplyDiffFunctions
  V4A diff format with '@@' anchors,
  '+'/'-'/' ' line prefixes.
  3-tier fuzzy context matching:
  exact → rstrip → strip (tracked as fuzz score).
end note

' ─── agents.prompts ──────────────────────────────────────────────────────────
package "agents.prompts" {

    class Prompt <<TypedDict>> {
        +id: str
        +version: str  «NotRequired»
        +variables: dict[str, Variables]  «NotRequired»
    }

    class GenerateDynamicPromptData <<dataclass>> {
        +context: RunContextWrapper[Any]
        +agent: Agent[Any]
    }

    class PromptUtil {
        +{static} to_model_input(prompt: Prompt | DynamicPromptFunction | None,\n  context: RunContextWrapper[Any],\n  agent: Agent[Any]): Awaitable[ResponsePromptParam | None]
    }
}

note right of Prompt
  Configuration for OpenAI model prompt.
  <b>DynamicPromptFunction</b> is a
  Callable[[GenerateDynamicPromptData],
  MaybeAwaitable[Prompt]] alias.
end note

note right of PromptUtil
  Resolves static <b>Prompt</b> or
  dynamic callable to OpenAI
  <b>ResponsePromptParam</b>.
  Raises <b>UserError</b> on bad
  dynamic prompt result.
end note

' ─── Relationships ───────────────────────────────────────────────────────────

' Computer hierarchy
Computer -[hidden]right- AsyncComputer

' Computer uses enumerations
Computer ..> Environment : uses
Computer ..> Button : uses
AsyncComputer ..> Environment : uses
AsyncComputer ..> Button : uses

' ApplyPatchEditor uses operation/result types
ApplyPatchEditor ..> ApplyPatchOperation : accepts
ApplyPatchEditor ..> ApplyPatchResult : returns

' ApplyPatchOperation uses its enum
ApplyPatchOperation --> ApplyPatchOperationType : type

' ApplyPatchOperation optionally holds RunContextWrapper
ApplyPatchOperation o-- RunContextWrapper : ctx_wrapper (optional)

' Composition relationships in apply_diff
ParsedUpdateDiff *-- Chunk : chunks
ReadSectionResult *-- Chunk : section_chunks

' apply_diff module functions use internal types
ApplyDiffFunctions ..> ParserState : uses
ApplyDiffFunctions ..> ParsedUpdateDiff : produces
ApplyDiffFunctions ..> ReadSectionResult : produces
ApplyDiffFunctions ..> ContextMatch : produces
ApplyDiffFunctions ..> Chunk : manipulates

' Prompt / PromptUtil relationships
GenerateDynamicPromptData o-- RunContextWrapper : context
GenerateDynamicPromptData o-- Agent : agent

PromptUtil ..> GenerateDynamicPromptData : constructs for dynamic dispatch
PromptUtil ..> RunContextWrapper : parameter
PromptUtil ..> Agent : parameter
PromptUtil ..> ResponsePromptParam : returns

@enduml
