@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9E6
    BorderColor #C8A000
}

title Extensions – Memory Backends

' ─────────────────────────────────────────
'  Core / Base Layer
' ─────────────────────────────────────────
package "agents.memory" {

    class SessionSettings {
        +default_limit: int
    }

    abstract class SessionABC {
        +session_id: str
        +session_settings: SessionSettings | None
        --
        +{abstract} get_items(limit: int | None): list[TResponseInputItem]
        +{abstract} add_items(items: list[TResponseInputItem]): None
        +{abstract} pop_item(): TResponseInputItem | None
        +{abstract} clear_session(): None
    }

    class SQLiteSession {
        +session_id: str
        +db_path: str | Path
        +session_settings: SessionSettings | None
        --
        +get_items(limit): list[TResponseInputItem]
        +add_items(items): None
        +pop_item(): TResponseInputItem | None
        +clear_session(): None
    }

    SQLiteSession --|> SessionABC
}

' ─────────────────────────────────────────
'  Extension Backends
' ─────────────────────────────────────────
package "agents.extensions.memory" {

    class AsyncSQLiteSession {
        +session_id: str
        +db_path: str | Path
        +sessions_table: str
        +messages_table: str
        +session_settings: SessionSettings | None
        -_connection: aiosqlite.Connection | None
        -_lock: asyncio.Lock
        -_init_lock: asyncio.Lock
        --
        +get_items(limit): list[TResponseInputItem]
        +add_items(items): None
        +pop_item(): TResponseInputItem | None
        +clear_session(): None
        +close(): None
        -_get_connection(): aiosqlite.Connection
        -_locked_connection(): AsyncIterator
        -_init_db_for_connection(conn): None
    }

    class AdvancedSQLiteSession {
        +session_id: str
        +db_path: str | Path
        +session_settings: SessionSettings | None
        -_current_branch_id: str
        -_logger: logging.Logger
        --
        +get_items(limit, branch_id): list[TResponseInputItem]
        +add_items(items): None
        +store_run_usage(result: RunResult): None
        +create_branch_from_turn(turn_number, branch_name): str
        +create_branch_from_content(search_term, branch_name): str
        +switch_to_branch(branch_id): None
        +delete_branch(branch_id, force): None
        +list_branches(): list[dict]
        +get_conversation_turns(branch_id): list[dict]
        +get_session_usage(branch_id): dict | None
        +get_turn_usage(user_turn_number, branch_id): dict | list
        -_init_structure_tables(): None
        -_copy_messages_to_new_branch(new_branch_id, from_turn_number): None
        -_cleanup_orphaned_messages(): int
    }

    class RedisSession {
        +session_id: str
        +session_settings: SessionSettings | None
        -_redis: Redis
        -_key_prefix: str
        -_ttl: int | None
        -_lock: asyncio.Lock
        -_owns_client: bool
        -_session_key: str
        -_messages_key: str
        -_counter_key: str
        --
        +{static} from_url(session_id, url, ...): RedisSession
        +get_items(limit): list[TResponseInputItem]
        +add_items(items): None
        +pop_item(): TResponseInputItem | None
        +clear_session(): None
        +close(): None
        +ping(): bool
        -_serialize_item(item): str
        -_deserialize_item(data): TResponseInputItem
        -_get_next_id(): int
        -_set_ttl_if_configured(*keys): None
    }

    class MongoDBSession {
        +session_id: str
        +session_settings: SessionSettings | None
        -{static} _init_state: dict
        -{static} _init_guard: threading.Lock
        -_client: AsyncMongoClient
        -_owns_client: bool
        -_sessions: AsyncCollection
        -_messages: AsyncCollection
        -_client_id: int
        --
        +{static} from_uri(session_id, uri, ...): MongoDBSession
        +get_items(limit): list[TResponseInputItem]
        +add_items(items): None
        +pop_item(): TResponseInputItem | None
        +clear_session(): None
        +close(): None
        +ping(): bool
        -_ensure_indexes(): None
        -_serialize_item(item): str
        -_deserialize_item(raw): TResponseInputItem
    }

    class SQLAlchemySession {
        +session_id: str
        +session_settings: SessionSettings | None
        -{static} _table_init_locks: dict
        -{static} _sqlite_configured_engines: set
        -{static} _SQLITE_BUSY_TIMEOUT_MS: int
        -{static} _SQLITE_LOCK_RETRY_DELAYS: tuple
        -_engine: AsyncEngine
        -_metadata: MetaData
        -_sessions: Table
        -_messages: Table
        -_session_factory: async_sessionmaker
        -_create_tables: bool
        --
        +{static} from_url(session_id, url, ...): SQLAlchemySession
        +engine: AsyncEngine
        +get_items(limit): list[TResponseInputItem]
        +add_items(items): None
        +pop_item(): TResponseInputItem | None
        +clear_session(): None
        -_ensure_tables(): None
        -{static} _configure_sqlite_engine(engine): None
        -{static} _is_sqlite_lock_error(exc): bool
        -_run_sqlite_write_with_retry(operation): None
        -_serialize_item(item): str
        -_deserialize_item(data): TResponseInputItem
    }

    class DaprSession {
        +session_id: str
        +session_settings: SessionSettings | None
        -_dapr_client: DaprClient
        -_state_store_name: str
        -_ttl: int | None
        -_consistency: ConsistencyLevel
        -_lock: asyncio.Lock
        -_owns_client: bool
        -_messages_key: str
        -_metadata_key: str
        --
        +{static} from_address(session_id, state_store_name, ...): DaprSession
        +get_items(limit): list[TResponseInputItem]
        +add_items(items): None
        +pop_item(): TResponseInputItem | None
        +clear_session(): None
        +close(): None
        +ping(): bool
        +__aenter__(): DaprSession
        +__aexit__(exc_type, exc_val, exc_tb): None
        -_calculate_retry_delay(attempt): float
        -_is_concurrency_conflict(error): bool
        -_handle_concurrency_conflict(error, attempt): bool
        -_serialize_item(item): str
        -_deserialize_item(item): TResponseInputItem
    }

    class EncryptedSession {
        +session_id: str
        +underlying_session: SessionABC
        +ttl: int
        +cipher: Fernet
        -_kid: str
        -_ver: int
        --
        +session_settings: SessionSettings | None
        +get_items(limit): list[TResponseInputItem]
        +add_items(items): None
        +pop_item(): TResponseInputItem | None
        +clear_session(): None
        +__getattr__(name)
        -_wrap(item): EncryptedEnvelope
        -_unwrap(item): TResponseInputItem | None
    }

    class EncryptedEnvelope << (T,#ADD8E6) TypedDict >> {
        +__enc__: Literal[1]
        +v: int
        +kid: str
        +payload: str
    }

    ' Inheritance from SessionABC
    AsyncSQLiteSession --|> SessionABC
    AdvancedSQLiteSession --|> SQLiteSession
    RedisSession --|> SessionABC
    MongoDBSession --|> SessionABC
    SQLAlchemySession --|> SessionABC
    DaprSession --|> SessionABC
    EncryptedSession --|> SessionABC

    ' EncryptedSession wraps any SessionABC (decorator pattern)
    EncryptedSession *-- SessionABC : wraps (underlying_session)

    ' EncryptedSession uses EncryptedEnvelope for storage
    EncryptedSession ..> EncryptedEnvelope : creates/reads
}

' ─────────────────────────────────────────
'  Configuration dependency
' ─────────────────────────────────────────
SessionABC o-- SessionSettings : configured by

' ─────────────────────────────────────────
'  Notes
' ─────────────────────────────────────────
note top of SessionABC
  Common protocol for all session backends.
  All extensions are drop-in replacements
  for agents.memory.SQLiteSession.
end note

note right of AdvancedSQLiteSession
  Extends SQLiteSession with:
  • Multi-branch conversation trees
  • Per-turn token usage analytics
  (tables: message_structure, turn_usage)
end note

note right of EncryptedSession
  Decorator pattern — wraps any SessionABC.
  Uses HKDF(SHA256, salt=session_id) to derive
  a per-session Fernet key from master key.
  Expired tokens silently skipped on reads.
end note

note right of DaprSession
  Optimistic concurrency via etag/CAS loop
  (max 5 attempts, exponential backoff + 10% jitter).
  Supports 'eventual' | 'strong' consistency.
end note

note right of MongoDBSession
  Class-level index registry (threading.Lock)
  ensures create_index runs once per
  client/database/collection combination.
end note

note right of SQLAlchemySession
  Supports PostgreSQL+asyncpg, MySQL+aiomysql,
  SQLite+aiosqlite. Auto-applies WAL mode and
  busy_timeout when dialect is SQLite.
end note

note bottom of RedisSession
  Messages stored in a Redis list (RPUSH/RPOP).
  Supports TTL and owns-client lifecycle.
  Factory: RedisSession.from_url()
end note

@enduml
