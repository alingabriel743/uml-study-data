@startuml class_items_and_stream_events

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF8DC
    BorderColor #CCA800
    FontSize 11
}

title Items & Stream Events

' ─────────────────────────────────────────────
' Package: agents.items
' ─────────────────────────────────────────────
package "agents.items" {

    abstract class "RunItemBase<T>" as RunItemBase {
        +agent : Agent[Any]
        +raw_item : T
        -_agent_ref : weakref.Ref[Agent] | None
        --
        +__post_init__() : None
        +release_agent() : None
        +to_input_item() : TResponseInputItem
        #__getattribute__(name: str) : Any
    }

    class MessageOutputItem {
        +raw_item : ResponseOutputMessage
        +type : Literal['message_output_item']
    }

    class ToolCallItem {
        +raw_item : ToolCallItemTypes
        +type : Literal['tool_call_item']
        +description : str | None
        +title : str | None
        +tool_origin : ToolOrigin | None
    }

    class ToolCallOutputItem {
        +raw_item : ToolCallOutputTypes
        +output : Any
        +type : Literal['tool_call_output_item']
        +tool_origin : ToolOrigin | None
        --
        +to_input_item() : TResponseInputItem
    }

    class HandoffCallItem {
        +raw_item : ResponseFunctionToolCall
        +type : Literal['handoff_call_item']
    }

    class HandoffOutputItem {
        +raw_item : TResponseInputItem
        +source_agent : Agent[Any]
        +target_agent : Agent[Any]
        +type : Literal['handoff_output_item']
        -_source_agent_ref : weakref.Ref[Agent] | None
        -_target_agent_ref : weakref.Ref[Agent] | None
        --
        +release_agent() : None
    }

    class ReasoningItem {
        +raw_item : ResponseReasoningItem
        +type : Literal['reasoning_item']
    }

    class MCPListToolsItem {
        +raw_item : McpListTools
        +type : Literal['mcp_list_tools_item']
    }

    class MCPApprovalRequestItem {
        +raw_item : McpApprovalRequest
        +type : Literal['mcp_approval_request_item']
    }

    class MCPApprovalResponseItem {
        +raw_item : McpApprovalResponse
        +type : Literal['mcp_approval_response_item']
    }

    class CompactionItem {
        +type : Literal['compaction_item']
        --
        +to_input_item() : TResponseInputItem
    }

    class ToolApprovalItem {
        +raw_item : ToolApprovalRawItem
        +tool_name : str | None
        +tool_namespace : str | None
        +tool_origin : ToolOrigin | None
        +tool_lookup_key : FunctionToolLookupKey | None
        +type : Literal['tool_approval_item']
        --
        +name : str | None  <<property>>
        +qualified_name : str | None  <<property>>
        +arguments : str | None  <<property>>
        +call_id : str | None  <<property>>
        +to_input_item() : raises AgentsException
    }

    class ToolSearchCallItem {
        +raw_item : ToolSearchCallRawItem
        +type : Literal['tool_search_call_item']
        --
        +to_input_item() : TResponseInputItem
    }

    class ToolSearchOutputItem {
        +raw_item : ToolSearchOutputRawItem
        +type : Literal['tool_search_output_item']
        --
        +to_input_item() : TResponseInputItem
    }

    class ModelResponse <<pydantic>> {
        +output : list[TResponseOutputItem]
        +usage : Usage
        +response_id : str | None
        +request_id : str | None
        --
        +to_input_items() : list[TResponseInputItem]
    }

    class ItemHelpers <<utility>> {
        +{static} extract_last_content(message) : str
        +{static} extract_last_text(message) : str | None
        +{static} extract_text(message) : str | None
        +{static} input_to_new_input_list(input) : list[TResponseInputItem]
        +{static} text_message_outputs(items) : str
        +{static} text_message_output(message) : str
        +{static} tool_call_output_item(tool_call, output) : FunctionCallOutput
    }
}

' ─────────────────────────────────────────────
' Package: agents.stream_events
' ─────────────────────────────────────────────
package "agents.stream_events" {

    class RawResponsesStreamEvent {
        +data : TResponseStreamEvent
        +type : Literal['raw_response_event']
    }

    class RunItemStreamEvent {
        +name : Literal[event_names]
        +item : RunItem
        +type : Literal['run_item_stream_event']
    }

    class AgentUpdatedStreamEvent {
        +new_agent : Agent[Any]
        +type : Literal['agent_updated_stream_event']
    }
}

' ─────────────────────────────────────────────
' Package: agents.run_internal.items  (helpers)
' ─────────────────────────────────────────────
package "agents.run_internal.items" {

    class RunInternalItemHelpers <<module>> {
        +{static} run_item_to_input_item(run_item, id_policy) : TResponseInputItem | None
        +{static} run_items_to_input_items(items, id_policy) : list[TResponseInputItem]
        +{static} prepare_model_input_items(caller, generated) : list[TResponseInputItem]
        +{static} drop_orphan_function_calls(items, pruning_idx) : list[TResponseInputItem]
        +{static} normalize_input_items_for_api(items) : list[TResponseInputItem]
        +{static} deduplicate_input_items(items) : list[TResponseInputItem]
        +{static} fingerprint_input_item(item, ignore_ids) : str | None
        +{static} strip_internal_input_item_metadata(item) : TResponseInputItem
        +{static} function_rejection_item(agent, tool_call, ...) : ToolCallOutputItem
        +{static} shell_rejection_item(agent, call_id, ...) : ToolCallOutputItem
    }
}

' ─────────────────────────────────────────────
' Inheritance: all RunItemBase subclasses
' ─────────────────────────────────────────────
MessageOutputItem      --|> RunItemBase
ToolCallItem           --|> RunItemBase
ToolCallOutputItem     --|> RunItemBase
HandoffCallItem        --|> RunItemBase
HandoffOutputItem      --|> RunItemBase
ReasoningItem          --|> RunItemBase
MCPListToolsItem       --|> RunItemBase
MCPApprovalRequestItem --|> RunItemBase
MCPApprovalResponseItem --|> RunItemBase
CompactionItem         --|> RunItemBase
ToolApprovalItem       --|> RunItemBase
ToolSearchCallItem     --|> RunItemBase
ToolSearchOutputItem   --|> RunItemBase

' ─────────────────────────────────────────────
' Associations
' ─────────────────────────────────────────────
RunItemStreamEvent *-- "1" RunItemBase : item (RunItem union)

ItemHelpers ..> MessageOutputItem   : operates on
ItemHelpers ..> ToolCallOutputItem  : creates

RunInternalItemHelpers ..> RunItemBase         : converts
RunInternalItemHelpers ..> ToolCallOutputItem  : produces rejection items

' ─────────────────────────────────────────────
' Notes
' ─────────────────────────────────────────────
note bottom of RunItemBase
  Generic base for all run items.
  Uses weakref to Agent for GC safety.
  release_agent() drops the strong reference.
  to_input_item() serializes via model_dump()
  or returns raw dict.
end note

note right of ToolApprovalItem
  to_input_item() raises AgentsException —
  must be filtered before sending to the API.
  Identity-based __hash__ / __eq__.
end note

note right of HandoffOutputItem
  source_agent and target_agent are both
  backed by weakrefs (_source_agent_ref,
  _target_agent_ref) for memory safety.
end note

note bottom of ToolSearchCallItem
  'created_by' output-only field is
  stripped in to_input_item() before replay.
end note

note right of RunItemStreamEvent
  name literals:
  'message_output_created' | 'handoff_requested' |
  'handoff_occured'(*) | 'tool_called' |
  'tool_search_called' | 'tool_search_output_created' |
  'tool_output' | 'reasoning_item_created' |
  'mcp_approval_requested' | 'mcp_approval_response' |
  'mcp_list_tools'
  (*) misspelling preserved for backwards compatibility
end note

note bottom of RunInternalItemHelpers
  ReasoningItemIdPolicy = 'preserve' | 'omit'
  TOOL_CALL_SESSION_DESCRIPTION_KEY = '_agents_tool_description'
  TOOL_CALL_SESSION_TITLE_KEY = '_agents_tool_title'
  Prunes orphan function calls and normalises
  items before each model API call.
end note

' ─────────────────────────────────────────────
' Union type aliases (informational notes)
' ─────────────────────────────────────────────
note as N_RunItem
  <b>RunItem</b> (union alias)
  MessageOutputItem | ToolSearchCallItem |
  ToolSearchOutputItem | HandoffCallItem |
  HandoffOutputItem | ToolCallItem |
  ToolCallOutputItem | ReasoningItem |
  MCPListToolsItem | MCPApprovalRequestItem |
  MCPApprovalResponseItem | CompactionItem |
  ToolApprovalItem
  ────────────────────────────────
  ModelResponse is a separate output envelope
  and is NOT part of the RunItem union.
end note

note as N_StreamEvent
  <b>StreamEvent</b> (union alias)
  RawResponsesStreamEvent |
  RunItemStreamEvent |
  AgentUpdatedStreamEvent
end note

@enduml
