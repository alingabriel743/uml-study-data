@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Memory – Session Management

package "agents.memory" {

    package "agents.memory.session" {

        interface Session <<Protocol>> {
            +session_id: str
            +session_settings: SessionSettings | None
            ..
            +{abstract} get_items(limit: int | None) : list[TResponseInputItem]
            +{abstract} add_items(items: list[TResponseInputItem]) : None
            +{abstract} pop_item() : TResponseInputItem | None
            +{abstract} clear_session() : None
        }

        abstract class SessionABC <<ABC>> {
            +session_id: str
            +session_settings: SessionSettings | None
            ..
            +{abstract} get_items(limit: int | None) : list[TResponseInputItem]
            +{abstract} add_items(items: list[TResponseInputItem]) : None
            +{abstract} pop_item() : TResponseInputItem | None
            +{abstract} clear_session() : None
        }

        interface OpenAIResponsesCompactionAwareSession <<Protocol>> {
            +{abstract} run_compaction(args: OpenAIResponsesCompactionArgs | None) : None
        }

        class OpenAIResponsesCompactionArgs <<TypedDict>> {
            +response_id: str  {optional}
            +compaction_mode: Literal['previous_response_id','input','auto']  {optional}
            +store: bool  {optional}
            +force: bool  {optional}
        }

    }

    package "agents.memory.session_settings" {

        class SessionSettings <<dataclass>> {
            +limit: int | None = None
            ..
            +resolve(override: SessionSettings | None) : SessionSettings
            +to_dict() : dict[str, Any]
        }

        note right of SessionSettings
          Immutable-style config.
          resolve() overlays non-None
          fields via dataclasses.replace().
          Used by all concrete sessions.
        end note

    }

    package "agents.memory.sqlite_session" {

        class SQLiteSession {
            -{static} _file_locks: dict[Path, RLock]
            -{static} _file_lock_counts: dict[Path, int]
            -{static} _file_locks_guard: threading.Lock
            ..
            +session_id: str
            +session_settings: SessionSettings | None
            +db_path: str | Path
            +sessions_table: str = "agent_sessions"
            +messages_table: str = "agent_messages"
            -_local: threading.local
            -_is_memory_db: bool
            -_lock: threading.RLock
            -_lock_path: Path | None
            -_lock_released: bool
            -_shared_connection: sqlite3.Connection
            ..
            +__init__(session_id, db_path, sessions_table, messages_table, session_settings)
            +{static} _acquire_file_lock(db_path) : tuple[Path, RLock]
            +{static} _release_file_lock(lock_path) : None
            -_locked_connection() : Iterator[sqlite3.Connection]
            -_get_connection() : sqlite3.Connection
            -_init_db_for_connection(conn) : None
            -_insert_items(conn, items) : None
            +get_items(limit) : list[TResponseInputItem]
            +add_items(items) : None
            +pop_item() : TResponseInputItem | None
            +clear_session() : None
            +close() : None
        }

        note bottom of SQLiteSession
          :memory: → shared connection.
          File-backed → thread-local conn + WAL mode.
          All DB ops offloaded via asyncio.to_thread.
          Schema: agent_sessions + agent_messages (FK).
        end note

    }

    package "agents.memory.openai_conversations_session" {

        class OpenAIConversationsSession {
            -_session_id: str | None
            +session_settings: SessionSettings | None
            -_openai_client: AsyncOpenAI
            ..
            +session_id: str  {lazy property — raises ValueError until init}
            ..
            +__init__(conversation_id, openai_client, session_settings)
            -_get_session_id() : str
            -_clear_session_id() : None
            +get_items(limit) : list[TResponseInputItem]
            +add_items(items) : None
            +pop_item() : TResponseInputItem | None
            +clear_session() : None
        }

        note bottom of OpenAIConversationsSession
          Lazy session init: conversation is created
          on the first API call.
          Uses openai.conversations.items API.
          pop_item() fetches last item then deletes by id.
          Cannot be wrapped by CompactionSession.
        end note

    }

    package "agents.memory.openai_responses_compaction_session" {

        class OpenAIResponsesCompactionSession {
            +session_id: str
            +underlying_session: Session
            -_client: AsyncOpenAI | None
            +model: str = "gpt-4.1"
            +compaction_mode: OpenAIResponsesCompactionMode = "auto"
            +should_trigger_compaction: Callable[[dict], bool]
            -_compaction_candidate_items: list[TResponseInputItem] | None
            -_session_items: list[TResponseInputItem] | None
            -_response_id: str | None
            -_deferred_response_id: str | None
            -_last_unstored_response_id: str | None
            ..
            +client: AsyncOpenAI  {lazy property}
            ..
            +__init__(session_id, underlying_session, client, model, compaction_mode, should_trigger_compaction)
            +run_compaction(args: OpenAIResponsesCompactionArgs | None) : None
            +get_items(limit) : list[TResponseInputItem]
            +add_items(items) : None
            +pop_item() : TResponseInputItem | None
            +clear_session() : None
            -_ensure_compaction_candidates() : tuple[list, list]
            -_defer_compaction(response_id, store) : None
            -_get_deferred_compaction_response_id() : str | None
            -_clear_deferred_compaction() : None
            -_resolve_compaction_mode_for_response(response_id, store, requested_mode) : _ResolvedCompactionMode
        }

        note bottom of OpenAIResponsesCompactionSession
          Decorator pattern over any Session
          except OpenAIConversationsSession.
          Default compaction threshold = 10 candidate items
          (excludes user messages & compaction items).
          'auto' mode → 'previous_response_id' if stored,
          otherwise 'input'.
          Delegates all CRUD to underlying_session.
        end note

    }

}

' ─── Inheritance ───────────────────────────────────────────────────────────────
Session <|.. SessionABC : mirrors (ABC for internal use)
Session <|-- OpenAIResponsesCompactionAwareSession : extends

SessionABC <|-- SQLiteSession : extends
SessionABC <|-- OpenAIConversationsSession : extends
SessionABC <|-- OpenAIResponsesCompactionSession : extends
OpenAIResponsesCompactionAwareSession <|.. OpenAIResponsesCompactionSession : implements

' ─── Composition / Dependency ──────────────────────────────────────────────────
OpenAIResponsesCompactionSession o-- Session : wraps\nunderlying_session

SQLiteSession ..> SessionSettings : uses
OpenAIConversationsSession ..> SessionSettings : uses
OpenAIResponsesCompactionSession ..> SessionSettings : uses
OpenAIResponsesCompactionSession ..> OpenAIResponsesCompactionArgs : run_compaction(args)

@enduml
