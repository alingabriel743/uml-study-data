@startuml class_models_chat_completions

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

title Models – Chat Completions

'--------------------------------------------------
' Abstract interface (agents.models.interface)
'--------------------------------------------------
package "agents.models.interface" {
    abstract class Model {
        +get_response(...) : ModelResponse
        +stream_response(...) : AsyncIterator[TResponseStreamEvent]
    }
}

'--------------------------------------------------
' Core model + helpers (agents.models)
'--------------------------------------------------
package "agents.models" {

    class OpenAIChatCompletionsModel {
        ' Class-level attributes
        ~{static} _OFFICIAL_OPENAI_SUPPORTED_INPUT_CONTENT_TYPES : frozenset[str]
        ' Instance attributes
        +model : str | ChatModel
        -_client : AsyncOpenAI
        +should_replay_reasoning_content : ShouldReplayReasoningContent | None
        --
        +__init__(model, openai_client, should_replay_reasoning_content) : None
        +get_response(system_instructions, input, model_settings, tools,\n  output_schema, handoffs, tracing, ...) : ModelResponse
        +stream_response(system_instructions, input, model_settings, tools,\n  output_schema, handoffs, tracing, ...) : AsyncIterator[TResponseStreamEvent]
        -_fetch_response(..., stream : bool) : ChatCompletion | tuple[Response, AsyncStream]
        -_validate_official_openai_input_content_types(request_input) : None
        -_supports_default_prompt_cache_key() : bool
        +get_retry_advice(request : ModelRetryAdviceRequest) : ModelRetryAdvice | None
        -_attach_logprobs_to_output(output_items, logprobs) : None
        -_get_client() : AsyncOpenAI
        -_merge_headers(model_settings : ModelSettings) : dict
        -_non_null_or_omit(value : Any) : Any
    }

    class Converter <<utility>> {
        ' All methods are @classmethods
        --
        +{static} convert_tool_choice(tool_choice) : ChatCompletionToolChoiceOptionParam | Omit
        +{static} convert_response_format(final_output_schema) : ResponseFormat | Omit
        +{static} message_to_output_items(message, provider_data) : list[TResponseOutputItem]
        +{static} items_to_messages(items, model, preserve_thinking_blocks,\n  preserve_tool_output_all_content, base_url,\n  should_replay_reasoning_content) : list[ChatCompletionMessageParam]
        +{static} tool_to_openai(tool : Tool) : ChatCompletionToolParam
        +{static} convert_handoff_tool(handoff : Handoff) : ChatCompletionToolParam
        +{static} maybe_easy_input_message(item) : EasyInputMessageParam | None
        +{static} maybe_input_message(item) : Message | None
        +{static} maybe_file_search_call(item) : ResponseFileSearchToolCallParam | None
        +{static} maybe_function_tool_call(item) : ResponseFunctionToolCallParam | None
        +{static} maybe_function_tool_call_output(item) : FunctionCallOutput | None
        +{static} maybe_item_reference(item) : ItemReference | None
        +{static} maybe_response_output_message(item) : ResponseOutputMessageParam | None
        +{static} maybe_reasoning_message(item) : ResponseReasoningItemParam | None
        +{static} extract_text_content(content) : str | list[ChatCompletionContentPartTextParam]
        +{static} extract_all_content(content) : str | list[ChatCompletionContentPartParam]
        -{static} _normalize_input_content_part_alias(content_part) : ResponseInputContentWithAudioParam
    }

    class ChatCmplStreamHandler <<utility>> {
        ' All methods are @classmethods
        --
        +{static} handle_stream(response : Response, stream : AsyncStream[ChatCompletionChunk],\n  model : str | None) : AsyncIterator[TResponseStreamEvent]
        -{static} _finish_reasoning_item(state : StreamingState,\n  sequence_number : SequenceNumber) : Iterator[TResponseStreamEvent]
        -{static} _finish_reasoning_summary_part(state : StreamingState,\n  sequence_number : SequenceNumber) : Iterator[TResponseStreamEvent]
    }

    class ChatCmplHelpers <<utility>> {
        ' Module-level constants
        +{static} HEADERS : dict[str, str]
        +{static} HEADERS_OVERRIDE : ContextVar[dict[str,str] | None]
        --
        +{static} is_openai(client : AsyncOpenAI) : bool
        +{static} get_store_param(client, model_settings) : bool | None
        +{static} get_stream_options_param(client, model_settings, stream) : dict | None
        +{static} convert_logprobs_for_output_text(logprobs) : list[Logprob] | None
        +{static} convert_logprobs_for_text_delta(logprobs) : list[DeltaLogprob] | None
        +{static} clean_gemini_tool_call_id(tool_call_id, model) : str
    }

    class StreamingState <<dataclass>> {
        +started : bool = False
        +text_content_index_and_output : tuple[int, ResponseOutputText] | None
        +refusal_content_index_and_output : tuple[int, ResponseOutputRefusal] | None
        +reasoning_content_index_and_output : tuple[int, ResponseReasoningItem] | None
        +active_reasoning_summary_index : int | None
        +reasoning_item_done : bool = False
        +function_calls : dict[int, ResponseFunctionToolCall]
        +function_call_streaming : dict[int, bool]
        +function_call_output_idx : dict[int, int]
        +thinking_text : str = ''
        +thinking_signature : str | None = None
        +provider_data : dict[str, Any]
    }

    class SequenceNumber <<helper>> {
        -_sequence_number : int = 0
        --
        +get_and_increment() : int
    }
}

'--------------------------------------------------
' External dependencies (abbreviated)
'--------------------------------------------------
package "External / openai SDK" {
    class AsyncOpenAI <<external>> {
        +chat.completions.create(...)
    }
    class AsyncStream <<external>>
    class ChatCompletionChunk <<external>>
}

package "agents (shared)" {
    class ModelSettings <<external>>
    class ModelResponse <<external>>
    class ShouldReplayReasoningContent <<external>>
    class ReasoningContentReplayContext <<external>>
    class Tool <<external>>
    class Handoff <<external>>
}

'--------------------------------------------------
' Relationships
'--------------------------------------------------

' Inheritance
OpenAIChatCompletionsModel --|> Model : extends

' Composition
OpenAIChatCompletionsModel *-- AsyncOpenAI : _client

' Dependencies – OpenAIChatCompletionsModel
OpenAIChatCompletionsModel ..> Converter           : uses\n(convert/build messages & tools)
OpenAIChatCompletionsModel ..> ChatCmplStreamHandler : uses\n(handle_stream)
OpenAIChatCompletionsModel ..> ChatCmplHelpers     : uses\n(store/stream params,\nlogprobs)
OpenAIChatCompletionsModel ..> ModelSettings       : uses
OpenAIChatCompletionsModel ..> ModelResponse       : produces

' Dependencies – ChatCmplStreamHandler
ChatCmplStreamHandler o-- StreamingState   : creates per call
ChatCmplStreamHandler o-- SequenceNumber   : creates per call
ChatCmplStreamHandler ..> ChatCmplHelpers  : uses\n(logprobs, Gemini tool_call_id)
ChatCmplStreamHandler ..> AsyncStream      : consumes chunks
ChatCmplStreamHandler ..> ChatCompletionChunk : processes

' Dependencies – Converter
Converter ..> ShouldReplayReasoningContent    : invokes hook
Converter ..> ReasoningContentReplayContext   : builds for hook

' Notes
note right of OpenAIChatCompletionsModel
  Wraps Chat Completions API but normalises
  output to Responses API type system
  (Response, ResponseOutputItem, etc.)
  using FAKE_RESPONSES_ID placeholders.
end note

note right of Converter
  Multi-provider reasoning support:
  Anthropic (thinking_blocks / encrypted signatures),
  DeepSeek (reasoning_content / delta.reasoning),
  Gemini (thought_signature in provider_data).
  MCPToolChoice & compaction items raise UserError.
end note

note right of ChatCmplHelpers
  HEADERS_OVERRIDE is a ContextVar allowing
  per-request header injection without
  mutating the AsyncOpenAI client.
  is_openai() gates store param and
  stream usage defaults to official endpoints.
end note

note right of ChatCmplStreamHandler
  Translates raw ChatCompletionChunk stream events
  into Responses API streaming events
  (ResponseTextDeltaEvent, ResponseOutputItemAddedEvent, etc.).
  Manages StreamingState for reasoning / refusal / tool-call tracks.
end note

@enduml
