@startuml class_models_responses

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Models – Responses API

' ─────────────────────────────────────────
' External / Base Types
' ─────────────────────────────────────────
package "agents (base)" <<Frame>> {
    interface Model {
        +get_response(...) : ModelResponse
        +stream_response(...) : AsyncIterator
    }

    class AsyncOpenAI <<external>> {
    }

    class OpenAIProvider <<external>> {
        +openai_client : AsyncOpenAI
    }

    class RunConfig <<external>> {
        +model_provider : ModelProvider
    }

    class MultiProvider <<external>> {
        +openai_provider : OpenAIProvider
    }

    class Runner <<external>> {
        +{static} run(...) : RunResult
        +{static} run_streamed(...) : RunResultStreaming
    }
}

' ─────────────────────────────────────────
' agents.models.openai_responses
' ─────────────────────────────────────────
package "agents.models.openai_responses" {

    class OpenAIResponsesModel {
        +model : str | ChatModel
        -_model_is_explicit : bool
        -_client : AsyncOpenAI
        --
        +__init__(model, openai_client, *, model_is_explicit)
        +get_response(...) : ModelResponse  <<async>>
        +stream_response(...) : AsyncIterator  <<async>>
        +get_retry_advice(request) : ModelRetryAdvice | None
        -_fetch_response(...) : Response  <<async>>
        -_build_response_create_kwargs(...) : dict
        -_remove_openai_responses_api_incompatible_fields(list_input) : list
        -_clean_item_for_openai(item) : Any | None
        -_get_client() : AsyncOpenAI
        -_merge_headers(model_settings) : dict
        -_supports_default_prompt_cache_key() : bool
        -_schedule_async_iterator_close(iterator) : None
        -_maybe_aclose_async_iterator(iterator) : None  <<async>>
    }

    class OpenAIResponsesWSModel {
        -_ws_connection : Any | None
        -_ws_connection_identity : tuple | None
        -_ws_connection_loop_ref : weakref | None
        -_ws_request_lock : asyncio.Lock | None
        -_ws_request_lock_loop_ref : weakref | None
        -_ws_client_close_generation : int
        --
        +__init__(model, openai_client, *, model_is_explicit)
        +close() : None  <<async>>
        +get_retry_advice(request) : ModelRetryAdvice | None
        -_fetch_response(...) : Response  <<async, overrides>>
        -_iter_websocket_response_events(...) : AsyncIterator  <<async>>
        -_ensure_websocket_connection(url, headers) : connection  <<async>>
        -_open_websocket_connection(url, headers) : connection  <<async>>
        -_is_websocket_connection_reusable(connection) : bool
        -_prepare_websocket_request(...) : dict  <<async>>
        -_prepare_websocket_url(extra_query) : str
        -_merge_websocket_headers(extra_headers) : dict
        -_await_websocket_with_timeout(...) : Any  <<async>>
        -_get_ws_request_lock() : asyncio.Lock
        -_drop_websocket_connection() : None  <<async>>
        -_force_abort_websocket_connection(connection) : None
        -_clear_websocket_connection_state() : None
        -_get_websocket_request_timeouts(timeout) : _WebsocketRequestTimeouts
        -_should_wrap_pre_event_websocket_disconnect(exc) : bool
        -_supports_default_prompt_cache_key() : bool  <<overrides>>
    }

    class Converter <<utility>> {
        +{static} convert_tool_choice(tool_choice, *, tools, handoffs, model) : ToolChoice | Omit
        +{static} convert_tools(tools, handoffs, *, model, ...) : ConvertedTools
        +{static} get_response_format(output_schema) : ResponseFormat
        +{static} resolve_computer_tool_model(request_model, tools) : str | None
        -{static} _convert_function_tool(tool) : ResponsesToolParam
        -{static} _convert_tool(tool, ...) : ResponsesToolParam
        -{static} _convert_handoff_tool(handoff) : ResponsesToolParam
        -{static} _convert_preview_computer_tool(tool) : ResponsesToolParam
        -{static} _has_computer_tool(tools) : bool
        -{static} _is_preview_computer_model(model) : bool
        -{static} _is_ga_computer_model(model) : bool
        -{static} _should_use_preview_computer_tool(...) : bool
        -{static} _validate_required_tool_choice(tools) : None
    }

    class ConvertedTools <<dataclass>> {
        +tools : list[ResponsesToolParam]
        +includes : list[ResponseIncludable]
    }

    class "_ResponseStreamWithRequestId" as StreamWrapper <<internal>> {
        --
        +__init__(stream, response_future, request_id_future, cleanup_callbacks)
        +__aiter__() : _ResponseStreamWithRequestId
        +__anext__() : ResponseStreamEvent  <<async>>
        +aclose() : None  <<async>>
        +close() : None  <<async>>
        -_attach_request_id(event) : None
        -_cleanup_once() : None  <<async>>
        -_cleanup_after_exhaustion() : None  <<async>>
        -_close_stream_once() : None  <<async>>
    }

    class "_WebsocketRequestTimeouts" as WsTimeouts <<dataclass>> {
        ' connect, request_lock_wait, stream timeouts
    }

    class ResponsesWebSocketError {
        +payload : Mapping[str, Any]
        --
        +__init__(payload : Mapping[str, Any])
        -{static} _coerce_optional_str(value) : str | None
    }
}

' ─────────────────────────────────────────
' agents.models.openai_agent_registration
' ─────────────────────────────────────────
package "agents.models.openai_agent_registration" {

    class OpenAIAgentRegistrationConfig <<frozen dataclass>> {
        +harness_id : str | None
    }

    class ResolvedOpenAIAgentRegistrationConfig <<frozen dataclass>> {
        +harness_id : str
    }
}

' ─────────────────────────────────────────
' agents.responses_websocket_session
' ─────────────────────────────────────────
package "agents.responses_websocket_session" {

    class ResponsesWebSocketSession <<frozen dataclass>> {
        +provider : OpenAIProvider
        +run_config : RunConfig
        --
        +run(starting_agent, input, **kwargs) : RunResult  <<async>>
        +run_streamed(starting_agent, input, **kwargs) : RunResultStreaming
        +aclose() : None  <<async>>
        -__post_init__() : None
        -_validate_provider_alignment() : MultiProvider
        -_prepare_runner_kwargs(method_name, kwargs) : dict
    }
}

' ─────────────────────────────────────────
' agents.models.reasoning_content_replay
' ─────────────────────────────────────────
package "agents.models.reasoning_content_replay" {

    class ReasoningContentSource <<dataclass>> {
        +item : Any
        +origin_model : str | None
        +provider_data : Mapping[str, Any]
    }

    class ReasoningContentReplayContext <<dataclass>> {
        +model : str
        +base_url : str | None
        +reasoning : ReasoningContentSource
    }
}

' ─────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────

' Inheritance / Implementation
OpenAIResponsesModel     ..|> Model                          : implements
OpenAIResponsesWSModel   --|> OpenAIResponsesModel           : extends
ResponsesWebSocketError  --|> RuntimeError                   : extends

' Composition
OpenAIResponsesModel     *--  AsyncOpenAI                    : _client
ResponsesWebSocketSession *-- OpenAIProvider                 : provider
ResponsesWebSocketSession *-- RunConfig                      : run_config
ReasoningContentReplayContext *-- ReasoningContentSource     : reasoning

' Dependencies / Usage
OpenAIResponsesModel     ..>  Converter                      : uses (static)
OpenAIResponsesModel     ..>  ConvertedTools                 : receives
OpenAIResponsesModel     ..>  StreamWrapper                  : wraps stream
OpenAIResponsesWSModel   ..>  WsTimeouts                     : builds
ResponsesWebSocketSession ..> MultiProvider                  : validates against
ResponsesWebSocketSession ..> Runner                         : delegates run/run_streamed

' Config resolution
OpenAIAgentRegistrationConfig ..> ResolvedOpenAIAgentRegistrationConfig : resolved by\nresolve_openai_agent_registration_config()

' Converter produces ConvertedTools
Converter ..> ConvertedTools : produces

' ─────────────────────────────────────────
' Notes
' ─────────────────────────────────────────
note right of OpenAIResponsesWSModel
  Maintains a per-event-loop WebSocket connection.
  Uses close-generation versioning to detect stale
  connections. Always streams events; get_response()
  consumes until terminal event.
end note

note right of ReasoningContentReplayContext
  Default replay policy: only DeepSeek models.
  origin_model tracking prevents cross-family
  contamination.
  ShouldReplayReasoningContent = Callable[[ReasoningContentReplayContext], bool]
end note

note bottom of OpenAIAgentRegistrationConfig
  harness_id resolution priority:
  1. Explicit config
  2. Global default (set_default_openai_agent_registration_config)
  3. OPENAI_AGENT_HARNESS_ID env var
end note

note bottom of ResponsesWebSocketSession
  Created via responses_websocket_session() async
  context manager. Enforces run_config.model_provider
  is MultiProvider whose openai_provider == session.provider.
end note

note right of StreamWrapper
  Injects request_id into ResponseCompletedEvent
  at stream exhaustion (HTTP transport only).
  WS transport does not expose request_id.
end note

@enduml
