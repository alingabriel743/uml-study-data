@startuml class_realtime_events_and_items

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam interface {
    BackgroundColor #D0E8FF
    BorderColor #3A7FCC
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Realtime – Events, Items & Inputs

' ═══════════════════════════════════════════════════════
' SHARED CONTEXT
' ═══════════════════════════════════════════════════════

class RealtimeEventInfo <<dataclass>> {
    +context: RunContextWrapper
}

note right of RealtimeEventInfo
  Carried by every session-layer event.
  Provides access to the run context
  for all application listeners.
end note

' ═══════════════════════════════════════════════════════
' SESSION EVENTS — application-level (high layer)
' Union type: RealtimeSessionEvent
' ═══════════════════════════════════════════════════════

package "Session Events  ·  RealtimeSessionEvent  (union)" #E8F4FD {

    class RealtimeAgentStartEvent <<dataclass>> {
        +type: Literal['agent_start']
        +agent: RealtimeAgent
        +info: RealtimeEventInfo
    }

    class RealtimeAgentEndEvent <<dataclass>> {
        +type: Literal['agent_end']
        +agent: RealtimeAgent
        +info: RealtimeEventInfo
    }

    class RealtimeHandoffEvent <<dataclass>> {
        +type: Literal['handoff']
        +from_agent: RealtimeAgent
        +to_agent: RealtimeAgent
        +info: RealtimeEventInfo
    }

    class RealtimeToolStart <<dataclass>> {
        +type: Literal['tool_start']
        +agent: RealtimeAgent
        +tool: Tool
        +arguments: str
        +info: RealtimeEventInfo
    }

    class RealtimeToolEnd <<dataclass>> {
        +type: Literal['tool_end']
        +agent: RealtimeAgent
        +tool: Tool
        +arguments: str
        +output: Any
        +info: RealtimeEventInfo
    }

    class RealtimeToolApprovalRequired <<dataclass>> {
        +type: Literal['tool_approval_required']
        +agent: RealtimeAgent
        +tool: Tool
        +call_id: str
        +arguments: str
        +info: RealtimeEventInfo
    }

    class RealtimeRawModelEvent <<dataclass>> {
        +type: Literal['raw_model_event']
        +data: RealtimeModelEvent
        +info: RealtimeEventInfo
    }

    class RealtimeAudio <<dataclass>> {
        +type: Literal['audio']
        +audio: RealtimeModelAudioEvent
        +item_id: str
        +content_index: int
        +info: RealtimeEventInfo
    }

    class RealtimeAudioEnd <<dataclass>> {
        +type: Literal['audio_end']
        +item_id: str
        +content_index: int
        +info: RealtimeEventInfo
    }

    class RealtimeAudioInterrupted <<dataclass>> {
        +type: Literal['audio_interrupted']
        +item_id: str
        +content_index: int
        +info: RealtimeEventInfo
    }

    class RealtimeHistoryUpdated <<dataclass>> {
        +type: Literal['history_updated']
        +history: list[RealtimeItem]
        +info: RealtimeEventInfo
    }

    class RealtimeHistoryAdded <<dataclass>> {
        +type: Literal['history_added']
        +item: RealtimeItem
        +info: RealtimeEventInfo
    }

    class RealtimeGuardrailTripped <<dataclass>> {
        +type: Literal['guardrail_tripped']
        +guardrail_results: list[OutputGuardrailResult]
        +message: str
        +info: RealtimeEventInfo
    }

    class RealtimeError <<dataclass>> {
        +type: Literal['error']
        +error: Any
        +info: RealtimeEventInfo
    }

    class RealtimeInputAudioTimeoutTriggered <<dataclass>> {
        +type: Literal['input_audio_timeout_triggered']
        +info: RealtimeEventInfo
    }
}

' ═══════════════════════════════════════════════════════
' MODEL EVENTS — raw/transport-level (low layer)
' Union type: RealtimeModelEvent
' ═══════════════════════════════════════════════════════

package "Model Events  ·  RealtimeModelEvent  (union)" #EDF7ED {

    class RealtimeModelToolCallEvent <<dataclass>> {
        +type: Literal['function_call']
        +name: str
        +call_id: str
        +arguments: str
        +id: str | None
        +previous_item_id: str | None
    }

    class RealtimeModelAudioEvent <<dataclass>> {
        +type: Literal['audio']
        +data: bytes
        +response_id: str
        +item_id: str
        +content_index: int
    }

    class RealtimeModelAudioInterruptedEvent <<dataclass>> {
        +type: Literal['audio_interrupted']
        +item_id: str
        +content_index: int
    }

    class RealtimeModelAudioDoneEvent <<dataclass>> {
        +type: Literal['audio_done']
        +item_id: str
        +content_index: int
    }

    class RealtimeModelInputAudioTranscriptionCompletedEvent <<dataclass>> {
        +type: Literal['input_audio_transcription_completed']
        +item_id: str
        +transcript: str
    }

    class RealtimeModelInputAudioTimeoutTriggeredEvent <<dataclass>> {
        +type: Literal['input_audio_timeout_triggered']
        +item_id: str
        +audio_start_ms: int
        +audio_end_ms: int
    }

    class RealtimeModelTranscriptDeltaEvent <<dataclass>> {
        +type: Literal['transcript_delta']
        +item_id: str
        +delta: str
        +response_id: str
    }

    class RealtimeModelItemUpdatedEvent <<dataclass>> {
        +type: Literal['item_updated']
        +item: RealtimeItem
    }

    class RealtimeModelItemDeletedEvent <<dataclass>> {
        +type: Literal['item_deleted']
        +item_id: str
    }

    class RealtimeModelConnectionStatusEvent <<dataclass>> {
        +type: Literal['connection_status']
        +status: RealtimeConnectionStatus
    }

    class RealtimeModelTurnStartedEvent <<dataclass>> {
        +type: Literal['turn_started']
    }

    class RealtimeModelTurnEndedEvent <<dataclass>> {
        +type: Literal['turn_ended']
    }

    class RealtimeModelErrorEvent <<dataclass>> {
        +type: Literal['error']
        +error: Any
    }

    class RealtimeModelExceptionEvent <<dataclass>> {
        +type: Literal['exception']
        +exception: Exception
        +context: str | None
    }

    class RealtimeModelOtherEvent <<dataclass>> {
        +type: Literal['other']
        +data: Any
    }

    class RealtimeModelRawServerEvent <<dataclass>> {
        +type: Literal['raw_server_event']
        +data: Any
    }
}

note bottom of RealtimeModelConnectionStatusEvent
  RealtimeConnectionStatus =
  'connecting' | 'connected' | 'disconnected'
end note

' ═══════════════════════════════════════════════════════
' CONVERSATION ITEMS & CONTENT TYPES
' Union type: RealtimeItem  (discriminated by role / type)
' ═══════════════════════════════════════════════════════

package "Conversation Items  ·  RealtimeItem  (union)" #F3EEFF {

    class SystemMessageItem <<Pydantic>> {
        +type: Literal['message']
        +role: Literal['system']
        +item_id: str
        +previous_item_id: str | None
        +content: list[InputText]
    }

    class UserMessageItem <<Pydantic>> {
        +type: Literal['message']
        +role: Literal['user']
        +item_id: str
        +previous_item_id: str | None
        +content: list[InputText | InputAudio | InputImage]
    }

    class AssistantMessageItem <<Pydantic>> {
        +type: Literal['message']
        +role: Literal['assistant']
        +item_id: str
        +previous_item_id: str | None
        +status: Literal['in_progress','completed','incomplete'] | None
        +content: list[AssistantText | AssistantAudio]
    }

    class RealtimeToolCallItem <<Pydantic>> {
        +type: Literal['function_call']
        +item_id: str
        +previous_item_id: str | None
        +call_id: str | None
        +name: str
        +arguments: str
        +status: Literal['in_progress','completed']
        +output: str | None
    }

    class RealtimeResponse <<Pydantic>> {
        +id: str
        +output: list[RealtimeMessageItem]
    }

    ' ── User content types ──────────────────────────────
    class InputText <<Pydantic>> {
        +type: Literal['input_text']
        +text: str | None
    }

    class InputAudio <<Pydantic>> {
        +type: Literal['input_audio']
        +audio: str | None
        +transcript: str | None
    }

    class InputImage <<Pydantic>> {
        +type: Literal['input_image']
        +image_url: str | None
        +detail: str | None
    }

    ' ── Assistant content types ─────────────────────────
    class AssistantText <<Pydantic>> {
        +type: Literal['text']
        +text: str | None
    }

    class AssistantAudio <<Pydantic>> {
        +type: Literal['audio']
        +audio: str | None
        +transcript: str | None
    }
}

note right of RealtimeResponse
  RealtimeMessageItem (union) =
  SystemMessageItem | UserMessageItem
  | AssistantMessageItem
  (message-only subset of RealtimeItem)
end note

note bottom of UserMessageItem
  Audio data convention:
  model-layer uses <b>bytes</b>;
  item/response layer uses
  <b>base64-encoded strings</b>
end note

' ═══════════════════════════════════════════════════════
' MODEL INPUTS — client → model send events
' Union type: RealtimeModelSendEvent
' ═══════════════════════════════════════════════════════

package "Model Inputs  ·  RealtimeModelSendEvent  (union)" #FFF3E0 {

    class RealtimeModelSendUserInput <<dataclass>> {
        +user_input: str | RealtimeModelUserInputMessage
    }

    class RealtimeModelSendAudio <<dataclass>> {
        +audio: bytes
        +commit: bool = False
    }

    class RealtimeModelSendToolOutput <<dataclass>> {
        +tool_call: RealtimeModelToolCallEvent
        +output: str
        +start_response: bool
    }

    class RealtimeModelSendInterrupt <<dataclass>> {
        +force_response_cancel: bool = False
    }

    class RealtimeModelSendSessionUpdate <<dataclass>> {
        +session_settings: RealtimeSessionModelSettings
    }

    class RealtimeModelSendRawMessage <<dataclass>> {
        +message: RealtimeModelRawClientMessage
    }

    class RealtimeModelRawClientMessage <<TypedDict>> {
        +type: str
        +other_data: NotRequired[dict[str, Any]]
    }

    class RealtimeModelUserInputMessage <<TypedDict>> {
        +type: Literal['message']
        +role: Literal['user']
        +content: list[RealtimeModelInputTextContent | RealtimeModelInputImageContent]
    }

    class RealtimeModelInputTextContent <<TypedDict>> {
        +type: Literal['input_text']
        +text: str
    }

    class RealtimeModelInputImageContent <<TypedDict>> {
        +type: Literal['input_image']
        +image_url: str
        +detail: NotRequired[str]
    }
}

' ═══════════════════════════════════════════════════════
' KEY RELATIONSHIPS
' ═══════════════════════════════════════════════════════

' ── Bridge: session layer wraps model layer ──────────────
RealtimeRawModelEvent ..> RealtimeModelToolCallEvent : wraps via\nRealtimeModelEvent union
RealtimeAudio *-- RealtimeModelAudioEvent : audio (bytes)

' ── Session events share RealtimeEventInfo ───────────────
RealtimeAgentStartEvent *-- RealtimeEventInfo : info
RealtimeHandoffEvent *-- RealtimeEventInfo : info
RealtimeToolStart *-- RealtimeEventInfo : info
RealtimeRawModelEvent *-- RealtimeEventInfo : info
RealtimeHistoryUpdated *-- RealtimeEventInfo : info
RealtimeGuardrailTripped *-- RealtimeEventInfo : info

' ── Items referenced by session events ───────────────────
RealtimeHistoryUpdated o-- UserMessageItem : history list
RealtimeHistoryAdded o-- SystemMessageItem : item
RealtimeModelItemUpdatedEvent o-- AssistantMessageItem : item

' ── Content composition ──────────────────────────────────
UserMessageItem o-- InputText : content
UserMessageItem o-- InputAudio : content
UserMessageItem o-- InputImage : content
SystemMessageItem o-- InputText : content
AssistantMessageItem o-- AssistantText : content
AssistantMessageItem o-- AssistantAudio : content
RealtimeResponse o-- AssistantMessageItem : output

' ── Model inputs reference model events & payloads ───────
RealtimeModelSendToolOutput ..> RealtimeModelToolCallEvent : references tool_call
RealtimeModelSendRawMessage *-- RealtimeModelRawClientMessage : message
RealtimeModelSendUserInput ..> RealtimeModelUserInputMessage : structured input
RealtimeModelUserInputMessage o-- RealtimeModelInputTextContent : content
RealtimeModelUserInputMessage o-- RealtimeModelInputImageContent : content

' ═══════════════════════════════════════════════════════
' ARCHITECTURE NOTES
' ═══════════════════════════════════════════════════════

note as ArchNote
  <b>Two-Tier Event Architecture</b>
  ─────────────────────────────────────────
  <b>Session layer</b> (RealtimeSessionEvent):
    High-level events emitted to app listeners.
    All carry RealtimeEventInfo (RunContextWrapper).

  <b>Model layer</b> (RealtimeModelEvent):
    Raw/transport events from the model API.
    Exposed via RealtimeRawModelEvent bridge.

  <b>Items layer</b> (RealtimeItem):
    Discriminated union — role discriminates
    message variants; type='function_call'
    for tool calls. input_filter NOT supported
    for RealtimeAgent handoffs.

  <b>Inputs layer</b> (RealtimeModelSendEvent):
    All outbound client→model commands:
    user input, audio, tool output,
    interrupt, session update, raw message.
end note

@enduml
