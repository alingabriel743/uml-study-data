@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Sandbox – Entries & Mounts

' ─────────────────────────────────────────────
'  EXTERNAL / SUPPORT TYPES
' ─────────────────────────────────────────────
package "External / Support" <<Frame>> {
    class BaseSandboxSession <<external>> {
        +exec(cmd): ExecResult
        +mkdir(path): None
        +write(path, data): None
        +state: SandboxState
    }

    class MaterializedFile <<external>> {
        +path: Path
        +sha256: str
    }

    class Permissions <<external>> {
        +owner: FileMode
        +group: FileMode
        +other: FileMode
        +is_dir: bool
    }

    abstract class MountPattern <<external>> {
        +apply(config, session, path): None
        +unapply(config, session, path): None
    }

    class RcloneMountPattern <<external>>
    class MountpointMountPattern <<external>>
    class FuseMountPattern <<external>>

    RcloneMountPattern --|> MountPattern
    MountpointMountPattern --|> MountPattern
    FuseMountPattern --|> MountPattern
}

' ─────────────────────────────────────────────
'  ENTRY HIERARCHY
' ─────────────────────────────────────────────
package "entries" {

    abstract class BaseEntry {
        {static} -_subclass_registry: ClassVar[dict[str, type[BaseEntry]]]
        {static} -_abstract_entry_base: ClassVar[bool]
        +type: str
        +description: str | None
        +ephemeral: bool = False
        +group: Group | User | None
        +is_dir: bool = False
        +permissions: Permissions
        --
        {static} +registered_types(): dict[str, type[BaseEntry]]
        {static} +parse(payload): BaseEntry
        +_apply_metadata(session, dest): None
        {abstract} +apply(session, dest, base_dir): list[MaterializedFile]
    }
    note right of BaseEntry
      **Registry pattern**: subclasses auto-register
      via __pydantic_init_subclass__.
      parse() dispatches by 'type' literal field.
    end note

    class Dir {
        +type: Literal['dir'] = 'dir'
        +is_dir: bool = True
        +children: dict[str | Path, BaseEntry]
        --
        +apply(session, dest, base_dir): list[MaterializedFile]
    }

    class File {
        +type: Literal['file'] = 'file'
        +content: bytes
        --
        +apply(session, dest, base_dir): list[MaterializedFile]
    }

    class LocalFile {
        +type: Literal['local_file'] = 'local_file'
        +src: Path
        --
        +apply(session, dest, base_dir): list[MaterializedFile]
    }
    note bottom of LocalFile
      Computes sha256 before upload;
      raises LocalFileReadError /
      LocalChecksumError on failure.
    end note

    class LocalDir {
        +type: Literal['local_dir'] = 'local_dir'
        +is_dir: bool = True
        +src: Path | None
        --
        +apply(session, dest, base_dir, user): list[MaterializedFile]
        -_resolve_local_dir_src_root(base_dir): Path
        -_list_local_dir_files(base_dir, src_root): list[Path]
        -_copy_local_dir_file(...): MaterializedFile
    }
    note bottom of LocalDir
      Uses dir-fd pinning (O_DIRECTORY/O_NOFOLLOW)
      on Linux. Symlinks are **rejected**.
      Concurrent copy via gather_in_order().
    end note

    class GitRepo {
        +type: Literal['git_repo'] = 'git_repo'
        +is_dir: bool = True
        +host: str = 'github.com'
        +repo: str
        +ref: str
        +subpath: str | None
        --
        +apply(session, dest, base_dir): list[MaterializedFile]
        -_clone_named_ref(session, url, tmp_dir): ExecResult
        -_fetch_commit_ref(session, url, tmp_dir): ExecResult
        {static} -_looks_like_commit_ref(ref): bool
    }
    note bottom of GitRepo
      Tries fetch-by-commit-sha first for
      40-char hex hashes; falls back to
      clone --branch.
    end note

    BaseEntry <|-- Dir
    BaseEntry <|-- File
    BaseEntry <|-- LocalFile
    BaseEntry <|-- LocalDir
    BaseEntry <|-- GitRepo

    Dir *-- BaseEntry : children
}

' ─────────────────────────────────────────────
'  MOUNT ABSTRACTIONS & STRATEGIES
' ─────────────────────────────────────────────
package "entries.mounts" {

    abstract class Mount {
        {static} -_abstract_entry_base: ClassVar[bool] = True
        +is_dir: bool = True
        +mount_path: Path | None
        +ephemeral: bool = True
        +read_only: bool = True
        +mount_strategy: MountStrategy
        --
        +model_post_init(context): None
        +in_container_adapter(): InContainerMountAdapter
        +docker_volume_adapter(): DockerVolumeMountAdapter
        +apply(session, dest, base_dir): list[MaterializedFile]
        +unmount(session, dest, base_dir): None
        +build_in_container_mount_config(session, pattern, include_config_text): MountPatternConfig | None
        +supported_in_container_patterns(): tuple[type[MountPatternBase], ...]
        +supported_docker_volume_drivers(): frozenset[str]
        +build_docker_volume_driver_config(strategy): tuple[str, dict, bool]
        -_resolve_mount_path(session, dest): Path
    }
    note right of Mount
      **Always ephemeral** – snapshots exclude
      mount state. apply() delegates to
      mount_strategy.activate().
      Permissions reset to 755 with warning.
    end note

    abstract class MountStrategyBase {
        {static} -_subclass_registry: ClassVar[dict[str, type[MountStrategyBase]]]
        +type: str
        --
        {static} +parse(payload): MountStrategyBase
        {abstract} +validate_mount(mount): None
        +supports_native_snapshot_detach(mount): bool
        {abstract} +activate(mount, session, dest, base_dir): list[MaterializedFile]
        {abstract} +deactivate(mount, session, dest, base_dir): None
        {abstract} +teardown_for_snapshot(mount, session, path): None
        {abstract} +restore_after_snapshot(mount, session, path): None
        {abstract} +build_docker_volume_driver_config(mount): tuple | None
    }

    class InContainerMountStrategy {
        +type: Literal['in_container'] = 'in_container'
        +pattern: MountPattern
        --
        +validate_mount(mount): None
        +activate(mount, session, dest, base_dir): list[MaterializedFile]
        +deactivate(mount, session, dest, base_dir): None
        +teardown_for_snapshot(mount, session, path): None
        +restore_after_snapshot(mount, session, path): None
        +build_docker_volume_driver_config(mount): None
    }
    note bottom of InContainerMountStrategy
      All lifecycle calls delegate to
      mount.in_container_adapter().
    end note

    class DockerVolumeMountStrategy {
        +type: Literal['docker_volume'] = 'docker_volume'
        +driver: str
        +driver_options: dict[str, str]
        --
        +validate_mount(mount): None
        +activate(mount, session, dest, base_dir): list[MaterializedFile]
        +deactivate(mount, session, dest, base_dir): None
        +teardown_for_snapshot(mount, session, path): None
        +restore_after_snapshot(mount, session, path): None
        +build_docker_volume_driver_config(mount): tuple[str, dict, bool] | None
    }
    note bottom of DockerVolumeMountStrategy
      activate/deactivate are **no-ops**;
      backend attaches volumes before session
      starts. Requires supports_docker_volume_mounts().
    end note

    class InContainerMountAdapter {
        -_mount: Mount
        --
        +__init__(mount: Mount)
        +validate(strategy: InContainerMountStrategy): None
        +activate(strategy, session, dest, base_dir): list[MaterializedFile]
        +deactivate(strategy, session, dest, base_dir): None
        +teardown_for_snapshot(strategy, session, path): None
        +restore_after_snapshot(strategy, session, path): None
    }
    note bottom of InContainerMountAdapter
      Calls mount.build_in_container_mount_config()
      then strategy.pattern.apply()/unapply().
    end note

    class DockerVolumeMountAdapter {
        -_mount: Mount
        --
        +__init__(mount: Mount)
        +validate(strategy: DockerVolumeMountStrategy): None
        +build_docker_volume_driver_config(strategy): tuple[str, dict, bool]
    }

    MountStrategyBase <|-- InContainerMountStrategy
    MountStrategyBase <|-- DockerVolumeMountStrategy

    Mount *-- MountStrategyBase : mount_strategy\n(composition)
    InContainerMountAdapter --> Mount : wraps (_mount)
    DockerVolumeMountAdapter --> Mount : wraps (_mount)
    InContainerMountStrategy ..> InContainerMountAdapter : delegates lifecycle\nvia in_container_adapter()
    DockerVolumeMountStrategy ..> DockerVolumeMountAdapter : delegates driver config\nvia docker_volume_adapter()
    InContainerMountAdapter ..> MountPattern : calls apply()/unapply()
}

' ─────────────────────────────────────────────
'  CLOUD STORAGE PROVIDERS
' ─────────────────────────────────────────────
package "entries.mounts.providers" {

    abstract class _ConfiguredMount {
        --
        #_require_mount_pattern(): MountPattern
        +in_container_adapter(): InContainerMountAdapter
        +docker_volume_adapter(): DockerVolumeMountAdapter
        {static} #_require_session_id_hex(session, mount_type): str
        {static} #_join_remote_path(root, prefix): str
        #_build_rclone_config(session, pattern, remote_kind, remote_path, required_lines, include_config_text): RcloneMountConfig
        {abstract} +build_in_container_mount_config(session, pattern, include_config_text): MountPatternConfig
    }
    note right of _ConfiguredMount
      **Template Method**: _build_rclone_config()
      is the shared rclone builder; providers
      supply only _rclone_required_lines().
    end note

    class S3Mount {
        +type: Literal['s3_mount'] = 's3_mount'
        +bucket: str
        +access_key_id: str | None
        +secret_access_key: str | None
        +session_token: str | None
        +prefix: str | None
        +region: str | None
        +endpoint_url: str | None
        +s3_provider: str = 'AWS'
        --
        +supported_in_container_patterns(): tuple
        +supported_docker_volume_drivers(): frozenset
        +build_docker_volume_driver_config(strategy): tuple[str, dict, bool]
        +build_in_container_mount_config(session, pattern, include_config_text): MountPatternConfig
        -_rclone_required_lines(remote_name): list[str]
    }
    note bottom of S3Mount
      Drivers: **rclone** + **mountpoint**.
      Uses env_auth=true when no credentials
      provided (IAM role passthrough).
    end note

    class GCSMount {
        +type: Literal['gcs_mount'] = 'gcs_mount'
        +bucket: str
        +access_id: str | None
        +secret_access_key: str | None
        +prefix: str | None
        +region: str | None
        +endpoint_url: str | None
        +service_account_file: str | None
        +service_account_credentials: str | None
        +access_token: str | None
        --
        +supported_in_container_patterns(): tuple
        +supported_docker_volume_drivers(): frozenset
        -_use_s3_compatible_rclone(): bool
        -_rclone_remote_kind(): str
        +build_docker_volume_driver_config(strategy): tuple[str, dict, bool]
        +build_in_container_mount_config(session, pattern, include_config_text): MountPatternConfig
        -_rclone_required_lines(remote_name): list[str]
        -_s3_compatible_rclone_required_lines(remote_name): list[str]
    }
    note bottom of GCSMount
      **Dual auth**: HMAC → rclone S3+GCS provider;
      native GCS → rclone google cloud storage.
      Default endpoint: storage.googleapis.com.
    end note

    class AzureBlobMount {
        +type: Literal['azure_blob_mount'] = 'azure_blob_mount'
        +account: str
        +container: str
        +endpoint: str | None
        +identity_client_id: str | None
        +account_key: str | None
        --
        +supported_in_container_patterns(): tuple
        +supported_docker_volume_drivers(): frozenset
        +build_docker_volume_driver_config(strategy): tuple[str, dict, bool]
        +build_in_container_mount_config(session, pattern, include_config_text): MountPatternConfig
        -_rclone_required_lines(remote_name): list[str]
    }
    note bottom of AzureBlobMount
      In-container: rclone + **blobfuse2** (Fuse).
      Docker driver: **rclone only** (no mountpoint).
      Auth: account_key or MSI (use_msi=true).
    end note

    class R2Mount {
        +type: Literal['r2_mount'] = 'r2_mount'
        +bucket: str
        +account_id: str
        +access_key_id: str | None
        +secret_access_key: str | None
        +custom_domain: str | None
        --
        -_validate_credential_pair(): None
        +supported_in_container_patterns(): tuple
        +supported_docker_volume_drivers(): frozenset
        +build_docker_volume_driver_config(strategy): tuple[str, dict, bool]
        +build_in_container_mount_config(session, pattern, include_config_text): MountPatternConfig
        -_rclone_required_lines(remote_name): list[str]
    }
    note bottom of R2Mount
      **rclone only** – no mountpoint/fuse.
      Uses rclone S3 backend (provider=Cloudflare).
      Endpoint: {account_id}.r2.cloudflarestorage.com
      or custom_domain.
    end note

    _ConfiguredMount <|-- S3Mount
    _ConfiguredMount <|-- GCSMount
    _ConfiguredMount <|-- AzureBlobMount
    _ConfiguredMount <|-- R2Mount
}

' ─────────────────────────────────────────────
'  CROSS-PACKAGE INHERITANCE
' ─────────────────────────────────────────────
BaseEntry <|-- Mount
Mount <|-- _ConfiguredMount

' ─────────────────────────────────────────────
'  USAGE RELATIONSHIPS
' ─────────────────────────────────────────────
BaseEntry ..> BaseSandboxSession : uses in apply() /\n_apply_metadata()
BaseEntry ..> MaterializedFile : produces
BaseEntry ..> Permissions : has

S3Mount ..> RcloneMountPattern : supports
S3Mount ..> MountpointMountPattern : supports
GCSMount ..> RcloneMountPattern : supports
GCSMount ..> MountpointMountPattern : supports
AzureBlobMount ..> RcloneMountPattern : supports
AzureBlobMount ..> FuseMountPattern : supports
R2Mount ..> RcloneMountPattern : supports (only)

@enduml
