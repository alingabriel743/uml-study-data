' ═══════════════════════════════════════════════════════════
'  RUNLOOP PROVIDER
' ═══════════════════════════════════════════════════════════
package "Runloop — runloop.ai" {

    class RunloopSandboxSession {
        +state: RunloopSandboxSessionState
        -_sdk: Any
        -_devbox: Any
        -_skip_start: bool
    }

    class RunloopSandboxClient {
        +backend_id = "runloop"
        +supports_default_options = True
        -_sdk: AsyncRunloopSDK
        -_platform: RunloopPlatformClient
        -_instrumentation: Instrumentation
        --
        +create(*, snapshot, manifest, options): SandboxSession
    }

    class RunloopSandboxClientOptions <<pydantic>> {
        +type: Literal["runloop"]
        +blueprint_id: str | None
        +blueprint_name: str | None
        +pause_on_exit: bool = False
        +exposed_ports: tuple[int, ...]
        +tunnel: RunloopTunnelConfig | None
        +gateways: dict[str, RunloopGatewaySpec] | None
        +mcp: dict[str, RunloopMcpSpec] | None
        +managed_secrets: dict[str, str] | None
    }

    class RunloopSandboxSessionState <<pydantic>> {
        +type: Literal["runloop"]
        +devbox_id: str
        +blueprint_id: str | None
        +pause_on_exit: bool
        +timeouts: RunloopTimeouts
        +tunnel: RunloopTunnelConfig | None
        +gateways: dict[str, RunloopGatewaySpec]
        +mcp: dict[str, RunloopMcpSpec]
        +secret_refs: dict[str, str]
    }

    class RunloopPlatformClient {
        +blueprints: RunloopPlatformBlueprintsClient
        +benchmarks: RunloopPlatformBenchmarksClient
        +secrets: RunloopPlatformSecretsClient
        +network_policies: RunloopPlatformNetworkPoliciesClient
        +axons: RunloopPlatformAxonsClient
    }

    class RunloopCloudBucketMountStrategy <<pydantic>> {
        +type: str
    }
}

note bottom of RunloopSandboxClientOptions
  Devbox-based execution. Rich platform API:
  blueprints, benchmarks, secrets, network_policies, axons.
  Public tunnel + MCP gateway specs. Lazy SDK import.
  Only provider with supports_default_options = True.
end note

