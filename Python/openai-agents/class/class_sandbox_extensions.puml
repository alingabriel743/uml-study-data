title Sandbox – Cloud Provider Extensions

' ═══════════════════════════════════════════════════════════
'  CORE BASE CLASSES
' ═══════════════════════════════════════════════════════════
package "Core — agents.sandbox.session" {

    abstract class BaseSandboxSession {
        +state: SandboxSessionState
        #_dependencies: Dependencies
        #_pre_stop_hooks: list[Callable]
        --
        +start(): None
        +stop(): None
        +shutdown(): None
        +exec(cmd, ...): ExecResult
        +read(path, *, user): IOBase
        +write(path, data, *, user): None
        +running(): bool
        +persist_workspace(): IOBase
        +hydrate_workspace(data): None
        +ls(path): list
        +rm(path): None
        +mkdir(path): None
        +resolve_exposed_port(port): ExposedPortEndpoint
        +supports_pty(): bool
        +pty_exec_start(...): int
        +pty_write_stdin(process_id, payload): None
        +pty_terminate_all(): None
        #{abstract} _exec_internal(...)
        #{abstract} _resolve_exposed_port(port)
        #{abstract} _ensure_backend_started()
        #{abstract} _prepare_backend_workspace()
        #{abstract} _after_start()
        #{abstract} _shutdown_backend()
    }

    abstract class BaseSandboxClient {
        +backend_id: str
        +supports_default_options: bool = False
        #_dependencies: Dependencies | None
        --
        +{abstract} create(*, snapshot, manifest, options): SandboxSession
        +delete(session): SandboxSession
        +resume(state, ...): SandboxSession
        +serialize_session_state(state): dict
        +deserialize_session_state(payload): SandboxSessionState
    }

    class BaseSandboxClientOptions <<pydantic>> {
        +type: str
        +{static} _subclass_registry: dict
        --
        +{static} parse(payload): BaseSandboxClientOptions
    }

    class SandboxSessionState <<pydantic>> {
        +type: str
        +session_id: UUID
        +snapshot: SnapshotBase
        +manifest: Manifest
        +exposed_ports: tuple[int, ...]
        +snapshot_fingerprint: str | None
        +workspace_root_ready: bool
        +{static} _subclass_registry: dict
    }

    abstract class MountStrategyBase <<pydantic>> {
        +type: str
    }
}

' ═══════════════════════════════════════════════════════════
'  MODAL PROVIDER
' ═══════════════════════════════════════════════════════════
package "Modal — modal.com" {

    class ModalSandboxSession {
        +state: ModalSandboxSessionState
        -_sandbox: modal.Sandbox | None
        -_image: modal.Image | None
        -_running: bool
        -_pty_lock: asyncio.Lock
        -_pty_processes: dict[int, _ModalPtyProcessEntry]
        --
        +snapshot_filesystem(): str
        -_persist_workspace_via_snapshot_filesystem(): IOBase
        -_persist_workspace_via_snapshot_directory(): IOBase
        -_persist_workspace_via_tar(): IOBase
    }

    class ModalSandboxClient {
        +backend_id = "modal"
        -_default_image: ModalImageSelector | None
        -_default_sandbox: ModalSandboxSelector | None
        -_instrumentation: Instrumentation
        --
        +create(*, snapshot, manifest, options): SandboxSession
        +delete(session): SandboxSession
        +resume(state, ...): SandboxSession
        +deserialize_session_state(payload): SandboxSessionState
    }

    class ModalSandboxClientOptions <<pydantic>> {
        +type: Literal["modal"]
        +app_name: str
        +gpu: str | None
        +timeout: int = 300
        +workspace_persistence: WorkspacePersistenceMode = "tar"
        +exposed_ports: tuple[int, ...]
        +use_sleep_cmd: bool = True
        +sandbox_create_timeout_s: float | None
    }

    class ModalSandboxSessionState <<pydantic>> {
        +type: Literal["modal"]
        +app_name: str
        +image_id: str | None
        +image_tag: str | None
        +sandbox_id: str | None
        +gpu: str | None
        +timeout: int
        +workspace_persistence: WorkspacePersistenceMode
        +sandbox_create_timeout_s: float
    }

    class ModalImageSelector {
        +from_image()
        +from_id()
        +from_tag()
    }

    class ModalSandboxSelector {
    }

    class ModalCloudBucketMountStrategy <<pydantic>> {
        +type: str
    }
}

note bottom of ModalSandboxClientOptions
  GPU support: A100, H100:8.
  workspace_persistence: tar |
  snapshot_filesystem | snapshot_directory
end note

' ═══════════════════════════════════════════════════════════
'  E2B PROVIDER
