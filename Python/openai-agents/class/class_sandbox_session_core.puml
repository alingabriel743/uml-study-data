    }

    class Manifest <<external>> {
    }
}

' ─────────────────────────────────────────────
'  Session package
' ─────────────────────────────────────────────
package "agents.sandbox.session" {

    abstract class BaseSandboxSession {
        ' ── State ──
        +state: SandboxSessionState
        -_dependencies: Dependencies | None
        -_pre_stop_hooks: list[Callable] | None
        -_start_workspace_state_preserved: bool
        -_start_system_state_preserved: bool
        -_runtime_helpers_installed: set[Path] | None
        ' ── Lifecycle (Template Method) ──
        +async start(): None
        +async stop(): None
        +async shutdown(): None
        +async aclose(): None
        ' ── Hook points (overridden by subclasses) ──
        #async _ensure_backend_started(): None
        #async _prepare_backend_workspace(): None
        #async _after_start(): None
        #async _before_stop(): None
        #async _shutdown_backend(): None
        ' ── File system API ──
        +async ls(path): list[FileEntry]
        +async rm(path): None
        +async mkdir(path): None
        ' ── Execution API ──
        +async exec(*command, timeout, shell, user): ExecResult
        +{abstract} async _exec_internal(*command, timeout): ExecResult
        ' ── I/O API ──
        +{abstract} async read(path): IOBase
        +{abstract} async write(path, data): None
        ' ── Snapshot API ──
        +{abstract} async persist_workspace(): IOBase
        +{abstract} async hydrate_workspace(data): None
        +async _start_workspace(): None
        +async _persist_snapshot(): None
        ' ── PTY API ──
        +async pty_exec_start(*command): PtyExecUpdate
        +async pty_write_stdin(session_id, chars): PtyExecUpdate
        +async pty_terminate_all(): None
        +async running(): bool
        ' ── Capabilities ──
        +supports_pty(): bool
        +supports_docker_volume_mounts(): bool
        +normalize_path(path): Path
        ' ── Manifest ──
        +async apply_manifest(only_ephemeral): MaterializationResult
        +async provision_manifest_accounts(): None
        ' ── Dependencies / hooks ──
        +set_dependencies(dependencies): None
        +register_pre_stop_hook(hook): None
        +async run_pre_stop_hooks(): None
        +async resolve_exposed_port(port): ExposedPortEndpoint
    }

    class SandboxSession {
        ' ── Decorator fields ──
        -_inner: BaseSandboxSession
        -_instrumentation: Instrumentation
        -_seq: int
        ' ── Instrumented lifecycle ──
        +async start(): None
        +async stop(): None
        +async shutdown(): None
        ' ── Instrumented operations ──
        +async exec(*command, timeout, shell, user): ExecResult
        +async read(path, user): IOBase
        +async write(path, data, user): None
        +async running(): bool
        +async persist_workspace(): IOBase
        +async hydrate_workspace(data): None
        +async resolve_exposed_port(port): ExposedPortEndpoint
        ' ── Passthrough (not instrumented) ──
        +async ls(path, user): list[FileEntry]
        +async rm(path, recursive, user): None
        +async mkdir(path, parents, user): None
        +async pty_exec_start(*command): PtyExecUpdate
        +async pty_write_stdin(session_id, chars): PtyExecUpdate
        +async pty_terminate_all(): None
        ' ── Proxied properties ──
        +{property} state: SandboxSessionState
        +{property} dependencies: Dependencies
        +normalize_path(path): Path
        +supports_pty(): bool
        ' ── Internal ──
        -async _annotate(op, start_data, run, finish_data, ok, outputs): T
        -async _emit_start_event(...): None
        -async _emit_finish_event(...): None
        -_next_seq(): int
    }

    class SandboxSessionState <<pydantic.BaseModel>> {
        ' ── Discriminator ──
        +type: str
        ' ── Identity ──
        +session_id: UUID
        ' ── Content ──
        +snapshot: SnapshotBase
        +manifest: Manifest
        +exposed_ports: tuple[int, ...]
        ' ── Fingerprint ──
        +snapshot_fingerprint: str | None
        +snapshot_fingerprint_version: str | None
        +workspace_root_ready: bool
        ' ── Registry ──
        -{static} _subclass_registry: dict[str, SessionStateClass]
        ' ── Methods ──
        +{classmethod} parse(payload): SandboxSessionState
        +{classmethod} __pydantic_init_subclass__(**kwargs): None
    }

}

