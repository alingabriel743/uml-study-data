@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Tools & Function Schema

' =====================================================
' Tool Union type note
' =====================================================
note as ToolUnionNote
  **Tool** (Union Discriminator)
  FunctionTool | FileSearchTool | WebSearchTool
  ComputerTool | HostedMCPTool | CustomTool | ShellTool
  ApplyPatchTool | LocalShellTool | ImageGenerationTool
  CodeInterpreterTool | ToolSearchTool
end note

' =====================================================
' agents.tool
' =====================================================
package "agents.tool" {

    class FunctionTool <<dataclass>> {
        +name: str
        +description: str
        +params_json_schema: dict[str, Any]
        +on_invoke_tool: Callable[[ToolContext, str], Awaitable[Any]]
        +strict_json_schema: bool = True
        +is_enabled: bool | Callable = True
        +tool_input_guardrails: list[ToolInputGuardrail] | None
        +tool_output_guardrails: list[ToolOutputGuardrail] | None
        +needs_approval: bool | Callable = False
        +timeout_seconds: float | None
        +timeout_behavior: ToolTimeoutBehavior
        +defer_loading: bool = False
        -_tool_namespace: str | None
        -_tool_namespace_description: str | None
        -_tool_origin: ToolOrigin | None
        -_is_agent_tool: bool
        -_is_codex_tool: bool
        --
        +qualified_name: str <<property>>
        +__post_init__()
        +__copy__(): FunctionTool
    }

    class FunctionToolResult <<dataclass>> {
        +tool: FunctionTool
        +output: Any
        +run_item: RunItem | None
        +interruptions: list[ToolApprovalItem]
        +agent_run_result: Any | None
    }

    class ToolOrigin <<frozen dataclass>> {
        +type: ToolOriginType
        +mcp_server_name: str | None
        +agent_name: str | None
        +agent_tool_name: str | None
        --
        +to_json_dict(): dict[str, str]
        +from_json_dict(data): ToolOrigin | None <<classmethod>>
    }

    enum ToolOriginType <<str, Enum>> {
        FUNCTION
        MCP
        AGENT_AS_TOOL
    }
}

' =====================================================
' agents.function_schema
' =====================================================
package "agents.function_schema" {

    class FuncSchema <<dataclass>> {
        +name: str
        +description: str | None
        +params_pydantic_model: type[BaseModel]
        +params_json_schema: dict[str, Any]
        +signature: inspect.Signature
        +takes_context: bool = False
        +strict_json_schema: bool = True
        --
        +to_call_args(data: BaseModel): tuple[list[Any], dict[str, Any]]
    }

    class FuncDocumentation <<dataclass>> {
        +name: str
        +description: str | None
        +param_descriptions: dict[str, str] | None
    }
}

' =====================================================
' agents.tool_context
' =====================================================
package "agents.tool_context" {

    class RunContextWrapper <<external>> {
        {field} (context, deps, usage, ...)
    }

    class ToolContext <<dataclass>> {
        +tool_name: str
        +tool_call_id: str
        +tool_arguments: str
        +tool_call: ResponseFunctionToolCall | None
        +tool_namespace: str | None
        +agent: AgentBase | None
        +run_config: RunConfig | None
        --
        +qualified_tool_name: str <<property>>
        +from_agent_context(ctx, tool_call_id, ...): ToolContext <<classmethod>>
    }
}

' =====================================================
' agents.tool_guardrails
' =====================================================
package "agents.tool_guardrails" {

    class ToolInputGuardrailData <<dataclass>> {
        +context: ToolContext[Any]
        +agent: Agent[Any]
    }

    class ToolOutputGuardrailData <<dataclass>> {
        +output: Any
    }

    class ToolInputGuardrail <<dataclass>> {
        +guardrail_function: Callable[[ToolInputGuardrailData], Awaitable[ToolGuardrailFunctionOutput]]
        +name: str | None
        --
        +get_name(): str
        +run(data: ToolInputGuardrailData): ToolGuardrailFunctionOutput <<async>>
    }

    class ToolOutputGuardrail <<dataclass>> {
        +guardrail_function: Callable[[ToolOutputGuardrailData], Awaitable[ToolGuardrailFunctionOutput]]
        +name: str | None
        --
        +get_name(): str
        +run(data: ToolOutputGuardrailData): ToolGuardrailFunctionOutput <<async>>
    }

    class ToolGuardrailFunctionOutput <<dataclass>> {
        +output_info: Any
        +behavior: AllowBehavior | RejectContentBehavior | RaiseExceptionBehavior
        --
        +allow(output_info): ToolGuardrailFunctionOutput <<classmethod>>
        +reject_content(message, output_info): ToolGuardrailFunctionOutput <<classmethod>>
        +raise_exception(output_info): ToolGuardrailFunctionOutput <<classmethod>>
    }

    class ToolInputGuardrailResult <<dataclass>> {
        +guardrail: ToolInputGuardrail[Any]
        +output: ToolGuardrailFunctionOutput
    }

    class ToolOutputGuardrailResult <<dataclass>> {
        +guardrail: ToolOutputGuardrail[Any]
        +output: ToolGuardrailFunctionOutput
    }
}

' =====================================================
' Guardrail Behaviors
' =====================================================
package "Guardrail Behaviors (TypedDicts)" {

    class AllowBehavior <<TypedDict>> {
        +type: Literal['allow']
    }

    class RejectContentBehavior <<TypedDict>> {
        +type: Literal['reject_content']
        +message: str
    }

    class RaiseExceptionBehavior <<TypedDict>> {
        +type: Literal['raise_exception']
    }
}

' =====================================================
' agents.guardrail  (Agent-Level)
' =====================================================
package "agents.guardrail  (Agent-Level)" {

    class InputGuardrail <<dataclass>> {
        +guardrail_function: Callable[..., Awaitable[GuardrailFunctionOutput]]
        +name: str | None
        +run_in_parallel: bool = True
        --
        +get_name(): str
        +run(agent, input, context): InputGuardrailResult <<async>>
    }

    class OutputGuardrail <<dataclass>> {
        +guardrail_function: Callable[..., Awaitable[GuardrailFunctionOutput]]
        +name: str | None
        --
        +get_name(): str
        +run(context, agent, agent_output): OutputGuardrailResult <<async>>
    }

    class GuardrailFunctionOutput <<dataclass>> {
        +output_info: Any
        +tripwire_triggered: bool
    }

    class InputGuardrailResult <<dataclass>> {
        +guardrail: InputGuardrail[Any]
        +output: GuardrailFunctionOutput
    }

    class OutputGuardrailResult <<dataclass>> {
        +guardrail: OutputGuardrail[Any]
        +agent_output: Any
        +agent: Agent[Any]
        +output: GuardrailFunctionOutput
    }
}

' =====================================================
' Tool Variants (Union Members)
' =====================================================
package "Tool Variants" {

    class FileSearchTool <<dataclass>> {
