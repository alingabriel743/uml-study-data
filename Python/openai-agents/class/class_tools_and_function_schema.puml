        +on_approval_request: MCPToolApprovalFunction | None
        +name: str <<property>> = "hosted_mcp"
    }

    class ToolSearchTool <<dataclass>> {
        +description: str | None
        +execution: Literal['server','client'] | None
        +parameters: object | None
        +name: str <<property>> = "tool_search"
    }

    class ShellTool <<dataclass>> {
        +executor: ShellExecutor | None
        +needs_approval: bool | ShellApprovalFunction
