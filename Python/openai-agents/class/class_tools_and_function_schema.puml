    }

    class CustomTool <<dataclass>> {
        +name: str
        +description: str
        +needs_approval: bool | CustomToolApprovalFunction
        +defer_loading: bool
    }

    class LocalShellTool <<dataclass>> {
        +executor: LocalShellExecutor
        +name: str <<property>> = "local_shell"
    }

    class ImageGenerationTool <<dataclass>> {
        +tool_config: ImageGeneration
        +name: str <<property>> = "image_generation"
    }

    class CodeInterpreterTool <<dataclass>> {
        +tool_config: CodeInterpreter
        +name: str <<property>> = "code_interpreter"
