' =====================================================
' Tool Output Types
' =====================================================
package "Tool Output Types (ValidToolOutputPydanticModels)" {

    class ToolOutputText <<BaseModel>> {
        +type: Literal['text']
        +text: str
    }

    class ToolOutputImage <<BaseModel>> {
        +type: Literal['image']
