@startuml class_tracing_core

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Tracing – Core Traces & Spans

' ─────────────────────────────────────────────
' TRACES
' ─────────────────────────────────────────────
package "traces.py" {

    abstract class Trace {
        {abstract} +trace_id: str
        {abstract} +name: str
        {abstract} +tracing_api_key: str | None
        --
        +__enter__(): Trace
        +__exit__(exc_type, exc_val, exc_tb)
        +start(mark_as_current: bool = False)
        +finish(reset_current: bool = False)
        +export(): dict | None
        +to_json(include_tracing_api_key: bool): dict | None
    }

    class TraceImpl {
        -_name: str
        -_trace_id: str
        -_tracing_api_key: str | None
        +group_id: str | None
        +metadata: dict | None
        -_prev_context_token
        -_processor: TracingProcessor
        -_started: bool
        --
        +__init__(name, trace_id, group_id, metadata,\n  processor, tracing_api_key)
        +start(mark_as_current: bool = False)
        +finish(reset_current: bool = False)
        +export(): dict
    }

    class NoOpTrace {
        +trace_id: str = "no-op"
        --
        +export(): None
    }

    class ReattachedTrace {
        +trace_id: str
        +name: str
        +group_id: str | None
        +metadata: dict | None
        +tracing_api_key: str | None
        --
        +__init__(*, name, trace_id, group_id,\n  metadata, tracing_api_key)
        +start(mark_as_current: bool = False)
        +finish(reset_current: bool = False)
    }

    class TraceState <<dataclass>> {
        +trace_id: str | None
        +workflow_name: str | None
        +group_id: str | None
        +metadata: dict | None
        +tracing_api_key: str | None
        +tracing_api_key_hash: str | None
        +object_type: str | None
        +extra: dict
        --
        +{static} from_trace(trace: Trace | None): TraceState | None
        +{static} from_json(payload: Mapping | None): TraceState | None
        +to_json(include_tracing_api_key: bool): dict | None
    }

}

' ─────────────────────────────────────────────
' SPANS
' ─────────────────────────────────────────────
package "spans.py" {

    abstract class Span~TSpanData~ {
        {abstract} +trace_id: str
        {abstract} +span_id: str
        {abstract} +span_data: TSpanData
        {abstract} +parent_id: str | None
        {abstract} +error: SpanError | None
        {abstract} +started_at: str | None
        {abstract} +ended_at: str | None
        {abstract} +tracing_api_key: str | None
        +trace_metadata: dict | None
        --
        +__enter__(): Span
        +__exit__(exc_type, exc_val, exc_tb)
        +start(mark_as_current: bool = False)
        +finish(reset_current: bool = False)
        +set_error(error: SpanError)
        +export(): dict | None
    }

    class SpanImpl~TSpanData~ {
        -_trace_id: str
        -_span_id: str
        -_parent_id: str | None
        -_started_at: str | None
        -_ended_at: str | None
        -_error: SpanError | None
        -_prev_span_token
        -_processor: TracingProcessor
        -_span_data: TSpanData
        -_tracing_api_key: str | None
        -_trace_metadata: dict | None
        --
        +__init__(trace_id, span_id, parent_id,\n  processor, span_data, tracing_api_key,\n  trace_metadata)
        +start(mark_as_current: bool = False)
        +finish(reset_current: bool = False)
        +export(): dict
    }

    class NoOpSpan~TSpanData~ {
        +trace_id: str = "no-op"
        --
        +export(): None
    }

    class SpanError <<TypedDict>> {
        +message: str
        +data: dict | None
    }

}

' ─────────────────────────────────────────────
' SPAN DATA
' ─────────────────────────────────────────────
package "span_data.py" {

    abstract class SpanData {
        {abstract} +type: str
        --
        {abstract} +export(): dict
    }

    class AgentSpanData {
        +type: str = "agent"
        +name: str
        +handoffs: list | None
        +tools: list | None
        +output_type: str | None
        +metadata: dict | None
    }

    class TaskSpanData {
        +type: str = "task"
        +name: str
        +usage: dict | None
        +metadata: dict | None
    }

    class TurnSpanData {
        +type: str = "turn"
        +turn: int
        +agent_name: str | None
        +usage: dict | None
        +metadata: dict | None
    }

    class FunctionSpanData {
        +type: str = "function"
        +name: str
        +input: str | None
        +output: str | None
        +mcp_data: dict | None
    }

    class GenerationSpanData {
        +type: str = "generation"
        +input: list | None
        +output: list | None
        +model: str | None
        +model_config: dict | None
        +usage: dict | None
    }

    class ResponseSpanData {
        +type: str = "response"
        +response: object
        +input: list | None
        +usage: dict | None
    }

    class HandoffSpanData {
        +type: str = "handoff"
        +from_agent: str | None
        +to_agent: str | None
    }

    class GuardrailSpanData {
        +type: str = "guardrail"
        +name: str
        +triggered: bool
    }

    class CustomSpanData {
        +type: str = "custom"
        +name: str
        +data: dict | None
    }

    class TranscriptionSpanData {
        +type: str = "transcription"
        +input: str | None
        +input_format: str | None
        +output: str | None
        +model: str | None
        +model_config: dict | None
    }

    class SpeechSpanData {
        +type: str = "speech"
        +input: str | None
        +output: bytes | None
        +output_format: str | None
        +model: str | None
        +model_config: dict | None
        +first_content_at: str | None
    }

    class SpeechGroupSpanData {
        +type: str = "speech_group"
        +input: str | None
    }

    class MCPListToolsSpanData {
        +type: str = "mcp_tools"
        +server: str | None
        +result: list | None
    }

}

' ─────────────────────────────────────────────
' CONTEXT
' ─────────────────────────────────────────────
package "context.py" {

    class TraceCtxManager {
        -_workflow_name: str
        -_trace_id: str | None
        -_group_id: str | None
        -_metadata: dict | None
        -_tracing: TracingConfig | None
        -_disabled: bool
        -_trace_state: TraceState | None
        -_reattach_resumed_trace: bool
        -_trace: Trace | None
        --
        +__init__(workflow_name, trace_id, group_id,\n  metadata, tracing, disabled,\n  trace_state, reattach_resumed_trace)
        +__enter__(): TraceCtxManager
        +__exit__()
    }

}

' ─────────────────────────────────────────────
' SCOPE
' ─────────────────────────────────────────────
package "scope.py" {

    class Scope <<utility>> {
        -{static} _current_span: ContextVar<Span | None>
        -{static} _current_trace: ContextVar<Trace | None>
        --
        +{static} get_current_span(): Span | None
        +{static} set_current_span(span): Token
        +{static} reset_current_span(token)
        +{static} get_current_trace(): Trace | None
        +{static} set_current_trace(trace): Token
        +{static} reset_current_trace(token)
    }

}

' ─────────────────────────────────────────────
' INHERITANCE
' ─────────────────────────────────────────────
TraceImpl     --|> Trace
NoOpTrace     --|> Trace
ReattachedTrace --|> Trace

SpanImpl      --|> Span
NoOpSpan      --|> Span

AgentSpanData        --|> SpanData
TaskSpanData         --|> SpanData
TurnSpanData         --|> SpanData
FunctionSpanData     --|> SpanData
GenerationSpanData   --|> SpanData
ResponseSpanData     --|> SpanData
HandoffSpanData      --|> SpanData
GuardrailSpanData    --|> SpanData
CustomSpanData       --|> SpanData
TranscriptionSpanData --|> SpanData
SpeechSpanData       --|> SpanData
SpeechGroupSpanData  --|> SpanData
MCPListToolsSpanData --|> SpanData

' ─────────────────────────────────────────────
' ASSOCIATIONS & DEPENDENCIES
' ─────────────────────────────────────────────

' SpanImpl composes SpanData
SpanImpl *-- SpanData : span_data

' Span carries SpanError
Span o-- SpanError : error

' parent_id links spans within the same trace (self-reference)
Span ..> Span : parent_id (nested spans)

' TraceCtxManager owns and manages a Trace
TraceCtxManager *-- Trace : creates / manages

' TraceCtxManager uses TraceState for resume/reattach
TraceCtxManager ..> TraceState : reads for reattach

' TraceState is a serializable snapshot of Trace metadata
TraceState ..> Trace : from_trace()

' Scope tracks the active Trace and Span via ContextVars
Scope ..> Trace  : set/get current trace
Scope ..> Span   : set/get current span

' TraceImpl and SpanImpl use Scope to register themselves
TraceImpl ..> Scope : updates current trace
SpanImpl  ..> Scope : updates current span
NoOpTrace ..> Scope : updates current trace
NoOpSpan  ..> Scope : updates current span
ReattachedTrace ..> Scope : registers in Scope

' ─────────────────────────────────────────────
' NOTES
' ─────────────────────────────────────────────
note right of Trace
  Root container for all spans in a workflow.
  Supports context-manager (with-statement).
  trace_id format: "trace_<32_alphanumeric>"
end note

note right of NoOpTrace
  Singleton NO_OP_TRACE used when
  tracing is globally disabled.
  Still updates Scope for correct
  context propagation.
end note

note right of ReattachedTrace
  Rebuilt from persisted TraceState.
  Does NOT fire processor.on_trace_start —
  only re-registers in Scope.
  Used for resuming interrupted runs.
end note

note right of TraceState
  Serializable snapshot of trace metadata.
  tracing_api_key stored as SHA-256 hash
  fingerprint for secure state snapshots.
end note

note bottom of Scope
  Static utility class. Uses Python
  contextvars.ContextVar — async/thread-safe
  propagation of current Trace and Span.
end note

note right of SpanImpl
  export() outputs object="trace.span".
  _SPAN_METADATA_ROUTING_KEYS=('agent_harness_id')
  selectively forwarded from trace metadata.
  GeneratorExit: reset_current=False to avoid
  corrupting context on generator cleanup.
end note

note right of GenerationSpanData
  May contain sensitive LLM input/output.
  Capture controlled by
  RunConfig.trace_include_sensitive_data.
end note

note right of SpeechSpanData
  May contain base64-encoded PCM audio data.
  Capture controlled by
  VoicePipelineConfig.trace_include_sensitive_audio_data.
end note

@enduml
