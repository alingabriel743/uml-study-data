@startuml class_utilities_and_schema

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Utilities & Schema Helpers

' в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
' Core Utility Classes (all are module-level function collections)
' в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

package "agents.util" {

    class JSONUtil <<utility>> {
        +validate_json(json_str: str, type_adapter: TypeAdapter[T], partial: bool): T
        -_to_dump_compatible(obj: Any): Any
        -_to_dump_compatible_internal(obj: Any): Any
    }
    note right of JSONUtil
      Supports partial='trailing-strings' via
      pydantic experimental_allow_partial.
      On ValidationError: attaches SpanError to
      current span, then raises ModelBehaviorError.
    end note

    class TypeTransforms <<utility>> {
        +transform_string_function_style(name: str): str
    }
    note right of TypeTransforms
      Converts tool names to valid function-call
      identifiers: spacesв†’underscore,
      non-alphanumericв†’underscore (regex), lowercase.
      Logs warning if transformation occurred.
    end note

    class ErrorTracing <<utility>> {
        +attach_error_to_span(span: Span<Any>, error: SpanError): None
        +attach_error_to_current_span(error: SpanError): None
    }
    note right of ErrorTracing
      attach_error_to_current_span calls
      get_current_span(); logs warning
      if no active span is found.
      Bridges exception handling to tracing layer.
    end note

    class ApprovalsUtil <<utility>> {
        +{async} evaluate_needs_approval_setting(needs_approval_setting: bool | Callable, *args, default: bool, strict: bool): bool
    }
    note right of ApprovalsUtil
      Handles bool or callable (sync or async).
      Awaits if callable returns Awaitable.
      Falls back to default when strict=False.
      Shared between run_internal and realtime
      to avoid cross-package dependencies.
    end note

    class PrettyPrint <<utility>> {
        -_indent(text: str, indent_level: int): str
        -_final_output_str(result: RunResultBase): str
        +pretty_print_result(result: RunResult): str
        +pretty_print_run_error_details(result: RunErrorDetails): str
        +pretty_print_run_result_streaming(result: RunResultStreaming): str
    }
    note right of PrettyPrint
      _final_output_str handles:
      None / str / BaseModel.model_dump_json() / fallback.
      Formats: last/current agent, final output type+value,
      item/response/guardrail counts.
    end note

    class MaybeAwaitable <<type_alias>> {
        +definition: Awaitable[T] | T
    }
    note right of MaybeAwaitable
      Generic TypeAlias used across
      async utilities to accept both
      sync and async callables.
    end note

}

package "agents (strict_schema)" {

    class StrictSchema <<utility>> {
        -{static} _EMPTY_SCHEMA: dict
        +ensure_strict_json_schema(schema: dict): dict
        -_ensure_strict_json_schema(json_schema, path: tuple, root: dict): dict
        +resolve_ref(root: dict, ref: str): object
        +is_dict(obj): TypeGuard[dict]
        +is_list(obj): TypeGuard[list]
        +has_more_than_n_keys(obj: dict, n: int): bool
    }
    note right of StrictSchema
      Recursively mutates JSON schema for OpenAI
      strict mode: sets additionalProperties=False,
      marks all properties required,
      converts oneOfв†’anyOf, inlines $ref when
      co-located with other keys, strips null defaults.
      Adapted from openai-python's _pydantic.py.
    end note

}

' в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
' External Dependencies
' в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

package "agents.exceptions" <<external>> {
    class UserError <<exception>> {
    }
    class ModelBehaviorError <<exception>> {
    }
}

package "agents.tracing" <<external>> {
    class Span <<external>> {
    }
    class SpanError <<external>> {
    }
    class get_current_span <<external>> {
    }
}

package "agents.result (TYPE_CHECKING)" <<external>> {
    class RunResult <<external>> {
    }
    class RunResultStreaming <<external>> {
    }
    class RunResultBase <<external>> {
    }
    class RunErrorDetails <<external>> {
    }
}

package "pydantic" <<external>> {
    class TypeAdapter <<external>> {
    }
    class ValidationError <<external>> {
    }
}

' в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
' Relationships
' в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

' JSONUtil в†’ ErrorTracing (calls attach_error_to_current_span)
JSONUtil ..> ErrorTracing : calls attach_error_to_current_span

' JSONUtil в†’ SpanError (constructs SpanError on ValidationError)
JSONUtil ..> SpanError : constructs

' JSONUtil в†’ ModelBehaviorError (raises on bad JSON)
JSONUtil ..> ModelBehaviorError : raises

' JSONUtil в†’ TypeAdapter / ValidationError (pydantic)
JSONUtil ..> TypeAdapter : uses
JSONUtil ..> ValidationError : catches

' ErrorTracing в†’ tracing layer
ErrorTracing ..> Span : attaches error to
ErrorTracing ..> SpanError : receives
ErrorTracing ..> get_current_span : calls

' StrictSchema в†’ UserError (raises for additionalProperties conflict)
StrictSchema ..> UserError : raises

' ApprovalsUtil в†’ UserError (raises for invalid approval type)
ApprovalsUtil ..> UserError : raises

' ApprovalsUtil в†’ MaybeAwaitable (accepts awaitable callables)
ApprovalsUtil ..> MaybeAwaitable : evaluates

' PrettyPrint в†’ result types (TYPE_CHECKING only)
PrettyPrint ..> RunResult : formats
PrettyPrint ..> RunResultStreaming : formats
PrettyPrint ..> RunResultBase : formats (base)
PrettyPrint ..> RunErrorDetails : formats

@enduml
