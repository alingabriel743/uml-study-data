    "coerce_turn_options(options) -> TurnOptions | None",
    "coerce_thread_event(raw) -> ThreadEvent",
    "coerce_thread_item(raw) -> ThreadItem",
    "codex_tool(options, **kwargs) -> FunctionTool",
    "find_codex_path() -> str  (env CODEX_PATH → PATH → bundled vendor binary)"
  ],

  "important_notes": "codex_tool() is the main integration point that wraps Codex as an agents FunctionTool. persist_session=True reuses a single Thread across calls. use_run_context_thread_id=True stores/reads thread_id from RunContextWrapper keyed by 'codex_thread_id' (default). CodexExec spawns 'codex exec --experimental-json' as a subprocess and reads JSONL events line by line. Stream limit defaults to 8 MiB (configurable via OPENAI_AGENTS_CODEX_SUBPROCESS_STREAM_LIMIT_BYTES env). Thread captures its ID from the first ThreadStartedEvent so callers can resume later."
}
