{
  "scope": "items_and_stream_events",
  "title": "Items & Stream Events",
  "diagram_type": "class",
  "description": "Data models for run items and streaming events in the agents SDK",

  "classes": [
    {
      "name": "RunItemBase",
      "kind": "abstract_dataclass",
      "generic": "T",
      "file": "src/agents/items.py",
      "attributes": [
        "agent: Agent[Any]",
        "raw_item: T",
        "_agent_ref: weakref.ReferenceType[Agent[Any]] | None"
      ],
      "methods": [
        "__post_init__() -> None",
        "__getattribute__(name: str) -> Any",
        "release_agent() -> None",
        "_get_agent_via_weakref(attr_name, ref_name) -> Any",
        "to_input_item() -> TResponseInputItem"
      ],
      "notes": "Uses weakref to agent for memory safety; to_input_item() serializes via model_dump or returns raw dict"
    },
    {
      "name": "MessageOutputItem",
      "kind": "dataclass",
      "extends": "RunItemBase[ResponseOutputMessage]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: ResponseOutputMessage",
        "type: Literal['message_output_item'] = 'message_output_item'"
      ]
    },
    {
      "name": "ToolCallItem",
      "kind": "dataclass",
      "extends": "RunItemBase[Any]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: ToolCallItemTypes",
        "type: Literal['tool_call_item'] = 'tool_call_item'",
        "description: str | None = None",
        "title: str | None = None",
        "tool_origin: ToolOrigin | None = None"
      ],
      "notes": "ToolCallItemTypes = ResponseFunctionToolCall | ResponseComputerToolCall | ResponseFileSearchToolCall | ResponseFunctionWebSearch | McpCall | ResponseCodeInterpreterToolCall | ImageGenerationCall | LocalShellCall | dict"
    },
    {
      "name": "ToolCallOutputItem",
      "kind": "dataclass",
      "extends": "RunItemBase[Any]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: ToolCallOutputTypes",
        "output: Any",
        "type: Literal['tool_call_output_item'] = 'tool_call_output_item'",
        "tool_origin: ToolOrigin | None = None"
      ],
      "methods": [
        "to_input_item() -> TResponseInputItem  # strips shell_call status/shell_output/provider_data"
      ]
    },
    {
      "name": "HandoffCallItem",
      "kind": "dataclass",
      "extends": "RunItemBase[ResponseFunctionToolCall]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: ResponseFunctionToolCall",
        "type: Literal['handoff_call_item'] = 'handoff_call_item'"
      ]
    },
    {
      "name": "HandoffOutputItem",
      "kind": "dataclass",
      "extends": "RunItemBase[TResponseInputItem]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: TResponseInputItem",
        "source_agent: Agent[Any]",
        "target_agent: Agent[Any]",
        "type: Literal['handoff_output_item'] = 'handoff_output_item'",
        "_source_agent_ref: weakref.ReferenceType[Agent[Any]] | None",
        "_target_agent_ref: weakref.ReferenceType[Agent[Any]] | None"
      ],
      "methods": [
        "__post_init__() -> None",
        "__getattribute__(name: str) -> Any",
        "release_agent() -> None"
      ]
    },
    {
      "name": "ReasoningItem",
      "kind": "dataclass",
      "extends": "RunItemBase[ResponseReasoningItem]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: ResponseReasoningItem",
        "type: Literal['reasoning_item'] = 'reasoning_item'"
      ]
    },
    {
      "name": "MCPListToolsItem",
      "kind": "dataclass",
      "extends": "RunItemBase[McpListTools]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: McpListTools",
        "type: Literal['mcp_list_tools_item'] = 'mcp_list_tools_item'"
      ]
    },
    {
      "name": "MCPApprovalRequestItem",
      "kind": "dataclass",
      "extends": "RunItemBase[McpApprovalRequest]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: McpApprovalRequest",
        "type: Literal['mcp_approval_request_item'] = 'mcp_approval_request_item'"
      ]
    },
    {
      "name": "MCPApprovalResponseItem",
      "kind": "dataclass",
      "extends": "RunItemBase[McpApprovalResponse]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: McpApprovalResponse",
        "type: Literal['mcp_approval_response_item'] = 'mcp_approval_response_item'"
      ]
    },
    {
      "name": "CompactionItem",
      "kind": "dataclass",
      "extends": "RunItemBase[TResponseInputItem]",
      "file": "src/agents/items.py",
      "attributes": [
        "type: Literal['compaction_item'] = 'compaction_item'"
      ],
      "methods": [
        "to_input_item() -> TResponseInputItem  # returns raw_item directly"
      ]
    },
    {
      "name": "ToolApprovalItem",
      "kind": "dataclass",
      "extends": "RunItemBase[Any]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: ToolApprovalRawItem",
        "tool_name: str | None = None",
        "type: Literal['tool_approval_item'] = 'tool_approval_item'",
        "tool_namespace: str | None = None",
        "tool_origin: ToolOrigin | None = None",
        "tool_lookup_key: FunctionToolLookupKey | None = None",
        "_allow_bare_name_alias: bool = False"
      ],
      "methods": [
        "__post_init__() -> None  # populates tool_name/namespace/lookup_key from raw_item",
        "__hash__() -> int  # identity-based",
        "__eq__(other) -> bool  # identity-based",
        "name: str | None  # @property",
        "qualified_name: str | None  # @property, collapses synthetic namespaces",
        "arguments: str | None  # @property, JSON-encodes if needed",
        "call_id: str | None  # @property",
        "to_input_item() -> raises AgentsException  # must not be sent as input"
      ],
      "notes": "ToolApprovalRawItem = ResponseFunctionToolCall | McpCall | McpApprovalRequest | LocalShellCall | dict"
    },
    {
      "name": "ToolSearchCallItem",
      "kind": "dataclass",
      "extends": "RunItemBase[ToolSearchCallRawItem]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: ToolSearchCallRawItem",
        "type: Literal['tool_search_call_item'] = 'tool_search_call_item'"
      ],
      "methods": [
        "to_input_item() -> TResponseInputItem  # strips 'created_by'"
      ]
    },
    {
      "name": "ToolSearchOutputItem",
      "kind": "dataclass",
      "extends": "RunItemBase[ToolSearchOutputRawItem]",
      "file": "src/agents/items.py",
      "attributes": [
        "raw_item: ToolSearchOutputRawItem",
        "type: Literal['tool_search_output_item'] = 'tool_search_output_item'"
      ],
      "methods": [
        "to_input_item() -> TResponseInputItem  # strips 'created_by'"
      ]
    },
    {
      "name": "ModelResponse",
      "kind": "pydantic_dataclass",
      "file": "src/agents/items.py",
      "attributes": [
        "output: list[TResponseOutputItem]",
        "usage: Usage",
        "response_id: str | None",
        "request_id: str | None = None"
      ],
      "methods": [
        "to_input_items() -> list[TResponseInputItem]  # sanitizes tool_search items"
      ]
    },
    {
      "name": "ItemHelpers",
      "kind": "class",
      "file": "src/agents/items.py",
      "methods": [
        "extract_last_content(message: TResponseOutputItem) -> str  # @classmethod",
        "extract_last_text(message: TResponseOutputItem) -> str | None  # @classmethod",
        "extract_text(message: TResponseOutputItem) -> str | None  # @classmethod, concatenates all text blocks",
        "input_to_new_input_list(input: str | list[TResponseInputItem]) -> list[TResponseInputItem]  # @classmethod",
        "text_message_outputs(items: list[RunItem]) -> str  # @classmethod",
        "text_message_output(message: MessageOutputItem) -> str  # @classmethod",
        "tool_call_output_item(tool_call: ResponseFunctionToolCall, output: Any) -> FunctionCallOutput  # @classmethod",
        "_convert_tool_output(output: Any) -> str | ResponseFunctionCallOutputItemListParam  # @classmethod",
        "_maybe_get_output_as_structured_function_output(output: Any) -> ValidToolOutputPydanticModels | None  # @classmethod",
        "_convert_single_tool_output_pydantic_model(output: ValidToolOutputPydanticModels) -> ResponseFunctionCallOutputItemParam  # @classmethod"
      ]
    },
    {
      "name": "RawResponsesStreamEvent",
      "kind": "dataclass",
      "file": "src/agents/stream_events.py",
      "attributes": [
        "data: TResponseStreamEvent",
        "type: Literal['raw_response_event'] = 'raw_response_event'"
      ],
      "notes": "Passes through raw LLM events directly"
    },
    {
      "name": "RunItemStreamEvent",
      "kind": "dataclass",
      "file": "src/agents/stream_events.py",
      "attributes": [
        "name: Literal['message_output_created' | 'handoff_requested' | 'handoff_occured' | 'tool_called' | 'tool_search_called' | 'tool_search_output_created' | 'tool_output' | 'reasoning_item_created' | 'mcp_approval_requested' | 'mcp_approval_response' | 'mcp_list_tools']",
        "item: RunItem",
        "type: Literal['run_item_stream_event'] = 'run_item_stream_event'"
      ],
      "notes": "'handoff_occured' is a misspelling kept for backwards compatibility"
    },
    {
      "name": "AgentUpdatedStreamEvent",
      "kind": "dataclass",
      "file": "src/agents/stream_events.py",
      "attributes": [
        "new_agent: Agent[Any]",
        "type: Literal['agent_updated_stream_event'] = 'agent_updated_stream_event'"
      ]
    }
  ],

  "type_aliases": [
    "RunItem = MessageOutputItem | ToolSearchCallItem | ToolSearchOutputItem | HandoffCallItem | HandoffOutputItem | ToolCallItem | ToolCallOutputItem | ReasoningItem | MCPListToolsItem | MCPApprovalRequestItem | MCPApprovalResponseItem | CompactionItem | ToolApprovalItem",
    "StreamEvent = RawResponsesStreamEvent | RunItemStreamEvent | AgentUpdatedStreamEvent",
    "TResponse = Response  (openai)",
    "TResponseInputItem = ResponseInputItemParam  (openai)",
    "TResponseOutputItem = ResponseOutputItem  (openai)",
    "TResponseStreamEvent = ResponseStreamEvent  (openai)",
    "ToolCallItemTypes = ResponseFunctionToolCall | ResponseComputerToolCall | ResponseFileSearchToolCall | ResponseFunctionWebSearch | McpCall | ResponseCodeInterpreterToolCall | ImageGenerationCall | LocalShellCall | dict",
    "ToolCallOutputTypes = FunctionCallOutput | ComputerCallOutput | LocalShellCallOutput | ResponseFunctionShellToolCallOutput | dict",
    "ToolApprovalRawItem = ResponseFunctionToolCall | McpCall | McpApprovalRequest | LocalShellCall | dict",
    "ToolSearchCallRawItem = ResponseToolSearchCall | dict",
    "ToolSearchOutputRawItem = ResponseToolSearchOutputItem | dict"
  ],

  "run_internal_items_module": {
    "file": "src/agents/run_internal/items.py",
    "purpose": "Internal helpers for input normalization, orphan-call pruning, deduplication, and synthetic rejection item construction",
    "key_functions": [
      "run_item_to_input_item(run_item, reasoning_item_id_policy) -> TResponseInputItem | None  # filters tool_approval_item",
      "run_items_to_input_items(run_items, reasoning_item_id_policy) -> list[TResponseInputItem]",
      "prepare_model_input_items(caller_items, generated_items) -> list[TResponseInputItem]  # normalizes + prunes orphan calls",
      "drop_orphan_function_calls(items, pruning_indexes) -> list[TResponseInputItem]",
      "normalize_input_items_for_api(items) -> list[TResponseInputItem]  # coerce to dict + strip internal metadata",
      "normalize_resumed_input(raw_input) -> str | list[TResponseInputItem]",
      "deduplicate_input_items(items) -> list[TResponseInputItem]  # first-wins by id/call_id",
      "deduplicate_input_items_preferring_latest(items) -> list[TResponseInputItem]  # last-wins",
      "fingerprint_input_item(item, ignore_ids_for_matching) -> str | None  # JSON fingerprint for dedupe",
      "strip_internal_input_item_metadata(item) -> TResponseInputItem  # removes _agents_tool_description/_agents_tool_title",
      "function_rejection_item(agent, tool_call, ...) -> ToolCallOutputItem",
      "shell_rejection_item(agent, call_id, ...) -> ToolCallOutputItem",
      "apply_patch_rejection_item(agent, call_id, ...) -> ToolCallOutputItem",
      "extract_mcp_request_id(raw_item) -> str | None",
      "extract_mcp_request_id_from_run(mcp_run) -> str | None"
    ],
    "constants": [
      "TOOL_CALL_SESSION_DESCRIPTION_KEY = '_agents_tool_description'",
      "TOOL_CALL_SESSION_TITLE_KEY = '_agents_tool_title'",
      "ReasoningItemIdPolicy = Literal['preserve', 'omit']",
      "_TOOL_CALL_TO_OUTPUT_TYPE: dict  # maps call type -> output type, e.g. function_call -> function_call_output"
    ]
  },

  "key_relationships": [
    "RunItemBase<T> is abstract base (Generic[T], ABC) for ALL run item types",
    "MessageOutputItem, ToolCallItem, HandoffCallItem, ReasoningItem, MCPListToolsItem, MCPApprovalRequestItem, MCPApprovalResponseItem, CompactionItem, ToolApprovalItem, ToolCallOutputItem, HandoffOutputItem, ToolSearchCallItem, ToolSearchOutputItem all extend RunItemBase",
    "HandoffOutputItem extends RunItemBase and adds source_agent + target_agent (both weakref-backed)",
    "RunItemStreamEvent contains_a RunItem (composition)",
    "RunItemStreamEvent references Agent via AgentUpdatedStreamEvent",
    "StreamEvent is a union of RawResponsesStreamEvent | RunItemStreamEvent | AgentUpdatedStreamEvent",
    "ModelResponse aggregates list[TResponseOutputItem] and Usage",
    "ItemHelpers is a utility class operating on RunItem / TResponseOutputItem / MessageOutputItem",
    "run_internal/items.py depends_on items.py (imports ItemHelpers, RunItem, ToolCallOutputItem, TResponseInputItem)"
  ],

  "important_notes": [
    "All RunItemBase subclasses use weakref for the agent field to enable GC; release_agent() drops the strong ref",
    "ToolApprovalItem.to_input_item() raises AgentsException — these must be filtered before sending to API",
    "tool_search items carry output-only 'created_by' field that must be stripped before replay",
    "RunItem union does NOT include ModelResponse — it is a separate output envelope",
    "ReasoningItemIdPolicy ('preserve'|'omit') controls whether reasoning item IDs are stripped from API input",
    "StreamEvent types are flat dataclasses (not Pydantic), identified by their 'type' literal field",
    "'handoff_occured' is a known misspelling preserved for API backwards compatibility"
  ],

  "openai_sdk_types_used": [
    "Response", "ResponseOutputMessage", "ResponseOutputItem", "ResponseInputItemParam",
    "ResponseStreamEvent", "ResponseFunctionToolCall", "ResponseComputerToolCall",
    "ResponseFileSearchToolCall", "ResponseFunctionWebSearch", "ResponseCodeInterpreterToolCall",
    "ResponseReasoningItem", "ResponseToolSearchCall", "ResponseToolSearchOutputItem",
    "ResponseFunctionShellToolCallOutput", "McpCall", "McpListTools", "McpApprovalRequest",
    "McpApprovalResponse", "ImageGenerationCall", "LocalShellCall", "FunctionCallOutput",
    "ComputerCallOutput", "LocalShellCallOutput"
  ],

  "source_files_analyzed": [
    "src/agents/items.py",
    "src/agents/stream_events.py",
    "src/agents/run_internal/items.py"
  ]
}
