  "key_relationships": [
    "MCPServer <|-- _MCPServerWithClientSession (abstract extends abstract)",
    "_MCPServerWithClientSession <|-- MCPServerStdio",
    "_MCPServerWithClientSession <|-- MCPServerSse",
    "_MCPServerWithClientSession <|-- MCPServerStreamableHttp",
    "MCPServerManager o-- MCPServer (aggregates 0..*)",
    "MCPServerManager *-- _ServerWorker (composes, 0..* for parallel mode)",
    "_ServerWorker --> MCPServer (holds reference, calls connect/cleanup)",
    "_ServerWorker *-- _ServerCommand (queue of commands)",
    "_MCPServerWithClientSession --> ClientSession (holds session: mcp.ClientSession)",
    "_MCPServerWithClientSession --> ToolFilter (uses for filtering)",
    "_MCPServerWithClientSession --> MCPToolMetaResolver (via MCPServer.tool_meta_resolver)",
    "MCPUtil --> MCPServer (calls list_tools, call_tool)",
    "MCPUtil --> MCPToolMetadata (via resolve_mcp_tool_description_for_model, resolve_mcp_tool_title)",
    "MCPUtil --> FunctionTool (produces via _build_wrapped_function_tool)",
    "MCPUtil --> MCPToolMetaContext (creates for meta resolution)",
    "MCPUtil --> ToolFilterContext (indirectly via server._apply_tool_filter)",
    "MCPServerStdio ..> MCPServerStdioParams (uses params TypedDict)",
    "MCPServerSse ..> MCPServerSseParams",
    "MCPServerStreamableHttp ..> MCPServerStreamableHttpParams",
    "MCPServer --> RequireApprovalSetting (normalized at init)"
  ],

  "important_notes": [
    "MCPServer is the abstract protocol interface; 3 concrete transports: stdio, SSE (deprecated), StreamableHttp",
    "_MCPServerWithClientSession provides all real logic: session mgmt, caching, retries, tool filtering, approval policy",
    "MCPServerManager keeps MCP connect/cleanup on same asyncio task (required by AnyIO cancel scopes)",
    "MCPServerManager.connect_in_parallel=True uses _ServerWorker tasks per server; parallel connect but sequential cleanup preserved",
    "Tool filtering: ToolFilterStatic (allowlist/blocklist dict) or ToolFilterCallable (async fn with ToolFilterContext)",
    "Approval policy (require_approval): normalized to bool|dict[str,bool]|Callable; callable receives (run_context, agent, MCPTool)",
    "MCPToolMetadata: frozen dataclass for display metadata (title/description) resolved from MCP tool annotations",
    "collect_mcp_list_tools_metadata: collects hosted MCP metadata from mcp_list_tools response items (server_label, tool name) -> MCPToolMetadata",
    "MCPUtil.to_function_tool: converts MCPTool to FunctionTool, uses schema strict conversion, resolves meta before call_tool",
    "MCPServerStreamableHttp has special isolated session retry logic for request-isolation failures",
    "cache_tools_list: bool controls whether list_tools result is cached; invalidate_tools_cache() forces refresh",
    "failure_error_function: _UNSET means use agent-level default; None means raise errors; explicit fn means convert to model-visible text"
  ]
}
