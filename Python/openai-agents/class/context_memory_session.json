{
  "scope": "memory_session",
  "title": "Memory – Session Management",
  "diagram_type": "class",
  "key_classes": [
    {
      "name": "Session",
      "type": "Protocol",
      "module": "agents.memory.session",
      "decorator": "@runtime_checkable",
      "attributes": [
        "session_id: str",
        "session_settings: SessionSettings | None = None"
      ],
      "methods": [
        "async get_items(limit: int | None = None) -> list[TResponseInputItem]",
        "async add_items(items: list[TResponseInputItem]) -> None",
        "async pop_item() -> TResponseInputItem | None",
        "async clear_session() -> None"
      ],
      "notes": "Runtime-checkable Protocol; intended for third-party implementations"
    },
    {
      "name": "SessionABC",
      "type": "ABC",
      "module": "agents.memory.session",
      "attributes": [
        "session_id: str",
        "session_settings: SessionSettings | None = None"
      ],
      "methods": [
        "@abstractmethod async get_items(limit: int | None = None) -> list[TResponseInputItem]",
        "@abstractmethod async add_items(items: list[TResponseInputItem]) -> None",
        "@abstractmethod async pop_item() -> TResponseInputItem | None",
        "@abstractmethod async clear_session() -> None"
      ],
      "notes": "Internal base class; concrete implementations extend this"
    },
    {
      "name": "OpenAIResponsesCompactionAwareSession",
      "type": "Protocol",
      "module": "agents.memory.session",
      "decorator": "@runtime_checkable",
      "extends": ["Session"],
      "methods": [
        "async run_compaction(args: OpenAIResponsesCompactionArgs | None = None) -> None"
      ]
    },
    {
      "name": "OpenAIResponsesCompactionArgs",
      "type": "TypedDict",
      "module": "agents.memory.session",
      "attributes": [
        "response_id: str (optional)",
        "compaction_mode: Literal['previous_response_id', 'input', 'auto'] (optional)",
        "store: bool (optional)",
        "force: bool (optional)"
      ]
    },
    {
      "name": "SessionSettings",
      "type": "dataclass (pydantic)",
      "module": "agents.memory.session_settings",
      "attributes": [
        "limit: int | None = None"
      ],
      "methods": [
        "resolve(override: SessionSettings | None) -> SessionSettings",
        "to_dict() -> dict[str, Any]"
      ],
      "notes": "Immutable-style; resolve() uses dataclasses.replace() to overlay non-None fields"
    },
    {
      "name": "SQLiteSession",
      "type": "class",
      "module": "agents.memory.sqlite_session",
      "extends": ["SessionABC"],
      "class_attributes": [
        "_file_locks: ClassVar[dict[Path, threading.RLock]]",
        "_file_lock_counts: ClassVar[dict[Path, int]]",
        "_file_locks_guard: ClassVar[threading.Lock]"
      ],
      "instance_attributes": [
        "session_id: str",
        "session_settings: SessionSettings | None",
        "db_path: str | Path",
        "sessions_table: str = 'agent_sessions'",
        "messages_table: str = 'agent_messages'",
        "_local: threading.local",
        "_is_memory_db: bool",
        "_lock: threading.RLock",
        "_lock_path: Path | None",
        "_lock_released: bool",
        "_shared_connection: sqlite3.Connection (memory-only)"
      ],
      "methods": [
        "__init__(session_id, db_path=':memory:', sessions_table, messages_table, session_settings)",
        "@classmethod _acquire_file_lock(db_path) -> tuple[Path, RLock]",
        "@classmethod _release_file_lock(lock_path) -> None",
        "@contextmanager _locked_connection() -> Iterator[sqlite3.Connection]",
        "_get_connection() -> sqlite3.Connection",
        "_init_db_for_connection(conn) -> None",
        "_insert_items(conn, items) -> None",
        "async get_items(limit) -> list[TResponseInputItem]",
        "async add_items(items) -> None",
        "async pop_item() -> TResponseInputItem | None",
        "async clear_session() -> None",
        "close() -> None"
      ],
      "notes": "Uses asyncio.to_thread for all DB ops. WAL mode. Shared conn for :memory:, thread-local for file DBs. Schema: agent_sessions + agent_messages tables with FK."
    },
    {
      "name": "OpenAIConversationsSession",
      "type": "class",
      "module": "agents.memory.openai_conversations_session",
      "extends": ["SessionABC"],
      "instance_attributes": [
        "_session_id: str | None",
        "session_settings: SessionSettings | None",
        "_openai_client: AsyncOpenAI"
      ],
      "properties": [
        "session_id: str (lazy, raises ValueError if not initialized)"
      ],
      "methods": [
        "__init__(conversation_id, openai_client, session_settings)",
        "async _get_session_id() -> str (lazy init via start_openai_conversations_session)",
        "async _clear_session_id() -> None",
        "async get_items(limit) -> list[TResponseInputItem]",
        "async add_items(items) -> None",
        "async pop_item() -> TResponseInputItem | None",
        "async clear_session() -> None"
      ],
      "notes": "Lazy session init: conversation created on first API call. Uses openai.conversations.items API. pop_item fetches last item then deletes by id."
    },
    {
      "name": "OpenAIResponsesCompactionSession",
      "type": "class",
      "module": "agents.memory.openai_responses_compaction_session",
      "extends": ["SessionABC", "OpenAIResponsesCompactionAwareSession"],
      "instance_attributes": [
        "session_id: str",
        "underlying_session: Session",
        "_client: AsyncOpenAI | None",
        "model: str = 'gpt-4.1'",
        "compaction_mode: OpenAIResponsesCompactionMode = 'auto'",
        "should_trigger_compaction: Callable[[dict], bool]",
        "_compaction_candidate_items: list[TResponseInputItem] | None",
        "_session_items: list[TResponseInputItem] | None",
        "_response_id: str | None",
        "_deferred_response_id: str | None",
        "_last_unstored_response_id: str | None"
      ],
      "properties": [
        "client: AsyncOpenAI (lazy init)"
      ],
      "methods": [
        "__init__(session_id, underlying_session, client, model, compaction_mode, should_trigger_compaction)",
        "async run_compaction(args: OpenAIResponsesCompactionArgs | None) -> None",
        "async get_items(limit) -> list[TResponseInputItem]",
        "async add_items(items) -> None",
        "async pop_item() -> TResponseInputItem | None",
        "async clear_session() -> None",
        "async _ensure_compaction_candidates() -> tuple[list, list]",
        "async _defer_compaction(response_id, store) -> None",
        "_get_deferred_compaction_response_id() -> str | None",
        "_clear_deferred_compaction() -> None",
        "_resolve_compaction_mode_for_response(response_id, store, requested_mode) -> _ResolvedCompactionMode"
      ],
      "notes": "Decorator pattern over any Session except OpenAIConversationsSession. Calls openai.responses.compact when threshold met (default=10 candidates). Delegates all CRUD to underlying_session."
    }
  ],
  "module_level_functions": [
    "resolve_session_limit(explicit_limit, settings) -> int | None  [session_settings.py]",
    "async start_openai_conversations_session(openai_client) -> str  [openai_conversations_session.py]",
    "select_compaction_candidate_items(items) -> list  [compaction: excludes user msgs & compaction items]",
    "default_should_trigger_compaction(context) -> bool  [triggers at >=10 candidates]",
    "is_openai_model_name(model) -> bool  [validates gpt-* / o* / ft:gpt-*]",
    "is_openai_responses_compaction_aware_session(session) -> TypeGuard  [session.py]",
    "_resolve_compaction_mode(requested_mode, response_id, store) -> _ResolvedCompactionMode",
    "_strip_orphaned_assistant_ids(items) -> list",
    "_normalize_compaction_output_items(items) -> list",
    "_normalize_compaction_session_items(items) -> list"
  ],
  "key_relationships": [
    "Session (Protocol) — defines interface; SessionABC mirrors it as ABC",
    "OpenAIResponsesCompactionAwareSession extends Session Protocol, adds run_compaction()",
    "SQLiteSession extends SessionABC",
    "OpenAIConversationsSession extends SessionABC",
    "OpenAIResponsesCompactionSession extends SessionABC AND implements OpenAIResponsesCompactionAwareSession",
    "OpenAIResponsesCompactionSession composes/wraps underlying_session: Session (decorator pattern)",
    "SQLiteSession depends_on SessionSettings (via resolve_session_limit)",
    "OpenAIConversationsSession depends_on SessionSettings + AsyncOpenAI",
    "OpenAIResponsesCompactionSession depends_on Session + AsyncOpenAI + OpenAIConversationsSession (excluded)",
    "SessionSettings used by all concrete sessions as optional config",
    "OpenAIResponsesCompactionArgs is a TypedDict parameter passed to run_compaction()"
  ],
  "type_aliases": [
    "OpenAIResponsesCompactionMode = Literal['previous_response_id', 'input', 'auto']",
    "_ResolvedCompactionMode = Literal['previous_response_id', 'input']",
    "TResponseInputItem — imported from agents.items (external type)"
  ],
  "important_notes": [
    "Session is a Protocol (structural typing); SessionABC is for internal/library use",
    "SQLiteSession supports both :memory: (shared conn) and file-backed (thread-local conn + WAL)",
    "OpenAIConversationsSession uses lazy init — session_id raises ValueError until first API call",
    "OpenAIResponsesCompactionSession is a decorator that cannot wrap OpenAIConversationsSession",
    "Compaction threshold default = 10 candidate items (excludes user messages and compaction items)",
    "Compaction mode 'auto' resolves to 'previous_response_id' if stored, 'input' otherwise",
    "All session ops are async; SQLiteSession offloads to asyncio.to_thread"
  ],
  "source_files_analyzed": [
    "src/agents/memory/session.py",
    "src/agents/memory/session_settings.py",
    "src/agents/memory/sqlite_session.py",
    "src/agents/memory/openai_conversations_session.py",
    "src/agents/memory/openai_responses_compaction_session.py"
  ]
}
