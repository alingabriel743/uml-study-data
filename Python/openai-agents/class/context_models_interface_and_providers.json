{
  "scope": "models_interface_and_providers",
  "title": "Models – Interface & Providers",
  "diagram_type": "class",
  "key_classes": [
    {
      "name": "Model",
      "type": "abstract_class",
      "module": "agents.models.interface",
      "methods": [
        "get_response(system_instructions, input, model_settings: ModelSettings, tools, output_schema, handoffs, tracing: ModelTracing, *, previous_response_id, conversation_id, prompt) -> ModelResponse [abstract, async]",
        "stream_response(system_instructions, input, model_settings: ModelSettings, tools, output_schema, handoffs, tracing: ModelTracing, *, previous_response_id, conversation_id, prompt) -> AsyncIterator[TResponseStreamEvent] [abstract]",
        "close() -> None [async, default no-op]",
        "get_retry_advice(request: ModelRetryAdviceRequest) -> ModelRetryAdvice | None [default None]"
      ],
      "notes": "Base interface for LLM calls. Concrete implementations: OpenAIChatCompletionsModel, OpenAIResponsesModel, OpenAIResponsesWSModel"
    },
    {
      "name": "ModelProvider",
      "type": "abstract_class",
      "module": "agents.models.interface",
      "methods": [
        "get_model(model_name: str | None) -> Model [abstract]",
        "aclose() -> None [async, default no-op]"
      ],
      "notes": "Base interface responsible for looking up Model instances by name"
    },
    {
      "name": "ModelTracing",
      "type": "enum",
      "module": "agents.models.interface",
      "values": ["DISABLED=0", "ENABLED=1", "ENABLED_WITHOUT_DATA=2"],
      "methods": [
        "is_disabled() -> bool",
        "include_data() -> bool"
      ]
    },
    {
      "name": "ModelSettings",
      "type": "pydantic_dataclass",
      "module": "agents.model_settings",
      "attributes": [
        "temperature: float | None",
        "top_p: float | None",
        "frequency_penalty: float | None",
        "presence_penalty: float | None",
        "tool_choice: ToolChoice | None",
        "parallel_tool_calls: bool | None",
        "truncation: Literal['auto','disabled'] | None",
        "max_tokens: int | None",
        "reasoning: Reasoning | None",
        "verbosity: Literal['low','medium','high'] | None",
        "metadata: dict[str,str] | None",
        "store: bool | None",
        "prompt_cache_retention: Literal['in_memory','24h'] | None",
        "include_usage: bool | None",
        "response_include: list[ResponseIncludable | str] | None",
        "top_logprobs: int | None",
        "extra_query: Query | None",
        "extra_body: Body | None",
        "extra_headers: Headers | None",
        "extra_args: dict[str,Any] | None",
        "retry: ModelRetrySettings | None"
      ],
      "methods": [
        "resolve(override: ModelSettings | None) -> ModelSettings",
        "to_json_dict() -> dict[str, Any]"
      ],
      "notes": "resolve() merges non-None values from override; extra_args dicts are merged, not replaced; retry settings deep-merged via _merge_retry_settings()"
    },
    {
      "name": "MCPToolChoice",
      "type": "dataclass",
      "module": "agents.model_settings",
      "attributes": ["server_label: str", "name: str"],
      "notes": "Used in ToolChoice type alias alongside 'auto'|'required'|'none'|str"
    },
    {
      "name": "OpenAIProvider",
      "type": "class",
      "module": "agents.models.openai_provider",
      "inherits": "ModelProvider",
      "attributes": [
        "_client: AsyncOpenAI | None",
        "_stored_api_key: str | None",
        "_stored_base_url: str | None",
        "_stored_websocket_base_url: str | None",
        "_stored_organization: str | None",
        "_stored_project: str | None",
        "_use_responses: bool",
        "_responses_transport: 'http' | 'websocket'",
        "_use_responses_websocket: bool",
        "_ws_model_cache_by_loop: WeakKeyDictionary[EventLoop, dict]",
        "_agent_registration: ResolvedOpenAIAgentRegistrationConfig | None"
      ],
      "methods": [
        "get_model(model_name: str | None) -> Model",
        "aclose() -> None [async]",
        "agent_registration [property] -> ResolvedOpenAIAgentRegistrationConfig | None",
        "_get_client() -> AsyncOpenAI [lazy init]",
        "_get_running_loop() -> AbstractEventLoop | None",
        "_prune_closed_ws_loop_caches() -> None",
        "_collect_unique_cached_models(loop_cache, seen) -> list[Model]",
        "_close_models(models) -> None [async]",
        "_close_ws_models_for_loop(loop, models, current_loop) -> None [async]",
        "_clear_ws_loop_cache_entry(loop, loop_cache) -> None"
      ],
      "constructor_params": "api_key, base_url, websocket_base_url, openai_client, organization, project, use_responses, use_responses_websocket, agent_registration",
      "notes": "DEFAULT_MODEL constant = 'gpt-4o' (backward compat). get_model() returns: OpenAIChatCompletionsModel if not use_responses; OpenAIResponsesWSModel if websocket transport; OpenAIResponsesModel otherwise. WS models cached by event loop via WeakKeyDictionary."
    },
    {
      "name": "MultiProviderMap",
      "type": "class",
      "module": "agents.models.multi_provider",
      "attributes": ["_mapping: dict[str, ModelProvider]"],
      "methods": [
        "has_prefix(prefix: str) -> bool",
        "get_mapping() -> dict[str, ModelProvider]",
        "set_mapping(mapping: dict[str, ModelProvider])",
        "get_provider(prefix: str) -> ModelProvider | None",
        "add_provider(prefix: str, provider: ModelProvider)",
        "remove_provider(prefix: str)"
      ]
    },
    {
      "name": "MultiProvider",
      "type": "class",
      "module": "agents.models.multi_provider",
      "inherits": "ModelProvider",
      "attributes": [
        "provider_map: MultiProviderMap | None",
        "openai_provider: OpenAIProvider",
        "_openai_prefix_mode: 'alias' | 'model_id'",
        "_unknown_prefix_mode: 'error' | 'model_id'",
        "_fallback_providers: dict[str, ModelProvider]"
      ],
      "methods": [
        "get_model(model_name: str | None) -> Model",
        "aclose() -> None [async]",
        "_get_prefix_and_model_name(model_name) -> tuple[str|None, str|None]",
        "_resolve_prefixed_model(original_model_name, prefix, stripped_model_name) -> tuple[ModelProvider, str|None]",
        "_get_fallback_provider(prefix) -> ModelProvider",
        "_create_fallback_provider(prefix) -> ModelProvider [lazy imports LitellmProvider/AnyLLMProvider]",
        "_validate_openai_prefix_mode(mode) -> MultiProviderOpenAIPrefixMode [static]",
        "_validate_unknown_prefix_mode(mode) -> MultiProviderUnknownPrefixMode [static]"
      ],
      "routing_logic": [
        "None or no prefix -> openai_provider.get_model(stripped_name)",
        "'openai/' prefix + alias mode -> openai_provider.get_model(stripped_name)",
        "'openai/' prefix + model_id mode -> openai_provider.get_model(original_name)",
        "'litellm/' -> LitellmProvider (lazy)",
        "'any-llm/' -> AnyLLMProvider (lazy)",
        "provider_map entry -> mapped provider",
        "unknown + error mode -> raises UserError",
        "unknown + model_id mode -> openai_provider.get_model(original_name)"
      ]
    }
  ],
  "default_models_module": {
    "module": "agents.models.default_models",
    "constants": [
      "OPENAI_DEFAULT_MODEL_ENV_VARIABLE_NAME = 'OPENAI_DEFAULT_MODEL'",
      "_GPT_5_LOW_DEFAULT_MODEL_SETTINGS: ModelSettings(reasoning=low, verbosity=low)",
      "_GPT_5_NONE_DEFAULT_MODEL_SETTINGS: ModelSettings(reasoning=none, verbosity=low)",
      "_GPT_5_MEDIUM_DEFAULT_MODEL_SETTINGS: ModelSettings(reasoning=medium, verbosity=low)",
      "_GPT_5_TEXT_ONLY_DEFAULT_MODEL_SETTINGS: ModelSettings(verbosity=low)"
    ],
    "functions": [
      "get_default_model() -> str  # env OPENAI_DEFAULT_MODEL or 'gpt-4.1'",
      "get_default_model_settings(model: str | None) -> ModelSettings",
      "gpt_5_reasoning_settings_required(model_name: str) -> bool",
      "is_gpt_5_default() -> bool",
      "_get_default_reasoning_effort(model_name) -> GPT5DefaultReasoningEffort | None"
    ],
    "gpt5_patterns": "Regex patterns for gpt-5, gpt-5.1..5.4 with/without dates, -pro, -mini, -nano, -codex variants; chat-latest aliases skip reasoning"
  },
  "key_relationships": [
    "OpenAIProvider extends ModelProvider",
    "MultiProvider extends ModelProvider",
    "MultiProvider composes OpenAIProvider (owns instance)",
    "MultiProvider optionally composes MultiProviderMap",
    "MultiProvider lazy-creates LitellmProvider / AnyLLMProvider in _fallback_providers",
    "Model.get_response() / stream_response() depends_on ModelSettings",
    "ModelSettings depends_on ModelRetrySettings (retry field)",
    "OpenAIProvider.get_model() creates OpenAIChatCompletionsModel | OpenAIResponsesModel | OpenAIResponsesWSModel",
    "OpenAIProvider._get_client() creates / reuses AsyncOpenAI",
    "OpenAIProvider uses shared_http_client() singleton httpx.AsyncClient",
    "default_models module provides factory functions consumed by agent runner to resolve ModelSettings",
    "ModelTracing passed into Model.get_response() / stream_response() calls"
  ],
  "type_aliases": [
    "ToolChoice = Literal['auto','required','none'] | str | MCPToolChoice | None",
    "Headers = Mapping[str, str | Omit]",
    "MultiProviderOpenAIPrefixMode = Literal['alias','model_id']",
    "MultiProviderUnknownPrefixMode = Literal['error','model_id']",
    "GPT5DefaultReasoningEffort = Literal['none','low','medium']"
  ],
  "important_notes": "Model and ModelProvider are ABCs from abc module. ModelSettings is a Pydantic dataclass with deep merge semantics. OpenAIProvider lazily creates AsyncOpenAI client and caches WS models per event loop via WeakKeyDictionary. MultiProvider is the main entry point for multi-provider routing; bare model names always go to OpenAI. Default model resolved from env var OPENAI_DEFAULT_MODEL (fallback: gpt-4.1). GPT-5 models require special reasoning/verbosity defaults set by default_models module.",
  "source_files_analyzed": [
    "src/agents/models/interface.py",
    "src/agents/models/openai_provider.py",
    "src/agents/models/multi_provider.py",
    "src/agents/model_settings.py",
    "src/agents/models/default_models.py"
  ]
}
