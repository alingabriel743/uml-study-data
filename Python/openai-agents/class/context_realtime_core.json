{
  "scope": "realtime_core",
  "title": "Realtime – Core Session & Runner",
  "diagram_type": "class",
  "description": "Realtime model interface, session, runner, OpenAI WebSocket backend, and realtime agent for voice/streaming agents.",

  "classes": [
