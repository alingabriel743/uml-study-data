  "relationships": [
    "RealtimeSession implements RealtimeModelListener",
    "RealtimeSession composes RealtimeModel (1:1, _model)",
    "RealtimeSession composes RealtimeAgent (1:1, _current_agent, mutable via update_agent/handoff)",
    "RealtimeSession composes RunContextWrapper (1:1)",
    "RealtimeSession produces RealtimeSessionEvent (queued via _event_queue)",
    "RealtimeRunner creates RealtimeSession (factory, run())",
    "RealtimeRunner depends_on RealtimeModel (injected or default OpenAIRealtimeWebSocketModel)",
    "RealtimeRunner depends_on RealtimeAgent (starting_agent)",
    "OpenAIRealtimeWebSocketModel extends RealtimeModel",
    "OpenAIRealtimeWebSocketModel uses list[RealtimeModelListener] (listener registry)",
    "OpenAIRealtimeWebSocketModel uses RealtimePlaybackTracker (optional, from ModelConfig)",
    "OpenAIRealtimeWebSocketModel uses websockets.ClientConnection (transport)",
    "RealtimeAgent extends AgentBase",
    "RealtimeAgent self-references via handoffs: list[RealtimeAgent | Handoff]",
    "RealtimeModelConfig references RealtimePlaybackTracker (composition)",
    "RealtimePlaybackTracker produces RealtimePlaybackState"
  ],

  "event_types": {
    "model_events_received_by_session": ["error", "function_call", "audio", "audio_end", "audio_interrupted", "history_added", "history_updated", "handoff", "input_audio_transcription_completed", "input_audio_timeout"],
    "session_events_emitted_to_consumer": ["RealtimeAudio", "RealtimeAudioEnd", "RealtimeAudioInterrupted", "RealtimeError", "RealtimeHandoffEvent", "RealtimeHistoryAdded", "RealtimeHistoryUpdated", "RealtimeToolStart", "RealtimeToolEnd", "RealtimeToolApprovalRequired", "RealtimeAgentStartEvent", "RealtimeAgentEndEvent", "RealtimeGuardrailTripped", "RealtimeRawModelEvent", "RealtimeInputAudioTimeoutTriggered"]
  },

  "key_patterns": [
    "RealtimeSession is an async context manager (__aenter__/__aexit__) and async iterator (__aiter__)",
    "RealtimeRunner.run() returns RealtimeSession before connecting; connection happens in __aenter__",
    "OpenAIRealtimeWebSocketModel spawns a background asyncio.Task (_websocket_task) to receive messages",
    "Tool approval flow: session tracks pending_tool_calls, exposes approve_tool_call/reject_tool_call",
    "Guardrails run async on transcribed text; debounced by debounce_text_length setting",
    "Handoffs: session replaces _current_agent and calls update_agent() to push settings to model",
    "RealtimePlaybackTracker is optional; default assumes immediate realtime playback"
  ],

  "source_files_analyzed": [
    "src/agents/realtime/model.py",
    "src/agents/realtime/session.py",
    "src/agents/realtime/runner.py",
    "src/agents/realtime/openai_realtime.py",
    "src/agents/realtime/agent.py"
  ]
