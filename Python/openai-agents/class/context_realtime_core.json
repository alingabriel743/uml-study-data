    {
      "name": "RealtimeAgent",
      "type": "dataclass",
      "module": "realtime/agent.py",
      "bases": ["AgentBase", "Generic[TContext]"],
      "fields": [
        "instructions: str | Callable[[RunContextWrapper, RealtimeAgent], MaybeAwaitable[str]] | None",
        "prompt: Prompt | None",
