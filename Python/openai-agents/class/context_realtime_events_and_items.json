  "key_relationships": [
    "RealtimeSessionEvent --contains--> RealtimeEventInfo (all session events have info field)",
    "RealtimeAgentStartEvent --references--> RealtimeAgent",
    "RealtimeAgentEndEvent --references--> RealtimeAgent",
    "RealtimeHandoffEvent --references--> RealtimeAgent (from_agent, to_agent)",
    "RealtimeToolStart --references--> RealtimeAgent, Tool",
    "RealtimeToolEnd --references--> RealtimeAgent, Tool",
    "RealtimeToolApprovalRequired --references--> RealtimeAgent, Tool",
    "RealtimeRawModelEvent --wraps--> RealtimeModelEvent",
    "RealtimeAudio --wraps--> RealtimeModelAudioEvent",
    "RealtimeHistoryUpdated --contains--> list[RealtimeItem]",
    "RealtimeHistoryAdded --contains--> RealtimeItem",
    "RealtimeGuardrailTripped --contains--> list[OutputGuardrailResult]",
    "RealtimeModelItemUpdatedEvent --references--> RealtimeItem",
    "RealtimeModelSendToolOutput --references--> RealtimeModelToolCallEvent",
    "RealtimeModelSendSessionUpdate --references--> RealtimeSessionModelSettings",
    "UserMessageItem --contains--> list[InputText | InputAudio | InputImage]",
    "SystemMessageItem --contains--> list[InputText]",
    "AssistantMessageItem --contains--> list[AssistantText | AssistantAudio]",
    "RealtimeResponse --contains--> list[RealtimeMessageItem]",
    "RealtimeModelUserInputMessage --contains--> list[RealtimeModelInputTextContent | RealtimeModelInputImageContent]",
    "realtime_handoff() --returns--> Handoff[TContext, RealtimeAgent[TContext]]",
    "realtime_handoff() --accepts--> RealtimeAgent, on_handoff callback, input_type",
    "Handoff --uses--> RunContextWrapper, TypeAdapter (for input validation)"
  ],

  "layering": {
    "session_layer": "RealtimeSessionEvent variants — emitted to application-level listeners (high level)",
    "model_layer": "RealtimeModelEvent variants — raw/transport-level events from the model API (low level)",
    "bridge": "RealtimeRawModelEvent wraps RealtimeModelEvent, exposing model-layer events to session listeners",
    "items_layer": "RealtimeItem / RealtimeMessageItem / RealtimeToolCallItem — conversation history data model",
    "inputs_layer": "RealtimeModelSendEvent variants — client→model commands/messages",
    "handoff_layer": "realtime_handoff() factory creates Handoff objects routing between RealtimeAgents"
  },

  "important_notes": [
    "Two-tier event architecture: high-level RealtimeSessionEvent (application) wraps low-level RealtimeModelEvent (model/transport)",
    "All session events share RealtimeEventInfo carrying RunContextWrapper",
    "RealtimeItem is a discriminated union (role discriminator for messages, type='function_call' for tool calls)",
    "Content types use Pydantic discriminated unions (type field) — InputText/InputAudio/InputImage for user, AssistantText/AssistantAudio for assistant",
    "realtime_handoff() is a factory function (not a class); supports optional on_handoff callbacks with or without typed input; input_filter NOT supported for RealtimeAgent handoffs",
    "RealtimeModelSendEvent covers all outbound commands: raw, user input, audio, tool output, interrupt, session update",
    "Audio data: model-layer uses bytes; item/response layer uses base64-encoded strings"
  ]
}
