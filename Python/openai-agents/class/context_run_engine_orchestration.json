  "relationships": [
    "Runner depends_on AgentRunner (delegates all methods to DEFAULT_AGENT_RUNNER singleton)",
    "Runner.run() returns RunResult",
    "Runner.run_sync() returns RunResult",
    "Runner.run_streamed() returns RunResultStreaming",
    "AgentRunner.run() accepts RunOptions[TContext] as **kwargs",
    "AgentRunner.run() creates RunConfig() if none provided",
    "AgentRunner.run() accepts RunState as input for resume flows",
