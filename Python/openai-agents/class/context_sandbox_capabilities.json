{
  "scope": "sandbox_capabilities",
  "title": "Sandbox – Capabilities",
  "diagram_type": "class",
  "description": "Capability registry, filesystem, shell, memory, skills, compaction capabilities, and built-in tools",

  "classes": [
    {
      "name": "Capability",
      "module": "capabilities/capability.py",
      "base": "pydantic.BaseModel",
      "attributes": [
        "type: str",
        "session: BaseSandboxSession | None",
        "run_as: User | None"
      ],
      "methods": [
        "clone() -> Capability",
        "bind(session: BaseSandboxSession) -> None",
        "bind_run_as(user: User | None) -> None",
        "required_capability_types() -> set[str]",
        "tools() -> list[Tool]",
        "process_manifest(manifest: Manifest) -> Manifest",
        "async instructions(manifest: Manifest) -> str | None",
        "sampling_params(sampling_params: dict) -> dict",
        "process_context(context: list[TResponseInputItem]) -> list[TResponseInputItem]"
      ],
      "notes": "Base Pydantic model for all capabilities. arbitrary_types_allowed=True."
    },
    {
      "name": "Capabilities",
      "module": "capabilities/capabilities.py",
      "base": null,
      "attributes": [],
      "methods": [
        "classmethod default() -> list[Capability]  # returns [Filesystem(), Shell(), Compaction()]"
      ],
      "notes": "Factory/registry class. Default set: Filesystem, Shell, Compaction."
    },
    {
      "name": "Filesystem",
      "module": "capabilities/filesystem.py",
      "base": "Capability",
      "attributes": [
        "type: Literal['filesystem'] = 'filesystem'",
        "configure_tools: FilesystemToolConfigurator | None"
      ],
      "methods": [
        "tools() -> list[Tool]  # returns [ViewImageTool, SandboxApplyPatchTool]"
      ],
      "notes": "Builds FilesystemToolSet(view_image, apply_patch), calls configure_tools callback if set."
    },
    {
      "name": "FilesystemToolSet",
      "module": "capabilities/filesystem.py",
      "base": "dataclass",
      "attributes": [
        "view_image: ViewImageTool",
        "apply_patch: SandboxApplyPatchTool"
      ],
      "methods": [],
      "notes": "Mutable bundle passed to FilesystemToolConfigurator callback."
    },
    {
      "name": "Shell",
      "module": "capabilities/shell.py",
      "base": "Capability",
      "attributes": [
        "type: Literal['shell'] = 'shell'",
        "configure_tools: ShellToolConfigurator | None"
      ],
      "methods": [
        "tools() -> list[Tool]  # returns [ExecCommandTool] + optional [WriteStdinTool]",
        "async instructions(manifest: Manifest) -> str | None  # returns _SHELL_INSTRUCTIONS"
      ],
      "notes": "WriteStdinTool only added if session.supports_pty(). Provides shell usage instructions to model."
    },
    {
      "name": "ShellToolSet",
      "module": "capabilities/shell.py",
      "base": "dataclass",
      "attributes": [
        "exec_command: ExecCommandTool",
        "write_stdin: WriteStdinTool | None"
      ],
      "methods": [],
      "notes": "Mutable bundle passed to ShellToolConfigurator callback."
    },
    {
      "name": "Memory",
      "module": "capabilities/memory.py",
      "base": "Capability",
      "attributes": [
        "type: Literal['memory'] = 'memory'",
        "layout: MemoryLayoutConfig",
        "read: MemoryReadConfig | None",
        "generate: MemoryGenerateConfig | None"
      ],
      "methods": [
        "clone() -> Memory",
        "model_post_init(context) -> None",
        "required_capability_types() -> set[str]  # {'shell'} or {'filesystem','shell'}",
        "async instructions(manifest: Manifest) -> str | None  # reads memory_summary.md"
      ],
      "notes": "Requires Shell; optionally Filesystem if live_update=True. Reads memory_summary.md from sandbox."
    },
    {
      "name": "Skills",
      "module": "capabilities/skills.py",
      "base": "Capability",
      "attributes": [
        "type: Literal['skills'] = 'skills'",
        "skills: list[Skill]",
        "from_: BaseEntry | None",
        "lazy_from: LazySkillSource | None",
        "skills_path: str = '.agents'",
        "_skills_metadata: list[SkillMetadata] | None (private)"
      ],
      "methods": [
        "process_manifest(manifest: Manifest) -> Manifest",
        "bind(session: BaseSandboxSession) -> None",
        "tools() -> list[Tool]  # returns [_LoadSkillTool] if lazy_from else []",
        "async load_skill(skill_name: str) -> dict[str, str]",
        "async _resolve_runtime_metadata(manifest) -> list[SkillMetadata]",
        "async _skill_metadata(manifest) -> list[SkillMetadata]",
        "async instructions(manifest: Manifest) -> str | None"
      ],
      "notes": "Mounts skill dirs into sandbox. Supports inline skills, from_ (dir entry), or lazy_from (on-demand load). Exactly one source required."
    },
    {
      "name": "Skill",
      "module": "capabilities/skills.py",
      "base": "pydantic.BaseModel",
      "attributes": [
        "name: str",
        "description: str",
        "content: str | bytes | BaseEntry",
        "compatibility: str | None",
        "scripts: dict[str | Path, BaseEntry]",
        "references: dict[str | Path, BaseEntry]",
        "assets: dict[str | Path, BaseEntry]",
        "deferred: bool"
      ],
      "methods": [
        "content_artifact() -> BaseEntry",
        "as_dir_entry() -> Dir  # builds Dir with SKILL.md, scripts/, references/, assets/"
      ],
      "notes": "Content must be file-like. Paths are relative and must not escape skills root."
    },
    {
      "name": "SkillMetadata",
      "module": "capabilities/skills.py",
      "base": "frozen dataclass",
      "attributes": ["name: str", "description: str", "path: Path"],
      "methods": [],
      "notes": "Indexed metadata for rendering into agent instructions."
    },
    {
      "name": "LazySkillSource",
      "module": "capabilities/skills.py",
      "base": "pydantic.BaseModel (abc.ABC)",
      "attributes": [],
      "methods": [
        "abstractmethod list_skill_metadata(*, skills_path: str) -> list[SkillMetadata]",
        "abstractmethod async load_skill(*, skill_name, session, skills_path, user) -> dict[str, str]"
      ],
      "notes": "Abstract base for on-demand skill loading."
    },
    {
      "name": "LocalDirLazySkillSource",
      "module": "capabilities/skills.py",
      "base": "LazySkillSource",
      "attributes": ["source: LocalDir"],
      "methods": [
        "list_skill_metadata(*, skills_path: str) -> list[SkillMetadata]",
        "async load_skill(*, skill_name, session, skills_path, user) -> dict[str, str]"
      ],
      "notes": "Reads SKILL.md frontmatter from local host filesystem. Copies skill dir into sandbox on demand."
    },
    {
      "name": "Compaction",
      "module": "capabilities/compaction.py",
      "base": "Capability",
      "attributes": [
        "type: Literal['compaction'] = 'compaction'",
        "policy: CompactionPolicy | None"
      ],
      "methods": [
        "sampling_params(sampling_params: dict) -> dict  # injects context_management compaction config",
        "process_context(context: list[TResponseInputItem]) -> list[TResponseInputItem]  # trims before last compaction item"
      ],
      "notes": "Auto-selects DynamicCompactionPolicy from model name if no policy set. Default threshold 240,000 tokens."
    },
    {
      "name": "CompactionPolicy",
      "module": "capabilities/compaction.py",
      "base": "pydantic.BaseModel (abc.ABC)",
      "attributes": ["type: str"],
      "methods": [
        "abstractmethod compaction_threshold(sampling_params: dict) -> int"
      ]
    },
    {
      "name": "StaticCompactionPolicy",
      "module": "capabilities/compaction.py",
      "base": "CompactionPolicy",
      "attributes": ["type: Literal['static']", "threshold: int = 240_000"],
      "methods": ["compaction_threshold(sampling_params: dict) -> int"]
    },
    {
      "name": "DynamicCompactionPolicy",
      "module": "capabilities/compaction.py",
      "base": "CompactionPolicy",
      "attributes": [
        "type: Literal['dynamic']",
        "model_info: CompactionModelInfo",
        "threshold: float = 0.9"
      ],
      "methods": ["compaction_threshold(sampling_params: dict) -> int  # context_window * threshold"]
    },
    {
      "name": "CompactionModelInfo",
      "module": "capabilities/compaction.py",
      "base": "pydantic.BaseModel",
      "attributes": ["context_window: int"],
      "methods": ["classmethod for_model(model: str) -> CompactionModelInfo"]
    },
    {
      "name": "ExecCommandTool",
      "module": "capabilities/tools/shell_tool.py",
      "base": "FunctionTool (dataclass)",
      "attributes": [
        "tool_name: ClassVar[str] = 'exec_command'",
        "args_model: ClassVar[type] = ExecCommandArgs",
        "session: BaseSandboxSession",
        "user: str | User | None"
      ],
      "methods": [
        "__init__(*, session, user, needs_approval)",
        "async _invoke(_, raw_input: str) -> str",
        "async run(args: ExecCommandArgs) -> str"
      ],
      "notes": "Supports PTY exec with fallback to one-shot exec. Returns formatted output with chunk ID, wall time, exit code."
    },
    {
      "name": "ExecCommandArgs",
      "module": "capabilities/tools/shell_tool.py",
      "base": "pydantic.BaseModel",
      "attributes": [
        "cmd: str",
        "workdir: str | None",
        "shell: str | None",
        "login: bool = True",
        "tty: bool = False",
        "yield_time_ms: int = 10_000",
        "max_output_tokens: int | None"
      ]
    },
    {
      "name": "WriteStdinTool",
      "module": "capabilities/tools/shell_tool.py",
      "base": "FunctionTool (dataclass)",
      "attributes": [
        "tool_name: ClassVar[str] = 'write_stdin'",
        "args_model: ClassVar[type] = WriteStdinArgs",
        "session: BaseSandboxSession"
      ],
      "methods": [
        "__init__(*, session, needs_approval)",
        "async _invoke(_, raw_input: str) -> str",
        "async run(args: WriteStdinArgs) -> str"
      ],
      "notes": "Only available when session.supports_pty(). Writes chars to running PTY session."
    },
    {
      "name": "WriteStdinArgs",
      "module": "capabilities/tools/shell_tool.py",
      "base": "pydantic.BaseModel",
      "attributes": [
        "session_id: int",
        "chars: str = ''",
        "yield_time_ms: int = 250",
        "max_output_tokens: int | None"
      ]
    },
    {
      "name": "SandboxApplyPatchTool",
      "module": "capabilities/tools/apply_patch_tool.py",
      "base": "CustomTool",
      "attributes": [
        "needs_approval: bool | ApplyPatchApprovalFunction = False",
        "on_approval: ApplyPatchOnApprovalFunction | None",
        "session: BaseSandboxSession",
        "editor: SandboxApplyPatchEditor"
      ],
      "methods": [
        "__init__(*, session, user, needs_approval, on_approval)",
        "property operation_needs_approval",
        "runtime_needs_approval() -> CustomToolApprovalFunction",
        "parse_custom_input(raw_input: str) -> list[ApplyPatchOperation]",
        "async _needs_custom_approval(ctx_wrapper, raw_input, call_id) -> bool",
        "async _on_invoke_tool(ctx, raw_input) -> str"
      ],
      "notes": "Freeform patch format (not JSON). Supports Add/Update/Delete/Move file operations. Grammar defined via Lark."
    },
    {
      "name": "SandboxApplyPatchEditor",
      "module": "capabilities/tools/apply_patch_tool.py",
      "base": "ApplyPatchEditor",
      "attributes": ["session: BaseSandboxSession", "user: str | User | None"],
      "methods": [
        "__init__(session, *, user)",
        "async create_file(operation: ApplyPatchOperation) -> ApplyPatchResult",
        "async update_file(operation: ApplyPatchOperation) -> ApplyPatchResult",
        "async delete_file(operation: ApplyPatchOperation) -> ApplyPatchResult"
      ],
      "notes": "Delegates all operations to WorkspaceEditor."
    },
    {
      "name": "ViewImageTool",
      "module": "capabilities/tools/view_image.py",
      "base": "FunctionTool (dataclass)",
      "attributes": [
        "tool_name: ClassVar[str] = 'view_image'",
        "args_model: ClassVar[type] = ViewImageArgs",
        "session: BaseSandboxSession",
        "user: str | User | None"
      ],
      "methods": [
        "__init__(*, session, user, needs_approval)",
        "async _invoke(_, raw_input: str) -> ToolOutputImage | str",
        "async run(args: ViewImageArgs) -> ToolOutputImage | str"
      ],
      "notes": "Max 10MB. Detects MIME type (PNG, JPEG, GIF, WEBP, BMP, TIFF, SVG). Returns base64 data URL."
    },
    {
      "name": "_LoadSkillTool",
      "module": "capabilities/skills.py",
      "base": "FunctionTool (dataclass)",
      "attributes": [
        "tool_name = 'load_skill'",
        "args_model = _LoadSkillArgs",
        "skills: Skills"
      ],
      "methods": [
        "__init__(*, skills: Skills)",
        "async _invoke(_, raw_input: str) -> dict[str, str]",
        "async run(args: _LoadSkillArgs) -> dict[str, str]  # delegates to skills.load_skill()"
      ],
      "notes": "Only exposed when Skills.lazy_from is configured."
    }
  ],

  "relationships": [
    "Capabilities uses Filesystem, Shell, Compaction (factory)",
    "Filesystem extends Capability",
    "Shell extends Capability",
    "Memory extends Capability",
    "Skills extends Capability",
    "Compaction extends Capability",
    "Capability extends pydantic.BaseModel",
    "Filesystem composes FilesystemToolSet (creates on tools())",
    "Shell composes ShellToolSet (creates on tools())",
    "FilesystemToolSet contains ViewImageTool, SandboxApplyPatchTool",
    "ShellToolSet contains ExecCommandTool, WriteStdinTool (optional)",
    "Skills contains list[Skill]",
    "Skills references LazySkillSource (optional)",
    "LocalDirLazySkillSource extends LazySkillSource",
    "Skills creates _LoadSkillTool (when lazy_from set)",
    "Compaction contains CompactionPolicy (optional)",
    "StaticCompactionPolicy extends CompactionPolicy",
    "DynamicCompactionPolicy extends CompactionPolicy",
    "DynamicCompactionPolicy uses CompactionModelInfo",
    "SandboxApplyPatchTool extends CustomTool",
    "SandboxApplyPatchTool composes SandboxApplyPatchEditor",
    "SandboxApplyPatchEditor extends ApplyPatchEditor",
    "SandboxApplyPatchEditor uses WorkspaceEditor",
    "ExecCommandTool extends FunctionTool",
    "WriteStdinTool extends FunctionTool",
    "ViewImageTool extends FunctionTool",
    "_LoadSkillTool extends FunctionTool",
    "Capability depends_on BaseSandboxSession (bound at runtime)",
    "Capability depends_on User (optional identity)"
  ],

  "key_patterns": [
    "Plugin pattern: each Capability subclass overrides tools(), instructions(), sampling_params(), process_manifest(), process_context()",
    "Tool configurator callbacks (FilesystemToolConfigurator, ShellToolConfigurator) allow external customization of tool bundles",
    "Lazy loading: Skills.lazy_from defers skill materialization; _LoadSkillTool invoked by model to stage skill files",
    "Capability.clone() deep-copies most values but shares sessions/locks/asyncio primitives",
    "Compaction.process_context() truncates context to start from the last compaction event item"
  ],

  "important_notes": "Capabilities.default() = [Filesystem, Shell, Compaction]. Memory requires Shell (+ Filesystem if live_update). Skills requires no other capabilities but mounts SKILL.md directories. All tool classes use FunctionTool or CustomTool from agents.tool.",

