{
  "scope": "sandbox_extensions",
  "title": "Sandbox – Cloud Provider Extensions",
  "diagram_type": "class",
  "description": "Extension sandbox sessions for Modal, E2B, Cloudflare, Daytona, Runloop, Blaxel, and Vercel. Each provider implements the BaseSandboxSession + BaseSandboxClient pattern with a provider-specific SessionState and ClientOptions.",

  "base_classes": [
    {
      "name": "BaseSandboxSession",
      "module": "agents.sandbox.session.base_sandbox_session",
      "type": "abstract",
      "key_methods": [
        "start() -> None",
        "stop() -> None",
        "shutdown() -> None",
        "exec(cmd, ...) -> ExecResult",
        "read(path, *, user) -> io.IOBase",
        "write(path, data, *, user) -> None",
        "running() -> bool",
        "persist_workspace() -> io.IOBase",
        "hydrate_workspace(data) -> None",
        "ls(path) -> list",
        "rm(path) -> None",
        "mkdir(path) -> None",
        "resolve_exposed_port(port) -> ExposedPortEndpoint",
        "supports_pty() -> bool",
        "pty_exec_start(...) -> int",
        "pty_write_stdin(process_id, payload) -> None",
        "pty_terminate_all() -> None",
        "_exec_internal(...) [abstract]",
        "_resolve_exposed_port(port) [abstract]",
        "_ensure_backend_started() [abstract]",
        "_prepare_backend_workspace() [abstract]",
        "_after_start() [abstract]",
        "_shutdown_backend() [abstract]"
      ],
      "key_attributes": [
        "state: SandboxSessionState",
        "_dependencies: Dependencies",
        "_pre_stop_hooks: list[Callable]"
      ]
    },
    {
      "name": "BaseSandboxClient",
      "module": "agents.sandbox.session.sandbox_client",
      "type": "abstract_generic",
      "generic_param": "ClientOptionsT",
      "key_methods": [
        "create(*, snapshot, manifest, options) -> SandboxSession [abstract]",
        "delete(session) -> SandboxSession",
        "resume(state, ...) -> SandboxSession",
        "serialize_session_state(state) -> dict",
        "deserialize_session_state(payload) -> SandboxSessionState"
      ],
      "key_attributes": [
        "backend_id: str",
        "supports_default_options: bool = False",
        "_dependencies: Dependencies | None"
      ]
    },
    {
      "name": "BaseSandboxClientOptions",
      "module": "agents.sandbox.session.sandbox_client",
      "type": "pydantic_basemodel",
      "key_attributes": [
        "type: str",
        "_subclass_registry: ClassVar[dict]"
      ],
      "key_methods": [
        "parse(payload) -> BaseSandboxClientOptions [classmethod]"
      ]
    },
    {
      "name": "SandboxSessionState",
      "module": "agents.sandbox.session.sandbox_session_state",
      "type": "pydantic_basemodel",
      "key_attributes": [
        "type: str",
        "session_id: UUID",
        "snapshot: SnapshotBase",
        "manifest: Manifest",
        "exposed_ports: tuple[int, ...]",
        "snapshot_fingerprint: str | None",
        "workspace_root_ready: bool",
        "_subclass_registry: ClassVar[dict]"
      ]
    },
    {
      "name": "MountStrategyBase",
      "module": "agents.sandbox.entries.mounts.base",
      "type": "abstract_pydantic",
      "key_attributes": ["type: str"]
    }
  ],

  "providers": [
    {
      "name": "Modal",
      "sdk": "modal (modal.com)",
