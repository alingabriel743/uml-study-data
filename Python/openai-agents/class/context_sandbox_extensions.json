      "state_class": "ModalSandboxSessionState",
      "auxiliary_classes": ["ModalImageSelector", "ModalSandboxSelector", "ModalCloudBucketMountStrategy"],
      "options_key_attrs": [
        "type: Literal['modal'] = 'modal'",
        "app_name: str",
        "sandbox_create_timeout_s: float | None",
        "workspace_persistence: WorkspacePersistenceMode = 'tar'",
        "snapshot_filesystem_timeout_s: float | None",
        "exposed_ports: tuple[int, ...]",
        "gpu: str | None",
        "timeout: int = 300",
        "use_sleep_cmd: bool = True"
      ],
      "state_key_attrs": [
        "type: Literal['modal'] = 'modal'",
        "app_name: str",
        "image_id: str | None",
        "image_tag: str | None",
        "sandbox_create_timeout_s: float",
        "sandbox_id: str | None",
        "workspace_persistence: WorkspacePersistenceMode",
        "gpu: str | None",
        "timeout: int"
      ],
      "session_key_attrs": [
        "state: ModalSandboxSessionState",
        "_sandbox: modal.Sandbox | None",
        "_image: modal.Image | None",
        "_running: bool",
        "_pty_lock: asyncio.Lock",
        "_pty_processes: dict[int, _ModalPtyProcessEntry]"
      ],
      "session_extra_methods": [
        "snapshot_filesystem() -> str",
        "_persist_workspace_via_snapshot_filesystem() -> io.IOBase",
        "_persist_workspace_via_snapshot_directory() -> io.IOBase",
        "_persist_workspace_via_tar() -> io.IOBase",
        "_call_modal(...)"
      ],
      "client_key_attrs": [
        "backend_id = 'modal'",
        "_default_image: ModalImageSelector | None",
        "_default_sandbox: ModalSandboxSelector | None",
        "_instrumentation: Instrumentation"
      ],
      "client_methods": [
        "create(*, snapshot, manifest, options) -> SandboxSession",
        "delete(session) -> SandboxSession",
        "resume(state, ...) -> SandboxSession",
        "deserialize_session_state(payload) -> SandboxSessionState"
      ],
      "workspace_persistence_modes": ["tar", "snapshot_filesystem", "snapshot_directory"],
      "notes": "GPU support (A100, H100:8). Optional modal dependency. Image config via ModalImageSelector (from_image/from_id/from_tag). Sandbox attach via ModalSandboxSelector."
    },
