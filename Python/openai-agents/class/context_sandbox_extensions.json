  "common_patterns": {
    "lifecycle": "All sessions: start() -> exec/read/write -> persist_workspace/hydrate_workspace -> stop()",
    "workspace_persistence": "Modal and E2B and Vercel support both 'tar' and native snapshot modes. Others support 'tar' only.",
    "pty_support": "Modal, E2B, Cloudflare, Daytona, Runloop, Blaxel support PTY. Vercel does NOT.",
    "lazy_imports": "E2B, Daytona, Runloop, Blaxel use lazy SDK imports. Modal and Cloudflare import at module level.",
    "state_serialization": "All *SessionState classes are Pydantic models, serialized to dict for resume(). Type discriminator field enables polymorphic deserialization.",
    "options_type_literal": "Each Options class has a 'type' Literal field matching backend_id for polymorphic parse().",
    "instrumentation": "All clients accept optional Instrumentation for tracing/metrics.",
    "dependencies": "All clients accept optional Dependencies (injected into sessions for tool use).",
    "exposed_ports": "All providers support exposed_ports; Cloudflare/Blaxel add public URL exposure with TTL."
  },

