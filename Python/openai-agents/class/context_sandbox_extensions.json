      ],
      "client_key_attrs": [
        "backend_id = 'cloudflare'",
        "_instrumentation: Instrumentation",
        "_exec_timeout_s: float",
        "_request_timeout_s: float"
      ],
      "transport": "HTTP REST + WebSocket (aiohttp). SSE used for exec streaming.",
      "notes": "Communicates over HTTP/WebSocket to a deployed Cloudflare Worker. No lazy import (requires aiohttp extra). PTY over WebSocket."
    },
    {
