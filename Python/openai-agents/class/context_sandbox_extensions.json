      ],
      "e2b_sandbox_types": ["CODE_INTERPRETER = 'e2b_code_interpreter'", "E2B = 'e2b'"],
      "notes": "Two sandbox modes: plain E2B and code interpreter. Lazy SDK import. Supports MCP config dict."
    },
    {
      "name": "Cloudflare",
      "sdk": "aiohttp HTTP+WebSocket to Cloudflare Worker",
