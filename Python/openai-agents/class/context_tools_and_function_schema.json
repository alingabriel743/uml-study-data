  "key_relationships": [
    "ToolContext extends RunContextWrapper[TContext]",
    "ToolOutputGuardrailData extends ToolInputGuardrailData",
    "FunctionTool composes list[ToolInputGuardrail] (tool_input_guardrails)",
    "FunctionTool composes list[ToolOutputGuardrail] (tool_output_guardrails)",
    "FunctionTool references ToolOrigin (_tool_origin)",
    "FunctionTool.on_invoke_tool accepts ToolContext as first argument",
    "ToolInputGuardrail produces ToolInputGuardrailResult containing ToolGuardrailFunctionOutput",
    "ToolOutputGuardrail produces ToolOutputGuardrailResult containing ToolGuardrailFunctionOutput",
    "ToolGuardrailFunctionOutput contains one of AllowBehavior | RejectContentBehavior | RaiseExceptionBehavior",
    "InputGuardrail produces InputGuardrailResult containing GuardrailFunctionOutput (agent-level)",
    "OutputGuardrail produces OutputGuardrailResult containing GuardrailFunctionOutput (agent-level)",
    "FunctionToolResult references FunctionTool",
    "FuncSchema is produced by function_schema() factory; wraps a Pydantic BaseModel for params",
    "FuncDocumentation is produced by generate_func_documentation() and consumed by function_schema()",
    "Tool (union) includes FunctionTool as primary callable variant; others are hosted/local specializations",
    "ToolSearchTool enables deferred loading for FunctionTool (defer_loading=True) and HostedMCPTool",
    "tool_namespace() groups FunctionTool instances under shared namespace metadata",
    "ComputerProvider composes ComputerCreate and ComputerDispose protocols for lifecycle management"
  ],

  "key_functions_and_decorators": [
    "function_schema(func, docstring_style, name_override, description_override, use_docstring_info, strict_json_schema) -> FuncSchema — introspects Python function, builds Pydantic model, returns FuncSchema",
    "generate_func_documentation(func, style) -> FuncDocumentation — parses docstring via griffe",
    "@function_tool / function_tool(name_override, description_override, ...) -> FunctionTool — decorator wrapping Python function as FunctionTool",
    "@tool_input_guardrail / tool_input_guardrail(name) -> ToolInputGuardrail — decorator",
    "@tool_output_guardrail / tool_output_guardrail(name) -> ToolOutputGuardrail — decorator",
    "@input_guardrail / input_guardrail(name, run_in_parallel) -> InputGuardrail — agent-level input guardrail decorator",
    "@output_guardrail / output_guardrail(name) -> OutputGuardrail — agent-level output guardrail decorator",
    "tool_namespace(name, description, tools) -> list[FunctionTool] — attaches namespace metadata for Responses API tool search",
    "ToolContext.from_agent_context(context, tool_call_id, ...) -> ToolContext — factory from RunContextWrapper",
    "default_tool_error_function(ctx, error) -> str — default failure formatter",
    "resolve_computer(tool, run_context) -> ComputerLike (async) — resolves ComputerTool computer instance with caching"
  ],

  "important_notes": [
    "Tool guardrails (ToolInputGuardrail/ToolOutputGuardrail) differ from agent guardrails (InputGuardrail/OutputGuardrail): tool guardrails fire per function-tool invocation; agent guardrails fire at agent input/output boundaries",
    "ToolGuardrailFunctionOutput uses behavior TypedDict variants (allow/reject_content/raise_exception) vs GuardrailFunctionOutput's boolean tripwire_triggered",
    "function_schema() auto-detects docstring style (google/numpy/sphinx) via griffe; supports Annotated[T, 'description'] and Pydantic Field for arg metadata",
    "FuncSchema.takes_context=True strips RunContextWrapper/ToolContext from the params Pydantic model but still passes it at call time",
    "FunctionTool.defer_loading=True hides the tool until ToolSearchTool loads it (Responses API only); requires ToolSearchTool() on agent",
    "ToolTimeoutBehavior: 'error_as_result' returns timeout message to model; 'raise_exception' raises ToolTimeoutError",
    "InputGuardrail.run_in_parallel=True (default) runs concurrently with agent; False blocks agent start (prevents token waste but adds latency)",
    "Strict JSON schema (default True on FuncSchema/FunctionTool) enforces OpenAI strict mode for higher LLM compliance",
    "ToolOriginType tracks whether a FunctionTool came from a plain function, MCP server, or agent-as-tool pattern",
    "ValidToolOutputPydanticModels = ToolOutputText | ToolOutputImage | ToolOutputFileContent — tool return types understood by the runner"
  ]
}
