  "key_relationships": [
    "VoicePipeline aggregates VoiceWorkflowBase (workflow)",
    "VoicePipeline aggregates STTModel (stt_model, lazy-loaded via provider)",
    "VoicePipeline aggregates TTSModel (tts_model, lazy-loaded via provider)",
    "VoicePipeline aggregates VoicePipelineConfig (config)",
    "VoicePipeline creates StreamedAudioResult on run()",
    "VoicePipeline calls STTModel.create_session() for StreamedAudioInput → returns StreamedTranscriptionSession",
    "VoicePipelineConfig has VoiceModelProvider (default: OpenAIVoiceModelProvider)",
    "VoicePipelineConfig has STTModelSettings and TTSModelSettings",
    "VoiceModelProvider (abstract) provides STTModel and TTSModel by name",
    "SingleAgentVoiceWorkflow extends VoiceWorkflowBase",
    "SingleAgentVoiceWorkflow uses Runner.run_streamed() + VoiceWorkflowHelper.stream_text_from()",
    "SingleAgentVoiceWorkflow has SingleAgentWorkflowCallbacks (optional)",
    "OpenAISTTModel extends STTModel",
    "OpenAISTTModel creates OpenAISTTTranscriptionSession via create_session()",
    "OpenAISTTTranscriptionSession extends StreamedTranscriptionSession",
    "OpenAISTTTranscriptionSession depends_on AsyncOpenAI (websocket to wss://api.openai.com/v1/realtime)",
    "OpenAITTSModel extends TTSModel",
    "OpenAITTSModel depends_on AsyncOpenAI (audio.speech streaming)",
    "StreamedAudioResult aggregates TTSModel and TTSModelSettings",
    "StreamedAudioResult calls TTSModel.run() per text chunk in _stream_audio()",
    "StreamedAudioResult emits VoiceStreamEvent (Audio / Lifecycle / Error)"
  ],

  "type_aliases": [
    "TTSVoice = Literal['alloy', 'ash', 'coral', 'echo', 'fable', 'onyx', 'nova', 'sage', 'shimmer']"
  ],

  "constants": [
    "DEFAULT_SAMPLE_RATE = 24000 (AudioInput/output PCM format)",
    "DEFAULT_TTS_BUFFER_SIZE = 120",
    "DEFAULT_TURN_DETECTION = {'type': 'semantic_vad'}",
    "EVENT_INACTIVITY_TIMEOUT = 1000s",
    "SESSION_CREATION_TIMEOUT = 10s",
    "SESSION_UPDATE_TIMEOUT = 10s",
    "DEFAULT_VOICE = 'ash' (OpenAI TTS)"
  ],

  "important_notes": [
    "VoicePipeline.run() dispatches to _run_single_turn (AudioInput) or _run_multi_turn (StreamedAudioInput)",
    "Multi-turn uses a persistent WebSocket session (OpenAI Realtime API, intent=transcription) via OpenAISTTTranscriptionSession",
    "Single-turn calls STTModel.transcribe() (REST: audio/transcriptions endpoint)",
    "TTS output is PCM audio bytes streamed as numpy arrays via VoiceStreamEventAudio events",
    "StreamedAudioResult uses ordered deque of local queues to emit TTS audio in generation order",
    "Tracing spans: TranscriptionSpanData for STT, SpeechGroupSpanData + SpeechSpan for TTS",
    "VoicePipelineConfig.model_provider defaults to OpenAIVoiceModelProvider (not shown in scope but referenced)",
    "SingleAgentVoiceWorkflow maintains multi-turn conversation history (_input_history) and tracks last_agent for handoff support"
  ]
}
