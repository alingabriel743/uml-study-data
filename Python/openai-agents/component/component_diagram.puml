@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam component {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}
skinparam ArrowColor #495057
skinparam ArrowThickness 1.5

title OpenAI Agents SDK — Component Architecture

' ─────────────────────────────────────────
' External actors / boundary
' ─────────────────────────────────────────
actor "User Application" as user_app

package "External Services" {
    [OpenAI Responses API] as responses_api
    [OpenAI Chat Completions API] as chatcmpl_api
    [OpenAI Realtime API] as realtime_api
    [MCP Servers\n(stdio / SSE / HTTP)] as mcp_servers
}

' ─────────────────────────────────────────
' CORE AGENT RUNTIME  (src/agents/)
' ─────────────────────────────────────────
package "Core Agent Runtime" {
    [Agent\n(instructions, tools, handoffs,\nguardrails, output_type)] as agent
    [Runner\n(run / run_sync / run_streamed)] as runner
    [RunContext &\nRunContextWrapper] as run_ctx
    [Lifecycle Hooks\n(RunHooks / AgentHooks)] as hooks
    [RunState &\nRunResult / RunResultStreaming] as run_result
    [Exceptions\n(MaxTurnsExceeded, GuardrailTripped,\nInputGuardrailTripwireTriggered)] as exceptions
}

' ─────────────────────────────────────────
' TOOL SYSTEM
' ─────────────────────────────────────────
package "Tool System" {
    [Function Tools\n(@function_tool / FunctionTool)] as func_tools
    [Hosted Tools\n(WebSearchTool, FileSearchTool,\nComputerTool, CodeInterpreterTool)] as hosted_tools
    [Agent-as-Tool\n(Agent.as_tool())] as agent_as_tool
    [Function Schema\n(Pydantic-powered auto-schema)] as func_schema
}

' ─────────────────────────────────────────
' GUARDRAILS
' ─────────────────────────────────────────
package "Guardrails" {
    [Input Guardrails\n(parallel validation on first input)] as input_guard
    [Output Guardrails\n(validation on final output)] as output_guard
    [Tool Guardrails\n(input & output per tool call)] as tool_guard
}

' ─────────────────────────────────────────
' HANDOFFS & ORCHESTRATION
' ─────────────────────────────────────────
package "Handoffs & Multi-Agent Orchestration" {
    [Handoff\n(agent delegation, history transfer)] as handoff
    [Handoff Filters\n(remove_all_tools / custom filters)] as handoff_filters
    [Multi-Agent Patterns\n(manager-as-tools / peer handoffs\n/ parallel asyncio)] as multi_agent
}

' ─────────────────────────────────────────
' MEMORY & SESSIONS  (src/agents/memory/)
' ─────────────────────────────────────────
package "Memory & Sessions" {
    [Session Interface\n(SessionBase)] as session_iface
    [SQLite Session\n(sqlite_session)] as sqlite_session
    [OpenAI Conversations Session\n(server-side history)] as oai_conv_session
    [OpenAI Compaction Session\n(auto context-window management)] as oai_compact_session

    package "Extension Sessions" {
        [Advanced SQLite Session] as adv_sqlite
        [Redis Session] as redis_session
        [MongoDB Session] as mongo_session
        [SQLAlchemy Session] as sqlalchemy_session
        [Encrypted Session\n(Fernet envelope)] as enc_session
        [Dapr Session] as dapr_session
    }
}

note right of session_iface
  Sessions persist conversation history
  across turns, enabling stateful agents.
  Strategy is chosen per run via
  RunConfig.session.
end note

' ─────────────────────────────────────────
' MODEL PROVIDERS  (src/agents/models/)
' ─────────────────────────────────────────
package "Model Providers" {
    [Model Interface\n(Model / ModelProvider)] as model_iface
    [OpenAI Provider\n(Responses API — default)] as openai_provider
    [OpenAI Chat Completions\n(legacy / non-OpenAI compat)] as chatcmpl_provider
    [Multi-Provider Router] as multi_provider

    package "Extension Providers" {
        [LiteLLM Model / Provider\n(100+ LLM backends)] as litellm
        [AnyLLM Model / Provider\n(openai-compatible wrapper)] as anyllm
    }
}

' ─────────────────────────────────────────
' MCP INTEGRATION  (src/agents/mcp/)
' ─────────────────────────────────────────
package "MCP Integration" {
    [MCPServer\n(stdio / SSE / Streamable HTTP)] as mcp_server_comp
    [MCPServerManager\n(lifecycle, reconnect, tool cache)] as mcp_manager
    [MCP Tool Metadata\n(schema, filter, strict mode)] as mcp_meta
}

note bottom of mcp_server_comp
  MCP tools are exposed to agents
  identically to function tools —
  no special agent-side handling needed.
end note

' ─────────────────────────────────────────
' TRACING  (src/agents/tracing/)
' ─────────────────────────────────────────
package "Tracing & Observability" {
    [Trace / Span Manager] as trace_span
    [TraceProcessor Interface\n(OpenAI Traces — default)] as trace_proc
    [Custom Processors\n(third-party integrations)] as custom_proc
    [Visualization\n(draw_graph / Graphviz)] as visualization
}

' ─────────────────────────────────────────
' REALTIME AGENTS  (src/agents/realtime/)
' ─────────────────────────────────────────
package "Realtime Agents" {
    [RealtimeAgent\n(gpt-realtime-1.5)] as realtime_agent
    [RealtimeRunner\n(WebSocket session)] as realtime_runner
    [RealtimeSession\n(turn management,\ninterruption detection)] as realtime_session
    [Realtime Guardrails\n(parallel safety checks)] as realtime_guard
}

' ─────────────────────────────────────────
' VOICE PIPELINE  (src/agents/voice/)
' ─────────────────────────────────────────
package "Voice Pipeline" {
    [VoicePipeline\n(STT → Agent → TTS)] as voice_pipeline
    [VoiceWorkflow\n(input events, tool execution)] as voice_workflow
    [STT / TTS Model Adapters\n(OpenAI Whisper / TTS)] as voice_models
}

' ─────────────────────────────────────────
' SANDBOX AGENTS  (src/agents/extensions/sandbox/)
' ─────────────────────────────────────────
package "Sandbox Agents & Backends" {
    [SandboxAgent\n(manifest, capabilities, run_as)] as sandbox_agent
    [SandboxSession Interface] as sandbox_iface

    package "Sandbox Backends" {
        [Blaxel Backend] as blaxel
        [Cloudflare Backend] as cloudflare
        [E2B Backend] as e2b
        [Daytona Backend] as daytona
        [Modal Backend] as modal_be
        [Runloop Backend] as runloop
        [Vercel Backend] as vercel
    }
}

note right of sandbox_agent
  SandboxAgent extends Agent with
  real isolated workspaces.
  Each backend provides PTY shells,
  file mounts, and resumable sessions.
end note

' ─────────────────────────────────────────
' EXPERIMENTAL EXTENSIONS
' ─────────────────────────────────────────
package "Experimental Extensions" {
    [Codex\n(code-execution thread,\nresumable turns)] as codex
}

' ═══════════════════════════════════════════════════════
' RELATIONSHIPS
' ═══════════════════════════════════════════════════════

' --- User app entry point ---
user_app --> runner : "Runner.run() /\nrun_sync() /\nrun_streamed()"

' --- Runner orchestrates core primitives ---
runner --> agent            : "resolves agent config"
runner --> run_ctx          : "creates & passes context"
runner --> hooks            : "fires lifecycle events"
runner --> run_result       : "returns result"
runner --> exceptions       : "raises on limits/guardrail trips"

' --- Agent configuration ---
agent --> func_tools        : "tools[]"
agent --> hosted_tools      : "tools[]"
agent --> agent_as_tool     : "Agent.as_tool()"
agent --> input_guard       : "input_guardrails[]"
agent --> output_guard      : "output_guardrails[]"
agent --> handoff           : "handoffs[]"
agent --> mcp_server_comp   : "mcp_servers[]"

' --- Tool system internals ---
func_tools --> func_schema  : "auto-generates JSON schema"
agent_as_tool --> runner    : "sub-run via Runner"
tool_guard --> func_tools   : "wraps tool execution"

' --- Guardrails ---
input_guard --> runner      : "tripwire triggers fast-fail"
output_guard --> runner     : "tripwire triggers fast-fail"

' --- Handoff flow ---
handoff --> handoff_filters : "applies input filter"
handoff --> multi_agent     : "pattern: peer handoff"
agent_as_tool --> multi_agent : "pattern: manager-as-tools"

' --- Model provider selection ---
runner --> model_iface      : "calls model per turn"
model_iface <|-- openai_provider
model_iface <|-- chatcmpl_provider
model_iface <|-- multi_provider
model_iface <|-- litellm
model_iface <|-- anyllm

openai_provider --> responses_api     : "HTTPS / WebSocket"
chatcmpl_provider --> chatcmpl_api   : "HTTPS"
litellm --> chatcmpl_api             : "via litellm router"
anyllm --> chatcmpl_api              : "openai-compat endpoint"

' --- Session / memory ---
runner --> session_iface    : "RunConfig.session"
session_iface <|-- sqlite_session
session_iface <|-- oai_conv_session
session_iface <|-- oai_compact_session
session_iface <|-- adv_sqlite
session_iface <|-- redis_session
session_iface <|-- mongo_session
session_iface <|-- sqlalchemy_session
session_iface <|-- enc_session
session_iface <|-- dapr_session

oai_conv_session --> responses_api   : "server-side history"
oai_compact_session --> responses_api : "context compaction"

' --- MCP ---
mcp_manager --> mcp_server_comp : "manages lifecycle"
mcp_server_comp --> mcp_servers : "stdio / SSE / HTTP"
mcp_server_comp --> mcp_meta    : "schema & filter"

' --- Tracing ---
runner --> trace_span        : "emits spans per turn/tool/handoff"
trace_span --> trace_proc    : "flushes trace data"
trace_span --> custom_proc   : "optional third-party sink"
trace_span --> visualization : "draw_graph()"

' --- Realtime ---
user_app --> realtime_runner : "RealtimeRunner.run()"
realtime_runner --> realtime_agent   : "session management"
realtime_runner --> realtime_session : "turn & interruption control"
realtime_agent --> realtime_guard    : "parallel guardrails"
realtime_agent --> func_tools        : "tool execution"
realtime_runner --> realtime_api     : "WebSocket"
realtime_runner --> trace_span       : "emits spans"

' --- Voice ---
user_app --> voice_pipeline  : "VoicePipeline.run()"
voice_pipeline --> voice_workflow   : "routes audio events"
voice_pipeline --> voice_models     : "STT / TTS"
voice_workflow --> runner    : "executes agent turns"

' --- Sandbox ---
user_app --> sandbox_agent   : "SandboxAgent + manifest"
sandbox_agent --> sandbox_iface      : "SandboxSession"
sandbox_iface <|-- blaxel
sandbox_iface <|-- cloudflare
sandbox_iface <|-- e2b
sandbox_iface <|-- daytona
sandbox_iface <|-- modal_be
sandbox_iface <|-- runloop
sandbox_iface <|-- vercel
sandbox_agent --> runner     : "inherits Runner execution"

' --- Codex experimental ---
codex --> responses_api      : "Codex API"
codex --> trace_span         : "thread-level tracing"

@enduml
