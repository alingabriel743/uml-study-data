@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam node {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam artifact {
    BackgroundColor #DEE2E6
    BorderColor #6C757D
}
skinparam database {
    BackgroundColor #D0EBFF
    BorderColor #339AF0
}
skinparam cloud {
    BackgroundColor #E3FAFC
    BorderColor #0C8599
}
skinparam component {
    BackgroundColor #FFF3BF
    BorderColor #F59F00
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 10

title OpenAI Agents SDK — Deployment Architecture

' ─────────────────────────────────────────────
' Developer / Application Runtime
' ─────────────────────────────────────────────
node "Developer Application\n(Python 3.10+)" <<Runtime>> as app {

    artifact "openai-agents\npackage" as sdk

    node "Agent Runtime" <<Process>> as runtime {
        artifact "Runner\n(run / run_sync / run_streamed)" as runner
        artifact "Agent + Guardrails" as agent
        artifact "Tool Dispatcher\n(function tools, hosted tools)" as tools
        artifact "Handoff Engine" as handoffs
    }

    node "Tracing Subsystem" <<Module>> as tracing_local {
        artifact "TraceProvider" as trace_provider
        artifact "BatchTraceProcessor" as batch_proc
    }

    node "Session / Memory Layer" <<Module>> as session_layer {
        artifact "Session Interface\n(SQLiteSession, RedisSession,\nMongoDBSession, DaprSession,\nSQLAlchemySession)" as session_impl
    }
}

' ─────────────────────────────────────────────
' OpenAI Platform
' ─────────────────────────────────────────────
cloud "OpenAI Platform" as openai_cloud {
    node "Responses API" <<HTTPS>> as responses_api
    node "Chat Completions API" <<HTTPS>> as chatcmpl_api
    node "Traces Dashboard\n(platform.openai.com/traces)" <<Web>> as traces_dashboard
    database "OpenAI Conversations\n(Hosted Sessions)" as openai_sessions
}

' ─────────────────────────────────────────────
' Third-party / Alternative LLM Providers
' ─────────────────────────────────────────────
cloud "Third-party LLM Providers\n(LiteLLM / AnyLLM)" <<Cloud>> as llm_providers {
    artifact "Anthropic / Gemini /\nAzure OpenAI / etc." as alt_models
}

' ─────────────────────────────────────────────
' MCP Server Layer
' ─────────────────────────────────────────────
node "MCP Servers" <<External>> as mcp_layer {
    artifact "Hosted MCP Server\n(via Responses API)" as mcp_hosted
    artifact "Streamable HTTP\nMCP Server" as mcp_http
    artifact "HTTP + SSE\nMCP Server" as mcp_sse
    artifact "stdio MCP Server\n(local process)" as mcp_stdio
}

' ─────────────────────────────────────────────
' Sandbox Execution Environments
' ─────────────────────────────────────────────
node "Sandbox Execution Environments" <<Compute>> as sandbox_layer {
    artifact "Unix Local /\nDocker Sandbox" as sandbox_local
    artifact "E2B Sandbox" as sandbox_e2b
    artifact "Daytona Sandbox" as sandbox_daytona
    artifact "Modal Sandbox" as sandbox_modal
    artifact "Runloop Sandbox" as sandbox_runloop
    artifact "Blaxel Sandbox" as sandbox_blaxel
    artifact "Cloudflare /\nVercel Sandbox" as sandbox_cf
}

' ─────────────────────────────────────────────
' Session / Persistent Storage Backends
' ─────────────────────────────────────────────
node "Persistent Storage Backends" <<Infrastructure>> as storage_layer {
    database "SQLite\n(local file)" as db_sqlite
    database "Redis" as db_redis
    database "MongoDB" as db_mongo
    database "Dapr State Store" as db_dapr
    database "SQLAlchemy\n(PostgreSQL / MySQL / etc.)" as db_sqlalchemy
}

' ─────────────────────────────────────────────
' External Tracing / Observability Backends
' ─────────────────────────────────────────────
cloud "Observability & Tracing Backends\n(optional)" as obs_cloud {
    artifact "Weights & Biases /\nLangfuse / Braintrust /\nArize Phoenix / MLflow\n(+ many others)" as ext_tracing
}

' ─────────────────────────────────────────────
' CI / CD Pipeline
' ─────────────────────────────────────────────
node "GitHub Actions CI/CD" <<Pipeline>> as cicd {
    artifact "tests.yml\n(pytest suite)" as ci_tests
    artifact "publish.yml\n(PyPI release)" as ci_publish
}

' ─────────────────────────────────────────────
' Connections
' ─────────────────────────────────────────────

' SDK wires the runtime together
sdk --> runtime : "imports / initialises"

' Agent runtime calls OpenAI APIs
runner --> responses_api    : "Responses API\n(HTTPS / WebSocket)"
runner --> chatcmpl_api     : "Chat Completions API\n(HTTPS)"

' Tools
tools --> mcp_hosted        : "HostedMCPTool\n(delegated to Responses API)"
tools --> mcp_http          : "MCPServerStreamableHttp\n(HTTPS)"
tools --> mcp_sse           : "MCPServerSse\n(HTTP+SSE)"
tools --> mcp_stdio         : "MCPServerStdio\n(subprocess stdin/stdout)"

' MCP hosted tool goes through Responses API
mcp_hosted ..> responses_api : "executed by\nOpenAI"

' Handoff engine
handoffs --> agent           : "delegates to\nnext agent"

' Tracing pipeline
trace_provider --> batch_proc : "buffers spans"
batch_proc --> traces_dashboard : "BackendSpanExporter\n(HTTPS batch)"
batch_proc --> ext_tracing      : "custom TraceProcessor\n(optional)"

' Session / Memory
session_layer --> db_sqlite    : "local persistence"
session_layer --> db_redis     : "Redis session"
session_layer --> db_mongo     : "MongoDB session"
session_layer --> db_dapr      : "Dapr state"
session_layer --> db_sqlalchemy : "SQL session"
session_layer --> openai_sessions : "OpenAI Conversations\nAPI (hosted)"

' Sandbox execution
runner --> sandbox_local  : "SandboxRunConfig\n(UnixLocal / Docker)"
runner --> sandbox_e2b    : "E2BSandboxClient"
runner --> sandbox_daytona : "DaytonaSandboxClient"
runner --> sandbox_modal  : "ModalSandboxClient"
runner --> sandbox_runloop : "RunloopSandboxClient"
runner --> sandbox_blaxel  : "BlaxelSandboxClient"
runner --> sandbox_cf      : "Cloudflare / Vercel\nSandboxClient"

' Alternative model providers
runner --> llm_providers : "LiteLLMModel /\nAnyLLMModel (HTTPS)"

' CI/CD publishes the package
cicd --> sdk : "publishes\nopenai-agents to PyPI"

note top of mcp_layer
  MCP transports:
  • Hosted — OpenAI routes calls
  • Streamable HTTP / SSE — remote servers
  • stdio — local subprocess
end note

note right of session_layer
  Session backends are pluggable.
  Default: SQLiteSession (local file).
  Production: Redis, MongoDB,
  SQLAlchemy, or OpenAI Conversations.
end note

note bottom of sandbox_layer
  Sandbox agents run in isolated workspaces.
  Client choice is runtime-configurable via
  SandboxRunConfig.client.
end note

@enduml
