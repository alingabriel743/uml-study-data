{
  "scope": "realtime_websocket_session",
  "title": "Realtime WebSocket Session",
  "diagram_type": "sequence",
  "key_participants": [
    "Application",
    "RealtimeSession",
    "OpenAIRealtimeWebSocketModel",
    "_ResponseCreateSequencer",
    "WebSocketConnection",
    "OpenAI_RealtimeAPI",
    "RealtimeAgent",
    "FunctionTool"
  ],
  "interaction_flow": [
    "=== CONNECTION SETUP ===",
    "Application → RealtimeSession: __aenter__() / enter()",
    "RealtimeSession → OpenAIRealtimeWebSocketModel: add_listener(self)",
    "RealtimeSession → RealtimeAgent: _get_updated_model_settings_from_agent(starting_settings, agent)",
    "RealtimeAgent → RealtimeAgent: get_system_prompt(context_wrapper)",
    "RealtimeAgent → RealtimeAgent: get_all_tools(context_wrapper)",
    "RealtimeSession → OpenAIRealtimeWebSocketModel: connect(model_config)",
    "OpenAIRealtimeWebSocketModel → OpenAIRealtimeWebSocketModel: get_api_key(options.api_key)",
    "OpenAIRealtimeWebSocketModel → WebSocketConnection: _create_websocket_connection(url, headers, transport_config)",
    "WebSocketConnection → OpenAI_RealtimeAPI: websockets.connect(wss://api.openai.com/v1/realtime?model=...)",
    "OpenAIRealtimeWebSocketModel → OpenAIRealtimeWebSocketModel: asyncio.create_task(_listen_for_messages())",
    "OpenAIRealtimeWebSocketModel → OpenAIRealtimeWebSocketModel: _update_session_config(model_settings)",
    "OpenAIRealtimeWebSocketModel → WebSocketConnection: _send_raw_message(SessionUpdateEvent)",
    "WebSocketConnection → OpenAI_RealtimeAPI: send session.update payload",
    "RealtimeSession → Application: return self (RealtimeSession context manager)",
    "RealtimeSession → Application: put_event(RealtimeHistoryUpdated)",

    "=== SEND AUDIO ===",
    "Application → RealtimeSession: send_audio(audio_bytes, commit=False)",
    "RealtimeSession → OpenAIRealtimeWebSocketModel: send_event(RealtimeModelSendAudio(audio, commit))",
    "OpenAIRealtimeWebSocketModel → OpenAIRealtimeWebSocketModel: _send_audio(event)",
    "OpenAIRealtimeWebSocketModel → _ConversionHelper: convert_audio_to_input_audio_buffer_append(event)",
    "OpenAIRealtimeWebSocketModel → WebSocketConnection: _send_raw_message(InputAudioBufferAppendEvent)",
    "WebSocketConnection → OpenAI_RealtimeAPI: send input_audio_buffer.append (base64 PCM16)",
    "alt commit=True",
    "  OpenAIRealtimeWebSocketModel → WebSocketConnection: _send_raw_message(InputAudioBufferCommitEvent)",
    "  WebSocketConnection → OpenAI_RealtimeAPI: send input_audio_buffer.commit",
    "end",

    "=== RECEIVE MESSAGES LOOP (_listen_for_messages) ===",
    "OpenAI_RealtimeAPI → WebSocketConnection: server event (JSON text)",
    "WebSocketConnection → OpenAIRealtimeWebSocketModel: async for message in _websocket",
    "OpenAIRealtimeWebSocketModel → OpenAIRealtimeWebSocketModel: json.loads(message)",
    "OpenAIRealtimeWebSocketModel → OpenAIRealtimeWebSocketModel: _handle_ws_event(parsed_dict)",
    "OpenAIRealtimeWebSocketModel → RealtimeSession: _emit_event(RealtimeModelRawServerEvent)",

    "=== AUDIO DELTA EVENT ===",
    "alt parsed.type == response.output_audio.delta",
    "  OpenAIRealtimeWebSocketModel → OpenAIRealtimeWebSocketModel: _handle_audio_delta(parsed)",
    "  OpenAIRealtimeWebSocketModel → ModelAudioTracker: on_audio_delta(item_id, content_index, audio_bytes)",
    "  OpenAIRealtimeWebSocketModel → RealtimeSession: _emit_event(RealtimeModelAudioEvent(data, response_id, item_id))",
    "  RealtimeSession → Application: put_event(RealtimeAudio)",
    "end",

    "=== AUDIO DONE EVENT ===",
    "alt parsed.type == response.output_audio.done",
    "  OpenAIRealtimeWebSocketModel → RealtimeSession: _emit_event(RealtimeModelAudioDoneEvent)",
    "  RealtimeSession → Application: put_event(RealtimeAudioEnd)",
    "end",

    "=== TURN STARTED / ENDED ===",
    "alt event.type == turn_started",
    "  OpenAIRealtimeWebSocketModel → RealtimeSession: _emit_event(RealtimeModelTurnStartedEvent)",
    "  RealtimeSession → Application: put_event(RealtimeAgentStartEvent(agent))",
    "end",
    "alt event.type == turn_ended",
    "  OpenAIRealtimeWebSocketModel → RealtimeSession: _emit_event(RealtimeModelTurnEndedEvent)",
    "  RealtimeSession → Application: put_event(RealtimeAgentEndEvent(agent))",
    "end",

    "=== FUNCTION CALL / TOOL EXECUTION ===",
    "alt event.type == function_call (RealtimeModelToolCallEvent)",
    "  OpenAIRealtimeWebSocketModel → RealtimeSession: _emit_event(RealtimeModelToolCallEvent)",
    "  RealtimeSession → RealtimeSession: _handle_tool_call(event, agent_snapshot) [or enqueue async task]",
    "  RealtimeSession → RealtimeAgent: get_all_tools(context_wrapper)",
    "  RealtimeSession → Application: put_event(RealtimeToolStart)",
    "  RealtimeSession → FunctionTool: invoke_function_tool(tool, context, arguments)",
    "  FunctionTool → RealtimeSession: return result",
    "  RealtimeSession → OpenAIRealtimeWebSocketModel: send_event(RealtimeModelSendToolOutput(output, start_response=True))",
    "  OpenAIRealtimeWebSocketModel → WebSocketConnection: _send_raw_message(ConversationItemCreateEvent)",
    "  OpenAIRealtimeWebSocketModel → _ResponseCreateSequencer: reserve_response_create_request()",
    "  OpenAIRealtimeWebSocketModel → WebSocketConnection: _send_raw_message(ResponseCreateEvent)",
    "  WebSocketConnection → OpenAI_RealtimeAPI: send response.create",
    "  RealtimeSession → Application: put_event(RealtimeToolEnd)",
    "end",

    "=== VAD SPEECH STARTED / INTERRUPT ===",
    "alt parsed.type == input_audio_buffer.speech_started",
    "  OpenAIRealtimeWebSocketModel → RealtimeSession: _emit_event(RealtimeModelAudioInterruptedEvent)",
    "  OpenAIRealtimeWebSocketModel → WebSocketConnection: _send_raw_message(ConversationItemTruncateEvent)",
    "  OpenAIRealtimeWebSocketModel → OpenAIRealtimeWebSocketModel: _cancel_response()",
    "  OpenAIRealtimeWebSocketModel → WebSocketConnection: _send_raw_message(ResponseCancelEvent)",
    "  RealtimeSession → Application: put_event(RealtimeAudioInterrupted)",
    "end",

    "=== TRANSCRIPT DELTA & GUARDRAILS ===",
    "alt event.type == transcript_delta",
    "  RealtimeSession → RealtimeSession: accumulate _item_transcripts[item_id]",
    "  RealtimeSession → RealtimeSession: _enqueue_guardrail_task(transcript, response_id) [if debounce threshold crossed]",
    "  RealtimeSession → Application: (guardrail tripped) put_event(RealtimeGuardrailTripped)",
    "end",

    "=== SESSION CLOSE ===",
    "Application → RealtimeSession: __aexit__() / close()",
    "RealtimeSession → RealtimeSession: _cleanup() — cancel guardrail/tool tasks, remove listener",
    "RealtimeSession → OpenAIRealtimeWebSocketModel: close()",
    "OpenAIRealtimeWebSocketModel → OpenAIRealtimeWebSocketModel: _cancel_response_create_tasks()",
    "OpenAIRealtimeWebSocketModel → WebSocketConnection: websocket.close()",
    "OpenAIRealtimeWebSocketModel → OpenAIRealtimeWebSocketModel: cancel _websocket_task"
  ],
  "key_relationships": [
    "RealtimeSession implements RealtimeModelListener (on_event callback)",
    "RealtimeSession composes OpenAIRealtimeWebSocketModel (via RealtimeModel interface)",
    "OpenAIRealtimeWebSocketModel composes _ResponseCreateSequencer (response sequencing)",
    "OpenAIRealtimeWebSocketModel composes ModelAudioTracker (audio state tracking)",
    "OpenAIRealtimeWebSocketModel composes WebSocketConnection (websockets.asyncio.client.ClientConnection)",
    "OpenAIRealtimeWebSocketModel holds list[RealtimeModelListener] for event fan-out",
    "RealtimeSession composes RealtimeAgent (current active agent, can switch on handoff)",
    "RealtimeSession uses asyncio.Queue[RealtimeSessionEvent] as event buffer to Application"
  ],
  "class_signatures": {
    "RealtimeSession": {
      "inherits": "RealtimeModelListener",
      "constructor": "__init__(model: RealtimeModel, agent: RealtimeAgent, context: TContext | None, model_config: RealtimeModelConfig | None, run_config: RealtimeRunConfig | None)",
      "key_methods": [
        "async __aenter__() -> RealtimeSession",
        "async __aexit__(...) -> None",
        "async __aiter__() -> AsyncIterator[RealtimeSessionEvent]",
        "async send_message(message: RealtimeUserInput) -> None",
        "async send_audio(audio: bytes, *, commit: bool = False) -> None",
        "async interrupt() -> None",
        "async update_agent(agent: RealtimeAgent) -> None",
        "async on_event(event: RealtimeModelEvent) -> None",
        "async approve_tool_call(call_id: str, *, always: bool = False) -> None",
        "async reject_tool_call(call_id: str, *, always: bool = False, rejection_message: str | None = None) -> None",
        "async close() -> None"
      ],
      "key_state": [
        "_model: RealtimeModel",
        "_current_agent: RealtimeAgent",
        "_history: list[RealtimeItem]",
        "_event_queue: asyncio.Queue[RealtimeSessionEvent]",
        "_pending_tool_calls: dict[str, tuple[...]]",
        "_item_transcripts: dict[str, str]",
        "_guardrail_tasks: set[asyncio.Task]",
        "_async_tool_calls: bool"
      ]
    },
    "OpenAIRealtimeWebSocketModel": {
      "inherits": "RealtimeModel",
      "constructor": "__init__(*, transport_config: TransportConfig | None = None)",
      "key_methods": [
        "async connect(options: RealtimeModelConfig) -> None",
        "async _listen_for_messages() -> None",
        "async send_event(event: RealtimeModelSendEvent) -> None",
        "async _send_audio(event: RealtimeModelSendAudio) -> None",
        "async _send_user_input(event: RealtimeModelSendUserInput) -> None",
        "async _send_tool_output(event: RealtimeModelSendToolOutput) -> None",
        "async _send_interrupt(event: RealtimeModelSendInterrupt) -> None",
        "async _handle_ws_event(event: dict) -> None",
        "async _handle_audio_delta(parsed: ResponseAudioDeltaEvent) -> None",
        "async _emit_event(event: RealtimeModelEvent) -> None",
        "async close() -> None",
        "void add_listener(listener: RealtimeModelListener)",
        "void remove_listener(listener: RealtimeModelListener)"
      ],
      "key_state": [
        "_websocket: ClientConnection | None",
        "_websocket_task: asyncio.Task | None",
        "_listeners: list[RealtimeModelListener]",
        "_response_create_sequencer: _ResponseCreateSequencer",
        "_audio_state_tracker: ModelAudioTracker",
        "_playback_tracker: RealtimePlaybackTracker | None",
        "_tracing_config: RealtimeModelTracingConfig | 'auto' | None"
      ]
    }
  },
  "ws_events_sent_to_openai": [
    "session.update — initial config with instructions/tools/voice/modalities",
    "input_audio_buffer.append — raw PCM16 audio chunks (base64)",
    "input_audio_buffer.commit — manual commit of audio buffer",
    "conversation.item.create — user text/image message",
    "response.create — trigger model response",
    "response.cancel — cancel ongoing response",
    "conversation.item.truncate — truncate audio on interrupt"
  ],
  "ws_events_received_from_openai": [
    "response.output_audio.delta — audio bytes streamed back",
    "response.output_audio.done — audio stream complete",
    "response.output_item.added/done — message/function_call items",
    "conversation.item.created/retrieved — conversation history items",
    "input_audio_buffer.speech_started — VAD detects user speech (triggers barge-in)",
    "response.created — model started a response",
    "response.done — model finished a response",
    "error — API-level error"
  ],
  "session_events_emitted_to_application": [
    "RealtimeRawModelEvent — every model event (raw pass-through)",
    "RealtimeAudio(audio, item_id, content_index)",
    "RealtimeAudioEnd(item_id, content_index)",
    "RealtimeAudioInterrupted(item_id, content_index)",
    "RealtimeAgentStartEvent(agent) — turn started",
    "RealtimeAgentEndEvent(agent) — turn ended",
    "RealtimeHistoryAdded(item)",
    "RealtimeHistoryUpdated(history)",
    "RealtimeToolStart(tool, agent, arguments)",
    "RealtimeToolEnd(tool, output, agent, arguments)",
    "RealtimeToolApprovalRequired(agent, tool, call_id, arguments)",
    "RealtimeHandoffEvent(from_agent, to_agent)",
    "RealtimeGuardrailTripped",
    "RealtimeError(error)",
    "RealtimeInputAudioTimeoutTriggered"
  ],
  "important_notes": [
    "Default model: gpt-realtime-1.5; default voice: ash; default turn_detection: semantic_vad with interrupt_response=True",
    "Audio format: pcm16 for both input and output by default",
    "Transcription model: gpt-4o-mini-transcribe",
    "WebSocket URL: wss://api.openai.com/v1/realtime?model={model} or ?call_id={call_id}",
    "_ResponseCreateSequencer serializes response.create events to prevent concurrent responses",
    "Guardrails run on transcript deltas with debounce_text_length threshold (default 100 chars)",
    "Tool calls can run async (default) or sync based on run_config.async_tool_calls",
    "Handoffs update the session config (instructions/tools) before sending tool output",
    "On WebSocket close, _listen_for_messages releases all response waiters via _release_response_waiters()"
  ],
  "source_files_analyzed": [
    "src/agents/realtime/session.py",
    "src/agents/realtime/openai_realtime.py"
  ]
}
