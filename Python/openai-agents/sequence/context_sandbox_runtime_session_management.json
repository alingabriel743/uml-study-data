{
  "scope": "sandbox_runtime_session_management",
  "title": "Sandbox Runtime Session Management",
  "diagram_type": "sequence",
  "key_participants": [
    "Runner",
    "SandboxRuntimeSessionManager",
    "SandboxRunConfig",
    "BaseSandboxClient",
    "BaseSandboxSession",
    "_SandboxSessionResources",
    "SandboxAgent",
    "Capability",
    "Manifest",
    "RunState"
  ],
  "interaction_flow": [
    "Runner → SandboxRuntimeSessionManager: __init__(starting_agent, sandbox_config, run_state)",
    "SandboxRuntimeSessionManager → RunState: _build_agent_identity_keys_by_id(resume_identity_root)",
    "Runner → SandboxRuntimeSessionManager: acquire_agent(agent: SandboxAgent)",
    "SandboxRuntimeSessionManager → agent: get _sandbox_concurrency_guard; create if absent",
    "SandboxRuntimeSessionManager → _SandboxConcurrencyGuard: check active_runs > 0 → raise RuntimeError if concurrent",
    "SandboxRuntimeSessionManager → _SandboxConcurrencyGuard: active_runs += 1",
    "SandboxRuntimeSessionManager → self: _ensure_resume_key(agent)",
    "Runner → SandboxRuntimeSessionManager: ensure_session(agent, capabilities, is_resumed_state)",
    "SandboxRuntimeSessionManager → self: _resources_by_agent.get(agent_id) → None → _create_resources()",
    "--- _create_resources: BRANCH A (live session injected) ---",
    "SandboxRuntimeSessionManager → SandboxRunConfig: sandbox_config.session is not None?",
    "SandboxRuntimeSessionManager → self: _configure_session_materialization(session, concurrency_limits)",
    "SandboxRuntimeSessionManager → BaseSandboxSession: running()",
    "SandboxRuntimeSessionManager → self: _process_live_session_manifest(agent, capabilities, session, running)",
    "_process_live_session_manifest → self: _process_manifest(capabilities, manifest, run_as_user)",
    "_process_manifest → Capability: capability.process_manifest(manifest) [for each]",
    "SandboxRuntimeSessionManager → BaseSandboxSession: _apply_entry_batch(entries_to_apply, base_dir) [if entries differ]",
    "SandboxRuntimeSessionManager → _SandboxSessionResources: return(session, client=None, owns_session=False)",
    "--- _create_resources: BRANCH B (resume from state) ---",
    "SandboxRuntimeSessionManager → self: _resolve_client() → BaseSandboxClient",
    "SandboxRuntimeSessionManager → self: _resume_state_payload_for_agent(client, agent, agent_id)",
    "_resume_state_payload_for_agent → RunState: read _sandbox dict, match backend_id, match resume key",
    "SandboxRuntimeSessionManager → BaseSandboxClient: deserialize_session_state(payload)",
    "SandboxRuntimeSessionManager → self: _process_resumed_state_manifest(agent, capabilities, session_state)",
    "SandboxRuntimeSessionManager → BaseSandboxClient: resume(explicit_state) [spans: sandbox.resume_session]",
    "SandboxRuntimeSessionManager → self: _configure_session_materialization(resumed_session, concurrency_limits)",
    "SandboxRuntimeSessionManager → _SandboxSessionResources: return(resumed_session, client, owns_session=True)",
    "--- _create_resources: BRANCH C (create fresh session) ---",
    "SandboxRuntimeSessionManager → self: _resolve_manifest(agent, resume_from_run_state)",
    "SandboxRuntimeSessionManager → self: _process_manifest(capabilities, manifest, run_as_user)",
    "SandboxRuntimeSessionManager → BaseSandboxClient: create(snapshot, manifest, options) [spans: sandbox.create_session]",
    "SandboxRuntimeSessionManager → self: _configure_session_materialization(session, concurrency_limits)",
    "SandboxRuntimeSessionManager → self: _ensure_session_manifest_has_run_as_user(session, agent)",
    "SandboxRuntimeSessionManager → _SandboxSessionResources: return(session, client, owns_session=True)",
    "--- back in ensure_session ---",
    "SandboxRuntimeSessionManager → _SandboxSessionResources: ensure_started()",
    "_SandboxSessionResources → BaseSandboxSession: running() → if not started: session.start()",
    "SandboxRuntimeSessionManager → Runner: return session",
    "--- Agent preparation (runtime_agent_preparation.py) ---",
    "Runner → prepare_sandbox_agent(agent, session, capabilities, run_config_model)",
    "prepare_sandbox_agent → session: session.state.manifest",
    "prepare_sandbox_agent → Capability[]: capability.required_capability_types() [validate deps]",
    "prepare_sandbox_agent → Capability[]: capability.tools() → capability_tools",
    "prepare_sandbox_agent → resolve_sandbox_model_name(agent, run_config_model)",
    "prepare_sandbox_agent → Capability[]: capability.sampling_params() → deep_merge extra_args",
    "prepare_sandbox_agent → build_sandbox_instructions(base_instructions, additional_instructions, capabilities, manifest)",
    "build_sandbox_instructions → get_default_sandbox_instructions() [cached]",
    "build_sandbox_instructions → Capability[]: capability.instructions(manifest)",
    "build_sandbox_instructions → build_remote_mount_policy_instructions(manifest)",
    "build_sandbox_instructions → _filesystem_instructions(manifest) [render_manifest_description]",
    "prepare_sandbox_agent → agent.clone(instructions, model_settings, tools, capabilities)",
    "prepare_sandbox_agent → set_public_agent(prepared_agent, agent)",
    "--- cleanup ---",
    "Runner → SandboxRuntimeSessionManager: cleanup()",
    "SandboxRuntimeSessionManager → custom_span: sandbox.cleanup_sessions [if tracing enabled]",
    "SandboxRuntimeSessionManager → _SandboxSessionResources: cleanup() [for each, if owns_session]",
    "_SandboxSessionResources → BaseSandboxSession: run_pre_stop_hooks()",
    "_SandboxSessionResources → BaseSandboxSession: stop()",
    "_SandboxSessionResources → BaseSandboxSession: shutdown()",
    "_SandboxSessionResources → BaseSandboxClient: delete(session) [if SandboxSession]",
    "_SandboxSessionResources → BaseSandboxSession: _aclose_dependencies()",
    "SandboxRuntimeSessionManager → self: serialize_resume_state() → resume_state dict",
    "serialize_resume_state → self: _resolve_client()",
    "serialize_resume_state → self: _serialize_sessions_by_agent(client)",
    "_serialize_sessions_by_agent → BaseSandboxClient: serialize_session_state(agent_resources.state)",
    "SandboxRuntimeSessionManager → self: _release_agents() [decrement active_runs guards]",
    "SandboxRuntimeSessionManager → Runner: return resume_state dict"
  ],
  "key_relationships": [
    "SandboxRuntimeSessionManager composes _SandboxSessionResources (one per agent_id)",
    "SandboxRuntimeSessionManager depends_on SandboxRunConfig (sandbox_config)",
    "SandboxRuntimeSessionManager depends_on RunState (for sandbox resume payload)",
    "SandboxRuntimeSessionManager depends_on BaseSandboxClient (create/resume/delete/serialize)",
    "_SandboxSessionResources wraps BaseSandboxSession and BaseSandboxClient",
    "_SandboxSessionResources owns lifecycle: ensure_started → cleanup (stop/shutdown/delete)",
    "SandboxRuntimeSessionManager uses _SandboxConcurrencyGuard (per SandboxAgent) to prevent concurrent reuse",
    "prepare_sandbox_agent depends_on BaseSandboxSession (reads manifest from session.state)",
    "prepare_sandbox_agent depends_on Capability[] (tools, sampling_params, instructions, process_manifest)",
    "SandboxAgent has default_manifest, run_as, base_instructions, instructions, model_settings, tools"
  ],
  "session_creation_branches": {
    "live_session": "sandbox_config.session provided → owns_session=False, apply manifest diffs if running",
    "resume_from_state": "session_state or run_state._sandbox match → client.resume(state) → owns_session=True",
    "fresh_create": "no existing state → client.create(snapshot, manifest, options) → owns_session=True"
  },
  "resume_state_schema": {
    "backend_id": "client.backend_id string",
    "current_agent_key": "stable resume key for the current agent",
    "current_agent_name": "agent.name",
    "session_state": "serialized session state dict (current agent)",
    "sessions_by_agent": "dict[resume_key → {agent_name, session_state}]"
  },
  "important_notes": [
    "acquire_agent() must be called before ensure_session(); raises RuntimeError on concurrent reuse of same SandboxAgent across runs",
    "Session cleanup is idempotent via _cleanup_lock; errors are propagated after all cleanup steps attempt",
    "Resume keys are stable (derived from agent name hierarchy via _build_agent_identity_keys_by_id) to survive across runs",
    "Live injected sessions (owns_session=False) cannot change root/env/users/groups/mounts; only file additions allowed",
    "Tracing uses custom_span for create_session, resume_session, and cleanup_sessions when a trace is active",
    "prepare_sandbox_agent clones the agent with merged instructions (base+additional+capability+filesystem) and capability tools injected",
    "SandboxConcurrencyLimits are validated on resolve and set on every session via _configure_session_materialization"
  ],
  "source_files_analyzed": [
    "src/agents/sandbox/runtime_session_manager.py",
    "src/agents/sandbox/runtime_agent_preparation.py",
    "docs/sandbox_agents.md"
  ]
}
