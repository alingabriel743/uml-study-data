title Function Tool Registration & Invocation

actor Developer as dev
participant "@function_tool\n(decorator)" as ft_dec
participant "function_schema" as fs
participant "FuncSchema" as fschema
participant "_build_wrapped\nFunctionTool" as bwft
participant "_FailureHandling\nFunctionToolInvoker" as fhfti
participant "FunctionTool" as ft
participant "Runner /\nRun Loop" as runner
participant "execute_function\n_tool_calls" as eftc
participant "ToolContext" as tctx
participant "invoke_function\n_tool" as ift
participant "_on_invoke\n_tool_impl" as oiti
participant "PythonFunction" as pyfunc

' ─────────────────────────────────────────────
box "Phase 1 — Tool Registration" #EEF2FF
' ─────────────────────────────────────────────

dev -> ft_dec : @function_tool(func,\nname_override?, description_override?,\nfailure_error_function?, strict_mode?,\nis_enabled?, needs_approval?,\ntimeout?, defer_loading?)
activate ft_dec

ft_dec -> fs : function_schema(func,\nname_override, description_override,\ndocstring_style, use_docstring_info,\nstrict_json_schema)
activate fs

note right of fs
  Parses function signature via **inspect**
  Parses docstring via **griffe**
  Builds **Pydantic** validation model
  Derives JSON Schema from signature types
end note

fs --> ft_dec : FuncSchema { name, description,\nparams_pydantic_model,\nparams_json_schema, signature,\ntakes_context }
deactivate fs

ft_dec -> ft_dec : defines _on_invoke_tool_impl(ctx, input)\nclosure capturing FuncSchema + original func

note right of ft_dec
  **takes_context=True** when first param is
  RunContextWrapper/ToolContext — ctx injected automatically
end note

ft_dec -> bwft : _build_wrapped_function_tool(\nname, description, params_json_schema,\ninvoke_tool_impl=_on_invoke_tool_impl,\nfailure_error_function, strict_json_schema,\nis_enabled, needs_approval, timeout_seconds,\ntimeout_behavior, defer_loading)
activate bwft

bwft -> bwft : _build_handled_function_tool\n_error_handler(span_message, log_label,\nspan_message_for_json_decode_error)\n→ _on_handled_error closure

bwft -> fhfti : with_function_tool_failure_error_handler(\n_on_invoke_tool_impl, _on_handled_error)\n→ wraps invoker with error handling
activate fhfti
fhfti --> bwft : _FailureHandlingFunctionToolInvoker
deactivate fhfti

bwft -> ft : FunctionTool(\nname, description, params_json_schema,\non_invoke_tool=_FailureHandlingFunctionToolInvoker,\nstrict_json_schema, is_enabled,\nneeds_approval, timeout_seconds,\ntimeout_behavior, defer_loading)
activate ft

note right of ft
  **__post_init__** runs:
  • ensure_strict_json_schema(params_json_schema)
    if strict_json_schema=True (default)
  • _validate_function_tool_timeout_config(self)
  • Rebinds on_invoke_tool if it exposes
    __agents_bind_function_tool__ (copy-awareness)
  • defer_loading=True hides tool from LLM
    until ToolSearchTool loads it (Responses API)
end note

ft --> bwft : FunctionTool instance
deactivate ft

bwft -> bwft : set_function_tool_failure_error_function(\nfunction_tool, failure_error_function)\nstores _failure_error_function +\n_use_default_failure_error_function

bwft --> ft_dec : FunctionTool
deactivate bwft

ft_dec --> dev : FunctionTool
deactivate ft_dec

end box

' ─────────────────────────────────────────────
box "Phase 2 — Tool Invocation (Run Loop)" #F0FFF4
' ─────────────────────────────────────────────

runner -> eftc : execute_function_tool_calls(\nbindings, tool_runs: list[ToolRunFunction],\nhooks, context_wrapper, config)
activate eftc

loop for each ToolRunFunction (function_tool + tool_call)

    eftc -> tctx : ToolContext.from_agent_context(\ncontext_wrapper, tool_call.call_id,\ntool_call=raw_tool_call,\ntool_namespace, agent, run_config)
    activate tctx
    note right of tctx
      Extends RunContextWrapper[TContext]
      Adds: tool_name, tool_call_id,
      tool_arguments, tool_call,
      tool_namespace, agent, run_config
      Inherits agent_tool_state_scope
    end note
    tctx --> eftc : ToolContext
    deactivate tctx

    eftc -> eftc : open function_span(trace_tool_name)\nfor distributed tracing

    eftc -> ift : invoke_function_tool(\nfunction_tool, context=tool_context,\narguments=tool_call.arguments)
    activate ift

    alt timeout_seconds is None
        ift -> fhfti : await function_tool.on_invoke_tool\n(tool_context, arguments)
    else timeout_seconds set
        ift -> ift : asyncio.wait_for(\non_invoke_tool(...),\ntimeout=timeout_seconds)
        note right of ift
          On TimeoutError:
          • 'error_as_result' (default) → returns timeout message string
          • 'raise_exception' → raises ToolTimeoutError
          Timeout only valid for async handlers
        end note
        ift -> fhfti : await function_tool.on_invoke_tool\n(tool_context, arguments)
    end

    activate fhfti
    fhfti -> oiti : _on_invoke_tool_impl(ctx, input)
    activate oiti

    oiti -> oiti : _parse_function_tool_json_input(\ntool_name, input_json)\n→ json.loads(input)\nor raises ModelBehaviorError

    oiti -> oiti : schema.params_pydantic_model(**json_data)\n→ parsed Pydantic model\nor raises ModelBehaviorError on ValidationError

    oiti -> fschema : to_call_args(parsed)
    activate fschema
    fschema --> oiti : (args, kwargs)
    deactivate fschema

    alt async function
        oiti -> pyfunc : await the_func(ctx, *args, **kwargs)\nor await the_func(*args, **kwargs)
    else sync function
        oiti -> pyfunc : asyncio.to_thread(\nthe_func, ctx, *args, **kwargs)
        note right of pyfunc
          Sync functions are offloaded
          to a thread pool via asyncio.to_thread
        end note
    end

    activate pyfunc
    pyfunc --> oiti : result
    deactivate pyfunc

    oiti --> fhfti : result
    deactivate oiti

    fhfti --> ift : result
    deactivate fhfti

    ift --> eftc : tool_result string
    deactivate ift

end

eftc --> runner : tool results
deactivate eftc

end box

' ─────────────────────────────────────────────
box "Phase 3 — Error Handling Path" #FFF5F5
' ─────────────────────────────────────────────

runner -> eftc : (same call — error scenario)
activate eftc
eftc -> ift : invoke_function_tool(...)
activate ift
ift -> fhfti : await on_invoke_tool(ctx, input)
activate fhfti
fhfti -> oiti : _on_invoke_tool_impl(ctx, input)
activate oiti
oiti -> pyfunc : call function
activate pyfunc
pyfunc --> oiti : raises Exception
deactivate pyfunc
deactivate oiti

fhfti -> fhfti : maybe_invoke_function_tool\n_failure_error_function(\nfunction_tool, context, error)

fhfti -> fhfti : resolve_function_tool_failure\n_error_function(function_tool)\n→ if _use_default_failure_error_function\n   → default_tool_error_function\n   else → _failure_error_function

alt failure_error_function returns a string
    fhfti -> fhfti : failure_error_function(context, error)\n→ error string for LLM
    fhfti -> fhfti : _on_handled_error: attach_error_to\n_current_span(SpanError) + logger.error()\n_extract_tool_argument_json_error\nfor JSON decode detail
    fhfti --> ift : error string (LLM receives friendly message)
else failure_error_function is None
    fhfti --> ift : re-raises Exception
    note right of ift
      Exception propagates up to caller.
      No friendly error — caller handles it.
    end note
end

deactivate fhfti
ift --> eftc : error result / exception
deactivate ift
eftc --> runner : propagated result
deactivate eftc

end box

@enduml
