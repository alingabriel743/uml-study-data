@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #495057
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceParticipantFontColor #212529
skinparam sequenceLifeLineBorderColor #6C757D
skinparam sequenceGroupBorderColor #495057
skinparam sequenceGroupBackgroundColor #E9ECEF
skinparam sequenceGroupFontColor #212529
skinparam noteBorderColor #6C757D
skinparam noteBackgroundColor #FFF9C4
skinparam noteFontColor #212529

title Output Guardrails Execution

participant "Runner\n(run.py)" as Runner
participant "run_loop\n(run_loop.py)" as RunLoop
participant "run_output_guardrails\n(guardrails.py)" as RunOutputGuardrails
participant "run_single_output_guardrail" as RunSingleGuardrail
participant "OutputGuardrail\n(guardrail.py)" as OutputGuardrail
participant "guardrail_function\n(user-defined)" as GuardrailFn
participant "TracingSpan\n(guardrail_span)" as TracingSpan
participant "RunResultStreaming" as StreamingResult
participant "FunctionToolExecutor\n(tool_execution.py)" as ToolExecutor

' ─────────────────────────────────────────────
== Non-Streaming Path ==
' ─────────────────────────────────────────────

Runner -> RunLoop: run(agent, input, run_config)
activate RunLoop

RunLoop -> RunLoop: run_single_turn()\n→ SingleStepResult(NextStepFinalOutput)

RunLoop -> RunLoop: run_final_output_hooks(\nagent, hooks, context_wrapper, output)
note right of RunLoop
  on_agent_end lifecycle hooks
  fire **before** output guardrails
end note

RunLoop -> RunOutputGuardrails: run_output_guardrails(\nagent.output_guardrails + run_config.output_guardrails,\nagent, output, context_wrapper)
activate RunOutputGuardrails

note over RunOutputGuardrails
  Only runs for the **final agent** in a chain.
  Guardrails are merged from agent + RunConfig.
end note

loop for each guardrail — parallel via asyncio.create_task
    RunOutputGuardrails -> RunSingleGuardrail: asyncio.create_task(\nrun_single_output_guardrail(guardrail, ...))
    activate RunSingleGuardrail

    RunSingleGuardrail -> TracingSpan: guardrail_span(guardrail.get_name())
    activate TracingSpan

    RunSingleGuardrail -> OutputGuardrail: run(agent, agent_output, context)
    activate OutputGuardrail

    OutputGuardrail -> GuardrailFn: guardrail_function(\ncontext, agent, agent_output)\n[sync or async]
    activate GuardrailFn
    GuardrailFn --> OutputGuardrail: GuardrailFunctionOutput\n{ output_info: Any,\n  tripwire_triggered: bool }
    deactivate GuardrailFn

    OutputGuardrail --> RunSingleGuardrail: OutputGuardrailResult\n{ guardrail, agent, agent_output, output }
    deactivate OutputGuardrail

    RunSingleGuardrail -> TracingSpan: span_data.triggered =\nresult.output.tripwire_triggered
    deactivate TracingSpan

    RunSingleGuardrail --> RunOutputGuardrails: OutputGuardrailResult
    deactivate RunSingleGuardrail
end

note over RunOutputGuardrails
  asyncio.as_completed() — results processed
  in completion order, not submission order
end note

alt tripwire_triggered == True (first triggered guardrail)
    RunOutputGuardrails -> RunOutputGuardrails: cancel all remaining\nasyncio tasks
    RunOutputGuardrails -> TracingSpan: attach_error_to_current_span(SpanError)
    RunOutputGuardrails --> RunLoop: raise OutputGuardrailTripwireTriggered(result)
else all guardrails pass
    RunOutputGuardrails --> RunLoop: list[OutputGuardrailResult]
end
deactivate RunOutputGuardrails

RunLoop --> Runner: RunResult(\n  final_output=output,\n  output_guardrail_results=results\n)
deactivate RunLoop

' ─────────────────────────────────────────────
== Streaming Path ==
' ─────────────────────────────────────────────

Runner -> RunLoop: run_streamed(agent, input, run_config)
activate RunLoop

RunLoop -> RunLoop: run_single_turn_streamed()\n→ NextStepFinalOutput

RunLoop -> RunLoop: run_final_output_hooks(\nagent, hooks, context_wrapper, output)

RunLoop -> RunLoop: _finalize_streamed_final_output(\nstreamed_result, agent, run_config,\noutput, context_wrapper, save_items, items)
activate RunLoop

    RunLoop -> RunOutputGuardrails: _run_output_guardrails_for_stream:\nasyncio.create_task(run_output_guardrails(...))\nstored → streamed_result._output_guardrails_task
    activate RunOutputGuardrails

    note over RunOutputGuardrails
      Executes same parallel guardrail logic
      as the non-streaming path
    end note

    alt OutputGuardrailTripwireTriggered
        RunOutputGuardrails --> RunLoop: re-raise\nOutputGuardrailTripwireTriggered
    else CancelledError
        RunOutputGuardrails --> RunLoop: re-raise CancelledError
    else other Exception
        RunOutputGuardrails --> RunLoop: log error, return []
    else all pass
        RunOutputGuardrails --> RunLoop: list[OutputGuardrailResult]
    end
    deactivate RunOutputGuardrails

    RunLoop -> StreamingResult: output_guardrail_results = results
    RunLoop -> StreamingResult: final_output = output\nis_complete = True
    RunLoop -> StreamingResult: _event_queue.put_nowait(\nQueueCompleteSentinel())

deactivate RunLoop
deactivate RunLoop

' ─────────────────────────────────────────────
== Tool Output Guardrails (per Function Tool call) ==
' ─────────────────────────────────────────────

note over ToolExecutor
  Tool guardrails apply only to **@function_tool**
  decorated tools. Not to handoffs, hosted tools,
  or built-in execution tools.
end note

RunLoop -> ToolExecutor: execute tools
activate ToolExecutor

ToolExecutor -> ToolExecutor: _execute_tool_input_guardrails(\nfunc_tool, tool_context, agent, ...)
note right of ToolExecutor: Runs **serially** (not in parallel)\nper tool call

alt input guardrail behavior == reject_content
    ToolExecutor -> ToolExecutor: return rejection message\n(tool function never called)
else input guardrail behavior == raise_exception
    ToolExecutor --> RunLoop: raise ToolInputGuardrailTripwireTriggered
else input guardrail allows
    ToolExecutor -> ToolExecutor: execute tool function()\n→ real_result
    ToolExecutor -> ToolExecutor: _execute_tool_output_guardrails(\nfunc_tool, tool_context, agent, real_result, ...)
    alt output guardrail behavior == reject_content
        ToolExecutor -> ToolExecutor: replace final_result\nwith rejection message
    else output guardrail behavior == raise_exception
        ToolExecutor --> RunLoop: raise ToolOutputGuardrailTripwireTriggered
    else output guardrail allows
        ToolExecutor -> ToolExecutor: final_result = real_result
    end
end

ToolExecutor --> RunLoop: (function_results,\ntool_input_guardrail_results,\ntool_output_guardrail_results)
deactivate ToolExecutor

@enduml
