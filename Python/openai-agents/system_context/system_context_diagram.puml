@startuml
title OpenAI Agents SDK — System Context Diagram

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing true
skinparam backgroundColor #FFFFFF

skinparam rectangle {
    BackgroundColor<<System>> #1168BD
    FontColor<<System>> #FFFFFF
    BorderColor<<System>> #0D47A1
    BorderThickness<<System>> 3

    BackgroundColor<<External>> #6D6D6D
    FontColor<<External>> #FFFFFF
    BorderColor<<External>> #4A4A4A
    BorderThickness<<External>> 1

    BackgroundColor<<Database>> #2E7D32
    FontColor<<Database>> #FFFFFF
    BorderColor<<Database>> #1B5E20
    BorderThickness<<Database>> 2

    BackgroundColor<<Queue>> #E65100
    FontColor<<Queue>> #FFFFFF
    BorderColor<<Queue>> #BF360C
    BorderThickness<<Queue>> 2

    BackgroundColor<<Infrastructure>> #4A148C
    FontColor<<Infrastructure>> #FFFFFF
    BorderColor<<Infrastructure>> #311B92
    BorderThickness<<Infrastructure>> 2

    BackgroundColor<<Cache>> #00695C
    FontColor<<Cache>> #FFFFFF
    BorderColor<<Cache>> #004D40
    BorderThickness<<Cache>> 2
}

skinparam actor {
    BackgroundColor<<Person>> #08427B
    FontColor<<Person>> #FFFFFF
    BorderColor<<Person>> #052E56
}

skinparam arrow {
    Color #424242
    FontSize 10
    FontColor #616161
}

' ── Actors ─────────────────────────────────────────────────────────
actor "SDK Developer
[Python Application]

Builds agentic AI apps
using Agent & Runner primitives" as developer <<Person>>

actor "End User
[Client Application]

Interacts with apps
built on the SDK" as enduser <<Person>>

actor "Human Reviewer
[HITL Approval]

Reviews and approves
agent actions mid-run" as hitl <<Person>>

' ── Core System ────────────────────────────────────────────────────
rectangle "**OpenAI Agents SDK**
[Python Library — openai-agents]

Production runtime for agentic AI:
manages the agent loop, tool calls,
handoffs, guardrails, sessions,
tracing, voice pipeline, and
sandbox agent execution" as system <<System>>

' ── OpenAI Platform ────────────────────────────────────────────────
rectangle "**OpenAI Responses API**
[Primary Model Interface]

Powers the default agent loop
via structured request/response;
supports streaming and WebSocket
transport for connection reuse" as responses_api <<External>>

rectangle "**OpenAI Chat Completions API**
[Alternative Model Interface]

Provides OpenAI-compatible
chat completions for non-Responses
workflows and third-party adapters" as chatcmpl_api <<External>>

rectangle "**OpenAI Realtime API**
[gpt-realtime-1.5 / WebSocket]

Low-latency voice & realtime
agent sessions; supports
interruption detection and
streaming audio I/O" as realtime_api <<External>>

rectangle "**OpenAI Traces Dashboard**
[Observability Backend]

Stores and visualises agent runs,
LLM generations, tool calls,
guardrail events, and handoffs
for debugging and evaluation" as traces_dashboard <<External>>

rectangle "**OpenAI Prompt Templates**
[platform.openai.com/playground]

Reusable versioned system prompts
with variable substitution;
referenced by Agent.prompt config" as prompt_store <<External>>

' ── Third-Party LLM Providers ───────────────────────────────────────
rectangle "**LiteLLM Gateway**
[Multi-Provider Proxy]

Bridges Anthropic, Google Gemini,
Mistral, Azure, and 100+ providers
to the OpenAI Chat Completions
interface via 'litellm/' prefix" as litellm <<External>>

rectangle "**Anthropic Claude API**
[claude-3 / claude-4 models]

Extended thinking, vision, and
tool-use via LiteLLM or direct
ChatCompletions adapter;
thinking block signature handling" as anthropic <<External>>

rectangle "**Google Gemini API**
[Gemini 1.5 / 2.x models]

Multimodal LLM access via
LiteLLM; includes Gemini-specific
tool-call ID normalisation in
the stream handler" as gemini <<External>>

' ── MCP Ecosystem ───────────────────────────────────────────────────
rectangle "**MCP Stdio Servers**
[Local Process — stdin/stdout]

Filesystem, code-execution, and
custom tool servers launched as
child processes; communicate via
JSON-RPC over stdio transport" as mcp_stdio <<External>>

rectangle "**MCP HTTP / SSE Servers**
[Remote HTTP + SSE Transport]

Remotely hosted or locally run
MCP servers reachable over
Streamable HTTP or classic SSE;
enable shared tool registries" as mcp_http <<External>>

rectangle "**Hosted MCP Tools**
[OpenAI-Managed MCP]

Publicly reachable MCP servers
called by the Responses API
on the model's behalf; no local
network access required" as mcp_hosted <<External>>

' ── Voice & Audio ───────────────────────────────────────────────────
rectangle "**OpenAI STT API**
[Speech-to-Text — Whisper]

Transcribes audio input to text
for voice pipeline; audio bytes
streamed from microphone or
telephony gateway" as stt <<External>>

rectangle "**OpenAI TTS API**
[Text-to-Speech]

Synthesizes agent responses to
audio for playback; supports
multiple voice models and
streaming PCM output" as tts <<External>>

rectangle "**Twilio Telephony**
[WebSocket Media Streams]

Bridges telephone calls to the
Realtime API via WebSocket;
TwilioHandler manages bidirectional
audio and call lifecycle" as twilio <<External>>

' ── Sandbox Execution ───────────────────────────────────────────────
rectangle "**Unix Local Sandbox**
[Local Process / Filesystem]

Runs agent tasks in isolated Unix
workspaces; manifest-staged files,
shell capabilities, and resumable
sandbox sessions for development" as unix_sandbox <<Infrastructure>>

rectangle "**Docker Sandbox**
[Container Runtime]

Fully isolated container-based
workspaces for production or CI;
installed via openai-agents[docker]
extra with Docker engine backend" as docker_sandbox <<Infrastructure>>

' ── Observability & Tracing ─────────────────────────────────────────
rectangle "**Third-Party Trace Processors**
[W&B / LangSmith / Langfuse /
Braintrust / Arize / AgentOps
and 20+ more integrations]

Receive trace spans via custom
TraceProcessor; plugged in with
add_trace_processor() or
set_trace_processors() calls" as third_party_tracing <<External>>

' ── Host Application Frameworks ─────────────────────────────────────
rectangle "**FastAPI / Celery / RQ**
[Async & Background Workers]

Host apps embed the SDK for
background agent tasks; use
flush_traces() for immediate
export after each job unit" as host_frameworks <<External>>

' ── Relationships ────────────────────────────────────────────────────

developer --> system : "Python API\n(Agent, Runner, tools,\nguardrails, sessions)"
enduser --> system : "Application calls\n(prompts / inputs\nvia host app)"
hitl --> system : "HITL approval\n(approve / reject\ntool calls & interruptions)"

system --> responses_api : "HTTPS REST + WebSocket\n(model turns, tool calls,\nstreaming responses)"
system --> chatcmpl_api : "HTTPS REST\n(OpenAI-compatible\nchat completions)"
system --> realtime_api : "WebSocket\n(realtime voice sessions,\naudio streaming, interrupts)"
system --> traces_dashboard : "HTTPS (BatchTraceProcessor)\n(spans: agent, generation,\ntool, guardrail, handoff)"
system --> prompt_store : "HTTPS REST\n(fetch versioned prompt\ntemplates by ID)"

system --> litellm : "HTTPS (OpenAI-compat)\n(route via 'litellm/' prefix\nto 100+ providers)"
litellm --> anthropic : "HTTPS REST\n(Claude API requests,\nthinking block handling)"
litellm --> gemini : "HTTPS REST\n(Gemini API requests,\ntool-call ID normalisation)"

system --> mcp_stdio : "JSON-RPC / stdio\n(list_tools, call_tool\nvia child process)"
system --> mcp_http : "HTTP + SSE / Streamable HTTP\n(list_tools, call_tool\nremote MCP transport)"
system --> mcp_hosted : "HTTPS (via Responses API)\n(hosted tool calls delegated\nto OpenAI infrastructure)"

system --> stt : "HTTPS REST\n(audio bytes upload,\ntranscription response)"
system --> tts : "HTTPS REST\n(text input, streaming\nPCM audio output)"
system --> twilio : "WebSocket\n(bidirectional audio frames,\nTwilioHandler lifecycle)"

system --> unix_sandbox : "Local process / filesystem\n(stage manifest, run shell,\nsnapshot sandbox state)"
system --> docker_sandbox : "Docker API\n(create container, exec cmds,\nmount volumes, snapshot)"

system --> third_party_tracing : "Custom TraceProcessor\n(push spans & traces\nto external backends)"

system --> host_frameworks : "Python SDK calls\n(embedded in worker tasks;\nflush_traces() on job end)"

@enduml
