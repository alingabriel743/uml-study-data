@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BorderColor #495057
    FontColor #212529
}

left to right direction

title Agent Configuration and Setup

actor "Developer" as Dev
actor "OpenAI Platform" as OpenAI <<external>>
actor "MCP Server" as MCPServer <<external>>
actor "Runner" as Runner <<system>>

rectangle "Agent Configuration and Setup" {

    package "Agent Definition" {
        usecase "Define Agent" as UC01
        usecase "Set Static Instructions" as UC02
        usecase "Set Dynamic Instructions" as UC03
        usecase "Configure Prompt Template" as UC04
        usecase "Add Function Tools" as UC05
        usecase "Configure MCP Servers" as UC06
        usecase "Set Output Type / Schema" as UC07
        usecase "Configure Input Guardrails" as UC08
        usecase "Configure Output Guardrails" as UC09
        usecase "Define Handoffs" as UC10
        usecase "Configure Tool Use Behavior" as UC11
        usecase "Tune Model Settings" as UC12
        usecase "Attach Lifecycle Hooks" as UC13
    }

    package "Agent Reuse" {
        usecase "Clone Agent" as UC14
        usecase "Expose Agent as Tool" as UC15
    }

    package "Run Configuration" {
        usecase "Configure RunConfig" as UC16
        usecase "Configure Error Handlers" as UC17
        usecase "Set SDK-wide Defaults" as UC18
    }
}

' Developer initiates all top-level configuration use cases
Dev --> UC01
Dev --> UC14
Dev --> UC15
Dev --> UC16
Dev --> UC17
Dev --> UC18

' Agent configuration options extend the core Define Agent use case
UC02 .> UC01 : <<extend>>
UC03 .> UC01 : <<extend>>
UC04 .> UC01 : <<extend>>
UC05 .> UC01 : <<extend>>
UC06 .> UC01 : <<extend>>
UC07 .> UC01 : <<extend>>
UC08 .> UC01 : <<extend>>
UC09 .> UC01 : <<extend>>
UC10 .> UC01 : <<extend>>
UC11 .> UC01 : <<extend>>
UC12 .> UC01 : <<extend>>
UC13 .> UC01 : <<extend>>

' External system interactions
UC04 --> OpenAI
UC06 --> MCPServer

' Runner consumes the configured Agent and RunConfig
UC01 --> Runner : <<provides Agent>>
UC16 --> Runner : <<provides RunConfig>>

note right of UC03
  Supports sync and async callable:
  (RunContextWrapper, Agent) -> str
  Resolved at run time via get_system_prompt()
end note

note right of UC04
  Only for OpenAI models on Responses API.
  Accepts static prompt {id, version, variables}
  or a DynamicPromptFunction
end note

note right of UC06
  Developer must call server.connect()
  before passing to agent.
  mcp_config: convert_schemas_to_strict,
  failure_error_function
end note

note right of UC07
  Triggers OpenAI structured outputs mode.
  Accepts Pydantic model, dataclass, TypedDict,
  or AgentOutputSchemaBase. Default is str.
end note

note right of UC11
  "run_llm_again" (default) |
  "stop_on_first_tool" |
  StopAtTools(stop_at_tool_names=[...]) |
  ToolsToFinalOutputFunction
  reset_tool_choice=True prevents infinite loops
end note

note right of UC16
  Overrides agent-level model/model_settings
  for the entire run. Includes tracing, sandbox,
  session, guardrails, and handoff filter config.
  DEFAULT_MAX_TURNS = 10
end note

note bottom of UC18
  Must be called before first model call:
  set_default_openai_key() | set_default_openai_client()
  set_default_openai_api('chat_completions')
  Tracing is ON by default.
end note

@enduml
