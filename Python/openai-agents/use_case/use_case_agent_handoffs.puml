@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #1A1A2E
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Agent Handoffs and Routing

left to right direction

' ── Actors ────────────────────────────────────────────────────────────────────
actor "Developer" as dev
actor "LLM" as llm
actor "AgentRunner" as runner
actor "Specialist Agent\n(Target)" as target

' ── System Boundary ───────────────────────────────────────────────────────────
rectangle "Agent Handoffs and Routing System" {

    ' ── Package: Handoff Configuration ───────────────────────────────────────
    package "Handoff Configuration" {
        usecase "Create Handoff\nvia handoff() function" as UC1
        usecase "Register Handoff\non Agent.handoffs" as UC2
        usecase "Override Tool Name\n& Description" as UC3
        usecase "Set on_handoff Callback\n& input_type Schema" as UC4
        usecase "Dynamically Enable /\nDisable Handoff (is_enabled)" as UC5
        usecase "Inject Handoff\nPrompt Prefix" as UC6
        usecase "Configure Conversation\nHistory Wrappers" as UC7
    }

    ' ── Package: Runtime Routing ──────────────────────────────────────────────
    package "Runtime Routing" {
        usecase "Resolve Enabled\nHandoffs (get_handoffs)" as UC8
        usecase "Expose Handoff\nas LLM Tool\n(transfer_to_<agent>)" as UC9
        usecase "Invoke Handoff Tool" as UC10
        usecase "Execute Handoffs Step\n(execute_handoffs)" as UC11
        usecase "Validate Handoff\nInput Schema" as UC12
        usecase "Execute on_handoff\nCallback" as UC13
        usecase "Emit Handoff Hooks\n(on_handoff events)" as UC14
        usecase "Switch Active Agent\n(NextStepHandoff)" as UC15
    }

    ' ── Package: History Management ───────────────────────────────────────────
    package "Conversation History Management" {
        usecase "Apply Input Filter\n(HandoffInputFilter)" as UC16
        usecase "Nest Handoff History\n(<CONVERSATION HISTORY> block)" as UC17
        usecase "Remove All Tools\nfrom History" as UC18
        usecase "Override Nest History\nPer-Handoff" as UC19
    }
}

' ── Developer Relationships ───────────────────────────────────────────────────
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4
dev --> UC5
dev --> UC6
dev --> UC7
dev --> UC19

' ── AgentRunner Relationships ─────────────────────────────────────────────────
runner --> UC8
runner --> UC11
runner --> UC15

' ── LLM Relationships ─────────────────────────────────────────────────────────
llm --> UC10

' ── Target Agent Relationships ────────────────────────────────────────────────
UC15 --> target : activates

' ── Use Case include / extend Relationships ───────────────────────────────────
' Configuration includes/extends
UC1 <.. UC3 : <<extend>>
UC1 <.. UC4 : <<extend>>
UC1 <.. UC5 : <<extend>>
UC1 <.. UC19 : <<extend>>
UC2 ..> UC1 : <<include>>

' Routing pipeline
UC8 ..> UC9 : <<include>>
UC10 ..> UC11 : <<include>>
UC11 ..> UC12 : <<include>>
UC11 ..> UC13 : <<include>>
UC11 ..> UC14 : <<include>>
UC11 ..> UC16 : <<include>>
UC11 ..> UC15 : <<include>>

' History management extensions
UC16 <.. UC17 : <<extend>>
UC16 <.. UC18 : <<extend>>

' ── Notes ─────────────────────────────────────────────────────────────────────
note right of UC12
  JSON args validated via TypeAdapter
  in strict mode (ensure_strict_json_schema).
  input_type and on_handoff must both
  be provided or neither.
end note

note right of UC17
  Opt-in beta (disabled by default).
  Collapses prior transcript into a
  single assistant summary message.
  Per-handoff flag overrides RunConfig.
end note

note bottom of UC11
  Only the first handoff is honoured
  when LLM requests multiple simultaneously.
  Remaining calls receive a
  "Multiple handoffs detected" message.
end note

note bottom of UC8
  Plain Agent entries in Agent.handoffs
  are auto-wrapped via handoff().
  Disabled handoffs (is_enabled=False)
  are hidden from the LLM tool list.
end note

note left of UC16
  Per-handoff input_filter takes
  precedence over RunConfig.handoff_input_filter.
  Server-managed conversations disallow
  input_filter and nest_handoff_history.
end note

@enduml
