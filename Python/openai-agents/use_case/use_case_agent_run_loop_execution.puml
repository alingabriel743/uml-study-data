@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343A40
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
    FontColor #212529
}

title Agent Run Loop Execution

left to right direction

' ── External actors (left side) ──────────────────────────────────
actor "Developer\n(SDK User)" as Developer
actor "Runner\n(Static Facade)" as Runner

' ── Supporting actors (right side) ───────────────────────────────
actor "LLM / Model" as LLM
actor "Tool" as Tool
actor "Session\n(Conversation Memory)" as Session
actor "RunHooks\n(Lifecycle Observer)" as RunHooks
actor "InputGuardrail" as InputGuardrail
actor "OutputGuardrail" as OutputGuardrail
actor "ErrorHandler" as ErrorHandler

' ── System boundary ───────────────────────────────────────────────
rectangle "Agent Run Loop  [AgentRunner]" {

    ' Entry points
    usecase "Run Agent Synchronously\n(Runner.run_sync)" as UC_RunSync
    usecase "Run Agent Asynchronously\n(Runner.run)" as UC_RunAsync
    usecase "Run Agent in Streaming Mode\n(Runner.run_streamed)" as UC_RunStream
    usecase "Resume Interrupted Run\n(pass RunState as input)" as UC_Resume

    ' Configuration
    usecase "Configure Run Settings\n(RunConfig)" as UC_Config
    usecase "Set Max Turns Limit" as UC_MaxTurns

    ' Session management
    usecase "Load Conversation History\nfrom Session" as UC_LoadSession
    usecase "Save Conversation History\nto Session" as UC_SaveSession

    ' Core per-turn loop
    usecase "Call LLM for Current Agent\n(run_single_turn)" as UC_LLMCall
    usecase "Apply call_model_input_filter\nbefore LLM Call" as UC_InputFilter
    usecase "Process Model Response\n(classify tools / handoffs / text)" as UC_ProcessResp
    usecase "Execute Tool Calls\n(execute_tools_and_side_effects)" as UC_ExecTools
    usecase "Execute Handoff\nto Next Agent" as UC_Handoff

    ' Guardrails
    usecase "Run Input Guardrails\n(turn 0 only)" as UC_InputGuard
    usecase "Run Output Guardrails\n(on final output)" as UC_OutputGuard

    ' Turn outcomes / next-step dispatch
    usecase "Continue Loop\n(NextStepRunAgain)" as UC_RunAgain
    usecase "Interrupt Run for\nTool Approval (HITL)\n(NextStepInterruption)" as UC_Interrupt
    usecase "Handle Max Turns Exceeded\n(MaxTurnsExceeded)" as UC_MaxTurnsErr

    ' Results
    usecase "Return RunResult\n(final output)" as UC_ReturnResult
    usecase "Return RunResultStreaming\n(streaming events)" as UC_ReturnStream

    ' Observability
    usecase "Receive Lifecycle Hook\nCallbacks\n(on_agent_start/end, on_llm_start/end,\non_tool_start/end, on_handoff)" as UC_Hooks
    usecase "Trace Run with Spans\n(task_span, agent_span, turn_span)" as UC_Trace
}

' ── Developer associations ────────────────────────────────────────
Developer --> UC_RunSync
Developer --> UC_RunAsync
Developer --> UC_RunStream
Developer --> UC_Resume
Developer --> UC_Config
Developer --> UC_MaxTurns

' ── Runner delegates to AgentRunner ──────────────────────────────
Runner --> UC_RunSync
Runner --> UC_RunAsync
Runner --> UC_RunStream

' ── Supporting actor associations ────────────────────────────────
LLM --> UC_LLMCall
Tool --> UC_ExecTools
Session --> UC_LoadSession
Session --> UC_SaveSession
RunHooks --> UC_Hooks
InputGuardrail --> UC_InputGuard
OutputGuardrail --> UC_OutputGuard
ErrorHandler --> UC_MaxTurnsErr

' ── Include / extend relationships ───────────────────────────────
UC_RunAsync .down.> UC_Config         : <<include>>
UC_RunAsync .down.> UC_LoadSession    : <<include>>
UC_RunAsync .down.> UC_InputGuard     : <<include>>
UC_RunAsync .down.> UC_LLMCall        : <<include>>
UC_RunAsync .down.> UC_ProcessResp    : <<include>>
UC_RunAsync .down.> UC_ExecTools      : <<include>>
UC_RunAsync .down.> UC_Trace          : <<include>>

UC_RunSync  .down.> UC_RunAsync       : <<include>>
UC_RunStream .down.> UC_ReturnStream  : <<include>>

UC_LLMCall  .down.> UC_InputFilter    : <<include>>
UC_ExecTools .down.> UC_RunAgain      : <<extend>>
UC_ExecTools .down.> UC_Handoff       : <<extend>>
UC_ExecTools .down.> UC_Interrupt     : <<extend>>
UC_ExecTools .down.> UC_MaxTurnsErr   : <<extend>>

UC_RunAgain .down.> UC_LLMCall        : <<include>>
UC_Handoff  .down.> UC_LLMCall        : <<include>>

UC_ProcessResp .right.> UC_OutputGuard : <<extend>>
UC_ProcessResp .right.> UC_SaveSession : <<extend>>
UC_ProcessResp .right.> UC_ReturnResult : <<extend>>

UC_Resume   .down.> UC_RunAsync       : <<include>>

UC_Hooks    .up.> UC_LLMCall          : <<extend>>
UC_Hooks    .up.> UC_ExecTools        : <<extend>>
UC_Hooks    .up.> UC_Handoff          : <<extend>>

' ── Notes ────────────────────────────────────────────────────────
note bottom of UC_InputGuard
  Runs only on turn 0.
  Parallel guardrails execute
  concurrently with the first LLM
  call via asyncio.gather.
end note

note bottom of UC_Interrupt
  Freezes RunState.
  Developer resumes by passing
  the RunState back as input.
  Enables durable / HITL execution.
end note

note right of UC_Config
  Key settings: model, max_turns,
  input_guardrails, output_guardrails,
  call_model_input_filter,
  session_settings, tracing_disabled
end note

note right of Runner
  Static facade.
  Delegates to DEFAULT_AGENT_RUNNER
  (AgentRunner instance).
  Runner is public API;
  AgentRunner is experimental.
end note

@enduml
