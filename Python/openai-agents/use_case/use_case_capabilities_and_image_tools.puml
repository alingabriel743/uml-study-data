@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
    FontColor #212529
}

title Capabilities and Image Tool Execution

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────
actor "SandboxAgent\n(LLM)" as Agent
actor "Runner" as Runner
actor "BaseSandboxSession" as Session

' ── System Boundary ──────────────────────────────────────────────────────
rectangle "Capability & Image Tool System" {

    ' ── Capability Setup ────────────────────────────────────────────────
    package "Capability Configuration" {
        usecase "Configure Default\nCapabilities\n(Filesystem + Shell + Compaction)" as UC1
        usecase "Bind Capability\nto Sandbox Session" as UC2
        usecase "Expose Tools to Agent\n(Capability.tools())" as UC3
    }

    ' ── Tool Invocation ─────────────────────────────────────────────────
    package "view_image Tool Execution" {
        usecase "Invoke view_image\nwith path argument" as UC4
        usecase "Resolve Workspace Path\n(absolute or relative)" as UC5
        usecase "Read Image File\nfrom Sandbox Session" as UC6
        usecase "Detect Image MIME Type\n(PNG/JPEG/GIF/WEBP/BMP/TIFF/SVG)" as UC7
        usecase "Encode Image as\nBase64 Data URL" as UC8
        usecase "Return ToolOutputImage\nto the Model" as UC9
    }

    ' ── Error Handling ───────────────────────────────────────────────────
    package "Error Handling" {
        usecase "Handle Error:\nFile Not Found" as UC10
        usecase "Handle Error:\nUnsupported File Type" as UC11
        usecase "Handle Error:\nImage Exceeds 10 MB Limit" as UC12
    }
}

' ── Actor → Use Case Relationships ──────────────────────────────────────
Runner  --> UC1 : initialises
Runner  --> UC2 : binds at run time
Runner  --> UC3 : generates tool list

Agent   --> UC4 : calls tool
Agent   --> UC9 : receives image output

Session --> UC5 : supplies workspace path policy
Session --> UC6 : reads raw bytes

' ── Include / Extend Relationships ──────────────────────────────────────
UC1 ..> UC2 : <<include>>
UC2 ..> UC3 : <<include>>
UC3 ..> UC4 : <<include>>

UC4 ..> UC5 : <<include>>
UC4 ..> UC6 : <<include>>
UC6 ..> UC7 : <<include>>
UC7 ..> UC8 : <<include>>
UC8 ..> UC9 : <<include>>

UC6 ..> UC10 : <<extend>>
UC6 ..> UC11 : <<extend>>
UC6 ..> UC12 : <<extend>>
UC7 ..> UC11 : <<extend>>

' ── Notes ────────────────────────────────────────────────────────────────
note bottom of UC1
  <b>Capabilities.default()</b> returns
  [Filesystem(), Shell(), Compaction()].
  Additional capabilities (e.g. Skills)
  may be appended by the caller.
end note

note right of UC5
  <b>WorkspacePathPolicy</b>:
  resolves relative paths against
  the session workspace root.
  Error messages expose only the
  relative <i>display_path</i>, never
  provider-internal absolute paths.
end note

note right of UC7
  Supported MIME types:
  image/png · image/jpeg · image/gif
  image/webp · image/bmp · image/tiff
  image/svg+xml
  (fallback: mimetypes.guess_type)
end note

note right of UC12
  Hard limit: <b>10 MB</b> per image.
  Agent receives an actionable error:
  "resize or compress the image".
end note

note bottom of UC2
  <b>needs_approval</b> callback can
  gate tool calls on path patterns
  (e.g. 'sensitive/' prefix).
  User identity propagated via
  capability.run_as → session.read(user=…).
end note

@enduml
