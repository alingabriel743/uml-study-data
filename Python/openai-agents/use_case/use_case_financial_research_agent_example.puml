@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7DBF
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #343A40
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F0C030
    FontColor #4A3B00
}
skinparam ArrowColor #495057
skinparam ArrowFontColor #343A40
skinparam ArrowFontSize 11

title Financial Research Agent (Example)\nMulti-Agent Orchestrated Pipeline

left to right direction

' ── External Actors ──────────────────────────────────────────────
actor "Analyst\n(User)" as Analyst #D0E8FF
actor "WebSearch\n(Tool)" as WebSearch #D8F5D8

' ── System Boundary ──────────────────────────────────────────────
rectangle "Financial Research Agent Pipeline" {

    ' Entry & Exit
    usecase "Submit Financial\nResearch Query" as UC1
    usecase "View Final Report &\nFollow-up Questions" as UC8

    ' Core Pipeline
    usecase "Plan Search\nStrategy" as UC2
    usecase "Execute Parallel\nWeb Searches" as UC3
    usecase "Write Financial\nReport" as UC6
    usecase "Verify Report\nQuality" as UC7

    ' Specialist Analysis (called as tools by WriterAgent)
    usecase "Perform\nFundamentals Analysis" as UC4
    usecase "Perform\nRisk Analysis" as UC5

}

' ── Actor → Use Case associations ────────────────────────────────
Analyst        --> UC1
Analyst        --> UC8
WebSearch      --> UC3

' ── Include / Extend relationships ───────────────────────────────
UC1            ..> UC2  : <<include>>
UC2            ..> UC3  : <<include>>
UC3            ..> UC6  : <<include>>
UC6            .up.> UC4 : <<extend>>
UC6            .up.> UC5 : <<extend>>
UC6            ..> UC7  : <<include>>
UC7            ..> UC8  : <<include>>

' ── Agent Annotations ────────────────────────────────────────────
note right of UC2
  <b>FinancialPlannerAgent</b>
  Model: o3-mini
  Output: FinancialSearchPlan
  (5–15 FinancialSearchItem entries)
end note

note right of UC3
  <b>FinancialSearchAgent</b>
  Model: gpt-5.4 · Tool: WebSearchTool
  Parallel via asyncio.create_task
  Output: ≤300-word summary per query
end note

note right of UC6
  <b>FinancialWriterAgent</b>
  Model: gpt-5.4 · Streaming (run_streamed)
  Output: FinancialReportData
  {short_summary, markdown_report,
   follow_up_questions}
  Cloned at runtime with specialist tools
end note

note left of UC4
  <b>FundamentalsAnalystAgent</b>
  Exposed as: fundamentals_analysis tool
  Covers: revenue, margins, growth
  Output: AnalysisSummary
end note

note left of UC5
  <b>RiskAnalystAgent</b>
  Exposed as: risk_analysis tool
  Covers: competitive, regulatory,
  supply chain risks
  Output: AnalysisSummary
end note

note right of UC7
  <b>VerificationAgent</b>
  Model: gpt-5.4
  Checks: consistency, sourcing,
  unsupported claims
  Output: VerificationResult
  {verified: bool, issues: str}
end note

note bottom of UC1
  Entry point:
  <i>python -m examples.financial_research_agent.main</i>
  → FinancialResearchManager.run(query)
  Full pipeline wrapped in trace('Financial research trace')
end note

@enduml
