@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #336699
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFBE6
    BorderColor #C8A200
    FontColor #333333
}

title Guardrails — Input and Output Filtering

left to right direction

actor "Developer" as Dev
actor "Runner" as Runner
actor "Agent" as AgentActor
actor "FunctionTool" as ToolActor

rectangle "Guardrails System" {

    package "Guardrail Definition" {
        usecase "Define Input Guardrail\n(@input_guardrail)" as UC1
        usecase "Define Output Guardrail\n(@output_guardrail)" as UC2
        usecase "Define Tool Input Guardrail\n(@tool_input_guardrail)" as UC3
        usecase "Define Tool Output Guardrail\n(@tool_output_guardrail)" as UC4
    }

    package "Guardrail Execution" {
        usecase "Run Input Guardrails\n(Blocking Mode)" as UC5
        usecase "Run Input Guardrails\n(Parallel Mode)" as UC6
        usecase "Run Output Guardrails" as UC7
        usecase "Run Tool Input Guardrail\nBefore Tool Call" as UC8
        usecase "Run Tool Output Guardrail\nAfter Tool Call" as UC9
    }

    package "Tripwire Handling" {
        usecase "Handle Input Tripwire\n(InputGuardrailTripwireTriggered)" as UC10
        usecase "Handle Output Tripwire\n(OutputGuardrailTripwireTriggered)" as UC11
        usecase "Handle Tool Guardrail Response\n(allow / reject_content / raise_exception)" as UC12
    }

    package "Observability" {
        usecase "Trace Guardrail Execution\n(guardrail_span)" as UC13
    }
}

' Developer interactions
Dev --> UC1
Dev --> UC2
Dev --> UC3
Dev --> UC4
Dev --> UC10
Dev --> UC11

' Runner interactions
Runner --> UC5
Runner --> UC6
Runner --> UC7
Runner --> UC13

' Agent carries guardrails
AgentActor --> UC5
AgentActor --> UC6
AgentActor --> UC7

' FunctionTool carries tool guardrails
ToolActor --> UC8
ToolActor --> UC9
ToolActor --> UC12

' Include relationships — execution depends on definition
UC5 .> UC1 : <<include>>
UC6 .> UC1 : <<include>>
UC7 .> UC2 : <<include>>
UC8 .> UC3 : <<include>>
UC9 .> UC4 : <<include>>

' Tripwire extend relationships
UC5 .> UC10 : <<extend>>\ntripwire triggered
UC6 .> UC10 : <<extend>>\ntripwire triggered
UC7 .> UC11 : <<extend>>\ntripwire triggered
UC8 .> UC12 : <<extend>>
UC9 .> UC12 : <<extend>>

' Tracing covers all execution
UC5 .> UC13 : <<include>>
UC6 .> UC13 : <<include>>
UC7 .> UC13 : <<include>>
UC8 .> UC13 : <<include>>
UC9 .> UC13 : <<include>>

note bottom of UC5
  <b>Blocking mode</b> (run_in_parallel=False):
  Guardrail completes BEFORE agent starts.
  Prevents token waste on policy violations.
end note

note bottom of UC6
  <b>Parallel mode</b> (run_in_parallel=True, default):
  Guardrail runs concurrently WITH agent.
  Best latency; agent may consume tokens
  before cancellation if tripwire fires.
end note

note right of UC7
  Output guardrails always run AFTER
  agent completion — no parallel mode.
  Only fires on the LAST agent in a chain.
end note

note right of UC12
  Three behaviors available:
  • <b>allow</b> — continue normally
  • <b>reject_content</b> — skip call, send message to model
  • <b>raise_exception</b> — halt via tripwire exception
end note

note top of UC1
  Input guardrails run only on the
  FIRST agent in a chain.
  Tool guardrails run on every
  function-tool invocation.
end note

@enduml
