@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #FFC107
    FontColor #212529
}

title MCP Server Integration

left to right direction

' ── Actors ──────────────────────────────────────────────────────────────
actor "Developer" as dev
actor "Agent" as agent
actor "OpenAI\nResponses API" as openai #D4EDDA
actor "External MCP\nServer Process" as mcpproc #D4EDDA

' ── System Boundary ──────────────────────────────────────────────────────
rectangle "MCP Server Integration  (Agents Python SDK)" {

    ' ── Package: Server Connection ──────────────────────────────────────
    package "Server Connection" {
        usecase "Connect MCP Server\nvia Stdio" as UC1
        usecase "Connect MCP Server\nvia SSE\n(deprecated)" as UC2
        usecase "Connect MCP Server\nvia Streamable HTTP" as UC3
        usecase "Use Hosted\nMCP Tool" as UC5
        usecase "Manage Multiple MCP\nServer Lifecycles" as UC4
    }

    ' ── Package: Tool Discovery & Filtering ─────────────────────────────
    package "Tool Discovery & Filtering" {
        usecase "Discover Available\nTools (list_tools)" as UC6
        usecase "Filter Available\nTools" as UC7
        usecase "Cache Tool List" as UC8
    }

    ' ── Package: Tool Execution ──────────────────────────────────────────
    package "Tool Execution" {
        usecase "Invoke MCP Tool\n(call_tool)" as UC10
        usecase "Require Tool Approval\n(Human-in-the-Loop)" as UC11
        usecase "Inject Per-Call\nMetadata (_meta)" as UC12
    }

    ' ── Package: Server Capabilities ────────────────────────────────────
    package "Server Capabilities" {
        usecase "Retrieve Prompts\nfrom MCP Server" as UC13
        usecase "Read Resources\nfrom MCP Server" as UC14
    }
}

' ── Developer associations ───────────────────────────────────────────────
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC5
dev --> UC4
dev --> UC7  : configure\ntool filter
dev --> UC8  : enable\ncaching
dev --> UC11 : set\nrequire_approval
dev --> UC12 : provide\ntool_meta_resolver
dev --> UC13

' ── Agent associations ───────────────────────────────────────────────────
agent --> UC6
agent --> UC10
agent --> UC13
agent --> UC14

' ── External system associations ─────────────────────────────────────────
UC5    --> openai  : delegates tool\nround-trip
UC1    --> mcpproc : spawns subprocess\n(stdio_client)
UC3    --> mcpproc : HTTP session\n(streamablehttp_client)
UC2    --> mcpproc : SSE connection\n(sse_client)

' ── Include / Extend relationships ───────────────────────────────────────
UC6    ..> UC7  : <<include>>\n(if tool_filter set)
UC6    ..> UC8  : <<include>>\n(if cache_tools_list)
UC10   <.. UC11 : <<extend>>\n(if needs_approval)
UC10   <.. UC12 : <<extend>>\n(if tool_meta_resolver set)

' ── Notes ────────────────────────────────────────────────────────────────
note bottom of UC4
  <b>MCPServerManager</b>
  active_servers = connected only
  (when drop_failed_servers=True).
  Supports parallel connect via
  connect_in_parallel=True.
end note

note right of UC7
  <b>Static</b>: allowed_tool_names /
  blocked_tool_names allow-list
  applied first, then block-list.
  <b>Dynamic</b>: callable(ToolFilterContext,
  MCPTool) → bool; errors → tool excluded.
end note

note right of UC11
  Policies: "always" | "never" |
  per-tool dict | callable.
  Agent pauses for approval before
  executing the tool.
end note

note bottom of UC5
  Added to <b>agent.tools</b> (not
  mcp_servers). OpenAI Responses API
  handles discovery & invocation remotely.
  Supports defer_loading + ToolSearchTool.
end note

@enduml
