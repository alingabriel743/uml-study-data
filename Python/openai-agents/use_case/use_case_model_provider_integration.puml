@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam ArrowColor #495057
skinparam NoteBackgroundColor #FFF9C4
skinparam NoteBorderColor #F0C040

title Model Provider Integration

left to right direction

' ── Primary Actors ─────────────────────────────────────────────
actor "Developer" as Dev
actor "Agent Runner" as Runner

' ── External Systems ────────────────────────────────────────────
actor "OpenAI API\n(Chat Completions /\nResponses API)" as OpenAI_API #D6EAF8
actor "LiteLLM Proxy\n(100+ LLMs)" as LiteLLM #D5F5E3
actor "AnyLLM Provider\n(OpenRouter etc.)" as AnyLLM #FAE5D3

' ── System Boundary ─────────────────────────────────────────────
rectangle "Model Provider Integration\n(Agent SDK – ModelProvider / Model abstractions)" {

    ' ── Developer use cases ─────────────────────────────────────
    usecase "Configure Model Settings\n(temperature, top_p, max_tokens,\ntool_choice, reasoning effort, etc.)" as UC1
    usecase "Select Responses API Transport\n(HTTP vs. WebSocket)" as UC8
    usecase "Integrate Third-Party LLM\nvia LiteLLM  (litellm/<model>)" as UC9
    usecase "Integrate Third-Party LLM\nvia AnyLLM  (any-llm/<model>)" as UC10
    usecase "Register Custom Provider Mapping\n(MultiProviderMap / prefix modes)" as UC12

    ' ── Agent Runner use cases ───────────────────────────────────
    usecase "Select Provider by Model Name\n(MultiProvider prefix routing)" as UC2
    usecase "Get Non-Streaming Completion\n(Model.get_response() → ModelResponse)" as UC3
    usecase "Stream LLM Response\n(Model.stream_response() → TResponseStreamEvent)" as UC4
    usecase "Retry Failed Model Requests\n(ModelRetryAdvice + backoff)" as UC11
    usecase "Close Provider Resources\n(aclose() / WebSocket teardown)" as UC13

    ' ── Internal / sub-function use cases ───────────────────────
    usecase "Translate Chat Completion Chunks\nto Responses API Event Format" as UC5
    usecase "Handle Reasoning / Thinking Blocks\n(o-series, Anthropic, Gemini)" as UC6
    usecase "Stream Tool Call Arguments\n(incremental delta accumulation)" as UC7

    ' ── Include / Extend relationships ──────────────────────────
    UC4 ..> UC5 : <<include>>
    UC4 <.. UC6 : <<extend>>\nif reasoning content detected
    UC4 <.. UC7 : <<extend>>\nif tool_calls present

    UC2 ..> UC12 : <<include>>\nresolve prefix mapping
    UC3 ..> UC1 : <<include>>\napply ModelSettings
    UC4 ..> UC1 : <<include>>\napply ModelSettings

    UC9 ..> UC5 : <<include>>\nstreaming normalization
}

' ── Actor → Use Case relationships ──────────────────────────────
Dev --> UC1
Dev --> UC8
Dev --> UC9
Dev --> UC10
Dev --> UC12

Runner --> UC2
Runner --> UC3
Runner --> UC4
Runner --> UC11
Runner --> UC13

' ── External system connections ──────────────────────────────────
UC3 --> OpenAI_API : Chat Completions\n(stream=False)
UC4 --> OpenAI_API : Chat Completions\n(stream=True)
UC8 --> OpenAI_API : Responses API\n(HTTP / WebSocket)
UC9 --> LiteLLM   : litellm.acompletion()
UC10 --> AnyLLM   : any_llm completions

' ── Notes ────────────────────────────────────────────────────────
note bottom of UC2
  Default model: **gpt-4o** (OpenAIProvider)
  Prefix examples: "openai/", "litellm/", "any-llm/"
  Unknown prefix mode: "error" | "model_id" pass-through
end note

note bottom of UC5
  ChatCmplStreamHandler normalises output from
  OpenAI, LiteLLM, Gemini and Anthropic into
  the unified Responses API event sequence:
  ResponseCreated → OutputItemAdded →
  TextDelta / FunctionArgsDelta →
  OutputItemDone → ResponseCompleted
end note

note right of UC6
  Anthropic: delta.thinking_blocks →
  thinking_text + encrypted_content
  OpenAI o-series: delta.reasoning_content
  Gemini: thought_signature field
end note

note top of UC8
  OpenAIProvider.get_model() returns
  OpenAIResponsesModel (HTTP) or
  OpenAIResponsesWSModel (WebSocket).
  WS connections cached per event loop.
end note

@enduml
