@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A6FA8
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontColor #212529
}

title Prompt and Instructions Management

left to right direction

' ── Actors ──────────────────────────────────────────────────
actor "Developer" as Dev
actor "RunLoop\n(SDK Orchestrator)" as RunLoop #D5E8D4
actor "OpenAI Model" as Model #FFE6CC

' ── System boundary ─────────────────────────────────────────
rectangle "Prompt and Instructions Management" {

    ' ── Instructions sub-group ──────────────────────────────
    package "Instructions Configuration" {
        usecase "Define Static Instructions\n<size:10>(Agent.instructions: str)</size>" as UC1
        usecase "Define Dynamic Instructions\n<size:10>(Agent.instructions: Callable)</size>" as UC2
        usecase "Apply Handoff Prompt Prefix\n<size:10>(prompt_with_handoff_instructions)</size>" as UC9
        usecase "Clone Agent with\nNew Instructions\n<size:10>(Agent.clone(instructions=...))</size>" as UC12
    }

    ' ── Prompt template sub-group ───────────────────────────
    package "Prompt Template Configuration" {
        usecase "Define Static Prompt Template\n<size:10>(Agent.prompt: Prompt TypedDict)</size>" as UC3
        usecase "Define Dynamic Prompt Template\n<size:10>(Agent.prompt: DynamicPromptFunction)</size>" as UC4
        usecase "Configure Handoff\nTool Description\n<size:10>(Agent.handoff_description)</size>" as UC10
    }

    ' ── SDK Validation & Resolution ─────────────────────────
    package "SDK Validation & Runtime Resolution" {
        usecase "Validate Instructions Type\n<size:10>(__post_init__ + get_system_prompt)</size>" as UC5
        usecase "Validate Prompt Type\n<size:10>(__post_init__ + PromptUtil.to_model_input)</size>" as UC6
        usecase "Resolve System Prompt\nat Runtime\n<size:10>(Agent.get_system_prompt)</size>" as UC7
        usecase "Render Prompt to\nModel Input\n<size:10>(PromptUtil.to_model_input → ResponsePromptParam)</size>" as UC8
        usecase "Pass Instructions\nto Model\n<size:10>(model.stream_response / get_response)</size>" as UC13
    }
}

' ── Developer → Instructions use cases ──────────────────────
Dev --> UC1
Dev --> UC2
Dev --> UC3
Dev --> UC4
Dev --> UC9
Dev --> UC10
Dev --> UC12

' ── RunLoop → Validation & Resolution use cases ─────────────
RunLoop --> UC5
RunLoop --> UC6
RunLoop --> UC7
RunLoop --> UC8
RunLoop --> UC13

' ── Model receives resolved prompt ──────────────────────────
UC13 --> Model

' ── Include relationships ────────────────────────────────────
UC7 ..> UC5 : <<include>>
UC8 ..> UC6 : <<include>>
UC13 ..> UC7 : <<include>>
UC13 ..> UC8 : <<include>>

' ── Extend relationships ─────────────────────────────────────
UC9 ..> UC1 : <<extend>>
UC9 ..> UC2 : <<extend>>
UC12 ..> UC1 : <<extend>>
UC12 ..> UC2 : <<extend>>

' ── Notes / business rules ───────────────────────────────────
note bottom of UC5
  **Validation rules:**
  instructions must be str,
  callable, or None (TypeError
  raised in __post_init__).
  Callable must accept exactly
  2 args: (context, agent).
end note

note bottom of UC6
  **Validation rules:**
  prompt must be None, callable,
  or dict-like (has .get()).
  DynamicPromptFunction must
  return a Prompt dict or
  UserError is raised.
end note

note right of UC13
  RunLoop resolves system_prompt
  and prompt **concurrently**
  (asyncio.gather), then applies
  call_model_input_filter before
  passing both to the model.
end note

note top of UC3
  Requires OpenAI
  Responses API only.
  References a prompt by
  ID from OpenAI platform.
end note

note top of UC9
  RECOMMENDED_PROMPT_PREFIX
  is a string constant —
  opt-in, not SDK-enforced.
  Helps LLM understand
  transfer_to_<agent_name>
  handoff pattern.
end note

@enduml
