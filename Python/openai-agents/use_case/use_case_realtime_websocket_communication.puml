@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Realtime WebSocket Communication

left to right direction

actor "Client\n(Browser)" as Client #D0E8FF
actor "OpenAI\nRealtime API" as OpenAI #FFE0B2

rectangle "Realtime WebSocket Server  [ /ws/{session_id} ]" {

    package "Connection Lifecycle" {
        usecase "Connect WebSocket Session" as UC1
        usecase "Disconnect Session" as UC13
    }

    package "Audio Streaming" {
        usecase "Stream Audio to Agent" as UC2
        usecase "Receive Audio from Agent" as UC3
        usecase "Commit Audio Buffer" as UC4
    }

    package "Media & Control" {
        usecase "Send Image to Agent" as UC5
        usecase "Interrupt Agent Response" as UC6
    }

    package "Tool Approval Flow" {
        usecase "Execute Function Tool" as UC9
        usecase "Approve Tool Call" as UC7
        usecase "Reject Tool Call" as UC8
    }

    package "Agent Orchestration" {
        usecase "Handle Agent Handoff" as UC10
        usecase "Enforce Output Guardrails" as UC11
    }

    package "Event Relay" {
        usecase "Stream Session Events to Client" as UC12
    }
}

' ── Client interactions ──────────────────────────────────────────────────────
Client --> UC1       : open WS
Client --> UC2       : {type: audio}
Client --> UC3       : receive audio
Client --> UC4       : {type: commit_audio}
Client --> UC5       : {type: image / image_chunk}
Client --> UC6       : {type: interrupt}
Client --> UC7       : {type: tool_approval_decision\napprove: true}
Client --> UC8       : {type: tool_approval_decision\napprove: false}
Client --> UC13      : disconnect / close

' ── OpenAI Realtime API interactions ─────────────────────────────────────────
UC2  --> OpenAI      : RealtimeModelSendAudio
OpenAI --> UC3       : RealtimeModelAudioEvent
UC9  --> OpenAI      : RealtimeModelSendToolOutput
OpenAI --> UC9       : function_call event
UC10 --> OpenAI      : RealtimeModelSendSessionUpdate
UC11 --> OpenAI      : RealtimeModelSendInterrupt\n(guardrail tripped)
UC6  --> OpenAI      : RealtimeModelSendInterrupt

' ── UC → Client (event relay) ────────────────────────────────────────────────
UC12 --> Client      : JSON events\n(audio, tool_*, handoff,\nguardrail_tripped, …)

' ── Use case relationships ───────────────────────────────────────────────────
UC7  ..> UC9  : <<extend>>\n(on approve decision)
UC8  ..> UC9  : <<extend>>\n(on reject decision)
UC10 ..> UC9  : <<extend>>\n(Handoff detected\nin tool result)
UC11 ..> UC6  : <<include>>\n(auto-interrupt\non guardrail trip)
UC3  ..> UC12 : <<include>>\n(audio event relayed)

' ── Notes ─────────────────────────────────────────────────────────────────────
note bottom of UC1
  RealtimeRunner creates RealtimeSession;
  session.__aenter__() connects to OpenAI;
  background _process_events task started;
  initial history_updated event emitted
end note

note right of UC9
  Checks needs_approval policy;
  if required → suspends in
  _pending_tool_calls dict and emits
  tool_approval_required to client
end note

note bottom of UC11
  Accumulates transcript_delta text;
  debounce threshold: 100 chars;
  trip → interrupt model + emit
  RealtimeGuardrailTripped event
end note

note bottom of UC10
  Detects Handoff object in tool result;
  calls update_agent(new_agent);
  emits RealtimeHandoffEvent(from, to)
end note

note bottom of UC2
  Client sends int16 PCM array;
  server packs via struct → bytes;
  server-side VAD: silence 500 ms
end note

@enduml
