@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A86C8
    FontColor #1A3A5C
    FontSize 12
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    FontSize 11
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 10

title Research Bot (Example)\nMulti-Agent Research Pipeline

left to right direction

' ── Actors ──────────────────────────────────────────────
actor "User" as User
actor "OpenAI LLM\n(gpt-4.5 / gpt-4o-mini)" as LLM #D8F0D8/AADDAA
actor "Web\n(WebSearchTool)" as Web #FFE8CC/FFCC99

' ── System boundary ──────────────────────────────────────
rectangle "Research Bot System" {

    usecase "Submit Research Query" as UC1
    note right of UC1
      Entry point: main.py
      ResearchManager().run(query)
      Generates OpenAI trace ID
    end note

    usecase "Plan Web Searches" as UC2
    note bottom of UC2
      PlannerAgent (gpt-4.5)
      reasoning=medium
      Output: WebSearchPlan
      (5–20 WebSearchItem objects)
    end note

    usecase "Execute Parallel Web Searches" as UC3
    note bottom of UC3
      SearchAgent per item
      asyncio.create_task concurrency
      Each summary: 2-3 paragraphs, <300 words
      Failed searches excluded from results
    end note

    usecase "Synthesize Research Report" as UC4
    note bottom of UC4
      WriterAgent (gpt-4o-mini)
      reasoning=medium
      Streamed output (run_streamed)
      UI updated every 5s
    end note

    usecase "View Research Report" as UC5
    note right of UC5
      Output: markdown report
      + short summary
      + follow-up questions
    end note

    usecase "Monitor Progress" as UC6
    note right of UC6
      Printer: live Rich console
      Stages: planning → searching (X/N) → writing
      Trace URL shown at start
    end note

}

' ── Actor → Use Case associations ───────────────────────
User        --> UC1 : submits query
User        --> UC5 : receives report
User        --> UC6 : views live status

LLM         --> UC2 : generates search plan
LLM         --> UC4 : synthesizes report

Web         --> UC3 : returns search results

' ── Include relationships (pipeline flow) ────────────────
UC1 ..> UC2  : <<include>>
UC2 ..> UC3  : <<include>>
UC3 ..> UC4  : <<include>>
UC4 ..> UC5  : <<include>>
UC1 ..> UC6  : <<include>>\n(parallel monitoring)

@enduml
