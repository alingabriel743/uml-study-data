@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7DC9
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #EEF3F8
    BorderColor #6C757D
    FontColor #343A40
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontColor #4E342E
}

title OpenAI Responses API Compatibility

left to right direction

actor "Agent Runner" as agentRunner
actor "External Provider\n(Gemini, Claude, etc.)" as extProvider
actor "OpenAI\nResponses API" as openaiAPI

rectangle "OpenAI Responses API Compatibility Layer\n(OpenAIResponsesModel / OpenAIResponsesWSModel)" {

    usecase "Build Compatible\nAPI Request" as UC1
    note right of UC1
        _build_response_create_params()
        Orchestrates the full normalization
        pipeline before calling the API
    end note

    usecase "Normalize Input\nItem List" as UC2
    note right of UC2
        _remove_openai_responses_api_incompatible_fields()
        Scans all input items and cleans
        each one via _clean_item_for_openai()
    end note

    usecase "Early-Exit When No\nNormalization Needed" as UC6
    note bottom of UC6
        Business Rule: if no item carries
        a truthy provider_data field, the
        original list is returned unchanged
        (optimization for pure-OpenAI flows)
    end note

    usecase "Filter Provider-Specific\nReasoning Items" as UC3
    note right of UC3
        type == 'reasoning' AND provider_data
        is truthy → item dropped entirely.
        OpenAI reasoning is model-internal
        and cannot accept external content.
    end note

    usecase "Strip Fake\nResponse ID" as UC4
    note right of UC4
        id == FAKE_RESPONSES_ID ('__fake_id__')
        → id field deleted.
        SDK-internal sentinel must never
        reach the OpenAI API.
    end note

    usecase "Remove\nprovider_data Field" as UC5
    note right of UC5
        provider_data field deleted from
        all dict items. Holds provider-
        specific metadata (e.g. model name
        from Gemini/Claude) not in OpenAI schema.
    end note

    usecase "Preserve\nReal IDs" as UC7
    note bottom of UC7
        id != FAKE_RESPONSES_ID → id field
        kept intact. Only the sentinel
        triggers deletion.
    end note

    usecase "Send Normalized\nRequest to OpenAI" as UC8
    note right of UC8
        Cleaned payload dispatched via:
        • HTTP (OpenAIResponsesModel)
        • WebSocket (OpenAIResponsesWSModel)
    end note

}

' --- Primary actor flows ---
agentRunner --> UC1 : initiates model inference
agentRunner --> UC8 : submits cleaned request

' --- Normalization pipeline includes ---
UC1 ..> UC2 : <<include>>

UC2 <.. UC6 : <<extend>>\n[no provider_data found]
UC2 ..> UC3 : <<include>>
UC2 ..> UC4 : <<include>>
UC2 ..> UC5 : <<include>>
UC2 <.. UC7 : <<extend>>\n[id is real]

' --- External provider contributes incompatible items ---
extProvider --> UC3 : injects reasoning items\nwith provider_data
extProvider --> UC4 : injects items\nwith fake IDs
extProvider --> UC5 : injects items\nwith provider_data field

' --- Cleaned request reaches OpenAI ---
UC8 --> openaiAPI : normalized HTTP/WS request

@enduml
