@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #495057
    FontColor #212529
    BorderThickness 2
}
skinparam note {
    BackgroundColor #FFF9E6
    BorderColor #CCAA00
    FontColor #212529
}

left to right direction

title Run Configuration and Lifecycle

actor "Developer" as dev
actor "RunHooks\n(Observer)" as hooks

rectangle "Run Configuration and Lifecycle  [OpenAI Agents SDK — Runner]" {

    package "Run Configuration" {
        usecase "Configure Run Parameters\n(model, model_provider,\nmodel_settings, sandbox)" as UC1
        usecase "Configure Tracing\n(tracing, workflow_name,\ntrace_id, group_id, trace_metadata)" as UC12
        usecase "Set Guardrails &\nHandoff Behavior\n(input_guardrails, output_guardrails,\nhandoff_input_filter, nest_handoff_history)" as UC1b
        usecase "Filter Model Input Pre-Call\n(call_model_input_filter)" as UC15
    }

    package "Run Invocation" {
        usecase "Start Synchronous Run\n(Runner.run_sync)" as UC2
        usecase "Start Async Run\n(Runner.run)" as UC3
        usecase "Start Streaming Run\n(Runner.run_streamed)" as UC4
    }

    package "Turn Control" {
        usecase "Set Max Turns Limit\n(max_turns, default = 10)" as UC5
        usecase "Handle Max Turns\nvia Error Handler\n(error_handlers)" as UC6
    }

    package "Lifecycle Observation" {
        usecase "Attach Run-Level Hooks\n(RunHooks)" as UC7
        usecase "Observe LLM Start / End\n(on_llm_start, on_llm_end)" as UC8
        usecase "Observe Agent Start / End\n(on_agent_start, on_agent_end)" as UC9
        usecase "Observe Tool Start / End\n(on_tool_start, on_tool_end)" as UC10
        usecase "Observe Handoff Event\n(on_handoff)" as UC11
    }

    package "State & Conversation Management" {
        usecase "Resume Interrupted Run\n(RunState as input)" as UC13
        usecase "Manage Conversation State\n(Session / conversation_id /\nprevious_response_id / to_input_list)" as UC14
    }
}

' ── Developer primary interactions ──────────────────────────────────────────
dev --> UC1
dev --> UC2
dev --> UC3
dev --> UC4
dev --> UC5
dev --> UC6
dev --> UC7
dev --> UC13
dev --> UC14

' ── RunConfig includes sub-capabilities ─────────────────────────────────────
UC1 ..> UC12  : <<include>>
UC1 ..> UC1b  : <<include>>
UC1 ..> UC15  : <<include>>

' ── Every run entry point consumes RunConfig and enforces max_turns ──────────
UC2 ..> UC1 : <<include>>
UC3 ..> UC1 : <<include>>
UC4 ..> UC1 : <<include>>

UC2 ..> UC5 : <<include>>
UC3 ..> UC5 : <<include>>
UC4 ..> UC5 : <<include>>

' ── Error handler is an optional extension of the max-turns mechanism ────────
UC6 ..> UC5 : <<extend>>

' ── Attaching hooks includes all lifecycle event observations ────────────────
UC7 ..> UC8  : <<include>>
UC7 ..> UC9  : <<include>>
UC7 ..> UC10 : <<include>>
UC7 ..> UC11 : <<include>>

' ── RunHooks observer implements the lifecycle callbacks ─────────────────────
hooks --> UC8
hooks --> UC9
hooks --> UC10
hooks --> UC11

' ── Resuming an interrupted run is an extension of Start Async Run ───────────
UC13 ..> UC3 : <<extend>>

' ── Business rule annotations ────────────────────────────────────────────────
note right of UC5
  DEFAULT_MAX_TURNS = 10.
  Raises MaxTurnsExceeded when limit
  is exceeded. Pass
  error_handlers={"max_turns": fn}
  to return a controlled RunResult
  instead of raising.
  RunErrorHandlerResult.include_in_history
  controls whether the fallback output
  is appended to conversation history.
end note

note right of UC14
  Four strategies — choose ONE per conversation:
  1. to_input_list()  — manual, client-managed
  2. Session          — auto client-side persistence
  3. conversation_id  — OpenAI server-managed
  4. previous_response_id — lightweight chaining
  ⚠ session cannot be combined with
    conversation_id / previous_response_id /
    auto_previous_response_id in the same run.
end note

note right of UC1
  model set in RunConfig overrides
  the per-Agent model definition.
  tracing_disabled=True suppresses all spans.
  trace_include_sensitive_data=False keeps
  spans but strips payload data.
  reasoning_item_id_policy="omit" avoids
  Responses API 400 errors with reasoning IDs.
end note

note right of UC15
  Runs AFTER session history is merged.
  Must return a ModelInputData object;
  wrong return type raises UserError.
  Use session_input_callback to customise
  the earlier session-merge step.
end note

@enduml
