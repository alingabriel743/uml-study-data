@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #1A2D4A
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Sandbox Code Execution (E2B)

left to right direction

' ── Actors ──────────────────────────────────────────────────
actor "Developer" as developer
actor "SandboxAgent" as agent
actor "Runner" as runner
actor "E2B Platform" as e2b #D5F5E3

' ── System Boundary ─────────────────────────────────────────
rectangle "E2B Sandbox Runtime  (openai-agents SDK)" {

    ' ── Configuration ───────────────────────────────────────
    package "Configuration" {
        usecase "Configure Sandbox Options\n(E2BSandboxClientOptions)" as UC01
    }

    ' ── Session Lifecycle ───────────────────────────────────
    package "Session Lifecycle" {
        usecase "Manage Session Lifecycle\n(Acquire / Ensure / Cleanup)" as UC13
        usecase "Create Sandbox Session" as UC02
        usecase "Resume Sandbox Session" as UC03
        usecase "Start Sandbox\n(Prepare Workspace)" as UC04
        usecase "Stop / Pause Sandbox" as UC11
        usecase "Create Workspace Snapshot" as UC12
        usecase "Serialize / Deserialize\nSession State" as UC14
        usecase "Delete Sandbox Session" as UC15
    }

    ' ── Code & Shell Execution ───────────────────────────────
    package "Code & Shell Execution" {
        usecase "Execute Shell Command\n(ExecCommandTool)" as UC05
        usecase "Execute Command with PTY\n(Interactive TTY)" as UC06
        usecase "Write to Process Stdin\n(WriteStdinTool)" as UC07
    }

    ' ── File & Port Operations ───────────────────────────────
    package "File & Port Operations" {
        usecase "Read File from Workspace" as UC08
        usecase "Write File to Workspace" as UC09
        usecase "Resolve Exposed Port Endpoint" as UC10
    }
}

' ── Developer relationships ──────────────────────────────────
developer --> UC01
developer --> UC13 : triggers via Runner.run()

' ── Runner relationships ─────────────────────────────────────
runner --> UC13
runner --> UC02
runner --> UC03
runner --> UC04
runner --> UC11
runner --> UC12
runner --> UC14
runner --> UC15

' ── SandboxAgent relationships ───────────────────────────────
agent --> UC05
agent --> UC06
agent --> UC07
agent --> UC08
agent --> UC09
agent --> UC10

' ── E2B Platform relationships ───────────────────────────────
UC02 --> e2b : _sandbox_create()
UC03 --> e2b : _sandbox_connect()
UC05 --> e2b : commands.run()
UC06 --> e2b : pty.create() / poll
UC07 --> e2b : pty.send_stdin()
UC08 --> e2b : files.read()
UC09 --> e2b : files.write()
UC11 --> e2b : sandbox.pause() /\nsandbox.kill()
UC12 --> e2b : sandbox.create_snapshot()
UC15 --> e2b : sandbox.delete()

' ── Include / Extend relationships ───────────────────────────
UC13 .> UC02 : <<include>>
UC13 .> UC03 : <<include>>
UC04 .> UC13 : <<include>>
UC11 .> UC12 : <<extend>>\nif workspace_persistence\n= 'snapshot'
UC06 .> UC05 : <<extend>>\nif tty=true or\nsupports_pty()
UC07 .> UC06 : <<extend>>\nwrite stdin to\nactive PTY session
UC14 .> UC03 : <<include>>\ndeserialize state\nbefore resume
UC11 .> UC14 : <<include>>\nserialize state\non cleanup

' ── Notes ────────────────────────────────────────────────────
note bottom of UC01
  sandbox_type: 'e2b' (bash) |
  'e2b_code_interpreter' (Jupyter/IPython)
  workspace_persistence: 'tar' | 'snapshot'
  on_timeout: 'kill' | 'pause'
  Requires E2B_API_KEY env var
end note

note bottom of UC05
  Returns ExecResult(stdout, stderr, exit_code)
  Errors: ExecNonZeroError | ExecTimeoutError |
  ExecTransportError
end note

note right of UC12
  'snapshot' mode: sandbox.create_snapshot()
  with magic prefix _E2B_SANDBOX_SNAPSHOT_V1
  'tar' mode: workspace tar-archived
end note

note right of UC10
  Port 443 → TLS=true
  Others → TLS=false
  url_for(scheme) → http/https/ws/wss
  Raises ExposedPortUnavailableError
  if host is invalid
end note

note right of UC13
  SandboxAgent cannot be reused
  concurrently across runs
  (_SandboxConcurrencyGuard)
  Sessions tracked per-agent
  by stable resume key (agent.name)
end note

@enduml
