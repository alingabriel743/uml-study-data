@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

title Streaming Responses and Event Handling

left to right direction

' ─── Actors ───────────────────────────────────────────────
actor "Caller\n(Developer / Application)" as Caller
actor "Runner" as Runner
actor "Background\nrun_loop_task" as RunLoop
actor "ChatCmplStream\nHandler" as ChatCmpl
actor "Guardrail\nSystem" as Guardrail

' ─── System boundary ──────────────────────────────────────
rectangle "Agents SDK — Streaming Subsystem" {

    ' ── Initiation ──────────────────────────────────────
    usecase "Start Streaming Run\n<size:10>Runner.run_streamed(agent, input)\n→ RunResultStreaming</size>" as UC1

    ' ── Event consumption ───────────────────────────────
    usecase "Consume Stream Events\n<size:10>async for event in\nresult.stream_events()</size>" as UC2

    usecase "Receive Raw LLM\nToken Deltas\n<size:10>RawResponsesStreamEvent\n(type='raw_response_event')</size>" as UC3

    usecase "Receive Run Item\nUpdates\n<size:10>RunItemStreamEvent\n(type='run_item_stream_event')</size>" as UC4

    usecase "Receive Agent Change\nNotification\n<size:10>AgentUpdatedStreamEvent\n(type='agent_updated_stream_event')</size>" as UC5

    ' ── Cancellation ────────────────────────────────────
    usecase "Cancel Streaming\nImmediately\n<size:10>result.cancel(mode='immediate')</size>" as UC6

    usecase "Cancel After\nCurrent Turn\n<size:10>result.cancel(mode='after_turn')</size>" as UC7

    ' ── Interruption & resume ───────────────────────────
    usecase "Handle Streaming\nInterruption (Tool Approval)\n<size:10>Inspect result.interruptions\n: list[ToolApprovalItem]</size>" as UC8

    usecase "Resume Streaming\nfrom State\n<size:10>result.to_state() → state.approve()\n→ Runner.run_streamed(agent, state)</size>" as UC9

    usecase "Convert Stream Result\nto Input List\n<size:10>result.to_input_list(\nmode='preserve_all'|'normalized')</size>" as UC10

    ' ── Internal / infrastructure ───────────────────────
    usecase "Translate ChatCompletion\nChunks to Response Events\n<size:10>ChatCmplStreamHandler.handle_stream()\n→ AsyncIterator[TResponseStreamEvent]</size>" as UC11

    usecase "Handle MaxTurns\nExceeded Error\n<size:10>_check_errors() → MaxTurnsExceeded\nraised after queue drained</size>" as UC12

    usecase "Handle Guardrail\nTripwire\n<size:10>InputGuardrailTripwireTriggered\nraised from stream_events()</size>" as UC13
}

' ─── Actor → Use-Case associations ───────────────────────
Caller   --> UC1
Caller   --> UC2
Caller   --> UC6
Caller   --> UC7
Caller   --> UC8
Caller   --> UC9
Caller   --> UC10

Runner   --> UC1

RunLoop  --> UC11
RunLoop  --> UC12

ChatCmpl --> UC11

Guardrail --> UC13

' ─── Include / Extend relationships ──────────────────────
UC2 ..> UC3  : <<include>>
UC2 ..> UC4  : <<include>>
UC2 ..> UC5  : <<include>>

UC8 ..> UC2  : <<extend>>
UC9 ..> UC8  : <<extend>>

UC6 ..> UC2  : <<extend>>
UC7 ..> UC2  : <<extend>>

' ─── Notes ───────────────────────────────────────────────
note bottom of UC2
  **Must be fully consumed.**
  Post-processing (session persistence,
  approval bookkeeping, history compaction)
  completes after the last visible token.
  When loop exits, result.is_complete
  reflects the final run state.
end note

note right of UC4
  RunItemStreamEvent.name values:
  message_output_created, handoff_requested,
  handoff_occured*, tool_called,
  tool_search_called, tool_search_output_created,
  tool_output, reasoning_item_created,
  mcp_approval_requested, mcp_approval_response,
  mcp_list_tools
  (* intentionally misspelled for backward compat)
end note

note right of UC11
  Bridges ChatCompletion API (chunks)
  → OpenAI Responses API (events).
  Event sequence:
  ResponseCreatedEvent →
  ResponseOutputItemAddedEvent →
  ResponseContentPartAddedEvent →
  ResponseTextDeltaEvent / RefusalDelta /
  ReasoningDelta / FunctionArgsDelta →
  ResponseContentPartDoneEvent →
  ResponseOutputItemDoneEvent →
  ResponseCompletedEvent
  Also handles Anthropic thinking_blocks
  and Gemini thought_signature.
end note

note right of UC7
  Graceful stop: LLM response,
  tool calls, and session state
  all complete before the run halts.
  Use result.last_agent + to_input_list()
  to continue the unfinished turn.
end note

@enduml
