@startuml use_case_structured_output_and_schemas

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #333333
}

title Structured Output and Schema Validation

left to right direction

' ─────────────────────────────────────────────────
' Actors
' ─────────────────────────────────────────────────
actor "Developer" as Dev
actor "Agent SDK Runtime" as SDK
actor "LLM Model\n(OpenAI Responses /\nChat Completions)" as LLM
actor "Pydantic /\nTypeAdapter" as Pydantic

' ─────────────────────────────────────────────────
' System boundary
' ─────────────────────────────────────────────────
rectangle "Claude Agent SDK — Structured Output System" {

    ' ── Schema Definition ──────────────────────────
    package "Schema Definition" {
        usecase "Define plain-text output\n(output_type = None | str)" as UC_PlainText
        usecase "Define typed output\n(Python class / dataclass /\nPydantic BaseModel)" as UC_TypedOutput
        usecase "Define output via\nAgentOutputSchema" as UC_OutputSchema
        usecase "Define fully custom schema\n(subclass AgentOutputSchemaBase)" as UC_CustomSchema
    }

    ' ── Schema Resolution & Preparation ───────────
    package "Schema Resolution & Preparation" {
        usecase "Resolve output schema\nat run time\n(get_output_schema)" as UC_Resolve
        usecase "Apply strict JSON schema\nconstraints\n(ensure_strict_json_schema)" as UC_Strict
        usecase "Convert oneOf → anyOf\nfor OpenAI compatibility" as UC_OneOf
        usecase "Strip additionalProperties\nfor strict mode" as UC_StripProps
        usecase "Format schema for LLM API\n(get_response_format /\nconvert_response_format)" as UC_Format
    }

    ' ── LLM Interaction ────────────────────────────
    package "LLM Interaction" {
        usecase "Receive structured output\nconstraint (json_schema format)" as UC_LLMReceive
        usecase "Return raw JSON string\nresponse" as UC_LLMReturn
    }

    ' ── Validation & Result ────────────────────────
    package "Validation & Result" {
        usecase "Validate and parse JSON\ninto typed object\n(validate_json)" as UC_Validate
        usecase "Unwrap wrapped output\n(extract 'response' key)" as UC_Unwrap
        usecase "Raise ModelBehaviorError\non invalid JSON" as UC_Error
        usecase "Expose typed final_output\non RunResult" as UC_FinalOutput
    }
}

' ─────────────────────────────────────────────────
' Actor → Use Case associations
' ─────────────────────────────────────────────────

' Developer initiates schema definition
Dev --> UC_PlainText
Dev --> UC_TypedOutput
Dev --> UC_OutputSchema
Dev --> UC_CustomSchema
Dev --> UC_FinalOutput

' SDK Runtime drives resolution, formatting, and result assembly
SDK --> UC_Resolve
SDK --> UC_Format
SDK --> UC_Validate
SDK --> UC_FinalOutput

' LLM Model receives constraints and returns structured responses
LLM --> UC_LLMReceive
LLM --> UC_LLMReturn

' Pydantic handles schema derivation, strict enforcement, and parsing
Pydantic --> UC_Strict
Pydantic --> UC_Validate
Pydantic --> UC_Unwrap
Pydantic --> UC_Error

' ─────────────────────────────────────────────────
' Include / Extend relationships
' ─────────────────────────────────────────────────

' Typed output definition leads to AgentOutputSchema creation
UC_TypedOutput ..> UC_OutputSchema : <<include>>

' Custom schema extends the standard AgentOutputSchema path
UC_CustomSchema ..> UC_OutputSchema : <<extend>>

' Schema resolution triggers strict constraint application (when strict=True)
UC_Resolve ..> UC_Strict : <<include>>

' Strict schema enforcement includes specific transformations
UC_Strict ..> UC_OneOf      : <<include>>
UC_Strict ..> UC_StripProps : <<include>>

' Resolved schema is formatted for the target LLM API
UC_Resolve ..> UC_Format : <<include>>

' Formatted schema is sent to the LLM
UC_Format ..> UC_LLMReceive : <<include>>

' LLM response triggers validation
UC_LLMReturn ..> UC_Validate : <<include>>

' Validation unwraps wrapped non-BaseModel types
UC_Validate ..> UC_Unwrap : <<extend>>

' Validation failure raises ModelBehaviorError
UC_Validate ..> UC_Error : <<extend>>

' Successful validation surfaces typed result
UC_Validate ..> UC_FinalOutput : <<include>>

' Plain-text path skips schema serialization entirely
UC_PlainText ..> UC_Resolve : <<extend>>

' ─────────────────────────────────────────────────
' Notes
' ─────────────────────────────────────────────────

note right of UC_Strict
  Strict mode (default=True):
  adds additionalProperties:false
  and makes all fields required —
  guarantees valid JSON from model.
end note

note right of UC_Unwrap
  Non-BaseModel / non-dict types are
  auto-wrapped in a TypedDict with key
  'response' during schema creation and
  unwrapped here after validation.
end note

note bottom of UC_CustomSchema
  Developers can bypass all auto-logic
  by subclassing AgentOutputSchemaBase
  and implementing is_plain_text(),
  json_schema(), and validate_json().
end note

note bottom of UC_FinalOutput
  final_output is typed Any —
  handoffs can change which agent
  runs last, so the SDK cannot
  statically know the output type.
end note

note right of UC_Error
  validate_json raises ModelBehaviorError
  (not Python TypeError) so callers can
  distinguish model misbehaviour from
  application errors.
end note

@enduml
