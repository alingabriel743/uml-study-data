@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam actor {
    BackgroundColor #DEE2E6
    BorderColor #495057
    FontColor #212529
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
}

left to right direction

title Testing Infrastructure and Fake Models

' ── Primary Actor ──────────────────────────────────────────────
actor "Test Author\n(pytest)" as TestAuthor

' ── External System Being Tested ───────────────────────────────
actor "Agents SDK\n(under test)" as AgentsSDK

' ══════════════════════════════════════════════════════════════
' SYSTEM BOUNDARY
' ══════════════════════════════════════════════════════════════
rectangle "Testing Infrastructure" {

    ' ── 1. Fake LLM Model ─────────────────────────────────────
    package "Fake LLM Model  (FakeModel / PromptCacheFakeModel)" {
        usecase "Configure Scripted\nTurn Outputs" as UC_SetOutput
        usecase "Run Agent with\nFake Responses" as UC_RunFake
        usecase "Assert on\nModel Inputs Received" as UC_AssertInputs
        usecase "Override Usage Stats\nfor Billing Tests" as UC_HardcodedUsage
        usecase "Stream Fake\nSSE Response Events" as UC_StreamResponse
        usecase "Test Prompt Cache\nKey Support" as UC_PromptCache
    }

    ' ── 2. Model Provider / Client Stubs ──────────────────────
    package "Model Provider & Client Stubs  (DummyProvider / DummyClient)" {
        usecase "Resolve Named Model\nvia DummyProvider" as UC_DummyProvider
        usecase "Override model_provider\non RunConfig" as UC_RunConfig
        usecase "Inject Controlled\nCompletions via DummyClient" as UC_DummyClient
    }

    ' ── 3. Tracing & Observability Testing ────────────────────
    package "Tracing & Observability  (SpanProcessorForTests / DummyTracing)" {
        usecase "Stub ModelTracing\nto Control Span Creation" as UC_DummyTracing
        usecase "Record Trace / Span\nLifecycle in Memory" as UC_RecordSpans
        usecase "Assert No Spans\nor Traces Emitted" as UC_AssertNoSpans
        usecase "Fetch Ordered\nor Normalized Spans" as UC_FetchSpans
        usecase "Clear Span Processor\nBefore Each Test" as UC_ClearSpans
    }

    ' ── 4. MCP Server Testing ─────────────────────────────────
    package "MCP Server Testing  (FakeMCPServer / _TestFilterServer)" {
        usecase "Simulate MCP Tool Server\nwith Scripted Results" as UC_FakeMCP
        usecase "Register & List\nTools on Fake MCP Server" as UC_MCPTools
        usecase "Apply Real Tool-Filter\nLogic without I/O" as UC_ToolFilter
        usecase "Return Fake MCP\nPrompts & Resources" as UC_MCPPrompts
    }

    ' ── 5. Voice Model Testing ────────────────────────────────
    package "Voice Model Testing  (FakeTTS / FakeSTT / FakeSession / FakeWorkflow)" {
        usecase "Fake TTS Returning\nZero-Byte Audio" as UC_FakeTTS
        usecase "Fake STT Returning\nPreconfigured Transcripts" as UC_FakeSTT
        usecase "Fake Streamed\nTranscription Session" as UC_FakeSession
        usecase "Fake Voice Workflow\nYielding Text Chunks" as UC_FakeWorkflow
        usecase "Build Synthetic\nStreamed Audio Input" as UC_AudioInput
    }

    ' ── 6. Test Fixtures & Guards (conftest) ──────────────────
    package "Test Fixtures & Guards  (conftest.py)" {
        usecase "Prevent Accidental\nReal Model API Calls" as UC_DisableReal
        usecase "Reset OpenAI Settings\nBetween Tests" as UC_ResetOpenAI
        usecase "Clear Default\nAgent Runner" as UC_ClearRunner
        usecase "Register Span Processor\nat Session Scope" as UC_RegisterProcessor
    }

}

' ── Include / Extend relationships ────────────────────────────
UC_RunFake .down.> UC_SetOutput : <<include>>
UC_StreamResponse .right.> UC_RunFake : <<extend>>
UC_PromptCache .up.> UC_RunFake : <<extend>>
UC_FetchSpans .down.> UC_RecordSpans : <<include>>
UC_AssertNoSpans .right.> UC_RecordSpans : <<include>>
UC_ToolFilter .up.> UC_FakeMCP : <<extend>>
UC_FakeSTT .down.> UC_FakeSession : <<include>>

' ── Test Author associations ───────────────────────────────────
TestAuthor --> UC_SetOutput
TestAuthor --> UC_RunFake
TestAuthor --> UC_AssertInputs
TestAuthor --> UC_HardcodedUsage
TestAuthor --> UC_StreamResponse
TestAuthor --> UC_PromptCache

TestAuthor --> UC_DummyProvider
TestAuthor --> UC_RunConfig
TestAuthor --> UC_DummyClient

TestAuthor --> UC_DummyTracing
TestAuthor --> UC_RecordSpans
TestAuthor --> UC_AssertNoSpans
TestAuthor --> UC_FetchSpans

TestAuthor --> UC_FakeMCP
TestAuthor --> UC_MCPTools
TestAuthor --> UC_MCPPrompts

TestAuthor --> UC_FakeTTS
TestAuthor --> UC_FakeSTT
TestAuthor --> UC_FakeWorkflow
TestAuthor --> UC_AudioInput

' ── Agents SDK associations (consumer of fake infrastructure) ──
AgentsSDK --> UC_RunFake
AgentsSDK --> UC_StreamResponse
AgentsSDK --> UC_DummyProvider
AgentsSDK --> UC_FakeMCP
AgentsSDK --> UC_FakeTTS
AgentsSDK --> UC_FakeSTT
AgentsSDK --> UC_FakeWorkflow

' ── Fixtures are automatically applied ─────────────────────────
TestAuthor --> UC_DisableReal
TestAuthor --> UC_ResetOpenAI
TestAuthor --> UC_ClearRunner
TestAuthor --> UC_RegisterProcessor
UC_ClearSpans .up.> UC_RegisterProcessor : <<include>>

' ── Notes ──────────────────────────────────────────────────────
note bottom of UC_SetOutput
  FakeModel.turn_outputs is a queue:
  pop(0) each call — supports
  multi-turn scripted scenarios
end note

note bottom of UC_DisableReal
  autouse fixture monkeypatches
  OpenAIResponsesModel.get_response /
  stream_response to raise unless
  @pytest.mark.allow_call_model_methods
end note

note right of UC_ToolFilter
  _TestFilterServer bridges FakeMCPServer
  to real _apply_tool_filter() logic
  with no real network I/O
end note

note bottom of UC_FetchSpans
  fetch_normalized_spans collapses
  'task' & 'turn' spans into parent
  for cleaner test assertions
end note

@enduml
