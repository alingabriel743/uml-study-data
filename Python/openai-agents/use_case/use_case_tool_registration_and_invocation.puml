@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}

skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7EC5
    FontColor #1A3A5C
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam ArrowColor #495057
skinparam ArrowFontSize 10

title Tool Registration and Invocation

left to right direction

' ─── Actors ───────────────────────────────────────────────────────────────────
actor "Developer" as dev
actor "Runner\n(Agent)" as runner
actor "LLM\n(OpenAI Model)" as llm
actor "Sandbox\nSession" as sandbox

' ─── System Boundary ──────────────────────────────────────────────────────────
rectangle "Tool Registration and Invocation" {

    ' == Tool Definition ==
    package "Tool Definition" {
        usecase "Define Function Tool\nvia @function_tool Decorator" as UC1
        note right of UC1
          Auto-extracts name, description
          (docstring), and params_json_schema
          via inspect + griffe + pydantic
        end note

        usecase "Create FunctionTool\nManually" as UC2
        note right of UC2
          Directly instantiate FunctionTool
          with on_invoke_tool: async
          Callable[[ToolContext, str], Any]
        end note

        usecase "Expose Agent as Tool\n(agent.as_tool)" as UC12
        note right of UC12
          Creates FunctionTool with
          _is_agent_tool=True; runs
          a nested Runner.run() on invoke
        end note
    }

    ' == Tool Organisation ==
    package "Tool Organisation" {
        usecase "Register Tools on Agent\n(Agent.tools=[...])" as UC3
        note right of UC3
          No separate ToolRegistry —
          Agent.tools list IS the registry.
          Accepts FunctionTool, hosted tools,
          ComputerTool, agent-as-tool.
        end note

        usecase "Group Tools into\nNamespace (tool_namespace)" as UC4
        note right of UC4
          Attaches _tool_namespace metadata.
          Required for ToolSearchTool
          deferred loading.
        end note

        usecase "Enable Deferred\nTool Loading" as UC5
        note right of UC5
          @function_tool(defer_loading=True)
          hides tool until ToolSearchTool
          loads it at runtime.
          OpenAI Responses models only.
        end note
    }

    ' == Tool Invocation ==
    package "Tool Invocation" {
        usecase "Invoke Tool\nDuring Agent Run" as UC6
        note bottom of UC6
          Runner resolves FunctionTool by
          qualified_name, checks is_enabled,
          checks needs_approval, then calls
          on_invoke_tool(ctx, json_args)
        end note

        usecase "Handle Tool Output\n(FunctionToolResult)" as UC7
        note right of UC7
          Wraps output (ToolOutputText |
          ToolOutputImage | ToolOutputFileContent
          | str | list) and feeds back to LLM
        end note

        usecase "View Image\nfrom Sandbox" as UC11
        note right of UC11
          ViewImageTool reads file via
          BaseSandboxSession, base64-encodes
          payload, returns ToolOutputImage.
          Max 10 MB; PNG/JPEG/GIF/WEBP/BMP/TIFF/SVG
        end note
    }

    ' == Error & Control Flow ==
    package "Error & Control Handling" {
        usecase "Handle Tool Errors\n(failure_error_function)" as UC8
        note right of UC8
          On exception: invoke
          failure_error_function(ctx, error)->str
          or re-raise if set to None
        end note

        usecase "Handle Tool Timeout\n(timeout_behavior)" as UC9
        note right of UC9
          'error_as_result': sends timeout
          message to LLM.
          'raise_exception': raises
          ToolTimeoutError. Async tools only.
        end note

        usecase "Approve or Reject\nTool Call" as UC10
        note right of UC10
          When needs_approval=True:
          run pauses; interruptions appear in
          RunResult. Developer calls
          state.approve() or state.reject().
        end note
    }
}

' ─── Developer Associations ───────────────────────────────────────────────────
dev --> UC1 : define via decorator
dev --> UC2 : define manually
dev --> UC3 : register tools
dev --> UC4 : group into namespace
dev --> UC5 : enable deferred loading
dev --> UC12 : expose agent as tool
dev --> UC10 : approve / reject

' ─── Runner (Agent) Associations ──────────────────────────────────────────────
runner --> UC6 : invoke tool
runner --> UC7 : handle output
runner --> UC8 : handle errors
runner --> UC9 : handle timeouts

' ─── LLM Associations ─────────────────────────────────────────────────────────
llm --> UC6 : emit tool_call\n(name + JSON args)

' ─── Sandbox Session Associations ─────────────────────────────────────────────
sandbox --> UC11 : provide file\nread access

' ─── Include / Extend Relationships ───────────────────────────────────────────
' Tool definition feeds into registration
UC1 ..> UC3 : <<include>>
UC2 ..> UC3 : <<include>>
UC12 ..> UC3 : <<include>>

' Deferred loading requires namespace grouping
UC5 ..> UC4 : <<include>>

' Core invocation flow
UC6 ..> UC7 : <<include>>

' Conditional extensions on invocation
UC8 ..> UC6 : <<extend>>\n(on exception)
UC9 ..> UC6 : <<extend>>\n(on timeout)
UC10 ..> UC6 : <<extend>>\n(needs_approval=True)

' Image output is a specialisation of tool output
UC11 ..> UC7 : <<extend>>\n(image output)

@enduml
