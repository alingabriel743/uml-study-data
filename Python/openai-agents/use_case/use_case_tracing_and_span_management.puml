@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #D0E8FF
    BorderColor #3A7BD5
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title Tracing and Span Management

left to right direction

' ── Actors ────────────────────────────────────────────────
actor "Developer" as Developer
actor "Runner" as Runner
actor "Agent" as Agent

actor "OpenAI Backend" as OpenAIBackend #D5F5E3
actor "Custom Exporter\n(W&B / Langfuse /\nMLflow / etc.)" as CustomExporter #D5F5E3

' ── System Boundary ───────────────────────────────────────
rectangle "Tracing and Span Management" {

    ' ── Trace Lifecycle ───────────────────────────────────
    package "Trace Lifecycle" {
        usecase "Create and Manage Trace\n(trace() / TraceImpl)" as UC01
        usecase "Reattach Resumed Trace\n(TraceCtxManager)" as UC11
        usecase "Disable Tracing\n(env var / set_tracing_disabled /\nRunConfig.tracing_disabled)" as UC10
    }

    ' ── Span Lifecycle ────────────────────────────────────
    package "Span Lifecycle" {
        usecase "Create Typed Span\n(agent_span / generation_span /\nfunction_span / guardrail_span /\nhandoff_span / custom_span /\ntranscription_span / speech_span)" as UC02
        usecase "Start and Finish\nSpan Lifecycle\n(SpanImpl.start / finish)" as UC03
        usecase "Record Span Error\n(span.set_error)" as UC04
    }

    ' ── Export Pipeline ───────────────────────────────────
    package "Export Pipeline" {
        usecase "Export Trace/Span Data\n(BatchTraceProcessor –\nbatches every 5s or\nwhen queue > 70% full)" as UC05
        usecase "Flush Traces Immediately\n(flush_traces)" as UC09
        usecase "Send Traces to\nOpenAI Backend\n(BackendSpanExporter –\nPOST /v1/traces/ingest)" as UC06
        usecase "Print Traces to Console\n(ConsoleSpanExporter)" as UC12
    }

    ' ── Processor Configuration ───────────────────────────
    package "Processor Configuration" {
        usecase "Register Additional\nTrace Processor\n(add_trace_processor)" as UC07
        usecase "Replace Default\nTrace Processors\n(set_trace_processors)" as UC08
    }
}

' ── Developer relationships ───────────────────────────────
Developer --> UC01 : creates trace manually\nor wraps workflow
Developer --> UC10 : disables tracing globally\nor per-run
Developer --> UC09 : flushes buffered traces\n(Celery / FastAPI workers)
Developer --> UC07 : adds secondary\nexport destination
Developer --> UC08 : replaces default\nprocessor pipeline
Developer --> UC12 : local debug console output

' ── Runner relationships ──────────────────────────────────
Runner --> UC01 : auto-wraps run() /\nrun_sync() / run_streamed()
Runner --> UC11 : reattaches resumed\ntrace across multi-turn runs
Runner --> UC02 : emits spans per\nagent loop turn

' ── Agent relationships ───────────────────────────────────
Agent --> UC02 : emits AgentSpanData\nGenerationSpanData\nFunctionSpanData\nHandoffSpanData\nGuardrailSpanData
Agent --> UC04 : attaches SpanError\non failure

' ── Internal include relationships ───────────────────────
UC02 ..> UC03 : <<include>>
UC01 ..> UC05 : <<include>>\n(on_trace_start enqueues)
UC03 ..> UC05 : <<include>>\n(on_span_end enqueues)
UC09 ..> UC05 : <<include>>\n(force_flush)
UC05 ..> UC06 : <<include>>\n(default exporter)
UC05 <.. UC07 : <<extend>>\n(adds processor)
UC05 <.. UC08 : <<extend>>\n(replaces processors)
UC05 <.. UC12 : <<extend>>\n(via BatchTraceProcessor\n+ ConsoleSpanExporter)
UC01 <.. UC10 : <<extend>>\n(returns NoOpTrace\nwhen disabled)

' ── External system relationships ─────────────────────────
UC06 --> OpenAIBackend : HTTP POST with\nBearer API key\n(retry on 5xx,\nno retry on 4xx)
UC07 --> CustomExporter : fan-out via\nSynchronousMultiTracingProcessor
UC08 --> CustomExporter : custom pipeline\n(no OpenAI unless configured)

' ── Notes ─────────────────────────────────────────────────
note bottom of UC05
  <b>BatchTraceProcessor</b>
  • Background daemon thread, lazy start
  • Queue capacity: 8 192 items (drops when full)
  • Triggers: every 5 s or queue > 70%
  • atexit handler calls provider.shutdown()
end note

note bottom of UC06
  <b>BackendSpanExporter</b>
  • Groups exports by tracing_api_key
  • Sanitizes fields > 100 KB before send
  • Exponential backoff: max 3 retries,
    base 1 s, max 30 s
  • ZDR orgs cannot use tracing
end note

note top of UC02
  <b>Span Data Types</b>
  AgentSpanData · TaskSpanData · TurnSpanData
  GenerationSpanData · ResponseSpanData
  FunctionSpanData · HandoffSpanData
  GuardrailSpanData · CustomSpanData
  TranscriptionSpanData · SpeechSpanData
  SpeechGroupSpanData · MCPListToolsSpanData
end note

note right of UC10
  <b>Sensitive Data Controls</b>
  RunConfig.trace_include_sensitive_data
  controls LLM I/O capture.
  VoicePipelineConfig.trace_include_sensitive_audio_data
  controls audio PCM capture.
end note

@enduml
