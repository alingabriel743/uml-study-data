@startuml

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #495057
    ArrowColor #495057
    FontColor #212529
}
skinparam package {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
}
skinparam actor {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
}
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #495057
    FontColor #212529
    ArrowColor #495057
}
skinparam rectangle {
    BackgroundColor #E9ECEF
    BorderColor #6C757D
    FontColor #212529
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontColor #212529
}

title Twilio Telephony Integration\n<size:11>//Twilio WebSocket bridge relays phone call audio to the agent realtime session//</size>

left to right direction

' ── External Actors ──────────────────────────────────────────────
actor "Caller\n(Phone User)" as Caller
actor "Twilio\nPlatform" as Twilio
actor "OpenAI\nRealtime API" as OpenAI

' ── System Boundary ──────────────────────────────────────────────
rectangle "Twilio Telephony Integration\n(FastAPI + uvicorn  •  port 8000)" {

    ' ── Call Setup ───────────────────────────────────────────────
    package "Call Setup" {
        usecase "Place Incoming\nPhone Call" as UC1
        usecase "Handle Incoming Call\n(Return TwiML)" as UC2
        usecase "Establish WebSocket\nMedia Stream" as UC3
        usecase "Start Realtime\nAgent Session" as UC4
    }

    ' ── Audio Relay ──────────────────────────────────────────────
    package "Audio Relay" {
        usecase "Relay Caller Audio\nto OpenAI" as UC5
        usecase "Buffer & Chunk\nAudio (50 ms)" as UC11
        usecase "Receive Agent\nAudio Response" as UC6
        usecase "Play Agent Audio\nto Caller" as UC7
    }

    ' ── Conversation Features ────────────────────────────────────
    package "Conversation Features" {
        usecase "Execute Function\nTools" as UC10
        usecase "Handle Audio\nInterruption" as UC8
        usecase "Track Audio\nPlayback Progress" as UC9
    }

    ' ── Call Teardown ────────────────────────────────────────────
    package "Call Teardown" {
        usecase "Terminate\nCall Session" as UC12
    }
}

' ── Actor → Use Case associations ────────────────────────────────
Caller  --> UC1
Caller  --> UC7

Twilio  --> UC2
Twilio  --> UC3
Twilio  --> UC7
Twilio  --> UC9
Twilio  --> UC12

OpenAI  --> UC6

' ── Internal flow associations (initiating subsystem as actor) ───
' TwilioWebSocketManager / TwilioHandler interactions
UC3     ..> UC4  : <<triggers>>
UC4     ..> UC5  : <<triggers>>
UC4     ..> UC6  : <<triggers>>

UC5     ..> UC11 : <<include>>
UC6     ..> UC9  : <<include>>
UC6     ..> UC8  : <<extend>>
UC10    ..> UC6  : <<extend>>

' ── Notes ────────────────────────────────────────────────────────
note bottom of UC2
  TwiML instructs Twilio to connect
  call audio to WebSocket /media-stream
end note

note right of UC5
  G.711 µ-law (mulaw) @ 8 kHz
  Startup warm-up: buffers first N chunks
  (default 3) before forwarding to OpenAI
end note

note right of UC4
  Model: gpt-realtime-1.5
  Format: g711_ulaw in/out
  Turn detection: semantic_vad
  interrupt_response: true
end note

note bottom of UC9
  Mark events correlate audio chunks
  to item_id / content_index for
  accurate interruption support
end note

note bottom of UC12
  Triggered by Twilio 'stop' event
  or WebSocket disconnect.
  active_handlers cleanup: TODO
end note

@enduml
